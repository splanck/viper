module openworld_slice;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind Zanna.Time.Clock as Clock;

class OpenWorldSlice {
    hide World3D world;
    hide Canvas3D canvas;
    hide Camera3D camera;
    hide WorldStream3D stream;
    hide Entity3D player;
    hide CharacterController3D character;
    hide FirstPersonController fps;
    hide Entity3D scoutA;
    hide Entity3D scoutB;
    hide Entity3D beacon;
    hide SceneTemplate skinnedTemplate;
    hide Entity3D skinnedAgent;
    hide Boolean skinnedIkBound;
    hide Entity3D glbFixtureProp;
    hide Boolean glbFixtureLoaded;
    hide Boolean audioFixtureLoaded;
    hide Entity3D asyncProp;
    hide AssetHandle3D asyncHandle;
    hide TextureAsset3D groundTexture;
    hide TextureAsset3D compressedTexture;
    hide Boolean asyncSpawned;
    hide NavMesh3D navmesh;
    hide NavAgent3D agentA;
    hide NavAgent3D agentB;
    hide Skeleton3D footIkSkeleton;
    hide AnimController3D footIkController;
    hide IKSolver3D footIkSolver;
    hide Entity3D footIkMarker;
    hide Entity3D footIkLegMarker;
    hide Integer footIkFootBone;
    hide Float footIkTargetX;
    hide Float footIkTargetY;
    hide Float footIkTargetZ;
    hide Boolean footIkBound;
    hide Entity3D compressedTexturePanel;
    hide Float sceneTime;

    expose func setup(title: String, width: Integer, height: Integer) {
        world = World3D.New(title, width, height);
        canvas = world.Canvas;
        camera = world.Camera;
        Canvas3D.SetMaxDeltaTime(canvas, 50);

        Quality.Apply(world, QualityLevel.get_Balanced());
        Lighting.Outdoor(world, Vec3.New(-0.35, -1.0, -0.25));
        PostFX.Crisp(world);
        var env: EnvHandle = Environment3D.Outdoor(world);
        env.WithFog(28.0, 420.0);
        env.WithWater(-0.08);
        world.SetAmbient(0.22, 0.25, 0.29);
        world.SetFog(0.025, 0.035, 0.045, 48.0, 520.0);
        camera.Yaw = -30.0;
        camera.Pitch = -12.0;

        stream = world.Stream;
        stream.SetRadii(360.0, 520.0);
        stream.SetCenter(Vec3.New(-1100.0, 0.0, -1100.0));
        stream.MountCells("assets/world/cells.vscn");
        stream.MountTiledTerrain("assets/world/terrain.vscn");
        settleStream(2);

        setupTextureAssets();
        spawnBaseScene();
        setupTerrainFootIkProof();
        setupPlayer();
        setupNavAgents();
        setupSkinnedAgent();
        setupFixtureAssets();
        asyncHandle = Assets3D.LoadEntityAssetAsync("assets/models/triangle.gltf");
        asyncSpawned = false;
        completeAsyncAsset();
        sceneTime = 0.0;
    }

    expose func getWorld() -> World3D {
        return world;
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func getCharacter() -> CharacterController3D {
        return character;
    }

    expose func getStream() -> WorldStream3D {
        return stream;
    }

    expose func getResidentCellCount() -> Integer {
        return stream.ResidentCellCount;
    }

    expose func getResidentTerrainTileCount() -> Integer {
        return stream.ResidentTerrainTileCount;
    }

    expose func getResidentBytes() -> Integer {
        return stream.ResidentBytes;
    }

    expose func getResidentTileHeight() -> Float {
        var tile = stream.GetResidentTerrainTile(0);
        if (tile == null) { return -99999.0; }
        return Terrain3D.GetHeightAt(tile, 0.0, 0.0);
    }

    expose func asyncAssetSpawned() -> Boolean {
        completeAsyncAsset();
        return asyncSpawned;
    }

    expose func textureAssetsReady() -> Boolean {
        return TextureAsset3D.get_Width(groundTexture) == 2 &&
               TextureAsset3D.get_Height(groundTexture) == 2 &&
               TextureAsset3D.get_ResidentBytes(groundTexture) == 16 &&
               TextureAsset3D.get_Compressed(compressedTexture) &&
               TextureAsset3D.get_Format(compressedTexture) == "bc7" &&
               TextureAsset3D.get_ResidentBytes(compressedTexture) == 16 &&
               compressedTexturePanel != null &&
               hasNode("NativeCompressedTexturePanel");
    }

    expose func skinnedCharacterReady() -> Boolean {
        if (skinnedAgent == null) { return false; }
        var anim = skinnedAgent.Anim;
        if (anim == null) { return false; }
        return anim.IsPlaying("Wave") &&
               anim.StateTime() > 0.0 &&
               skinnedIkBound &&
               hasNode("SkinnedAgentMeshNode");
    }

    expose func fixtureAssetsReady() -> Boolean {
        return glbFixtureLoaded &&
               audioFixtureLoaded &&
               glbFixtureProp != null &&
               world.FindEntity("FixtureGLBTriangle").IsSome &&
               hasNode("GlbTriangle");
    }

    expose func terrainFootIkReady() -> Boolean {
        if (footIkBound == false || footIkController == null || footIkFootBone < 0) {
            return false;
        }
        var footMat = AnimController3D.GetBoneMatrix(footIkController, footIkFootBone);
        if (footMat == null) { return false; }
        return footIkMarker != null &&
               footIkLegMarker != null &&
               hasNode("TerrainFootIkMarker") &&
               hasNode("TerrainFootIkLegMarker") &&
               nearFloat(Mat4.Get(footMat, 0, 3), footIkTargetX, 0.06) &&
               nearFloat(Mat4.Get(footMat, 1, 3), footIkTargetY, 0.06) &&
               nearFloat(Mat4.Get(footMat, 2, 3), footIkTargetZ, 0.06);
    }

    expose func navmeshIncludesStreamedTerrain() -> Boolean {
        if (navmesh == null || NavMesh3D.get_TriangleCount(navmesh) <= 32) {
            return false;
        }
        var snapped = NavMesh3D.SamplePosition(navmesh, Vec3.New(-1500.0, 8.0, -1500.0));
        if (snapped == null) { return false; }
        return nearFloat(Vec3.get_X(snapped), -1500.0, 1.0) &&
               nearFloat(Vec3.get_Z(snapped), -1500.0, 1.0);
    }

    expose func hasNode(name: String) -> Boolean {
        return world.FindNode(name).IsSome;
    }

    expose func setStreamCenter(x: Float, z: Float) {
        stream.SetCenter(Vec3.New(x, 0.0, z));
        settleStream(4);
    }

    expose func stepFixed(dt: Float) {
        sceneTime = sceneTime + dt;
        completeAsyncAsset();
        NavAgent3D.Update(agentA, dt);
        NavAgent3D.Update(agentB, dt);
        stream.SetCenter(player.Position);
        stream.Update(dt);
        world.RunFramesOnly(1, dt);
    }

    expose func renderFrame() {
        beacon.SetRotationEuler(0.0, sceneTime * 38.0, 0.0);

        world.BeginFrame();
        world.DrawScene();
        world.DrawEffects();
        world.EndScene();

        Canvas3D.BeginOverlay(canvas);
        Canvas3D.DrawRect2D(canvas, 10, 10, 214, 42, 0x111821);
        Canvas3D.DrawRect2D(canvas, 10, 10, 214, 3, 0x00E8FF);
        Canvas3D.DrawText2D(canvas, 22, 24, "OPEN_WORLD_SLICE", 0xFFFFFF);
        Canvas3D.DrawRect2D(canvas, canvas.Width - 48, canvas.Height - 48,
                            32, 32, 0x00E8FF);
        Canvas3D.DrawRect2D(canvas, canvas.Width - 40, canvas.Height - 40,
                            16, 16, 0x101722);
        Canvas3D.EndOverlay(canvas);
    }

    expose func replayMetric() -> Float {
        var a = scoutA.Position;
        var b = scoutB.Position;
        var p = player.Position;
        return Vec3.get_X(a) + Vec3.get_Z(a) + Vec3.get_X(b) + Vec3.get_Z(b) +
               Vec3.get_X(p) + Vec3.get_Z(p);
    }

    expose func run() {
        fps.CaptureMouse();
        while (world.Update()) {
            var dt = world.DeltaTime;
            if (dt <= 0.0) { dt = 0.016; }
            if (dt > 0.050) { dt = 0.050; }
            stepFixed(dt);
            renderFrame();
            world.Present();
        }
        fps.ReleaseMouse();
    }

    expose func destroy() {
        world.Destroy();
    }

    hide func setupTextureAssets() {
        groundTexture = TextureAsset3D.LoadKtx2Asset("assets/textures/checker_rgba8.ktx2");
        TextureAsset3D.SetResidentMipRange(groundTexture, 0, 1);
        compressedTexture = TextureAsset3D.LoadKtx2Asset("assets/textures/marker_bc7.ktx2");
        TextureAsset3D.SetResidentMipRange(compressedTexture, 0, 1);
    }

    hide func settleStream(frames: Integer) {
        var i = 0;
        while (i < frames) {
            stream.Update(1.0 / 60.0);
            i = i + 1;
        }
        // Worker-backed streaming stages payloads off-thread: keep updating until
        // the pending set drains so callers still observe settled residency.
        var spins = 0;
        while (stream.PendingRequestCount > 0 && spins < 2000) {
            stream.Update(1.0 / 60.0);
            if (spins % 8 == 0) { Clock.Sleep(1); }
            spins = spins + 1;
        }
    }

    hide func spawnBaseScene() {
        var groundMat = Materials.Rubber(0.22, 0.34, 0.25);
        Material3D.SetAlbedoMap(groundMat, groundTexture);
        var ground: Entity3D = Prefab.Ground(48.0, groundMat);
        ground.Name = "SliceGround";
        ground.SetPosition(-1100.0, 0.0, -1100.0);
        ground.AttachBody(BodyDef.StaticPlane(48.0));
        world.Spawn(ground);

        var compressedMat = Material3D.PBR(1.0, 1.0, 1.0);
        Material3D.SetAlbedoMap(compressedMat, compressedTexture);
        compressedTexturePanel = Prefab.BoxXYZ(1.25, 1.25, 0.10, compressedMat);
        compressedTexturePanel.Name = "NativeCompressedTexturePanel";
        compressedTexturePanel.SetPosition(-1102.15, 0.95, -1098.75);
        world.Spawn(compressedTexturePanel);

        var crate: Entity3D = Prefab.BoxXYZ(1.2, 0.9, 1.2, Materials.Metal(0.58, 0.61, 0.63));
        crate.Name = "SliceCrate";
        crate.SetPosition(-1101.6, 0.45, -1100.8);
        crate.AttachBody(BodyDef.StaticBox(0.6, 0.45, 0.6));
        world.Spawn(crate);

        beacon = Prefab.BoxXYZ(0.42, 0.42, 0.42, Materials.Emissive(0.12, 0.72, 1.0, 1.6));
        beacon.Name = "SliceBeacon";
        beacon.SetPosition(-1098.3, 1.1, -1101.2);
        world.Spawn(beacon);

        var ball: Entity3D = Prefab.Sphere(0.42, 18, Materials.Plastic(0.92, 0.24, 0.16));
        ball.Name = "SlicePhysicsBall";
        ball.SetPosition(-1099.7, 0.55, -1099.9);
        var ballBody = BodyDef.Sphere(0.42, 1.0);
        ballBody.Restitution = 0.25;
        ballBody.WithMask(LayerMask.Of(Layers.get_World()));
        ball.AttachBody(ballBody);
        world.Spawn(ball);
        ball.ApplyImpulse(0.8, 1.6, 0.2);
    }

    hide func setupTerrainFootIkProof() {
        footIkBound = false;
        footIkMarker = null;
        footIkLegMarker = null;
        footIkFootBone = -1;
        var tile = stream.GetResidentTerrainTile(0);
        if (tile == null) { return; }
        var center = stream.GetTerrainTileCenter(0);
        if (center == null) { return; }
        var localFootX = -2.30;
        var localFootZ = 1.30;
        var groundY = Terrain3D.GetHeightAt(tile, localFootX, localFootZ);
        footIkTargetX = Vec3.get_X(center) + localFootX;
        footIkTargetY = groundY + 0.05;
        footIkTargetZ = Vec3.get_Z(center) + localFootZ;

        footIkSkeleton = Skeleton3D.New();
        var hip = Skeleton3D.AddBone(footIkSkeleton, "FootIkHip", -1,
                                     Mat4.Translate(footIkTargetX - 0.90, groundY + 1.20, footIkTargetZ));
        var knee = Skeleton3D.AddBone(footIkSkeleton, "FootIkKnee", hip,
                                      Mat4.Translate(0.45, -0.65, 0.0));
        footIkFootBone = Skeleton3D.AddBone(footIkSkeleton, "FootIkFoot", knee,
                                            Mat4.Translate(0.45, -0.65, 0.0));
        Skeleton3D.ComputeInverseBind(footIkSkeleton);

        footIkController = AnimController3D.New(footIkSkeleton);
        footIkSolver = IKSolver3D.TwoBone(footIkSkeleton, hip, knee, footIkFootBone);
        if (footIkSolver == null) { return; }
        IKSolver3D.SetTarget(footIkSolver, Vec3.New(footIkTargetX, footIkTargetY, footIkTargetZ));
        IKSolver3D.SetWeight(footIkSolver, 1.0);
        IKSolver3D.Solve(footIkSolver);
        footIkBound = AnimController3D.SetIKSolver(footIkController, footIkSolver);

        footIkMarker = Prefab.Sphere(0.16, 12, Materials.Emissive(0.08, 0.95, 0.62, 1.4));
        footIkMarker.Name = "TerrainFootIkMarker";
        footIkMarker.SetPosition(footIkTargetX, 0.32, footIkTargetZ);
        world.Spawn(footIkMarker);

        footIkLegMarker = Prefab.BoxXYZ(0.12, 0.92, 0.12, Materials.Plastic(0.12, 0.64, 0.50));
        footIkLegMarker.Name = "TerrainFootIkLegMarker";
        footIkLegMarker.SetPosition(footIkTargetX + 0.20, 0.76, footIkTargetZ + 0.08);
        world.Spawn(footIkLegMarker);
    }

    hide func setupPlayer() {
        player = Entity3D.New();
        player.Name = "SlicePlayer";
        player.Layer = Layers.get_Player();
        player.SetPosition(-1100.0, 1.0, -1094.5);
        world.Spawn(player);

        character = CharacterController3D.New(world, player, 0.32, 1.8, 70.0);
        character.Speed = 3.0;

        fps = FirstPersonController.New(world);
        fps.Character = character;
        fps.Speed = 3.0;
        fps.ReleaseMouse();
        world.SetCameraController(fps);
    }

    hide func setupNavAgents() {
        navmesh = world.BakeNavMesh(0.35, 1.8, 45.0, 0.3);

        scoutA = Prefab.BoxXYZ(0.35, 0.70, 0.35, Materials.Plastic(0.12, 0.42, 0.92));
        scoutA.Name = "ScoutA";
        scoutA.SetPosition(-1101.6, 0.35, -1098.6);
        world.Spawn(scoutA);

        scoutB = Prefab.BoxXYZ(0.35, 0.70, 0.35, Materials.Plastic(0.92, 0.64, 0.18));
        scoutB.Name = "ScoutB";
        scoutB.SetPosition(-1098.4, 0.35, -1098.6);
        world.Spawn(scoutB);

        agentA = NavAgent3D.New(navmesh, 0.35, 1.8);
        agentB = NavAgent3D.New(navmesh, 0.35, 1.8);
        NavAgent3D.BindNode(agentA, scoutA.Node);
        NavAgent3D.BindNode(agentB, scoutB.Node);
        NavAgent3D.set_DesiredSpeed(agentA, 1.7);
        NavAgent3D.set_DesiredSpeed(agentB, 1.5);
        NavAgent3D.set_StoppingDistance(agentA, 0.05);
        NavAgent3D.set_StoppingDistance(agentB, 0.05);
        NavAgent3D.set_AvoidanceEnabled(agentA, true);
        NavAgent3D.set_AvoidanceEnabled(agentB, true);
        NavAgent3D.set_AvoidanceRadius(agentA, 0.75);
        NavAgent3D.set_AvoidanceRadius(agentB, 0.75);
        NavAgent3D.Warp(agentA, Vec3.New(-1101.6, 0.0, -1098.6));
        NavAgent3D.Warp(agentB, Vec3.New(-1098.4, 0.0, -1098.6));
        NavAgent3D.SetTarget(agentA, Vec3.New(-1098.4, 0.0, -1101.4));
        NavAgent3D.SetTarget(agentB, Vec3.New(-1101.6, 0.0, -1101.4));
    }

    hide func setupSkinnedAgent() {
        skinnedIkBound = false;
        skinnedTemplate = Prefab.LoadAsset("assets/models/skinned_agent.gltf");
        if (skinnedTemplate == null) { return; }
        skinnedAgent = skinnedTemplate.Instantiate();
        if (skinnedAgent == null) { return; }
        skinnedAgent.Name = "SkinnedAgent";
        skinnedAgent.SetPosition(-1099.2, 0.32, -1098.0);
        skinnedAgent.SetScale(0.85);
        world.Spawn(skinnedAgent);

        var anim = skinnedAgent.Anim;
        if (anim != null) {
            anim.Crossfade("Wave", 0.08);
            var model = skinnedTemplate.Model;
            if (model != null) {
                var skeleton = SceneAsset.GetSkeleton(model, 0);
                var solver = IKSolver3D.LookAt(skeleton, 0);
                if (solver != null) {
                    IKSolver3D.SetTarget(solver, Vec3.New(0.35, 0.65, 1.0));
                    IKSolver3D.SetWeight(solver, 0.35);
                    skinnedIkBound = anim.SetIKSolver(solver);
                }
            }
        }
    }

    hide func setupFixtureAssets() {
        glbFixtureLoaded = false;
        audioFixtureLoaded = false;

        glbFixtureProp = Assets3D.LoadEntityAsset("assets/models/triangle.glb");
        if (glbFixtureProp != null) {
            glbFixtureProp.Name = "FixtureGLBTriangle";
            glbFixtureProp.SetPosition(-1097.0, 0.12, -1100.6);
            glbFixtureProp.SetScale(0.75);
            world.Spawn(glbFixtureProp);
            glbFixtureLoaded = hasNode("GlbTriangle");
        }

        var audio = world.Audio;
        if (audio == null) { return; }
        var clip = audio.LoadAsset("assets/audio/jump.wav");
        audioFixtureLoaded = clip != null;
        if (clip != null) {
            var source = audio.PlayAt(clip, Vec3.New(-1097.0, 0.6, -1100.6));
            if (source != null) {
                audio.ClearSources();
            }
        }
    }

    hide func completeAsyncAsset() {
        if (asyncSpawned || asyncHandle == null) { return; }
        if (asyncHandle.IsReady == false) { return; }
        asyncProp = asyncHandle.GetEntity();
        if (asyncProp == null) { return; }
        asyncProp.Name = "AsyncTriangle";
        Entity3D.SetPosition(asyncProp, -1097.5, 0.08, -1098.8);
        Entity3D.SetScale(asyncProp, 0.85);
        world.Spawn(asyncProp);
        asyncSpawned = true;
    }

    hide func nearFloat(a: Float, b: Float, eps: Float) -> Boolean {
        var d = a - b;
        if (d < 0.0) { d = 0.0 - d; }
        return d <= eps;
    }
}

func start() {
    var game = new OpenWorldSlice();
    game.setup("Zanna Open World Slice", 960, 540);
    game.run();
    game.destroy();
    Terminal.Say("RESULT: ok");
}
