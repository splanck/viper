module walk_min;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind Zanna.Input.Key as Key;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;

class WalkMinGame {
    hide World3D world;
    hide Canvas3D canvas;
    hide Camera3D camera;
    hide Mesh3D groundMesh;
    hide Mesh3D boxMesh;
    hide Mesh3D sphereMesh;
    hide Mesh3D cylinderMesh;
    hide Material3D groundMat;
    hide Material3D crateMat;
    hide Material3D orbMat;
    hide Material3D columnMat;
    hide Material3D markerMat;
    hide PostFX3D postfx;
    hide Entity3D groundEntity;
    hide Entity3D crateEntity;
    hide Entity3D orbEntity;
    hide Entity3D columnEntity;
    hide Entity3D markerEntity;
    hide Entity3D playerEntity;
    hide CharacterController3D character;
    hide FirstPersonController fps;
    hide Float sceneTime;
    hide Boolean quitRequested;

    expose func setup(title: String, width: Integer, height: Integer) {
        world = World3D.New(title, width, height);
        canvas = world.Canvas;
        camera = world.Camera;
        Canvas3D.SetMaxDeltaTime(canvas, 50);

        world.SetFog(0.025, 0.035, 0.050, 16.0, 42.0);
        world.SetAmbient(0.24, 0.26, 0.30);
        world.SetQuality(QualityLevel.get_Balanced());

        camera.Yaw = -30.6;
        camera.Pitch = -14.3;

        groundMesh = Mesh3D.Plane(18.0, 18.0);
        boxMesh = Mesh3D.Box(1.0, 1.0, 1.0);
        sphereMesh = Mesh3D.Sphere(0.55, 22);
        cylinderMesh = Mesh3D.Cylinder(0.36, 1.35, 18);

        groundMat = Material3D.FromColor(0.24, 0.36, 0.30);
        groundMat.Roughness = 0.82;

        crateMat = Material3D.FromColor(0.72, 0.34, 0.18);
        crateMat.Roughness = 0.58;
        Material3D.SetShininess(crateMat, 36.0);

        orbMat = Material3D.FromColor(0.08, 0.42, 0.94);
        Material3D.SetEmissiveColor(orbMat, 0.02, 0.14, 0.52);
        orbMat.EmissiveIntensity = 0.75;
        orbMat.Roughness = 0.34;

        columnMat = Material3D.FromColor(0.78, 0.70, 0.52);
        columnMat.Roughness = 0.46;

        markerMat = Material3D.FromColor(1.0, 0.82, 0.28);
        Material3D.SetEmissiveColor(markerMat, 0.35, 0.20, 0.02);
        markerMat.EmissiveIntensity = 1.1;

        postfx = PostFX3D.New();
        PostFX3D.AddTonemap(postfx, 1, 1.14);
        PostFX3D.AddBloom(postfx, 0.78, 0.18, 2);
        PostFX3D.AddColorGrade(postfx, 0.015, 1.08, 1.06);
        PostFX3D.AddVignette(postfx, 0.72, 0.14);
        Canvas3D.SetPostFX(canvas, postfx);

        groundEntity = spawnProp("Ground", groundMesh, groundMat, 0.0, 0.0, 0.0, 1.0);
        crateEntity = spawnProp("Crate", boxMesh, crateMat, -1.22, 0.55, 0.16, 1.10);
        orbEntity = spawnProp("Orb", sphereMesh, orbMat, 1.25, 0.72, -0.78, 1.0);
        columnEntity = spawnProp("Column", cylinderMesh, columnMat, 0.22, 0.68, 1.42, 1.0);
        markerEntity = spawnProp("Marker", boxMesh, markerMat, 0.22, 1.55, 1.42, 0.26);

        spawnStaticBox("GroundCollider", 9.0, 0.10, 9.0, 0.0, -0.10, 0.0);
        spawnStaticBox("CrateCollider", 0.62, 0.55, 0.62, -1.22, 0.55, 0.16);
        spawnStaticBox("ColumnCollider", 0.40, 0.70, 0.40, 0.22, 0.68, 1.42);

        playerEntity = Entity3D.New();
        playerEntity.Name = "Player";
        playerEntity.Layer = Layers.get_Player();
        playerEntity.SetPosition(3.2, 1.0, 5.4);
        world.Spawn(playerEntity);

        character = CharacterController3D.New(world, playerEntity, 0.32, 1.8, 70.0);
        character.Speed = 3.2;

        fps = FirstPersonController.New(world);
        fps.Character = character;
        fps.Speed = 3.2;
        fps.LookSensitivity = 0.17;
        fps.ReleaseMouse();
        world.SetCameraController(fps);

        world.StepSimulation(0.016);

        sceneTime = 0.0;
        quitRequested = false;
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func getWorld() -> World3D {
        return world;
    }

    expose func getPlayer() -> Entity3D {
        return playerEntity;
    }

    expose func getCharacter() -> CharacterController3D {
        return character;
    }

    expose func step(dt: Float) {
        sceneTime = sceneTime + dt;

        var input = world.Input;
        if (input.Pressed(Key.Escape)) {
            quitRequested = true;
            return;
        }

        var speed = 3.2;
        if (input.IsDown(Key.LeftShift)) {
            speed = 5.2;
        }
        fps.Speed = speed;

        world.StepSimulation(dt);
    }

    expose func renderFrame() {
        updateAnimatedProps();

        world.BeginFrame();
        world.DrawScene();
        world.DrawEffects();
        world.EndScene();

        Canvas3D.BeginOverlay(canvas);
        drawFinalOverlay();
        Canvas3D.EndOverlay(canvas);
    }

    expose func run() {
        fps.CaptureMouse();

        while (quitRequested == false && world.Update()) {
            var dt = world.DeltaTime;
            if (dt <= 0.0) { dt = 0.016; }
            if (dt > 0.050) { dt = 0.050; }

            step(dt);
            renderFrame();
            world.Present();
        }

        fps.ReleaseMouse();
    }

    expose func destroy() {
        world.Destroy();
    }

    hide func spawnProp(
        name: String,
        mesh: Mesh3D,
        material: Material3D,
        x: Float,
        y: Float,
        z: Float,
        scale: Float) -> Entity3D {
        var entity = Entity3D.Of(mesh, material);
        entity.Name = name;
        entity.SetPosition(x, y, z);
        entity.SetScale(scale);
        world.Spawn(entity);
        return entity;
    }

    hide func spawnStaticBox(
        name: String,
        halfX: Float,
        halfY: Float,
        halfZ: Float,
        x: Float,
        y: Float,
        z: Float) {
        var body = PhysicsBody3D.NewAABB(halfX, halfY, halfZ, 0.0);
        var entity = Entity3D.New();
        entity.Name = name;
        entity.Layer = Layers.get_World();
        entity.AttachBody(body);
        entity.SetPosition(x, y, z);
        world.Spawn(entity);
    }

    hide func updateAnimatedProps() {
        var orbBob = 0.09 * Sin(sceneTime * 2.2);
        orbEntity.SetPosition(1.25, 0.72 + orbBob, -0.78);

        markerEntity.SetPosition(0.22, 1.55, 1.42);
        markerEntity.SetRotationEuler(0.0, sceneTime * 42.9718, 0.0);
        markerEntity.SetScale(0.26);
    }

    hide func drawFinalOverlay() {
        var w = canvas.Width;
        var h = canvas.Height;

        Canvas3D.DrawRect2D(canvas, 12, 12, 280, 54, 0x101722);
        Canvas3D.DrawRect2D(canvas, 12, 12, 280, 3, 0x00E8FF);
        Canvas3D.DrawText2D(canvas, 24, 26, "WALK_MIN", 0xFFFFFF);
        Canvas3D.DrawText2D(canvas, 104, 26, "WASD walk  mouse look  SPACE jump", 0xC6D6E8);

        Canvas3D.DrawRect2D(canvas, w - 54, h - 54, 38, 38, 0x00E8FF);
        Canvas3D.DrawRect2D(canvas, w - 48, h - 48, 26, 26, 0x101722);
        Canvas3D.DrawRect2D(canvas, w - 42, h - 42, 14, 14, 0x00E8FF);
    }
}

func start() {
    var game = new WalkMinGame();
    game.setup("Zanna Walk Min", 960, 540);
    game.run();
    game.destroy();
    Terminal.Say("RESULT: ok");
}
