module HttpReqDemo;
bind Zanna.Terminal;

func start() {
    Say("=== API Audit: Zanna.Network.HttpReq ===");
    Say("NOTE: HttpReq requires network access to Send/SendResult. API surface test only.");
    Say("Methods: New(method,url), SetHeader(key,val), SetBody(bytes), SetBodyStr(str), SetTimeout(ms), Send() -> HttpRes, SendResult() -> Result<HttpRes>");
    Say("=== HttpReq Audit Complete (API surface only) ===");
}
