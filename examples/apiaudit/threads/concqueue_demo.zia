// =============================================================================
// API Audit: Zanna.Threads.ConcurrentQueue
// =============================================================================
// Tests: New, Enqueue, TryDequeueOption, Dequeue, Peek, Len, IsEmpty, Clear
// =============================================================================

module ConcQueueDemo;
bind Zanna.Threads.ConcurrentQueue as CQ;
bind Zanna.Core.Box as Box;
bind Zanna.Terminal;
bind Zanna.Text.Fmt as Fmt;

func start() {
    Say("=== API Audit: Zanna.Threads.ConcurrentQueue ===");

    // --- New ---
    Say("--- New ---");
    var q = CQ.New();
    Say("Created queue");

    // --- IsEmpty (initial) ---
    Say("--- IsEmpty (initial) ---");
    Say("IsEmpty: " + Fmt.Bool(q.get_IsEmpty()));

    // --- Len (initial) ---
    Say("--- Len (initial) ---");
    Say("Len: " + Fmt.Int(q.get_Count()));

    // --- Enqueue ---
    Say("--- Enqueue ---");
    q.Push(Box.Str("alpha"));
    q.Push(Box.Str("beta"));
    q.Push(Box.Str("gamma"));
    Say("Enqueued 3 items");

    // --- Len (after enqueue) ---
    Say("--- Len (after enqueue) ---");
    Say("Len: " + Fmt.Int(q.get_Count()));

    // --- IsEmpty (after enqueue) ---
    Say("--- IsEmpty (after enqueue) ---");
    Say("IsEmpty: " + Fmt.Bool(q.get_IsEmpty()));

    // --- Peek ---
    Say("--- Peek ---");
    var front = q.Peek();
    Say("Peek: " + Box.ToStr(front));

    // --- TryDequeueOption ---
    Say("--- TryDequeueOption ---");
    var item1 = q.TryPop();
    Say("TryDequeueOption: " + Box.ToStr(item1.Unwrap()));
    Say("Len after TryDequeueOption: " + Fmt.Int(q.get_Count()));

    // --- Dequeue (blocking, but queue has items) ---
    Say("--- Dequeue ---");
    var item2 = q.Pop();
    Say("Dequeue: " + Box.ToStr(item2));
    Say("Len after Dequeue: " + Fmt.Int(q.get_Count()));

    // --- TryDequeueOption remaining ---
    Say("--- TryDequeueOption remaining ---");
    var item3 = q.TryPop();
    Say("TryDequeueOption: " + Box.ToStr(item3.Unwrap()));

    // --- TryDequeueOption on empty ---
    Say("--- TryDequeueOption on empty ---");
    var item4 = q.TryPop();
    Say("TryDequeueOption (empty): " + Fmt.Bool(item4.IsNone));

    // --- Enqueue more and Clear ---
    Say("--- Clear ---");
    q.Push(Box.I64(10));
    q.Push(Box.I64(20));
    q.Push(Box.I64(30));
    Say("Len before Clear: " + Fmt.Int(q.get_Count()));
    q.Clear();
    Say("Len after Clear: " + Fmt.Int(q.get_Count()));
    Say("IsEmpty after Clear: " + Fmt.Bool(q.get_IsEmpty()));

    Say("=== ConcurrentQueue Audit Complete ===");
}
