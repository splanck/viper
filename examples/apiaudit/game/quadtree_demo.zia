// quadtree_demo.zia - Comprehensive API audit for Zanna.Game.Quadtree
// Tests: New, Insert, Remove, Update, QueryRectResult, QueryPointResult,
//        QueryPairs, QueryResult, QuadtreePairResult, ItemCount, Clear

module QuadtreeDemo;

bind Zanna.Game;
bind Zanna.Terminal;

func start() {
    Say("=== Quadtree API Audit ===");

    // --- New (x, y, width, height) ---
    Say("--- New ---");
    var qt = Quadtree.New(0, 0, 800, 600);
    SayInt(qt.ItemCount);       // 0

    // --- Insert (id, x, y, w, h) ---
    Say("--- Insert ---");
    var ok1 = qt.Insert(1, 10, 10, 20, 20);
    SayBool(ok1);               // 1
    SayInt(qt.ItemCount);       // 1

    var ok2 = qt.Insert(2, 100, 100, 30, 30);
    SayBool(ok2);               // 1
    SayInt(qt.ItemCount);       // 2

    var ok3 = qt.Insert(3, 50, 50, 15, 15);
    SayBool(ok3);               // 1
    SayInt(qt.ItemCount);       // 3

    // --- QueryRectResult (x, y, w, h) -> QueryResult ---
    Say("--- QueryRectResult ---");
    var result = qt.QueryRect(0, 0, 200, 200);
    SayInt(result.Count);       // 3 (all items in range)
    SayBool(result.Contains(1));
    var r0 = result.GetId(0);
    SayInt(r0);
    // r0 should be one of the inserted IDs (1, 2, or 3)

    // --- QueryRectResult (narrow region) ---
    Say("--- QueryRectResult narrow ---");
    var result2 = qt.QueryRect(0, 0, 40, 40);
    SayInt(result2.Count);      // 1 (only item 1 at 10,10,20,20)

    // --- QueryPointResult (x, y, radius) ---
    Say("--- QueryPointResult ---");
    var pFound = qt.QueryPoint(15, 15, 10);
    SayInt(pFound.Count);
    // Should find item 1 near point (15,15)

    // --- Update (id, x, y, w, h) ---
    Say("--- Update ---");
    var upd = qt.Update(1, 400, 400, 20, 20);
    SayBool(upd);               // 1 (moved item 1)
    SayInt(qt.ItemCount);       // 3 (same count)

    // --- QueryRect after move ---
    Say("--- QueryRect after move ---");
    var found3 = qt.QueryRect(0, 0, 40, 40);
    SayInt(found3.Count);       // 0 (item 1 moved away)

    var found4 = qt.QueryRect(390, 390, 30, 30);
    SayInt(found4.Count);       // 1 (item 1 now here)

    // --- Remove ---
    Say("--- Remove ---");
    var rem = qt.Remove(2);
    SayBool(rem);               // 1
    SayInt(qt.ItemCount);       // 2

    // --- Remove nonexistent ---
    Say("--- Remove nonexistent ---");
    var rem2 = qt.Remove(999);
    SayBool(rem2);              // 0

    // --- QueryPairs / PairResult ---
    Say("--- QueryPairs ---");
    // Insert overlapping items
    qt.Insert(10, 200, 200, 50, 50);
    qt.Insert(11, 210, 210, 50, 50);
    var pairs = qt.QueryPairs();
    SayInt(pairs.Count);        // >= 1 (overlapping pair)

    if pairs.Count > 0 {
        var pf = pairs.First(0);
        var ps = pairs.Second(0);
        SayInt(pf);
        SayInt(ps);
        // pf and ps should be IDs of overlapping items
    }

    // --- Clear ---
    Say("--- Clear ---");
    qt.Clear();
    SayInt(qt.ItemCount);       // 0
    var found5 = qt.QueryRect(0, 0, 800, 600);
    SayInt(found5.Count);       // 0

    Say("=== Quadtree audit complete ===");
}
