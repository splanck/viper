// =============================================================================
// API Audit: Viper.Data.Yaml - YAML Processing
// =============================================================================
// Tests: ParseResult, Parse, Error, IsValid, Format, FormatIndent, TypeOf
// =============================================================================

module YamlDemo;
bind Viper.Terminal;
bind Viper.Data.Yaml as Yaml;
func start() {
    Say("=== API Audit: Viper.Data.Yaml ===");

    // --- IsValid ---
    Say("--- IsValid ---");
    Say("IsValid('name: test'):");
    SayBool(Yaml.IsValid("name: test\nage: 30\n"));
    Say("IsValid('key: value'):");
    SayBool(Yaml.IsValid("key: value"));

    // --- ParseResult ---
    Say("--- ParseResult ---");
    var yamlStr = "name: Alice\nage: 30\nactive: true\ntags:\n  - viper\n  - lang\n";
    var parsed = Yaml.ParseResult(yamlStr);
    SayBool(parsed.IsOk);
    var doc = parsed.Unwrap();
    Say("ParseResult done");

    var nullDoc = Yaml.ParseResult("null");
    SayBool(nullDoc.IsOk);
    var badYaml = Yaml.ParseResult("name: [unterminated\n");
    SayBool(badYaml.IsErr);
    Say(badYaml.UnwrapErrStr());

    // --- Parse / Error compatibility ---
    Say("--- Parse / Error compatibility ---");
    var legacyDoc = Yaml.Parse("name: Bob\n");
    Say(Yaml.TypeOf(legacyDoc));
    var legacyBad = Yaml.Parse("name: [unterminated\n");
    SayBool(legacyBad == null);
    Say(Yaml.Error());

    // --- TypeOf ---
    Say("--- TypeOf ---");
    Say("TypeOf(doc):");
    Say(Yaml.TypeOf(doc));

    // --- Format ---
    Say("--- Format ---");
    Say("Format:");
    Say(Yaml.Format(doc));

    // --- FormatIndent ---
    Say("--- FormatIndent ---");
    Say("FormatIndent(4):");
    Say(Yaml.FormatIndent(doc, 4));

    // Parse a simple scalar
    Say("--- Scalar ---");
    var scalar = Yaml.ParseResult("42").Unwrap();
    Say("TypeOf(scalar):");
    Say(Yaml.TypeOf(scalar));
    Say("Format(scalar):");
    Say(Yaml.Format(scalar));

    // Parse a list
    Say("--- List ---");
    var list = Yaml.ParseResult("- one\n- two\n- three\n").Unwrap();
    Say("TypeOf(list):");
    Say(Yaml.TypeOf(list));
    Say("Format(list):");
    Say(Yaml.Format(list));

    // Roundtrip: format then re-parse
    Say("--- Roundtrip ---");
    var formatted = Yaml.Format(doc);
    var reparsed = Yaml.ParseResult(formatted).Unwrap();
    Say("Re-format after roundtrip:");
    Say(Yaml.Format(reparsed));

    Say("=== Yaml Demo Complete ===");
}
