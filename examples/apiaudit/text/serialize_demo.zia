// =============================================================================
// API Audit: Viper.Data.Serialize - Multi-Format Serialization
// =============================================================================
// Tests: ParseResult, Parse, Error, Format, FormatPretty, IsValid, Detect,
//        AutoParseResult, AutoParse, Convert, FormatName, MimeType, FormatFromName
// =============================================================================

module SerializeDemo;
bind Viper.Terminal;
bind Viper.Data.Serialize as Ser;
func start() {
    Say("=== API Audit: Viper.Data.Serialize ===");

    // Format constants: 0=JSON, 1=XML, 2=YAML, 3=TOML, 4=CSV

    // --- FormatName ---
    Say("--- FormatName ---");
    Say("FormatName(0) JSON:");
    Say(Ser.FormatName(0));
    Say("FormatName(1) XML:");
    Say(Ser.FormatName(1));
    Say("FormatName(2) YAML:");
    Say(Ser.FormatName(2));
    Say("FormatName(3) TOML:");
    Say(Ser.FormatName(3));
    Say("FormatName(4) CSV:");
    Say(Ser.FormatName(4));

    // --- MimeType ---
    Say("--- MimeType ---");
    Say("MimeType(0) JSON:");
    Say(Ser.MimeType(0));
    Say("MimeType(1) XML:");
    Say(Ser.MimeType(1));
    Say("MimeType(2) YAML:");
    Say(Ser.MimeType(2));
    Say("MimeType(3) TOML:");
    Say(Ser.MimeType(3));
    Say("MimeType(4) CSV:");
    Say(Ser.MimeType(4));

    // --- FormatFromName ---
    Say("--- FormatFromName ---");
    Say("FormatFromName('json'):");
    SayInt(Ser.FormatFromName("json"));
    Say("FormatFromName('yaml'):");
    SayInt(Ser.FormatFromName("yaml"));
    Say("FormatFromName('toml'):");
    SayInt(Ser.FormatFromName("toml"));
    Say("FormatFromName('xml'):");
    SayInt(Ser.FormatFromName("xml"));
    Say("FormatFromName('csv'):");
    SayInt(Ser.FormatFromName("csv"));

    // --- IsValid ---
    Say("--- IsValid ---");
    var jsonStr = "{\"name\":\"Alice\",\"age\":30}";
    Say("IsValid(JSON, 0):");
    SayBool(Ser.IsValid(jsonStr, 0));
    Say("IsValid('not json', 0):");
    SayBool(Ser.IsValid("not json {{", 0));

    // --- Detect ---
    Say("--- Detect ---");
    Say("Detect(JSON string):");
    SayInt(Ser.Detect(jsonStr));
    Say("Detect(YAML string):");
    SayInt(Ser.Detect("name: Alice\nage: 30\n"));
    Say("Detect(TOML string):");
    SayInt(Ser.Detect("[person]\nname = \"Alice\"\n"));
    Say("Detect(CSV string):");
    SayInt(Ser.Detect("name,age\nAlice,30\n"));
    Say("Detect(plain text unknown):");
    SayInt(Ser.Detect("plain text"));

    // --- ParseResult ---
    Say("--- ParseResult ---");
    var parsed = Ser.ParseResult(jsonStr, 0);
    SayBool(parsed.IsOk);
    var doc = parsed.Unwrap();
    Say("ParseResult(JSON) done");

    var badParse = Ser.ParseResult("{", 0);
    SayBool(badParse.IsErr);
    Say(badParse.UnwrapErrStr());

    // --- Parse / Error compatibility ---
    Say("--- Parse / Error compatibility ---");
    var legacyDoc = Ser.Parse(jsonStr, 0);
    SayBool(legacyDoc != null);
    var legacyBad = Ser.Parse("{", 0);
    SayBool(legacyBad == null);
    Say(Ser.Error());

    // --- Format ---
    Say("--- Format ---");
    Say("Format(doc, 0) as JSON:");
    Say(Ser.Format(doc, 0));

    // --- FormatPretty ---
    Say("--- FormatPretty ---");
    Say("FormatPretty(doc, 0, 2):");
    Say(Ser.FormatPretty(doc, 0, 2));

    // --- AutoParseResult ---
    Say("--- AutoParseResult ---");
    var autoResult = Ser.AutoParseResult(jsonStr);
    SayBool(autoResult.IsOk);
    var auto = autoResult.Unwrap();
    Say("AutoParseResult done");
    Say("Format auto-parsed:");
    Say(Ser.Format(auto, 0));

    var autoBad = Ser.AutoParseResult("plain text");
    SayBool(autoBad.IsErr);
    Say(autoBad.UnwrapErrStr());

    // --- AutoParse compatibility ---
    Say("--- AutoParse compatibility ---");
    var autoLegacy = Ser.AutoParse(jsonStr);
    SayBool(autoLegacy != null);

    // --- Convert ---
    Say("--- Convert ---");
    Say("Convert JSON to YAML:");
    Say(Ser.Convert(jsonStr, 0, 2));
    Say("Convert JSON to XML:");
    Say(Ser.Convert(jsonStr, 0, 1));
    Say("Convert JSON to TOML:");
    Say(Ser.Convert(jsonStr, 0, 3));
    Say("Convert JSON to CSV:");
    Say(Ser.Convert(jsonStr, 0, 4));

    Say("=== Serialize Demo Complete ===");
}
