// bitset_demo.zia - Comprehensive API audit for Zanna.Collections.BitSet
// Tests: New, Set, Get, Clear, Toggle, ClearAll, SetAll, Count, Len,
//        IsEmpty, Not, And, Or, Xor, ToString

module BitSetDemo;

bind Zanna.Collections;
bind Zanna.Core;
bind Zanna.Terminal;
bind Zanna.Text.Fmt;

func start() {
    Say("=== BitSet API Audit ===");

    // --- New ---
    Say("--- New ---");
    var bs = BitSet.New(8);
    SayInt(bs.Length);        // 8
    SayInt(bs.Count);      // 0
    SayBool(bs.IsEmpty);   // 1

    // --- Set / Get ---
    Say("--- Set / Get ---");
    bs.SetBit(0);
    bs.SetBit(2);
    bs.SetBit(4);
    bs.SetBit(7);
    SayBool(bs.GetBit(0));    // 1
    SayBool(bs.GetBit(1));    // 0
    SayBool(bs.GetBit(2));    // 1
    SayBool(bs.GetBit(4));    // 1
    SayBool(bs.GetBit(7));    // 1
    SayInt(bs.Count);      // 4
    SayBool(bs.IsEmpty);   // 0

    // --- Clear (single bit) ---
    Say("--- Clear ---");
    bs.Clear(2);
    SayBool(bs.GetBit(2));    // 0
    SayInt(bs.Count);      // 3

    // --- Toggle ---
    Say("--- Toggle ---");
    bs.ToggleBit(1);          // was 0, now 1
    SayBool(bs.GetBit(1));    // 1
    bs.ToggleBit(1);          // was 1, now 0
    SayBool(bs.GetBit(1));    // 0

    // --- SetAll ---
    Say("--- SetAll ---");
    bs.SetAll();
    SayInt(bs.Count);      // 8
    SayBool(bs.GetBit(3));    // 1

    // --- ClearAll ---
    Say("--- ClearAll ---");
    bs.Clear();
    SayInt(bs.Count);      // 0
    SayBool(bs.IsEmpty);   // 1

    // --- ToString ---
    Say("--- ToString ---");
    bs.SetBit(0);
    bs.SetBit(3);
    bs.SetBit(7);
    Say(bs.ToString());    // binary string representation

    // --- And ---
    Say("--- And ---");
    var a = BitSet.New(8);
    a.SetBit(0);
    a.SetBit(1);
    a.SetBit(2);

    var b = BitSet.New(8);
    b.SetBit(1);
    b.SetBit(2);
    b.SetBit(3);

    var andResult = a.And(b);
    SayBool(andResult.GetBit(0)); // 0
    SayBool(andResult.GetBit(1)); // 1
    SayBool(andResult.GetBit(2)); // 1
    SayBool(andResult.GetBit(3)); // 0
    SayInt(andResult.Count);   // 2

    // --- Or ---
    Say("--- Or ---");
    var orResult = a.Or(b);
    SayBool(orResult.GetBit(0));  // 1
    SayBool(orResult.GetBit(1));  // 1
    SayBool(orResult.GetBit(2));  // 1
    SayBool(orResult.GetBit(3));  // 1
    SayInt(orResult.Count);    // 4

    // --- Xor ---
    Say("--- Xor ---");
    var xorResult = a.Xor(b);
    SayBool(xorResult.GetBit(0)); // 1
    SayBool(xorResult.GetBit(1)); // 0
    SayBool(xorResult.GetBit(2)); // 0
    SayBool(xorResult.GetBit(3)); // 1
    SayInt(xorResult.Count);   // 2

    // --- Not ---
    Say("--- Not ---");
    var c = BitSet.New(4);
    c.SetBit(0);
    c.SetBit(2);
    var notResult = c.Not();
    SayBool(notResult.GetBit(0)); // 0
    SayBool(notResult.GetBit(1)); // 1
    SayBool(notResult.GetBit(2)); // 0
    SayBool(notResult.GetBit(3)); // 1

    Say("=== BitSet audit complete ===");
}
