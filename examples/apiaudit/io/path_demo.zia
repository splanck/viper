// =============================================================================
// API Audit: Viper.IO.Path - Path Manipulation
// =============================================================================
// Tests: Abs, Dir, Ext, Name, Stem, IsAbs, Join, Norm, Sep, WithExt
// =============================================================================

module PathDemo;
bind Viper.Terminal;
bind Viper.IO.Path as Path;
func start() {
    Say("=== API Audit: Viper.IO.Path ===");

    var testPath = "/home/user/documents/file.txt";

    // --- Name ---
    Say("--- Name ---");
    Say("Name('/home/user/documents/file.txt'):");
    Say(Path.Name(testPath));
    Say("Name('test.tar.gz'):");
    Say(Path.Name("test.tar.gz"));

    // --- Stem ---
    Say("--- Stem ---");
    Say("Stem('/home/user/documents/file.txt'):");
    Say(Path.Stem(testPath));
    Say("Stem('archive.tar.gz'):");
    Say(Path.Stem("archive.tar.gz"));

    // --- Dir ---
    Say("--- Dir ---");
    Say("Dir('/home/user/documents/file.txt'):");
    Say(Path.Directory(testPath));
    Say("Dir('file.txt'):");
    Say(Path.Directory("file.txt"));

    // --- Ext ---
    Say("--- Ext ---");
    Say("Ext('/home/user/documents/file.txt'):");
    Say(Path.Extension(testPath));
    Say("Ext('noext'):");
    Say(Path.Extension("noext"));
    Say("Ext('archive.tar.gz'):");
    Say(Path.Extension("archive.tar.gz"));

    // --- IsAbs ---
    Say("--- IsAbs ---");
    Say("IsAbs('/home/user'):");
    SayBool(Path.IsAbsolute("/home/user"));
    Say("IsAbs('relative/path'):");
    SayBool(Path.IsAbsolute("relative/path"));
    Say("IsAbs(''):");
    SayBool(Path.IsAbsolute(""));

    // --- Join ---
    Say("--- Join ---");
    Say("Join('/home', 'user'):");
    Say(Path.Join("/home", "user"));
    Say("Join('a', 'b'):");
    Say(Path.Join("a", "b"));
    Say("Join('/root', 'file.txt'):");
    Say(Path.Join("/root", "file.txt"));

    // --- Abs ---
    Say("--- Abs ---");
    Say("Abs('.'):");
    Say(Path.Absolute("."));
    Say("Abs('test.txt'):");
    Say(Path.Absolute("test.txt"));

    // --- Norm ---
    Say("--- Norm ---");
    Say("Norm('/home/user/../user/./docs'):");
    Say(Path.Normalize("/home/user/../user/./docs"));
    Say("Norm('/a/b/c/../../d'):");
    Say(Path.Normalize("/a/b/c/../../d"));

    // --- Sep ---
    Say("--- Sep ---");
    Say("Sep:");
    Say(Path.Separator());

    // --- WithExt ---
    Say("--- WithExt ---");
    Say("WithExt('file.txt', '.md'):");
    Say(Path.WithExtension("file.txt", ".md"));
    Say("WithExt('archive.tar.gz', '.zip'):");
    Say(Path.WithExtension("archive.tar.gz", ".zip"));
    Say("WithExt('noext', '.txt'):");
    Say(Path.WithExtension("noext", ".txt"));

    Say("=== Path Demo Complete ===");
}
