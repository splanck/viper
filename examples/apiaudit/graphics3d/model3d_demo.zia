module SceneAssetDemo;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal;

func start() {
    Say("=== SceneAsset Demo ===");

    var path = "scene_asset_demo.vscn";
    var scene = SceneGraph.New();
    var parent = SceneNode.New();
    var child = SceneNode.New();
    var mesh = Mesh3D.Box(1.0, 2.0, 3.0);
    var mat = Material3D.FromColor(0.2, 0.4, 0.8);

    SceneNode.set_Name(parent, "parent");
    SceneNode.set_Name(child, "child");
    SceneNode.SetPosition(parent, 1.0, 2.0, 3.0);
    SceneNode.SetPosition(child, 0.0, 5.0, 0.0);
    SceneNode.set_Mesh(parent, mesh);
    SceneNode.set_Material(parent, mat);
    SceneNode.set_Mesh(child, mesh);
    SceneNode.set_Material(child, mat);
    SceneNode.AddChild(parent, child);
    SceneGraph.Add(scene, parent);
    SceneGraph.Save(scene, path);

    var model = SceneAsset.LoadResult(path).Unwrap();
    Say("MeshCount = " + toString(SceneAsset.get_MeshCount(model)));
    Say("MaterialCount = " + toString(SceneAsset.get_MaterialCount(model)));
    Say("NodeCount = " + toString(SceneAsset.get_NodeCount(model)));

    var templateChild = SceneAsset.FindNode(model, "child").Unwrap();
    Say("Template child Y = " + toString(Vec3.get_Y(SceneNode.get_Position(templateChild))));

    var instRoot = SceneAsset.Instantiate(model);
    var instChild = SceneNode.FindOption(instRoot, "child").Unwrap();
    SceneNode.SetPosition(instChild, 9.0, 9.0, 9.0);
    Say("Instance child Y = " + toString(Vec3.get_Y(SceneNode.get_Position(instChild))));
    Say("Template child still Y = " + toString(Vec3.get_Y(SceneNode.get_Position(templateChild))));

    var instScene = SceneAsset.InstantiateScene(model);
    Say("Scene node count = " + toString(SceneGraph.get_NodeCount(instScene)));
}
