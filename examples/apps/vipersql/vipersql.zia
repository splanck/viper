// =============================================================================
// vipersql.zia — Full-featured server entry point (argument parsing,
//                dual-protocol listeners, thread pool, optional REPL)
// Part of ViperSQL
// =============================================================================
//
// PURPOSE
// -------
// The canonical entry point for launching ViperSQL in server mode.
// Responsibilities:
//
//   * parse CLI arguments (`--port`, `--max-connections`,
//     `--pool-size`, `--data-dir`, `--log-queries`, `--repl`, ...)
//   * construct a shared `DatabaseServer`
//   * initialise the connection handler and thread pool
//   * start the text protocol listener on a background thread
//   * run the PG wire protocol accept loop on the main thread
//   * OR, if `--repl` is given, enter standalone in-memory REPL
//     mode (same meta-commands as `main.zia`, but backed by this
//     file's own `Executor`).
//
// This file is structurally the "thick" entry — `main.zia` and
// `server/tcp_server.zia` are simpler variants that share code
// through `server/connection.zia` + `server/threadpool.zia` +
// `engine/server.zia`.
//
// WHERE THIS FITS
// ---------------
//     vipersql.zia   (YOU ARE HERE — `start()`)
//         │
//         ├─► runRepl()     → engine/executor.zia
//         │
//         └─► runServer()   → engine/server.zia (DatabaseServer)
//                           → server/threadpool.zia
//                           → server/connection.zia
//                           → PG wire accept loop on main thread
//                           → text protocol on a background thread
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Default-value constants.
//   2. `ServerConfig` — the struct populated from CLI args.
//   3. `parseArgs` + `printUsage` — CLI parsing.
//   4. `runServer` — the real server entry.
//   5. `textProtocolListener` — background thread body.
//   6. `runRepl` + `processReplCommand` — REPL mode.
//   7. `start` — the executable's top-level.
//
// =============================================================================

module vipersql;

bind Viper.Terminal as Terminal;
bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind Viper.Network as Network;
bind Viper.Threads as Threads;
bind Viper.Core.Parse as Parse;
bind Viper.Environment as Env;
bind "./engine/server";
bind "./server/connection";
bind "./server/threadpool";
bind "./engine/executor";

//=============================================================================
// DEFAULT CONFIGURATION
//=============================================================================

final DEFAULT_PG_PORT = 5432;          // PG wire default — matches psql
final DEFAULT_TEXT_PORT = 5433;        // Text protocol default
final DEFAULT_MAX_CONNECTIONS = 100;
final VERSION = "0.2.0";

//=============================================================================
// CONFIGURATION
//=============================================================================

/// @brief Struct of runtime config populated from CLI arguments.
///        Defaults set in `init()`; overridden by `parseArgs`.
class ServerConfig {
    expose Integer pgPort;
    expose Integer textPort;         // 0 disables the text listener
    expose Integer maxConnections;
    expose Boolean logQueries;
    expose Boolean replMode;
    expose String dataDir;
    expose Integer poolSize;

    /// @brief Load sensible defaults.
    expose func init() {
        pgPort = DEFAULT_PG_PORT;
        textPort = DEFAULT_TEXT_PORT;
        maxConnections = DEFAULT_MAX_CONNECTIONS;
        logQueries = false;
        replMode = false;
        dataDir = "./data";
        poolSize = 10;
    }
}

/// @brief Parse argv into a populated `ServerConfig`.
///
/// Iterates arguments, consuming one or two per switch as
/// appropriate.  Unknown flags are silently ignored — simpler
/// than erroring out for a demo-grade CLI.  Falls back to the
/// help text on `--help` / `-h`.
func parseArgs() -> ServerConfig {
    var config = new ServerConfig();
    config.init();

    var argc = Env.GetArgumentCount();
    var i = 0;
    while i < argc {
        var arg = Env.GetArgument(i);

        if arg == "--port" && i + 1 < argc {
            i = i + 1;
            config.pgPort = Parse.IntOr(Env.GetArgument(i), DEFAULT_PG_PORT);
        }

        if arg == "--text-port" && i + 1 < argc {
            i = i + 1;
            config.textPort = Parse.IntOr(Env.GetArgument(i), DEFAULT_TEXT_PORT);
        }

        if arg == "--max-connections" && i + 1 < argc {
            i = i + 1;
            config.maxConnections = Parse.IntOr(Env.GetArgument(i), DEFAULT_MAX_CONNECTIONS);
        }

        if arg == "--data-dir" && i + 1 < argc {
            i = i + 1;
            config.dataDir = Env.GetArgument(i);
        }

        if arg == "--pool-size" && i + 1 < argc {
            i = i + 1;
            config.poolSize = Parse.IntOr(Env.GetArgument(i), 10);
        }

        if arg == "--log-queries" {
            config.logQueries = true;
        }

        if arg == "--repl" || arg == "--standalone" {
            config.replMode = true;
        }

        if arg == "--no-text" {
            config.textPort = 0;
        }

        if arg == "--help" || arg == "-h" {
            printUsage();
            return config;
        }

        i = i + 1;
    }

    return config;
}

/// @brief Print the help text for `--help` / `-h`.  Kept as
///        literal strings so the output stays identical across
///        releases.
func printUsage() {
    Terminal.Say("ViperSQL v" + VERSION + " — SQL Database Server");
    Terminal.Say("");
    Terminal.Say("Usage: vipersql [options]");
    Terminal.Say("");
    Terminal.Say("Options:");
    Terminal.Say("  --port N            PG wire protocol port (default: 5432)");
    Terminal.Say("  --text-port N       Text protocol port (default: 5433, 0 to disable)");
    Terminal.Say("  --no-text           Disable text protocol listener");
    Terminal.Say("  --max-connections N Maximum concurrent connections (default: 100)");
    Terminal.Say("  --pool-size N       Thread pool size (default: 10)");
    Terminal.Say("  --data-dir PATH     Data directory (default: ./data)");
    Terminal.Say("  --log-queries       Log all queries to stdout");
    Terminal.Say("  --repl              Start in standalone REPL mode (no server)");
    Terminal.Say("  --help, -h          Show this help");
}

//=============================================================================
// SERVER MODE
//=============================================================================

/// @brief Run as a multi-user server until the process exits.
///
/// Concrete sequence:
///   1. Construct a shared `DatabaseServer`.
///   2. Initialise the connection handler + thread pool.
///   3. (Optional) enable query logging.
///   4. Spawn the text-protocol listener on a background thread
///      (unless disabled via `--no-text`).
///   5. Open the PG-wire listener on the main thread and run
///      its accept loop, submitting each client to the pool.
///
/// Graceful shutdown is not yet wired — the loop terminates on
/// process signal only.
func runServer(config: ServerConfig) {
    Terminal.Say("================================================");
    Terminal.Say("  ViperSQL v" + VERSION);
    Terminal.Say("  PostgreSQL Wire Protocol v3 Compatible");
    Terminal.Say("================================================");
    Terminal.Say("");

    var dbServer = new DatabaseServer();
    dbServer.init();
    Terminal.Say("Database server initialized (database: main)");
    Terminal.Say("Default user: admin / admin");

    sql_connection_init(dbServer);

    sql_pool_init(config.poolSize);

    Terminal.Say("Thread model: pool (" + Fmt.Int(config.poolSize) + " workers, max " + Fmt.Int(config.maxConnections) + " connections)");
    if config.logQueries {
        sql_connection_enable_logging();
        Terminal.Say("Query logging: enabled");
    }
    Terminal.Say("");

    if config.textPort > 0 {
        var textArgs: List[Integer] = [];
        textArgs.add(config.textPort);
        Threads.Thread.StartSafe(&textProtocolListener, textArgs);
        Terminal.Say("Text protocol listening on port " + Fmt.Int(config.textPort));
    }

    var pgServer = Network.TcpServer.Listen(config.pgPort);
    Terminal.Say("PG wire protocol listening on port " + Fmt.Int(config.pgPort));
    Terminal.Say("");
    Terminal.Say("Connect via: psql -h localhost -p " + Fmt.Int(config.pgPort) + " -U admin -d main");
    Terminal.Say("         or: vsql -h localhost -p " + Fmt.Int(config.pgPort) + " -U admin");
    Terminal.Say("");

    var running = 1;
    var activeConns = 0;
    while running == 1 {
        var client = Network.TcpServer.Accept(pgServer);
        sql_pool_submit_pg(client);
    }

    Terminal.Say("Shutting down...");
    Network.TcpServer.Close(pgServer);
    Terminal.Say("Server stopped.");
}

/// @brief Thread body for the text protocol listener.  Mirrors
///        the PG accept loop but targets the text-protocol
///        handler in `server/connection.zia`.
func textProtocolListener(args: List[Integer]) {
    var port = args.get(0);
    var server = Network.TcpServer.Listen(port);

    var running = 1;
    while running == 1 {
        var client = Network.TcpServer.Accept(server);
        Threads.Thread.StartSafe(&handleSqlClient, client);
    }

    Network.TcpServer.Close(server);
}

//=============================================================================
// REPL MODE
//=============================================================================

/// @brief Standalone REPL.  Same meta-commands as `main.zia`,
///        but shares the `vipersql` version string and banner.
///        Backed by its own private `Executor` — no shared
///        `DatabaseServer`, no network.
func runRepl() {
    Terminal.Say("ViperSQL v" + VERSION + " — Standalone REPL (in-memory)");
    Terminal.Say("Type SQL commands or 'exit' to quit. Type .help for commands.");
    Terminal.Say("");

    var exec = new Executor();
    exec.init();

    var running = true;
    while running {
        Terminal.Print("sql> ");
        var rawInput = Terminal.ReadLine();
        if rawInput == null {
            running = false;
            continue;
        }
        var input = rawInput!;

        if input == "exit" || input == "quit" {
            running = false;
            continue;
        }

        if input == "" {
            continue;
        }

        var trimmed = String.Trim(input);
        if String.StartsWith(trimmed, ".") {
            processReplCommand(trimmed, exec);
            continue;
        }

        var result = exec.executeSql(input);
        Terminal.Say(result.toString());
        Terminal.Say("");
    }

    Terminal.Say("Goodbye!");
}

/// @brief REPL meta-command dispatch.  Identical semantics to
///        `main.zia::processMetaCommand`; kept as a separate
///        copy here so the two entry modes stay independent.
func processReplCommand(cmd: String, exec: Executor) {
    var lower = String.ToLower(cmd);

    if lower == ".help" {
        Terminal.Say("");
        Terminal.Say("Meta-commands:");
        Terminal.Say("  .help          Show this help");
        Terminal.Say("  .quit/.exit    Exit the shell");
        Terminal.Say("  .tables        List all tables");
        Terminal.Say("  .schema        Show all table schemas");
        Terminal.Say("  .schema <tbl>  Show specific table schema");
        Terminal.Say("");
        return;
    }

    if lower == ".quit" || lower == ".exit" {
        Terminal.Say("Goodbye!");
        return;
    }

    if lower == ".tables" {
        var result = exec.executeSql("SHOW TABLES");
        Terminal.Say(result.toString());
        Terminal.Say("");
        return;
    }

    if lower == ".schema" {
        var tablesResult = exec.executeSql("SHOW TABLES");
        var ti = 0;
        while ti < tablesResult.rowCount() {
            var row = tablesResult.getRow(ti);
            if row != null {
                var r = row;
                var tableName = r.getValue(0).textValue;
                Terminal.Say("");
                Terminal.Say("Table: " + tableName);
                var descResult = exec.executeSql("DESCRIBE " + tableName);
                Terminal.Say(descResult.toString());
            }
            ti = ti + 1;
        }
        Terminal.Say("");
        return;
    }

    if String.StartsWith(lower, ".schema ") {
        var tableName = String.Substring(cmd, 8, String.Length(cmd) - 8);
        tableName = String.Trim(tableName);
        var result = exec.executeSql("DESCRIBE " + tableName);
        Terminal.Say(result.toString());
        Terminal.Say("");
        return;
    }

    Terminal.Say("Unknown command: " + cmd);
    Terminal.Say("Type .help for help");
    Terminal.Say("");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

/// @brief Top-level entry: parse CLI args, route to REPL or
///        server mode based on `--repl`.
func start() {
    var config = parseArgs();

    if config.replMode {
        runRepl();
    } else {
        runServer(config);
    }
}
