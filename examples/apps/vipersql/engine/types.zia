// =============================================================================
// types.zia — `SqlValue`: the tagged-union cell type that is SQL's lingua
//              franca inside ViperSQL
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// SQL is dynamically typed at the *cell* level — every row cell carries a
// value whose type is known only at runtime (NULL, INTEGER, REAL, TEXT,
// BLOB, BOOLEAN, DATE, TIMESTAMP, JSON, ARRAY).  This file gives the
// engine one uniform runtime representation for *all* of them:
//
//   * a single class, `SqlValue`, with a `kind` tag and three payload
//     slots (`intValue`, `realValue`, `textValue`);
//   * type-code constants (`SQL_NULL`, `SQL_INTEGER`, …) used by every
//     other module that needs to talk about "what kind of value is this";
//   * small free-function constructors (`sqlNull`, `sqlInteger`,
//     `sqlText`, …) that read much cleaner than four lines of manual
//     construction at a call site;
//   * the SQL three-valued comparison operator (`compare`), which is
//     responsible for implementing SQL's messy cross-type ordering rules
//     (an INTEGER compared to a TEXT, a DATE compared to a TEXT, etc.).
//
// WHERE THIS FITS
// ---------------
//     parser/*     — never touches `SqlValue`.  Literals are handed down
//                    as AST nodes; the evaluator turns them into cells.
//
//     engine/schema.zia
//                  — each `Row` is a `List[SqlValue]` (see already-
//                    annotated `schema.zia`).
//
//     engine/executor.zia, query.zia, dml.zia, ddl.zia
//                  — produce, consume, compare, and arithmeticise these.
//
//     storage/serializer.zia
//                  — writes / reads `SqlValue` as typed bytes on-page,
//                    using the matching VAL_TYPE_* codes in `page.zia`.
//
//     server/pg_wire.zia
//                  — maps `kind` to a PostgreSQL OID when advertising
//                    column types to clients.
//
// KEY DESIGN CHOICES
// ------------------
//   1. One class, four slots, no sum type.  Zia does have ADTs, but
//      `SqlValue` pre-dates that work and — more importantly — SQL
//      comparisons frequently coerce one kind into another (INTEGER ↔
//      REAL, TEXT ↔ DATE, TEXT ↔ INTEGER).  A flat class with typed
//      accessor-by-tag avoids the "you have to pattern-match on both
//      sides" pain that pops up in the N² comparison matrix below.
//
//   2. `textValue` is reused for three kinds: TEXT, BLOB, JSON, and
//      (via a textual rendering) REAL.  This is a memory-efficiency
//      trade: the common "small integer" cell only pays for one
//      Integer field; the slightly less common TEXT cell pays for the
//      string.  The tag tells you which slot is authoritative.
//
//   3. REAL carries both `realValue` *and* `textValue`.  The text is
//      the exact lexer-preserved representation (`"3.14"`,
//      `"1e-10"`).  Preserving the original text means we can
//      round-trip a numeric literal through the engine without the
//      usual double-to-string rounding quirks, which in turn means
//      SHOW CREATE TABLE and EXPLAIN output stay identical to the
//      user's source.
//
//   4. `compare` returns **2** for NULL.  Classic SQL three-valued
//      logic: NULL compared to anything (including NULL) is UNKNOWN.
//      The executor treats 2 as "neither true nor false" when
//      evaluating predicates, so `WHERE x = y` drops rows where either
//      side is NULL — the SQL-spec behaviour.
//
//   5. `stringToInt` falls back to float-truncate.  This is a small
//      but load-bearing quirk: SQL `CAST('3.14' AS INTEGER)` should
//      yield 3, not 0 (the latter is what a naive `IntOr(_, 0)` gives
//      you).  The helper punts to float parse when the integer parse
//      fails.  See the flag-don't-fix note below: this swallows real
//      conversion errors silently (`'abc'` becomes 0), which is bug-
//      compatible with SQLite but arguably wrong for us — a candidate
//      for later tightening.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. The SQL_* and PARTITION_* constants at the top — short, skim.
//   2. The helper functions (`stringToInt`, `fmtDateParts`,
//      `parseDateText`, …) are used inside `compare` below.
//   3. The `SqlValue` class itself: init helpers, kind predicates,
//      then the big `compare` N² matrix.
//   4. The `sql*` factory functions at the bottom — these are what
//      you call in everyday engine code.
//   5. The array helpers (`parseArrayElements`, `buildArrayString`)
//      are only used by JSON/array support in the executor.
//
// FLAG-DON'T-FIX NOTES
// --------------------
//   * `stringToInt` silently coerces bad input to 0 (see note 5).
//   * JSON / ARRAY comparison returns -1 on non-equal, which is a lie
//     about ordering — JSON is genuinely unordered.  The executor
//     carefully only asks `compare` for equality, so this is safe
//     today but is an easy foot-gun if a future caller uses < or >.
//   * `compare` is huge.  It is a candidate for splitting into a
//     coercion step + a mono-typed compare, but that refactor is
//     intentionally deferred per your flag-don't-fix convention.
//
// =============================================================================

module types;

bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind Viper.Time.DateTime as DateTime;

//=============================================================================
// SQL TYPE CONSTANTS
//=============================================================================
//
// These are the integers that live in `SqlValue.kind`.  Keep them stable:
// they are *also* used as on-disk tags in the schema page layout and on
// the JSON path, so renumbering would silently corrupt every existing
// database file.  Append-only.

final SQL_NULL = 0;
final SQL_INTEGER = 1;
final SQL_REAL = 2;
final SQL_TEXT = 3;
final SQL_BLOB = 4;
final SQL_BOOLEAN = 5;
final SQL_DATE = 6;       // intValue = days since Unix epoch (1970-01-01)
final SQL_TIMESTAMP = 7;  // intValue = epoch seconds
final SQL_JSON = 8;       // textValue = JSON string
final SQL_ARRAY = 9;      // textValue = PG-format array "{1,2,3}"

// Partition strategy tags (Phase 28 — CREATE TABLE ... PARTITION BY ...).
// Stored on `Table` so the executor knows how to route rows to the
// appropriate child partition.
final PARTITION_NONE = 0;
final PARTITION_RANGE = 1;
final PARTITION_LIST = 2;
final PARTITION_HASH = 3;

//=============================================================================
// STRING → NUMBER HELPERS
//=============================================================================

/// @brief Coerce a string to an Integer, tolerating float-like input.
///
/// Parses "123" and "-5" directly via the runtime integer parser, and
/// falls back to a double parse + truncate for "3.14"-style values.  The
/// fallback exists because SQL's `CAST('3.14' AS INTEGER)` should yield
/// 3, not 0 — without this, `IntOr(_, 0)` would succeed with 0 for any
/// non-integer text, swallowing the decimal.
///
/// NOTE (flag-don't-fix): this also returns 0 for text like `"abc"` or
/// `""` because `ToDouble` of a non-numeric returns 0.  That is SQLite-
/// compatible but arguably wrong.  Called from `compare` to cross-coerce
/// INTEGER ↔ TEXT; any tightening would ripple through the compare
/// matrix below.
func stringToInt(text: String) -> Integer {
    var n = Viper.Core.Parse.IntOr(text, 0);
    if n != 0 { return n; }
    // IntOr rejects "3.14" — fall back to float parse + truncate.
    var f = Viper.Core.Convert.ToDouble(text);
    return Viper.Core.Convert.NumToInt(f);
}

/// @brief Coerce a string to a Float.
///
/// A one-liner wrapper around the runtime's `ToDouble`.  Exists as a
/// named function so the N² compare matrix below reads symmetrically
/// alongside `stringToInt`.
func stringToNumber(text: String) -> Float {
    return Viper.Core.Convert.ToDouble(text);
}

//=============================================================================
// DATE/TIME HELPERS
//=============================================================================

/// @brief Format "2024-01-31"-style date parts with zero-padded
///        month/day.
///
/// Factored out because both `toString` and `toSqlString` render DATE
/// values the same way.  Using `Fmt.IntPad` keeps month=7 from coming
/// out as "7" instead of "07".
func fmtDateParts(y: Integer, m: Integer, d: Integer) -> String {
    return Fmt.Int(y) + "-" + Fmt.IntPad(m, 2, "0") + "-" + Fmt.IntPad(d, 2, "0");
}

/// @brief Format "HH:MM:SS" with zero-padded parts.
///
/// Symmetric to `fmtDateParts`.  Currently unused here but referenced
/// by `sql_functions.zia`'s TIME rendering — kept in types.zia so both
/// modules share the padding convention.
func fmtTimeParts(h: Integer, m: Integer, s: Integer) -> String {
    return Fmt.IntPad(h, 2, "0") + ":" + Fmt.IntPad(m, 2, "0") + ":" + Fmt.IntPad(s, 2, "0");
}

/// @brief Convert a DATE epoch (noon-of-day convention) to a TIMESTAMP
///        epoch (midnight of the same calendar date).
///
/// ViperSQL stores DATE as "seconds since epoch" anchored at **12:00
/// local** — picking noon protects against DST transitions silently
/// shifting the encoded day.  When we promote DATE to TIMESTAMP (for
/// comparison, arithmetic, or SELECT output) we need the day to start
/// at 00:00, so we re-project through the calendar.
func dateToTimestamp(dateEpoch: Integer) -> Integer {
    var y = DateTime.Year(dateEpoch);
    var m = DateTime.Month(dateEpoch);
    var d = DateTime.Day(dateEpoch);
    return DateTime.Create(y, m, d, 0, 0, 0);
}

/// @brief Inverse of `dateToTimestamp`: drop the time-of-day portion of
///        a TIMESTAMP and re-anchor at noon-of-day.
func timestampToDate(tsEpoch: Integer) -> Integer {
    var y = DateTime.Year(tsEpoch);
    var m = DateTime.Month(tsEpoch);
    var d = DateTime.Day(tsEpoch);
    return DateTime.Create(y, m, d, 12, 0, 0);
}

/// @brief Parse "YYYY-MM-DD" text into a DATE epoch (noon-of-day).
///
/// Returns 0 for strings shorter than 10 characters rather than raising
/// — callers (`compare`'s DATE-vs-TEXT branches, CAST paths) treat 0 as
/// "no date today", and the three-valued comparison still drops the
/// row.
func parseDateText(text: String) -> Integer {
    var sLen = String.Length(text);
    if sLen < 10 { return 0; }
    var yr = stringToInt(String.Substring(text, 0, 4));
    var mo = stringToInt(String.Substring(text, 5, 2));
    var dy = stringToInt(String.Substring(text, 8, 2));
    return DateTime.Create(yr, mo, dy, 12, 0, 0);
}

/// @brief Parse "YYYY-MM-DD" or "YYYY-MM-DDTHH:MM:SS" into epoch
///        seconds.
///
/// Delegates to the Viper runtime's `TryParse`, which accepts all three
/// ISO forms (date, date+time, date+time+Z).  Returns 0 on parse failure
/// for the same "stay out of the way" reason as `parseDateText`.
func parseDateTimeText(text: String) -> Integer {
    return DateTime.TryParse(text);
}

//=============================================================================
// SQL VALUE
//=============================================================================

/// @brief Universal runtime representation of a SQL cell.
///
/// A `SqlValue` is a tagged union with:
///   * `kind` — one of the `SQL_*` constants above.
///   * `intValue` — backing store for SQL_INTEGER, SQL_BOOLEAN (0/1),
///                  SQL_DATE (days-or-seconds depending on helper used),
///                  SQL_TIMESTAMP (seconds-since-epoch).
///   * `realValue` — backing store for SQL_REAL.
///   * `textValue` — backing store for SQL_TEXT, SQL_BLOB, SQL_JSON,
///                   SQL_ARRAY, and (auxiliary) the source text of
///                   REAL literals so rounding stays faithful.
///
/// Consumers branch on `kind`; a wrong-kind access is a bug in the
/// caller (the predicate helpers `isInteger()`, `isText()`, etc. exist
/// to guard).
class SqlValue {
    expose Integer kind;
    expose Integer intValue;
    expose Float realValue;
    expose String textValue;

    /// @brief Zero-init to SQL NULL.  Matches `initNull`.
    expose func init() {
        kind = SQL_NULL;
        intValue = 0;
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Explicit "set me to SQL NULL".
    ///
    /// Exists as a separate method (rather than just re-using `init`) so
    /// that code which re-uses a `SqlValue` object (common in tight
    /// inner loops to avoid an allocation) has a semantically clear
    /// way to reset it.
    expose func initNull() {
        kind = SQL_NULL;
        intValue = 0;
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Populate as SQL_INTEGER.
    ///
    /// Zia's `Integer` is 64-bit — this is sufficient for every SQL
    /// numeric range we support (no BIGINT/SMALLINT sub-typing).
    expose func initInteger(val: Integer) {
        kind = SQL_INTEGER;
        intValue = val;
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Populate as SQL_REAL with both the parsed value and the
    ///        source text preserved.
    ///
    /// `text` is the lexer-captured source spelling ("3.14", "1.0e-5").
    /// Keeping it means `SELECT 3.14` prints back as "3.14" rather than
    /// "3.1400000000000001", which matters for EXPLAIN/SHOW/DESCRIBE
    /// output stability and test goldens.
    expose func initReal(val: Float, text: String) {
        kind = SQL_REAL;
        intValue = 0;
        realValue = val;
        textValue = text;
    }

    /// @brief Populate as SQL_TEXT.
    expose func initText(val: String) {
        kind = SQL_TEXT;
        intValue = 0;
        realValue = 0.0;
        textValue = val;
    }

    /// @brief Populate as SQL_BLOB.  The bytes are carried inside a
    ///        `String` — Zia's `String` is byte-safe, not required to
    ///        be UTF-8.
    expose func initBlob(val: String) {
        kind = SQL_BLOB;
        intValue = 0;
        realValue = 0.0;
        textValue = val;
    }

    /// @brief Populate as SQL_BOOLEAN (stored as 0/1 inside `intValue`).
    expose func initBoolean(val: Boolean) {
        kind = SQL_BOOLEAN;
        if val { intValue = 1; } else { intValue = 0; }
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Populate as SQL_DATE.  `daysSinceEpoch` name is the
    ///        historical field label; ViperSQL actually stores epoch-
    ///        seconds at noon-of-day (see `parseDateText` and
    ///        `dateToTimestamp` rationale).  TODO: rename field in a
    ///        future refactor.
    expose func initDate(daysSinceEpoch: Integer) {
        kind = SQL_DATE;
        intValue = daysSinceEpoch;
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Populate as SQL_TIMESTAMP (epoch seconds).
    expose func initTimestamp(epochSeconds: Integer) {
        kind = SQL_TIMESTAMP;
        intValue = epochSeconds;
        realValue = 0.0;
        textValue = "";
    }

    /// @brief Populate as SQL_JSON.  Stored as the raw JSON text; the
    ///        executor re-parses through `io/json.zia` as needed.
    expose func initJson(val: String) {
        kind = SQL_JSON;
        intValue = 0;
        realValue = 0.0;
        textValue = val;
    }

    /// @brief Populate as SQL_ARRAY.  Stored in PostgreSQL textual array
    ///        form ("{1,2,3}") so the wire protocol can ship it
    ///        verbatim.
    expose func initArray(val: String) {
        kind = SQL_ARRAY;
        intValue = 0;
        realValue = 0.0;
        textValue = val;
    }

    // -------- Kind predicates -----------------------------------------------
    // Cheap one-liners.  Exist so call sites read as `v.isNull()` rather
    // than `v.kind == SQL_NULL` — the former is harder to typo-swap.
    expose func isNull() -> Boolean { return kind == SQL_NULL; }
    expose func isInteger() -> Boolean { return kind == SQL_INTEGER; }
    expose func isReal() -> Boolean { return kind == SQL_REAL; }
    expose func isText() -> Boolean { return kind == SQL_TEXT; }
    expose func isBlob() -> Boolean { return kind == SQL_BLOB; }
    expose func isBoolean() -> Boolean { return kind == SQL_BOOLEAN; }
    expose func isDate() -> Boolean { return kind == SQL_DATE; }
    expose func isTimestamp() -> Boolean { return kind == SQL_TIMESTAMP; }
    expose func isJson() -> Boolean { return kind == SQL_JSON; }
    expose func isArray() -> Boolean { return kind == SQL_ARRAY; }

    /// @brief SQL keyword for this cell's type (used by `DESCRIBE`, the
    ///        catalog views, and error messages).
    ///
    /// Kept in lock-step with `Column.typeName` in `schema.zia` — if you
    /// add a new SQL_* here, add the case there too.
    expose func typeName() -> String {
        if (kind == SQL_NULL) { return "NULL"; }
        if (kind == SQL_INTEGER) { return "INTEGER"; }
        if (kind == SQL_REAL) { return "REAL"; }
        if (kind == SQL_TEXT) { return "TEXT"; }
        if (kind == SQL_BLOB) { return "BLOB"; }
        if (kind == SQL_BOOLEAN) { return "BOOLEAN"; }
        if (kind == SQL_DATE) { return "DATE"; }
        if (kind == SQL_TIMESTAMP) { return "TIMESTAMP"; }
        if (kind == SQL_JSON) { return "JSON"; }
        if (kind == SQL_ARRAY) { return "ARRAY"; }
        return "UNKNOWN";
    }

    /// @brief Render for human consumption — no quoting, no escaping.
    ///
    /// Used by `QueryResult.toString()` (the psql-style result table).
    /// Notice that REAL is rendered from `textValue`, not `realValue`:
    /// this is the point of preserving the source spelling in
    /// `initReal`.
    expose func toString() -> String {
        if (kind == SQL_NULL) { return "NULL"; }
        if (kind == SQL_INTEGER) { return Fmt.Int(intValue); }
        if (kind == SQL_REAL) { return textValue; }
        if (kind == SQL_TEXT) { return textValue; }
        if (kind == SQL_BLOB) { return textValue; }
        if (kind == SQL_BOOLEAN) {
            if intValue != 0 { return "true"; }
            return "false";
        }
        if (kind == SQL_DATE) {
            var y = DateTime.Year(intValue);
            var m = DateTime.Month(intValue);
            var d = DateTime.Day(intValue);
            return fmtDateParts(y, m, d);
        }
        if (kind == SQL_TIMESTAMP) {
            return DateTime.ToLocal(intValue);
        }
        if (kind == SQL_JSON) { return textValue; }
        if (kind == SQL_ARRAY) { return textValue; }
        return "?";
    }

    /// @brief Render as a SQL literal — quoted, with `'` doubled-up.
    ///
    /// Used by code paths that need to embed the value back into a SQL
    /// string (SHOW CREATE TABLE, DEFAULT clause rendering, trigger body
    /// substitution).  Booleans come out as TRUE/FALSE (SQL keywords,
    /// not quoted), BLOBs as `X'<hex>'`, and TEXT/JSON with proper
    /// quote-escape doubling.
    expose func toSqlString() -> String {
        if (kind == SQL_NULL) { return "NULL"; }
        if (kind == SQL_INTEGER) { return Fmt.Int(intValue); }
        if (kind == SQL_REAL) { return textValue; }
        if (kind == SQL_TEXT) {
            return "'" + String.Replace(textValue, "'", "''") + "'";
        }
        if (kind == SQL_BLOB) { return "X'" + textValue + "'"; }
        if (kind == SQL_BOOLEAN) {
            if intValue != 0 { return "TRUE"; }
            return "FALSE";
        }
        if (kind == SQL_DATE) {
            var y = DateTime.Year(intValue);
            var m = DateTime.Month(intValue);
            var d = DateTime.Day(intValue);
            return "'" + fmtDateParts(y, m, d) + "'";
        }
        if (kind == SQL_TIMESTAMP) {
            var s = DateTime.ToLocal(intValue);
            return "'" + s + "'";
        }
        if (kind == SQL_JSON) {
            return "'" + String.Replace(textValue, "'", "''") + "'";
        }
        return "?";
    }

    /// @brief SQL three-valued comparison.
    ///
    /// Return value contract:
    ///     -1  — self <  other
    ///      0  — self == other
    ///      1  — self >  other
    ///      2  — UNKNOWN (either side is NULL, i.e. SQL three-valued
    ///           logic)
    ///
    /// The body is a matrix of cross-type cases — every pair of kinds
    /// the engine can plausibly compare gets its own branch.  The
    /// guiding principle is PostgreSQL's implicit-cast rules:
    ///
    ///   * Numeric / numeric: widen to the larger type
    ///     (INTEGER + REAL → REAL).
    ///   * Numeric / text: parse the text through `stringToInt` /
    ///     `stringToNumber`.
    ///   * DATE / TEXT, TIMESTAMP / TEXT: parse the text as a date or
    ///     timestamp.
    ///   * BOOLEAN / INTEGER: both are stored in `intValue`, so a direct
    ///     integer compare works.
    ///   * DATE ↔ TIMESTAMP: both store epoch seconds, so a direct
    ///     integer compare is semantically correct.
    ///   * JSON: equality only (returning -1 on inequality is a
    ///     deliberate "not ordered" shrug — see the flag-don't-fix note
    ///     in the header).
    ///   * Fallback: compare by `kind` tag so at least the sort is
    ///     stable.
    ///
    /// `compare` is invoked by `WHERE` predicate evaluation, `ORDER BY`
    /// sort comparators, B-tree index key comparisons, and join matchers
    /// — it is arguably the hottest function in the entire engine.  If
    /// you ever profile a slow query and see `SqlValue.compare` high,
    /// consider specialising the indexed-column type into its own
    /// fast-path (INTEGER-INTEGER is already most of it).
    expose func compare(other: SqlValue) -> Integer {
        var result = 0;

        // SQL NULL → UNKNOWN.  Callers must treat 2 as "neither true
        // nor false" and drop the row from WHERE results.
        if kind == SQL_NULL || other.kind == SQL_NULL {
            return 2;
        }

        // -------------- same-kind fast paths --------------
        if kind == SQL_INTEGER && other.kind == SQL_INTEGER {
            if intValue < other.intValue {
                result = -1;
            } else if intValue > other.intValue {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_REAL && other.kind == SQL_REAL {
            if realValue < other.realValue {
                result = -1;
            } else if realValue > other.realValue {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_TEXT && other.kind == SQL_TEXT {
            // Lexicographic codepoint compare (byte-wise on ASCII).
            // We short-circuit on full equality first to dodge the loop
            // when strings are identical — common in WHERE eqjoins on
            // VARCHAR keys.
            if textValue == other.textValue {
                result = 0;
            } else {
                var myLen = String.Length(textValue);
                var otherLen = String.Length(other.textValue);
                var minLen = myLen;
                if otherLen < minLen { minLen = otherLen; }
                var i = 0;
                var found = false;
                while i < minLen && found == false {
                    var myChar = String.Asc(String.Substring(textValue, i, 1));
                    var otherChar = String.Asc(String.Substring(other.textValue, i, 1));
                    if myChar < otherChar {
                        result = -1;
                        found = true;
                    } else if myChar > otherChar {
                        result = 1;
                        found = true;
                    }
                    i = i + 1;
                }
                // Tie on the shared prefix — whichever string is shorter
                // is the "lesser" one (standard lexicographic rule).
                if found == false {
                    if myLen < otherLen {
                        result = -1;
                    } else if myLen > otherLen {
                        result = 1;
                    } else {
                        result = 0;
                    }
                }
            }
        // -------------- cross-type numeric coercions --------------
        } else if kind == SQL_TEXT && other.kind == SQL_INTEGER {
            var myInt = stringToInt(textValue);
            if myInt < other.intValue {
                result = -1;
            } else if myInt > other.intValue {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_INTEGER && other.kind == SQL_TEXT {
            var otherInt = stringToInt(other.textValue);
            if intValue < otherInt {
                result = -1;
            } else if intValue > otherInt {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_REAL && other.kind == SQL_INTEGER {
            // Widen INTEGER → REAL.  `*1.0` is cheaper than calling a
            // conversion helper and it is what the optimizer recognises.
            var otherReal = other.intValue * 1.0;
            if realValue < otherReal {
                result = -1;
            } else if realValue > otherReal {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_INTEGER && other.kind == SQL_REAL {
            var myReal = intValue * 1.0;
            if myReal < other.realValue {
                result = -1;
            } else if myReal > other.realValue {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_REAL && other.kind == SQL_TEXT {
            var otherReal = stringToNumber(other.textValue);
            if realValue < otherReal {
                result = -1;
            } else if realValue > otherReal {
                result = 1;
            } else {
                result = 0;
            }
        } else if kind == SQL_TEXT && other.kind == SQL_REAL {
            var myReal = stringToNumber(textValue);
            if myReal < other.realValue {
                result = -1;
            } else if myReal > other.realValue {
                result = 1;
            } else {
                result = 0;
            }
        // -------------- BOOLEAN --------------
        // Booleans live in `intValue` as 0/1, so int-compare is sound
        // for both boolean/boolean and boolean/integer mixes.
        } else if kind == SQL_BOOLEAN && other.kind == SQL_BOOLEAN {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_BOOLEAN && other.kind == SQL_INTEGER {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_INTEGER && other.kind == SQL_BOOLEAN {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        // -------------- DATE / TIMESTAMP --------------
        // Both are integer-epoch; same-type compare is a direct int
        // compare.  Cross-type (DATE vs TIMESTAMP) also works by raw
        // int-compare because both use second-granular epoch values.
        } else if kind == SQL_DATE && other.kind == SQL_DATE {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_TIMESTAMP && other.kind == SQL_TIMESTAMP {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_DATE && other.kind == SQL_TIMESTAMP {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_TIMESTAMP && other.kind == SQL_DATE {
            if intValue < other.intValue { result = -1; }
            else if intValue > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_DATE && other.kind == SQL_TEXT {
            var otherDays = parseDateText(other.textValue);
            if intValue < otherDays { result = -1; }
            else if intValue > otherDays { result = 1; }
            else { result = 0; }
        } else if kind == SQL_TEXT && other.kind == SQL_DATE {
            var myDays = parseDateText(textValue);
            if myDays < other.intValue { result = -1; }
            else if myDays > other.intValue { result = 1; }
            else { result = 0; }
        } else if kind == SQL_TIMESTAMP && other.kind == SQL_TEXT {
            var otherEpoch = parseDateTimeText(other.textValue);
            if intValue < otherEpoch { result = -1; }
            else if intValue > otherEpoch { result = 1; }
            else { result = 0; }
        } else if kind == SQL_TEXT && other.kind == SQL_TIMESTAMP {
            var myEpoch = parseDateTimeText(textValue);
            if myEpoch < other.intValue { result = -1; }
            else if myEpoch > other.intValue { result = 1; }
            else { result = 0; }
        // -------------- JSON --------------
        // JSON is not totally ordered; we only support equality.
        // Returning -1 for "not equal" is the flag-don't-fix lie noted
        // in the header — callers have been careful to only test ==.
        } else if kind == SQL_JSON && other.kind == SQL_JSON {
            if textValue == other.textValue { result = 0; }
            else { result = -1; }
        } else if kind == SQL_JSON && other.kind == SQL_TEXT {
            if textValue == other.textValue { result = 0; }
            else { result = -1; }
        } else if kind == SQL_TEXT && other.kind == SQL_JSON {
            if textValue == other.textValue { result = 0; }
            else { result = -1; }
        // -------------- final fallback --------------
        // Sort by kind tag.  Not semantically meaningful, but it keeps
        // ORDER BY stable across mixed-type columns instead of
        // crashing.
        } else if kind < other.kind {
            result = -1;
        } else if kind > other.kind {
            result = 1;
        }

        return result;
    }

    /// @brief Strict equality — returns **false** when either side is
    ///        NULL (SQL default).
    expose func equals(other: SqlValue) -> Boolean {
        return compare(other) == 0;
    }

    /// @brief NULL-safe equality.  Used by UNIQUE/primary-key
    ///        enforcement and by `IS NOT DISTINCT FROM` — in those
    ///        contexts NULL == NULL must be *true*, which vanilla
    ///        `equals` would report as UNKNOWN (2 → false).
    expose func nullSafeEquals(other: SqlValue) -> Boolean {
        if kind == SQL_NULL && other.kind == SQL_NULL { return true; }
        if kind == SQL_NULL || other.kind == SQL_NULL { return false; }
        return compare(other) == 0;
    }
}

//=============================================================================
// FACTORY FUNCTIONS
//=============================================================================
//
// These are the "everyday" constructors.  Prefer them over manual
// `new SqlValue()` + init — call sites read much more naturally:
//
//     row.setValue(0, sqlInteger(42));
//     row.addValue(sqlText("hello"));
//
// All of them allocate a fresh `SqlValue`.  For hot paths that need to
// avoid allocation, reuse an existing `SqlValue` and call its `init*`
// method instead.

func sqlNull() -> SqlValue {
    var v = new SqlValue();
    v.initNull();
    return v;
}

func sqlInteger(val: Integer) -> SqlValue {
    var v = new SqlValue();
    v.initInteger(val);
    return v;
}

func sqlReal(val: Float, text: String) -> SqlValue {
    var v = new SqlValue();
    v.initReal(val, text);
    return v;
}

func sqlText(val: String) -> SqlValue {
    var v = new SqlValue();
    v.initText(val);
    return v;
}

func sqlBlob(val: String) -> SqlValue {
    var v = new SqlValue();
    v.initBlob(val);
    return v;
}

func sqlBoolean(val: Boolean) -> SqlValue {
    var v = new SqlValue();
    v.initBoolean(val);
    return v;
}

func sqlDate(daysSinceEpoch: Integer) -> SqlValue {
    var v = new SqlValue();
    v.initDate(daysSinceEpoch);
    return v;
}

func sqlTimestamp(epochSeconds: Integer) -> SqlValue {
    var v = new SqlValue();
    v.initTimestamp(epochSeconds);
    return v;
}

func sqlJson(val: String) -> SqlValue {
    var v = new SqlValue();
    v.initJson(val);
    return v;
}

func sqlArray(val: String) -> SqlValue {
    var v = new SqlValue();
    v.initArray(val);
    return v;
}

//=============================================================================
// PG-STYLE ARRAY TEXT HELPERS
//=============================================================================

/// @brief Parse a PostgreSQL text-format array literal ("{1,2,3}") into
///        its element strings.
///
/// Supports quoted elements with escaped double-quotes (`""` → `"`)
/// inside — this is enough for the SQL-standard element types the demo
/// actually uses (integers, short strings).  Does *not* yet support
/// nested arrays ("{{1,2},{3,4}}"): multidimensional arrays would need
/// a brace-depth counter added to the inQuotes state machine.  Another
/// flag-don't-fix item.
///
/// The algorithm walks the interior of the `{...}` one character at a
/// time, maintaining:
///   * `current` — the element being built.
///   * `inQuotes` — are we inside a `"..."`-quoted element?
///
/// A comma outside quotes flushes `current` into `elements` and resets.
func parseArrayElements(arrayText: String) -> List[String] {
    var elements: List[String] = [];
    var len = String.Length(arrayText);
    if len < 2 { return elements; }

    // Strip outer braces.
    var inner = String.Substring(arrayText, 1, len - 2);
    var innerLen = String.Length(inner);
    if innerLen == 0 { return elements; }

    var current = "";
    var inQuotes = false;
    var i = 0;
    while i < innerLen {
        var ch = String.Substring(inner, i, 1);
        if inQuotes {
            if ch == "\"" {
                // Look for `""` → escaped quote.  Otherwise close the
                // quoted section.
                if i + 1 < innerLen && String.Substring(inner, i + 1, 1) == "\"" {
                    current = current + "\"";
                    i = i + 2;
                    continue;
                }
                inQuotes = false;
            } else {
                current = current + ch;
            }
        } else {
            if ch == "\"" {
                inQuotes = true;
            } else if ch == "," {
                elements.add(String.Trim(current));
                current = "";
            } else {
                current = current + ch;
            }
        }
        i = i + 1;
    }
    // Flush the trailing element.  The `innerLen > 0` guard is there so
    // `"{}"` correctly produces an empty list.
    if String.Length(current) > 0 || innerLen > 0 {
        elements.add(String.Trim(current));
    }
    return elements;
}

/// @brief Inverse of `parseArrayElements`: build "{a,b,c}" from a list
///        of pre-encoded element strings.
///
/// Does not quote or escape — callers pass elements already in
/// PG-legal form.  Used when the executor turns a runtime `List[…]`
/// back into a `SqlValue` of kind SQL_ARRAY for result rendering.
func buildArrayString(elements: List[String]) -> String {
    var result = "{";
    var i = 0;
    while i < elements.count() {
        if i > 0 { result = result + ","; }
        result = result + elements.get(i);
        i = i + 1;
    }
    result = result + "}";
    return result;
}
