// =============================================================================
// database.zia — The `Database` container: tables, views, materialised views
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// A `Database` is the top-level namespace inside ViperSQL.  A single
// server typically hosts several of them ("main" is always present;
// `CREATE DATABASE foo` makes more).  Each Database owns:
//
//   * a `List[Table]`              — named tables and their rows
//                                    (schema + data in one object;
//                                    see `engine/table.zia`);
//   * two parallel lists for VIEWS — name + SQL definition.  Views
//                                    are expanded inline at query
//                                    time by the executor, so there
//                                    is no materialised state;
//   * two parallel lists for MATERIALIZED VIEWS — same shape; the
//                                    executor creates a real `Table`
//                                    next to them to hold the cached
//                                    rows after REFRESH.
//
// This file deliberately stays as simple as possible: lookups are
// linear scans over tiny lists, everything is public via `expose`,
// and there is no persistence — serialisation and page writes live
// in `storage/`.
//
// WHERE THIS FITS
// ---------------
//     engine/server.zia (DatabaseServer)
//         │  owns a List[Database], indexed by name
//         ▼
//     engine/database.zia  (YOU ARE HERE)
//         │  owns List[Table] and view lists
//         ▼
//     engine/table.zia
//
//     engine/executor.zia
//         │  on every statement, resolves tables/views via this class
//         ▼
//     (hot path: `findTable`, `findView`, `findMatView`)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Views are stored as parallel lists (name, SQL) rather than a
//      single class.  This matches the CRUD shape of the three other
//      list-y fields on the class and lets us share the view-removal
//      pattern across `dropView` / `dropMatView`.  Two parallel lists
//      are fine when both are always mutated together.
//
//   2. Views are NOT parsed at creation.  We keep the raw SQL text;
//      the executor re-parses and inlines the view body each time a
//      query references it.  That gives us free schema re-binding (a
//      view referencing `users.*` will silently track column
//      additions) at the cost of per-call parse work.  PG caches
//      parse trees; we do not yet.
//
//   3. Materialised views are *separate* from regular views.  They
//      share the same view-name + sql-body shape but the executor
//      treats them differently — a materialised view has an
//      accompanying `Table` (created lazily on first REFRESH) that
//      stores the cached result set.  Keeping the two lists separate
//      means "is this a materialised view?" is a single lookup, not
//      a branch on some kind flag.
//
//   4. "None" sentinels for lookups vary by method.  `findTable` /
//      `findView` return an object reference (nullable) or an empty
//      string, matching the shape of each callsite's needs; see the
//      per-method docs.  This mixed convention is flag-don't-fix —
//      tidying it up would ripple into every caller.
//
// HOW TO READ THIS FILE
// ---------------------
// Read the `Database` class top to bottom.  The three feature groups
// are independent — tables, views, matviews — and each follows the
// same lookup / add / drop / is-* pattern.
//
// =============================================================================

module database;

bind "./table";

//=============================================================================
// DATABASE
//=============================================================================

/// @brief Top-level namespace of tables and views.
///
/// One `Database` per logical database.  The `DatabaseServer` in
/// `engine/server.zia` keeps a list of these keyed by `name`; issuing
/// `USE foo` in the REPL just changes which `Database` the current
/// session's executor points at.
class Database {
    expose String name;
    expose List[Table] tables;
    // Views: parallel arrays of names and SQL definitions.
    expose List[String] viewNames;
    expose List[String] viewDefs;
    // Materialised views: same shape, but the executor also creates
    // a backing Table on REFRESH.
    expose List[String] matViewNames;
    expose List[String] matViewDefs;

    /// @brief Default init: the "default" database, empty of tables
    ///        and views.  Mostly placeholder — nearly every caller
    ///        uses `initWithName` immediately afterwards.
    expose func init() {
        name = "default";
        tables = [];
        viewNames = [];
        viewDefs = [];
        matViewNames = [];
        matViewDefs = [];
    }

    /// @brief Init with a caller-chosen name.  The canonical entry
    ///        point used by `makeDatabase` and by the server when it
    ///        processes CREATE DATABASE.
    expose func initWithName(dbName: String) {
        name = dbName;
        tables = [];
        viewNames = [];
        viewDefs = [];
        matViewNames = [];
        matViewDefs = [];
    }

    /// @brief Number of tables registered.  Does not count views.
    expose func tableCount() -> Integer {
        return tables.count();
    }

    /// @brief Positional table access.  Null on out-of-range; used
    ///        by catalog scans (pg_class, information_schema.tables).
    expose func getTable(index: Integer) -> Table? {
        if index < 0 || index >= tables.count() {
            return null;
        }
        return tables.get(index);
    }

    /// @brief Linear name lookup for a table.  Null if missing — the
    ///        hot path (executor) turns that into a "relation does
    ///        not exist" error.
    expose func findTable(tableName: String) -> Table? {
        var i = 0;
        while i < tables.count() {
            var t = tables.get(i);
            if t.name == tableName {
                return t;
            }
            i = i + 1;
        }
        return null;
    }

    /// @brief Register a table.  No duplicate check here — DDL
    ///        catches collisions before reaching us.
    expose func addTable(table: Table) {
        tables.add(table);
    }

    /// @brief Remove a table by name.  Returns true if we removed
    ///        something — DROP TABLE IF EXISTS tolerates false.
    expose func dropTable(tableName: String) -> Boolean {
        var i = 0;
        while i < tables.count() {
            if tables.get(i).name == tableName {
                tables.removeAt(i);
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    //-------------------------------------------------------------------------
    // VIEWS
    //-------------------------------------------------------------------------

    /// @brief Register a view.  Again no duplicate check — DDL
    ///        ("CREATE VIEW ... IF NOT EXISTS" / plain CREATE)
    ///        takes responsibility.
    expose func addView(viewName: String, sql: String) {
        viewNames.add(viewName);
        viewDefs.add(sql);
    }

    /// @brief Return the SQL text of a view, or empty string if no
    ///        such view exists.
    ///
    /// The empty-string sentinel (rather than `String?`) is a
    /// simplification that only works because "" is never a legal
    /// view body in SQL — a query would be rejected long before
    /// reaching here.
    expose func findView(viewName: String) -> String {
        var i = 0;
        while i < viewNames.count() {
            if viewNames.get(i) == viewName {
                return viewDefs.get(i);
            }
            i = i + 1;
        }
        return "";
    }

    /// @brief DROP VIEW.  Pulls both parallel lists in lockstep so
    ///        they cannot drift.
    expose func dropView(viewName: String) -> Boolean {
        var i = 0;
        while i < viewNames.count() {
            if viewNames.get(i) == viewName {
                viewNames.removeAt(i);
                viewDefs.removeAt(i);
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief "Is this name a view?"  Used by the executor to decide
    ///        whether to expand a FROM clause through `findView`
    ///        before trying the table list.
    expose func isView(name: String) -> Boolean {
        var i = 0;
        while i < viewNames.count() {
            if viewNames.get(i) == name {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    //-------------------------------------------------------------------------
    // MATERIALIZED VIEWS
    //-------------------------------------------------------------------------
    //
    // Same shape as the view registry, plus the executor is
    // responsible for creating an accompanying `Table` on REFRESH
    // MATERIALIZED VIEW.  This registry only stores the name and the
    // defining SQL — the cached rows live in the normal table list.

    expose func addMatView(viewName: String, sql: String) {
        matViewNames.add(viewName);
        matViewDefs.add(sql);
    }

    /// @brief Matview SQL text or "" if not found.  Same sentinel
    ///        convention as `findView`.
    expose func findMatView(viewName: String) -> String {
        var i = 0;
        while i < matViewNames.count() {
            if matViewNames.get(i) == viewName {
                return matViewDefs.get(i);
            }
            i = i + 1;
        }
        return "";
    }

    /// @brief DROP MATERIALIZED VIEW.  See `dropView` for the
    ///        parallel-list rationale.
    expose func dropMatView(viewName: String) -> Boolean {
        var i = 0;
        while i < matViewNames.count() {
            if matViewNames.get(i) == viewName {
                matViewNames.removeAt(i);
                matViewDefs.removeAt(i);
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief Membership predicate.  Symmetric to `isView`.
    expose func isMatView(name: String) -> Boolean {
        var i = 0;
        while i < matViewNames.count() {
            if matViewNames.get(i) == name {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief "\n"-joined list of table names.  Used by the REPL's
    ///        `.tables` meta-command and by SHOW TABLES.
    expose func listTables() -> String {
        var result = "";
        var i = 0;
        while i < tables.count() {
            if i > 0 {
                result = result + "\n";
            }
            result = result + tables.get(i).name;
            i = i + 1;
        }
        return result;
    }
}

/// @brief Named-database factory matching the `makeTable` /
///        `makeColumn` style used across the engine.
func makeDatabase(name: String) -> Database {
    var db = new Database();
    db.initWithName(name);
    return db;
}
