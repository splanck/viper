// =============================================================================
// table.zia — The in-memory `Table` object that ties columns to rows
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// A `Table` is the live, working-memory representation of a SQL table:
// a name, a `List[Column]` describing its schema, and a `List[Row]` of
// its current data.  Tables are owned by the `Database` object (see
// `engine/database.zia`) and persisted via the storage layer
// (`storage/engine.zia`).  This file defines the *shape* and the small
// query-helper methods; it deliberately contains no planning, no
// execution, no I/O.
//
// The file also carries the bookkeeping fields for two richer SQL
// features — table partitioning (Phase 28: RANGE / LIST / HASH) and
// table inheritance (Phase 52, PostgreSQL-style).  Those fields are
// inert on plain tables; DDL sets them when a CREATE TABLE ... PARTITION
// BY or CREATE TABLE ... INHERITS clause is parsed.
//
// WHERE THIS FITS
// ---------------
//     ./schema.zia      ──► Column, Row (already annotated)
//                             │
//                             ▼
//     ./table.zia  (YOU ARE HERE)
//                             │
//                             ▼
//     ./database.zia    ──► owns a `List[Table]` keyed by name
//                             │
//                             ▼
//     ./executor.zia    ──► reads/writes tables while running SQL
//                             │
//                             ▼
//     storage/engine.zia ─► serialises tables to schema+data pages
//
// KEY DESIGN CHOICES
// ------------------
//   1. One list of rows, soft-delete in place.  Deleted rows are not
//      removed from `rows`; they are flipped to `deleted = true` via
//      `deleteRow`.  Benefits: SELECTs can still see the old row under
//      MVCC, and B-tree index RIDs (row indices) stay valid.  Cost:
//      `rows.count()` is NOT the number of live rows.  VACUUM later
//      compacts, assigns new RIDs, and rebuilds indexes.
//
//   2. `autoIncrementValue` lives on the table itself, not a side
//      table.  One INSERT → one increment.  When the engine persists,
//      the current value is written into the table's schema page so a
//      restart resumes the sequence.  The name is slightly misleading
//      — this is really the *next* value to hand out (see
//      `nextAutoIncrement`).
//
//   3. Partition and inheritance bookkeeping is flat.  Rather than
//      subclass Table into `PartitionedTable` / `PartitionChild` /
//      `InheritingTable`, all three feature states live as fields on
//      every Table.  This keeps `Database.tables` homogeneously-typed
//      and means DDL can flip a plain table into a partition by
//      setting three fields — no type conversion dance.
//
//   4. `insertRow` validates arity, not types.  DDL's NOT NULL /
//      CHECK / FK enforcement happens in the DML layer
//      (`engine/dml.zia::executeInsert`) before we get here; this
//      path only catches the cheap structural error "wrong number of
//      values".  That separation keeps the `Table` object honest and
//      test-friendly.
//
//   5. Lookup by name is O(N).  `findColumnIndex` is a linear scan.
//      Good enough because tables almost always have fewer than 50
//      columns.  Building a per-table name→index map would save a few
//      microseconds per column lookup but complicate schema mutation
//      (ALTER TABLE ADD COLUMN) — not worth it for a demo-grade
//      engine.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. The `Table` class declaration and its init pair are the
//      structural contract.
//   2. The column helpers (`addColumn`, `findColumnIndex`,
//      `getColumnByName`) show how DDL builds a table up one column at
//      a time.
//   3. The row helpers (`addRow`, `deleteRow`, `createRow`,
//      `insertRow`) are what DML calls.
//   4. `schemaString` is used by SHOW CREATE TABLE and by the smoke
//      probes — it is how you get a round-trippable DDL rendering.
//
// =============================================================================

module table;

// Fmt for column/row count rendering in `toString`.
// `types` / `schema` define `SqlValue`, `Column`, `Row` which appear in
// every method signature below.
bind Viper.Fmt as Fmt;
bind "./types";
bind "./schema";

//=============================================================================
// TABLE
//=============================================================================

/// @brief Live in-memory representation of a SQL table.
///
/// Combines schema (columns) and data (rows) into one object.  The
/// engine never consults columns or rows independently — they are
/// always accessed through the same `Table` instance — which is why
/// splitting them into two objects would only add ceremony.
///
/// Fields divide into four groups:
///   * core        : `name`, `columns`, `rows`, `autoIncrementValue`
///   * partition   : all `is*Partition*` / `part*` / `partition*`
///   * inheritance : all `inherit*` / `isInherited` / `hasChildren`
///
/// Core fields are always populated; partition and inheritance fields
/// are meaningful only when the corresponding flag is true.
class Table {
    expose String name;
    expose List[Column] columns;
    expose List[Row] rows;
    // NEXT value handed out by AUTOINCREMENT, not the last one used.
    // Starts at 1 (conventional in SQL) and monotonically rises.
    expose Integer autoIncrementValue;

    // Partition metadata (Phase 28).
    // `isPartitioned` marks a *parent* table; `isPartition` marks a
    // *child* table.  The two flags are mutually exclusive on the
    // same Table object.
    expose Boolean isPartitioned;
    expose Integer partitionType;           // PARTITION_RANGE / LIST / HASH (from types.zia)
    expose String partitionColumn;          // column name used as the key
    expose List[String] partitionChildren;  // parent-only: names of its partitions
    expose Boolean isPartition;             // child-only flag
    expose String partitionParent;          // child-only: back-pointer name
    expose String partRangeFromStr;         // RANGE child: lower bound ("1", "2020-01-01", ...)
    expose String partRangeToStr;           // RANGE child: upper bound (exclusive)
    expose List[String] partListValues;     // LIST child: allowed key values
    expose Integer partHashModulus;         // HASH child: divisor (total partitions)
    expose Integer partHashRemainder;       // HASH child: this partition's remainder

    // Inheritance metadata (Phase 52, PostgreSQL-style).
    // Again, `hasChildren` and `isInherited` are the parent/child
    // complement.  Inheritance and partitioning can coexist on the
    // same Table but that combination is uncommon and not exercised
    // by smoke_probe.zia.
    expose Boolean hasChildren;
    expose List[String] inheritChildren;
    expose Boolean isInherited;
    expose String inheritParent;

    /// @brief Blank-slate init.
    ///
    /// Preserves the invariant that every field has a defined zero
    /// state — so that code reading any of the partition / inheritance
    /// fields on a plain Table sees falsy defaults rather than
    /// uninitialised junk.
    expose func init() {
        name = "";
        columns = [];
        rows = [];
        autoIncrementValue = 1;
        isPartitioned = false;
        partitionType = 0;
        partitionColumn = "";
        partitionChildren = [];
        isPartition = false;
        partitionParent = "";
        partRangeFromStr = "";
        partRangeToStr = "";
        partListValues = [];
        partHashModulus = 0;
        partHashRemainder = 0;
        hasChildren = false;
        inheritChildren = [];
        isInherited = false;
        inheritParent = "";
    }

    /// @brief Init with a known name; everything else defaulted.
    ///
    /// Called by `makeTable(name)` and by `engine/ddl.zia` when
    /// CREATE TABLE fires.  The caller then adds columns via
    /// `addColumn` in the order they appeared in the DDL — that order
    /// becomes the positional order used everywhere else in the engine.
    expose func initWithName(tableName: String) {
        name = tableName;
        columns = [];
        rows = [];
        autoIncrementValue = 1;
        isPartitioned = false;
        partitionType = 0;
        partitionColumn = "";
        partitionChildren = [];
        isPartition = false;
        partitionParent = "";
        partRangeFromStr = "";
        partRangeToStr = "";
        partListValues = [];
        partHashModulus = 0;
        partHashRemainder = 0;
        hasChildren = false;
        inheritChildren = [];
        isInherited = false;
        inheritParent = "";
    }

    /// @brief Column count.  Shallow wrapper over `columns.count()`.
    expose func columnCount() -> Integer {
        return columns.count();
    }

    /// @brief Total row slot count — including soft-deleted rows.
    ///
    /// NOTE: use this *only* when you want the raw capacity (e.g. for
    /// allocating an index bitmap).  SELECT-visible counts go through
    /// the MVCC / soft-delete filter in `engine/executor.zia`.
    expose func rowCount() -> Integer {
        return rows.count();
    }

    /// @brief Append a column to the schema.
    ///
    /// Preserves insertion order — the positional index here is what
    /// rows use to address their cells later.
    expose func addColumn(col: Column) {
        columns.add(col);
    }

    /// @brief Bounds-checked column fetch.  Returns null on out-of-range
    ///        so callers can distinguish "no such column" without
    ///        trapping.
    expose func getColumn(index: Integer) -> Column? {
        if index < 0 || index >= columns.count() {
            return null;
        }
        return columns.get(index);
    }

    /// @brief Linear lookup from column *name* to positional index.
    ///
    /// Returns -1 if not found — callers commonly treat that as the
    /// "unknown column" sentinel and raise a parse/plan-time error.
    /// Tables are small enough (typically <50 columns) that an O(N)
    /// scan beats a hash map for cache friendliness; see design note
    /// (5) in the header.
    expose func findColumnIndex(colName: String) -> Integer {
        var i = 0;
        while i < columns.count() {
            if columns.get(i).name == colName {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Convenience: name → `Column?` in one call.
    ///
    /// Composes `findColumnIndex` + `columns.get`.  The null return is
    /// propagated; callers use `!` to unwrap when they know the name
    /// came from a validated plan.
    expose func getColumnByName(colName: String) -> Column? {
        var idx = findColumnIndex(colName);
        if idx < 0 {
            return null;
        }
        return columns.get(idx);
    }

    /// @brief Append a row.  No validation — callers must have checked
    ///        the row's arity against `columnCount()` first.
    ///
    /// The DML layer (`dml.zia::executeInsert`) runs all constraint
    /// checks *before* invoking `addRow`, so errors fail the statement
    /// without corrupting the table.
    expose func addRow(row: Row) {
        rows.add(row);
    }

    /// @brief Bounds-checked row fetch.  Null on out-of-range.
    ///
    /// Called by UPDATE/DELETE executors that iterate row indices they
    /// got from an index scan.  A null here means the index is stale
    /// (row was VACUUMed) — caller treats that as "skip this tuple".
    expose func getRow(index: Integer) -> Row? {
        if index < 0 || index >= rows.count() {
            return null;
        }
        return rows.get(index);
    }

    /// @brief Soft-delete the row at `index` (set `deleted = true`).
    ///
    /// We keep the row slot — see design choice (1) in the header.
    /// Returns false if the index was out of range so the DELETE
    /// executor can report "0 rows affected" honestly rather than
    /// silently succeeding.
    expose func deleteRow(index: Integer) -> Boolean {
        if index < 0 || index >= rows.count() {
            return false;
        }
        var row = rows.get(index);
        row.deleted = true;
        return true;
    }

    /// @brief Wipe the row buffer without touching schema.
    ///
    /// Used by `TRUNCATE` and by test setup/teardown to reset a table
    /// to empty between cases.  Does NOT reset `autoIncrementValue`
    /// (TRUNCATE in Postgres also preserves it unless RESTART IDENTITY
    /// is given — we match that default).
    expose func clearAllRows() {
        rows = [];
    }

    /// @brief Post-increment: return the current value, then bump.
    ///
    /// Chosen over a pre-increment API because SQL AUTOINCREMENT is
    /// "first row gets 1" — the caller substitutes the returned value
    /// directly into its INSERT without any -1 fixup.
    expose func nextAutoIncrement() -> Integer {
        var val = autoIncrementValue;
        autoIncrementValue = autoIncrementValue + 1;
        return val;
    }

    /// @brief Allocate a row with the right arity, pre-filled with
    ///        NULLs.
    ///
    /// DML uses this as the starting point for building a row from a
    /// VALUES list: it creates a NULL-filled row, then writes each
    /// supplied column.  Columns left NULL pick up their DEFAULT (or
    /// raise a NOT NULL error) in the subsequent `applyDefaults` pass.
    expose func createRow() -> Row {
        var row = new Row();
        row.initWithCount(columns.count());
        return row;
    }

    /// @brief Insert a row straight from an ordered `List[SqlValue]`.
    ///
    /// Returns false on arity mismatch.  Does not copy the input list
    /// — the caller must not mutate `values` after the call.  This is
    /// the cheapest possible insert path and is used mainly by the
    /// storage-rehydration code, where the list is freshly-built from
    /// bytes and will not be touched again.
    expose func insertRow(values: List[SqlValue]) -> Boolean {
        if values.count() != columns.count() {
            return false;
        }
        var row = new Row();
        row.init();
        var i = 0;
        while i < values.count() {
            row.addValue(values.get(i));
            i = i + 1;
        }
        rows.add(row);
        return true;
    }

    /// @brief Render a CREATE TABLE statement equivalent to this
    ///        table's schema.
    ///
    /// Used by the `SHOW CREATE TABLE` REPL command, by smoke probes
    /// that want to assert round-trippability, and by any path that
    /// needs to dump a schema for human or machine re-parsing.
    /// Produces no trailing newline.
    expose func schemaString() -> String {
        var result = "CREATE TABLE " + name + " (\n";
        var i = 0;
        while i < columns.count() {
            if i > 0 {
                result = result + ",\n";
            }
            result = result + "  " + columns.get(i).toString();
            i = i + 1;
        }
        result = result + "\n);";
        return result;
    }

    /// @brief One-line summary used in debug logs and `.tables` output.
    expose func toString() -> String {
        var numCols = columns.count();
        var numRows = rows.count();
        var colStr = Fmt.Int(numCols);
        var rowStr = Fmt.Int(numRows);
        var result = "Table: " + name + " (" + colStr + " cols, " + rowStr + " rows)";
        return result;
    }
}

/// @brief Module-level factory.  One-liner that matches the
///        `makeColumn`/`makeRow` style from `schema.zia`.
///
/// Prefer this in DDL / test code — `makeTable("users")` reads more
/// naturally than constructing and initialising by hand.
func makeTable(name: String) -> Table {
    var table = new Table();
    table.initWithName(name);
    return table;
}
