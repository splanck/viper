// =============================================================================
// session.zia ŌĆö Per-connection state: Session, PreparedStatement, Portal
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// A `Session` is what the server creates when a client connects and
// tears down when the client disconnects.  It owns three things:
//
//   1. Identity & bookkeeping ŌĆö session id, client host, username,
//      whether authentication has passed, a running query counter.
//
//   2. An `Executor` ŌĆö the object that actually runs SQL.  Each
//      session gets its *own* executor so per-session state
//      (transaction status, current database, search_path, set-local
//      variables) cannot leak between clients.  The executor's
//      databases, however, are *shared* via the `DatabaseServer`
//      (see `engine/server.zia`), which is how two concurrent
//      sessions can see each other's committed data.
//
//   3. PostgreSQL extended-query-protocol state ŌĆö `PreparedStatement`
//      and `Portal` registries.  The PG wire protocol allows a client
//      to parse a statement once, name it, then execute it many times
//      with different parameters.  A Portal is a named "execution in
//      progress" that can be stepped a row at a time.  Both are
//      addressed by an ASCII name; the empty string is the convention
//      for the single unnamed statement / portal.
//
// WHERE THIS FITS
// ---------------
//     server/connection.zia
//         Ōöé  builds a Session on accept and stashes it on the
//         Ōöé  connection.
//         Ō¢╝
//     engine/session.zia  (YOU ARE HERE)
//         Ōöé  forwards executeSql() to its Executor, looks up prepared
//         Ōöé  statements and portals on the PG-wire path.
//         Ō¢╝
//     engine/executor.zia
//
// KEY DESIGN CHOICES
// ------------------
//   1. One Executor per session, shared databases via DatabaseServer.
//      This is the cheapest way to get multi-user concurrency without
//      introducing a full lock manager on a single Executor ŌĆö each
//      session has its own transaction cursor, the underlying tables
//      and pagers are shared under the MVCC regime (see `txn.zia`).
//
//   2. Prepared statements live in a flat `List`, not a map.  There
//      are rarely more than a few active per session and PG clients
//      tend to reuse the unnamed one ŌĆö a linear scan through a
//      three-element list is nearly free, and it saves us a hash
//      dependency.  Same reasoning for portals.
//
//   3. `clearPortals` is called at transaction end, not at session
//      end.  Prepared statements *survive* a transaction (they can be
//      EXECUTEd in a new transaction); portals cannot, because a
//      portal holds row cursors over possibly-rolled-back state.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `PreparedStatement` and `Portal` ŌĆö the two tiny data-only
//      classes used by the PG wire layer.
//   2. `Session` ŌĆö identity, executor ownership, and the registries.
//   3. Registry helpers come in two flavours: `find*`, `add*`,
//      `remove*` ŌĆö all simple linear scans.
//
// =============================================================================

module session;

bind Viper.Fmt as Fmt;
bind Viper.String as String;
bind "./executor";
bind "./server";
bind "./result";

//=============================================================================
// PREPARED STATEMENT (PG extended-query protocol, Phase 11)
//=============================================================================

/// @brief A parsed-but-not-yet-executed statement, addressable by name.
///
/// When a client sends a `Parse` message over the PG wire protocol, we
/// store the resulting `PreparedStatement` on the session; later
/// `Bind`/`Execute` messages reference it by `name`.  The empty string
/// is the special "unnamed" statement slot that clients tend to reuse
/// for one-shot queries.
///
/// `paramCount` is derived from the number of `$N` placeholders the
/// parser found; `paramOids` is the client's optional type annotation
/// (OID 0 = "infer").  The query text is kept raw ŌĆö substitution
/// happens at Bind time in `server/pg_wire.zia`.
class PreparedStatement {
    expose String name;             // "" = unnamed statement slot
    expose String query;            // original SQL with $1, $2, ... intact
    expose Integer paramCount;      // count of $N placeholders
    expose List[Integer] paramOids; // 0 per slot means "unspecified"

    /// @brief Blank-state initialiser.  The wire layer populates all
    ///        four fields immediately after construction.
    expose func init() {
        name = "";
        query = "";
        paramCount = 0;
        paramOids = [];
    }
}

//=============================================================================
// PORTAL (PG extended-query protocol, Phase 11)
//=============================================================================

/// @brief A bound, partially-executed statement.
///
/// When a client sends a `Bind` message, the server substitutes
/// parameter values into the statement and stores the bound SQL plus
/// its execution state in a `Portal`.  An Execute can then pull rows
/// from the cached `result` one batch at a time ("execute for 100
/// rows" is a legal wire-level request), and re-entries use
/// `rowsSent` to know where they left off.
///
/// `descSent` guards against double-sending `RowDescription` on
/// successive Execute messages against the same portal.
class Portal {
    expose String name;             // "" = unnamed portal
    expose String stmtName;         // which prepared stmt we bound
    expose String boundQuery;       // SQL with parameters substituted
    expose QueryResult result;      // null until first Execute runs
    expose Boolean executed;        // has Execute been called yet?
    expose Integer rowsSent;        // cursor index into result.rows
    expose Boolean descSent;        // has RowDescription been sent?

    /// @brief Zero-state initialiser.  `result` is intentionally left
    ///        uninitialised ŌĆö it is overwritten on first Execute and
    ///        accessing it before then is a protocol error the wire
    ///        layer catches.
    expose func init() {
        name = "";
        stmtName = "";
        boundQuery = "";
        executed = false;
        rowsSent = 0;
        descSent = false;
    }
}

//=============================================================================
// SESSION
//=============================================================================

/// @brief One logical connection's worth of state.
///
/// Created by the connection handler on accept and discarded on
/// disconnect.  Forwards `executeSql` to the owned `Executor`, which
/// does the actual work.  The session layer's *own* value-add is
/// (a) identifying the client, (b) counting queries for observability,
/// and (c) holding the extended-query registries.
class Session {
    expose Integer sessionId;       // monotonic id assigned by the server
    expose String clientHost;       // "127.0.0.1", "[::1]", hostname, ...
    expose String username;
    expose Boolean authenticated;
    expose Integer queryCount;

    // Owned executor.  Carries transaction state, subquery stack, the
    // current database pointer, GUC overrides, etc.
    expose Executor executor;

    // Extended-query-protocol registries.  Both are tiny per-session
    // lists; see note (2) in the header on why we skip a hash map.
    expose List[PreparedStatement] preparedStmts;
    expose List[Portal] portals;

    /// @brief Zero-state init ŌĆö before `initWithServer` wires the
    ///        executor.  Useful only as a pre-step to the real init.
    expose func init() {
        sessionId = 0;
        clientHost = "";
        username = "";
        authenticated = false;
        queryCount = 0;
        preparedStmts = [];
        portals = [];
    }

    /// @brief Wire up a session attached to the shared DatabaseServer.
    ///
    /// This is the normal construction path.  Creates a fresh
    /// Executor, binds it to `server` (so it sees the shared catalog
    /// of databases), and pins the session id for log/trace
    /// correlation.
    expose func initWithServer(id: Integer, host: String, server: DatabaseServer) {
        sessionId = id;
        clientHost = host;
        username = "";
        authenticated = false;
        queryCount = 0;
        executor = new Executor();
        executor.initWithServer(server, sessionId);
        preparedStmts = [];
        portals = [];
    }

    /// @brief One-line identifier used in server logs.
    expose func toString() -> String {
        return "Session[" + Fmt.Int(sessionId) + "] " + clientHost + " user=" + username + " db=" + executor.currentDbName;
    }

    /// @brief Run a SQL string through the owned executor.
    ///
    /// The only thing this layer adds is the `queryCount` bump ŌĆö the
    /// actual parsing, planning, and execution happens in the
    /// `Executor`.  Centralising counter maintenance here keeps the
    /// executor focused on SQL semantics.
    expose func executeSql(sql: String) -> QueryResult {
        queryCount = queryCount + 1;
        return executor.executeSql(sql);
    }

    /// @brief Release per-session resources at disconnect time.
    ///
    /// Right now this drops temporary tables ŌĆö real tables are shared
    /// and stay.  Extend here if you add anything else with
    /// per-session lifetime (e.g. advisory locks, pg_temp schema
    /// cleanup).
    expose func disconnect() {
        executor.cleanupTempTables();
    }

    //=========================================================================
    // PREPARED STATEMENT REGISTRY
    //=========================================================================

    /// @brief Linear scan for a prepared statement by name.
    ///
    /// Returns null if not found ŌĆö the wire layer turns that into an
    /// `ErrorResponse` with SQLSTATE 26000 ("invalid_sql_statement_name").
    expose func findPreparedStmt(name: String) -> PreparedStatement? {
        var i = 0;
        while i < preparedStmts.count() {
            var stmt = preparedStmts.get(i);
            if stmt.name == name {
                return stmt;
            }
            i = i + 1;
        }
        return null;
    }

    /// @brief Append a prepared statement.  Does not check for a
    ///        duplicate name ŌĆö the wire layer is supposed to
    ///        `CLOSE` first per the PG protocol spec.
    expose func addPreparedStmt(stmt: PreparedStatement) {
        preparedStmts.add(stmt);
    }

    /// @brief Remove a prepared statement by name.  Silent if not
    ///        found ŌĆö the PG `Close` message is idempotent.
    expose func removePreparedStmt(name: String) {
        var i = 0;
        while i < preparedStmts.count() {
            if preparedStmts.get(i).name == name {
                preparedStmts.removeAt(i);
                return;
            }
            i = i + 1;
        }
    }

    //=========================================================================
    // PORTAL REGISTRY
    //=========================================================================

    /// @brief Linear scan for a portal by name.  Null if unknown.
    expose func findPortal(name: String) -> Portal? {
        var i = 0;
        while i < portals.count() {
            var portal = portals.get(i);
            if portal.name == name {
                return portal;
            }
            i = i + 1;
        }
        return null;
    }

    /// @brief Append a portal.  See `addPreparedStmt` for the
    ///        deliberate lack of duplicate checking.
    expose func addPortal(portal: Portal) {
        portals.add(portal);
    }

    /// @brief Remove a portal by name.  Idempotent.
    expose func removePortal(name: String) {
        var i = 0;
        while i < portals.count() {
            if portals.get(i).name == name {
                portals.removeAt(i);
                return;
            }
            i = i + 1;
        }
    }

    /// @brief Drop all portals.  Called at transaction boundaries
    ///        because a portal can be pointing at a cursor over rows
    ///        that no longer exist after COMMIT/ROLLBACK.  Prepared
    ///        statements survive and are not touched here.
    expose func clearPortals() {
        portals = [];
    }
}
