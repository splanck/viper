// =============================================================================
// sequence.zia тАФ PostgreSQL-style SEQUENCE objects
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// This file implements named integer sequences тАФ persistent counters
// that hand out unique values on demand.  Every SQL flavour has them
// in some form; ViperSQL models PostgreSQL's:
//
//     CREATE SEQUENCE orders_id_seq
//         START WITH 1 INCREMENT BY 1
//         MINVALUE 1 MAXVALUE 2147483647
//         NO CYCLE;
//
//     SELECT nextval('orders_id_seq');
//     SELECT currval('orders_id_seq');
//     SELECT setval('orders_id_seq', 42);
//
// Two classes live here: `Sequence` (one counter) and `SequenceManager`
// (a registry of sequences, owned by each `Database`).
//
// WHERE THIS FITS
// ---------------
//   engine/ddl.zia   тФАтФАтЦ║ calls `SequenceManager.addSequence` for
//                        CREATE SEQUENCE and `dropSequence` for DROP.
//
//   engine/executor.zia / sql_functions.zia
//                    тФАтФАтЦ║ invokes `Sequence.nextVal` / `currVal` /
//                        `setVal` when it evaluates the SQL
//                        `nextval()` / `currval()` / `setval()` calls.
//
//   engine/database.zia
//                    тФАтФАтЦ║ owns a `SequenceManager` per database.
//
// KEY DESIGN CHOICES
// ------------------
//   1. `called` is the pre-first-NEXTVAL flag.  The convention is:
//        * First NEXTVAL returns `startValue` (or whatever a prior
//          `setVal` left in `currentValue`) without advancing.
//        * Subsequent NEXTVALs increment first, then return.
//      `called` is what lets us tell the two phases apart with one
//      extra bit per sequence.
//
//   2. We use `SEQ_ERROR_SENTINEL = -2147483647` rather than a
//      separate success/error return.  Rationale: the in-band sentinel
//      lets the SQL functions in `sql_functions.zia` compare the
//      returned Integer directly and translate it into a NULL or an
//      error without needing a tuple return.  This is a small
//      engineering debt тАФ a real SQL engine would use an out-param or
//      a two-field return тАФ but it keeps the function signature
//      trivial.
//
//   3. Sequences are stored in a flat list, not a map.  Sequence
//      lookups happen per `nextval()` call; typical workloads have
//      maybe a handful of sequences, not thousands.  O(N) wins on
//      cache locality.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `Sequence` тАФ the counter itself: config fields, plus the three
//      mutators (`nextVal`, `currVal`, `setVal`).
//   2. `SEQ_ERROR_SENTINEL` тАФ shared error magic.
//   3. `SequenceManager` тАФ the registry; CRUD over the list of
//      sequences.
//
// =============================================================================

module sequence;

bind Viper.Fmt as Fmt;

//=============================================================================
// SEQUENCE
//=============================================================================

/// @brief One named integer sequence.
///
/// Configuration fields (`startValue`, `incrementBy`, `minValue`,
/// `maxValue`, `cycle`) capture the CREATE SEQUENCE options; the
/// runtime fields (`currentValue`, `called`) carry the counter state.
/// `incrementBy` can be negative for descending sequences.
class Sequence {
    expose String name;
    expose Integer currentValue;
    expose Integer startValue;
    expose Integer incrementBy;
    expose Integer minValue;
    expose Integer maxValue;
    expose Boolean cycle;      // wrap at boundary vs. raise error
    expose Boolean called;     // has nextVal been called yet?

    /// @brief Default init: a standard 1-to-2147483647 ascending
    ///        non-cycling sequence.  The name is left blank because
    ///        `initWithName` is the normal entry point.
    expose func init() {
        name = "";
        currentValue = 1;
        startValue = 1;
        incrementBy = 1;
        minValue = 1;
        maxValue = 2147483647;  // ~2^31, PG default for INTEGER column seq
        cycle = false;
        called = false;
    }

    /// @brief Same defaults as `init`, but named.  Used by CREATE
    ///        SEQUENCE with only a name.
    expose func initWithName(seqName: String) {
        name = seqName;
        currentValue = 1;
        startValue = 1;
        incrementBy = 1;
        minValue = 1;
        maxValue = 2147483647;
        cycle = false;
        called = false;
    }

    /// @brief Full init used by the DDL executor after parsing all
    ///        options.  Notice how `currentValue` is seeded from
    ///        `start` тАФ first `nextVal` returns it unchanged.
    expose func initFull(seqName: String, start: Integer, incr: Integer,
                         minVal: Integer, maxVal: Integer, doCycle: Boolean) {
        name = seqName;
        startValue = start;
        currentValue = start;
        incrementBy = incr;
        minValue = minVal;
        maxValue = maxVal;
        cycle = doCycle;
        called = false;
    }

    /// @brief Advance the sequence and return the new value.
    ///
    /// Three-state machine:
    ///
    ///   1. `called == false` (fresh sequence or post-setVal reset):
    ///      return `currentValue` as-is, set `called`.  No advance.
    ///
    ///   2. Ascending (`incrementBy > 0`): compute `next = current +
    ///      incr`.  If it would exceed `maxValue`:
    ///         * CYCLE: wrap to `minValue`.
    ///         * NO CYCLE: return `SEQ_ERROR_SENTINEL`.
    ///
    ///   3. Descending: mirror image тАФ wrap to `maxValue` or error at
    ///      `minValue`.
    ///
    /// Why not raise an exception on exhaustion?  The SQL function
    /// that calls this (`sql_functions.zia::sqlNextval`) wraps the
    /// result into a QueryResult with a friendly error message тАФ that
    /// layer is the right place for SQL-level error semantics.
    expose func nextVal() -> Integer {
        if called == false {
            called = true;
            return currentValue;
        }

        var nextV = currentValue + incrementBy;

        if incrementBy > 0 {
            // Ascending.
            if nextV > maxValue {
                if cycle {
                    nextV = minValue;
                } else {
                    return 0 - 2147483647;  // SEQ_ERROR_SENTINEL, inlined
                }
            }
        } else {
            // Descending.
            if nextV < minValue {
                if cycle {
                    nextV = maxValue;
                } else {
                    return 0 - 2147483647;
                }
            }
        }

        currentValue = nextV;
        return currentValue;
    }

    /// @brief Return the last value handed out by NEXTVAL, without
    ///        advancing.
    ///
    /// PG semantics: CURRVAL is a session-level operation and errors
    /// if no NEXTVAL has been called in the current session.  We
    /// approximate that with the per-sequence `called` flag тАФ good
    /// enough for a single-session engine, imperfect for concurrent
    /// sessions sharing one sequence (they will both see the last
    /// value written by either).  Flag-don't-fix.
    expose func currVal() -> Integer {
        if called == false {
            return 0 - 2147483647;
        }
        return currentValue;
    }

    /// @brief Reseed the counter.
    ///
    /// If `isCalled = true`, the next NEXTVAL will advance before
    /// returning (matches PG's `setval(seq, 5)`: next value is 6).  If
    /// `isCalled = false` тАФ equivalent to PG's `setval(seq, 5, false)`
    /// тАФ the next NEXTVAL returns 5 unchanged.
    expose func setVal(newVal: Integer, isCalled: Boolean) {
        currentValue = newVal;
        called = isCalled;
    }

    /// @brief Debug / SHOW SEQUENCES output.
    ///
    /// Not on the wire-protocol path: clients get sequences through
    /// `pg_catalog.pg_sequence` system-view queries (see
    /// `engine/system_views.zia`).
    expose func toString() -> String {
        var result = "SEQUENCE " + name + " (current=" + Fmt.Int(currentValue);
        result = result + ", start=" + Fmt.Int(startValue);
        result = result + ", increment=" + Fmt.Int(incrementBy);
        result = result + ", min=" + Fmt.Int(minValue);
        result = result + ", max=" + Fmt.Int(maxValue);
        if cycle {
            result = result + ", CYCLE";
        } else {
            result = result + ", NO CYCLE";
        }
        result = result + ")";
        return result;
    }
}

//=============================================================================
// SEQUENCE MANAGER
//=============================================================================

/// @brief Sentinel returned by nextVal / currVal when a sequence is
///        exhausted or has never been called.
///
/// Value is `-2147483647` тАФ one more than the minimum 32-bit signed
/// integer so it cannot be confused with a legitimate `INT_MIN`.  The
/// constant is re-inlined inside `Sequence.nextVal` / `currVal`
/// because those methods predate this name; the inlined literal and
/// this constant must stay in sync.
final SEQ_ERROR_SENTINEL = 0 - 2147483647;

/// @brief Registry of sequences within a single `Database`.
///
/// One `SequenceManager` per database means cross-database sequence
/// access requires a qualified reference (`db.name.nextval(...)`) тАФ we
/// do not implement that yet, so the registries are effectively
/// database-local.  Internally a plain `List[Sequence]` is enough
/// (see design note 3 in the header).
class SequenceManager {
    expose List[Sequence] sequences;

    /// @brief Empty registry.
    expose func init() {
        sequences = [];
    }

    /// @brief Register a new sequence.  Returns an empty string on
    ///        success, or an error message if the name is already
    ///        taken.
    ///
    /// The "" = success convention matches the DDL / constraint check
    /// paths throughout the engine; callers that need structured
    /// errors wrap this return in a `QueryResult`.
    expose func addSequence(seq: Sequence) -> String {
        var i = 0;
        while i < sequences.count() {
            if sequences.get(i).name == seq.name {
                return "Sequence '" + seq.name + "' already exists";
            }
            i = i + 1;
        }
        sequences.add(seq);
        return "";
    }

    /// @brief Remove a sequence by name.  Returns true on success,
    ///        false on "not found" тАФ which DROP SEQUENCE IF EXISTS
    ///        treats as a success.
    expose func dropSequence(name: String) -> Boolean {
        var i = 0;
        while i < sequences.count() {
            if sequences.get(i).name == name {
                sequences.removeAt(i);
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief Linear lookup by name.  Null if not found тАФ callers
    ///        turn that into a "does not exist" SQL error.
    expose func findSequence(name: String) -> Sequence? {
        var i = 0;
        while i < sequences.count() {
            if sequences.get(i).name == name {
                return sequences.get(i);
            }
            i = i + 1;
        }
        return null;
    }

    /// @brief Return the underlying list.  Used by the pg_catalog
    ///        views; not a defensive copy because the views only
    ///        iterate.
    expose func listSequences() -> List[Sequence] {
        return sequences;
    }

    /// @brief Number of sequences in this database.
    expose func count() -> Integer {
        return sequences.count();
    }
}
