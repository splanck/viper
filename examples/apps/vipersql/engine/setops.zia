// =============================================================================
// setops.zia — SQL set operations: UNION, UNION ALL, EXCEPT, INTERSECT,
//              and their ALL variants
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// SQL lets you combine two result sets:
//
//     SELECT a, b FROM x UNION     SELECT a, b FROM y;
//     SELECT a, b FROM x UNION ALL SELECT a, b FROM y;
//     SELECT a, b FROM x EXCEPT    SELECT a, b FROM y;
//     SELECT a, b FROM x INTERSECT SELECT a, b FROM y;
//     SELECT a, b FROM x EXCEPT ALL SELECT a, b FROM y;
//     SELECT a, b FROM x INTERSECT ALL SELECT a, b FROM y;
//
// After the executor has materialised each side into a `QueryResult`
// (see already-annotated `result.zia`), the functions in this file
// mechanically combine them.  Dedup-style operations (UNION, EXCEPT,
// INTERSECT) are implemented on top of a tiny 128-bucket hash set
// keyed by a stringified row.  The `ALL` variants preserve multiplicity
// and use a linear-scan "consume-on-match" strategy.
//
// WHERE THIS FITS
// ---------------
//   engine/query.zia  ──►  lowers `SELECT … UNION …` into left and
//                          right sub-queries, each executed
//                          independently.
//        │
//        ▼
//   engine/setops.zia  (YOU ARE HERE)  ──►  combines two
//                          `QueryResult`s into one.
//
// KEY DESIGN CHOICES
// ------------------
//   1. String-keyed dedup.  A `Row` is reduced to a pipe-separated
//      concatenation of its cell `toString()` values.  Pros: uniform
//      treatment of every type, dirt-simple code, cheap equality.
//      Cons: two distinct cells that happen to stringify the same
//      would dedup incorrectly — e.g. `1` (INTEGER) and `'1'` (TEXT)
//      both produce "1".  In practice the executor enforces column
//      alignment (UNION requires matching types on both sides), so
//      this is safe.
//
//   2. 128-bucket open hash.  `CryptoHash.Fast(key) mod 128` picks a
//      bucket; membership scans the bucket linearly.  128 is enough
//      for typical set-op cardinalities (< a few thousand rows
//      across both sides).  For extreme cases, the dedup path
//      degrades to O(N²/128) rather than O(N²), which is acceptable
//      for the demo.
//
//   3. EXCEPT ALL / INTERSECT ALL use an O(N·M) "consume" strategy.
//      For each row in the left side, we look for an unused equal
//      row in the right side.  This mimics the standard SQL
//      multiplicity rules (max(N-M,0) and min(N,M)) without needing
//      a multi-set hash — `secondUsed: List[Integer]` flags track
//      which right-side rows have been consumed.  Adequate for demo
//      cardinalities; a production engine would hash.
//
//   4. No column-arity check here.  It is the caller's responsibility
//      to ensure both sides expose compatible column lists — `query`
//      rejects shape mismatches upstream.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. UNION / UNION ALL — `executeUnion` with a boolean dispatch.
//   2. EXCEPT, INTERSECT — their dedup variants (hash-set based).
//   3. `rowKey`, `buildRowKeySet`, `rowKeyInSet`, `addRowKeyToSet` —
//      the 128-bucket hash set API.
//   4. Two lower-level helpers: `isDuplicateRow`, `rowsEqual`,
//      `isRowInResult` — O(N) fallbacks used by callers outside
//      set-ops.
//   5. EXCEPT ALL / INTERSECT ALL — the multi-set variants.
//
// =============================================================================

module setops;

bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind Viper.Crypto.Hash as CryptoHash;
bind "./types";
bind "./result";

//=============================================================================
// SET OPERATIONS (ENTRY POINTS)
//=============================================================================

/// @brief UNION or UNION ALL of two result sets.
///
/// The column-name list is copied from the first side — PG semantics
/// require that the left query's column names prevail.  In UNION ALL
/// mode we append each side's rows verbatim.  In UNION mode we feed
/// every row through a shared hash set, skipping anything we have
/// seen.  Note that both sides go through the same `seen` set — that
/// is what dedupes across the join, not just within each side.
func executeUnion(first: QueryResult, second: QueryResult, unionAll: Boolean) -> QueryResult {
    var result = new QueryResult();
    result.init();

    // Left side provides column-name identity (SQL-standard).
    var ci = 0;
    while ci < first.columnNames.count() {
        result.addColumnName(first.columnNames.get(ci));
        ci = ci + 1;
    }

    if unionAll {
        // Straight concatenation; no dedup.
        var ri = 0;
        while ri < first.rowCount() {
            var row = first.getRow(ri);
            if row != null { result.addRow(row); }
            ri = ri + 1;
        }
        ri = 0;
        while ri < second.rowCount() {
            var row = second.getRow(ri);
            if row != null { result.addRow(row); }
            ri = ri + 1;
        }
    } else {
        // UNION: dedup across both sides with one shared hash set.
        var seen = buildRowKeySet(new QueryResult());  // preallocate empty buckets
        var ri = 0;
        while ri < first.rowCount() {
            var row = first.getRow(ri);
            if row != null {
                var r = row;
                var key = rowKey(r);
                if rowKeyInSet(seen, key) == false {
                    addRowKeyToSet(seen, key);
                    result.addRow(r);
                }
            }
            ri = ri + 1;
        }
        ri = 0;
        while ri < second.rowCount() {
            var row = second.getRow(ri);
            if row != null {
                var r = row;
                var key = rowKey(r);
                if rowKeyInSet(seen, key) == false {
                    addRowKeyToSet(seen, key);
                    result.addRow(r);
                }
            }
            ri = ri + 1;
        }
    }

    return result;
}

/// @brief EXCEPT (set-difference, dedupd): left rows not present in
///        the right side.
///
/// Pre-builds a hash set of the right side once, then filters the
/// left.  A second `seen` set prevents us from emitting duplicates
/// *within* the left side (EXCEPT — not EXCEPT ALL — produces a
/// distinct result).
func executeExcept(first: QueryResult, second: QueryResult) -> QueryResult {
    var result = new QueryResult();
    result.init();

    var ci = 0;
    while ci < first.columnNames.count() {
        result.addColumnName(first.columnNames.get(ci));
        ci = ci + 1;
    }

    var secondSet = buildRowKeySet(second);     // everything to exclude
    var seen = buildRowKeySet(new QueryResult());  // left-side dedup guard

    var ri = 0;
    while ri < first.rowCount() {
        var row = first.getRow(ri);
        if row != null {
            var r = row;
            var key = rowKey(r);
            if rowKeyInSet(secondSet, key) == false && rowKeyInSet(seen, key) == false {
                addRowKeyToSet(seen, key);
                result.addRow(r);
            }
        }
        ri = ri + 1;
    }

    return result;
}

/// @brief INTERSECT: left rows that also appear in the right side.
///
/// Same structure as `executeExcept`, but the membership test flips.
/// Again, the `seen` set dedupes within the left — two identical
/// rows on the left only emit once.
func executeIntersect(first: QueryResult, second: QueryResult) -> QueryResult {
    var result = new QueryResult();
    result.init();

    var ci = 0;
    while ci < first.columnNames.count() {
        result.addColumnName(first.columnNames.get(ci));
        ci = ci + 1;
    }

    var secondSet = buildRowKeySet(second);
    var seen = buildRowKeySet(new QueryResult());

    var ri = 0;
    while ri < first.rowCount() {
        var row = first.getRow(ri);
        if row != null {
            var r = row;
            var key = rowKey(r);
            if rowKeyInSet(secondSet, key) && rowKeyInSet(seen, key) == false {
                addRowKeyToSet(seen, key);
                result.addRow(r);
            }
        }
        ri = ri + 1;
    }

    return result;
}

//=============================================================================
// ROW-KEY HELPERS (128-bucket hash set over stringified rows)
//=============================================================================

/// @brief Reduce a row to a canonical string key for hash dedup.
///
/// Cells are rendered via `SqlValue.toString()` and joined with the
/// pipe character `|`.  The pipe is a legal text character so a
/// malicious row can manufacture collisions (`"a|b"` vs two-cell
/// `"a"`, `"b"`), but this is only a dedup correctness concern, not
/// a security one: UNION producing one row instead of two is the
/// worst case, and it requires that both interpretations agree on
/// type and position, which the executor rejects before getting here.
func rowKey(row: Row) -> String {
    var key = "";
    var ci = 0;
    while ci < row.columnCount() {
        if ci > 0 { key = key + "|"; }
        key = key + row.getValue(ci).toString();
        ci = ci + 1;
    }
    return key;
}

/// @brief Build a fresh 128-bucket hash set pre-populated with every
///        row of `result`.  Pass an empty `QueryResult` to get an
///        empty set.
///
/// The return type is `List[List[String]]` — a list of 128 buckets,
/// each a list of keys that hashed into that bucket.  `CryptoHash.Fast`
/// may return negative values (Zia's `Integer` is signed); we flip
/// the sign before modding so the bucket index is always valid.
func buildRowKeySet(result: QueryResult) -> List[List[String]] {
    var buckets: List[List[String]] = [];
    var bi = 0;
    while bi < 128 {
        var bucket: List[String] = [];
        buckets.add(bucket);
        bi = bi + 1;
    }
    var ri = 0;
    while ri < result.rowCount() {
        var row = result.getRow(ri);
        if row != null {
            var r = row;
            var key = rowKey(r);
            var h = CryptoHash.Fast(key);
            if h < 0 { h = 0 - h; }
            buckets.get(h % 128).add(key);
        }
        ri = ri + 1;
    }
    return buckets;
}

/// @brief Hash-set membership test.  O(N/128) average.
func rowKeyInSet(buckets: List[List[String]], key: String) -> Boolean {
    var h = CryptoHash.Fast(key);
    if h < 0 { h = 0 - h; }
    var bucket = buckets.get(h % 128);
    var i = 0;
    while i < bucket.count() {
        if bucket.get(i) == key { return true; }
        i = i + 1;
    }
    return false;
}

/// @brief Hash-set insertion.  Does **not** dedupe within a bucket —
///        callers pair it with `rowKeyInSet` for that.  Splitting
///        test-and-insert into two calls lets the dedup loop in the
///        entry-point functions decide whether to also emit the row.
func addRowKeyToSet(buckets: List[List[String]], key: String) {
    var h = CryptoHash.Fast(key);
    if h < 0 { h = 0 - h; }
    buckets.get(h % 128).add(key);
}

//=============================================================================
// GENERIC ROW-EQUALITY HELPERS (used outside the hash path)
//=============================================================================

/// @brief O(N) "is this row already in this result?" used by the
///        INSERT path to deduplicate when inserting into a UNIQUE
///        column without an index.
///
/// When the caller already has a hash set, prefer `rowKeyInSet`.
/// This is the fallback for one-shot checks.
func isDuplicateRow(result: QueryResult, row: Row) -> Boolean {
    var key = rowKey(row);
    var ri = 0;
    while ri < result.rowCount() {
        var existingRow = result.getRow(ri);
        if existingRow != null {
            var er = existingRow;
            if rowKey(er) == key { return true; }
        }
        ri = ri + 1;
    }
    return false;
}

/// @brief Row-wise equality via `rowKey`.  Used by the `ALL`
///        variants where we need to match rows one-by-one without
///        building a hash.
func rowsEqual(row1: Row, row2: Row) -> Boolean {
    return rowKey(row1) == rowKey(row2);
}

/// @brief O(N) membership test — same shape as `isDuplicateRow` but
///        the callsite intent is "does this row match anything?"
///        rather than "is this row a duplicate?".  Separated to keep
///        callsites self-documenting.
func isRowInResult(result: QueryResult, row: Row) -> Boolean {
    var key = rowKey(row);
    var ri = 0;
    while ri < result.rowCount() {
        var existingRow = result.getRow(ri);
        if existingRow != null {
            var er = existingRow;
            if rowKey(er) == key {
                return true;
            }
        }
        ri = ri + 1;
    }
    return false;
}

//=============================================================================
// MULTI-SET VARIANTS (EXCEPT ALL, INTERSECT ALL)
//=============================================================================

/// @brief EXCEPT ALL: if a row appears N times on the left and M
///        times on the right, emit max(N − M, 0) copies.
///
/// The algorithm maintains a `secondUsed` 0/1 flag list over the
/// right-side rows — each time we find a matching pair, we mark the
/// right-side row "used" so it cannot match a later left-side copy.
/// Runs in O(N·M); fine for the demo's cardinalities.
///
/// NOTE: setting `si = second.rowCount()` is the file's idiomatic
/// "break" — Zia does not have an early-exit `break`, so the loop
/// terminates naturally on the next iteration.  Same technique in
/// `executeIntersectAll`.
func executeExceptAll(first: QueryResult, second: QueryResult) -> QueryResult {
    var result = new QueryResult();
    result.init();

    var ci = 0;
    while ci < first.columnNames.count() {
        result.addColumnName(first.columnNames.get(ci));
        ci = ci + 1;
    }

    var secondUsed = new List[Integer]();
    var si = 0;
    while si < second.rowCount() {
        secondUsed.add(0);
        si = si + 1;
    }

    var ri = 0;
    while ri < first.rowCount() {
        var row = first.getRow(ri);
        if row != null {
            var r = row;
            var consumed = false;
            si = 0;
            while si < second.rowCount() {
                if secondUsed.get(si) == 0 {
                    var secRow = second.getRow(si);
                    if secRow != null {
                        var sr = secRow;
                        if rowsEqual(r, sr) {
                            secondUsed.set(si, 1);
                            consumed = true;
                            si = second.rowCount();  // idiomatic break
                        }
                    }
                }
                si = si + 1;
            }
            if consumed == false {
                result.addRow(r);
            }
        }
        ri = ri + 1;
    }

    return result;
}

/// @brief INTERSECT ALL: emit min(N, M) copies where N is the left
///        multiplicity and M is the right.
///
/// Same consume-on-match bookkeeping as `executeExceptAll`; we emit
/// the left-side row on every successful pairing.  Unpaired left
/// rows are dropped (this is the intersection, not the union).
func executeIntersectAll(first: QueryResult, second: QueryResult) -> QueryResult {
    var result = new QueryResult();
    result.init();

    var ci = 0;
    while ci < first.columnNames.count() {
        result.addColumnName(first.columnNames.get(ci));
        ci = ci + 1;
    }

    var secondUsed = new List[Integer]();
    var si = 0;
    while si < second.rowCount() {
        secondUsed.add(0);
        si = si + 1;
    }

    var ri = 0;
    while ri < first.rowCount() {
        var row = first.getRow(ri);
        if row != null {
            var r = row;
            si = 0;
            while si < second.rowCount() {
                if secondUsed.get(si) == 0 {
                    var secRow = second.getRow(si);
                    if secRow != null {
                        var sr = secRow;
                        if rowsEqual(r, sr) {
                            secondUsed.set(si, 1);
                            result.addRow(r);
                            si = second.rowCount();  // idiomatic break
                        }
                    }
                }
                si = si + 1;
            }
        }
        ri = ri + 1;
    }

    return result;
}
