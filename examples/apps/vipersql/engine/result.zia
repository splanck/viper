// =============================================================================
// result.zia — The universal return type for every SQL operation
// Part of ViperSQL  (package: engine)
// =============================================================================
//
// PURPOSE
// -------
// Every path through the SQL engine — parser, planner, executor, DDL, DML,
// set-operations, the REPL, the PG wire-protocol server, the text protocol,
// and the client tools — eventually produces a `QueryResult`.  This file
// defines that single, uniform value type so that callers never have to
// branch on "was this a SELECT or an UPDATE?" just to find out what came
// back.  A `QueryResult` carries *both* row data (for queries) *and* a row
// count / status message (for statements), plus a success flag and an error
// message slot for failures.
//
// WHERE THIS FITS
// ---------------
// ViperSQL's layering looks roughly like:
//
//     client/vsql.zia  ─┐
//     server/*          │
//                       ├──► engine/executor.zia ──► engine/*.zia ──► storage/*
//     REPL (main.zia)  ─┘             │
//                                     └──► returns QueryResult (THIS FILE)
//
// Whoever called `executor.executeSql(...)` — whether that is the PG wire
// protocol reader, the text-protocol server, or the interactive REPL — only
// needs to know how to interrogate a `QueryResult`.  That makes this the
// single most-important data contract in the whole demo, even though the
// file itself is tiny.
//
// KEY DESIGN CHOICES
// ------------------
//   1. One type, two modes.  Instead of having a `SelectResult` and a
//      `CommandResult` class, we collapse both shapes into one: SELECTs
//      populate `columnNames` / `rows`, DML statements populate
//      `rowsAffected` / `message`, and both share the `success` flag.  This
//      matches how PostgreSQL's wire protocol describes results — a single
//      "CommandComplete" frame can carry either a row count or a tag — and
//      it simplifies the executor's return path (no union / sum type juggle).
//
//   2. Rows are first-class `Row` objects, not untyped lists.  `Row` lives
//      in `./schema` (imported below); it owns typed `Value` cells, so once
//      the executor has built a `QueryResult` the caller can read columns
//      by index without any further decoding.
//
//   3. Rendering lives on the result itself.  `toString()` prints a
//      psql-style table.  Keeping this here (rather than in a separate
//      formatter module) means the REPL in `main.zia` and `vipersql.zia`
//      can call `result.toString()` directly — no intermediate types.
//
// HOW TO READ THIS FILE
// ---------------------
// The file has one class with three small method families:
//   - Construction / error state      :  init, setError
//   - Row & column assembly           :  addColumnName, addRow, getRow,
//                                        setRow, swapRows, rowCount
//   - Human-friendly rendering        :  toString
//
// It deliberately stays small.  If you are new to the codebase, read this
// file, then `./schema` (which defines `Row` and `Value`), then
// `engine/executor.zia` (which is the main producer of `QueryResult`s).
//
// =============================================================================

module result;

// `Fmt` provides `Fmt.Int(n) -> String` for printing row counts.
// `StringBuilder` lets us concatenate row rendering output without creating
// O(N²) intermediate strings — important when a SELECT returns thousands of
// rows.  Every file in this demo uses `SB` as the short alias for it.
bind Viper.Fmt as Fmt;
bind Viper.Text.StringBuilder as SB;

// `Row` (and transitively `Value`) live in `schema.zia`.  We import the
// module so the `List[Row]` below type-checks; we do not otherwise
// participate in the schema subsystem from here.
bind "./schema";

//=============================================================================
// QUERY RESULT
//=============================================================================

/// @brief Uniform return type for every SQL execution path.
///
/// A `QueryResult` behaves in one of three modes:
///
///   * Success + rows      — populated `columnNames` and `rows`.  Typical
///                           result of SELECT / SHOW / DESCRIBE / EXPLAIN.
///
///   * Success + command   — empty `rows`/`columnNames`, non-null `message`
///                           (e.g. "CREATE TABLE") and/or `rowsAffected`.
///                           Typical result of DDL and DML statements.
///
///   * Error               — `success == false`, `message` contains the
///                           diagnostic.  Producers set this via `setError`.
///
/// The `success` flag is the first thing callers should check.  The wire
/// protocol layer turns `false` into an `ErrorResponse` frame; the REPL
/// prints `ERROR: <message>`; the test harness asserts on it.
class QueryResult {
    // When true, this is a successful query (row or command).  When false,
    // `message` holds the human-readable reason for failure and
    // `rows`/`columnNames` are typically empty.
    expose Boolean success;

    // For DML: the PostgreSQL-style command tag (e.g. "INSERT 0 5").
    // For errors: the diagnostic.  For SELECT: usually empty.
    expose String message;

    // Parallel to `rows` — same length as each row's value list.  Kept as a
    // list of plain strings (not a `Column` type) because the wire protocol
    // and the REPL only ever need the textual name for display.
    expose List[String] columnNames;

    // The actual result set.  Empty for pure command executions.
    expose List[Row] rows;

    // DML row count.  Populated by INSERT / UPDATE / DELETE executors, used
    // by the PG wire layer when synthesising CommandComplete.  For SELECT
    // this stays at 0 — callers use `rowCount()` which reflects `rows.count()`.
    expose Integer rowsAffected;

    /// @brief Zero-state initialiser.
    ///
    /// Why a method instead of assigning these in field declarations?  Zia
    /// allows field initialisers, but centralising the defaults in `init()`
    /// (a) keeps them next to the constructor semantics and (b) makes it
    /// trivial to "recycle" a `QueryResult` by calling `init()` again —
    /// useful inside tight loops in the executor where we want to avoid
    /// allocating a new object per iteration.
    expose func init() {
        success = true;
        message = "";
        columnNames = [];
        rows = [];
        rowsAffected = 0;
    }

    /// @brief Turn a success into a failure.
    ///
    /// Any layer that detects an error — syntax error from the parser,
    /// constraint violation from the executor, I/O error from storage —
    /// flips the result using this helper instead of mutating fields
    /// directly.  Going through a single method means that if we later add
    /// a `sqlState` field (PostgreSQL's 5-char error code) we only touch
    /// one call site.
    expose func setError(msg: String) {
        success = false;
        message = msg;
    }

    /// @brief Append one column name to the result's header row.
    ///
    /// The executor builds column names as it lowers a projection list; it
    /// calls this once per output column, in left-to-right SQL order, so
    /// `columnNames[i]` always lines up with `row.getValue(i)` later.
    expose func addColumnName(name: String) {
        columnNames.add(name);
    }

    /// @brief Append one row to the materialised result set.
    ///
    /// Rows come from two places:
    ///   (a) The executor's row-pipeline, one row at a time;
    ///   (b) The set-operations module (`engine/setops.zia`), which dedupes
    ///       / unions pre-built `QueryResult`s.
    /// Both just call `addRow` — the `QueryResult` does not own the row
    /// construction logic.
    expose func addRow(row: Row) {
        rows.add(row);
    }

    /// @brief Safe random-access row lookup.
    ///
    /// Returns `null` rather than trapping on an out-of-range index.  The
    /// optional return is the idiomatic "maybe" in Zia; callers unwrap it
    /// with `!` or pattern-match on `null` (see `setops.zia` and the REPL
    /// helpers in `main.zia` for both styles).  Bounds-checking lives here
    /// rather than at call sites because every user of a `QueryResult`
    /// (executor, REPL, tests, wire protocol) would otherwise need to
    /// duplicate the check.
    expose func getRow(idx: Integer) -> Row? {
        if idx >= 0 && idx < rows.count() {
            return rows.get(idx);
        }
        return null;
    }

    /// @brief In-place row replacement.
    ///
    /// Used by the ORDER BY pipeline in the executor, which reshuffles
    /// rows after projection, and by the UPDATE executor in `dml.zia`,
    /// which rewrites rows in their original result-set position when
    /// reporting affected tuples.
    expose func setRow(idx: Integer, row: Row) {
        if idx >= 0 && idx < rows.count() {
            rows.set(idx, row);
        }
    }

    /// @brief Swap two rows by index.
    ///
    /// The ORDER BY implementation uses this in its sort inner loops
    /// (`sortResultByColumns` in the executor calls it inside an insertion
    /// / quicksort swap).  Keeping the swap here — behind a bounds-checked
    /// method — means the sort code can stay focused on comparator logic.
    expose func swapRows(i: Integer, j: Integer) {
        if i >= 0 && i < rows.count() && j >= 0 && j < rows.count() {
            var temp = rows.get(i);
            rows.set(i, rows.get(j));
            rows.set(j, temp);
        }
    }

    /// @brief Row count — convenience wrapper for `rows.count()`.
    ///
    /// Exists mostly as a stable public API: we could expose `rows`
    /// directly (it already is `expose`), but having `rowCount()` means
    /// external callers that do not need to mutate the list can stay on
    /// the shallower interface.  `main.zia`'s `.schema` meta-command
    /// iterates via this method, for example.
    expose func rowCount() -> Integer {
        return rows.count();
    }

    /// @brief Render the result as a psql-style ASCII table.
    ///
    /// Output layout (matches `psql --tuples-only=off`):
    ///
    ///     col1 | col2 | col3
    ///     --------+--------+--------
    ///     v11  | v12  | v13
    ///     v21  | v22  | v23
    ///     (2 rows)
    ///
    /// Behaviour for non-SELECT modes:
    ///   * Error        — returns `"ERROR: <message>"` verbatim.
    ///   * Pure command — (no columns *and* no rows) returns the `message`
    ///                    unchanged, so callers see `"CREATE TABLE"` or
    ///                    similar without a trailing "(0 rows)".
    ///   * Empty select — headers + separator + "(0 rows)".
    ///
    /// We build into a `StringBuilder` because string concatenation in a
    /// hot per-row loop would be quadratic; a 10K-row result would run
    /// hundreds of millions of byte copies otherwise.
    expose func toString() -> String {
        if success == false {
            return "ERROR: " + message;
        }

        var sb = SB.New();

        // Header row — column names separated by " | ".
        var i = 0;
        while i < columnNames.count() {
            if i > 0 { SB.Append(sb, " | "); }
            SB.Append(sb, columnNames.get(i));
            i = i + 1;
        }

        // Separator row ("---+----") only makes sense when we actually
        // rendered a header.  For pure-command results (no columns) we skip
        // this so the fallback below prints just the message.
        if columnNames.count() > 0 {
            SB.Append(sb, "\n");
            i = 0;
            while i < columnNames.count() {
                if i > 0 { SB.Append(sb, "-+-"); }
                SB.Append(sb, "--------");
                i = i + 1;
            }
            SB.Append(sb, "\n");
        }

        // Data rows.  We use the row's own column count rather than
        // `columnNames.count()` so that rows that happen to have fewer or
        // more cells render honestly instead of silently being clipped —
        // that divergence only arises in bugs, but we'd rather see it.
        var r = 0;
        while r < rows.count() {
            var row = rows.get(r);
            var c = 0;
            while c < row.columnCount() {
                if c > 0 { SB.Append(sb, " | "); }
                SB.Append(sb, row.getValue(c).toString());
                c = c + 1;
            }
            SB.Append(sb, "\n");
            r = r + 1;
        }

        // Fallback: no columns AND no rows means this is a command-style
        // result (CREATE, INSERT with tag only, etc.).  Return the message
        // without any table chrome or "(0 rows)" trailer.
        if rows.count() == 0 && columnNames.count() == 0 {
            return message;
        }
        SB.Append(sb, "(");
        SB.Append(sb, Fmt.Int(rows.count()));
        SB.Append(sb, " rows)");
        return SB.ToString(sb);
    }
}
