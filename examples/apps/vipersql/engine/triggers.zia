// =============================================================================
// triggers.zia — SQL triggers: BEFORE/AFTER INSERT/UPDATE/DELETE hooks
// Part of ViperSQL  (package: engine, Phase 17)
// =============================================================================
//
// PURPOSE
// -------
// SQL triggers let a DDL author register a chunk of SQL to fire at
// every write.  This file defines:
//
//   * `Trigger`        — the metadata for one registered trigger:
//                        name, timing (BEFORE/AFTER), event
//                        (INSERT/UPDATE/DELETE), table, body SQL.
//   * `TriggerManager` — the per-database registry: CRUD + the
//                        "give me every trigger for this (table,
//                        timing, event)" query the executor needs
//                        each time it runs a DML statement.
//   * A small insertion-sort that the lookup uses to order triggers
//     alphabetically by name — PostgreSQL's documented ordering rule.
//
// The *execution* of a trigger's body is not here — it lives in
// `engine/executor.zia`, which sets up `OLD`/`NEW` row-valued tables
// as temporary tables and recursively invokes `executeSql` on the
// body.  `MAX_TRIGGER_DEPTH` below is the recursion guard it consults.
//
// WHERE THIS FITS
// ---------------
//     engine/ddl.zia
//         │  CREATE/DROP TRIGGER → calls `addTrigger` / `dropTrigger`.
//         ▼
//     engine/triggers.zia  (YOU ARE HERE)
//         │  metadata only; lookup via `getTriggersFor`.
//         ▼
//     engine/executor.zia (DML paths)
//         │  fires BEFORE triggers, runs the core op, fires AFTER
//         │  triggers.
//         ▼
//     engine/dml.zia
//
// KEY DESIGN CHOICES
// ------------------
//   1. Parallel-list design (one `List[Trigger]`), not a multi-index
//      map.  Lookups filter on (tableName, timing, event); even with
//      a few dozen triggers a linear filter is microseconds.
//
//   2. Alphabetical firing order (PG convention, per spec).  The
//      `getTriggersFor` helper sorts results before returning so the
//      executor does not have to.  Insertion sort is used because the
//      filtered list is tiny — almost always fewer than 10 elements.
//
//   3. Body is stored as raw SQL, not a parsed AST.  Re-parsing on
//      each fire is the price for not needing to keep the parser's
//      AST types in sync across phases of the engine's life; for the
//      demo's workloads this is negligible.
//
//   4. `forEachRow` is kept, but PG's `FOR EACH STATEMENT` variant is
//      not yet implemented — the executor treats FOR EACH STATEMENT
//      as a single-row fire.  Flag-don't-fix: either drop the field
//      or finish the feature.  The parser does accept the keyword.
//
//   5. `MAX_TRIGGER_DEPTH = 16` is an arbitrary cap protecting
//      against a trigger that writes to a table that has a trigger
//      that writes back to the original table ad infinitum.
//      PostgreSQL's is unbounded until stack exhaustion — ours trades
//      flexibility for a predictable failure mode.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `MAX_TRIGGER_DEPTH` at the top.
//   2. The `Trigger` class — one object per registered trigger.
//   3. `TriggerManager` — the registry plus `getTriggersFor`, which
//      is the function the hot DML path calls.
//   4. `sortTriggersByName` — insertion sort, tucked at the bottom.
//
// NOTE: the `TRIGGER_BEFORE`, `TRIGGER_AFTER`, `TRIGGER_INSERT`,
// `TRIGGER_UPDATE`, `TRIGGER_DELETE` constants referenced below are
// declared in `../parser/stmt.zia`.  We `bind` that module so we get
// the names in scope.
//
// =============================================================================

module triggers;

bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind "./types";
bind "./schema";
bind "../parser/stmt";

/// @brief Maximum trigger recursion depth before the executor aborts.
///
/// Consulted by `executor.zia` when it is about to fire a trigger: if
/// the current fire-depth counter is already at this limit, it raises
/// an error instead.  See design note (5).
final MAX_TRIGGER_DEPTH = 16;

//=============================================================================
// TRIGGER
//=============================================================================

/// @brief One registered trigger.
///
/// Values of `timing` (BEFORE vs. AFTER) and `event` (INSERT vs.
/// UPDATE vs. DELETE) are encoded as small integers — their symbolic
/// names live in `../parser/stmt.zia` so the parser and this module
/// agree on them.
///
/// `bodySQL` is the raw SQL text.  At fire time the executor prefixes
/// it with `OLD`/`NEW` temp-table creation and invokes `executeSql`
/// on the string.
class Trigger {
    expose String name;
    expose Integer timing;       // TRIGGER_BEFORE | TRIGGER_AFTER
    expose Integer event;        // TRIGGER_INSERT | TRIGGER_UPDATE | TRIGGER_DELETE
    expose String tableName;
    expose Boolean forEachRow;   // false ⇒ FOR EACH STATEMENT (see note 4)
    expose String bodySQL;

    /// @brief Default init: a forEachRow BEFORE INSERT with empty
    ///        fields.  Actual values are filled by `initFull`.
    expose func init() {
        name = "";
        timing = TRIGGER_BEFORE;
        event = TRIGGER_INSERT;
        tableName = "";
        forEachRow = true;
        bodySQL = "";
    }

    /// @brief One-shot init taking every field.  Called by
    ///        `engine/ddl.zia::executeCreateTrigger` once the parser
    ///        has validated the CREATE TRIGGER syntax.
    expose func initFull(n: String, t: Integer, e: Integer, tbl: String, fer: Boolean, body: String) {
        name = n;
        timing = t;
        event = e;
        tableName = tbl;
        forEachRow = fer;
        bodySQL = body;
    }

    /// @brief "BEFORE" or "AFTER" as a keyword string.
    ///
    /// Any value that is not `TRIGGER_BEFORE` falls through to
    /// "AFTER" — there are only two, and mislabelling a corrupt
    /// timing as AFTER is strictly better than throwing during a
    /// SHOW TRIGGERS.
    expose func timingName() -> String {
        if timing == TRIGGER_BEFORE { return "BEFORE"; }
        return "AFTER";
    }

    /// @brief "INSERT" / "UPDATE" / "DELETE" as a keyword string.
    ///
    /// Default branch is DELETE for the same defensive reason as
    /// `timingName`.
    expose func eventName() -> String {
        if event == TRIGGER_INSERT { return "INSERT"; }
        if event == TRIGGER_UPDATE { return "UPDATE"; }
        return "DELETE";
    }

    /// @brief PG-style SHOW TRIGGERS summary line.  No `bodySQL`
    ///        rendering — that can be long; callers that want it call
    ///        `pg_trigger` through the catalog views instead.
    expose func toString() -> String {
        var result = name + " " + timingName() + " " + eventName() + " ON " + tableName;
        if forEachRow {
            result = result + " FOR EACH ROW";
        }
        return result;
    }
}

//=============================================================================
// TRIGGER MANAGER
//=============================================================================

/// @brief Per-database trigger registry.  One instance lives on each
///        `Database` (see `engine/database.zia`); global triggers
///        (across databases) are not a concept we support.
class TriggerManager {
    expose List[Trigger] triggers;

    /// @brief Empty registry.
    expose func init() {
        triggers = [];
    }

    /// @brief Register a trigger.  Returns "" on success or the
    ///        duplicate-name error message otherwise.
    expose func addTrigger(trigger: Trigger) -> String {
        var i = 0;
        while i < triggers.count() {
            if triggers.get(i).name == trigger.name {
                return "Trigger '" + trigger.name + "' already exists";
            }
            i = i + 1;
        }
        triggers.add(trigger);
        return "";
    }

    /// @brief Remove a trigger by name.  Returns true if we actually
    ///        dropped something; false is what DROP TRIGGER IF
    ///        EXISTS uses to stay silent.
    expose func dropTrigger(name: String) -> Boolean {
        var i = 0;
        while i < triggers.count() {
            if triggers.get(i).name == name {
                triggers.removeAt(i);
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief Purge every trigger pointing at the given table.
    ///
    /// Called by DROP TABLE so we do not leave dangling trigger
    /// metadata around.  Iterates *backwards* because `removeAt`
    /// shifts indices, and a backwards walk keeps the untouched
    /// indices stable.
    expose func dropTriggersForTable(tableName: String) {
        var i = triggers.count() - 1;
        while i >= 0 {
            if triggers.get(i).tableName == tableName {
                triggers.removeAt(i);
            }
            i = i - 1;
        }
    }

    /// @brief Linear lookup by name.  Null if not found.
    expose func findTrigger(name: String) -> Trigger? {
        var i = 0;
        while i < triggers.count() {
            if triggers.get(i).name == name {
                return triggers.get(i);
            }
            i = i + 1;
        }
        return null;
    }

    /// @brief Return triggers matching (table, timing, event) in
    ///        alphabetical order by name.
    ///
    /// The hot lookup the DML executor calls on every row write.
    /// Alphabetical ordering is the PostgreSQL convention.  We sort
    /// in place on a freshly-built result list — it never mutates
    /// `triggers` itself.
    expose func getTriggersFor(tableName: String, timing: Integer, event: Integer) -> List[Trigger] {
        var result: List[Trigger] = [];
        var i = 0;
        while i < triggers.count() {
            var t = triggers.get(i);
            if t.tableName == tableName && t.timing == timing && t.event == event {
                result.add(t);
            }
            i = i + 1;
        }
        sortTriggersByName(result);
        return result;
    }

    /// @brief Full trigger list (no filter).  Used by SHOW TRIGGERS
    ///        and by the pg_trigger system view.
    expose func listTriggers() -> List[Trigger] {
        return triggers;
    }

    /// @brief How many triggers reference the given table.
    ///
    /// Useful for SELECTs against pg_catalog and for DROP TABLE's
    /// "cascade?" prompt — if 0, DROP is a no-op; if >0, cascade
    /// mode matters.
    expose func countTriggersForTable(tableName: String) -> Integer {
        var count = 0;
        var i = 0;
        while i < triggers.count() {
            if triggers.get(i).tableName == tableName {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }
}

/// @brief Module-local insertion sort by trigger name.
///
/// Why insertion sort and not something general-purpose?  Two reasons:
///   1. The lists passed in are the output of `getTriggersFor`, which
///      has already filtered by (table, timing, event).  They are
///      almost always <10 elements, where insertion sort wins on
///      constant factors.
///   2. No third-party dependency — keeping the sort inline is
///      consistent with the "zero dependencies" rule in CLAUDE.md.
func sortTriggersByName(list: List[Trigger]) {
    var n = list.count();
    var i = 1;
    while i < n {
        var key = list.get(i);
        var j = i - 1;
        while j >= 0 && list.get(j).name > key.name {
            list.set(j + 1, list.get(j));
            j = j - 1;
        }
        list.set(j + 1, key);
        i = i + 1;
    }
}
