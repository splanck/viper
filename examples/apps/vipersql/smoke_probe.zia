// =============================================================================
// smoke_probe.zia — One-shot self-test for the in-memory executor
// Part of ViperSQL  (entry point: smoke probe)
// =============================================================================
//
// PURPOSE
// -------
// A deterministic, headless exercise of the whole end-to-end SQL
// pipeline: build an `Executor`, CREATE a table, INSERT two rows,
// UPDATE one of them, SELECT them back in a specific order, and
// verify every cell.  Prints exactly one line:
//
//     RESULT: ok      — full pipeline works
//     RESULT: fail <reason>  — something diverged
//
// Shipped as the "sanity check" binary demos can run in CI.  The
// `vipersql-smoke` build target wraps it.
//
// WHERE THIS FITS
// ---------------
//     smoke_probe.zia  (YOU ARE HERE — one `main` function)
//         │
//         ▼
//     engine/executor.zia  (the only subsystem we touch)
//
// Everything downstream of `Executor` — parser, planner, in-memory
// database, row engine — is exercised transitively.  Storage /
// WAL / network paths are NOT exercised here; see the test suite
// for those.
//
// HOW TO READ THIS FILE
// ---------------------
// Straight line from top to bottom:
//   1. `fail` — emit a failure line and return.
//   2. `requireSuccess` — assert a `QueryResult` did not error.
//   3. `main` — the scripted scenario: CREATE, two INSERTs, an
//      UPDATE, a SELECT, and four field-by-field checks.
//
// If you are writing your first Zia code against ViperSQL, this
// file is the shortest complete example of how to invoke the
// engine programmatically.
//
// =============================================================================

module smoke_probe;

bind Viper.Terminal as Terminal;
bind "./engine/executor";

/// @brief Print a "RESULT: fail <msg>" line and nothing else.
///        The build harness greps for "RESULT: ok" to pass/fail
///        the probe — any other first line is a failure.
func fail(msg: String) {
    Terminal.Say("RESULT: fail " + msg);
}

/// @brief Assert a `QueryResult` is successful.  If not, emits
///        a fail line labelled with `label` and returns false so
///        the caller can early-return.
///
/// This is how the probe keeps each step honest without
/// exception handling — the engine returns in-band success/fail,
/// so we check explicitly at every hop.
func requireSuccess(result: QueryResult, label: String) -> Boolean {
    if result.success == false {
        fail(label + ": " + result.message);
        return false;
    }
    return true;
}

/// @brief The scripted scenario — exercises DDL, DML, SELECT,
///        ORDER BY, and cell-level equality checks.
///
/// Steps:
///   1. Create `items(id INTEGER, name TEXT, qty INTEGER)`.
///   2. Insert `(1, 'alpha', 3)` and `(2, 'beta', 7)`.
///   3. Update `qty = 9 WHERE name = 'beta'`.
///   4. `SELECT name, qty FROM items ORDER BY id` — expect two
///      rows in id-ascending order.
///   5. Spot-check every cell: alpha/3 then beta/9.
///
/// If any step diverges, we emit a fail line and bail early; if
/// every step passes, we emit `RESULT: ok`.
func main() {
    var exec = new Executor();

    var createRes = exec.executeSql("CREATE TABLE items (id INTEGER, name TEXT, qty INTEGER)");
    if !requireSuccess(createRes, "create table") { return; }

    var insertA =
        exec.executeSql("INSERT INTO items VALUES (1, 'alpha', 3)");
    if !requireSuccess(insertA, "insert alpha") { return; }

    var insertB =
        exec.executeSql("INSERT INTO items VALUES (2, 'beta', 7)");
    if !requireSuccess(insertB, "insert beta") { return; }

    var updateRes =
        exec.executeSql("UPDATE items SET qty = 9 WHERE name = 'beta'");
    if !requireSuccess(updateRes, "update beta") { return; }

    var selectRes =
        exec.executeSql("SELECT name, qty FROM items ORDER BY id");
    if !requireSuccess(selectRes, "select rows") { return; }

    // Basic shape: two rows came back.
    if selectRes.rowCount() != 2 {
        fail("unexpected row count");
        return;
    }

    // Cell-by-cell equality — uses the `textValue`/`intValue`
    // accessors on `SqlValue` (see engine/types.zia).
    var row0 = selectRes.rows.get(0);
    var row1 = selectRes.rows.get(1);

    if row0.getValue(0).textValue != "alpha" || row0.getValue(1).intValue != 3 {
        fail("unexpected first row");
        return;
    }
    if row1.getValue(0).textValue != "beta" || row1.getValue(1).intValue != 9 {
        fail("unexpected second row");
        return;
    }

    Terminal.Say("RESULT: ok");
}
