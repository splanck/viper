// =============================================================================
// csv.zia — CSV import/export
// Part of ViperSQL  (package: io)
// =============================================================================
//
// PURPOSE
// -------
// Implements the `IMPORT` and `EXPORT` SQL statements that move
// table contents to and from CSV files on disk.  The executor
// parses the DDL, finds the target table, and calls through
// `CsvHandler.executeImport` / `executeExport` here.
//
// Design is intentionally minimal: a one-line CSV header maps
// to column names; data rows are parsed field-by-field and
// coerced to each column's SQL type via the helpers in
// `engine/types.zia`.
//
// WHERE THIS FITS
// ---------------
//     engine/executor.zia
//         │  on IMPORT / EXPORT statements
//         ▼
//     io/csv.zia   (YOU ARE HERE)
//         │
//         ▼
//     Viper.Text.Csv                (runtime CSV parser)
//     Viper.IO.File                 (whole-file read/write)
//     engine/table.zia              (row insertion)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Header-driven column mapping.  IMPORT requires a header
//      row; we map header cells to column indices via
//      `table.findColumnIndex`.  Columns absent from the CSV get
//      NULL; CSV columns not present in the table are silently
//      ignored.
//
//   2. Type coercion on import.  Each parsed field is routed
//      through `parseCSVValue` which dispatches on the column's
//      `typeCode`.  Unknown types fall back to TEXT — matches
//      SQLite's permissive behaviour.
//
//   3. Quote escaping on export.  A cell gets wrapped in
//      double-quotes if it contains a comma, a newline, a CR,
//      or a quote itself; internal quotes are doubled (CSV
//      standard `""` escape).
//
//   4. `splitLines` strips trailing `\r` so mixed CRLF/LF files
//      Just Work.  Defensive against Windows-authored CSVs.
//
// HOW TO READ THIS FILE
// ---------------------
//   * `CsvHandler` — holds an `Executor` reference so DDL paths
//     can look up tables.  One instance per IMPORT/EXPORT call.
//   * `executeExport` — iterate rows, format, write.
//   * `escapeCSV` — per-cell escape.
//   * `executeImport` — read, parse, insert.
//   * `splitLines` / `parseCSVLine` / `parseCSVValue` — helpers.
//
// =============================================================================

module csv;

bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind Viper.IO as IO;
bind Viper.Text.StringBuilder as SB;
bind Viper.Text.Csv as Csv;
bind Viper.Collections.Seq as Seq;
bind "../engine/types";
bind "../engine/schema";
bind "../engine/table";
bind "../engine/result";
bind "../engine/executor";

//=============================================================================
// CSV HANDLER
//=============================================================================

/// @brief CSV import/export driver.  Holds an `Executor` so
///        table lookups go through the same catalog the rest of
///        the engine sees.
class CsvHandler {
    expose Executor exec;

    /// @brief Wire up against a live executor.
    expose func init(executor: Executor) {
        exec = executor;
    }

    /// @brief EXPORT: dump the table to a CSV file.
    ///
    /// Format: one header line of column names, then one line per
    /// live (non-tombstoned) row.  Every cell passes through
    /// `escapeCSV`; NULL cells render as an empty field.
    expose func executeExport(tableName: String, filename: String) -> QueryResult {
        var result = new QueryResult();
        result.init();

        var maybeTable = exec.findTable(tableName);
        if maybeTable == null {
            result.setError("Table '" + tableName + "' not found");
            return result;
        }
        var table = maybeTable;

        var sb = SB.New();

        // Header row.
        var ci = 0;
        while ci < table.columnCount() {
            var maybeCol = table.getColumn(ci);
            if maybeCol != null {
                var col = maybeCol;
                if ci > 0 { SB.Append(sb, ","); }
                SB.Append(sb, escapeCSV(col.name));
            }
            ci = ci + 1;
        }
        SB.Append(sb, "\n");

        // Data rows — skip tombstones.
        var ri = 0;
        while ri < table.rowCount() {
            var maybeRow = table.getRow(ri);
            if maybeRow != null {
                var row = maybeRow;
                if row.deleted == false {
                    ci = 0;
                    while ci < row.columnCount() {
                        if ci > 0 { SB.Append(sb, ","); }
                        var val = row.getValue(ci);
                        if val.isNull() == false {
                            SB.Append(sb, escapeCSV(val.toString()));
                        }
                        ci = ci + 1;
                    }
                    SB.Append(sb, "\n");
                }
            }
            ri = ri + 1;
        }

        IO.File.WriteAllText(filename, SB.ToString(sb));

        // Count for the "Exported N rows" message.
        var rowCount = 0;
        ri = 0;
        while ri < table.rowCount() {
            var maybeRow = table.getRow(ri);
            if maybeRow != null {
                var row = maybeRow;
                if row.deleted == false {
                    rowCount = rowCount + 1;
                }
            }
            ri = ri + 1;
        }
        result.message = "Exported " + Fmt.Int(rowCount) + " rows to '" + filename + "'";

        return result;
    }

    /// @brief Per-cell CSV escape.  Quote-wraps cells containing
    ///        `,`, `"`, `\n`, or `\r`; doubles internal quotes.
    ///        Matches RFC 4180.
    hide func escapeCSV(value: String) -> String {
        var needsQuotes = String.IndexOf(value, ",") > 0
            || String.IndexOf(value, "\"") > 0
            || String.IndexOf(value, "\n") > 0
            || String.IndexOf(value, "\r") > 0;

        if needsQuotes {
            var sb = SB.New();
            SB.Append(sb, "\"");
            var i = 0;
            var len = String.Length(value);
            while i < len {
                var ch = String.Substring(value, i, 1);
                if ch == "\"" { SB.Append(sb, "\"\""); }
                else { SB.Append(sb, ch); }
                i = i + 1;
            }
            SB.Append(sb, "\"");
            return SB.ToString(sb);
        }
        return value;
    }

    /// @brief IMPORT: read a CSV file and insert every row into
    ///        the named table.
    ///
    /// Header maps CSV field order → column indices in the
    /// table.  Missing columns (present in CSV, absent in
    /// table) are mapped to -1 and skipped; extra columns
    /// (present in table, absent in CSV) get NULL.  Type
    /// coercion happens per cell via `parseCSVValue`.
    expose func executeImport(tableName: String, filename: String) -> QueryResult {
        var result = new QueryResult();
        result.init();

        var maybeTable = exec.findTable(tableName);
        if maybeTable == null {
            result.setError("Table '" + tableName + "' not found");
            return result;
        }
        var table = maybeTable;

        if IO.File.Exists(filename) == false {
            result.setError("File not found: " + filename);
            return result;
        }

        var content = IO.File.ReadAllText(filename);
        if content == "" {
            result.setError("Failed to read file or file is empty: " + filename);
            return result;
        }

        var lines = splitLines(content);
        if lines.count() < 2 {
            result.setError("CSV file must have at least a header row and one data row");
            return result;
        }

        // Build header → column-index map.
        var headerFields = parseCSVLine(lines.get(0));
        var colIndices: List[Integer] = [];
        var fi = 0;
        while fi < headerFields.count() {
            var fieldName = String.Trim(headerFields.get(fi));
            var colIdx = table.findColumnIndex(fieldName);
            colIndices.add(colIdx);
            fi = fi + 1;
        }

        // Import data rows.
        var imported = 0;
        var li = 1;
        while li < lines.count() {
            var line = String.Trim(lines.get(li));
            if line != "" {
                var fields = parseCSVLine(line);
                var values: List[SqlValue] = [];

                // For every table column, find the matching CSV
                // field (or NULL).
                var ci = 0;
                while ci < table.columnCount() {
                    var val = sqlNull();

                    var csvIdx = -1;
                    var fi2 = 0;
                    while fi2 < colIndices.count() {
                        if colIndices.get(fi2) == ci {
                            csvIdx = fi2;
                            break;
                        }
                        fi2 = fi2 + 1;
                    }

                    if csvIdx >= 0 && csvIdx < fields.count() {
                        var fieldVal = fields.get(csvIdx);
                        val = parseCSVValue(fieldVal, table!, ci);
                    }
                    values.add(val);
                    ci = ci + 1;
                }

                if table.insertRow(values) {
                    imported = imported + 1;
                }
            }
            li = li + 1;
        }

        result.message = "Imported " + Fmt.Int(imported) + " rows from '" + filename + "'";
        return result;
    }

    /// @brief Split file content on `\n`, stripping trailing
    ///        `\r` so CRLF files parse the same as LF files.
    hide func splitLines(content: String) -> List[String] {
        var lines: List[String] = [];
        var rawSeq = String.Split(content, "\n");
        var count = Seq.get_Length(rawSeq);
        var i = 0;
        while i < count {
            var line = Seq.GetStr(rawSeq, i);
            var lineLen = String.Length(line);
            if lineLen > 0 && String.Substring(line, lineLen - 1, 1) == "\r" {
                line = String.Substring(line, 0, lineLen - 1);
            }
            if String.Length(line) > 0 || i < count - 1 {
                lines.add(line);
            }
            i = i + 1;
        }
        return lines;
    }

    /// @brief Parse one CSV line into its fields.  Delegates to
    ///        `Viper.Text.Csv.ParseLine` which handles the
    ///        standard quoting rules.
    hide func parseCSVLine(line: String) -> List[String] {
        var seq = Csv.ParseLine(line);
        var count = Seq.get_Length(seq);
        var fields: List[String] = [];
        var i = 0;
        while i < count {
            fields.add(Seq.GetStr(seq, i));
            i = i + 1;
        }
        return fields;
    }

    /// @brief Coerce a raw CSV cell to a `SqlValue` matching the
    ///        target column's declared type.  Empty cell → NULL.
    ///        Unknown type → TEXT.
    hide func parseCSVValue(value: String, table: Table, colIdx: Integer) -> SqlValue {
        var trimmed = String.Trim(value);
        if trimmed == "" {
            return sqlNull();
        }

        var maybeCol = table.getColumn(colIdx);
        if maybeCol == null {
            return sqlText(trimmed);
        }
        var col = maybeCol;

        if col.typeCode == SQL_INTEGER {
            return sqlInteger(stringToInt(trimmed));
        }
        if col.typeCode == SQL_REAL {
            return sqlReal(stringToNumber(trimmed), trimmed);
        }
        return sqlText(trimmed);
    }
}
