// =============================================================================
// threadpool.zia — Thread pool for accepting concurrent clients
// Part of ViperSQL  (package: server)
// =============================================================================
//
// PURPOSE
// -------
// Wraps the Viper runtime's `Viper.Threads.Pool` class so the SQL
// server can hand every new client to a worker thread without
// blocking its accept loop.  When the pool is off (the default for
// standalone-REPL mode), we fall back to spawning a fresh thread
// per connection — still correct, just less efficient.
//
// WHERE THIS FITS
// ---------------
//     vipersql.zia / main.zia
//         │  calls `sql_pool_init(size)` at startup
//         ▼
//     server/tcp_server.zia
//         │  accept loop
//         ▼
//     server/threadpool.zia   (YOU ARE HERE — submit to pool)
//         │
//         ▼
//     server/connection.zia   (handleSqlClient / handlePgClient)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Module-level state.  The pool is a singleton — one
//      server, one pool.  `pool`, `poolRunning`, `poolSize` are
//      plain module variables.  No class ceremony for a
//      genuinely-global resource.
//
//   2. Bounded size.  `sql_pool_init` clamps to `[1, 100]`.
//      Lower bound prevents the "0 workers = hang" footgun,
//      upper bound is a defensive cap against
//      `--pool-size=1000000`.
//
//   3. Fallback to direct thread spawn.  If the pool was never
//      initialised, `sql_pool_submit*` still works — it just
//      runs `Threads.Thread.StartSafe` for every client.  Means
//      the REPL mode doesn't need to bring up a pool it would
//      never use.
//
// HOW TO READ THIS FILE
// ---------------------
//   * Module state at the top.
//   * `sql_pool_init` — startup.
//   * `sql_pool_submit` / `sql_pool_submit_pg` — the two submit
//     paths (text protocol vs PG wire).
//   * Stats helpers at the bottom for the SHOW STATUS command.
//
// =============================================================================

module threadpool;

bind Viper.Terminal as Terminal;
bind Viper.Threads as Threads;
bind Viper.Fmt as Fmt;
bind Viper.Threads.Pool as Pool;
bind "./connection";

//=============================================================================
// MODULE STATE
//=============================================================================

// Pool handle.  Valid after `sql_pool_init` returns.
var pool: Pool;

// Whether `sql_pool_init` ran and set `pool`.  The submit paths
// branch on this — if false, they spawn threads directly.
var poolRunning: Boolean;

// Configured worker count.  Captured for the stats line.
var poolSize: Integer;

//=============================================================================
// INITIALIZATION
//=============================================================================

/// @brief Build the pool with `size` worker threads.
///
/// Clamps `size` to [1, 100] for the reasons in design choice 2.
/// Must be called before `sql_pool_submit*` if pool mode is
/// desired; otherwise the fallback thread-per-connection path
/// still works.
func sql_pool_init(size: Integer) {
    var requestedSize = size;
    if requestedSize < 1 { requestedSize = 1; }
    if requestedSize > 100 { requestedSize = 100; }
    poolSize = requestedSize;
    pool = Pool.New(requestedSize);
    poolRunning = true;
    Terminal.Say("Thread pool initialized: " + Fmt.Int(poolSize) + " workers");
}

//=============================================================================
// SUBMIT
//=============================================================================

/// @brief Run a text-protocol client in the pool (or a fresh
///        thread if no pool).  `client` is a raw network-handle
///        pointer the connection handler will unwrap.
func sql_pool_submit(client: Ptr) {
    if poolRunning {
        Pool.Submit(pool, &handleSqlClient, client);
    } else {
        Threads.Thread.StartSafe(&handleSqlClient, client);
    }
}

/// @brief Same as `sql_pool_submit` but dispatches to the PG
///        wire-protocol handler.  Separate function because the
///        two protocols have completely different entry points
///        and we want the pool-submit site to name the right
///        worker directly.
func sql_pool_submit_pg(client: Ptr) {
    if poolRunning {
        Pool.Submit(pool, &handlePgClient, client);
    } else {
        Threads.Thread.StartSafe(&handlePgClient, client);
    }
}

//=============================================================================
// STATISTICS
//=============================================================================

/// @brief One-line pool status for the SHOW STATUS command.
func sql_pool_stats() -> String {
    if poolRunning == false { return "Pool: not initialized"; }
    return "Pool: " + Fmt.Int(poolSize) + " workers, " +
           Fmt.Int(Pool.get_Active(pool)) + " active, " +
           Fmt.Int(Pool.get_Pending(pool)) + " pending";
}

/// @brief Configured worker count.
func sql_pool_size() -> Integer {
    return poolSize;
}

/// @brief "Has the pool been initialised?"
func sql_pool_is_running() -> Boolean {
    return poolRunning;
}
