// =============================================================================
// threadpool.zia — Managed worker handoff for concurrent clients
// Part of ViperSQL  (package: server)
// =============================================================================
//
// PURPOSE
// -------
// Provides the SQL server's safe managed worker handoff.  The native
// pool submit API is not VM-safe for managed callbacks yet,
// so ViperSQL uses `Thread.StartSafe` plus a `Gate` to cap active
// connection handlers while keeping socket handles strongly typed.
//
// WHERE THIS FITS
// ---------------
//     vipersql.zia / main.zia
//         │  calls `sql_pool_init(size)` at startup
//         ▼
//     server/tcp_server.zia
//         │  accept loop
//         ▼
//     server/threadpool.zia   (YOU ARE HERE — managed worker handoff)
//         │
//         ▼
//     server/connection.zia   (handleSqlClient / handlePgClient)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Module-level state.  The worker gate is a singleton — one
//      server, one concurrency gate.  `workerGate`, `poolRunning`, `poolSize` are
//      plain module variables.  No class ceremony for a
//      genuinely-global resource.
//
//   2. Bounded size.  `sql_pool_init` clamps to `[1, 100]`.
//      Lower bound prevents the "0 workers = hang" footgun,
//      upper bound is a defensive cap against
//      `--pool-size=1000000`.
//
//   3. Safe thread bridge.  Each accepted client runs through
//      `Threads.Thread.StartSafe`; when the gate is initialised,
//      only `poolSize` handlers may be active at once.
//
// HOW TO READ THIS FILE
// ---------------------
//   * Module state at the top.
//   * `sql_pool_init` — startup.
//   * `sql_pool_submit` / `sql_pool_submit_pg` — the two submit
//     paths (text protocol vs PG wire).
//   * Stats helpers at the bottom for the SHOW STATUS command.
//
// =============================================================================

module threadpool;

bind Viper.Terminal as Terminal;
bind Viper.Threads as Threads;
bind Viper.Text.Fmt as Fmt;
bind Viper.Threads.Gate as Gate;
bind "./connection";

//=============================================================================
// MODULE STATE
//=============================================================================

// Worker gate.  Valid after `sql_pool_init` returns.
var workerGate: Gate;

// Whether `sql_pool_init` ran and set `workerGate`.
var poolRunning: Boolean;

// Configured worker count.  Captured for the stats line.
var poolSize: Integer;

//=============================================================================
// INITIALIZATION
//=============================================================================

/// @brief Build the managed worker gate with `size` permits.
///
/// Clamps `size` to [1, 100] for the reasons in design choice 2.
/// Must be called before `sql_pool_submit*` if bounded worker mode is
/// desired; otherwise the fallback thread-per-connection path
/// still works.
func sql_pool_init(size: Integer) {
    var requestedSize = size;
    if requestedSize < 1 { requestedSize = 1; }
    if requestedSize > 100 { requestedSize = 100; }
    poolSize = requestedSize;
    workerGate = Gate.New(requestedSize);
    poolRunning = true;
    Terminal.Say("Managed worker gate initialized: " + Fmt.Int(poolSize) + " active handlers");
}

//=============================================================================
// SUBMIT
//=============================================================================

/// @brief Text-protocol worker entry used by the safe thread bridge.
func runSqlClientWithGate(client: Viper.Network.Tcp) {
    if poolRunning {
        Gate.Enter(workerGate);
        handleSqlClient(client);
        Gate.Leave(workerGate);
    } else {
        handleSqlClient(client);
    }
}

/// @brief PG-wire worker entry used by the safe thread bridge.
func runPgClientWithGate(client: Viper.Network.Tcp) {
    if poolRunning {
        Gate.Enter(workerGate);
        handlePgClient(client);
        Gate.Leave(workerGate);
    } else {
        handlePgClient(client);
    }
}

/// @brief Run a text-protocol client on the safe managed thread bridge.
func sql_pool_submit(client: Viper.Network.Tcp) {
    Threads.Thread.StartSafe(&runSqlClientWithGate, client);
}

/// @brief Same as `sql_pool_submit` but dispatches to the PG
///        wire-protocol handler.  Separate function because the
///        two protocols have completely different entry points
///        and we want the submit site to name the right
///        worker directly.
func sql_pool_submit_pg(client: Viper.Network.Tcp) {
    Threads.Thread.StartSafe(&runPgClientWithGate, client);
}

//=============================================================================
// STATISTICS
//=============================================================================

/// @brief One-line worker status for the SHOW STATUS command.
func sql_pool_stats() -> String {
    if poolRunning == false { return "Worker gate: not initialized"; }
    var available = Gate.get_Permits(workerGate);
    return "Worker gate: " + Fmt.Int(poolSize) + " max active, " +
           Fmt.Int(poolSize - available) + " active, " +
           Fmt.Int(available) + " available";
}

/// @brief Configured worker count.
func sql_pool_size() -> Integer {
    return poolSize;
}

/// @brief "Has the worker gate been initialised?"
func sql_pool_is_running() -> Boolean {
    return poolRunning;
}
