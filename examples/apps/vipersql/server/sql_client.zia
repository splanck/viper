// =============================================================================
// sql_client.zia — Text-protocol SQL client + interactive driver
// Part of ViperSQL  (package: server)
// =============================================================================
//
// PURPOSE
// -------
// A text-only CLI client that talks to ViperSQL's text protocol
// server on port 5433.  Simple line-at-a-time request/response —
// no PG wire framing.  Useful for `nc`-style debugging and for
// testing that the text server is wired up.
//
// Layered on top of `Viper.Network.Tcp`:
//   * `SqlClient`         — the connection + request/response API.
//   * `runInteractive`    — REPL loop driving one SqlClient.
//   * `main`              — default entry that connects to
//                           localhost:5432.
//
// NOTE: the richer PG-wire client lives in
// `client/pg_client.zia`; `client/vsql.zia` is the production CLI.
// This file is the simpler "talk to the text port" cousin.
//
// WHERE THIS FITS
// ---------------
//     sql_client.zia  (YOU ARE HERE — text client)
//         │
//         ▼
//     server/sql_server.zia  (text protocol server — listens on
//                             port 5433)
//
// KEY DESIGN CHOICES
// ------------------
//   1. "READY" as the end-of-response marker.  The text server
//      sends `READY\n` after each result.  The client reads
//      until it sees that token, then strips it.
//
//   2. One TCP recv per turn.  We call `RecvStr(..., 1 MB)` in a
//      loop until we see `READY`.  No framing byte count — rely
//      on the sentinel.
//
//   3. SEND `QUIT` on disconnect.  Clean shutdown lets the
//      server free the session without waiting for TCP RST.
//
// =============================================================================

module sql_client;

bind Viper.Network as Network;
bind Viper.Terminal as Terminal;
bind Viper.String as String;
bind Viper.Fmt as Fmt;

//=============================================================================
// CLIENT CONSTANTS
//=============================================================================

/// @brief Default server port.  Set to 5432 (PG convention) —
///        usually overridden since the text server lives on
///        5433, but defaults are kept consistent with the PG
///        default so both clients look alike.
final DEFAULT_PORT = 5432;

/// @brief Maximum bytes per `RecvStr` call.  1 MB is plenty for
///        typical query results; larger ones chunk naturally.
final MAX_RESPONSE_SIZE = 1048576;

/// @brief Per-recv timeout in milliseconds.
final RECV_TIMEOUT = 30000;

//=============================================================================
// SQL CLIENT
//=============================================================================

/// @brief A text-protocol client.  One `SqlClient` = one active
///        TCP connection + the last error message (if any).
class SqlClient {
    expose String host;
    expose Integer port;
    expose TcpClient connection;
    expose Boolean connected;
    expose String lastError;

    /// @brief Default init.  `connect` must be called before
    ///        sending queries.
    expose func init() {
        host = "localhost";
        port = DEFAULT_PORT;
        connected = false;
        lastError = "";
    }

    /// @brief Init with explicit host / port.  Typical path
    ///        from CLI arguments.
    expose func initWithHostPort(h: String, p: Integer) {
        host = h;
        port = p;
        connected = false;
        lastError = "";
    }

    //=========================================================================
    // CONNECTION
    //=========================================================================

    /// @brief Dial the server and wait for the initial `READY`
    ///        greeting.  Returns false if the server does not
    ///        send `READY` as the first message — caller checks
    ///        `lastError` for the reason.
    expose func connect() -> Boolean {
        connection = Network.Tcp.Connect(host, port);
        connected = true;

        Network.Tcp.SetRecvTimeout(connection, RECV_TIMEOUT);

        var response = Network.Tcp.RecvStr(connection, MAX_RESPONSE_SIZE);
        if String.Contains(response, "READY") == false {
            lastError = "Server did not send READY";
            disconnect();
            return false;
        }

        return true;
    }

    /// @brief Clean disconnect: send `QUIT`, close the socket.
    ///        Idempotent — second call is a no-op.
    expose func disconnect() {
        if connected {
            Network.Tcp.SendStr(connection, "QUIT\n");
            Network.Tcp.Close(connection);
            connected = false;
        }
    }

    /// @brief "Is this client connected?"
    expose func isConnected() -> Boolean {
        return connected;
    }

    //=========================================================================
    // QUERY EXECUTION
    //=========================================================================

    /// @brief Send a query, gather the response until `READY`,
    ///        return the response text minus the sentinel.
    ///
    /// Chunks via `RecvStr(..., MAX_RESPONSE_SIZE)` in a loop.
    /// If the server closes the socket mid-response,
    /// `RecvStr` returns "" and we terminate — the caller sees
    /// a partial result, which is the best we can do without
    /// framing.
    expose func execute(query: String) -> String {
        if connected == false {
            lastError = "Not connected";
            return "";
        }

        Network.Tcp.SendStr(connection, query + "\n");

        var response = "";
        var done = false;

        while done == false {
            var chunk = Network.Tcp.RecvStr(connection, MAX_RESPONSE_SIZE);
            if String.Length(chunk) == 0 {
                done = true;
            } else {
                response = response + chunk;
                if String.Contains(chunk, "READY") {
                    done = true;
                }
            }
        }

        // Strip the trailing READY sentinel — everything after
        // the first occurrence is metadata the caller doesn't
        // want.
        var readyPos = String.IndexOf(response, "READY");
        if readyPos >= 0 {
            response = String.Substring(response, 0, readyPos);
        }

        return String.Trim(response);
    }

    /// @brief Execute + print convenience wrapper.  Used by the
    ///        REPL below.
    expose func executeAndPrint(query: String) {
        var result = execute(query);
        if String.Length(result) > 0 {
            Terminal.Say(result);
        }
    }

    //=========================================================================
    // ERROR HANDLING
    //=========================================================================

    /// @brief Last error from `connect` or `execute`.  Cleared
    ///        on every new call.
    expose func getLastError() -> String {
        return lastError;
    }
}

//=============================================================================
// INTERACTIVE CLIENT
//=============================================================================

/// @brief REPL: connect, read-eval-print loop, disconnect.
///
/// Exit keywords: `quit`, `exit`, `\q`.  Any other non-empty
/// input is sent as a query via `executeAndPrint`.
func runInteractive(host: String, port: Integer) {
    var client = new SqlClient();
    client.initWithHostPort(host, port);

    Terminal.Say("Connecting to " + host + ":" + Fmt.Int(port) + "...");

    if client.connect() == false {
        Terminal.Say("Connection failed: " + client.getLastError());
        return;
    }

    Terminal.Say("Connected to ViperSQL server");
    Terminal.Say("Type SQL queries or 'quit' to exit");
    Terminal.Say("");

    var running = true;
    while running {
        Terminal.Say("vipersql> ");
        var input = Terminal.Hear();
        var query = String.Trim(input);

        if query == "quit" || query == "exit" || query == "\\q" {
            running = false;
        } else if String.Length(query) > 0 {
            client.executeAndPrint(query);
            Terminal.Say("");
        }
    }

    client.disconnect();
    Terminal.Say("Disconnected.");
}

//=============================================================================
// MAIN
//=============================================================================

/// @brief Top-level entry — print the banner and start the REPL
///        against `localhost:DEFAULT_PORT`.
func main() {
    Terminal.Say("========================================");
    Terminal.Say("  ViperSQL Client");
    Terminal.Say("========================================");
    Terminal.Say("");

    runInteractive("localhost", DEFAULT_PORT);
}
