// =============================================================================
// main.zia — Standalone REPL entry point
// Part of ViperSQL
// =============================================================================
//
// PURPOSE
// -------
// A one-user, in-memory SQL shell.  Runs a read-eval-print loop
// around a single `Executor` — no networking, no persistent
// storage, no authentication.  Useful for quick experimentation
// and for the test harness.
//
// Supports multi-line pasted input (any SQL the parser accepts is
// fair game) and a small set of meta-commands that start with `.`:
//
//     .help          show help
//     .quit / .exit  leave the shell
//     .tables        list tables (equivalent to SHOW TABLES)
//     .schema        print CREATE TABLE for every table
//     .schema <tbl>  print CREATE TABLE for one table
//
// For the multi-user server, see `vipersql.zia` (which also has
// a `--repl` flag wrapping the same meta-command vocabulary).
//
// WHERE THIS FITS
// ---------------
//     main.zia   (YOU ARE HERE — standalone REPL)
//         │
//         ▼
//     engine/executor.zia  (the only subsystem we touch)
//
// HOW TO READ THIS FILE
// ---------------------
//   * `main` — the REPL loop.
//   * `processMetaCommand` — dispatch for the `.xxx` commands.
//
// =============================================================================

module main;

bind Viper.Terminal as Terminal;
bind Viper.String as String;
bind "./engine/executor";

//=============================================================================
// MAIN ENTRY POINT
//=============================================================================

/// @brief The REPL loop.
///
/// Flow per iteration:
///   1. Print the `sql>` prompt.
///   2. Read a line.  Null (Ctrl-D / EOF) exits.
///   3. Empty line: re-prompt.
///   4. `.`-prefixed line: route to `processMetaCommand`.
///   5. Anything else: treat as SQL, run through the executor,
///      print the `QueryResult.toString()` rendering.
func main() {
    Terminal.Say("ViperSQL - Standalone Mode (in-memory)");
    Terminal.Say("Type SQL commands or 'exit' to quit.");
    Terminal.Say("Type .help for meta-commands.");
    Terminal.Say("For server mode, run vipersql.zia instead.");
    Terminal.Say("");

    var exec = new Executor();
    exec.init();

    var running = true;
    while running {
        Terminal.Print("sql> ");
        var rawInput = Terminal.ReadLine();
        if rawInput == null {
            running = false;
            continue;
        }
        var input = rawInput!;

        if input == "exit" || input == "quit" {
            running = false;
            continue;
        }

        if input == "" {
            continue;
        }

        // Meta-commands start with `.` — the SQLite / psql-flavoured
        // convention.  We route to `processMetaCommand` for those.
        var trimmed = String.Trim(input);
        if String.StartsWith(trimmed, ".") {
            processMetaCommand(trimmed, exec);
            continue;
        }

        // Normal SQL path: execute, print the result table.
        var result = exec.executeSql(input);
        Terminal.Say(result.toString());
        Terminal.Say("");
    }

    Terminal.Say("Goodbye!");
}

/// @brief Dispatch table for REPL meta-commands.
///
/// Normalises to lower-case once at the top so subsequent
/// comparisons are case-insensitive.  `.schema <tbl>` is matched
/// by prefix because it carries an argument; the rest are exact
/// equality.
///
/// Unknown commands print a usage hint — do not crash.
func processMetaCommand(cmd: String, exec: Executor) {
    var lower = String.ToLower(cmd);

    if lower == ".help" {
        Terminal.Say("");
        Terminal.Say("Meta-commands:");
        Terminal.Say("  .help          Show this help");
        Terminal.Say("  .quit/.exit    Exit the shell");
        Terminal.Say("  .tables        List all tables");
        Terminal.Say("  .schema        Show all table schemas");
        Terminal.Say("  .schema <tbl>  Show table schema");
        Terminal.Say("");
        return;
    }

    if lower == ".quit" || lower == ".exit" {
        Terminal.Say("Goodbye!");
        return;
    }

    if lower == ".tables" {
        var result = exec.executeSql("SHOW TABLES");
        Terminal.Say(result.toString());
        Terminal.Say("");
        return;
    }

    if lower == ".schema" {
        // No argument: iterate every table, DESCRIBE each.
        var tablesResult = exec.executeSql("SHOW TABLES");
        var ti = 0;
        while ti < tablesResult.rowCount() {
            var row = tablesResult.getRow(ti);
            if row != null {
                var r = row;
                var tableName = r.getValue(0).textValue;
                Terminal.Say("");
                Terminal.Say("Table: " + tableName);
                var descResult = exec.executeSql("DESCRIBE " + tableName);
                Terminal.Say(descResult.toString());
            }
            ti = ti + 1;
        }
        Terminal.Say("");
        return;
    }

    if String.StartsWith(lower, ".schema ") {
        // With argument: show the single named table.  We use the
        // *original* case-preserved `cmd` here so identifier
        // lookups remain case-sensitive.
        var tableName = String.Substring(cmd, 8, String.Length(cmd) - 8);
        tableName = String.Trim(tableName);
        var result = exec.executeSql("DESCRIBE " + tableName);
        Terminal.Say(result.toString());
        Terminal.Say("");
        return;
    }

    Terminal.Say("Unknown command: " + cmd);
    Terminal.Say("Type .help for help");
    Terminal.Say("");
}
