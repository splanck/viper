// test_comprehensive.zia — Comprehensive Feature & Stress Tests
// Part of ViperSQL
//
// An extensive battery of tests designed to probe edge cases, stress test
// the database engine, and validate correct behavior across feature
// interactions. Covers: NULL semantics, type coercion, division by zero,
// empty tables, deep nesting, large data, string edge cases, transaction
// integrity, constraint enforcement, and feature interactions.

module test_comprehensive;

bind Terminal = Viper.Terminal;
bind Fmt = Viper.Fmt;
bind String = Viper.String;

bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// 1. NULL SEMANTICS — Three-Valued Logic Edge Cases
//=============================================================================

func testNullSemantics() {
    section("NULL Semantics — Three-Valued Logic");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE nulls (id INTEGER, val INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO nulls VALUES (1, 10, 'alpha')");
    exec.executeSql("INSERT INTO nulls VALUES (2, NULL, 'beta')");
    exec.executeSql("INSERT INTO nulls VALUES (3, NULL, NULL)");
    exec.executeSql("INSERT INTO nulls VALUES (4, 0, '')");
    exec.executeSql("INSERT INTO nulls VALUES (5, 10, 'alpha')");

    // NULL = NULL should be false (SQL standard)
    var r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val = NULL");
    assertSuccess(r, "NULL = NULL query");
    assertEq(val(r, 0, 0), "0", "NULL = NULL returns no rows");

    // NULL IS NULL should be true
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val IS NULL");
    assertSuccess(r, "IS NULL query");
    assertEq(val(r, 0, 0), "2", "IS NULL returns 2 rows (ids 2,3)");

    // NULL IS NOT NULL should be false for NULLs
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val IS NOT NULL");
    assertSuccess(r, "IS NOT NULL query");
    assertEq(val(r, 0, 0), "3", "IS NOT NULL returns 3 rows");

    // NULL in arithmetic — any op with NULL should produce NULL
    r = exec.executeSql("SELECT val + 5 FROM nulls WHERE id = 2");
    assertSuccess(r, "NULL + 5");
    // The result should be NULL (displayed as empty or NULL)

    // NULL in comparison — WHERE val > 5 should exclude NULLs
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val > 5");
    assertSuccess(r, "val > 5 excludes NULLs");
    assertEq(val(r, 0, 0), "2", "val > 5 returns 2 rows (ids 1,5)");

    // NOT NULL — val <> 10 should still exclude NULLs
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val <> 10");
    assertSuccess(r, "val <> 10 excludes NULLs");
    assertEq(val(r, 0, 0), "1", "val <> 10 returns 1 row (id 4, val=0)");

    // COALESCE — should return first non-null
    r = exec.executeSql("SELECT COALESCE(val, -1) FROM nulls WHERE id = 2");
    assertSuccess(r, "COALESCE with NULL");
    assertEq(val(r, 0, 0), "-1", "COALESCE returns -1 for NULL");

    r = exec.executeSql("SELECT COALESCE(val, -1) FROM nulls WHERE id = 1");
    assertSuccess(r, "COALESCE with non-NULL");
    assertEq(val(r, 0, 0), "10", "COALESCE returns 10 for non-NULL");

    // NULLIF — returns NULL if args equal
    r = exec.executeSql("SELECT NULLIF(val, 10) FROM nulls WHERE id = 1");
    assertSuccess(r, "NULLIF equal");

    r = exec.executeSql("SELECT NULLIF(val, 99) FROM nulls WHERE id = 1");
    assertSuccess(r, "NULLIF not equal");
    assertEq(val(r, 0, 0), "10", "NULLIF returns value when not equal");

    // NULL in aggregates — COUNT(*) counts all, COUNT(col) skips NULLs
    r = exec.executeSql("SELECT COUNT(*), COUNT(val) FROM nulls");
    assertSuccess(r, "COUNT(*) vs COUNT(col)");
    assertEq(val(r, 0, 0), "5", "COUNT(*) = 5");
    assertEq(val(r, 0, 1), "3", "COUNT(val) = 3 (skips NULLs)");

    // SUM/AVG should skip NULLs
    r = exec.executeSql("SELECT SUM(val), AVG(val) FROM nulls");
    assertSuccess(r, "SUM/AVG with NULLs");
    assertEq(val(r, 0, 0), "20", "SUM(val) = 20 (10+0+10)");

    // MIN/MAX should skip NULLs
    r = exec.executeSql("SELECT MIN(val), MAX(val) FROM nulls");
    assertSuccess(r, "MIN/MAX with NULLs");
    assertEq(val(r, 0, 0), "0", "MIN(val) = 0");
    assertEq(val(r, 0, 1), "10", "MAX(val) = 10");

    // NULL in DISTINCT
    r = exec.executeSql("SELECT DISTINCT val FROM nulls ORDER BY val");
    assertSuccess(r, "DISTINCT with NULLs");

    // NULL in GROUP BY — NULLs should group together
    r = exec.executeSql("SELECT val, COUNT(*) FROM nulls GROUP BY val ORDER BY val");
    assertSuccess(r, "GROUP BY with NULLs");

    // NULL in ORDER BY — NULLs sort behavior
    r = exec.executeSql("SELECT id, val FROM nulls ORDER BY val NULLS FIRST");
    assertSuccess(r, "ORDER BY NULLS FIRST");

    r = exec.executeSql("SELECT id, val FROM nulls ORDER BY val NULLS LAST");
    assertSuccess(r, "ORDER BY NULLS LAST");

    // NULL in CASE WHEN
    r = exec.executeSql("SELECT CASE WHEN val IS NULL THEN 'missing' ELSE 'present' END FROM nulls WHERE id = 2");
    assertSuccess(r, "CASE WHEN IS NULL");
    assertEq(val(r, 0, 0), "missing", "CASE with NULL");

    // NULL in IN list
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val IN (10, NULL)");
    assertSuccess(r, "IN list with NULL");
    // Standard SQL: NULL IN (...) is unknown, so only exact matches count
    assertEq(val(r, 0, 0), "2", "IN with NULL matches non-NULL values only");

    // NULL in BETWEEN
    r = exec.executeSql("SELECT COUNT(*) FROM nulls WHERE val BETWEEN 0 AND 100");
    assertSuccess(r, "BETWEEN with NULLs");
    assertEq(val(r, 0, 0), "3", "BETWEEN skips NULLs");
}

//=============================================================================
// 2. TYPE COERCION — Mixed-Type Operations
//=============================================================================

func testTypeCoercion() {
    section("Type Coercion — Mixed Types");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE types (id INTEGER, ival INTEGER, rval REAL, tval TEXT, bval BOOLEAN)");
    exec.executeSql("INSERT INTO types VALUES (1, 42, 3.14, '100', true)");
    exec.executeSql("INSERT INTO types VALUES (2, 0, 0.0, '0', false)");
    exec.executeSql("INSERT INTO types VALUES (3, -1, -2.5, '-50', true)");

    // Integer + Real = Real
    var r = exec.executeSql("SELECT ival + rval FROM types WHERE id = 1");
    assertSuccess(r, "int + real");

    // CAST operations
    r = exec.executeSql("SELECT CAST(tval AS INTEGER) FROM types WHERE id = 1");
    assertSuccess(r, "CAST text to integer");
    assertEq(val(r, 0, 0), "100", "CAST '100' to INTEGER");

    r = exec.executeSql("SELECT CAST(ival AS TEXT) FROM types WHERE id = 1");
    assertSuccess(r, "CAST integer to text");
    assertEq(val(r, 0, 0), "42", "CAST 42 to TEXT");

    r = exec.executeSql("SELECT CAST(rval AS INTEGER) FROM types WHERE id = 1");
    assertSuccess(r, "CAST real to integer");

    // Boolean coercion
    r = exec.executeSql("SELECT COUNT(*) FROM types WHERE bval = true");
    assertSuccess(r, "boolean true comparison");
    assertEq(val(r, 0, 0), "2", "2 rows with bval=true");

    // Text comparison
    r = exec.executeSql("SELECT tval FROM types ORDER BY tval");
    assertSuccess(r, "text ordering");

    // Negative numbers in expressions
    r = exec.executeSql("SELECT ival * -1 FROM types WHERE id = 3");
    assertSuccess(r, "multiply by -1");
    assertEq(val(r, 0, 0), "1", "(-1) * -1 = 1");

    // Modulo operator
    r = exec.executeSql("SELECT 17 % 5");
    assertSuccess(r, "modulo");
    assertEq(val(r, 0, 0), "2", "17 % 5 = 2");

    // String concatenation with ||
    r = exec.executeSql("SELECT 'hello' || ' ' || 'world'");
    assertSuccess(r, "string concat");
    assertEq(val(r, 0, 0), "hello world", "concat result");
}

//=============================================================================
// 3. DIVISION BY ZERO & ARITHMETIC EDGE CASES
//=============================================================================

func testArithmeticEdgeCases() {
    section("Arithmetic Edge Cases");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE arith (id INTEGER, a INTEGER, b INTEGER)");
    exec.executeSql("INSERT INTO arith VALUES (1, 10, 0)");
    exec.executeSql("INSERT INTO arith VALUES (2, 100, 3)");
    exec.executeSql("INSERT INTO arith VALUES (3, 0, 0)");
    exec.executeSql("INSERT INTO arith VALUES (4, -100, 7)");

    // Division by zero — should not crash, should return NULL or error gracefully
    var r = exec.executeSql("SELECT a / b FROM arith WHERE id = 1");
    assertSuccess(r, "div by zero doesn't crash");

    // 0 / 0
    r = exec.executeSql("SELECT a / b FROM arith WHERE id = 3");
    assertSuccess(r, "0/0 doesn't crash");

    // Integer division truncation
    r = exec.executeSql("SELECT 7 / 2");
    assertSuccess(r, "integer division");
    assertEq(val(r, 0, 0), "3", "7 / 2 = 3 (truncated)");

    // Negative integer division
    r = exec.executeSql("SELECT -7 / 2");
    assertSuccess(r, "negative int division");

    // Large numbers
    r = exec.executeSql("SELECT 999999999 * 999999999");
    assertSuccess(r, "large multiplication");

    // Modulo with zero — should not crash
    r = exec.executeSql("SELECT 10 % 0");
    assertSuccess(r, "modulo by zero doesn't crash");

    // Order of operations
    r = exec.executeSql("SELECT 2 + 3 * 4");
    assertSuccess(r, "order of operations");
    assertEq(val(r, 0, 0), "14", "2 + 3*4 = 14");

    r = exec.executeSql("SELECT (2 + 3) * 4");
    assertSuccess(r, "parenthesized expression");
    assertEq(val(r, 0, 0), "20", "(2+3)*4 = 20");

    // Unary minus
    r = exec.executeSql("SELECT -(-5)");
    assertSuccess(r, "double negative");
    assertEq(val(r, 0, 0), "5", "-(-5) = 5");
}

//=============================================================================
// 4. EMPTY TABLE OPERATIONS
//=============================================================================

func testEmptyTableOps() {
    section("Empty Table Operations");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE empty (id INTEGER, name TEXT, val INTEGER)");

    // SELECT from empty table
    var r = exec.executeSql("SELECT * FROM empty");
    assertSuccess(r, "SELECT from empty");
    assertRowCount(r, 0, "empty returns 0 rows");

    // COUNT on empty table
    r = exec.executeSql("SELECT COUNT(*) FROM empty");
    assertSuccess(r, "COUNT on empty");
    assertEq(val(r, 0, 0), "0", "COUNT(*) = 0");

    // SUM/AVG/MIN/MAX on empty table — should return NULL
    r = exec.executeSql("SELECT SUM(val) FROM empty");
    assertSuccess(r, "SUM on empty");

    r = exec.executeSql("SELECT AVG(val) FROM empty");
    assertSuccess(r, "AVG on empty");

    r = exec.executeSql("SELECT MIN(val), MAX(val) FROM empty");
    assertSuccess(r, "MIN/MAX on empty");

    // GROUP BY on empty table
    r = exec.executeSql("SELECT name, COUNT(*) FROM empty GROUP BY name");
    assertSuccess(r, "GROUP BY on empty");
    assertRowCount(r, 0, "GROUP BY on empty = 0 groups");

    // HAVING on empty table
    r = exec.executeSql("SELECT name, COUNT(*) FROM empty GROUP BY name HAVING COUNT(*) > 0");
    assertSuccess(r, "HAVING on empty");
    assertRowCount(r, 0, "HAVING on empty = 0 rows");

    // DELETE from empty table
    r = exec.executeSql("DELETE FROM empty WHERE id = 1");
    assertSuccess(r, "DELETE from empty");
    assertEqInt(r.rowsAffected, 0, "DELETE 0 rows from empty");

    // UPDATE on empty table
    r = exec.executeSql("UPDATE empty SET val = 100 WHERE id = 1");
    assertSuccess(r, "UPDATE on empty");
    assertEqInt(r.rowsAffected, 0, "UPDATE 0 rows on empty");

    // JOIN with empty table
    exec.executeSql("CREATE TABLE nonempty (id INTEGER, label TEXT)");
    exec.executeSql("INSERT INTO nonempty VALUES (1, 'a')");
    exec.executeSql("INSERT INTO nonempty VALUES (2, 'b')");

    r = exec.executeSql("SELECT * FROM nonempty INNER JOIN empty ON nonempty.id = empty.id");
    assertSuccess(r, "INNER JOIN with empty");
    assertRowCount(r, 0, "INNER JOIN with empty = 0 rows");

    r = exec.executeSql("SELECT * FROM nonempty LEFT JOIN empty ON nonempty.id = empty.id");
    assertSuccess(r, "LEFT JOIN with empty");
    assertRowCount(r, 2, "LEFT JOIN with empty preserves left rows");

    // EXISTS on empty table
    r = exec.executeSql("SELECT COUNT(*) FROM nonempty WHERE EXISTS (SELECT 1 FROM empty)");
    assertSuccess(r, "EXISTS on empty subquery");
    assertEq(val(r, 0, 0), "0", "EXISTS on empty = false");

    // IN with empty subquery
    r = exec.executeSql("SELECT COUNT(*) FROM nonempty WHERE id IN (SELECT id FROM empty)");
    assertSuccess(r, "IN empty subquery");
    assertEq(val(r, 0, 0), "0", "IN empty subquery = 0");
}

//=============================================================================
// 5. STRING EDGE CASES
//=============================================================================

func testStringEdgeCases() {
    section("String Edge Cases");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE strings (id INTEGER, val TEXT)");

    // Empty string
    exec.executeSql("INSERT INTO strings VALUES (1, '')");
    var r = exec.executeSql("SELECT LENGTH(val) FROM strings WHERE id = 1");
    assertSuccess(r, "empty string length");
    assertEq(val(r, 0, 0), "0", "LENGTH('') = 0");

    // String with single quotes (SQL escaping)
    exec.executeSql("INSERT INTO strings VALUES (2, 'it''s a test')");
    r = exec.executeSql("SELECT val FROM strings WHERE id = 2");
    assertSuccess(r, "escaped quote");
    assertEq(val(r, 0, 0), "it's a test", "doubled quote works");

    // String with special characters
    exec.executeSql("INSERT INTO strings VALUES (3, 'hello\nworld')");
    r = exec.executeSql("SELECT LENGTH(val) FROM strings WHERE id = 3");
    assertSuccess(r, "string with newline");

    // Very long string
    var longStr = "";
    var li = 0;
    while li < 200 {
        longStr = longStr + "x";
        li = li + 1;
    }
    exec.executeSql("INSERT INTO strings VALUES (4, '" + longStr + "')");
    r = exec.executeSql("SELECT LENGTH(val) FROM strings WHERE id = 4");
    assertSuccess(r, "long string insert");
    assertEq(val(r, 0, 0), "200", "200-char string stored correctly");

    // UPPER/LOWER on empty string
    r = exec.executeSql("SELECT UPPER(''), LOWER('')");
    assertSuccess(r, "UPPER/LOWER empty string");

    // TRIM variants
    r = exec.executeSql("SELECT TRIM('  hello  ')");
    assertSuccess(r, "TRIM");
    assertEq(val(r, 0, 0), "hello", "TRIM works");

    r = exec.executeSql("SELECT LTRIM('  hello')");
    assertSuccess(r, "LTRIM");
    assertEq(val(r, 0, 0), "hello", "LTRIM works");

    r = exec.executeSql("SELECT RTRIM('hello  ')");
    assertSuccess(r, "RTRIM");
    assertEq(val(r, 0, 0), "hello", "RTRIM works");

    // REPLACE
    r = exec.executeSql("SELECT REPLACE('aabbcc', 'bb', 'XX')");
    assertSuccess(r, "REPLACE");
    assertEq(val(r, 0, 0), "aaXXcc", "REPLACE works");

    // SUBSTR boundary
    r = exec.executeSql("SELECT SUBSTR('hello', 1, 100)");
    assertSuccess(r, "SUBSTR past end");
    assertEq(val(r, 0, 0), "hello", "SUBSTR past end returns full string");

    r = exec.executeSql("SELECT SUBSTR('hello', 3)");
    assertSuccess(r, "SUBSTR without length");
    assertEq(val(r, 0, 0), "llo", "SUBSTR from pos 3");

    // LIKE patterns
    r = exec.executeSql("SELECT COUNT(*) FROM strings WHERE val LIKE '%test%'");
    assertSuccess(r, "LIKE wildcard");

    r = exec.executeSql("SELECT COUNT(*) FROM strings WHERE val LIKE ''");
    assertSuccess(r, "LIKE empty pattern");

    // Concatenation with NULL
    r = exec.executeSql("SELECT 'hello' || NULL");
    assertSuccess(r, "concat with NULL");
}

//=============================================================================
// 6. DEEP NESTING — Subqueries, CASE, CTEs
//=============================================================================

func testDeepNesting() {
    section("Deep Nesting — Subqueries, CASE, CTEs");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE data (id INTEGER, category TEXT, value INTEGER)");
    exec.executeSql("INSERT INTO data VALUES (1, 'A', 10)");
    exec.executeSql("INSERT INTO data VALUES (2, 'A', 20)");
    exec.executeSql("INSERT INTO data VALUES (3, 'B', 30)");
    exec.executeSql("INSERT INTO data VALUES (4, 'B', 40)");
    exec.executeSql("INSERT INTO data VALUES (5, 'C', 50)");

    // Subquery in WHERE
    var r = exec.executeSql("SELECT * FROM data WHERE value > (SELECT AVG(value) FROM data)");
    assertSuccess(r, "subquery in WHERE");
    assertRowCount(r, 2, "values > avg(30) = 2 rows (40, 50)");

    // Subquery in SELECT (scalar subquery)
    r = exec.executeSql("SELECT id, (SELECT MAX(value) FROM data) AS maxval FROM data WHERE id = 1");
    assertSuccess(r, "scalar subquery in SELECT");
    assertEq(val(r, 0, 1), "50", "scalar subquery returns max");

    // Nested CASE expressions
    r = exec.executeSql("SELECT id, CASE WHEN value > 40 THEN 'high' WHEN value > 20 THEN CASE WHEN category = 'B' THEN 'mid-B' ELSE 'mid-other' END ELSE 'low' END AS label FROM data ORDER BY id");
    assertSuccess(r, "nested CASE");
    assertEq(val(r, 0, 0), "1", "nested case id=1");
    assertEq(val(r, 0, 1), "low", "id=1 val=10 -> low");
    assertEq(val(r, 2, 1), "mid-B", "id=3 cat=B val=30 -> mid-B");
    assertEq(val(r, 4, 1), "high", "id=5 val=50 -> high");

    // CTE
    r = exec.executeSql("WITH summary AS (SELECT category, SUM(value) AS total FROM data GROUP BY category) SELECT category, total FROM summary ORDER BY total DESC");
    assertSuccess(r, "CTE query");
    assertEq(val(r, 0, 0), "B", "highest total = B (70)");
    assertEq(val(r, 0, 1), "70", "B total = 70");
    assertEq(val(r, 1, 0), "C", "second = C (50)");
    assertEq(val(r, 2, 0), "A", "third = A (30)");

    // Multiple CTEs
    r = exec.executeSql("WITH cat_totals AS (SELECT category, SUM(value) AS total FROM data GROUP BY category), ranked AS (SELECT category, total FROM cat_totals WHERE total > 30) SELECT * FROM ranked ORDER BY total DESC");
    assertSuccess(r, "multiple CTEs");
    assertRowCount(r, 2, "2 categories with total > 30");

    // Subquery in FROM (derived table)
    r = exec.executeSql("SELECT sub.category, sub.cnt FROM (SELECT category, COUNT(*) AS cnt FROM data GROUP BY category) AS sub ORDER BY sub.cnt DESC");
    assertSuccess(r, "derived table (subquery in FROM)");
    assertRowCount(r, 3, "3 categories from derived table");

    // EXISTS with correlated subquery
    r = exec.executeSql("SELECT d1.id FROM data d1 WHERE EXISTS (SELECT 1 FROM data d2 WHERE d2.category = d1.category AND d2.id <> d1.id) ORDER BY d1.id");
    assertSuccess(r, "correlated EXISTS");
    // A has 2 rows, B has 2 rows — those 4 have siblings
    assertRowCount(r, 4, "4 rows have same-category siblings");
}

//=============================================================================
// 7. JOIN COMPLEXITY
//=============================================================================

func testJoinComplexity() {
    section("Join Complexity — Multi-table, Self-join, Outer");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE departments (id INTEGER PRIMARY KEY, name TEXT)");
    exec.executeSql("INSERT INTO departments VALUES (1, 'Engineering')");
    exec.executeSql("INSERT INTO departments VALUES (2, 'Marketing')");
    exec.executeSql("INSERT INTO departments VALUES (3, 'Sales')");

    exec.executeSql("CREATE TABLE employees (id INTEGER PRIMARY KEY, name TEXT, dept_id INTEGER, manager_id INTEGER)");
    exec.executeSql("INSERT INTO employees VALUES (1, 'Alice', 1, NULL)");
    exec.executeSql("INSERT INTO employees VALUES (2, 'Bob', 1, 1)");
    exec.executeSql("INSERT INTO employees VALUES (3, 'Charlie', 2, 1)");
    exec.executeSql("INSERT INTO employees VALUES (4, 'Diana', 2, 3)");
    exec.executeSql("INSERT INTO employees VALUES (5, 'Eve', NULL, 1)");

    exec.executeSql("CREATE TABLE projects (id INTEGER PRIMARY KEY, name TEXT, lead_id INTEGER)");
    exec.executeSql("INSERT INTO projects VALUES (1, 'Alpha', 1)");
    exec.executeSql("INSERT INTO projects VALUES (2, 'Beta', 2)");
    exec.executeSql("INSERT INTO projects VALUES (3, 'Gamma', 4)");

    // INNER JOIN
    var r = exec.executeSql("SELECT e.name, d.name FROM employees e INNER JOIN departments d ON e.dept_id = d.id ORDER BY e.name");
    assertSuccess(r, "INNER JOIN");
    assertRowCount(r, 4, "4 employees have departments");

    // LEFT JOIN — shows employees without departments
    r = exec.executeSql("SELECT e.name, d.name FROM employees e LEFT JOIN departments d ON e.dept_id = d.id ORDER BY e.name");
    assertSuccess(r, "LEFT JOIN");
    assertRowCount(r, 5, "LEFT JOIN returns all 5 employees");

    // RIGHT JOIN — shows departments without employees
    r = exec.executeSql("SELECT e.name, d.name FROM employees e RIGHT JOIN departments d ON e.dept_id = d.id ORDER BY d.name");
    assertSuccess(r, "RIGHT JOIN");

    // Self-join — find employee-manager pairs
    r = exec.executeSql("SELECT e.name AS employee, m.name AS manager FROM employees e LEFT JOIN employees m ON e.manager_id = m.id ORDER BY e.name");
    assertSuccess(r, "self-join");
    assertRowCount(r, 5, "self-join returns all employees");

    // 3-table join
    r = exec.executeSql("SELECT e.name, d.name, p.name FROM employees e INNER JOIN departments d ON e.dept_id = d.id INNER JOIN projects p ON p.lead_id = e.id ORDER BY e.name");
    assertSuccess(r, "3-table join");

    // CROSS JOIN
    r = exec.executeSql("SELECT d.name, p.name FROM departments d CROSS JOIN projects p");
    assertSuccess(r, "CROSS JOIN");
    assertRowCount(r, 9, "CROSS JOIN = 3 * 3 = 9 rows");

    // LEFT JOIN with NULL FK — employees with no department
    r = exec.executeSql("SELECT e.name FROM employees e LEFT JOIN departments d ON e.dept_id = d.id WHERE d.id IS NULL");
    assertSuccess(r, "LEFT JOIN filter NULLs");
    assertRowCount(r, 1, "1 employee without department (Eve)");
    assertEq(val(r, 0, 0), "Eve", "Eve has no department");

    // Join with aggregate
    r = exec.executeSql("SELECT d.name, COUNT(e.id) AS emp_count FROM departments d LEFT JOIN employees e ON d.id = e.dept_id GROUP BY d.name ORDER BY emp_count DESC");
    assertSuccess(r, "JOIN with GROUP BY");
    // Both Engineering and Marketing have 2 employees; order by count DESC is stable
    assertEq(val(r, 0, 1), "2", "top dept has 2 employees");
}

//=============================================================================
// 8. TRANSACTION INTEGRITY
//=============================================================================

func testTransactionIntegrity() {
    section("Transaction Integrity");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE accounts (id INTEGER PRIMARY KEY, name TEXT, balance INTEGER)");
    exec.executeSql("INSERT INTO accounts VALUES (1, 'Alice', 1000)");
    exec.executeSql("INSERT INTO accounts VALUES (2, 'Bob', 500)");
    exec.executeSql("INSERT INTO accounts VALUES (3, 'Charlie', 750)");

    // Basic transaction: transfer 200 from Alice to Bob
    assertSuccess(exec.executeSql("BEGIN"), "BEGIN transfer");
    assertSuccess(exec.executeSql("UPDATE accounts SET balance = balance - 200 WHERE id = 1"), "debit Alice");
    assertSuccess(exec.executeSql("UPDATE accounts SET balance = balance + 200 WHERE id = 2"), "credit Bob");
    assertSuccess(exec.executeSql("COMMIT"), "COMMIT transfer");

    var r = exec.executeSql("SELECT balance FROM accounts WHERE id = 1");
    assertEq(val(r, 0, 0), "800", "Alice balance = 800 after transfer");
    r = exec.executeSql("SELECT balance FROM accounts WHERE id = 2");
    assertEq(val(r, 0, 0), "700", "Bob balance = 700 after transfer");

    // Rollback: attempt transfer but cancel
    assertSuccess(exec.executeSql("BEGIN"), "BEGIN rollback test");
    assertSuccess(exec.executeSql("UPDATE accounts SET balance = balance - 500 WHERE id = 1"), "debit Alice 500");
    assertSuccess(exec.executeSql("UPDATE accounts SET balance = balance + 500 WHERE id = 3"), "credit Charlie 500");

    // Verify mid-transaction visibility
    r = exec.executeSql("SELECT balance FROM accounts WHERE id = 1");
    assertEq(val(r, 0, 0), "300", "Alice = 300 mid-txn");

    assertSuccess(exec.executeSql("ROLLBACK"), "ROLLBACK");

    // Verify rollback restored values
    r = exec.executeSql("SELECT balance FROM accounts WHERE id = 1");
    assertEq(val(r, 0, 0), "800", "Alice balance restored to 800");
    r = exec.executeSql("SELECT balance FROM accounts WHERE id = 3");
    assertEq(val(r, 0, 0), "750", "Charlie balance unchanged at 750");

    // Rollback of INSERT
    assertSuccess(exec.executeSql("BEGIN"), "BEGIN insert rollback");
    assertSuccess(exec.executeSql("INSERT INTO accounts VALUES (4, 'Dave', 999)"), "insert Dave");
    r = exec.executeSql("SELECT COUNT(*) FROM accounts");
    assertEq(val(r, 0, 0), "4", "4 rows mid-txn");
    assertSuccess(exec.executeSql("ROLLBACK"), "ROLLBACK insert");
    r = exec.executeSql("SELECT COUNT(*) FROM accounts");
    assertEq(val(r, 0, 0), "3", "back to 3 rows after rollback");

    // Rollback of DELETE
    assertSuccess(exec.executeSql("BEGIN"), "BEGIN delete rollback");
    assertSuccess(exec.executeSql("DELETE FROM accounts WHERE id = 3"), "delete Charlie");
    r = exec.executeSql("SELECT COUNT(*) FROM accounts");
    assertEq(val(r, 0, 0), "2", "2 rows mid-txn");
    assertSuccess(exec.executeSql("ROLLBACK"), "ROLLBACK delete");
    r = exec.executeSql("SELECT COUNT(*) FROM accounts");
    assertEq(val(r, 0, 0), "3", "back to 3 rows after rollback");

    // Savepoints — use fresh executor to avoid prior txn side effects
    var spExec = new Executor();
    spExec.init();
    spExec.executeSql("CREATE TABLE sp_test (id INTEGER, val INTEGER)");
    spExec.executeSql("INSERT INTO sp_test VALUES (1, 100)");
    spExec.executeSql("INSERT INTO sp_test VALUES (2, 200)");
    spExec.executeSql("INSERT INTO sp_test VALUES (3, 300)");

    assertSuccess(spExec.executeSql("BEGIN"), "BEGIN savepoint test");
    assertSuccess(spExec.executeSql("INSERT INTO sp_test VALUES (10, 1000)"), "insert row 10");
    assertSuccess(spExec.executeSql("SAVEPOINT sp1"), "create savepoint sp1");
    assertSuccess(spExec.executeSql("INSERT INTO sp_test VALUES (11, 1100)"), "insert row 11");
    assertSuccess(spExec.executeSql("SAVEPOINT sp2"), "create savepoint sp2");
    assertSuccess(spExec.executeSql("INSERT INTO sp_test VALUES (12, 1200)"), "insert row 12");

    r = spExec.executeSql("SELECT COUNT(*) FROM sp_test");
    assertEq(val(r, 0, 0), "6", "6 rows before rollback to sp2");

    assertSuccess(spExec.executeSql("ROLLBACK TO sp2"), "rollback to sp2");
    r = spExec.executeSql("SELECT COUNT(*) FROM sp_test");
    assertEq(val(r, 0, 0), "5", "5 rows after rollback to sp2");

    assertSuccess(spExec.executeSql("ROLLBACK TO sp1"), "rollback to sp1");
    r = spExec.executeSql("SELECT COUNT(*) FROM sp_test");
    assertEq(val(r, 0, 0), "4", "4 rows after rollback to sp1");

    assertSuccess(spExec.executeSql("COMMIT"), "COMMIT with savepoints");
    r = spExec.executeSql("SELECT COUNT(*) FROM sp_test");
    assertEq(val(r, 0, 0), "4", "4 rows committed (original 3 + row 10)");
}

//=============================================================================
// 9. CONSTRAINT ENFORCEMENT
//=============================================================================

func testConstraints() {
    section("Constraint Enforcement");

    var exec = new Executor();
    exec.init();

    // PRIMARY KEY uniqueness
    exec.executeSql("CREATE TABLE pk_test (id INTEGER PRIMARY KEY, name TEXT)");
    assertSuccess(exec.executeSql("INSERT INTO pk_test VALUES (1, 'a')"), "insert pk 1");
    assertFailure(exec.executeSql("INSERT INTO pk_test VALUES (1, 'b')"), "duplicate PK should fail");

    // NOT NULL constraint
    exec.executeSql("CREATE TABLE nn_test (id INTEGER PRIMARY KEY, name TEXT NOT NULL)");
    assertSuccess(exec.executeSql("INSERT INTO nn_test VALUES (1, 'hello')"), "insert with NOT NULL");
    assertFailure(exec.executeSql("INSERT INTO nn_test VALUES (2, NULL)"), "NULL for NOT NULL should fail");

    // UNIQUE constraint
    exec.executeSql("CREATE TABLE uniq_test (id INTEGER PRIMARY KEY, email TEXT UNIQUE)");
    assertSuccess(exec.executeSql("INSERT INTO uniq_test VALUES (1, 'a@b.com')"), "insert unique 1");
    assertFailure(exec.executeSql("INSERT INTO uniq_test VALUES (2, 'a@b.com')"), "duplicate UNIQUE should fail");
    assertSuccess(exec.executeSql("INSERT INTO uniq_test VALUES (3, 'c@d.com')"), "different unique OK");

    // FOREIGN KEY constraint
    exec.executeSql("CREATE TABLE parent (id INTEGER PRIMARY KEY, name TEXT)");
    exec.executeSql("INSERT INTO parent VALUES (1, 'P1')");
    exec.executeSql("INSERT INTO parent VALUES (2, 'P2')");

    exec.executeSql("CREATE TABLE child (id INTEGER PRIMARY KEY, parent_id INTEGER REFERENCES parent(id), name TEXT)");
    assertSuccess(exec.executeSql("INSERT INTO child VALUES (1, 1, 'C1')"), "valid FK");
    assertFailure(exec.executeSql("INSERT INTO child VALUES (2, 99, 'C2')"), "invalid FK should fail");

    // CHECK constraint
    exec.executeSql("CREATE TABLE chk_test (id INTEGER, val INTEGER CHECK (val >= 0))");
    assertSuccess(exec.executeSql("INSERT INTO chk_test VALUES (1, 10)"), "valid CHECK");
    assertFailure(exec.executeSql("INSERT INTO chk_test VALUES (2, -5)"), "negative violates CHECK");

    // DEFAULT values
    exec.executeSql("CREATE TABLE def_test (id INTEGER, status TEXT DEFAULT 'active', count INTEGER DEFAULT 0)");
    assertSuccess(exec.executeSql("INSERT INTO def_test (id) VALUES (1)"), "insert with defaults");
    var r = exec.executeSql("SELECT status, count FROM def_test WHERE id = 1");
    assertSuccess(r, "select defaults");
    assertEq(val(r, 0, 0), "active", "default status = active");
    assertEq(val(r, 0, 1), "0", "default count = 0");

    // ON DELETE CASCADE
    exec.executeSql("CREATE TABLE cascade_parent (id INTEGER PRIMARY KEY, name TEXT)");
    exec.executeSql("INSERT INTO cascade_parent VALUES (1, 'P1')");
    exec.executeSql("INSERT INTO cascade_parent VALUES (2, 'P2')");

    exec.executeSql("CREATE TABLE cascade_child (id INTEGER, parent_id INTEGER REFERENCES cascade_parent(id) ON DELETE CASCADE, label TEXT)");
    exec.executeSql("INSERT INTO cascade_child VALUES (1, 1, 'C1')");
    exec.executeSql("INSERT INTO cascade_child VALUES (2, 1, 'C2')");
    exec.executeSql("INSERT INTO cascade_child VALUES (3, 2, 'C3')");

    assertSuccess(exec.executeSql("DELETE FROM cascade_parent WHERE id = 1"), "cascade delete");
    r = exec.executeSql("SELECT COUNT(*) FROM cascade_child");
    assertSuccess(r, "count after cascade");
    assertEq(val(r, 0, 0), "1", "cascade deleted 2 children, 1 remains");
}

//=============================================================================
// 10. AGGREGATE FUNCTIONS — Edge Cases
//=============================================================================

func testAggregateEdgeCases() {
    section("Aggregate Edge Cases");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE agg (id INTEGER, grp TEXT, val INTEGER)");
    exec.executeSql("INSERT INTO agg VALUES (1, 'A', 10)");
    exec.executeSql("INSERT INTO agg VALUES (2, 'A', 20)");
    exec.executeSql("INSERT INTO agg VALUES (3, 'A', 30)");
    exec.executeSql("INSERT INTO agg VALUES (4, 'B', 100)");
    exec.executeSql("INSERT INTO agg VALUES (5, 'B', NULL)");
    exec.executeSql("INSERT INTO agg VALUES (6, 'C', NULL)");

    // COUNT(DISTINCT val)
    var r = exec.executeSql("SELECT COUNT(DISTINCT val) FROM agg");
    assertSuccess(r, "COUNT DISTINCT");
    assertEq(val(r, 0, 0), "4", "COUNT DISTINCT = 4 (10,20,30,100)");

    // GROUP BY with HAVING
    r = exec.executeSql("SELECT grp, SUM(val) FROM agg GROUP BY grp HAVING SUM(val) > 10 ORDER BY SUM(val) DESC");
    assertSuccess(r, "GROUP BY HAVING");
    assertEq(val(r, 0, 0), "B", "B has SUM=100");
    assertEq(val(r, 1, 0), "A", "A has SUM=60");

    // GROUP with all NULLs
    r = exec.executeSql("SELECT grp, SUM(val), COUNT(val), AVG(val) FROM agg WHERE grp = 'C' GROUP BY grp");
    assertSuccess(r, "GROUP with all NULLs");

    // Multiple aggregates in one query
    r = exec.executeSql("SELECT COUNT(*), SUM(val), MIN(val), MAX(val), AVG(val) FROM agg");
    assertSuccess(r, "multiple aggregates");
    assertEq(val(r, 0, 0), "6", "COUNT(*) = 6");

    // GROUP BY with ORDER BY on aggregate
    r = exec.executeSql("SELECT grp, COUNT(*) AS cnt FROM agg GROUP BY grp ORDER BY cnt DESC");
    assertSuccess(r, "ORDER BY aggregate alias");
    assertEq(val(r, 0, 0), "A", "A has 3 rows");
    assertEq(val(r, 0, 1), "3", "A count = 3");
}

//=============================================================================
// 11. WINDOW FUNCTIONS
//=============================================================================

func testWindowFunctions() {
    section("Window Functions");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE sales (id INTEGER, region TEXT, amount INTEGER)");
    exec.executeSql("INSERT INTO sales VALUES (1, 'North', 100)");
    exec.executeSql("INSERT INTO sales VALUES (2, 'North', 200)");
    exec.executeSql("INSERT INTO sales VALUES (3, 'South', 150)");
    exec.executeSql("INSERT INTO sales VALUES (4, 'South', 250)");
    exec.executeSql("INSERT INTO sales VALUES (5, 'East', 300)");

    // ROW_NUMBER
    var r = exec.executeSql("SELECT id, ROW_NUMBER() OVER (ORDER BY amount DESC) AS rn FROM sales");
    assertSuccess(r, "ROW_NUMBER");
    assertRowCount(r, 5, "ROW_NUMBER returns all rows");

    // RANK with PARTITION
    r = exec.executeSql("SELECT id, region, RANK() OVER (PARTITION BY region ORDER BY amount DESC) AS rnk FROM sales ORDER BY region, rnk");
    assertSuccess(r, "RANK with PARTITION");

    // SUM window — include amount in SELECT so window expr can resolve it
    r = exec.executeSql("SELECT id, amount, SUM(amount) OVER (ORDER BY id) AS running_total FROM sales ORDER BY id");
    assertSuccess(r, "running SUM window");
    assertEq(val(r, 0, 2), "100", "running total after row 1 = 100");
    assertEq(val(r, 1, 2), "300", "running total after row 2 = 300");

    // COUNT window with PARTITION — include region in SELECT
    r = exec.executeSql("SELECT id, region, COUNT(*) OVER (PARTITION BY region) AS region_count FROM sales ORDER BY id");
    assertSuccess(r, "COUNT window with PARTITION");
    assertEq(val(r, 0, 2), "2", "North has 2");
    assertEq(val(r, 4, 2), "1", "East has 1");

    // Window over empty partition
    r = exec.executeSql("SELECT id, SUM(amount) OVER (PARTITION BY region) FROM sales ORDER BY id");
    assertSuccess(r, "SUM window by partition");
}

//=============================================================================
// 12. VIEW AND DERIVED TABLE TESTS
//=============================================================================

func testViewsAndDerived() {
    section("Views and Derived Tables");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE products (id INTEGER, name TEXT, price INTEGER, category TEXT)");
    exec.executeSql("INSERT INTO products VALUES (1, 'Widget', 10, 'A')");
    exec.executeSql("INSERT INTO products VALUES (2, 'Gadget', 25, 'A')");
    exec.executeSql("INSERT INTO products VALUES (3, 'Doohickey', 5, 'B')");
    exec.executeSql("INSERT INTO products VALUES (4, 'Thingamajig', 50, 'B')");
    exec.executeSql("INSERT INTO products VALUES (5, 'Whatsit', 15, 'C')");

    // Create and query a view
    assertSuccess(exec.executeSql("CREATE VIEW expensive AS SELECT * FROM products WHERE price > 20"), "create view");
    var r = exec.executeSql("SELECT name FROM expensive ORDER BY price");
    assertSuccess(r, "query view");
    assertRowCount(r, 2, "2 expensive products");
    assertEq(val(r, 0, 0), "Gadget", "Gadget at 25");
    assertEq(val(r, 1, 0), "Thingamajig", "Thingamajig at 50");

    // View with aggregate
    assertSuccess(exec.executeSql("CREATE VIEW cat_summary AS SELECT category, COUNT(*) AS cnt, SUM(price) AS total FROM products GROUP BY category"), "create aggregate view");
    r = exec.executeSql("SELECT * FROM cat_summary ORDER BY category");
    assertSuccess(r, "query aggregate view");
    assertRowCount(r, 3, "3 categories in view");

    // Derived table with alias
    r = exec.executeSql("SELECT d.category, d.total FROM (SELECT category, SUM(price) AS total FROM products GROUP BY category) d WHERE d.total > 20 ORDER BY d.total DESC");
    assertSuccess(r, "derived table with filter");
    assertRowCount(r, 2, "2 categories with total > 20");

    // Drop view
    assertSuccess(exec.executeSql("DROP VIEW expensive"), "drop view");
    assertFailure(exec.executeSql("SELECT * FROM expensive"), "dropped view fails");
}

//=============================================================================
// 13. SET OPERATIONS (UNION, INTERSECT, EXCEPT)
//=============================================================================

func testSetOperations() {
    section("Set Operations");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE set_a (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO set_a VALUES (1, 'Alice')");
    exec.executeSql("INSERT INTO set_a VALUES (2, 'Bob')");
    exec.executeSql("INSERT INTO set_a VALUES (3, 'Charlie')");

    exec.executeSql("CREATE TABLE set_b (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO set_b VALUES (2, 'Bob')");
    exec.executeSql("INSERT INTO set_b VALUES (3, 'Charlie')");
    exec.executeSql("INSERT INTO set_b VALUES (4, 'Diana')");

    // UNION (removes duplicates)
    var r = exec.executeSql("SELECT name FROM set_a UNION SELECT name FROM set_b");
    assertSuccess(r, "UNION");
    assertRowCount(r, 4, "UNION = 4 distinct names");

    // UNION ALL (keeps duplicates)
    r = exec.executeSql("SELECT name FROM set_a UNION ALL SELECT name FROM set_b");
    assertSuccess(r, "UNION ALL");
    assertRowCount(r, 6, "UNION ALL = 6 rows");

    // INTERSECT
    r = exec.executeSql("SELECT name FROM set_a INTERSECT SELECT name FROM set_b");
    assertSuccess(r, "INTERSECT");
    assertRowCount(r, 2, "INTERSECT = 2 (Bob, Charlie)");

    // EXCEPT
    r = exec.executeSql("SELECT name FROM set_a EXCEPT SELECT name FROM set_b");
    assertSuccess(r, "EXCEPT");
    assertRowCount(r, 1, "EXCEPT = 1 (Alice)");
}

//=============================================================================
// 14. LARGE DATA STRESS TEST
//=============================================================================

func testLargeDataStress() {
    section("Large Data Stress Test");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE big (id INTEGER, grp INTEGER, val INTEGER, name TEXT)");

    // Insert 500 rows
    var i = 0;
    while i < 500 {
        var grp = i % 10;
        var val = i * 7;
        exec.executeSql("INSERT INTO big VALUES (" + Fmt.Int(i) + ", " + Fmt.Int(grp) + ", " + Fmt.Int(val) + ", 'name_" + Fmt.Int(i) + "')");
        i = i + 1;
    }

    var r = exec.executeSql("SELECT COUNT(*) FROM big");
    assertSuccess(r, "500 rows inserted");
    assertEq(val(r, 0, 0), "500", "count = 500");

    // Full table scan with filter
    r = exec.executeSql("SELECT COUNT(*) FROM big WHERE grp = 5");
    assertSuccess(r, "filter 500 rows");
    assertEq(val(r, 0, 0), "50", "group 5 has 50 rows");

    // Aggregate over large dataset
    r = exec.executeSql("SELECT grp, COUNT(*), SUM(val), AVG(val) FROM big GROUP BY grp ORDER BY grp");
    assertSuccess(r, "GROUP BY 500 rows");
    assertRowCount(r, 10, "10 groups");

    // ORDER BY on large dataset
    r = exec.executeSql("SELECT id FROM big ORDER BY val DESC LIMIT 5");
    assertSuccess(r, "ORDER BY large + LIMIT");
    assertRowCount(r, 5, "top 5 rows");
    assertEq(val(r, 0, 0), "499", "highest val row is id=499");

    // DISTINCT on large dataset
    r = exec.executeSql("SELECT DISTINCT grp FROM big ORDER BY grp");
    assertSuccess(r, "DISTINCT large");
    assertRowCount(r, 10, "10 distinct groups");

    // Bulk UPDATE
    r = exec.executeSql("UPDATE big SET val = val + 1 WHERE grp = 0");
    assertSuccess(r, "bulk update group 0");
    assertEqInt(r.rowsAffected, 50, "updated 50 rows");

    // Verify update
    r = exec.executeSql("SELECT val FROM big WHERE id = 0");
    assertEq(val(r, 0, 0), "1", "id=0 val updated from 0 to 1");

    // Bulk DELETE
    r = exec.executeSql("DELETE FROM big WHERE grp = 9");
    assertSuccess(r, "bulk delete group 9");
    assertEqInt(r.rowsAffected, 50, "deleted 50 rows");

    r = exec.executeSql("SELECT COUNT(*) FROM big");
    assertEq(val(r, 0, 0), "450", "450 rows after delete");
}

//=============================================================================
// 15. INDEX OPERATIONS
//=============================================================================

func testIndexOperations() {
    section("Index Operations");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE indexed (id INTEGER PRIMARY KEY, name TEXT, value INTEGER)");

    // Insert data
    var i = 0;
    while i < 100 {
        exec.executeSql("INSERT INTO indexed VALUES (" + Fmt.Int(i) + ", 'item_" + Fmt.Int(i) + "', " + Fmt.Int(i * 10) + ")");
        i = i + 1;
    }

    // Create index
    assertSuccess(exec.executeSql("CREATE INDEX idx_value ON indexed(value)"), "create index");

    // Query that should use index
    var r = exec.executeSql("SELECT name FROM indexed WHERE value = 500");
    assertSuccess(r, "index lookup");
    assertRowCount(r, 1, "found 1 row via index");
    assertEq(val(r, 0, 0), "item_50", "correct row found");

    // Range scan
    r = exec.executeSql("SELECT COUNT(*) FROM indexed WHERE value >= 900");
    assertSuccess(r, "range scan");
    assertEq(val(r, 0, 0), "10", "10 rows with value >= 900");

    // Create unique index
    assertSuccess(exec.executeSql("CREATE UNIQUE INDEX idx_name ON indexed(name)"), "create unique index");

    // Drop index
    assertSuccess(exec.executeSql("DROP INDEX idx_value"), "drop index");

    // Queries still work after index drop
    r = exec.executeSql("SELECT name FROM indexed WHERE value = 500");
    assertSuccess(r, "query after index drop");
    assertRowCount(r, 1, "still finds row without index");
}

//=============================================================================
// 16. MULTI-STATEMENT COMPLEX QUERIES
//=============================================================================

func testComplexQueries() {
    section("Complex Multi-Feature Queries");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE orders (id INTEGER, customer TEXT, product TEXT, qty INTEGER, price INTEGER, order_date DATE)");
    exec.executeSql("INSERT INTO orders VALUES (1, 'Alice', 'Widget', 5, 10, '2024-01-15')");
    exec.executeSql("INSERT INTO orders VALUES (2, 'Bob', 'Gadget', 3, 25, '2024-01-20')");
    exec.executeSql("INSERT INTO orders VALUES (3, 'Alice', 'Widget', 2, 10, '2024-02-01')");
    exec.executeSql("INSERT INTO orders VALUES (4, 'Charlie', 'Doohickey', 10, 5, '2024-02-15')");
    exec.executeSql("INSERT INTO orders VALUES (5, 'Bob', 'Widget', 1, 10, '2024-03-01')");
    exec.executeSql("INSERT INTO orders VALUES (6, 'Alice', 'Gadget', 4, 25, '2024-03-10')");

    // Total revenue per customer
    var r = exec.executeSql("SELECT customer, SUM(qty * price) AS total FROM orders GROUP BY customer ORDER BY total DESC");
    assertSuccess(r, "revenue per customer");
    assertRowCount(r, 3, "3 customers");
    assertEq(val(r, 0, 0), "Alice", "Alice has highest revenue");

    // Running total with window function
    r = exec.executeSql("SELECT id, customer, qty * price AS line_total, SUM(qty * price) OVER (ORDER BY id) AS running FROM orders ORDER BY id");
    assertSuccess(r, "running total");

    // Subquery: customers who ordered more than average total
    r = exec.executeSql("SELECT customer, SUM(qty * price) AS total FROM orders GROUP BY customer HAVING SUM(qty * price) > (SELECT AVG(qty * price) FROM orders)");
    assertSuccess(r, "HAVING with subquery");

    // CASE with aggregation
    r = exec.executeSql("SELECT customer, CASE WHEN SUM(qty * price) > 100 THEN 'VIP' WHEN SUM(qty * price) > 50 THEN 'Regular' ELSE 'Casual' END AS tier FROM orders GROUP BY customer ORDER BY customer");
    assertSuccess(r, "CASE with aggregate");
    assertRowCount(r, 3, "3 customer tiers");

    // Multiple LIKE conditions
    r = exec.executeSql("SELECT DISTINCT product FROM orders WHERE product LIKE 'W%' OR product LIKE 'G%' ORDER BY product");
    assertSuccess(r, "multiple LIKE");
    assertRowCount(r, 2, "Widget and Gadget");

    // BETWEEN on dates
    r = exec.executeSql("SELECT COUNT(*) FROM orders WHERE order_date BETWEEN '2024-01-01' AND '2024-01-31'");
    assertSuccess(r, "BETWEEN on dates");
    assertEq(val(r, 0, 0), "2", "2 orders in January");
}

//=============================================================================
// 17. ALTER TABLE OPERATIONS
//=============================================================================

func testAlterTable() {
    section("ALTER TABLE");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE alterable (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO alterable VALUES (1, 'Alice')");
    exec.executeSql("INSERT INTO alterable VALUES (2, 'Bob')");

    // ADD COLUMN
    assertSuccess(exec.executeSql("ALTER TABLE alterable ADD COLUMN age INTEGER"), "add column");
    var r = exec.executeSql("SELECT * FROM alterable WHERE id = 1");
    assertSuccess(r, "select after add column");

    // RENAME COLUMN
    assertSuccess(exec.executeSql("ALTER TABLE alterable RENAME COLUMN name TO fullname"), "rename column");
    r = exec.executeSql("SELECT fullname FROM alterable WHERE id = 1");
    assertSuccess(r, "query renamed column");
    assertEq(val(r, 0, 0), "Alice", "renamed column has data");

    // ALTER TABLE on nonexistent table
    assertFailure(exec.executeSql("ALTER TABLE nonexistent ADD COLUMN x INTEGER"), "alter nonexistent table");

    // RENAME TABLE
    assertSuccess(exec.executeSql("ALTER TABLE alterable RENAME TO renamed_table"), "rename table");
    r = exec.executeSql("SELECT COUNT(*) FROM renamed_table");
    assertSuccess(r, "query renamed table");
    assertEq(val(r, 0, 0), "2", "renamed table has 2 rows");

    assertFailure(exec.executeSql("SELECT * FROM alterable"), "old table name fails");
}

//=============================================================================
// 18. SEQUENCES
//=============================================================================

func testSequences() {
    section("Sequences");

    var exec = new Executor();
    exec.init();

    assertSuccess(exec.executeSql("CREATE SEQUENCE test_seq START 1 INCREMENT 1"), "create sequence");

    var r = exec.executeSql("SELECT NEXTVAL('test_seq')");
    assertSuccess(r, "nextval 1");
    assertEq(val(r, 0, 0), "1", "first nextval = 1");

    r = exec.executeSql("SELECT NEXTVAL('test_seq')");
    assertSuccess(r, "nextval 2");
    assertEq(val(r, 0, 0), "2", "second nextval = 2");

    r = exec.executeSql("SELECT CURRVAL('test_seq')");
    assertSuccess(r, "currval");
    assertEq(val(r, 0, 0), "2", "currval = 2");

    // Sequence with INCREMENT BY
    assertSuccess(exec.executeSql("CREATE SEQUENCE step_seq START 10 INCREMENT 5"), "create step seq");
    r = exec.executeSql("SELECT NEXTVAL('step_seq')");
    assertEq(val(r, 0, 0), "10", "step seq starts at 10");
    r = exec.executeSql("SELECT NEXTVAL('step_seq')");
    assertEq(val(r, 0, 0), "15", "step seq increments by 5");

    // Drop sequence
    assertSuccess(exec.executeSql("DROP SEQUENCE test_seq"), "drop sequence");
}

//=============================================================================
// 19. TRIGGERS
//=============================================================================

func testTriggers() {
    section("Triggers");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE audit_log (id INTEGER, action TEXT, target_id INTEGER)");
    exec.executeSql("CREATE TABLE items (id INTEGER PRIMARY KEY, name TEXT, price INTEGER)");

    // Create AFTER INSERT trigger
    assertSuccess(exec.executeSql("CREATE TRIGGER items_insert_audit AFTER INSERT ON items FOR EACH ROW EXECUTE 'INSERT INTO audit_log VALUES (0, ''INSERT'', 0)'"), "create trigger");

    // Insert should fire trigger
    assertSuccess(exec.executeSql("INSERT INTO items VALUES (1, 'Widget', 100)"), "insert triggers audit");
    var r = exec.executeSql("SELECT COUNT(*) FROM audit_log");
    assertSuccess(r, "audit log count");
    assertEq(val(r, 0, 0), "1", "1 audit entry after insert");

    // Another insert
    assertSuccess(exec.executeSql("INSERT INTO items VALUES (2, 'Gadget', 200)"), "second insert");
    r = exec.executeSql("SELECT COUNT(*) FROM audit_log");
    assertEq(val(r, 0, 0), "2", "2 audit entries");

    // Drop trigger
    assertSuccess(exec.executeSql("DROP TRIGGER items_insert_audit"), "drop trigger");

    // Insert without trigger
    assertSuccess(exec.executeSql("INSERT INTO items VALUES (3, 'Doohickey', 50)"), "insert after trigger drop");
    r = exec.executeSql("SELECT COUNT(*) FROM audit_log");
    assertEq(val(r, 0, 0), "2", "still 2 audit entries (trigger dropped)");
}

//=============================================================================
// 20. PREPARED STATEMENTS
//=============================================================================

func testPreparedStatements() {
    section("Prepared Statements");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE prep_test (id INTEGER, name TEXT, val INTEGER)");
    exec.executeSql("INSERT INTO prep_test VALUES (1, 'alpha', 10)");
    exec.executeSql("INSERT INTO prep_test VALUES (2, 'beta', 20)");
    exec.executeSql("INSERT INTO prep_test VALUES (3, 'gamma', 30)");

    // PREPARE
    assertSuccess(exec.executeSql("PREPARE find_by_val AS SELECT name FROM prep_test WHERE val = $1"), "prepare statement");

    // EXECUTE
    var r = exec.executeSql("EXECUTE find_by_val(20)");
    assertSuccess(r, "execute prepared");
    assertRowCount(r, 1, "found 1 row");
    assertEq(val(r, 0, 0), "beta", "found beta");

    r = exec.executeSql("EXECUTE find_by_val(10)");
    assertSuccess(r, "execute prepared again");
    assertRowCount(r, 1, "found 1 row");
    assertEq(val(r, 0, 0), "alpha", "found alpha");

    // DEALLOCATE
    assertSuccess(exec.executeSql("DEALLOCATE find_by_val"), "deallocate");
}

//=============================================================================
// 21. TEMP TABLES
//=============================================================================

func testTempTables() {
    section("Temporary Tables");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE persistent (id INTEGER, val INTEGER)");
    exec.executeSql("INSERT INTO persistent VALUES (1, 100)");

    // Create temp table
    assertSuccess(exec.executeSql("CREATE TEMP TABLE tmp_data (id INTEGER, label TEXT)"), "create temp table");
    assertSuccess(exec.executeSql("INSERT INTO tmp_data VALUES (1, 'temp1')"), "insert into temp");
    assertSuccess(exec.executeSql("INSERT INTO tmp_data VALUES (2, 'temp2')"), "insert into temp 2");

    var r = exec.executeSql("SELECT COUNT(*) FROM tmp_data");
    assertSuccess(r, "query temp table");
    assertEq(val(r, 0, 0), "2", "temp table has 2 rows");

    // Join temp with persistent
    r = exec.executeSql("SELECT p.val, t.label FROM persistent p INNER JOIN tmp_data t ON p.id = t.id");
    assertSuccess(r, "join temp with persistent");
    assertRowCount(r, 1, "1 matching row");

    // Drop temp table
    assertSuccess(exec.executeSql("DROP TABLE tmp_data"), "drop temp table");
    assertFailure(exec.executeSql("SELECT * FROM tmp_data"), "temp table gone");
}

//=============================================================================
// 22. PARSER EDGE CASES
//=============================================================================

func testParserEdgeCases() {
    section("Parser Edge Cases");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE parse_test (id INTEGER, name TEXT, value INTEGER)");
    exec.executeSql("INSERT INTO parse_test VALUES (1, 'test', 42)");

    // Aliases
    var r = exec.executeSql("SELECT id AS item_id, name AS label FROM parse_test");
    assertSuccess(r, "column aliases");

    // Column alias in ORDER BY
    r = exec.executeSql("SELECT id, name AS label FROM parse_test ORDER BY label");
    assertSuccess(r, "alias in ORDER BY");

    // Multiple semicolons (should just ignore trailing)
    r = exec.executeSql("SELECT * FROM parse_test;");
    assertSuccess(r, "trailing semicolon");

    // Empty WHERE clause value
    r = exec.executeSql("SELECT * FROM parse_test WHERE 1 = 1");
    assertSuccess(r, "tautology WHERE");
    assertRowCount(r, 1, "1 row");

    r = exec.executeSql("SELECT * FROM parse_test WHERE 1 = 0");
    assertSuccess(r, "contradiction WHERE");
    assertRowCount(r, 0, "0 rows");

    // Nested parentheses in expressions
    r = exec.executeSql("SELECT ((1 + 2) * (3 + 4))");
    assertSuccess(r, "nested parens");
    assertEq(val(r, 0, 0), "21", "((1+2)*(3+4)) = 21");

    // Unterminated string — should produce error, not crash
    r = exec.executeSql("SELECT 'unterminated");
    assertFailure(r, "unterminated string is an error");

    // Unknown table
    r = exec.executeSql("SELECT * FROM nonexistent_table");
    assertFailure(r, "unknown table is an error");

    // Mismatched column count in INSERT
    r = exec.executeSql("INSERT INTO parse_test VALUES (1, 'too', 'many', 'values', 'here')");
    assertFailure(r, "too many values in INSERT");

    // SELECT with no FROM (expressions only)
    r = exec.executeSql("SELECT 1 + 1");
    assertSuccess(r, "SELECT without FROM");
    assertEq(val(r, 0, 0), "2", "1+1 = 2");

    r = exec.executeSql("SELECT 'hello'");
    assertSuccess(r, "SELECT string literal");
    assertEq(val(r, 0, 0), "hello", "string literal");
}

//=============================================================================
// 23. TRUNCATE TABLE
//=============================================================================

func testTruncate() {
    section("TRUNCATE TABLE");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE trunc (id INTEGER, val TEXT)");
    var i = 0;
    while i < 50 {
        exec.executeSql("INSERT INTO trunc VALUES (" + Fmt.Int(i) + ", 'row_" + Fmt.Int(i) + "')");
        i = i + 1;
    }

    var r = exec.executeSql("SELECT COUNT(*) FROM trunc");
    assertEq(val(r, 0, 0), "50", "50 rows before truncate");

    assertSuccess(exec.executeSql("TRUNCATE TABLE trunc"), "truncate");

    r = exec.executeSql("SELECT COUNT(*) FROM trunc");
    assertEq(val(r, 0, 0), "0", "0 rows after truncate");

    // Table still exists, can insert
    assertSuccess(exec.executeSql("INSERT INTO trunc VALUES (1, 'new')"), "insert after truncate");
    r = exec.executeSql("SELECT COUNT(*) FROM trunc");
    assertEq(val(r, 0, 0), "1", "1 row after insert post-truncate");
}

//=============================================================================
// 24. INSERT ... SELECT
//=============================================================================

func testInsertSelect() {
    section("INSERT ... SELECT");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE source (id INTEGER, name TEXT, val INTEGER)");
    exec.executeSql("INSERT INTO source VALUES (1, 'a', 10)");
    exec.executeSql("INSERT INTO source VALUES (2, 'b', 20)");
    exec.executeSql("INSERT INTO source VALUES (3, 'c', 30)");

    exec.executeSql("CREATE TABLE target (id INTEGER, name TEXT, val INTEGER)");

    // INSERT INTO ... SELECT
    var r = exec.executeSql("INSERT INTO target SELECT * FROM source WHERE val > 10");
    assertSuccess(r, "INSERT ... SELECT");
    assertEqInt(r.rowsAffected, 2, "inserted 2 rows");

    r = exec.executeSql("SELECT COUNT(*) FROM target");
    assertEq(val(r, 0, 0), "2", "target has 2 rows");

    r = exec.executeSql("SELECT name FROM target ORDER BY name");
    assertEq(val(r, 0, 0), "b", "first = b");
    assertEq(val(r, 1, 0), "c", "second = c");
}

//=============================================================================
// 25. STRESS: MANY TABLES
//=============================================================================

func testManyTables() {
    section("Stress: Many Tables");

    var exec = new Executor();
    exec.init();

    // Create 30 tables
    var i = 0;
    while i < 30 {
        var tname = "table_" + Fmt.Int(i);
        assertSuccess(exec.executeSql("CREATE TABLE " + tname + " (id INTEGER, data TEXT)"), "create " + tname);
        exec.executeSql("INSERT INTO " + tname + " VALUES (1, 'hello')");
        i = i + 1;
    }

    // Verify SHOW TABLES
    var r = exec.executeSql("SHOW TABLES");
    assertSuccess(r, "SHOW TABLES with 30 tables");
    assert(r.rowCount() >= 30, "at least 30 tables shown");

    // Query each table
    i = 0;
    while i < 30 {
        var tname = "table_" + Fmt.Int(i);
        r = exec.executeSql("SELECT data FROM " + tname);
        assertSuccess(r, "query " + tname);
        assertEq(val(r, 0, 0), "hello", tname + " data correct");
        i = i + 1;
    }

    // Drop all tables
    i = 0;
    while i < 30 {
        var tname = "table_" + Fmt.Int(i);
        assertSuccess(exec.executeSql("DROP TABLE " + tname), "drop " + tname);
        i = i + 1;
    }

    r = exec.executeSql("SHOW TABLES");
    assertSuccess(r, "SHOW TABLES after drops");
    assertRowCount(r, 0, "0 tables remain");
}

//=============================================================================
// 26. RECURSIVE CTE
//=============================================================================

func testRecursiveCTE() {
    section("Recursive CTE");

    var exec = new Executor();
    exec.init();

    // Generate numbers 1-10 using recursive CTE
    var r = exec.executeSql("WITH RECURSIVE nums(n) AS (SELECT 1 UNION ALL SELECT n + 1 FROM nums WHERE n < 10) SELECT n FROM nums ORDER BY n");
    assertSuccess(r, "recursive CTE 1-10");
    assertRowCount(r, 10, "10 numbers generated");
    assertEq(val(r, 0, 0), "1", "first = 1");
    assertEq(val(r, 9, 0), "10", "last = 10");

    // Hierarchical query with recursive CTE
    exec.executeSql("CREATE TABLE org (id INTEGER, name TEXT, mgr_id INTEGER)");
    exec.executeSql("INSERT INTO org VALUES (1, 'CEO', NULL)");
    exec.executeSql("INSERT INTO org VALUES (2, 'VP-Eng', 1)");
    exec.executeSql("INSERT INTO org VALUES (3, 'VP-Sales', 1)");
    exec.executeSql("INSERT INTO org VALUES (4, 'Dev-Lead', 2)");
    exec.executeSql("INSERT INTO org VALUES (5, 'Dev-1', 4)");
    exec.executeSql("INSERT INTO org VALUES (6, 'Dev-2', 4)");

    r = exec.executeSql("WITH RECURSIVE chain(id, name, depth) AS (SELECT id, name, 0 FROM org WHERE mgr_id IS NULL UNION ALL SELECT o.id, o.name, c.depth + 1 FROM org o INNER JOIN chain c ON o.mgr_id = c.id) SELECT name, depth FROM chain ORDER BY depth, name");
    assertSuccess(r, "hierarchical recursive CTE");
    assertRowCount(r, 6, "all 6 org members");
    assertEq(val(r, 0, 0), "CEO", "CEO at depth 0");
}

//=============================================================================
// 27. MULTIPLE DATABASES
//=============================================================================

func testMultipleDatabases() {
    section("Multiple Databases");

    var exec = new Executor();
    exec.init();

    assertSuccess(exec.executeSql("CREATE DATABASE testdb"), "create database");
    assertSuccess(exec.executeSql("USE testdb"), "use database");

    // Create table in new database
    assertSuccess(exec.executeSql("CREATE TABLE local_data (id INTEGER, val TEXT)"), "create in testdb");
    assertSuccess(exec.executeSql("INSERT INTO local_data VALUES (1, 'in testdb')"), "insert in testdb");

    var r = exec.executeSql("SELECT val FROM local_data");
    assertSuccess(r, "query testdb");
    assertEq(val(r, 0, 0), "in testdb", "data in testdb");

    // Switch back to main
    assertSuccess(exec.executeSql("USE main"), "use main");

    // Table shouldn't exist in main
    assertFailure(exec.executeSql("SELECT * FROM local_data"), "local_data not in main");
}

//=============================================================================
// 28. EXPLAIN QUERY PLAN
//=============================================================================

func testExplain() {
    section("EXPLAIN");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE explain_test (id INTEGER PRIMARY KEY, val INTEGER)");
    exec.executeSql("INSERT INTO explain_test VALUES (1, 100)");
    exec.executeSql("CREATE INDEX idx_et_val ON explain_test(val)");

    var r = exec.executeSql("EXPLAIN SELECT * FROM explain_test WHERE val = 100");
    assertSuccess(r, "EXPLAIN works");
    assert(r.rowCount() > 0, "EXPLAIN returns plan rows");
}

