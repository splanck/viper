// test_lateral_complete.zia — LATERAL JOIN Completion Tests
// Part of ViperSQL
//
// Tests advanced LATERAL subquery patterns: top-N per group,
// aggregate correlation, LEFT JOIN LATERAL, and expression correlation.

module test_lateral_complete;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// 1. Top-N per group with LATERAL + LIMIT
//=============================================================================

func testTopNPerGroup() {
    section("LATERAL: Top-N per group");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE categories (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO categories VALUES (1, 'Electronics')");
    exec.executeSql("INSERT INTO categories VALUES (2, 'Books')");

    exec.executeSql("CREATE TABLE products (id INTEGER, cat_id INTEGER, name TEXT, price INTEGER)");
    exec.executeSql("INSERT INTO products VALUES (1, 1, 'Laptop', 999)");
    exec.executeSql("INSERT INTO products VALUES (2, 1, 'Phone', 699)");
    exec.executeSql("INSERT INTO products VALUES (3, 1, 'Tablet', 499)");
    exec.executeSql("INSERT INTO products VALUES (4, 1, 'Watch', 299)");
    exec.executeSql("INSERT INTO products VALUES (5, 2, 'Novel', 15)");
    exec.executeSql("INSERT INTO products VALUES (6, 2, 'Textbook', 80)");
    exec.executeSql("INSERT INTO products VALUES (7, 2, 'Comic', 10)");

    // Top 2 most expensive products per category
    var r = exec.executeSql("SELECT c.name, p.name, p.price FROM categories c, LATERAL (SELECT name, price FROM products WHERE cat_id = c.id ORDER BY price DESC LIMIT 2) p ORDER BY c.name, p.price DESC");
    assertSuccess(r, "top-2 per category");
    assertRowCount(r, 4, "4 total (2 per category)");

    // Books category
    assertEq(val(r, 0, 0), "Books", "first group = Books");
    assertEq(val(r, 0, 1), "Textbook", "Books top 1 = Textbook");
    assertEq(val(r, 1, 1), "Novel", "Books top 2 = Novel");

    // Electronics category
    assertEq(val(r, 2, 0), "Electronics", "second group = Electronics");
    assertEq(val(r, 2, 1), "Laptop", "Electronics top 1 = Laptop");
    assertEq(val(r, 3, 1), "Phone", "Electronics top 2 = Phone");
}

//=============================================================================
// 2. Aggregate in LATERAL subquery
//=============================================================================

func testLateralAggregate() {
    section("LATERAL: aggregate per outer row");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE users (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO users VALUES (1, 'Alice')");
    exec.executeSql("INSERT INTO users VALUES (2, 'Bob')");
    exec.executeSql("INSERT INTO users VALUES (3, 'Charlie')");

    exec.executeSql("CREATE TABLE orders (id INTEGER, user_id INTEGER, amount INTEGER)");
    exec.executeSql("INSERT INTO orders VALUES (1, 1, 100)");
    exec.executeSql("INSERT INTO orders VALUES (2, 1, 200)");
    exec.executeSql("INSERT INTO orders VALUES (3, 2, 150)");
    exec.executeSql("INSERT INTO orders VALUES (4, 1, 50)");

    // Count and sum orders per user via LATERAL
    var r = exec.executeSql("SELECT u.name, o.cnt, o.total FROM users u, LATERAL (SELECT COUNT(*) AS cnt, SUM(amount) AS total FROM orders WHERE user_id = u.id) o ORDER BY u.name");
    assertSuccess(r, "LATERAL aggregate");
    assertRowCount(r, 3, "3 users");
    assertEq(val(r, 0, 0), "Alice", "Alice");
    assertEq(val(r, 0, 1), "3", "Alice has 3 orders");
    assertEq(val(r, 0, 2), "350", "Alice total = 350");
    assertEq(val(r, 1, 0), "Bob", "Bob");
    assertEq(val(r, 1, 1), "1", "Bob has 1 order");
}

//=============================================================================
// 3. LEFT JOIN LATERAL with empty subresult
//=============================================================================

func testLeftJoinLateral() {
    section("LEFT JOIN LATERAL");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE departments (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO departments VALUES (1, 'Engineering')");
    exec.executeSql("INSERT INTO departments VALUES (2, 'Marketing')");
    exec.executeSql("INSERT INTO departments VALUES (3, 'Legal')");

    exec.executeSql("CREATE TABLE employees (id INTEGER, dept_id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO employees VALUES (1, 1, 'Alice')");
    exec.executeSql("INSERT INTO employees VALUES (2, 1, 'Bob')");
    exec.executeSql("INSERT INTO employees VALUES (3, 2, 'Charlie')");
    // Legal has no employees

    // LEFT JOIN LATERAL: departments without employees should show NULL
    var r = exec.executeSql("SELECT d.name, e.name FROM departments d LEFT JOIN LATERAL (SELECT name FROM employees WHERE dept_id = d.id LIMIT 1) e ON true ORDER BY d.name");
    assertSuccess(r, "LEFT JOIN LATERAL");
    assertRowCount(r, 3, "3 departments (Legal has NULL employee)");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== LATERAL JOIN Completion Tests ===");
    Terminal.Say("");

    testTopNPerGroup();
    testLateralAggregate();
    testLeftJoinLateral();

    printResults();
}
