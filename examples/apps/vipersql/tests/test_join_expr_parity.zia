// test_join_expr_parity.zia — Join Engine Expression Parity Tests
// Part of ViperSQL
//
// Tests that evalJoinExpr supports all operators that the main executor
// handles: LIKE, IN, CONCAT, MOD, IS DISTINCT FROM, REAL arithmetic,
// CASE expressions, function calls, and unary operators in JOIN contexts.

module test_join_expr_parity;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind Viper.String as String;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// Setup helpers
//=============================================================================

func makeExec() -> Executor {
    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE left_t (id INTEGER, name TEXT, val INTEGER, price REAL)");
    exec.executeSql("INSERT INTO left_t VALUES (1, 'Alice', 10, 1.5)");
    exec.executeSql("INSERT INTO left_t VALUES (2, 'Bob', 20, 2.5)");
    exec.executeSql("INSERT INTO left_t VALUES (3, 'Charlie', 30, 3.5)");
    exec.executeSql("INSERT INTO left_t VALUES (4, NULL, NULL, NULL)");

    exec.executeSql("CREATE TABLE right_t (id INTEGER, label TEXT, ref_val INTEGER, factor REAL)");
    exec.executeSql("INSERT INTO right_t VALUES (1, 'alpha', 10, 0.5)");
    exec.executeSql("INSERT INTO right_t VALUES (2, 'beta', 25, 1.0)");
    exec.executeSql("INSERT INTO right_t VALUES (3, 'gamma', 30, 1.5)");
    exec.executeSql("INSERT INTO right_t VALUES (4, NULL, NULL, NULL)");

    return exec;
}

//=============================================================================
// 1. LIKE in JOIN ON clause
//=============================================================================

func testJoinLike() {
    section("JOIN with LIKE");

    var exec = makeExec();

    // JOIN where left name matches pattern from right
    exec.executeSql("CREATE TABLE patterns (id INTEGER, pat TEXT)");
    exec.executeSql("INSERT INTO patterns VALUES (1, 'A%')");
    exec.executeSql("INSERT INTO patterns VALUES (2, 'B%')");
    exec.executeSql("INSERT INTO patterns VALUES (3, '%lie')");

    var r = exec.executeSql("SELECT l.name, p.pat FROM left_t l INNER JOIN patterns p ON l.name LIKE p.pat ORDER BY l.name, p.pat");
    assertSuccess(r, "JOIN with LIKE");
    // Alice matches 'A%' and '%lie', Bob matches 'B%', Charlie matches '%lie'
    assert(r.rowCount() >= 3, "LIKE join has at least 3 matches");

    // LIKE with literal pattern in JOIN WHERE
    r = exec.executeSql("SELECT l.name, r.label FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.name LIKE 'A%'");
    assertSuccess(r, "JOIN WHERE with LIKE");
    assertRowCount(r, 1, "only Alice matches A%");
    assertEq(val(r, 0, 0), "Alice", "Alice found");
}

//=============================================================================
// 2. CONCAT (||) in JOIN context
//=============================================================================

func testJoinConcat() {
    section("JOIN with CONCAT");

    var exec = makeExec();

    // Use || in JOIN WHERE clause
    var r = exec.executeSql("SELECT l.name, r.label FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.name || '-' || r.label = 'Alice-alpha'");
    assertSuccess(r, "JOIN WHERE with CONCAT");
    assertRowCount(r, 1, "one row matches concat");
    assertEq(val(r, 0, 0), "Alice", "Alice-alpha");

    // CONCAT in SELECT with JOIN
    r = exec.executeSql("SELECT l.name || ' -> ' || r.label FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.id = 2");
    assertSuccess(r, "CONCAT in SELECT with JOIN");
    assertEq(val(r, 0, 0), "Bob -> beta", "Bob -> beta");
}

//=============================================================================
// 3. MOD (%) in JOIN context
//=============================================================================

func testJoinMod() {
    section("JOIN with MOD");

    var exec = makeExec();

    // JOIN ON condition using modulo
    var r = exec.executeSql("SELECT l.name, r.label FROM left_t l INNER JOIN right_t r ON l.val % 10 = r.ref_val % 10 ORDER BY l.name");
    assertSuccess(r, "JOIN ON with MOD");
    // l.val%10: 10%10=0, 20%10=0, 30%10=0; r.ref_val%10: 10%10=0, 25%10=5, 30%10=0
    // Matches: l(10)=r(10), l(10)=r(30), l(20)=r(10), l(20)=r(30), l(30)=r(10), l(30)=r(30)
    assert(r.rowCount() >= 4, "MOD join has matches");
}

//=============================================================================
// 4. IN list in JOIN WHERE
//=============================================================================

func testJoinIn() {
    section("JOIN with IN");

    var exec = makeExec();

    var r = exec.executeSql("SELECT l.name, r.label FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.val IN (10, 30)");
    assertSuccess(r, "JOIN WHERE with IN");
    assertRowCount(r, 2, "val IN (10, 30) matches 2 rows");
    assertEq(val(r, 0, 0), "Alice", "Alice has val=10");
    assertEq(val(r, 1, 0), "Charlie", "Charlie has val=30");

    // IN with strings
    r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE r.label IN ('alpha', 'gamma')");
    assertSuccess(r, "JOIN WHERE with IN strings");
    assertRowCount(r, 2, "label IN (alpha, gamma) matches 2");
}

//=============================================================================
// 5. IS DISTINCT FROM in JOIN context
//=============================================================================

func testJoinIsDistinct() {
    section("JOIN with IS DISTINCT FROM");

    var exec = makeExec();

    // IS DISTINCT FROM treats NULL as equal to NULL (unlike regular =)
    var r = exec.executeSql("SELECT l.id, r.id FROM left_t l INNER JOIN right_t r ON l.val IS NOT DISTINCT FROM r.ref_val");
    assertSuccess(r, "JOIN ON IS NOT DISTINCT FROM");
    // Matches: (1,1) val=10=ref_val=10, (3,3) val=30=ref_val=30, (4,4) NULL=NULL
    assert(r.rowCount() >= 3, "IS NOT DISTINCT FROM matches NULLs");

    // Verify NULL=NULL match exists
    var hasNullMatch = false;
    var ri = 0;
    while ri < r.rowCount() {
        if val(r, ri, 0) == "4" && val(r, ri, 1) == "4" {
            hasNullMatch = true;
        }
        ri = ri + 1;
    }
    assert(hasNullMatch, "NULL IS NOT DISTINCT FROM NULL matches");
}

//=============================================================================
// 6. REAL arithmetic in JOIN
//=============================================================================

func testJoinRealArith() {
    section("JOIN with REAL arithmetic");

    var exec = makeExec();

    // REAL multiplication in WHERE
    var r = exec.executeSql("SELECT l.name, l.price * r.factor FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.price * r.factor > 2.0 ORDER BY l.name");
    assertSuccess(r, "JOIN WHERE with REAL multiplication");
    // l1: 1.5*0.5=0.75, l2: 2.5*1.0=2.5, l3: 3.5*1.5=5.25
    assertRowCount(r, 2, "2 rows with product > 2.0");
    assertEq(val(r, 0, 0), "Bob", "Bob: 2.5*1.0=2.5 > 2.0");
    assertEq(val(r, 1, 0), "Charlie", "Charlie: 3.5*1.5=5.25 > 2.0");

    // REAL addition
    r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.price + r.factor > 4.0");
    assertSuccess(r, "JOIN WHERE with REAL addition");
    // l1: 1.5+0.5=2.0, l2: 2.5+1.0=3.5, l3: 3.5+1.5=5.0
    assertRowCount(r, 1, "1 row with sum > 4.0");
    assertEq(val(r, 0, 0), "Charlie", "Charlie: 3.5+1.5=5.0 > 4.0");
}

//=============================================================================
// 7. CASE expression in JOIN
//=============================================================================

func testJoinCase() {
    section("JOIN with CASE");

    var exec = makeExec();

    var r = exec.executeSql("SELECT l.name, CASE WHEN l.val > 20 THEN 'high' WHEN l.val > 10 THEN 'mid' ELSE 'low' END AS tier FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.id <= 3 ORDER BY l.id");
    assertSuccess(r, "JOIN SELECT with CASE");
    assertRowCount(r, 3, "3 rows");
    // Note: CASE is evaluated in SELECT projection, not in evalJoinExpr
    // The important thing is it doesn't crash and returns 3 rows
    // Verify at least one non-null tier result
    var hasTier = val(r, 0, 1) != "" && val(r, 0, 1) != "NULL";
    assert(hasTier, "CASE produces non-null results");
}

//=============================================================================
// 8. Function call in JOIN WHERE
//=============================================================================

func testJoinFunction() {
    section("JOIN with function calls");

    var exec = makeExec();

    // UPPER() in join WHERE
    exec.executeSql("CREATE TABLE names (id INTEGER, uname TEXT)");
    exec.executeSql("INSERT INTO names VALUES (1, 'ALICE')");
    exec.executeSql("INSERT INTO names VALUES (2, 'BOB')");

    var r = exec.executeSql("SELECT l.name, n.uname FROM left_t l INNER JOIN names n ON UPPER(l.name) = n.uname ORDER BY l.name");
    assertSuccess(r, "JOIN ON with UPPER()");
    assertRowCount(r, 2, "Alice=ALICE, Bob=BOB");
    assertEq(val(r, 0, 0), "Alice", "Alice matched ALICE");
    assertEq(val(r, 1, 0), "Bob", "Bob matched BOB");

    // LENGTH() in join WHERE
    r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE LENGTH(l.name) > 4");
    assertSuccess(r, "JOIN WHERE with LENGTH()");
    // Alice=5, Bob=3, Charlie=7
    assertRowCount(r, 2, "2 names longer than 4");
}

//=============================================================================
// 9. Unary NOT in JOIN WHERE
//=============================================================================

func testJoinUnaryNot() {
    section("JOIN with NOT");

    var exec = makeExec();

    var r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE NOT (l.val > 20)");
    assertSuccess(r, "JOIN WHERE with NOT");
    // NOT (val > 20): Alice(10)=true, Bob(20)=true, NULL→NOT(0)=true, Charlie(30)=false
    // Note: NULL > 20 evaluates to 0 (false), NOT 0 = 1 (true) — matches executor behavior
    assertRowCount(r, 3, "NOT val>20 matches Alice, Bob, and NULL row");

    // Unary minus
    r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE -l.val < -15");
    assertSuccess(r, "JOIN WHERE with unary minus");
    // -10 < -15? No. -20 < -15? Yes. -30 < -15? Yes.
    assertRowCount(r, 2, "Bob and Charlie have -val < -15");
}

//=============================================================================
// 10. Combined operators in complex JOIN
//=============================================================================

func testJoinCombined() {
    section("JOIN with combined operators");

    var exec = makeExec();

    // Complex WHERE: LIKE AND MOD AND comparison
    var r = exec.executeSql("SELECT l.name, r.label FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.name LIKE '%ob' AND l.val % 10 = 0");
    assertSuccess(r, "complex JOIN WHERE");
    assertRowCount(r, 1, "only Bob matches");
    assertEq(val(r, 0, 0), "Bob", "Bob matches LIKE '%ob' AND val%10=0");

    // LEFT JOIN with IS NULL and CONCAT
    var r2 = exec.executeSql("SELECT l.name, l.name || '-' || COALESCE(r.label, 'none') FROM left_t l LEFT JOIN right_t r ON l.id = r.id AND r.ref_val > 100 ORDER BY l.id");
    assertSuccess(r2, "LEFT JOIN with complex expression");
    assertRowCount(r2, 4, "LEFT JOIN preserves all left rows");
}

//=============================================================================
// 11. Regex match in JOIN
//=============================================================================

func testJoinRegex() {
    section("JOIN with regex");

    var exec = makeExec();

    var r = exec.executeSql("SELECT l.name FROM left_t l INNER JOIN right_t r ON l.id = r.id WHERE l.name ~ '^[AB]'");
    assertSuccess(r, "JOIN WHERE with regex ~");
    assertRowCount(r, 2, "Alice and Bob match ^[AB]");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== Join Engine Expression Parity Tests ===");
    Terminal.Say("");

    testJoinLike();
    testJoinConcat();
    testJoinMod();
    testJoinIn();
    testJoinIsDistinct();
    testJoinRealArith();
    testJoinCase();
    testJoinFunction();
    testJoinUnaryNot();
    testJoinCombined();
    testJoinRegex();

    printResults();
}
