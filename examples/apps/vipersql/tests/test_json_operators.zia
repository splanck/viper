// test_json_operators.zia — JSON Path Operator Tests (-> and ->>)
// Part of ViperSQL

module test_json_operators;

bind Terminal = Viper.Terminal;
bind Fmt = Viper.Fmt;

bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// 1. Basic -> operator (returns JSON)
//=============================================================================

func testArrowJson() {
    section("JSON -> operator");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE docs (id INTEGER, data JSON)");
    exec.executeSql("INSERT INTO docs VALUES (1, '{\"name\": \"Alice\", \"age\": 30}')");
    exec.executeSql("INSERT INTO docs VALUES (2, '{\"name\": \"Bob\", \"age\": 25}')");
    exec.executeSql("INSERT INTO docs VALUES (3, '{\"name\": \"Charlie\", \"age\": 35}')");

    // Extract JSON value with ->
    var r = exec.executeSql("SELECT data->'name' FROM docs WHERE id = 1");
    assertSuccess(r, "-> extracts JSON");
    assertRowCount(r, 1, "1 row");
    // Result should be a quoted JSON string: "Alice"
    var nameJson = val(r, 0, 0);
    assert(stringContains(nameJson, "Alice"), "-> returns JSON with Alice");

    // Extract integer from JSON
    r = exec.executeSql("SELECT data->'age' FROM docs WHERE id = 2");
    assertSuccess(r, "-> extracts JSON integer");
    assertEq(val(r, 0, 0), "25", "age = 25 as JSON");
}

//=============================================================================
// 2. ->> operator (returns TEXT)
//=============================================================================

func testArrowText() {
    section("JSON ->> operator");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE docs (id INTEGER, data JSON)");
    exec.executeSql("INSERT INTO docs VALUES (1, '{\"name\": \"Alice\", \"city\": \"NYC\"}')");
    exec.executeSql("INSERT INTO docs VALUES (2, '{\"name\": \"Bob\", \"city\": \"LA\"}')");

    // Extract as text with ->>
    var r = exec.executeSql("SELECT data->>'name' FROM docs WHERE id = 1");
    assertSuccess(r, "->> extracts text");
    assertEq(val(r, 0, 0), "Alice", "->> returns plain text Alice");

    r = exec.executeSql("SELECT data->>'city' FROM docs WHERE id = 2");
    assertSuccess(r, "->> city");
    assertEq(val(r, 0, 0), "LA", "->> returns LA");
}

//=============================================================================
// 3. Chained access: ->'key1'->'key2'
//=============================================================================

func testChainedAccess() {
    section("Chained JSON access");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE nested (id INTEGER, data JSON)");
    exec.executeSql("INSERT INTO nested VALUES (1, '{\"address\": {\"city\": \"NYC\", \"zip\": \"10001\"}}')");

    // Chain: data->'address'->'city'
    var r = exec.executeSql("SELECT data->'address'->>'city' FROM nested WHERE id = 1");
    assertSuccess(r, "chained -> then ->>");
    assertEq(val(r, 0, 0), "NYC", "nested city = NYC");

    // Chain: data->'address'->>'zip'
    r = exec.executeSql("SELECT data->'address'->>'zip' FROM nested WHERE id = 1");
    assertSuccess(r, "chained zip");
    assertEq(val(r, 0, 0), "10001", "nested zip = 10001");
}

//=============================================================================
// 4. JSON operators in WHERE clause
//=============================================================================

func testJsonWhere() {
    section("JSON operators in WHERE");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE users (id INTEGER, profile JSON)");
    exec.executeSql("INSERT INTO users VALUES (1, '{\"status\": \"active\", \"role\": \"admin\"}')");
    exec.executeSql("INSERT INTO users VALUES (2, '{\"status\": \"inactive\", \"role\": \"user\"}')");
    exec.executeSql("INSERT INTO users VALUES (3, '{\"status\": \"active\", \"role\": \"user\"}')");

    // Filter by JSON value
    var r = exec.executeSql("SELECT id FROM users WHERE profile->>'status' = 'active' ORDER BY id");
    assertSuccess(r, "WHERE with ->>");
    assertRowCount(r, 2, "2 active users");
    assertEq(val(r, 0, 0), "1", "user 1 active");
    assertEq(val(r, 1, 0), "3", "user 3 active");

    // Filter by JSON role
    r = exec.executeSql("SELECT id FROM users WHERE profile->>'role' = 'admin'");
    assertSuccess(r, "WHERE role = admin");
    assertRowCount(r, 1, "1 admin");
    assertEq(val(r, 0, 0), "1", "user 1 is admin");
}

//=============================================================================
// 5. NULL handling
//=============================================================================

func testJsonNull() {
    section("JSON operators with NULL");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE jnull (id INTEGER, data JSON)");
    exec.executeSql("INSERT INTO jnull VALUES (1, NULL)");
    exec.executeSql("INSERT INTO jnull VALUES (2, '{\"key\": \"val\"}')");

    // NULL -> 'key' should be NULL
    var r = exec.executeSql("SELECT data->>'key' FROM jnull WHERE id = 1");
    assertSuccess(r, "NULL ->> doesn't crash");

    // Non-existent key should return NULL
    r = exec.executeSql("SELECT data->>'nonexistent' FROM jnull WHERE id = 2");
    assertSuccess(r, "missing key doesn't crash");
}

//=============================================================================
// 6. JSON operators in JOIN
//=============================================================================

func testJsonJoin() {
    section("JSON operators in JOIN");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE products (id INTEGER, info JSON)");
    exec.executeSql("INSERT INTO products VALUES (1, '{\"category\": \"electronics\"}')");
    exec.executeSql("INSERT INTO products VALUES (2, '{\"category\": \"clothing\"}')");
    exec.executeSql("INSERT INTO products VALUES (3, '{\"category\": \"electronics\"}')");

    exec.executeSql("CREATE TABLE categories (name TEXT, discount INTEGER)");
    exec.executeSql("INSERT INTO categories VALUES ('electronics', 10)");
    exec.executeSql("INSERT INTO categories VALUES ('clothing', 20)");

    var r = exec.executeSql("SELECT p.id, c.discount FROM products p INNER JOIN categories c ON p.info->>'category' = c.name ORDER BY p.id");
    assertSuccess(r, "JOIN on JSON ->> value");
    assertRowCount(r, 3, "3 products matched");
    assertEq(val(r, 0, 1), "10", "product 1 electronics discount 10");
    assertEq(val(r, 1, 1), "20", "product 2 clothing discount 20");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== JSON Path Operator Tests ===");
    Terminal.Say("");

    testArrowJson();
    testArrowText();
    testChainedAccess();
    testJsonWhere();
    testJsonNull();
    testJsonJoin();

    printResults();
}
