// test_expression_indexes.zia — Expression/Functional Index Tests
// Part of ViperSQL

module test_expression_indexes;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// 1. LOWER() expression index
//=============================================================================

func testLowerIndex() {
    section("Expression Index: LOWER()");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE users (id INTEGER, email TEXT)");
    exec.executeSql("INSERT INTO users VALUES (1, 'Alice@Example.com')");
    exec.executeSql("INSERT INTO users VALUES (2, 'BOB@TEST.COM')");
    exec.executeSql("INSERT INTO users VALUES (3, 'charlie@demo.org')");

    // Create expression index
    assertSuccess(exec.executeSql("CREATE INDEX idx_lower_email ON users(LOWER(email))"), "create LOWER index");

    // Query using expression — should use index
    var r = exec.executeSql("SELECT id FROM users WHERE LOWER(email) = 'alice@example.com'");
    assertSuccess(r, "query with LOWER expression");
    assertRowCount(r, 1, "found 1 row");
    assertEq(val(r, 0, 0), "1", "found Alice");

    r = exec.executeSql("SELECT id FROM users WHERE LOWER(email) = 'bob@test.com'");
    assertSuccess(r, "query LOWER bob");
    assertRowCount(r, 1, "found Bob");
    assertEq(val(r, 0, 0), "2", "found Bob id=2");

    // Non-matching query
    r = exec.executeSql("SELECT id FROM users WHERE LOWER(email) = 'nonexistent@test.com'");
    assertSuccess(r, "query LOWER no match");
    assertRowCount(r, 0, "no match");
}

//=============================================================================
// 2. UPPER() expression index
//=============================================================================

func testUpperIndex() {
    section("Expression Index: UPPER()");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE products (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO products VALUES (1, 'Widget')");
    exec.executeSql("INSERT INTO products VALUES (2, 'gadget')");
    exec.executeSql("INSERT INTO products VALUES (3, 'DOOHICKEY')");

    assertSuccess(exec.executeSql("CREATE INDEX idx_upper_name ON products(UPPER(name))"), "create UPPER index");

    var r = exec.executeSql("SELECT id FROM products WHERE UPPER(name) = 'WIDGET'");
    assertSuccess(r, "query UPPER");
    assertRowCount(r, 1, "found Widget");
    assertEq(val(r, 0, 0), "1", "Widget id=1");

    r = exec.executeSql("SELECT id FROM products WHERE UPPER(name) = 'GADGET'");
    assertSuccess(r, "query UPPER gadget");
    assertRowCount(r, 1, "found gadget");
    assertEq(val(r, 0, 0), "2", "gadget id=2");
}

//=============================================================================
// 3. ABS() expression index
//=============================================================================

func testAbsIndex() {
    section("Expression Index: ABS()");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE readings (id INTEGER, value INTEGER)");
    exec.executeSql("INSERT INTO readings VALUES (1, -50)");
    exec.executeSql("INSERT INTO readings VALUES (2, 30)");
    exec.executeSql("INSERT INTO readings VALUES (3, -30)");
    exec.executeSql("INSERT INTO readings VALUES (4, 50)");

    assertSuccess(exec.executeSql("CREATE INDEX idx_abs_value ON readings(ABS(value))"), "create ABS index");

    var r = exec.executeSql("SELECT id FROM readings WHERE ABS(value) = 50 ORDER BY id");
    assertSuccess(r, "query ABS(value)=50");
    assertRowCount(r, 2, "2 rows with |value|=50");
    assertEq(val(r, 0, 0), "1", "id=1 (value=-50)");
    assertEq(val(r, 1, 0), "4", "id=4 (value=50)");
}

//=============================================================================
// 4. DROP expression index
//=============================================================================

func testDropExprIndex() {
    section("Drop expression index");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE t (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO t VALUES (1, 'Hello')");

    assertSuccess(exec.executeSql("CREATE INDEX idx_low ON t(LOWER(name))"), "create expr index");
    assertSuccess(exec.executeSql("DROP INDEX idx_low"), "drop expr index");

    // Query still works (falls back to scan)
    var r = exec.executeSql("SELECT id FROM t WHERE LOWER(name) = 'hello'");
    assertSuccess(r, "query after drop");
    assertRowCount(r, 1, "found via scan");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== Expression Index Tests ===");
    Terminal.Say("");

    testLowerIndex();
    testUpperIndex();
    testAbsIndex();
    testDropExprIndex();

    printResults();
}
