// test_new_features.zia — Tests for new aggregate and table function features
// Part of ViperSQL
//
// Tests: JSON_AGG, JSON_OBJECT_AGG, EVERY (BOOL_AND alias),
// and GENERATE_SERIES with dates.

module test_new_features;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind Viper.String as String;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// JSON_AGG
//=============================================================================

func testJsonAgg() {
    section("JSON_AGG");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE items (id INTEGER, category TEXT, name TEXT, price INTEGER)");
    exec.executeSql("INSERT INTO items VALUES (1, 'fruit', 'Apple', 100)");
    exec.executeSql("INSERT INTO items VALUES (2, 'fruit', 'Banana', 50)");
    exec.executeSql("INSERT INTO items VALUES (3, 'veg', 'Carrot', 30)");
    exec.executeSql("INSERT INTO items VALUES (4, 'veg', 'Daikon', 45)");
    exec.executeSql("INSERT INTO items VALUES (5, 'fruit', 'Elderberry', 200)");

    // JSON_AGG with GROUP BY
    var r = exec.executeSql("SELECT category, JSON_AGG(name) FROM items GROUP BY category ORDER BY category");
    assertSuccess(r, "JSON_AGG with GROUP BY");
    assertRowCount(r, 2, "2 categories");
    // fruit: ["Apple", "Banana", "Elderberry"]
    var fruitJson = val(r, 0, 1);
    assert(stringContains(fruitJson, "Apple"), "fruit JSON contains Apple");
    assert(stringContains(fruitJson, "Banana"), "fruit JSON contains Banana");
    assert(stringContains(fruitJson, "Elderberry"), "fruit JSON contains Elderberry");
    // veg: ["Carrot", "Daikon"]
    var vegJson = val(r, 1, 1);
    assert(stringContains(vegJson, "Carrot"), "veg JSON contains Carrot");
    assert(stringContains(vegJson, "Daikon"), "veg JSON contains Daikon");

    // JSON_AGG with integers
    r = exec.executeSql("SELECT category, JSON_AGG(price) FROM items GROUP BY category ORDER BY category");
    assertSuccess(r, "JSON_AGG with integers");
    var fruitPrices = val(r, 0, 1);
    assert(stringContains(fruitPrices, "100"), "fruit prices contains 100");
    assert(stringContains(fruitPrices, "50"), "fruit prices contains 50");

    // JSON_AGG without GROUP BY (all rows)
    r = exec.executeSql("SELECT JSON_AGG(name) FROM items");
    assertSuccess(r, "JSON_AGG without GROUP BY");
    assertRowCount(r, 1, "1 result row");
    var allJson = val(r, 0, 0);
    assert(stringContains(allJson, "["), "result is JSON array");
    assert(stringContains(allJson, "Apple"), "all JSON contains Apple");

    // JSON_AGG with NULL handling
    exec.executeSql("INSERT INTO items VALUES (6, 'veg', NULL, 10)");
    r = exec.executeSql("SELECT JSON_AGG(name) FROM items WHERE category = 'veg'");
    assertSuccess(r, "JSON_AGG skips NULLs");
    var vegAllJson = val(r, 0, 0);
    assert(stringContains(vegAllJson, "Carrot"), "veg all contains Carrot");
    // NULL name should be skipped
}

//=============================================================================
// JSON_OBJECT_AGG
//=============================================================================

func testJsonObjectAgg() {
    section("JSON_OBJECT_AGG");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE config (key TEXT, value TEXT)");
    exec.executeSql("INSERT INTO config VALUES ('host', 'localhost')");
    exec.executeSql("INSERT INTO config VALUES ('port', '5432')");
    exec.executeSql("INSERT INTO config VALUES ('database', 'main')");

    var r = exec.executeSql("SELECT JSON_OBJECT_AGG(key, value) FROM config");
    assertSuccess(r, "JSON_OBJECT_AGG");
    assertRowCount(r, 1, "1 result row");
    var jsonObj = val(r, 0, 0);
    assert(stringContains(jsonObj, "host"), "contains host key");
    assert(stringContains(jsonObj, "localhost"), "contains localhost value");
    assert(stringContains(jsonObj, "port"), "contains port key");
    assert(stringContains(jsonObj, "{"), "starts with {");

    // JSON_OBJECT_AGG with integer values
    exec.executeSql("CREATE TABLE scores (name TEXT, score INTEGER)");
    exec.executeSql("INSERT INTO scores VALUES ('Alice', 95)");
    exec.executeSql("INSERT INTO scores VALUES ('Bob', 87)");

    r = exec.executeSql("SELECT JSON_OBJECT_AGG(name, score) FROM scores");
    assertSuccess(r, "JSON_OBJECT_AGG with integers");
    var scoresJson = val(r, 0, 0);
    assert(stringContains(scoresJson, "Alice"), "contains Alice");
    assert(stringContains(scoresJson, "95"), "contains 95");
}

//=============================================================================
// EVERY (BOOL_AND alias)
//=============================================================================

func testEvery() {
    section("EVERY aggregate");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE students (id INTEGER, name TEXT, passed BOOLEAN, score INTEGER)");
    exec.executeSql("INSERT INTO students VALUES (1, 'Alice', true, 90)");
    exec.executeSql("INSERT INTO students VALUES (2, 'Bob', true, 85)");
    exec.executeSql("INSERT INTO students VALUES (3, 'Charlie', false, 40)");
    exec.executeSql("INSERT INTO students VALUES (4, 'Diana', true, 70)");

    // EVERY — all passed?
    var r = exec.executeSql("SELECT EVERY(passed) FROM students");
    assertSuccess(r, "EVERY all");
    assertEq(val(r, 0, 0), "false", "not all passed");

    // EVERY with WHERE filter
    r = exec.executeSql("SELECT EVERY(passed) FROM students WHERE score >= 70");
    assertSuccess(r, "EVERY filtered");
    assertEq(val(r, 0, 0), "true", "all with score>=70 passed");

    // EVERY with expression
    r = exec.executeSql("SELECT EVERY(score > 50) FROM students");
    assertSuccess(r, "EVERY with expression");
    assertEq(val(r, 0, 0), "false", "not all scored > 50");

    // BOOL_AND (same as EVERY)
    r = exec.executeSql("SELECT BOOL_AND(passed) FROM students WHERE score >= 70");
    assertSuccess(r, "BOOL_AND (same as EVERY)");
    assertEq(val(r, 0, 0), "true", "BOOL_AND agrees with EVERY");

    // BOOL_OR
    r = exec.executeSql("SELECT BOOL_OR(passed) FROM students");
    assertSuccess(r, "BOOL_OR");
    assertEq(val(r, 0, 0), "true", "at least one passed");

    r = exec.executeSql("SELECT BOOL_OR(score > 100) FROM students");
    assertSuccess(r, "BOOL_OR none true");
    assertEq(val(r, 0, 0), "false", "no score > 100");
}

//=============================================================================
// GENERATE_SERIES with dates
//=============================================================================

func testGenerateSeriesDates() {
    section("GENERATE_SERIES with dates");

    var exec = new Executor();
    exec.init();

    // Basic date series: 5 days
    var r = exec.executeSql("SELECT * FROM GENERATE_SERIES('2024-01-01', '2024-01-05', 1)");
    assertSuccess(r, "date series 5 days");
    assertRowCount(r, 5, "5 days generated");

    // Verify first and last dates
    var first = val(r, 0, 0);
    assert(stringContains(first, "2024-01-01"), "first date is 2024-01-01");
    var last = val(r, 4, 0);
    assert(stringContains(last, "2024-01-05"), "last date is 2024-01-05");

    // Date series with step > 1 (every 7 days = weekly)
    r = exec.executeSql("SELECT * FROM GENERATE_SERIES('2024-01-01', '2024-01-31', 7)");
    assertSuccess(r, "weekly date series");
    assertRowCount(r, 5, "5 weeks in January");

    // Reverse date series
    r = exec.executeSql("SELECT * FROM GENERATE_SERIES('2024-01-05', '2024-01-01', -1)");
    assertSuccess(r, "reverse date series");
    assertRowCount(r, 5, "5 days descending");

    // Integer mode still works
    r = exec.executeSql("SELECT * FROM GENERATE_SERIES(1, 5, 1)");
    assertSuccess(r, "integer series still works");
    assertRowCount(r, 5, "5 integers");
    assertEq(val(r, 0, 0), "1", "first int = 1");
    assertEq(val(r, 4, 0), "5", "last int = 5");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== New Features Test Suite ===");
    Terminal.Say("");

    testJsonAgg();
    testJsonObjectAgg();
    testEvery();
    testGenerateSeriesDates();

    printResults();
}
