// test_writeable_ctes.zia — Writeable CTE Tests
// Part of ViperSQL
//
// Tests WITH ... INSERT/UPDATE/DELETE RETURNING as CTE bodies.

module test_writeable_ctes;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// 1. DELETE ... RETURNING as CTE → INSERT INTO archive
//=============================================================================

func testDeleteCteInsert() {
    section("Writeable CTE: DELETE → INSERT");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE old_data (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO old_data VALUES (1, 'Alice')");
    exec.executeSql("INSERT INTO old_data VALUES (2, 'Bob')");
    exec.executeSql("INSERT INTO old_data VALUES (3, 'Charlie')");
    exec.executeSql("CREATE TABLE archive (id INTEGER, name TEXT)");

    var r = exec.executeSql("WITH deleted AS (DELETE FROM old_data RETURNING *) INSERT INTO archive SELECT * FROM deleted");
    assertSuccess(r, "DELETE CTE → INSERT");

    var r2 = exec.executeSql("SELECT COUNT(*) FROM old_data");
    assertEq(val(r2, 0, 0), "0", "source table empty after move");

    var r3 = exec.executeSql("SELECT COUNT(*) FROM archive");
    assertEq(val(r3, 0, 0), "3", "archive has all 3 rows");

    var r4 = exec.executeSql("SELECT name FROM archive ORDER BY id");
    assertEq(val(r4, 0, 0), "Alice", "archive row 1");
    assertEq(val(r4, 1, 0), "Bob", "archive row 2");
    assertEq(val(r4, 2, 0), "Charlie", "archive row 3");
}

//=============================================================================
// 2. UPDATE ... RETURNING as CTE → SELECT
//=============================================================================

func testUpdateCteSelect() {
    section("Writeable CTE: UPDATE → SELECT");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE prices (id INTEGER, item TEXT, price INTEGER)");
    exec.executeSql("INSERT INTO prices VALUES (1, 'Widget', 100)");
    exec.executeSql("INSERT INTO prices VALUES (2, 'Gadget', 200)");
    exec.executeSql("INSERT INTO prices VALUES (3, 'Doohickey', 50)");

    var r = exec.executeSql("WITH updated AS (UPDATE prices SET price = price * 2 WHERE price < 150 RETURNING *) SELECT item, price FROM updated ORDER BY id");
    assertSuccess(r, "UPDATE CTE → SELECT");
    assertRowCount(r, 2, "2 items updated (Widget and Doohickey)");
    assertEq(val(r, 0, 0), "Widget", "Widget updated");
    assertEq(val(r, 0, 1), "200", "Widget new price");
    assertEq(val(r, 1, 0), "Doohickey", "Doohickey updated");
    assertEq(val(r, 1, 1), "100", "Doohickey new price");
}

//=============================================================================
// 3. INSERT ... RETURNING as CTE → SELECT
//=============================================================================

func testInsertCteSelect() {
    section("Writeable CTE: INSERT → SELECT");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE items (id INTEGER, name TEXT)");

    var r = exec.executeSql("WITH inserted AS (INSERT INTO items VALUES (1, 'Alpha'), (2, 'Beta'), (3, 'Gamma') RETURNING *) SELECT COUNT(*) FROM inserted");
    assertSuccess(r, "INSERT CTE → SELECT COUNT");
    assertEq(val(r, 0, 0), "3", "3 rows inserted and counted");
}

//=============================================================================
// 4. Conditional DELETE with CTE
//=============================================================================

func testConditionalDeleteCte() {
    section("Writeable CTE: conditional DELETE");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE logs (id INTEGER, level TEXT, msg TEXT)");
    exec.executeSql("INSERT INTO logs VALUES (1, 'ERROR', 'bad thing')");
    exec.executeSql("INSERT INTO logs VALUES (2, 'INFO', 'normal')");
    exec.executeSql("INSERT INTO logs VALUES (3, 'ERROR', 'another bad')");
    exec.executeSql("INSERT INTO logs VALUES (4, 'DEBUG', 'trace')");
    exec.executeSql("CREATE TABLE error_archive (id INTEGER, level TEXT, msg TEXT)");

    var r = exec.executeSql("WITH errors AS (DELETE FROM logs WHERE level = 'ERROR' RETURNING *) INSERT INTO error_archive SELECT * FROM errors");
    assertSuccess(r, "conditional DELETE CTE");

    var r2 = exec.executeSql("SELECT COUNT(*) FROM logs");
    assertEq(val(r2, 0, 0), "2", "2 non-error logs remain");

    var r3 = exec.executeSql("SELECT COUNT(*) FROM error_archive");
    assertEq(val(r3, 0, 0), "2", "2 errors archived");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== Writeable CTE Tests ===");
    Terminal.Say("");

    testDeleteCteInsert();
    testUpdateCteSelect();
    testInsertCteSelect();
    testConditionalDeleteCte();

    printResults();
}
