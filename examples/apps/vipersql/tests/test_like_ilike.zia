// test_like_ilike.zia — LIKE (case-sensitive) vs ILIKE (case-insensitive) Tests
// Part of ViperSQL
//
// Verifies SQL-standard LIKE is case-sensitive, while ILIKE (PostgreSQL
// extension) is case-insensitive. Both support % and _ wildcards.

module test_like_ilike;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "../engine/executor";
bind "../engine/types";
bind "./test_common";

//=============================================================================
// Setup
//=============================================================================

func makeExec() -> Executor {
    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE names (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO names VALUES (1, 'Alice')");
    exec.executeSql("INSERT INTO names VALUES (2, 'ALICE')");
    exec.executeSql("INSERT INTO names VALUES (3, 'alice')");
    exec.executeSql("INSERT INTO names VALUES (4, 'Bob')");
    exec.executeSql("INSERT INTO names VALUES (5, 'BOB')");
    exec.executeSql("INSERT INTO names VALUES (6, 'Charlie')");

    return exec;
}

//=============================================================================
// 1. LIKE is case-sensitive
//=============================================================================

func testLikeCaseSensitive() {
    section("LIKE (case-sensitive)");

    var exec = makeExec();

    // 'Alice' should only match exactly
    var r = exec.executeSql("SELECT id FROM names WHERE name LIKE 'Alice' ORDER BY id");
    assertSuccess(r, "LIKE exact match");
    assertRowCount(r, 1, "only one Alice");
    assertEq(val(r, 0, 0), "1", "id=1 is Alice");

    // 'A%' should match Alice and ALICE but not alice
    r = exec.executeSql("SELECT id FROM names WHERE name LIKE 'A%' ORDER BY id");
    assertSuccess(r, "LIKE A% case-sensitive");
    assertRowCount(r, 2, "Alice and ALICE start with A");
    assertEq(val(r, 0, 0), "1", "id=1 Alice");
    assertEq(val(r, 1, 0), "2", "id=2 ALICE");

    // 'a%' should match only alice
    r = exec.executeSql("SELECT id FROM names WHERE name LIKE 'a%' ORDER BY id");
    assertSuccess(r, "LIKE a% case-sensitive");
    assertRowCount(r, 1, "only lowercase alice");
    assertEq(val(r, 0, 0), "3", "id=3 alice");

    // '%ob' should match Bob but not BOB
    r = exec.executeSql("SELECT id FROM names WHERE name LIKE '%ob' ORDER BY id");
    assertSuccess(r, "LIKE %ob");
    assertRowCount(r, 1, "only Bob ends with ob");
    assertEq(val(r, 0, 0), "4", "id=4 Bob");

    // '_lice' should match Alice and alice (single char wildcard)
    r = exec.executeSql("SELECT id FROM names WHERE name LIKE '_lice' ORDER BY id");
    assertSuccess(r, "LIKE _lice");
    assertRowCount(r, 2, "Alice and alice match _lice");

    // NOT LIKE
    r = exec.executeSql("SELECT COUNT(*) FROM names WHERE name NOT LIKE 'A%'");
    assertSuccess(r, "NOT LIKE A%");
    assertEq(val(r, 0, 0), "4", "4 names don't start with uppercase A");
}

//=============================================================================
// 2. ILIKE is case-insensitive
//=============================================================================

func testIlikeCaseInsensitive() {
    section("ILIKE (case-insensitive)");

    var exec = makeExec();

    // ILIKE 'alice' should match all three: Alice, ALICE, alice
    var r = exec.executeSql("SELECT id FROM names WHERE name ILIKE 'alice' ORDER BY id");
    assertSuccess(r, "ILIKE alice");
    assertRowCount(r, 3, "all three alice variants");
    assertEq(val(r, 0, 0), "1", "Alice");
    assertEq(val(r, 1, 0), "2", "ALICE");
    assertEq(val(r, 2, 0), "3", "alice");

    // ILIKE 'a%' should match all three alice variants
    r = exec.executeSql("SELECT id FROM names WHERE name ILIKE 'a%' ORDER BY id");
    assertSuccess(r, "ILIKE a%");
    assertRowCount(r, 3, "all three start with a/A");

    // ILIKE '%OB' should match both Bob and BOB
    r = exec.executeSql("SELECT id FROM names WHERE name ILIKE '%OB' ORDER BY id");
    assertSuccess(r, "ILIKE %OB");
    assertRowCount(r, 2, "Bob and BOB");
    assertEq(val(r, 0, 0), "4", "Bob");
    assertEq(val(r, 1, 0), "5", "BOB");

    // NOT ILIKE
    r = exec.executeSql("SELECT COUNT(*) FROM names WHERE name NOT ILIKE 'alice'");
    assertSuccess(r, "NOT ILIKE alice");
    assertEq(val(r, 0, 0), "3", "3 non-alice names");
}

//=============================================================================
// 3. LIKE/ILIKE with NULL
//=============================================================================

func testLikeWithNull() {
    section("LIKE/ILIKE with NULL");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE t (id INTEGER, val TEXT)");
    exec.executeSql("INSERT INTO t VALUES (1, 'hello')");
    exec.executeSql("INSERT INTO t VALUES (2, NULL)");

    // NULL LIKE pattern should not match
    var r = exec.executeSql("SELECT COUNT(*) FROM t WHERE val LIKE '%'");
    assertSuccess(r, "LIKE skips NULL");
    assertEq(val(r, 0, 0), "1", "only non-NULL matches");

    r = exec.executeSql("SELECT COUNT(*) FROM t WHERE val ILIKE '%'");
    assertSuccess(r, "ILIKE skips NULL");
    assertEq(val(r, 0, 0), "1", "only non-NULL matches");
}

//=============================================================================
// 4. LIKE/ILIKE in JOIN context
//=============================================================================

func testLikeInJoin() {
    section("LIKE/ILIKE in JOIN");

    var exec = new Executor();
    exec.init();

    exec.executeSql("CREATE TABLE items (id INTEGER, name TEXT)");
    exec.executeSql("INSERT INTO items VALUES (1, 'Apple')");
    exec.executeSql("INSERT INTO items VALUES (2, 'BANANA')");
    exec.executeSql("INSERT INTO items VALUES (3, 'cherry')");

    exec.executeSql("CREATE TABLE patterns (id INTEGER, pat TEXT)");
    exec.executeSql("INSERT INTO patterns VALUES (1, 'A%')");
    exec.executeSql("INSERT INTO patterns VALUES (2, 'B%')");

    // LIKE in JOIN (case-sensitive): 'A%' matches Apple, 'B%' matches BANANA
    var r = exec.executeSql("SELECT i.name, p.pat FROM items i INNER JOIN patterns p ON i.name LIKE p.pat ORDER BY i.name");
    assertSuccess(r, "LIKE in JOIN");
    assertRowCount(r, 2, "Apple matches A%, BANANA matches B%");
    assertEq(val(r, 0, 0), "Apple", "Apple matches A%");
    assertEq(val(r, 1, 0), "BANANA", "BANANA matches B%");

    // ILIKE in JOIN (case-insensitive): 'a%' matches Apple, 'b%' matches BANANA
    exec.executeSql("UPDATE patterns SET pat = 'a%' WHERE id = 1");
    exec.executeSql("UPDATE patterns SET pat = 'b%' WHERE id = 2");

    r = exec.executeSql("SELECT i.name, p.pat FROM items i INNER JOIN patterns p ON i.name ILIKE p.pat ORDER BY i.name");
    assertSuccess(r, "ILIKE in JOIN");
    assertRowCount(r, 2, "Apple ilike a%, BANANA ilike b%");
    assertEq(val(r, 0, 0), "Apple", "Apple matches a% (ilike)");
    assertEq(val(r, 1, 0), "BANANA", "BANANA matches b% (ilike)");
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func main() {
    Terminal.Say("=== LIKE vs ILIKE Tests ===");
    Terminal.Say("");

    testLikeCaseSensitive();
    testIlikeCaseInsensitive();
    testLikeWithNull();
    testLikeInJoin();

    printResults();
}
