// =============================================================================
// pg_client.zia — Client-side PostgreSQL wire protocol v3
// Part of ViperSQL  (package: client)
// =============================================================================
//
// PURPOSE
// -------
// A client-only PG wire-protocol library.  Can talk to ViperSQL's
// own server (`server/pg_wire.zia`) or to any stock PostgreSQL
// server.  The CLI in `client/vsql.zia` is layered on top of this.
//
// Protocol primer (v3):
//   * Startup packet: [int32 length][int32 proto][key\0val\0...\0]
//     — no type byte.  Advertises proto version and connect
//     params (user, database, application_name).
//   * Every subsequent message: [byte type][int32 length][body].
//     Type byte is ASCII ('Q' for query, 'D' for data row, etc.).
//     Length is inclusive of itself (4 bytes) but NOT of the
//     type byte — a PG quirk that every PG client has to get
//     right.
//
// We implement the "Simple Query" subset:
//   * `Query`          'Q'  → full SQL text in one message.
//   * `RowDescription` 'T'  ← column metadata.
//   * `DataRow`        'D'  ← one row per message.
//   * `CommandComplete`'C'  ← tag line ("SELECT 5", etc.).
//   * `ReadyForQuery`  'Z'  ← "you may send another".
//   * `ErrorResponse`  'E'  ← structured error.
//
// The Extended Query protocol (Parse / Bind / Execute / Sync)
// is implemented server-side in `server/pg_wire.zia` but not
// here — Simple Query is all the CLI needs.
//
// WHERE THIS FITS
// ---------------
//     client/vsql.zia     (interactive CLI)
//         │
//         ▼
//     client/pg_client.zia   (YOU ARE HERE)
//         │  TCP + wire framing
//         ▼
//     server/pg_wire.zia     (ViperSQL server-side protocol)
//       or any PG-compatible server.
//
// KEY DESIGN CHOICES
// ------------------
//   1. Byte-by-byte length fields.  Every multi-byte integer is
//      hand-assembled in big-endian (PG's network byte order).
//      No dependency on a network-byte-order helper.
//
//   2. Message types as `final PG_*` constants.  Keeps the
//      codebase self-documenting — `readMessage` branches on
//      `PG_READY`, not the raw `90`.
//
//   3. Startup's "length includes self" oddity is handled once
//      in the send path; after that, every message follows the
//      uniform `[type][length][body]` form.
//
// =============================================================================

module pg_client;

bind Viper.Collections;
bind Viper.Network as Network;
bind Viper.String as String;
bind Viper.Fmt as Fmt;//=============================================================================
// PROTOCOL CONSTANTS (must match server/pg_wire.zia)
//=============================================================================

final PG_PROTOCOL_V3 = 196608;     // 3.0 << 16

// Backend message types (server → client)
final PG_AUTH = 82;                 // 'R'
final PG_PARAM_STATUS = 83;        // 'S'
final PG_BACKEND_KEY = 75;         // 'K'
final PG_READY = 90;               // 'Z'
final PG_ROW_DESC = 84;            // 'T'
final PG_DATA_ROW = 68;            // 'D'
final PG_CMD_COMPLETE = 67;        // 'C'
final PG_ERROR_RESP = 69;          // 'E'
final PG_NOTICE_RESP = 78;         // 'N'
final PG_EMPTY_QUERY = 73;         // 'I'

// Frontend message types (client → server)
final PG_QUERY = 81;               // 'Q'
final PG_TERMINATE = 88;           // 'X'
final PG_PASSWORD = 112;           // 'p'

//=============================================================================
// BYTE ENCODING HELPERS
//=============================================================================

func writeInt32BE(buf: Bytes, offset: Integer, value: Integer) {
    if value < 0 {
        var unsigned = 4294967296 + value;
        buf.Set(offset,     (unsigned / 16777216) % 256);
        buf.Set(offset + 1, (unsigned / 65536) % 256);
        buf.Set(offset + 2, (unsigned / 256) % 256);
        buf.Set(offset + 3, unsigned % 256);
        return;
    }
    buf.Set(offset,     (value / 16777216) % 256);
    buf.Set(offset + 1, (value / 65536) % 256);
    buf.Set(offset + 2, (value / 256) % 256);
    buf.Set(offset + 3, value % 256);
}

func readInt32BE(data: Bytes, offset: Integer) -> Integer {
    var b0 = data.Get(offset);
    var b1 = data.Get(offset + 1);
    var b2 = data.Get(offset + 2);
    var b3 = data.Get(offset + 3);
    return b0 * 16777216 + b1 * 65536 + b2 * 256 + b3;
}

func readInt16BE(data: Bytes, offset: Integer) -> Integer {
    return data.Get(offset) * 256 + data.Get(offset + 1);
}

//=============================================================================
// QUERY RESULT
//=============================================================================

class PgQueryResult {
    expose Boolean success;
    expose String errorMessage;
    expose List[String] columns;
    expose List[List[String]] rows;
    expose String commandTag;

    expose func init() {
        success = true;
        errorMessage = "";
        columns = [];
        rows = [];
        commandTag = "";
    }
}

//=============================================================================
// PG CLIENT CONNECTION
//=============================================================================

class PgConnection {
    expose Ptr socket;
    expose Boolean connected;
    expose String host;
    expose Integer port;
    expose String user;
    expose String database;
    expose String lastError;
    expose Integer backendPid;
    expose Integer backendKey;
    expose String txnStatus;

    expose func init() {
        connected = false;
        host = "localhost";
        port = 5432;
        user = "admin";
        database = "main";
        lastError = "";
        backendPid = 0;
        backendKey = 0;
        txnStatus = "I";
    }

    //=========================================================================
    // CONNECT — Startup handshake
    //=========================================================================

    expose func connect(password: String) -> Boolean {
        // TCP connect
        socket = Network.Tcp.Connect(host, port);
        if socket == null {
            lastError = "Could not connect to " + host + ":" + Fmt.Int(port);
            return false;
        }

        Network.Tcp.SetRecvTimeout(socket, 30000);

        // Send StartupMessage: int32(len) + int32(protocol) + user\0val\0 + database\0val\0 + \0
        var userBytes = Bytes.FromStr(user);
        var dbBytes = Bytes.FromStr(database);
        // Length = 4(len) + 4(proto) + 5("user\0") + userLen+1 + 9("database\0") + dbLen+1 + 1(term)
        var bodyLen = 4 + 5 + userBytes.Length + 1 + 9 + dbBytes.Length + 1 + 1;
        var totalLen = 4 + bodyLen;
        var msg = Bytes.New(totalLen);
        var pos = 0;

        writeInt32BE(msg, pos, totalLen);
        pos = pos + 4;
        writeInt32BE(msg, pos, PG_PROTOCOL_V3);
        pos = pos + 4;

        // "user\0"
        var userKey = Bytes.FromStr("user");
        Bytes.Copy(msg, pos, userKey, 0, userKey.Length);
        pos = pos + userKey.Length;
        msg.Set(pos, 0);
        pos = pos + 1;

        // user value\0
        Bytes.Copy(msg, pos, userBytes, 0, userBytes.Length);
        pos = pos + userBytes.Length;
        msg.Set(pos, 0);
        pos = pos + 1;

        // "database\0"
        var dbKey = Bytes.FromStr("database");
        Bytes.Copy(msg, pos, dbKey, 0, dbKey.Length);
        pos = pos + dbKey.Length;
        msg.Set(pos, 0);
        pos = pos + 1;

        // database value\0
        Bytes.Copy(msg, pos, dbBytes, 0, dbBytes.Length);
        pos = pos + dbBytes.Length;
        msg.Set(pos, 0);
        pos = pos + 1;

        // Final null terminator
        msg.Set(pos, 0);

        Network.Tcp.SendAll(socket, msg);

        // Read server responses until ReadyForQuery
        var ready = false;
        while ready == false {
            var r = readMessage();
            if r.Length == 0 {
                lastError = "Connection closed during startup";
                connected = false;
                return false;
            }
            var msgType = r.Get(0);

            if msgType == PG_AUTH {
                var authType = readInt32BE(r, 5);
                if authType == 0 {
                    // AuthenticationOk — continue
                }
                if authType == 3 {
                    // AuthenticationCleartextPassword — send password
                    sendPassword(password);
                }
            }

            if msgType == PG_BACKEND_KEY {
                backendPid = readInt32BE(r, 5);
                backendKey = readInt32BE(r, 9);
            }

            if msgType == PG_PARAM_STATUS {
                // ParameterStatus — ignore for now
            }

            if msgType == PG_READY {
                txnStatus = r.Slice(5, 6).ToStr();
                ready = true;
                connected = true;
            }

            if msgType == PG_ERROR_RESP {
                lastError = extractErrorMessage(r);
                connected = false;
                return false;
            }
        }

        return true;
    }

    //=========================================================================
    // SEND QUERY (Simple Query protocol)
    //=========================================================================

    expose func query(sql: String) -> PgQueryResult {
        var result = new PgQueryResult();
        result.init();

        if connected == false {
            result.success = false;
            result.errorMessage = "Not connected";
            return result;
        }

        // Send Query message: 'Q' + int32(len) + query\0
        var sqlBytes = Bytes.FromStr(sql);
        var bodyLen = sqlBytes.Length + 1;  // query + null terminator
        var totalLen = 1 + 4 + bodyLen;
        var msg = Bytes.New(totalLen);
        msg.Set(0, PG_QUERY);
        writeInt32BE(msg, 1, bodyLen + 4);  // length includes self
        Bytes.Copy(msg, 5, sqlBytes, 0, sqlBytes.Length);
        msg.Set(5 + sqlBytes.Length, 0);    // null terminator
        Network.Tcp.SendAll(socket, msg);

        // Read responses until ReadyForQuery
        var done = false;
        while done == false {
            var r = readMessage();
            if r.Length == 0 {
                result.success = false;
                result.errorMessage = "Connection lost";
                connected = false;
                return result;
            }
            var msgType = r.Get(0);

            if msgType == PG_ROW_DESC {
                // Parse column names
                var numCols = readInt16BE(r, 5);
                var offset = 7;
                var ci = 0;
                while ci < numCols {
                    var colName = readCString(r, offset);
                    result.columns.add(colName);
                    offset = offset + String.Length(colName) + 1;  // name + null
                    offset = offset + 18;  // skip: tableOid(4) + colAttr(2) + typeOid(4) + typeLen(2) + typeMod(4) + format(2)
                    ci = ci + 1;
                }
            }

            if msgType == PG_DATA_ROW {
                // Parse row values
                var numCols = readInt16BE(r, 5);
                var offset = 7;
                var row: List[String] = [];
                var ci = 0;
                while ci < numCols {
                    var colLen = readInt32BE(r, offset);
                    offset = offset + 4;
                    if colLen < 0 {
                        // NULL
                        row.add("(null)");
                    } else {
                        var valSlice: Bytes = r.Slice(offset, offset + colLen);
                        row.add(valSlice.ToStr());
                        offset = offset + colLen;
                    }
                    ci = ci + 1;
                }
                result.rows.add(row);
            }

            if msgType == PG_CMD_COMPLETE {
                result.commandTag = readCString(r, 5);
            }

            if msgType == PG_ERROR_RESP {
                result.success = false;
                result.errorMessage = extractErrorMessage(r);
            }

            if msgType == PG_EMPTY_QUERY {
                // Empty query — no-op
            }

            if msgType == PG_NOTICE_RESP {
                // Notice — ignore
            }

            if msgType == PG_READY {
                txnStatus = r.Slice(5, 6).ToStr();
                done = true;
            }
        }

        return result;
    }

    //=========================================================================
    // DISCONNECT
    //=========================================================================

    expose func disconnect() {
        if connected {
            // Send Terminate message: 'X' + int32(4)
            var msg = Bytes.New(5);
            msg.Set(0, PG_TERMINATE);
            writeInt32BE(msg, 1, 4);
            Network.Tcp.SendAll(socket, msg);
            Network.Tcp.Close(socket);
            connected = false;
        }
    }

    //=========================================================================
    // INTERNAL HELPERS
    //=========================================================================

    // Read one complete PG message: byte(type) + int32(len) + body
    // Returns message with type at index 0, length at 1-4, body at 5+
    // Returns empty Bytes on failure (Length == 0)
    hide func readMessage() -> Bytes {
        // Read 1-byte message type (matches server pgReadMessage pattern)
        var typeBuf: Bytes = Network.Tcp.RecvExact(socket, 1);
        if typeBuf.Length < 1 { return Bytes.New(0); }
        var msgType = typeBuf.Get(0);

        // Read 4-byte length (includes itself)
        var lenBuf: Bytes = Network.Tcp.RecvExact(socket, 4);
        if lenBuf.Length < 4 { return Bytes.New(0); }
        var length = readInt32BE(lenBuf, 0);

        var bodyLen = length - 4;
        if bodyLen <= 0 {
            // Header-only message (e.g., EmptyQueryResponse)
            var result = Bytes.New(5);
            result.Set(0, msgType);
            Bytes.Copy(result, 1, lenBuf, 0, 4);
            return result;
        }

        // Read body
        var body: Bytes = Network.Tcp.RecvExact(socket, bodyLen);

        // Assemble: type(1) + length(4) + body
        var full = Bytes.New(1 + 4 + body.Length);
        full.Set(0, msgType);
        Bytes.Copy(full, 1, lenBuf, 0, 4);
        Bytes.Copy(full, 5, body, 0, body.Length);
        return full;
    }

    // Send password message: 'p' + int32(len) + password\0
    hide func sendPassword(password: String) {
        var pwBytes = Bytes.FromStr(password);
        var bodyLen = pwBytes.Length + 1;
        var totalLen = 1 + 4 + bodyLen;
        var msg = Bytes.New(totalLen);
        msg.Set(0, PG_PASSWORD);
        writeInt32BE(msg, 1, bodyLen + 4);
        Bytes.Copy(msg, 5, pwBytes, 0, pwBytes.Length);
        msg.Set(5 + pwBytes.Length, 0);
        Network.Tcp.SendAll(socket, msg);
    }

    // Read null-terminated string from bytes at offset
    hide func readCString(data: Bytes, offset: Integer) -> String {
        var end = offset;
        while end < data.Length && data.Get(end) != 0 {
            end = end + 1;
        }
        if end == offset { return ""; }
        var slice: Bytes = data.Slice(offset, end);
        return slice.ToStr();
    }

    // Extract 'M' (message) field from ErrorResponse body
    hide func extractErrorMessage(data: Bytes) -> String {
        var offset = 5;  // skip type byte + length
        while offset < data.Length {
            var fieldType = data.Get(offset);
            offset = offset + 1;
            if fieldType == 0 { return "Unknown error"; }  // terminator
            var fieldVal = readCString(data, offset);
            offset = offset + String.Length(fieldVal) + 1;
            if fieldType == 77 {  // 'M' = message
                return fieldVal;
            }
        }
        return "Unknown error";
    }
}
