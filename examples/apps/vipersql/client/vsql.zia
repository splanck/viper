// vsql.zia — ViperSQL Interactive Client
//
// Connects to a running ViperSQL (or PostgreSQL) server via the PG wire
// protocol and provides an interactive SQL shell with aligned output,
// meta-commands, and multi-line input.
//
// Usage:
//   viper run examples/apps/vipersql/client/vsql.zia
//   viper run examples/apps/vipersql/client/vsql.zia -- -h localhost -p 5432 -U admin -d main
//
// Meta-commands:
//   \q          Quit
//   \?          Show help
//   \dt         List tables
//   \d TABLE    Describe table
//   \l          List databases
//   \c DBNAME   Switch database
//   \i FILE     Execute SQL from file
//   \timing     Toggle query timing
//   \x          Toggle expanded display

module vsql;

bind Terminal = Viper.Terminal;
bind String = Viper.String;
bind Fmt = Viper.Fmt;
bind Env = Viper.Environment;
bind Parse = Viper.Core.Parse;
bind File = Viper.IO.File;
bind DateTime = Viper.Time.DateTime;

bind "./pg_client";

//=============================================================================
// CONFIGURATION
//=============================================================================

final VERSION = "0.2.0";

class ClientConfig {
    expose String host;
    expose Integer port;
    expose String user;
    expose String database;
    expose String password;
    expose Boolean timing;
    expose Boolean expanded;

    expose func init() {
        host = "localhost";
        port = 5432;
        user = "admin";
        database = "main";
        password = "admin";
        timing = false;
        expanded = false;
    }
}

func parseArgs() -> ClientConfig {
    var config = new ClientConfig();
    config.init();

    var argc = Env.GetArgumentCount();
    var i = 0;
    while i < argc {
        var arg = Env.GetArgument(i);

        if (arg == "-h" || arg == "--host") && i + 1 < argc {
            i = i + 1;
            config.host = Env.GetArgument(i);
        }

        if (arg == "-p" || arg == "--port") && i + 1 < argc {
            i = i + 1;
            config.port = Parse.IntOr(Env.GetArgument(i), 5432);
        }

        if (arg == "-U" || arg == "--user") && i + 1 < argc {
            i = i + 1;
            config.user = Env.GetArgument(i);
        }

        if (arg == "-d" || arg == "--database") && i + 1 < argc {
            i = i + 1;
            config.database = Env.GetArgument(i);
        }

        if (arg == "-W" || arg == "--password") && i + 1 < argc {
            i = i + 1;
            config.password = Env.GetArgument(i);
        }

        if arg == "--help" {
            printUsage();
            return config;
        }

        i = i + 1;
    }

    return config;
}

func printUsage() {
    Terminal.Say("vsql v" + VERSION + " — ViperSQL interactive client");
    Terminal.Say("");
    Terminal.Say("Usage: vsql [options]");
    Terminal.Say("");
    Terminal.Say("Options:");
    Terminal.Say("  -h, --host HOST       Server hostname (default: localhost)");
    Terminal.Say("  -p, --port PORT       Server port (default: 5432)");
    Terminal.Say("  -U, --user USER       Username (default: admin)");
    Terminal.Say("  -d, --database DB     Database name (default: main)");
    Terminal.Say("  -W, --password PASS   Password (default: admin)");
    Terminal.Say("  --help                Show this help");
}

//=============================================================================
// RESULT FORMATTING
//=============================================================================

func formatAligned(result: PgQueryResult) -> String {
    if result.columns.count() == 0 {
        return result.commandTag;
    }

    // Calculate column widths (minimum = header length)
    var widths: List[Integer] = [];
    var ci = 0;
    while ci < result.columns.count() {
        widths.add(String.Length(result.columns.get(ci)));
        ci = ci + 1;
    }

    // Update widths from data rows
    var ri = 0;
    while ri < result.rows.count() {
        var row = result.rows.get(ri);
        ci = 0;
        while ci < row.count() && ci < widths.count() {
            var valLen = String.Length(row.get(ci));
            if valLen > widths.get(ci) {
                widths.set(ci, valLen);
            }
            ci = ci + 1;
        }
        ri = ri + 1;
    }

    var out = "";

    // Header row
    ci = 0;
    while ci < result.columns.count() {
        if ci > 0 { out = out + " | "; }
        out = out + padRight(result.columns.get(ci), widths.get(ci));
        ci = ci + 1;
    }
    out = out + "\n";

    // Separator
    ci = 0;
    while ci < result.columns.count() {
        if ci > 0 { out = out + "-+-"; }
        out = out + repeatChar("-", widths.get(ci));
        ci = ci + 1;
    }
    out = out + "\n";

    // Data rows
    ri = 0;
    while ri < result.rows.count() {
        var row = result.rows.get(ri);
        ci = 0;
        while ci < row.count() {
            if ci > 0 { out = out + " | "; }
            var w = 0;
            if ci < widths.count() { w = widths.get(ci); }
            out = out + padRight(row.get(ci), w);
            ci = ci + 1;
        }
        out = out + "\n";
        ri = ri + 1;
    }

    // Row count
    var rowCount = result.rows.count();
    out = out + "(" + Fmt.Int(rowCount) + " row";
    if rowCount != 1 { out = out + "s"; }
    out = out + ")";

    return out;
}

func formatExpanded(result: PgQueryResult) -> String {
    if result.columns.count() == 0 {
        return result.commandTag;
    }

    var out = "";
    var ri = 0;
    while ri < result.rows.count() {
        out = out + "-[ RECORD " + Fmt.Int(ri + 1) + " ]";
        var dashes = 40;
        var di = 0;
        while di < dashes { out = out + "-"; di = di + 1; }
        out = out + "\n";

        var row = result.rows.get(ri);
        var ci = 0;
        while ci < result.columns.count() && ci < row.count() {
            out = out + result.columns.get(ci) + " | " + row.get(ci) + "\n";
            ci = ci + 1;
        }
        ri = ri + 1;
    }

    return out;
}

func padRight(s: String, width: Integer) -> String {
    var result = s;
    var len = String.Length(s);
    while len < width {
        result = result + " ";
        len = len + 1;
    }
    return result;
}

func repeatChar(ch: String, count: Integer) -> String {
    var result = "";
    var i = 0;
    while i < count {
        result = result + ch;
        i = i + 1;
    }
    return result;
}

//=============================================================================
// META-COMMANDS
//=============================================================================

// Returns true if command was handled, false if not a meta-command
func handleMetaCommand(cmd: String, conn: PgConnection, config: ClientConfig) -> Boolean {
    var lower = String.ToLower(String.Trim(cmd));

    if lower == "\\q" || lower == "\\quit" {
        conn.disconnect();
        Terminal.Say("Goodbye!");
        return true;
    }

    if lower == "\\?" || lower == "\\help" {
        Terminal.Say("");
        Terminal.Say("Meta-commands:");
        Terminal.Say("  \\q              Quit");
        Terminal.Say("  \\? or \\help     Show this help");
        Terminal.Say("  \\dt             List tables");
        Terminal.Say("  \\d TABLE        Describe table");
        Terminal.Say("  \\l              List databases");
        Terminal.Say("  \\c DBNAME       Switch database");
        Terminal.Say("  \\i FILE         Execute SQL from file");
        Terminal.Say("  \\timing         Toggle query timing");
        Terminal.Say("  \\x              Toggle expanded display");
        Terminal.Say("");
        return false;
    }

    if lower == "\\dt" {
        var result = conn.query("SHOW TABLES");
        if result.success {
            Terminal.Say(formatAligned(result));
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }
        Terminal.Say("");
        return false;
    }

    if String.StartsWith(lower, "\\d ") {
        var tableName = String.Trim(String.Substring(cmd, 3, String.Length(cmd) - 3));
        var result = conn.query("DESCRIBE " + tableName);
        if result.success {
            Terminal.Say(formatAligned(result));
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }
        Terminal.Say("");
        return false;
    }

    if lower == "\\l" {
        var result = conn.query("SHOW DATABASES");
        if result.success {
            Terminal.Say(formatAligned(result));
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }
        Terminal.Say("");
        return false;
    }

    if String.StartsWith(lower, "\\c ") {
        var dbName = String.Trim(String.Substring(cmd, 3, String.Length(cmd) - 3));
        var result = conn.query("USE " + dbName);
        if result.success {
            config.database = dbName;
            Terminal.Say("You are now connected to database \"" + dbName + "\"");
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }
        Terminal.Say("");
        return false;
    }

    if String.StartsWith(lower, "\\i ") {
        var filePath = String.Trim(String.Substring(cmd, 3, String.Length(cmd) - 3));
        if File.Exists(filePath) == false {
            Terminal.Say("ERROR: File not found: " + filePath);
            Terminal.Say("");
            return false;
        }
        var sql = File.ReadAllText(filePath);
        Terminal.Say("Executing " + filePath + "...");
        var result = conn.query(sql);
        if result.success {
            if result.columns.count() > 0 {
                Terminal.Say(formatAligned(result));
            } else {
                Terminal.Say(result.commandTag);
            }
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }
        Terminal.Say("");
        return false;
    }

    if lower == "\\timing" {
        config.timing = !config.timing;
        if config.timing {
            Terminal.Say("Timing is on.");
        } else {
            Terminal.Say("Timing is off.");
        }
        return false;
    }

    if lower == "\\x" {
        config.expanded = !config.expanded;
        if config.expanded {
            Terminal.Say("Expanded display is on.");
        } else {
            Terminal.Say("Expanded display is off.");
        }
        return false;
    }

    Terminal.Say("Unknown command: " + cmd);
    Terminal.Say("Type \\? for help.");
    Terminal.Say("");
    return false;
}

//=============================================================================
// INTERACTIVE REPL
//=============================================================================

func runInteractive(config: ClientConfig) {
    Terminal.Say("vsql v" + VERSION + " (ViperSQL interactive client)");

    // Connect
    var conn = new PgConnection();
    conn.init();
    conn.host = config.host;
    conn.port = config.port;
    conn.user = config.user;
    conn.database = config.database;

    Terminal.Say("Connecting to " + config.host + ":" + Fmt.Int(config.port) + " as " + config.user + "...");

    var ok = conn.connect(config.password);
    if ok == false {
        Terminal.Say("ERROR: " + conn.lastError);
        return;
    }

    Terminal.Say("Connected to database \"" + config.database + "\"");
    Terminal.Say("Type \\? for help, \\q to quit.");
    Terminal.Say("");

    var running = true;
    var buffer = "";
    var inMultiline = false;

    while running {
        // Prompt shows database name
        if inMultiline {
            Terminal.Print(config.database + "-> ");
        } else {
            Terminal.Print(config.database + "=> ");
        }

        var rawInput = Terminal.ReadLine();
        if rawInput == null {
            running = false;
            continue;
        }
        var input = rawInput!;

        // Empty line
        if input == "" && inMultiline == false {
            continue;
        }

        // Meta-commands (only at start of input, not in multi-line)
        var trimmed = String.Trim(input);
        if inMultiline == false && String.StartsWith(trimmed, "\\") {
            var shouldQuit = handleMetaCommand(trimmed, conn, config);
            if shouldQuit {
                running = false;
            }
            continue;
        }

        // Accumulate multi-line input
        if inMultiline {
            buffer = buffer + " " + input;
        } else {
            buffer = input;
        }

        // Check if query is complete (ends with semicolon)
        var trimBuf = String.Trim(buffer);
        if String.EndsWith(trimBuf, ";") == false {
            inMultiline = true;
            continue;
        }

        // Execute the complete query
        inMultiline = false;

        var startTime = DateTime.NowMs();
        var result = conn.query(trimBuf);
        var elapsed = DateTime.NowMs() - startTime;

        if result.success {
            if result.columns.count() > 0 {
                if config.expanded {
                    Terminal.Say(formatExpanded(result));
                } else {
                    Terminal.Say(formatAligned(result));
                }
            } else {
                Terminal.Say(result.commandTag);
            }
        } else {
            Terminal.Say("ERROR: " + result.errorMessage);
        }

        if config.timing {
            Terminal.Say("Time: " + Fmt.Int(elapsed) + " ms");
        }

        Terminal.Say("");
        buffer = "";
    }

    conn.disconnect();
}

//=============================================================================
// ENTRY POINT
//=============================================================================

func start() {
    var config = parseArgs();
    runInteractive(config);
}
