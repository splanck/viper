// =============================================================================
// stmt.zia — Statement-level AST classes (one per SQL statement kind)
// Part of ViperSQL  (package: parser)
// =============================================================================
//
// PURPOSE
// -------
// While `expr.zia` captures the *expression* shape of a SQL tree, this
// file captures the *statement* shape: the whole `SELECT`, `INSERT`,
// `UPDATE`, `DELETE`, `CREATE TABLE`, `CREATE INDEX`, `CREATE TRIGGER`,
// `MERGE`, and `DROP INDEX` objects the parser hands to the executor.
// Each statement kind gets its own class with the precise fields the
// grammar can produce — no `kind`-tagged union here, because the
// executor has a dedicated handler per class and a class hierarchy
// reads better than a 12-way tag at the top-level dispatch.
//
// The file also hosts a small pile of constants that are semantically
// shared between parser, trigger manager, and join planner:
//   * `STMT_*` — dispatch codes for the old union-style dispatch path.
//                Mostly historical; the executor prefers type-based
//                dispatch today.
//   * `TRIGGER_BEFORE`/`TRIGGER_AFTER` and
//     `TRIGGER_INSERT`/`TRIGGER_UPDATE`/`TRIGGER_DELETE` — the
//     timing/event codes used by `engine/triggers.zia`.  Defined here
//     because the parser emits them and the trigger manager consumes
//     them.
//   * `JOIN_*` — join-type codes used on `SelectStmt.joinTypes`.
//
// WHERE THIS FITS
// ---------------
//     parser/parser.zia   ──►  builds these statement AST objects
//         │
//         ▼
//     parser/stmt.zia    (YOU ARE HERE)
//         │
//         ▼
//     engine/executor.zia    ──►  dispatches on class & runs the
//                                 appropriate handler
//
// KEY DESIGN CHOICES
// ------------------
//   1. One class per statement kind.  Avoids `if stmt.kind == X { … }`
//      dispatch ladders in the executor.  Each class's field list is
//      precisely what its handler needs — no unused baggage.
//
//   2. Parallel-list idiom for compound clauses.  `SelectStmt` keeps
//      `tableNames` alongside `tableAliases` / `joinTypes` /
//      `joinConditions` / `lateralSubquerySQL` / `joinNatural` /
//      `joinUsingCols` — six lists, indexed in lockstep.  This makes
//      add/remove cheap and lets the parser grow the FROM clause
//      incrementally.
//
//   3. Subqueries are stored as raw SQL text.  Same rationale as in
//      `expr.zia`: avoids a cycle between parser and stmt modules,
//      and re-parse cost is minor.
//
//   4. Sentinel values.  `limitValue = -1` means "no LIMIT".
//      `offsetValue = 0` means "no OFFSET".  `tablesamplePercent =
//      -1` means "no TABLESAMPLE".  These live in the class defaults
//      so the executor can check `if lim >= 0 { apply LIMIT }`
//      without needing a separate `hasLimit` flag.
//
//   5. The `STMT_*` codes in this file are only used by the old
//      dispatch path; newer statement kinds (MERGE, CREATE INDEX,
//      CREATE TRIGGER, etc.) do not define one because their
//      dispatch is purely class-based now.  Leave them alone —
//      removing the old codes would ripple into `engine/executor.zia`
//      for no real benefit.
//
// HOW TO READ THIS FILE
// ---------------------
// Read the classes in dispatch order:
//   1. CreateTableStmt  — the richest DDL statement
//   2. InsertStmt       — VALUES, INSERT..SELECT, RETURNING,
//                          ON CONFLICT
//   3. SelectStmt       — the monster; joins, CTE-friendly sub-fields,
//                          windows, DISTINCT, GROUP BY, LIMIT
//   4. UpdateStmt, DeleteStmt  — simpler DML
//   5. MergeStmt        — Phase 73
//   6. CreateIndexStmt, DropIndexStmt
//   7. CreateTriggerStmt
//
// Each class's `toString` is a debugging helper; it does not attempt
// round-trippable SQL rendering — EXPLAIN and SHOW CREATE use
// dedicated renderers.
//
// =============================================================================

module stmt;

bind "../engine/types";
bind "../engine/schema";
bind "./expr";

//=============================================================================
// STATEMENT KIND CODES (legacy dispatch path)
//=============================================================================

final STMT_CREATE_TABLE = 1;
final STMT_INSERT = 2;
final STMT_SELECT = 3;
final STMT_UPDATE = 4;
final STMT_DELETE = 5;
final STMT_DROP_TABLE = 6;

//=============================================================================
// TRIGGER TIMING / EVENT CODES
//=============================================================================

// Shared between the parser (which builds CreateTriggerStmt), the
// trigger manager (which stores them in a `Trigger` object), and the
// executor (which fires them).  See `engine/triggers.zia` for the
// consumer side.
final TRIGGER_BEFORE = 1;
final TRIGGER_AFTER = 2;

final TRIGGER_INSERT = 1;
final TRIGGER_UPDATE = 2;
final TRIGGER_DELETE = 3;

//=============================================================================
// CREATE TABLE
//=============================================================================

/// @brief The AST for `CREATE TABLE`.
///
/// Covers plain tables, `TEMPORARY`, `IF NOT EXISTS`, partitioning
/// (RANGE / LIST / HASH), `PARTITION OF parent`, table inheritance,
/// composite PRIMARY KEY, and named table-level CHECK constraints.
/// Column-level constraints live on each `Column` itself (see
/// `engine/schema.zia`).
class CreateTableStmt {
    expose String tableName;
    expose List[Column] columns;
    expose Boolean isTemporary;
    // Partition support (Phase 28) — parent-table fields.
    expose Integer partitionType;         // PARTITION_NONE/RANGE/LIST/HASH
    expose String partitionColumn;
    // PARTITION OF (child creation).
    expose Boolean isPartitionOf;
    expose String partitionParentName;
    expose String partRangeFrom;          // RANGE bound lower
    expose String partRangeTo;            // RANGE bound upper
    expose List[String] partListValues;   // LIST allowed values
    expose Integer partHashModulus;       // HASH total partitions
    expose Integer partHashRemainder;     // HASH remainder for this child
    // Inheritance (Phase 52).
    expose Boolean isInherits;
    expose String inheritsParentName;
    // Phase 65: CREATE TABLE IF NOT EXISTS.
    expose Boolean ifNotExists;
    // Phase 68: composite PRIMARY KEY (PRIMARY KEY (a, b)) and
    // table-level CHECK constraints with optional names.
    expose List[String] compositePkColumns;
    expose List[String] tableCheckConstraints;
    expose List[String] tableCheckNames;

    /// @brief Zero-state init.
    expose func init() {
        tableName = "";
        columns = [];
        isTemporary = false;
        partitionType = 0;
        partitionColumn = "";
        isPartitionOf = false;
        partitionParentName = "";
        partRangeFrom = "";
        partRangeTo = "";
        partListValues = [];
        partHashModulus = 0;
        partHashRemainder = 0;
        isInherits = false;
        inheritsParentName = "";
        ifNotExists = false;
        compositePkColumns = [];
        tableCheckConstraints = [];
        tableCheckNames = [];
    }

    /// @brief Append a column definition.  Called once per column in
    ///        the DDL source.
    expose func addColumn(col: Column) {
        columns.add(col);
    }

    /// @brief Positional column access.  Unchecked — callers have
    ///        validated indices via `columnCount()` first.
    expose func getColumn(index: Integer) -> Column {
        return columns.get(index);
    }

    /// @brief Number of columns in the DDL.
    expose func columnCount() -> Integer {
        return columns.count();
    }

    /// @brief Debug renderer — approximately SQL form, suitable for
    ///        log output and EXPLAIN.
    expose func toString() -> String {
        var result = "CREATE TABLE " + tableName + " (\n";
        var i = 0;
        while i < columns.count() {
            if i > 0 {
                result = result + ",\n";
            }
            result = result + "  " + columns.get(i).toString();
            i = i + 1;
        }
        result = result + "\n);";
        return result;
    }
}

//=============================================================================
// INSERT
//=============================================================================

/// @brief The AST for `INSERT INTO ... VALUES (...)` and its
///        variants: `INSERT ... SELECT`, `RETURNING`, `ON CONFLICT
///        DO UPDATE / DO NOTHING`, and `DEFAULT VALUES`.
///
/// `valueRows` is a list-of-lists: outer index = row, inner index =
/// column position.  `INSERT INTO t VALUES (1,'a'),(2,'b')` produces
/// two rows with two expressions each.
class InsertStmt {
    expose String tableName;
    expose List[String] columnNames;          // optional column list
    expose List[List[Expr]] valueRows;        // VALUES rows
    expose String selectSQL;                  // INSERT..SELECT source
    expose Boolean hasSelect;                 // chooses VALUES vs SELECT
    // RETURNING.
    expose List[Expr] returningExprs;
    expose List[String] returningAliases;
    expose Boolean hasReturning;
    // ON CONFLICT (upsert).  Either DO NOTHING or DO UPDATE SET …
    expose List[String] conflictColumns;
    expose Boolean hasOnConflict;
    expose Boolean onConflictDoNothing;
    expose List[String] onConflictSetColumns;
    expose List[Expr] onConflictSetValues;
    // INSERT … DEFAULT VALUES.
    expose Boolean hasDefaultValues;

    /// @brief Zero-state init.
    expose func init() {
        tableName = "";
        columnNames = [];
        valueRows = [];
        selectSQL = "";
        hasSelect = false;
        returningExprs = [];
        returningAliases = [];
        hasReturning = false;
        conflictColumns = [];
        hasOnConflict = false;
        onConflictDoNothing = false;
        onConflictSetColumns = [];
        onConflictSetValues = [];
        hasDefaultValues = false;
    }

    /// @brief Add one column name to the optional `(col1, col2, …)`
    ///        list.
    expose func addColumnName(name: String) {
        columnNames.add(name);
    }

    /// @brief Start a new VALUES row.  Append subsequent expressions
    ///        via `addValue(rowIndex, val)`.
    expose func addValueRow() {
        var row: List[Expr] = [];
        valueRows.add(row);
    }

    /// @brief Append an expression into a particular VALUES row.
    expose func addValue(rowIndex: Integer, val: Expr) {
        valueRows.get(rowIndex).add(val);
    }

    /// @brief Number of VALUES rows — matches how many rows the
    ///        INSERT will produce before RETURNING.
    expose func rowCount() -> Integer {
        return valueRows.count();
    }

    /// @brief Debug renderer — approximately SQL for log output.
    expose func toString() -> String {
        var result = "INSERT INTO " + tableName;
        if columnNames.count() > 0 {
            result = result + " (";
            var i = 0;
            while i < columnNames.count() {
                if i > 0 {
                    result = result + ", ";
                }
                result = result + columnNames.get(i);
                i = i + 1;
            }
            result = result + ")";
        }
        result = result + " VALUES ";
        var r = 0;
        while r < valueRows.count() {
            if r > 0 {
                result = result + ", ";
            }
            result = result + "(";
            var row = valueRows.get(r);
            var v = 0;
            while v < row.count() {
                if v > 0 {
                    result = result + ", ";
                }
                result = result + row.get(v).toString();
                v = v + 1;
            }
            result = result + ")";
            r = r + 1;
        }
        result = result + ";";
        return result;
    }
}

//=============================================================================
// SELECT
//=============================================================================

/// @brief Join type codes used by `SelectStmt.joinTypes`.
///
/// Matched against the PG wire protocol's join-kind enum so the
/// executor can re-render explain output in PG form.  Values are
/// in the same numeric order as PG's internal JOIN_* enum to make
/// future compatibility trivial.
final JOIN_CROSS = 0;
final JOIN_INNER = 1;
final JOIN_LEFT = 2;
final JOIN_RIGHT = 3;
final JOIN_FULL = 4;

/// @brief The largest statement AST.  Models the whole SELECT grammar
///        ViperSQL supports: joins (INNER / LEFT / RIGHT / FULL /
///        CROSS / LATERAL / NATURAL / USING), DISTINCT (and DISTINCT
///        ON), WHERE, GROUP BY + GROUPING SETS / ROLLUP / CUBE,
///        HAVING, ORDER BY (with NULLS FIRST/LAST), LIMIT / OFFSET /
///        FETCH, window functions (with named WINDOW definitions),
///        derived tables, table functions, FOR SHARE/UPDATE locking,
///        TABLESAMPLE, SELECT INTO, and inherited-only (ONLY parent)
///        scans.
///
/// Most fields are parallel-list structures indexed by join or
/// ORDER BY position — see design choice 2.
class SelectStmt {
    // Projection.
    expose List[Expr] columns;                 // the SELECT list
    expose List[String] columnAliases;         // AS aliases per column
    // FROM: `tableName`/`tableAlias` are the legacy single-table
    // fields; modern code uses the `tableNames`/`tableAliases`
    // parallel lists (which always include at least the FROM table).
    expose String tableName;
    expose String tableAlias;
    expose List[String] tableNames;
    expose List[String] tableAliases;
    // JOINs — same indexing as `tableNames[1..]`.  Index i refers to
    // "joining tableNames[i+1] to the accumulated result".
    expose List[Integer] joinTypes;
    expose List[Expr] joinConditions;
    expose Expr? whereClause;
    expose Boolean selectAll;                  // `SELECT *`
    expose Boolean isDistinct;                 // `SELECT DISTINCT`
    // ORDER BY — three parallel lists.
    expose List[Expr] orderByExprs;
    expose List[Integer] orderByDir;           // 0=ASC, 1=DESC
    expose List[Integer] orderByNulls;         // 0=default, 1=NULLS FIRST, 2=NULLS LAST
    expose Integer limitValue;                 // -1 = no limit
    expose Integer offsetValue;                // 0 = no offset
    expose List[Expr] groupByExprs;
    expose Expr? havingClause;
    // Derived table: `FROM (SELECT ...) AS alias`.
    expose String derivedTableSQL;
    expose String derivedTableAlias;
    expose Boolean hasDerivedTable;
    // Row-level locking (Phase 14).
    expose Integer lockMode;                   // 0=none, 1=FOR SHARE, 2=FOR UPDATE
    expose Boolean lockNowait;
    expose Boolean lockSkipLocked;
    // Table functions (Phase 29) — SELECT * FROM generate_series(1,5).
    expose Boolean hasTableFunction;
    expose List[Expr] tableFunctionArgs;
    // Table inheritance (Phase 52) — `FROM ONLY parent`.
    expose Boolean onlyFlag;
    // LATERAL joins (Phase 55) — a per-join SQL-text column; non-empty
    // means the corresponding join right-hand side is a LATERAL
    // subquery.
    expose List[String] lateralSubquerySQL;
    // NATURAL JOIN / USING (Phase 56) — parallel to joinTypes.
    expose List[Integer] joinNatural;
    expose List[String] joinUsingCols;
    // DISTINCT ON (Phase 60).
    expose List[Expr] distinctOnExprs;
    // GROUPING SETS / ROLLUP / CUBE (Phase 59) — each entry is a
    // comma-separated list of `groupByExprs` indices describing one
    // grouping set.  Empty string = grand total ().
    expose List[String] groupingSets;
    // Phase 69: LIMIT n PERCENT and SELECT INTO <tbl>.
    expose Boolean isLimitPercent;
    expose String selectIntoTable;
    // Phase 70: TABLESAMPLE n PERCENT.
    expose Integer tablesamplePercent;         // -1 = no sampling
    // Phase 75: named WINDOW definitions.
    expose List[String] windowDefNames;
    expose List[Expr] windowDefExprs;

    /// @brief Zero-state init.
    expose func init() {
        columns = [];
        columnAliases = [];
        tableName = "";
        tableAlias = "";
        tableNames = [];
        tableAliases = [];
        joinTypes = [];
        joinConditions = [];
        whereClause = null;
        selectAll = false;
        isDistinct = false;
        orderByExprs = [];
        orderByDir = [];
        orderByNulls = [];
        limitValue = -1;
        offsetValue = 0;
        groupByExprs = [];
        havingClause = null;
        derivedTableSQL = "";
        derivedTableAlias = "";
        hasDerivedTable = false;
        lockMode = 0;
        lockNowait = false;
        lockSkipLocked = false;
        hasTableFunction = false;
        tableFunctionArgs = [];
        onlyFlag = false;
        lateralSubquerySQL = [];
        joinNatural = [];
        joinUsingCols = [];
        distinctOnExprs = [];
        groupingSets = [];
        isLimitPercent = false;
        selectIntoTable = "";
        tablesamplePercent = -1;
        windowDefNames = [];
        windowDefExprs = [];
    }

    /// @brief Add a table to the FROM list without a join.  First
    ///        call is typically the base FROM table.
    expose func addTable(name: String, alias: String) {
        tableNames.add(name);
        tableAliases.add(alias);
    }

    /// @brief Add a join to an existing FROM list.
    ///
    /// `condition` is an optional `ON <expr>`; CROSS joins pass null.
    /// We only append to `joinConditions` when a condition was given,
    /// which means the condition list may be *shorter* than the join
    /// list — callers indexing into it must handle the missing-cond
    /// case (executor treats it as "always true" for CROSS).
    expose func addJoin(name: String, alias: String, joinType: Integer, condition: Expr?) {
        tableNames.add(name);
        tableAliases.add(alias);
        joinTypes.add(joinType);
        if condition != null {
            joinConditions.add(condition);
        }
    }

    /// @brief Add one GROUP BY expression.
    expose func addGroupBy(expr: Expr) {
        groupByExprs.add(expr);
    }

    /// @brief Add an unaliased projection column.
    expose func addColumn(col: Expr) {
        columns.add(col);
        columnAliases.add("");
    }

    /// @brief Add an aliased projection column (`expr AS alias`).
    expose func addColumnWithAlias(col: Expr, alias: String) {
        columns.add(col);
        columnAliases.add(alias);
    }

    /// @brief Add one ORDER BY key with direction.  `isDesc` is 0
    ///        for ASC, 1 for DESC.  Defaults NULLS handling to 0
    ///        (engine-default: NULLS LAST for ASC, NULLS FIRST for
    ///        DESC, matching PG).
    expose func addOrderBy(expr: Expr, isDesc: Integer) {
        orderByExprs.add(expr);
        orderByDir.add(isDesc);
        orderByNulls.add(0);
    }

    /// @brief Add one ORDER BY key with direction AND explicit
    ///        NULLS handling.  `nullsMode`: 1 = NULLS FIRST,
    ///        2 = NULLS LAST.
    expose func addOrderByWithNulls(expr: Expr, isDesc: Integer, nullsMode: Integer) {
        orderByExprs.add(expr);
        orderByDir.add(isDesc);
        orderByNulls.add(nullsMode);
    }

    /// @brief Debug renderer — very short, does not recover clauses.
    ///        Actual round-trippable SQL rendering lives in
    ///        `engine/executor.zia` for EXPLAIN.
    expose func toString() -> String {
        var result = "SELECT ";
        if selectAll == true {
            result = result + "* FROM " + tableName;
        } else {
            result = result + "... FROM " + tableName;
        }
        return result + ";";
    }
}

//=============================================================================
// UPDATE
//=============================================================================

/// @brief `UPDATE <tbl> SET … [FROM other] [WHERE …] [RETURNING …]`.
///
/// `setColumns` / `setValues` are parallel lists — index i is one
/// `col = val` assignment.  FROM-join (PG extension) lets you
/// correlate the target with another table without a subquery;
/// `hasFrom` gates that code path in the executor.
class UpdateStmt {
    expose String tableName;
    expose List[String] setColumns;
    expose List[Expr] setValues;
    expose Expr? whereClause;
    // PG-extension: UPDATE … FROM other.
    expose String fromTableName;
    expose String fromTableAlias;
    expose Boolean hasFrom;
    // RETURNING.
    expose List[Expr] returningExprs;
    expose List[String] returningAliases;
    expose Boolean hasReturning;

    /// @brief Zero-state init.
    expose func init() {
        tableName = "";
        setColumns = [];
        setValues = [];
        whereClause = null;
        fromTableName = "";
        fromTableAlias = "";
        hasFrom = false;
        returningExprs = [];
        returningAliases = [];
        hasReturning = false;
    }

    /// @brief Add one `col = val` assignment.
    expose func addSet(colName: String, val: Expr) {
        setColumns.add(colName);
        setValues.add(val);
    }

    /// @brief Debug renderer.
    expose func toString() -> String {
        var result = "UPDATE " + tableName + " SET ";
        var i = 0;
        while i < setColumns.count() {
            if i > 0 {
                result = result + ", ";
            }
            result = result + setColumns.get(i) + " = ";
            result = result + setValues.get(i).toString();
            i = i + 1;
        }
        if whereClause != null {
            result = result + " WHERE ...";
        }
        return result + ";";
    }
}

//=============================================================================
// DELETE
//=============================================================================

/// @brief `DELETE FROM <tbl> [USING other] [WHERE …] [RETURNING …]`.
///
/// `USING` is the PG-extension symmetric to UPDATE…FROM.
class DeleteStmt {
    expose String tableName;
    expose Expr? whereClause;
    // PG-extension: DELETE … USING other.
    expose String usingTableName;
    expose String usingTableAlias;
    expose Boolean hasUsing;
    // RETURNING.
    expose List[Expr] returningExprs;
    expose List[String] returningAliases;
    expose Boolean hasReturning;

    /// @brief Zero-state init.
    expose func init() {
        tableName = "";
        whereClause = null;
        usingTableName = "";
        usingTableAlias = "";
        hasUsing = false;
        returningExprs = [];
        returningAliases = [];
        hasReturning = false;
    }

    /// @brief Debug renderer.
    expose func toString() -> String {
        var result = "DELETE FROM " + tableName;
        if whereClause != null {
            result = result + " WHERE ...";
        }
        return result + ";";
    }
}

//=============================================================================
// MERGE (Phase 73)
//=============================================================================

/// @brief `MERGE INTO target USING source ON cond WHEN MATCHED ...
///        WHEN NOT MATCHED ...` — the SQL-standard upsert operation.
///
/// Supports exactly one WHEN MATCHED arm (UPDATE or DELETE) and one
/// WHEN NOT MATCHED arm (INSERT).  The full SQL-2003 grammar allows
/// multiple arms with additional conditions; we do not.
class MergeStmt {
    expose String targetTable;
    expose String targetAlias;
    expose String sourceTable;
    expose String sourceAlias;
    expose Expr? onCondition;
    // WHEN MATCHED — only one arm, either UPDATE (setColumns/values)
    // or DELETE (whenMatchedIsDelete = true).
    expose Boolean hasWhenMatched;
    expose Boolean whenMatchedIsDelete;
    expose List[String] updateColumns;
    expose List[Expr] updateValues;
    // WHEN NOT MATCHED — a single INSERT arm.
    expose Boolean hasWhenNotMatched;
    expose List[String] insertColumns;
    expose List[Expr] insertValues;

    /// @brief Zero-state init.
    expose func init() {
        targetTable = "";
        targetAlias = "";
        sourceTable = "";
        sourceAlias = "";
        onCondition = null;
        hasWhenMatched = false;
        whenMatchedIsDelete = false;
        updateColumns = [];
        updateValues = [];
        hasWhenNotMatched = false;
        insertColumns = [];
        insertValues = [];
    }
}

//=============================================================================
// CREATE INDEX
//=============================================================================

/// @brief `CREATE [UNIQUE] INDEX [IF NOT EXISTS] <name> ON <tbl>
///        (<cols>) [WHERE <expr>]`.
///
/// `isExpression` flips the index from column-based to expression-
/// based.  In that mode `expressionSQL` carries the raw expression
/// text and `expressionFuncName` / `expressionColumnName` pre-split
/// the simple `FUNC(col)` case for fast lookup by the planner.
class CreateIndexStmt {
    expose String indexName;
    expose String tableName;
    expose List[String] columnNames;
    expose Boolean isUnique;
    expose Boolean ifNotExists;       // Phase 65
    expose Expr? whereClause;         // Phase 74 partial index
    expose Boolean isExpression;
    expose String expressionSQL;
    expose String expressionFuncName;
    expose String expressionColumnName;

    /// @brief Zero-state init.
    expose func init() {
        indexName = "";
        tableName = "";
        columnNames = [];
        isUnique = false;
        ifNotExists = false;
        whereClause = null;
        isExpression = false;
        expressionSQL = "";
        expressionFuncName = "";
        expressionColumnName = "";
    }

    /// @brief Append one indexed column name.
    expose func addColumn(colName: String) {
        columnNames.add(colName);
    }

    /// @brief Number of indexed columns.
    expose func columnCount() -> Integer {
        return columnNames.count();
    }

    /// @brief Debug renderer.
    expose func toString() -> String {
        var result = "";
        if isUnique {
            result = "UNIQUE ";
        }
        result = result + "CREATE INDEX " + indexName + " ON " + tableName + " (";
        var i = 0;
        while i < columnNames.count() {
            if i > 0 {
                result = result + ", ";
            }
            result = result + columnNames.get(i);
            i = i + 1;
        }
        result = result + ");";
        return result;
    }
}

//=============================================================================
// DROP INDEX
//=============================================================================

/// @brief `DROP INDEX <name>`.  No IF EXISTS yet in this AST — if
///        the underlying storage reports "no such index", the DDL
///        executor reports the error verbatim.
class DropIndexStmt {
    expose String indexName;

    /// @brief Zero-state init.
    expose func init() {
        indexName = "";
    }

    /// @brief Debug renderer.
    expose func toString() -> String {
        return "DROP INDEX " + indexName + ";";
    }
}

//=============================================================================
// CREATE TRIGGER (Phase 17)
//=============================================================================

/// @brief `CREATE TRIGGER <name> BEFORE|AFTER INSERT|UPDATE|DELETE
///        ON <tbl> [FOR EACH ROW] EXECUTE <body>`.
///
/// Timing / event use the module-level `TRIGGER_*` codes.  `bodySQL`
/// is stored raw; re-parsed on each fire — see `engine/triggers.zia`
/// for the reasoning.
class CreateTriggerStmt {
    expose String triggerName;
    expose Integer timing;
    expose Integer event;
    expose String tableName;
    expose Boolean forEachRow;
    expose String bodySQL;

    /// @brief Zero-state init: a FOR EACH ROW BEFORE INSERT stub.
    expose func init() {
        triggerName = "";
        timing = TRIGGER_BEFORE;
        event = TRIGGER_INSERT;
        tableName = "";
        forEachRow = true;
        bodySQL = "";
    }

    /// @brief "BEFORE" / "AFTER" for debug rendering.
    expose func timingName() -> String {
        if timing == TRIGGER_BEFORE { return "BEFORE"; }
        return "AFTER";
    }

    /// @brief "INSERT" / "UPDATE" / "DELETE" for debug rendering.
    expose func eventName() -> String {
        if event == TRIGGER_INSERT { return "INSERT"; }
        if event == TRIGGER_UPDATE { return "UPDATE"; }
        return "DELETE";
    }

    /// @brief Debug renderer.
    expose func toString() -> String {
        var result = "CREATE TRIGGER " + triggerName + " " + timingName() + " " + eventName();
        result = result + " ON " + tableName;
        if forEachRow {
            result = result + " FOR EACH ROW";
        }
        result = result + " EXECUTE " + bodySQL;
        return result;
    }
}
