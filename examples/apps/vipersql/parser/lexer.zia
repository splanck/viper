// =============================================================================
// lexer.zia — Turn raw SQL text into a stream of `Token`s
// Part of ViperSQL  (package: parser)
// =============================================================================
//
// PURPOSE
// -------
// The lexer (also called "scanner" or "tokenizer") is the first pass of
// the parser pipeline.  It consumes SQL source one character at a time
// and emits `Token` objects whose `kind` is one of the `TK_*` constants
// defined in `./token`.  The parser proper (`./parser.zia`) never
// inspects raw characters — it only ever deals with tokens, which
// dramatically shortens every grammar rule.
//
// Responsibilities:
//   * Skip whitespace and comments (`--` to end-of-line, `/* ... */`
//     block).
//   * Recognise numbers (INTEGER and REAL).
//   * Recognise identifiers and keywords.  Case-insensitive: we
//     uppercase the word before checking the keyword table.
//   * Recognise quoted strings with both escape styles: SQL-standard
//     `''` doubled-quote and C-style `\'` backslash.
//   * Recognise operators including the two-character forms
//     (`<=`, `>=`, `<>`, `!=`, `||`, `~*`, `->`, `->>`).
//   * Track `(line, column)` so error messages are useful.
//
// WHERE THIS FITS
// ---------------
//     ./token.zia       ──►  TK_* constants, Token class (annotated)
//         │
//         ▼
//     ./lexer.zia       ──►  YOU ARE HERE — char stream → token stream
//         │
//         ▼
//     ./parser.zia      ──►  token stream → AST
//         │
//         ▼
//     engine/executor.zia
//
// KEY DESIGN CHOICES
// ------------------
//   1. One-character-at-a-time design.  The lexer works by `peek()`,
//      `peekNext()`, `advance()` rather than regex.  That keeps it
//      dependency-free (the "zero dependencies" rule from CLAUDE.md)
//      and predictable on multi-byte boundaries — we never split a
//      grapheme mid-byte because every keyword and operator is ASCII.
//
//   2. Keywords are resolved by a long linear `if` chain in
//      `lookupKeyword`.  A hash-map lookup would be nicer aesthetically
//      but `String == String` is already cheap in Zia's runtime and
//      the cost difference is lost in the noise of the parser proper.
//      The `if` style also makes adding a new keyword a two-line
//      change instead of a map mutation.
//
//   3. Two-character operators are detected by "advance, peek".  The
//      dispatch for `-` is the trickiest case — we need to
//      distinguish `-` (minus), `--` (comment, handled by
//      `skipWhitespace`), `->` (JSON arrow), and `->>` (JSON text
//      arrow).  Order matters: the comment is consumed *before* we
//      reach the operator dispatch.
//
//   4. Unterminated strings return a `TK_ERROR` token rather than
//      trapping.  The parser sees `TK_ERROR`, produces a diagnostic,
//      and the caller gets a failed `QueryResult` instead of an
//      unexpected crash.  BUG-ADV-003 in the code comments refers to
//      an older regression where the lexer would loop on unterminated
//      strings.
//
//   5. `line`/`column` are updated *during* `advance()`, not in a
//      post-pass.  This means error tokens always know exactly where
//      they started — the `(startLine, startCol)` captured at the
//      top of each reader stays accurate through any amount of
//      internal advancement.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Fields — source text, position, line/column cursor.
//   2. Primitive char helpers: `peek`, `peekNext`, `advance`,
//      `isAtEnd`.
//   3. `skipWhitespace` — handles comments too.
//   4. Character-class predicates: `isDigit`, `isAlpha`, `isAlphaNum`.
//   5. Sub-readers: `readNumber`, `readString`, `readIdentifier`.
//   6. `lookupKeyword` — the big keyword table.
//   7. `nextToken` — the public dispatch that stitches everything
//      together.
//
// =============================================================================

module lexer;

bind Viper.String as String;
bind Viper.Text.StringBuilder as SB;
bind "./token";

//=============================================================================
// LEXER
//=============================================================================

/// @brief State machine that converts SQL text into tokens.
///
/// Hold a lexer, call `nextToken()` in a loop until you get `TK_EOF`
/// (or a `TK_ERROR`).  The internal cursor (`pos`, `line`, `column`)
/// advances as you read — never reset or rewound.  One Lexer
/// instance per SQL statement buffer; the parser creates a fresh one
/// per `executeSql` call.
class Lexer {
    // All state is `hide` — callers never poke at raw bytes.
    hide String source;    // full SQL text
    hide Integer pos;      // byte offset into `source`
    hide Integer line;     // current line, 1-based
    hide Integer column;   // current column, 1-based
    hide Integer length;   // cached `String.Length(source)`

    /// @brief Wire up a lexer for a given SQL source string.
    ///
    /// We cache `length` because `String.Length` is O(1) for Zia
    /// strings but the inner loop still benefits from not re-reading
    /// a field.
    expose func init(src: String) {
        source = src;
        pos = 0;
        line = 1;
        column = 1;
        length = String.Length(src);
    }

    /// @brief "Have we consumed every character?" — the termination
    ///        condition of every inner loop in the lexer.
    expose func isAtEnd() -> Boolean {
        return pos >= length;
    }

    /// @brief Current char, or "" at EOF.
    ///
    /// Non-advancing.  Every reader peeks first to decide which
    /// specialised path to take, then calls `advance()` once it has
    /// committed.
    hide func peek() -> String {
        if (isAtEnd()) { return ""; }
        return String.Substring(source, pos, 1);
    }

    /// @brief Char at position+1 (one-char lookahead), or "" at EOF.
    ///
    /// Used for two-character operator detection (`<=`, `->`, `--`
    /// comment start, `/*` block start, `''` escape).
    hide func peekNext() -> String {
        if (pos + 1 >= length) { return ""; }
        return String.Substring(source, pos + 1, 1);
    }

    /// @brief Return the current char and advance the cursor.
    ///
    /// Maintains `(line, column)` — a newline resets the column and
    /// bumps the line.  This is the only method that changes `line`
    /// or `column`, which means every reader can capture
    /// `(startLine, startCol)` once at its top and then call
    /// advance/peek freely without losing position.
    hide func advance() -> String {
        var ch = peek();
        pos = pos + 1;
        if (ch == "\n") {
            line = line + 1;
            column = 1;
        } else {
            column = column + 1;
        }
        return ch;
    }

    /// @brief Skip whitespace and comments until the next "real" char.
    ///
    /// Recognises:
    ///   * ASCII whitespace (` `, `\t`, `\r`, `\n`)
    ///   * `-- ... <EOL>` single-line comments (SQL-standard)
    ///   * `/* ... */` block comments (non-nestable, PG-compatible)
    ///
    /// Loops as long as one of these matches, so consecutive
    /// comments/whitespace are all consumed in one call.  Called from
    /// `nextToken` at every dispatch step.
    hide func skipWhitespace() {
        while (!isAtEnd()) {
            var ch = peek();
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") {
                advance();
            } else if (ch == "-" && peekNext() == "-") {
                // Single-line comment: read to end-of-line.
                while (!isAtEnd() && peek() != "\n") { advance(); }
            } else if (ch == "/" && peekNext() == "*") {
                // Block comment: consume opener, then read to `*/`.
                advance(); advance();
                while (!isAtEnd()) {
                    if (peek() == "*" && peekNext() == "/") {
                        advance(); advance(); break;
                    }
                    advance();
                }
            } else {
                break;
            }
        }
    }

    /// @brief ASCII digit test.  Uses `String.Asc` for the char code.
    hide func isDigit(ch: String) -> Boolean {
        var code = String.Asc(ch);
        return code >= 48 && code <= 57;  // '0' .. '9'
    }

    /// @brief ASCII letter or underscore — identifier start char.
    ///
    /// Note the underscore branch at the end: `_foo` is a legal SQL
    /// identifier (especially common for internal columns in the
    /// pg_catalog views).
    hide func isAlpha(ch: String) -> Boolean {
        var code = String.Asc(ch);
        if (code >= 65 && code <= 90) { return true; }   // 'A'..'Z'
        if (code >= 97 && code <= 122) { return true; }  // 'a'..'z'
        return ch == "_";
    }

    /// @brief Identifier continuation char — letter, digit, or
    ///        underscore.  Used by `readIdentifier` to consume the
    ///        word body after the alpha start.
    hide func isAlphaNum(ch: String) -> Boolean {
        return isAlpha(ch) || isDigit(ch);
    }

    /// @brief Read a numeric literal starting at the current cursor.
    ///
    /// Emits `TK_INTEGER` by default.  If the digits are followed by
    /// `.<digit>`, we consume the decimal point + fractional digits
    /// and emit `TK_NUMBER` instead.  A trailing `.` with no digit
    /// behind it is *not* consumed — that is probably the `.`
    /// operator for qualified names (`schema.table`), so we leave it
    /// for the next dispatch.
    hide func readNumber() -> Token {
        var startLine = line;
        var startCol = column;
        var startPos = pos;

        while (!isAtEnd() && isDigit(peek())) { advance(); }

        if (peek() == "." && isDigit(peekNext())) {
            advance();
            while (!isAtEnd() && isDigit(peek())) { advance(); }
            var text = String.Substring(source, startPos, pos - startPos);
            var tok = new Token(TK_NUMBER, text, startLine, startCol);
            return tok;
        }

        var text = String.Substring(source, startPos, pos - startPos);
        var tok = new Token(TK_INTEGER, text, startLine, startCol);
        return tok;
    }

    /// @brief Read a quoted string literal (either `'...'` or
    ///        `"..."`).
    ///
    /// Supports both escape styles:
    ///   * SQL standard:   `''`  →  `'`   (doubled quote)
    ///   * C-style:        `\'`  →  `'`   (backslash escape)
    ///
    /// The opening quote is consumed; contents are accumulated in a
    /// `StringBuilder` (see `result.zia` rationale for why we avoid
    /// string concatenation in a hot loop).  The matching closing
    /// quote is consumed before returning.
    ///
    /// If we hit EOF without seeing the closing quote, return a
    /// `TK_ERROR` with a descriptive text — the parser turns that
    /// into a user-visible error (BUG-ADV-003 reference).
    hide func readString() -> Token {
        var startLine = line;
        var startCol = column;
        var quote = advance();
        var sb = SB.New();

        while (!isAtEnd()) {
            var ch = peek();
            if ch == quote {
                if peekNext() == quote {
                    // SQL doubled-quote escape: `''` inside `'…'`.
                    SB.Append(sb, quote);
                    advance();
                    advance();
                    continue;
                }
                break;
            }
            if ch == "\\" {
                // C-style escape: copy the next character verbatim.
                advance();
                if (!isAtEnd()) {
                    SB.Append(sb, peek());
                    advance();
                }
            } else {
                SB.Append(sb, ch);
                advance();
            }
        }

        // EOF-inside-string: report, do not crash.
        if (isAtEnd()) {
            var tok = new Token(TK_ERROR, "Unterminated string literal", startLine, startCol);
            return tok;
        }

        advance();  // consume closing quote

        var tok = new Token(TK_STRING, SB.ToString(sb), startLine, startCol);
        return tok;
    }

    /// @brief Read a word: either a keyword or an identifier.
    ///
    /// We consume alpha-num characters until the run ends, then
    /// uppercase the result and look it up in the keyword table.
    /// Unrecognised words become `TK_IDENTIFIER`, preserving the
    /// *original* (pre-uppercase) text so column names like
    /// `LastName` survive case-preserved.
    hide func readIdentifier() -> Token {
        var startLine = line;
        var startCol = column;
        var startPos = pos;

        while (!isAtEnd() && isAlphaNum(peek())) { advance(); }

        var len = pos - startPos;
        var text = String.Substring(source, startPos, len);
        var upper = String.ToUpper(text);
        var kind = lookupKeyword(upper);

        var tok = new Token(kind, text, startLine, startCol);
        return tok;
    }

    /// @brief The big keyword switch — "is this word a reserved SQL
    ///        word, and if so, which `TK_*`?"
    ///
    /// A linear series of `if word == "..."` comparisons.  Not a map
    /// on purpose — see design choice (2) in the header.  Grouped
    /// loosely by theme (DDL, DML, JOIN, etc.) for reading order; the
    /// order does *not* affect correctness since the comparisons are
    /// disjoint.
    hide func lookupKeyword(word: String) -> Integer {
        if (word == "CREATE") { return TK_CREATE; }
        if (word == "TABLE") { return TK_TABLE; }
        if (word == "DROP") { return TK_DROP; }
        if (word == "ALTER") { return TK_ALTER; }
        if (word == "INDEX") { return TK_INDEX; }
        if (word == "VIEW") { return TK_VIEW; }
        if (word == "SELECT") { return TK_SELECT; }
        if (word == "INSERT") { return TK_INSERT; }
        if (word == "UPDATE") { return TK_UPDATE; }
        if (word == "DELETE") { return TK_DELETE; }
        if (word == "INTO") { return TK_INTO; }
        if (word == "FROM") { return TK_FROM; }
        if (word == "WHERE") { return TK_WHERE; }
        if (word == "SET") { return TK_SET; }
        if (word == "VALUES") { return TK_VALUES; }
        if (word == "ORDER") { return TK_ORDER; }
        if (word == "BY") { return TK_BY; }
        if (word == "ASC") { return TK_ASC; }
        if (word == "DESC") { return TK_DESC; }
        if (word == "LIMIT") { return TK_LIMIT; }
        if (word == "OFFSET") { return TK_OFFSET; }
        if (word == "GROUP") { return TK_GROUP; }
        if (word == "HAVING") { return TK_HAVING; }
        if (word == "DISTINCT") { return TK_DISTINCT; }
        if (word == "JOIN") { return TK_JOIN; }
        if (word == "INNER") { return TK_INNER; }
        if (word == "LEFT") { return TK_LEFT; }
        if (word == "RIGHT") { return TK_RIGHT; }
        if (word == "FULL") { return TK_FULL; }
        if (word == "OUTER") { return TK_OUTER; }
        if (word == "CROSS") { return TK_CROSS; }
        if (word == "ON") { return TK_ON; }
        if (word == "AND") { return TK_AND; }
        if (word == "OR") { return TK_OR; }
        if (word == "NOT") { return TK_NOT; }
        if (word == "IN") { return TK_IN; }
        if (word == "IS") { return TK_IS; }
        if (word == "LIKE") { return TK_LIKE; }
        if (word == "BETWEEN") { return TK_BETWEEN; }
        if (word == "EXISTS") { return TK_EXISTS; }
        if (word == "NULL") { return TK_NULL; }
        if (word == "TRUE") { return TK_TRUE; }
        if (word == "FALSE") { return TK_FALSE; }
        if (word == "DEFAULT") { return TK_DEFAULT; }
        if (word == "PRIMARY") { return TK_PRIMARY; }
        if (word == "FOREIGN") { return TK_FOREIGN; }
        if (word == "KEY") { return TK_KEY; }
        if (word == "REFERENCES") { return TK_REFERENCES; }
        if (word == "UNIQUE") { return TK_UNIQUE; }
        if (word == "CHECK") { return TK_CHECK; }
        if (word == "CONSTRAINT") { return TK_CONSTRAINT; }
        if (word == "AUTOINCREMENT") { return TK_AUTOINCREMENT; }
        if (word == "CASCADE") { return TK_CASCADE; }
        if (word == "RESTRICT") { return TK_RESTRICT; }
        if (word == "ACTION") { return TK_ACTION; }
        if (word == "INT") { return TK_INT; }
        if (word == "INTEGER") { return TK_INTEGER_TYPE; }
        if (word == "REAL") { return TK_REAL; }
        if (word == "TEXT") { return TK_TEXT; }
        if (word == "BLOB") { return TK_BLOB; }
        if (word == "BOOLEAN") { return TK_BOOLEAN; }
        if (word == "VARCHAR") { return TK_VARCHAR; }
        if (word == "DATE") { return TK_DATE_TYPE; }
        if (word == "TIMESTAMP") { return TK_TIMESTAMP_TYPE; }
        if (word == "BEGIN") { return TK_BEGIN; }
        if (word == "COMMIT") { return TK_COMMIT; }
        if (word == "ROLLBACK") { return TK_ROLLBACK; }
        if (word == "TRANSACTION") { return TK_TRANSACTION; }
        if (word == "SAVEPOINT") { return TK_SAVEPOINT; }
        if (word == "RELEASE") { return TK_RELEASE; }
        if (word == "AS") { return TK_AS; }
        if (word == "CASE") { return TK_CASE; }
        if (word == "WHEN") { return TK_WHEN; }
        if (word == "THEN") { return TK_THEN; }
        if (word == "ELSE") { return TK_ELSE; }
        if (word == "END") { return TK_END; }
        if (word == "UNION") { return TK_UNION; }
        if (word == "ALL") { return TK_ALL; }
        if (word == "CAST") { return TK_CAST; }
        if (word == "EXCEPT") { return TK_EXCEPT; }
        if (word == "INTERSECT") { return TK_INTERSECT; }
        if (word == "SHOW") { return TK_SHOW; }
        if (word == "DESCRIBE") { return TK_DESCRIBE; }
        if (word == "EXPLAIN") { return TK_EXPLAIN; }
        if (word == "VACUUM") { return TK_VACUUM; }
        if (word == "ANALYZE") { return TK_ANALYZE; }
        if (word == "VERBOSE") { return TK_VERBOSE; }
        if (word == "TRUNCATE") { return TK_TRUNCATE; }
        if (word == "RETURNING") { return TK_RETURNING; }
        if (word == "CONFLICT") { return TK_CONFLICT; }
        if (word == "DO") { return TK_DO; }
        if (word == "NOTHING") { return TK_NOTHING; }
        if (word == "PREPARE") { return TK_PREPARE; }
        if (word == "DEALLOCATE") { return TK_DEALLOCATE; }
        if (word == "SAVE") { return TK_SAVE; }
        if (word == "OPEN") { return TK_OPEN; }
        if (word == "EXPORT") { return TK_EXPORT; }
        if (word == "IMPORT") { return TK_IMPORT; }
        if (word == "HELP") { return TK_HELP; }
        if (word == "TO") { return TK_TO; }
        if (word == "ADD") { return TK_ADD; }
        if (word == "COLUMN") { return TK_COLUMN; }
        if (word == "RENAME") { return TK_RENAME; }
        if (word == "IF") { return TK_IF; }
        if (word == "DATABASE") { return TK_DATABASE; }
        if (word == "DATABASES") { return TK_DATABASES; }
        if (word == "USE") { return TK_USE; }
        if (word == "CLOSE") { return TK_CLOSE; }
        if (word == "FILE") { return TK_FILE; }
        if (word == "WITH") { return TK_WITH; }
        if (word == "OVER") { return TK_OVER; }
        if (word == "PARTITION") { return TK_PARTITION; }
        if (word == "USING") { return TK_USING; }
        if (word == "ROWS") { return TK_ROWS; }
        if (word == "RANGE") { return TK_RANGE; }
        if (word == "UNBOUNDED") { return TK_UNBOUNDED; }
        if (word == "PRECEDING") { return TK_PRECEDING; }
        if (word == "FOLLOWING") { return TK_FOLLOWING; }
        if (word == "CURRENT") { return TK_CURRENT; }
        if (word == "ROW") { return TK_ROW; }
        if (word == "RECURSIVE") { return TK_RECURSIVE; }
        if (word == "TEMPORARY") { return TK_TEMPORARY; }
        if (word == "TEMP") { return TK_TEMPORARY; }         // alias
        if (word == "USER") { return TK_USER; }
        if (word == "PASSWORD") { return TK_PASSWORD; }
        if (word == "GRANT") { return TK_GRANT; }
        if (word == "REVOKE") { return TK_REVOKE; }
        if (word == "PRIVILEGES") { return TK_PRIVILEGES; }
        if (word == "FOR") { return TK_FOR; }
        if (word == "SHARE") { return TK_SHARE; }
        if (word == "NOWAIT") { return TK_NOWAIT; }
        if (word == "LOCKED") { return TK_LOCKED; }
        if (word == "SKIP") { return TK_SKIP; }
        if (word == "BEFORE") { return TK_BEFORE; }
        if (word == "AFTER") { return TK_AFTER; }
        if (word == "EACH") { return TK_EACH; }
        if (word == "EXECUTE") { return TK_EXECUTE; }
        if (word == "TRIGGER") { return TK_TRIGGER; }
        if (word == "SEQUENCE") { return TK_SEQUENCE; }
        if (word == "START") { return TK_START; }
        if (word == "INCREMENT") { return TK_INCREMENT; }
        if (word == "MINVALUE") { return TK_MINVALUE; }
        if (word == "MAXVALUE") { return TK_MAXVALUE; }
        if (word == "CYCLE") { return TK_CYCLE; }
        if (word == "NO") { return TK_NO; }
        if (word == "FUNCTION") { return TK_FUNCTION; }
        if (word == "RETURNS") { return TK_RETURNS; }
        if (word == "LANGUAGE") { return TK_LANGUAGE; }
        if (word == "JSON") { return TK_JSON; }
        if (word == "JSONB") { return TK_JSONB; }
        if (word == "DECLARE") { return TK_DECLARE; }
        if (word == "CURSOR") { return TK_CURSOR; }
        if (word == "FETCH") { return TK_FETCH; }
        if (word == "MOVE") { return TK_MOVE; }
        if (word == "FORWARD") { return TK_FORWARD; }
        if (word == "BACKWARD") { return TK_BACKWARD; }
        if (word == "ABSOLUTE") { return TK_ABSOLUTE; }
        if (word == "RELATIVE") { return TK_RELATIVE; }
        if (word == "NEXT") { return TK_NEXT; }
        if (word == "PRIOR") { return TK_PRIOR; }
        if (word == "FIRST") { return TK_FIRST; }
        if (word == "LAST") { return TK_LAST; }
        if (word == "COPY") { return TK_COPY; }
        if (word == "STDIN") { return TK_STDIN; }
        if (word == "STDOUT") { return TK_STDOUT; }
        if (word == "FORMAT") { return TK_FORMAT; }
        if (word == "HEADER") { return TK_HEADER; }
        if (word == "DELIMITER") { return TK_DELIMITER; }
        if (word == "CALL") { return TK_CALL; }
        if (word == "ARRAY") { return TK_ARRAY; }
        if (word == "MATERIALIZED") { return TK_MATERIALIZED; }
        if (word == "REFRESH") { return TK_REFRESH; }
        if (word == "ILIKE") { return TK_ILIKE; }
        if (word == "REPLACE") { return TK_REPLACE; }
        if (word == "COMMENT") { return TK_COMMENT; }
        if (word == "RESET") { return TK_RESET; }
        if (word == "SIMILAR") { return TK_SIMILAR; }
        if (word == "INHERITS") { return TK_INHERITS; }
        if (word == "ONLY") { return TK_ONLY; }
        if (word == "GENERATED") { return TK_GENERATED; }
        if (word == "ALWAYS") { return TK_ALWAYS; }
        if (word == "STORED") { return TK_STORED; }
        if (word == "FILTER") { return TK_FILTER; }
        if (word == "LATERAL") { return TK_LATERAL; }
        if (word == "NATURAL") { return TK_NATURAL; }
        if (word == "ROLLUP") { return TK_ROLLUP; }
        if (word == "CUBE") { return TK_CUBE; }
        if (word == "GROUPING") { return TK_GROUPING; }
        if (word == "MERGE") { return TK_MERGE; }
        if (word == "MATCHED") { return TK_MATCHED; }
        return TK_IDENTIFIER;
    }

    /// @brief The public entry point.  Return the next token,
    ///        advancing the cursor past it.
    ///
    /// Dispatch order:
    ///   1. Skip whitespace/comments.
    ///   2. EOF? return TK_EOF.
    ///   3. Digit?      → `readNumber`.
    ///   4. Letter/_?   → `readIdentifier` (may produce a keyword).
    ///   5. Quote?      → `readString`.
    ///   6. Otherwise: single- or two-character operator /
    ///      punctuation inline.
    ///
    /// Unknown single characters become `TK_ERROR` so the parser
    /// can diagnose them without crashing the lexer.
    expose func nextToken() -> Token {
        skipWhitespace();

        if (isAtEnd()) {
            var tok = new Token(TK_EOF, "", line, column);
            return tok;
        }

        var startLine = line;
        var startCol = column;
        var ch = peek();

        if (isDigit(ch)) { return readNumber(); }
        if (isAlpha(ch)) { return readIdentifier(); }
        if (ch == "'" || ch == "\"") { return readString(); }

        advance();

        // Two-character operators.  We dispatch by first char + peek.
        if (ch == "<" && peek() == "=") { advance(); return new Token(TK_LE, "<=", startLine, startCol); }
        if (ch == ">" && peek() == "=") { advance(); return new Token(TK_GE, ">=", startLine, startCol); }
        if (ch == "<" && peek() == ">") { advance(); return new Token(TK_NE, "<>", startLine, startCol); }
        if (ch == "!" && peek() == "=") { advance(); return new Token(TK_NE, "!=", startLine, startCol); }
        if (ch == "|" && peek() == "|") { advance(); return new Token(TK_CONCAT, "||", startLine, startCol); }
        if (ch == "~" && peek() == "*") { advance(); return new Token(TK_TILDE_STAR, "~*", startLine, startCol); }
        if (ch == "~") { return new Token(TK_TILDE, "~", startLine, startCol); }

        // `-` vs `->` vs `->>` — order matters because we already
        // consumed the `-`; the comment form `--` was handled in
        // `skipWhitespace` and never reaches us.
        if (ch == "+") { return new Token(TK_PLUS, "+", startLine, startCol); }
        if (ch == "-" && peek() == ">") {
            advance();
            if (peek() == ">") {
                advance();
                return new Token(TK_ARROW_TEXT, "->>", startLine, startCol);
            }
            return new Token(TK_ARROW, "->", startLine, startCol);
        }
        if (ch == "-") { return new Token(TK_MINUS, "-", startLine, startCol); }
        if (ch == "*") { return new Token(TK_STAR, "*", startLine, startCol); }
        if (ch == "/") { return new Token(TK_SLASH, "/", startLine, startCol); }
        if (ch == "%") { return new Token(TK_PERCENT, "%", startLine, startCol); }
        if (ch == "=") { return new Token(TK_EQ, "=", startLine, startCol); }
        if (ch == "<") { return new Token(TK_LT, "<", startLine, startCol); }
        if (ch == ">") { return new Token(TK_GT, ">", startLine, startCol); }

        // Punctuation.
        if (ch == "(") { return new Token(TK_LPAREN, "(", startLine, startCol); }
        if (ch == ")") { return new Token(TK_RPAREN, ")", startLine, startCol); }
        if (ch == ",") { return new Token(TK_COMMA, ",", startLine, startCol); }
        if (ch == ";") { return new Token(TK_SEMICOLON, ";", startLine, startCol); }
        if (ch == ".") { return new Token(TK_DOT, ".", startLine, startCol); }
        if (ch == "[") { return new Token(TK_LBRACKET, "[", startLine, startCol); }
        if (ch == "]") { return new Token(TK_RBRACKET, "]", startLine, startCol); }

        // Unknown character — not a parser crash, a lexer error.
        return new Token(TK_ERROR, ch, startLine, startCol);
    }
}
