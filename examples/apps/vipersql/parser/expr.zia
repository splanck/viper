// =============================================================================
// expr.zia — The `Expr` AST node: every shape of SQL expression
// Part of ViperSQL  (package: parser)
// =============================================================================
//
// PURPOSE
// -------
// SQL expressions live on the right-hand side of WHERE, in SELECT
// projections, in ON clauses of joins, in CASE arms, in CHECK
// constraints — anywhere a value is computed.  This file defines the
// *shape* of that tree with a single class, `Expr`, whose `kind` tag
// picks which of several "shapes" is active:
//
//     EXPR_LITERAL    42
//     EXPR_COLUMN     users.name
//     EXPR_BINARY     a + b, x < y, p AND q
//     EXPR_UNARY      -x, NOT p
//     EXPR_FUNCTION   SUM(salary), LOWER(name)
//     EXPR_STAR       *   (only legal inside COUNT(*) and SELECT *)
//     EXPR_SUBQUERY   (SELECT ...) as a scalar
//     EXPR_CASE       CASE WHEN ... THEN ... ELSE ... END
//     EXPR_EXISTS     EXISTS (SELECT ...)
//     EXPR_WINDOW     rank() OVER (PARTITION BY ... ORDER BY ...)
//     EXPR_QUANTIFIED col = ANY (SELECT ...)
//     EXPR_ROW_VALUE  (a, b)    row constructor
//
// Plus the operator codes (`OP_*`) used by binary and unary nodes.
//
// The parser produces these; the executor's `evalExpr` walks them to
// produce a `SqlValue`.  Both sides agree via this file.
//
// WHERE THIS FITS
// ---------------
//     parser/parser.zia   ──►  builds `Expr` trees out of tokens
//         │
//         ▼
//     parser/expr.zia    (YOU ARE HERE)
//         │
//         ▼
//     engine/executor.zia::evalExpr
//     engine/query.zia, join.zia, dml.zia
//         ──►  consumes `Expr` during SELECT / predicate evaluation
//
// KEY DESIGN CHOICES
// ------------------
//   1. One class, kind-tagged.  Zia has proper ADTs but the evaluator
//      branches on `kind` in a giant if-ladder and a single flat class
//      matches that dispatch style exactly.  The cost is unused
//      fields per node — an `EXPR_LITERAL` carries empty lists for
//      CASE arms, for example.  We accept that because AST nodes
//      are short-lived (torn down after each statement) and the
//      parser is not an allocation bottleneck.
//
//   2. Children live in a single `args` list regardless of shape.
//      Binary → `args[0]` (left), `args[1]` (right).  Unary →
//      `args[0]`.  Function → all arguments.  This lets generic
//      tree-walkers work without branching on `kind`.  The
//      `getLeft`/`getRight`/`getOperand` helpers are sugar for the
//      common accesses.
//
//   3. Subqueries store the raw SQL text, not a nested AST.
//      `subquerySQL` is re-parsed by the executor on demand.
//      Rationale: keeping `parser/expr.zia` independent of
//      `parser/stmt.zia`'s `SelectStmt` avoids a cycle.  The
//      re-parse cost is negligible because subqueries are
//      cache-warmly small.
//
//   4. Window-function bookkeeping is embedded on `Expr`, not a
//      sibling object.  `frameMode`, `frameStartKind`,
//      `windowOrderBy`, etc. all live here.  Again it is wasted
//      space on non-window expressions but keeps the executor's
//      evaluator monomorphic.
//
//   5. Unary and binary share the `op` slot but have disjoint
//      op-code namespaces (`OP_NEG`/`OP_NOT` for unary,
//      `OP_ADD`/`OP_EQ`/… for binary).  The node's `kind` tells you
//      which namespace to read — mixing them up is a type error the
//      evaluator would catch.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `EXPR_*` kind constants.
//   2. `OP_*` binary operator codes.
//   3. `OP_NEG` / `OP_NOT` unary operator codes.
//   4. The `Expr` class — fields, init helpers (one per kind),
//      kind predicates, child accessors, `toString` for debug
//      rendering.
//   5. `opToString` — pretty-prints binary operator codes.
//   6. Factory functions (`exprLiteral`, `exprColumn`, …) — the
//      parser calls these instead of `new Expr()` boilerplate.
//
// =============================================================================

module expr;

bind "../engine/types";

//=============================================================================
// EXPRESSION KIND CONSTANTS
//=============================================================================

final EXPR_LITERAL = 1;      // NULL, 42, 'x' — a constant value
final EXPR_COLUMN = 2;       // users.name or just name
final EXPR_BINARY = 3;       // a <op> b
final EXPR_UNARY = 4;        // -x, NOT p
final EXPR_FUNCTION = 5;     // COUNT(*), SUM(x), LOWER(s)
final EXPR_STAR = 6;         // SELECT * / COUNT(*)
final EXPR_SUBQUERY = 7;     // scalar (SELECT ...)
final EXPR_CASE = 8;         // CASE WHEN ... THEN ... ELSE ... END
final EXPR_EXISTS = 9;       // EXISTS (SELECT ...)
final EXPR_WINDOW = 10;      // func(...) OVER (...)
final EXPR_QUANTIFIED = 11;  // col op ANY/ALL/SOME (subquery)   (Phase 71)
final EXPR_ROW_VALUE = 12;   // (a, b) row constructor           (Phase 76)

//=============================================================================
// BINARY OPERATOR CONSTANTS
//=============================================================================

// Arithmetic.
final OP_ADD = 1;
final OP_SUB = 2;
final OP_MUL = 3;
final OP_DIV = 4;
final OP_MOD = 5;

// Comparison.
final OP_EQ = 10;
final OP_NE = 11;
final OP_LT = 12;
final OP_LE = 13;
final OP_GT = 14;
final OP_GE = 15;

// Logical / pattern.
final OP_AND = 20;
final OP_OR = 21;
final OP_LIKE = 22;
final OP_IN = 23;
final OP_IS = 24;
final OP_CONCAT = 25;             // ||

// Regex and NULL-safe equality variants.
final OP_REGEX_MATCH = 26;        // ~     (POSIX regex match)
final OP_SIMILAR_TO = 27;         // SIMILAR TO
final OP_IS_DISTINCT = 28;        // IS DISTINCT FROM     (NULL-safe <>)
final OP_IS_NOT_DISTINCT = 29;    // IS NOT DISTINCT FROM (NULL-safe =)
final OP_ILIKE = 30;              // ILIKE (case-insensitive LIKE)
final OP_JSON_ARROW = 31;         // ->  (JSON subscript, returns JSON)
final OP_JSON_ARROW_TEXT = 32;    // ->> (JSON subscript, returns TEXT)

//=============================================================================
// UNARY OPERATOR CONSTANTS
//=============================================================================

final OP_NEG = 1;   // -x
final OP_NOT = 2;   // NOT p

//=============================================================================
// EXPRESSION NODE
//=============================================================================

/// @brief Universal SQL expression AST node.
///
/// Populate one of the `init*` methods based on which shape of
/// expression you are building.  The unused fields stay at their
/// zero defaults; the evaluator branches on `kind` and only reads
/// the fields relevant to that kind.
class Expr {
    expose Integer kind;

    // EXPR_LITERAL payload.
    expose SqlValue literalValue;

    // EXPR_COLUMN payload.  `tableName` is optional (empty string
    // when the user wrote just `col` without a qualifier); the
    // resolver in the executor fills it in when ambiguity must be
    // disambiguated via schema lookup.
    expose String tableName;
    expose String columnName;

    // EXPR_BINARY / EXPR_UNARY: the operator code plus children in
    // the shared `args` slot.
    expose Integer op;

    // EXPR_FUNCTION and any kind with child expressions.
    // Convention:
    //   BINARY   args = [left, right]
    //   UNARY    args = [operand]
    //   FUNCTION args = the function arguments, left-to-right
    //   WINDOW   args = the window function arguments
    expose String funcName;
    expose List[Expr] args;

    // EXPR_SUBQUERY / EXPR_EXISTS / EXPR_QUANTIFIED carry raw SQL
    // that the executor re-parses on demand (see design choice 3).
    expose String subquerySQL;

    // EXPR_CASE: parallel `caseConditions` / `caseResults` lists for
    // the WHEN/THEN pairs, plus an optional ELSE arm.
    expose List[Expr] caseConditions;
    expose List[Expr] caseResults;
    expose Expr? caseElse;

    // EXPR_WINDOW.
    expose List[Expr] partitionBy;
    expose List[Expr] windowOrderBy;
    expose List[Integer] windowOrderDir;   // 0=ASC, 1=DESC
    // Window frame (Phase 61).
    //   frameMode:      0=none 1=ROWS 2=RANGE
    //   frameStartKind: 0=default 1=UNBOUNDED_PRECEDING 2=N_PRECEDING
    //                   3=CURRENT_ROW 4=N_FOLLOWING 5=UNBOUNDED_FOLLOWING
    //   frameStartN:    the N in "N PRECEDING/FOLLOWING"
    // frameEnd* mirrors frameStart*.
    expose Integer frameMode;
    expose Integer frameStartKind;
    expose Integer frameStartN;
    expose Integer frameEndKind;
    expose Integer frameEndN;
    // Phase 72 EXCLUDE: 0=none 1=EXCLUDE CURRENT ROW 2=EXCLUDE GROUP
    // 3=EXCLUDE TIES
    expose Integer frameExclude;

    // Aggregate FILTER clause (Phase 54) — `SUM(x) FILTER (WHERE y)`.
    expose Expr? filterExpr;

    // Named-window reference (Phase 75) — `func() OVER w` where `w`
    // is declared in a WINDOW clause at the SELECT level.
    expose String windowRefName;

    /// @brief Fully-zero-initialised expression.  Every init*
    ///        specialisation builds on top of this.
    expose func init() {
        kind = EXPR_LITERAL;
        literalValue = new SqlValue();
        literalValue.initNull();
        tableName = "";
        columnName = "";
        op = 0;
        funcName = "";
        args = [];
        subquerySQL = "";
        caseConditions = [];
        caseResults = [];
        caseElse = null;
        partitionBy = [];
        windowOrderBy = [];
        windowOrderDir = [];
        frameMode = 0;
        frameStartKind = 0;
        frameStartN = 0;
        frameEndKind = 0;
        frameEndN = 0;
        frameExclude = 0;
        filterExpr = null;
        windowRefName = "";
    }

    /// @brief Specialise as a literal value.
    expose func initLiteral(val: SqlValue) {
        kind = EXPR_LITERAL;
        literalValue = val;
    }

    /// @brief Specialise as a column reference.  `tbl` may be empty
    ///        when the user wrote the name unqualified.
    expose func initColumn(tbl: String, col: String) {
        kind = EXPR_COLUMN;
        tableName = tbl;
        columnName = col;
    }

    /// @brief Specialise as a binary op.  Children are captured by
    ///        reference; do not mutate them afterwards.
    expose func initBinary(operator: Integer, l: Expr, r: Expr) {
        kind = EXPR_BINARY;
        op = operator;
        args = [];
        args.add(l);
        args.add(r);
    }

    /// @brief Specialise as a unary op.
    expose func initUnary(operator: Integer, expr: Expr) {
        kind = EXPR_UNARY;
        op = operator;
        args = [];
        args.add(expr);
    }

    /// @brief Specialise as a named function call.  Arguments are
    ///        appended by the parser via `args.add(...)`.
    expose func initFunction(name: String) {
        kind = EXPR_FUNCTION;
        funcName = name;
        args = [];
    }

    /// @brief Specialise as the `*` wildcard.  Valid only in
    ///        select lists and `COUNT(*)`.  The executor enforces
    ///        that context.
    expose func initStar() {
        kind = EXPR_STAR;
    }

    /// @brief Specialise as a scalar subquery with stored raw SQL.
    expose func initSubquery(sql: String) {
        kind = EXPR_SUBQUERY;
        subquerySQL = sql;
    }

    /// @brief Specialise as an EXISTS subquery.
    expose func initExists(sql: String) {
        kind = EXPR_EXISTS;
        subquerySQL = sql;
    }

    /// @brief Specialise as a window-function call.  Arguments are
    ///        appended by the parser; the PARTITION BY / ORDER BY /
    ///        frame fields are populated later as the parser walks
    ///        the OVER (...) clause.
    expose func initWindow(name: String) {
        kind = EXPR_WINDOW;
        funcName = name;
        args = [];
        partitionBy = [];
        windowOrderBy = [];
        windowOrderDir = [];
        frameMode = 0;
        frameStartKind = 0;
        frameStartN = 0;
        frameEndKind = 0;
        frameEndN = 0;
        frameExclude = 0;
    }

    /// @brief Specialise as a quantified comparison (`col op ANY
    ///        (SELECT ...)`).  `quantifier` is "ANY" / "ALL" /
    ///        "SOME"; `operator` is one of the `OP_*` comparison
    ///        codes; the left expression is stored as `args[0]`.
    expose func initQuantified(operator: Integer, quantifier: String, sql: String, leftExpr: Expr) {
        kind = EXPR_QUANTIFIED;
        op = operator;
        funcName = quantifier;
        subquerySQL = sql;
        args = [];
        args.add(leftExpr);
    }

    /// @brief Specialise as a CASE expression.  Arms are appended
    ///        via `addCaseWhen`; optional ELSE via `setCaseElse`.
    expose func initCase() {
        kind = EXPR_CASE;
        caseConditions = [];
        caseResults = [];
        caseElse = null;
    }

    /// @brief Add one WHEN/THEN arm to a CASE expression.  Both
    ///        lists are indexed in parallel — arm `i` means
    ///        "WHEN caseConditions[i] THEN caseResults[i]".
    expose func addCaseWhen(condition: Expr, result: Expr) {
        caseConditions.add(condition);
        caseResults.add(result);
    }

    /// @brief Set the ELSE arm of a CASE.  Without this call, the
    ///        ELSE defaults to null, and an unmatched CASE returns
    ///        SQL NULL.
    expose func setCaseElse(elseExpr: Expr) {
        caseElse = elseExpr;
    }

    /// @brief Kind predicate — literal.
    expose func isLiteral() -> Boolean {
        return kind == EXPR_LITERAL;
    }

    /// @brief Kind predicate — column reference.
    expose func isColumn() -> Boolean {
        return kind == EXPR_COLUMN;
    }

    /// @brief Kind predicate — binary expression.
    expose func isBinary() -> Boolean {
        return kind == EXPR_BINARY;
    }

    /// @brief Binary left child shortcut.  Only valid on BINARY.
    expose func getLeft() -> Expr {
        return args.get(0);
    }

    /// @brief Binary right child shortcut.  Only valid on BINARY.
    expose func getRight() -> Expr {
        return args.get(1);
    }

    /// @brief Unary operand shortcut.  Only valid on UNARY.
    expose func getOperand() -> Expr {
        return args.get(0);
    }

    /// @brief Render the expression back to SQL-ish form.
    ///
    /// Used by EXPLAIN output and in error messages that quote the
    /// offending predicate.  Parenthesised around binary operators
    /// so nested expressions render unambiguously.  Only covers the
    /// common kinds; exotic kinds return "?" — fine for debug, not
    /// round-trippable.
    expose func toString() -> String {
        if kind == EXPR_LITERAL {
            return literalValue.toString();
        }
        if kind == EXPR_COLUMN {
            if tableName != "" {
                return tableName + "." + columnName;
            }
            return columnName;
        }
        if kind == EXPR_STAR {
            return "*";
        }
        if kind == EXPR_BINARY {
            var opStr = opToString(op);
            var leftExpr = args.get(0);
            var rightExpr = args.get(1);
            return "(" + leftExpr.toString() + " " + opStr + " " + rightExpr.toString() + ")";
        }
        if kind == EXPR_UNARY {
            var opStr = "";
            if op == OP_NEG {
                opStr = "-";
            }
            if op == OP_NOT {
                opStr = "NOT ";
            }
            var operandExpr = args.get(0);
            return opStr + operandExpr.toString();
        }
        if kind == EXPR_FUNCTION {
            var result = funcName + "(";
            var i = 0;
            while i < args.count() {
                if i > 0 {
                    result = result + ", ";
                }
                var arg = args.get(i);
                result = result + arg.toString();
                i = i + 1;
            }
            return result + ")";
        }
        if kind == EXPR_SUBQUERY {
            return "(" + subquerySQL + ")";
        }
        return "?";
    }
}

//=============================================================================
// OPERATOR → STRING
//=============================================================================

/// @brief Pretty-print a binary op code.  Used only by
///        `Expr.toString`.  Missing codes fall through to "??" so
///        debug output never crashes.
func opToString(op: Integer) -> String {
    if op == OP_ADD { return "+"; }
    if op == OP_SUB { return "-"; }
    if op == OP_MUL { return "*"; }
    if op == OP_DIV { return "/"; }
    if op == OP_MOD { return "%"; }
    if op == OP_EQ { return "="; }
    if op == OP_NE { return "<>"; }
    if op == OP_LT { return "<"; }
    if op == OP_LE { return "<="; }
    if op == OP_GT { return ">"; }
    if op == OP_GE { return ">="; }
    if op == OP_AND { return "AND"; }
    if op == OP_OR { return "OR"; }
    if op == OP_LIKE { return "LIKE"; }
    if op == OP_ILIKE { return "ILIKE"; }
    if op == OP_CONCAT { return "||"; }
    if op == OP_REGEX_MATCH { return "~"; }
    if op == OP_SIMILAR_TO { return "SIMILAR TO"; }
    if op == OP_IS_DISTINCT { return "IS DISTINCT FROM"; }
    if op == OP_IS_NOT_DISTINCT { return "IS NOT DISTINCT FROM"; }
    if op == OP_JSON_ARROW { return "->"; }
    if op == OP_JSON_ARROW_TEXT { return "->>"; }
    return "??";
}

//=============================================================================
// FACTORY FUNCTIONS
//=============================================================================
//
// Every parser site uses these to build a fresh `Expr` in one line
// instead of the three-line `new Expr(); e.init(); e.initX(...)`
// dance.  They do nothing more than that composition — `toString`
// and tree-walk semantics are the same as if you had built the node
// by hand.

func exprLiteral(val: SqlValue) -> Expr {
    var e = new Expr();
    e.init();
    e.initLiteral(val);
    return e;
}

/// @brief NULL literal shortcut.
func exprNull() -> Expr {
    return exprLiteral(sqlNull());
}

/// @brief Integer literal shortcut.
func exprInt(val: Integer) -> Expr {
    return exprLiteral(sqlInteger(val));
}

/// @brief Real literal shortcut, preserving source text.
func exprReal(val: Float, text: String) -> Expr {
    return exprLiteral(sqlReal(val, text));
}

/// @brief Text literal shortcut.
func exprText(val: String) -> Expr {
    return exprLiteral(sqlText(val));
}

/// @brief Unqualified column reference (`name`).
func exprColumn(name: String) -> Expr {
    var e = new Expr();
    e.init();
    e.initColumn("", name);
    return e;
}

/// @brief Qualified column reference (`tbl.col`).
func exprTableColumn(table: String, column: String) -> Expr {
    var e = new Expr();
    e.init();
    e.initColumn(table, column);
    return e;
}

/// @brief Binary op node shortcut.
func exprBinary(op: Integer, left: Expr, right: Expr) -> Expr {
    var e = new Expr();
    e.init();
    e.initBinary(op, left, right);
    return e;
}

/// @brief Unary op node shortcut.
func exprUnary(op: Integer, operand: Expr) -> Expr {
    var e = new Expr();
    e.init();
    e.initUnary(op, operand);
    return e;
}

/// @brief `*` wildcard node shortcut.
func exprStar() -> Expr {
    var e = new Expr();
    e.init();
    e.initStar();
    return e;
}

/// @brief Function-call node shortcut.  The caller is expected to
///        append argument expressions into `args` after.
func exprFunction(name: String) -> Expr {
    var e = new Expr();
    e.init();
    e.initFunction(name);
    return e;
}

/// @brief Scalar-subquery node shortcut.  `sql` is re-parsed on
///        evaluation.
func exprSubquery(sql: String) -> Expr {
    var e = new Expr();
    e.init();
    e.initSubquery(sql);
    return e;
}

/// @brief Quantified comparison shortcut — "col op ANY (SELECT …)"
///        and "col op ALL (SELECT …)".  Phase 71.
func exprQuantified(operator: Integer, quantifier: String, sql: String, leftExpr: Expr) -> Expr {
    var e = new Expr();
    e.init();
    e.initQuantified(operator, quantifier, sql, leftExpr);
    return e;
}
