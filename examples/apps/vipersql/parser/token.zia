// =============================================================================
// token.zia — The TK_* token kinds and the `Token` record
// Part of ViperSQL  (package: parser)
// =============================================================================
//
// PURPOSE
// -------
// The parser is split into three layers that pass small, well-defined
// values between each other:
//
//     SQL text
//        │
//        ▼   parser/lexer.zia
//     stream of Tokens  ─── defined HERE
//        │
//        ▼   parser/parser.zia
//     AST of Statements and Exprs
//
// This file is the vocabulary of that middle layer.  It defines:
//
//   * A *very* long list of `TK_*` integer constants — one per token
//     kind the lexer can produce.  These are stable integers used
//     everywhere the parser compares tokens.
//
//   * The `Token` class — a four-tuple `(kind, text, line, column)`
//     that the lexer emits and the parser consumes.  The line/column
//     fields are carried through to error messages so we can report
//     `ERROR at line 3, column 12` instead of a raw byte offset.
//
//   * `tokenTypeName(kind)` — a diagnostic helper that converts a
//     `TK_*` constant back to a printable keyword.  Only covers the
//     common subset used in error messages; unknown kinds fall back
//     to `"UNKNOWN(N)"` so we never lose information.
//
// WHERE THIS FITS
// ---------------
//     parser/token.zia   (YOU ARE HERE)
//         │  vocabulary of TK_* and the Token class
//         ▼
//     parser/lexer.zia
//         │  char stream  →  Token stream
//         ▼
//     parser/expr.zia / parser/stmt.zia
//         │  Token kinds used as match targets
//         ▼
//     parser/parser.zia
//         │  Token stream  →  AST
//         ▼
//     engine/executor.zia (runs AST)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Integer tokens, not an enum ADT.  Zia supports enums, but the
//      parser's inner loop is a long series of `if tok.kind ==
//      TK_SELECT` comparisons — a plain integer compare is what the
//      native backend ends up emitting either way, so we keep it
//      simple.  The `final TK_* = N` style also makes the assigned
//      numbers visible for debugging and wire dumps.
//
//   2. **Number collisions matter.**  When this codebase grew through
//      dozens of feature "phases", some tokens were added with numbers
//      already in use.  You can see one such fix in this file: the
//      comment "TK_CLOSE and TK_FILE were previously 137/138, colliding
//      with TK_EXCEPT/TK_INTERSECT" — they were moved to 219/220.  If
//      you add a new token, pick a free number and grep to be sure.
//
//   3. Ranges *do* matter for the classification helpers.  `isOperator`
//      and `isPunctuation` rely on numeric ranges (140–159 / 160–169),
//      so inserting a new operator must keep it inside the right
//      window or the classifiers silently miscategorise it.
//
//   4. `tokenTypeName` is lossy on purpose.  Listing every single
//      `TK_*` here would give us near-zero value in proportion to the
//      maintenance burden (every new token = another case).  The
//      function covers only the symbols that actually appear in
//      hot-path error messages.
//
// HOW TO READ THIS FILE
// ---------------------
//   * Section 1 (top, largest): the TK_* constants, grouped by the
//     phase / feature that introduced them.
//   * Section 2: the `Token` class.
//   * Section 3: `tokenTypeName` for diagnostic rendering.
//
// Add new tokens at the end of the appropriate group with an unused
// number (see design choice 2).
//
// =============================================================================

module token;

bind Viper.Fmt as Fmt;

//=============================================================================
// TOKEN KINDS
//=============================================================================
//
// Conventionally grouped so numbers cluster by topic.  Not required —
// most parser code ignores the grouping and simply compares `tok.kind
// == TK_FOO`.  Gaps between groups leave room for future insertions
// without forcing a renumber.

// Meta.
final TK_EOF = 0;
final TK_ERROR = 1;

// Literals (10..19).  `isLiteral` tests this range.
final TK_INTEGER = 10;
final TK_NUMBER = 11;
final TK_STRING = 12;
final TK_IDENTIFIER = 13;

// DDL keywords.
final TK_CREATE = 20;
final TK_TABLE = 21;
final TK_DROP = 22;
final TK_ALTER = 23;
final TK_INDEX = 24;
final TK_VIEW = 25;
final TK_TRIGGER = 26;

// DML keywords.
final TK_SELECT = 30;
final TK_INSERT = 31;
final TK_UPDATE = 32;
final TK_DELETE = 33;
final TK_INTO = 34;
final TK_FROM = 35;
final TK_WHERE = 36;
final TK_SET = 37;
final TK_VALUES = 38;

// Query-clause keywords.
final TK_ORDER = 40;
final TK_BY = 41;
final TK_ASC = 42;
final TK_DESC = 43;
final TK_LIMIT = 44;
final TK_OFFSET = 45;
final TK_GROUP = 46;
final TK_HAVING = 47;
final TK_DISTINCT = 48;

// JOIN keywords.
final TK_JOIN = 50;
final TK_INNER = 51;
final TK_LEFT = 52;
final TK_RIGHT = 53;
final TK_FULL = 54;
final TK_OUTER = 55;
final TK_CROSS = 56;
final TK_ON = 57;

// Logical / predicate keywords.
final TK_AND = 60;
final TK_OR = 61;
final TK_NOT = 62;
final TK_IN = 63;
final TK_IS = 64;
final TK_LIKE = 65;
final TK_BETWEEN = 66;
final TK_EXISTS = 67;

// Value keywords (NULL, TRUE, FALSE, DEFAULT).
final TK_NULL = 70;
final TK_TRUE = 71;
final TK_FALSE = 72;
final TK_DEFAULT = 73;

// Constraint keywords.
final TK_PRIMARY = 80;
final TK_FOREIGN = 81;
final TK_KEY = 82;
final TK_REFERENCES = 83;
final TK_UNIQUE = 84;
final TK_CHECK = 85;
final TK_CONSTRAINT = 86;
final TK_AUTOINCREMENT = 87;

// Type keywords.
final TK_INT = 90;
final TK_INTEGER_TYPE = 91;
final TK_REAL = 92;
final TK_TEXT = 93;
final TK_BLOB = 94;
final TK_BOOLEAN = 95;
final TK_VARCHAR = 96;
final TK_DATE_TYPE = 97;
final TK_TIMESTAMP_TYPE = 98;

// Transaction keywords.
final TK_BEGIN = 100;
final TK_COMMIT = 101;
final TK_ROLLBACK = 102;
final TK_TRANSACTION = 103;
final TK_SAVEPOINT = 104;
final TK_RELEASE = 105;

// Miscellaneous query / utility keywords.
final TK_AS = 110;
final TK_CASE = 111;
final TK_WHEN = 112;
final TK_THEN = 113;
final TK_ELSE = 114;
final TK_END = 115;
final TK_UNION = 116;
final TK_ALL = 117;
final TK_CAST = 118;
final TK_EXCEPT = 137;       // NOTE: 137 is reused here — see design choice 2.
final TK_INTERSECT = 138;

// Utility statements.
final TK_SHOW = 120;
final TK_DESCRIBE = 121;
final TK_EXPLAIN = 122;
final TK_VACUUM = 123;
final TK_SAVE = 124;
final TK_OPEN = 125;
final TK_EXPORT = 126;
final TK_IMPORT = 127;
final TK_HELP = 128;
final TK_TO = 129;
final TK_ADD = 130;
final TK_COLUMN = 131;
final TK_RENAME = 132;
final TK_IF = 133;

// Multi-database (Phase 1).
final TK_DATABASE = 134;
final TK_DATABASES = 135;
final TK_USE = 136;

// Persistent storage (Phase 2).  NOTE: TK_CLOSE/TK_FILE were moved
// from 137/138 when TK_EXCEPT/TK_INTERSECT took those numbers.
final TK_CLOSE = 219;
final TK_FILE = 220;

// Foreign-key action keywords (Phase 3).
final TK_CASCADE = 139;
final TK_RESTRICT = 170;
final TK_ACTION = 171;

// User management (Phase 10).
final TK_USER = 213;
final TK_PASSWORD = 215;

// Privileges (Phase 13).
final TK_GRANT = 216;
final TK_REVOKE = 217;
final TK_PRIVILEGES = 218;

// Row-level locking (Phase 14).
final TK_FOR = 221;
final TK_SHARE = 222;
final TK_NOWAIT = 223;
final TK_LOCKED = 224;
final TK_SKIP = 225;

// Triggers (Phase 17).
final TK_BEFORE = 226;
final TK_AFTER = 227;
final TK_EACH = 228;
final TK_EXECUTE = 229;

// Sequences (Phase 18).
final TK_SEQUENCE = 232;
final TK_START = 233;
final TK_INCREMENT = 234;
final TK_MINVALUE = 235;
final TK_MAXVALUE = 236;
final TK_CYCLE = 237;
final TK_NO = 238;

// Stored functions (Phase 19).
final TK_FUNCTION = 239;
final TK_RETURNS = 240;
final TK_LANGUAGE = 241;

// JSON types (Phase 25).
final TK_JSON = 242;
final TK_JSONB = 243;
final TK_ANALYZE = 244;
final TK_VERBOSE = 245;

// Common SQL extensions (Phase 29).
final TK_TRUNCATE = 246;
final TK_RETURNING = 247;
final TK_CONFLICT = 248;
final TK_DO = 249;
final TK_NOTHING = 250;

// Prepared statements (Phase 30).
final TK_PREPARE = 251;
final TK_DEALLOCATE = 252;

// Cursors (Phase 32).
final TK_DECLARE = 253;
final TK_CURSOR = 254;
final TK_FETCH = 255;
final TK_MOVE = 256;
final TK_FORWARD = 257;
final TK_BACKWARD = 258;
final TK_ABSOLUTE = 259;
final TK_RELATIVE = 260;
final TK_NEXT = 261;
final TK_PRIOR = 262;
final TK_FIRST = 263;
final TK_LAST = 264;

// COPY (Phase 34).
final TK_COPY = 265;
final TK_STDIN = 266;
final TK_STDOUT = 267;
final TK_FORMAT = 268;
final TK_HEADER = 269;
final TK_DELIMITER = 270;
final TK_CALL = 271;

// Arrays (Phase 36).
final TK_ARRAY = 272;
final TK_LBRACKET = 273;
final TK_RBRACKET = 274;

// Materialised views (Phase 37).
final TK_MATERIALIZED = 275;
final TK_REFRESH = 276;

// SQL expression extensions (Phase 38).
final TK_ILIKE = 277;
final TK_REPLACE = 278;

// COMMENT ON, SET/SHOW (Phase 43).
final TK_COMMENT = 279;
final TK_RESET = 280;

// Regex operators (Phase 51).
final TK_SIMILAR = 281;
final TK_TILDE = 282;       // ~     (POSIX regex)
final TK_TILDE_STAR = 283;  // ~*    (case-insensitive POSIX regex)

// Table inheritance (Phase 52).
final TK_INHERITS = 284;
final TK_ONLY = 285;

// Generated columns (Phase 53).
final TK_GENERATED = 286;
final TK_ALWAYS = 287;
final TK_STORED = 288;

// FILTER clause (Phase 54).
final TK_FILTER = 289;

// LATERAL joins (Phase 55).
final TK_LATERAL = 290;

// NATURAL JOIN (Phase 56).
final TK_NATURAL = 291;

// GROUPING SETS / ROLLUP / CUBE (Phase 59).
final TK_ROLLUP = 292;
final TK_CUBE = 293;
final TK_GROUPING = 294;

// MERGE INTO (Phase 73).
final TK_MERGE = 295;
final TK_MATCHED = 296;

// CTEs, window functions, multi-table DML (Phase 4).
final TK_WITH = 200;
final TK_OVER = 201;
final TK_PARTITION = 202;
final TK_USING = 203;
final TK_ROWS = 204;
final TK_RANGE = 205;
final TK_UNBOUNDED = 206;
final TK_PRECEDING = 207;
final TK_FOLLOWING = 208;
final TK_CURRENT = 209;
final TK_ROW = 210;
final TK_RECURSIVE = 211;
final TK_TEMPORARY = 212;

// Operators (140..159).  `isOperator` tests this range.
final TK_PLUS = 140;
final TK_MINUS = 141;
final TK_STAR = 142;
final TK_SLASH = 143;
final TK_PERCENT = 144;
final TK_EQ = 145;
final TK_NE = 146;
final TK_LT = 147;
final TK_LE = 148;
final TK_GT = 149;
final TK_GE = 150;
final TK_CONCAT = 151;
final TK_ARROW = 152;       //  ->   (JSON key → element)
final TK_ARROW_TEXT = 153;  //  ->>  (JSON key → element as text)

// Punctuation (160..).  `isPunctuation` tests kind >= 160.
final TK_LPAREN = 160;
final TK_RPAREN = 161;
final TK_COMMA = 162;
final TK_SEMICOLON = 163;
final TK_DOT = 164;

//=============================================================================
// TOKEN
//=============================================================================

/// @brief One lexed token with source-position bookkeeping.
///
/// `kind` is one of the `TK_*` constants.  `text` is the raw source
/// text that produced the token — preserved because literals (numbers,
/// strings, identifiers) need their actual bytes, and because error
/// messages echo the offending substring back to the user.
///
/// `line` and `column` are **1-based** for humans.  The lexer
/// updates them as it advances through source; the parser carries
/// them into AST nodes so runtime errors (constraint violations, FK
/// failures) can also report the original statement location.
class Token {
    expose Integer kind;
    expose String text;
    expose Integer line;
    expose Integer column;

    /// @brief Construct with all four fields.  Only entry point —
    ///        the lexer always has all four in hand when it emits.
    expose func init(k: Integer, t: String, ln: Integer, col: Integer) {
        kind = k;
        text = t;
        line = ln;
        column = col;
    }

    /// @brief Literal text of the token.  Mirrors `text` — provided
    ///        as a method so callers that only have the abstract
    ///        concept "what did the user write here" do not have to
    ///        reach into field syntax.
    expose func getText() -> String {
        return text;
    }

    /// @brief "Is this a keyword" predicate.
    ///
    /// Anything below `TK_CREATE` (20) is a meta/literal.  Operators
    /// and punctuation live at 140..164 — we exclude both ranges.
    /// Everything else in the 20..139 / 170..299 space is a keyword.
    expose func isKeyword() -> Boolean {
        if kind < 20 { return false; }
        if kind >= 140 && kind <= 151 { return false; }
        if kind >= 160 && kind <= 164 { return false; }
        return true;
    }

    /// @brief "Is this an operator" predicate.  Range 140..159 —
    ///        PLUS through ARROW_TEXT.
    expose func isOperator() -> Boolean {
        return kind >= 140 && kind < 160;
    }

    /// @brief "Is this punctuation" — LPAREN, RPAREN, COMMA,
    ///        SEMICOLON, DOT.
    expose func isPunctuation() -> Boolean {
        return kind >= 160;
    }

    /// @brief "Is this a literal" — INTEGER, NUMBER, STRING,
    ///        IDENTIFIER (the 10..19 range).
    expose func isLiteral() -> Boolean {
        return kind >= 10 && kind < 20;
    }

    /// @brief Debug renderer — includes kind id, text, and source
    ///        position.  Used by the parser's error path and by the
    ///        `EXPLAIN LEX` meta-command when that surface is
    ///        enabled.
    expose func toString() -> String {
        return "Token(" + Fmt.Int(kind) + ", '" + text + "', " +
               Fmt.Int(line) + ":" + Fmt.Int(column) + ")";
    }
}

/// @brief Best-effort symbolic name for a token kind.
///
/// Used only in error messages and EXPLAIN output.  Not exhaustive —
/// see design choice 4 in the header.  For kinds not covered, returns
/// `"UNKNOWN(N)"` where N is the raw integer — never silently loses
/// information.
func tokenTypeName(kind: Integer) -> String {
    if (kind == TK_EOF) { return "EOF"; }
    if (kind == TK_ERROR) { return "ERROR"; }
    if (kind == TK_INTEGER) { return "INTEGER"; }
    if (kind == TK_NUMBER) { return "NUMBER"; }
    if (kind == TK_STRING) { return "STRING"; }
    if (kind == TK_IDENTIFIER) { return "IDENTIFIER"; }
    if (kind == TK_SELECT) { return "SELECT"; }
    if (kind == TK_INSERT) { return "INSERT"; }
    if (kind == TK_UPDATE) { return "UPDATE"; }
    if (kind == TK_DELETE) { return "DELETE"; }
    if (kind == TK_CREATE) { return "CREATE"; }
    if (kind == TK_TABLE) { return "TABLE"; }
    if (kind == TK_DROP) { return "DROP"; }
    if (kind == TK_FROM) { return "FROM"; }
    if (kind == TK_WHERE) { return "WHERE"; }
    if (kind == TK_AND) { return "AND"; }
    if (kind == TK_OR) { return "OR"; }
    if (kind == TK_NOT) { return "NOT"; }
    if (kind == TK_NULL) { return "NULL"; }
    if (kind == TK_INTO) { return "INTO"; }
    if (kind == TK_VALUES) { return "VALUES"; }
    if (kind == TK_PLUS) { return "PLUS"; }
    if (kind == TK_MINUS) { return "MINUS"; }
    if (kind == TK_STAR) { return "STAR"; }
    if (kind == TK_SLASH) { return "SLASH"; }
    if (kind == TK_EQ) { return "EQ"; }
    if (kind == TK_NE) { return "NE"; }
    if (kind == TK_LT) { return "LT"; }
    if (kind == TK_GT) { return "GT"; }
    if (kind == TK_LE) { return "LE"; }
    if (kind == TK_GE) { return "GE"; }
    if (kind == TK_LPAREN) { return "LPAREN"; }
    if (kind == TK_RPAREN) { return "RPAREN"; }
    if (kind == TK_COMMA) { return "COMMA"; }
    if (kind == TK_SEMICOLON) { return "SEMICOLON"; }
    if (kind == TK_DOT) { return "DOT"; }
    if (kind == TK_TRUNCATE) { return "TRUNCATE"; }
    if (kind == TK_RETURNING) { return "RETURNING"; }
    if (kind == TK_CONFLICT) { return "CONFLICT"; }
    if (kind == TK_DO) { return "DO"; }
    if (kind == TK_NOTHING) { return "NOTHING"; }
    if (kind == TK_PREPARE) { return "PREPARE"; }
    if (kind == TK_DEALLOCATE) { return "DEALLOCATE"; }
    if (kind == TK_DECLARE) { return "DECLARE"; }
    if (kind == TK_CURSOR) { return "CURSOR"; }
    if (kind == TK_FETCH) { return "FETCH"; }
    if (kind == TK_MOVE) { return "MOVE"; }
    if (kind == TK_COPY) { return "COPY"; }
    if (kind == TK_CALL) { return "CALL"; }
    return "UNKNOWN(" + Fmt.Int(kind) + ")";
}
