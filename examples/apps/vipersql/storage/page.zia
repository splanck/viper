// =============================================================================
// page.zia — The on-disk page format: constants, layouts, and tiny value types
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// Every persistent byte ViperSQL writes to disk lives inside a 4-KB "page".
// This file defines the *layout* of those pages: magic numbers, offsets,
// page-type tags, value-type tags, and two very small classes
// (`PageHeader`, `SlotEntry`) that describe the in-memory shape of a page
// header and of a single slot-directory entry.  No I/O, no serialisation
// logic — just the invariants every other storage file agrees on.
//
// WHERE THIS FITS
// ---------------
// The storage stack looks like a thin tower:
//
//     engine/*      (DDL / DML / SELECT planning)
//         │
//         ▼
//     storage/engine.zia         ← StorageEngine: tables + rows API
//         │
//         ▼
//     storage/pager.zia          ← Pager: page-cached I/O
//     storage/buffer.zia         ← page-ID → in-memory byte buffer
//         │
//         ▼
//     storage/serializer.zia     ← Value  ↔  bytes (uses VAL_TYPE_* here)
//     storage/data_page.zia      ← row-on-page slot directory (uses SlotEntry)
//     storage/schema_page.zia    ← table catalog pages
//     storage/btree_node.zia     ← index pages
//     storage/wal.zia            ← write-ahead log pages
//         │
//         ▼
//     storage/page.zia           ← YOU ARE HERE: the shared vocabulary
//
// Every layer above this one imports `page` to get the constants below.
// That centralisation is the point: if PAGE_SIZE ever changes, or we grow
// a new value-type tag, we touch exactly one file.
//
// KEY DESIGN CHOICES
// ------------------
//   1. Fixed 4 KB pages.  This matches SQLite, PostgreSQL, and most other
//      on-disk engines — it is the kernel's natural block size on every
//      supported platform (macOS/Linux/Windows), so a page read is always
//      a single `read()` call with no partial-page stitching.
//
//   2. Page-type is a single byte.  One byte is enough for the six kinds of
//      page we actually produce; leaving it a byte (not an int) keeps the
//      header tight and makes room for more fields inside the first 40
//      bytes of the file header.  That keeps the "disk header" under 64B
//      which in turn keeps a whole file header in a single cache line on
//      the read side.
//
//   3. Value-type tags are dense integers.  Ordering matters: the
//      serializer (`storage/serializer.zia`) uses these as jump-table keys,
//      and the PG wire protocol (`server/pg_wire.zia`) maps them to OIDs.
//      If you add a new type, *append* — do not reorder — or you break
//      existing data files.
//
//   4. `MAX_INLINE_SIZE = 2000` (half a page).  Values larger than this
//      overflow to dedicated PAGE_TYPE_OVERFLOW pages.  Two thousand was
//      picked so a row with one big `TEXT` value plus a few small columns
//      still fits on one page even with the slot directory, saving the
//      overflow chain hop for the common case.
//
//   5. `INVALID_PAGE_ID = -1`.  Using -1 (instead of 0) to mean "nothing"
//      is deliberate: page 0 is the *file header*, a very real page, so we
//      cannot repurpose it as a sentinel.  Any code that sees -1 in a
//      `nextPage` or `schemaPage` slot knows to stop walking the chain.
//
// HOW TO READ THIS FILE
// ---------------------
// Short.  Read the constants top-to-bottom — they are grouped by what part
// of the disk layout they describe (file header → data page → value
// types).  Then the two small classes.  The only logic is a pair of
// utility helpers at the bottom.  No state, no side effects.
//
// =============================================================================

module page;

//=============================================================================
// PAGE CONSTANTS
//=============================================================================

// The single most-load-bearing constant in the storage layer.  Every I/O
// happens in multiples of this size.  See note (1) above for why 4096.
final PAGE_SIZE = 4096;

// Page type tags.  Stored as the first byte of every page so a generic
// page reader can dispatch on type without first decoding the whole page.
//
// HEADER   — page 0 only: magic, version, freelist head, schema pointer.
// SCHEMA   — serialised table / column / constraint catalog.
// DATA     — heap pages: rows stored with a slot directory (see below).
// INDEX    — B-tree node pages (`storage/btree_node.zia`).
// OVERFLOW — spills from rows whose value exceeded MAX_INLINE_SIZE.
// FREELIST — linked list of reclaimed pages awaiting reuse.
final PAGE_TYPE_HEADER = 0;
final PAGE_TYPE_SCHEMA = 1;
final PAGE_TYPE_DATA = 2;
final PAGE_TYPE_INDEX = 3;
final PAGE_TYPE_OVERFLOW = 4;
final PAGE_TYPE_FREELIST = 5;

// 8 ASCII bytes that identify the file as ViperSQL.  A mismatched magic
// triggers the pager's "not a database file" error at open time, which is
// the cheapest possible guard against opening a random file as a DB.
final MAGIC_STRING = "VIPERSQL";

// On-disk format version.  Bumped whenever a layout changes in a way that
// old binaries would misread.  The persistence layer (`io/persistence.zia`)
// refuses to open files whose FILE_VERSION it doesn't recognise rather
// than silently "upgrading" them.
final FILE_VERSION = 1;

//-----------------------------------------------------------------------------
// File-header page layout.  Page 0 is carved up like this:
//
//     0 .. 7   MAGIC             ("VIPERSQL")
//     8 .. 11  VERSION           (FILE_VERSION as 4-byte int)
//    12 .. 15  PAGE_SIZE         (4096; stored for future-proofing)
//    16 .. 23  PAGE_COUNT        (total pages in the file)
//    24 .. 31  SCHEMA_PAGE       (page id of first schema page, or -1)
//    32 .. 39  FREELIST_HEAD     (page id of first free page, or -1)
//    40 ..     reserved          (zero-filled, available for future use)
//
// Why spell these offsets out as constants instead of hard-coding numbers
// in the pager?  Because these are the *protocol* between writer and
// reader.  If we ever add a field, we want the change to be reviewed in
// one place, and this file is that place.
//-----------------------------------------------------------------------------
final HEADER_MAGIC_OFFSET = 0;
final HEADER_VERSION_OFFSET = 8;
final HEADER_PAGE_SIZE_OFFSET = 12;
final HEADER_PAGE_COUNT_OFFSET = 16;
final HEADER_SCHEMA_PAGE_OFFSET = 24;
final HEADER_FREELIST_HEAD_OFFSET = 32;
final HEADER_RESERVED_OFFSET = 40;

//-----------------------------------------------------------------------------
// Data-page layout.  The first 17 bytes of a DATA page are a fixed header,
// then a slot directory grows *forward* from byte 17, while row payloads
// grow *backward* from byte PAGE_SIZE.  When they meet, the page is full.
//
//     0        TYPE              (= PAGE_TYPE_DATA)
//     1 .. 4   TABLE_ID          (every row on this page belongs to it)
//     5 .. 6   ROW_COUNT         (number of slot entries, including tombstones)
//     7 .. 8   FREE_SPACE_OFFSET (byte offset of first free byte, from 0)
//     9 .. 16  NEXT_PAGE         (page id of next data page for this table)
//    17 ..     slot directory    (grows forward, each entry = 6 bytes)
//       ..     [ free space ]
//       ..     row payloads      (grow backward from PAGE_SIZE)
//
// The "grow inward from both ends" trick is the classic slotted-page
// layout used by PostgreSQL, InnoDB, SQLite — it lets us reclaim space in
// the middle (deletes leave a tombstone slot; the row bytes vacate the
// payload area on VACUUM) without shifting anything else.
//-----------------------------------------------------------------------------
final DATA_PAGE_TYPE_OFFSET = 0;
final DATA_TABLE_ID_OFFSET = 1;
final DATA_ROW_COUNT_OFFSET = 5;
final DATA_FREE_SPACE_OFFSET = 7;
final DATA_NEXT_PAGE_OFFSET = 9;
final DATA_SLOT_DIR_OFFSET = 17;

//-----------------------------------------------------------------------------
// Value-type tags.  Each serialised cell is prefixed with one of these so
// the reader knows how to decode the bytes that follow.
//
//   NULL      — zero-length payload.
//   INT       — 8 bytes, little-endian (Zia Integer is 64-bit).
//   REAL      — 8 bytes, IEEE 754 double.
//   TEXT      — 4-byte length prefix + UTF-8 bytes.
//   BLOB      — 4-byte length prefix + raw bytes.
//   BOOL      — 1 byte (0 or 1).
//   DATE      — 8 bytes (days since the Viper epoch).
//   TIMESTAMP — 8 bytes (microseconds since epoch).
//   JSON      — like TEXT but tagged distinctly so executor can route it
//               to the JSON operators in `io/json.zia`.
//
// NOTE: keep these in sync with the tag switch in
// `storage/serializer.zia::writeValue` and with the OID map in
// `server/pg_wire.zia::typeToPgOid`.  Appending is safe; reordering is not.
//-----------------------------------------------------------------------------
final VAL_TYPE_NULL = 0;
final VAL_TYPE_INT = 1;
final VAL_TYPE_REAL = 2;
final VAL_TYPE_TEXT = 3;
final VAL_TYPE_BLOB = 4;
final VAL_TYPE_BOOL = 5;
final VAL_TYPE_DATE = 6;
final VAL_TYPE_TIMESTAMP = 7;
final VAL_TYPE_JSON = 8;

// Cells larger than this are moved off-row to a chain of OVERFLOW pages,
// with only a page pointer left inline.  See note (4) in the header.
final MAX_INLINE_SIZE = 2000;

//=============================================================================
// PAGE-ID SENTINEL
//=============================================================================

// Page IDs are plain 8-byte integers.  Three conventions:
//   *  0  — the file header page (always present).
//   *  1+ — data / schema / index / overflow / freelist pages.
//   * -1  — "no such page" sentinel.  Used as `nextPage` terminator,
//           `schemaPage = INVALID_PAGE_ID` when no catalog exists yet, and
//           `freelistHead = INVALID_PAGE_ID` when nothing is reclaimable.
final INVALID_PAGE_ID = -1;

//=============================================================================
// PAGE HEADER (in-memory view)
//=============================================================================

/// @brief In-memory mirror of the tiny portion of a page header every
///        caller in the storage layer needs to look at.
///
/// The full on-disk headers (file, data, schema, index) each have more
/// bytes than this, but *every* caller needs at least (type, id), so we
/// surface those two fields here as the minimum shared contract.  The
/// heavier layouts live on top of `PageHeader` — see `data_page.zia`'s
/// `DataPageHeader` and `schema_page.zia`'s `SchemaPageHeader` for the
/// extensions.
class PageHeader {
    expose Integer pageType;
    expose Integer pageId;

    /// @brief Default-init to "unknown data page, no id yet".
    ///
    /// Handy when the pager allocates a fresh page and will fill the id in
    /// later after the freelist or EOF extension tells it the number.
    expose func init() {
        pageType = PAGE_TYPE_DATA;
        pageId = INVALID_PAGE_ID;
    }

    /// @brief Convenience constructor with the type and id already known.
    ///
    /// Used throughout the pager when a page is being *loaded* from disk
    /// (type was read from byte 0; id is the block number we asked for).
    expose func initWithType(ptype: Integer, pid: Integer) {
        pageType = ptype;
        pageId = pid;
    }
}

//=============================================================================
// SLOT DIRECTORY ENTRY (in-memory view)
//=============================================================================

/// @brief One entry in a data page's slot directory.
///
/// Why a slot directory at all?  Rows on a heap page have variable length,
/// so we cannot index them by `rowIndex * rowSize`.  Instead, the slot
/// directory gives every row an integer id (its slot position) and stores
/// where the row bytes live (`offset`) and how long they are (`length`).
/// This decouples a row's public id from its physical position — we can
/// move or compact row bytes during VACUUM without invalidating row ids or
/// any index that points at them.
///
/// Why the tombstone (`deleted`)?  Soft-deletion.  An UPDATE or DELETE
/// flips `deleted` to true without immediately rewriting the page or the
/// indexes; the space is reclaimed later by VACUUM
/// (`engine/executor.zia::executeVacuum`).  This amortises the cost of
/// deletes and lets MVCC readers still see the old tuple until they
/// advance past the transaction that removed it.
///
/// NOTE: the on-disk size of one slot entry is 6 bytes (see
/// `calculateFreeSpace` below).  That number is duplicated in
/// `storage/serializer.zia::SLOT_ENTRY_SIZE`; keep them in sync.
class SlotEntry {
    expose Integer offset;      // byte offset from the start of the page
    expose Integer length;      // payload length in bytes
    expose Boolean deleted;     // true once the row is tombstoned

    /// @brief Zero-initialise a slot entry.
    ///
    /// Equivalent to "empty slot that has never held a row".  Rarely used
    /// directly — callers typically go through `initWithValues` once they
    /// know where they are writing the row bytes.
    expose func init() {
        offset = 0;
        length = 0;
        deleted = false;
    }

    /// @brief Initialise a live slot pointing at a freshly written row.
    ///
    /// `off` is where the row's first byte sits in the page; `len` is how
    /// many bytes of row payload to read.  The `deleted` flag stays false
    /// — a newly inserted row is always live.
    expose func initWithValues(off: Integer, len: Integer) {
        offset = off;
        length = len;
        deleted = false;
    }
}

//=============================================================================
// UTILITY FUNCTIONS
//=============================================================================

/// @brief Compute the free byte count in a data page.
///
/// A data page has three zones:
///
///     [ fixed header ][ slot dir → ][ ... free ... ][ ← row payloads ]
///
/// `freeSpaceOffset` records where the payload zone *ends* growing
/// backwards (so smaller values = more rows packed in).  The slot
/// directory starts immediately after the header at DATA_SLOT_DIR_OFFSET
/// and grows forward 6 bytes per entry.  Free space is whatever is left
/// between them.  A negative return would indicate corruption (the two
/// zones have crossed); callers treat that as "page full, go allocate
/// another".
func calculateFreeSpace(rowCount: Integer, freeSpaceOffset: Integer) -> Integer {
    // 6 bytes/slot: 4-byte offset + 2-byte length (the tombstone bit is
    // packed into the high bit of `length` on disk).
    var slotDirEnd = DATA_SLOT_DIR_OFFSET + (rowCount * 6);
    return freeSpaceOffset - slotDirEnd;
}

/// @brief Decide whether a serialised value should be forced off-row.
///
/// Called by the INSERT path before it tries to squeeze a value into the
/// current data page.  If the value is big enough, the serializer diverts
/// it to the OVERFLOW chain and stores only the head-page id inline.  The
/// threshold is `MAX_INLINE_SIZE`, tuned so that the common "big TEXT
/// column + a few small ones" row still fits on one page.
func needsOverflow(valueSize: Integer) -> Boolean {
    return valueSize > MAX_INLINE_SIZE;
}
