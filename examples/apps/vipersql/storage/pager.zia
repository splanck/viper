// =============================================================================
// pager.zia ŌĆö Low-level file I/O: `Page` object, `Pager` for raw page r/w
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// Two classes:
//
//   * `Page`  ŌĆö an in-memory page: id, type, 4-KB byte buffer,
//               dirty flag, pin count.  Handed up and down the
//               storage stack.
//   * `Pager` ŌĆö the file-level I/O layer.  Knows how to create /
//               open / close a database file, read the header,
//               allocate a fresh page (either from the freelist or
//               by extending the file), free a page (push onto
//               freelist), and read/write arbitrary pages to disk.
//
// Above the pager is the buffer pool (`./buffer.zia`) which caches
// pages in memory; below is the OS file system via `Viper.IO.BinFile`.
// The pager is the only module in the demo that touches the disk
// directly.
//
// WHERE THIS FITS
// ---------------
//     engine/ddl, dml, query, executor
//         Ōöé
//         Ō¢╝
//     storage/engine.zia, btree.zia, data_page.zia, schema_page.zia
//         Ōöé
//         Ō¢╝
//     storage/buffer.zia      (page cache)
//         Ōöé
//         Ō¢╝
//     storage/pager.zia       (YOU ARE HERE ŌĆö raw file I/O)
//         Ōöé
//         Ō¢╝
//     Viper.IO.BinFile (OS file descriptor)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Page id = file block number.  Page 0 is always the file
//      header, 1 is the first schema/catalog page, and onwards.
//      `pageId * PAGE_SIZE` is the byte offset in the file ŌĆö no
//      indirection table.
//
//   2. Freelist: a linked list of freed pages.  `freeListHead`
//      sits in the file header; each freed page's first bytes are
//      `[ PAGE_TYPE_FREELIST | next-page-id | ...zeroes... ]`.  On
//      allocation we pop the head; on free we push.  LIFO reuse
//      keeps recently-freed pages hot in OS cache.
//
//   3. Header flushed on demand, not on every mutation.  The
//      pager tracks `pageCount`/`freeListHead` in RAM and writes
//      them back via `flushHeader` ŌĆö which the buffer pool calls
//      during `flushAll` and `closeDatabase`.  This is what
//      protects us from "crash between page alloc and header
//      update" races (the freelist head ends up stale, not
//      corrupt ŌĆö recovery treats it as a minor leak).
//
//   4. Close-on-every-op for `BinFile`.  Each `writePageToFile`
//      opens, seeks, writes, flushes, closes.  This is the cost
//      of simplicity ŌĆö no long-lived file descriptor to worry
//      about.  The buffer pool absorbs the repeated access
//      overhead on the hot path.
//
//   5. Magic bytes hard-coded.  `writeHeaderMagic` /
//      `verifyHeaderMagic` spell out `V I P E R S Q L` byte by
//      byte.  No runtime "string ŌåÆ bytes" conversion step that
//      could fail on an unusual character encoding.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `Page` ŌĆö simple data class with pin/dirty lifecycle.
//   2. `Pager` fields.
//   3. File lifecycle: `createDatabase`, `openDatabase`,
//      `flushHeader`, `closeDatabase`.
//   4. Page allocation: `allocatePage`, `freePage`.
//   5. Read/write: `readPage`, `writePage` and their internal
//      helpers `readPageIntoBuffer`, `writePageToFile`.
//   6. Header helpers at the bottom.
//
// =============================================================================

module pager;

bind Viper.IO as IO;
bind Viper.String as String;
bind Viper.Collections as Collections;
bind "./page";
bind "./serializer";

//=============================================================================
// PAGE (in-memory view)
//=============================================================================

/// @brief One 4-KB page held in memory.
///
/// `data` is a `BinaryBuffer` pre-allocated to PAGE_SIZE so writes
/// don't cascade into list growth.  `dirty` flips on any write and
/// is cleared by `writePage` once the page has been persisted.
/// `pinCount` is the buffer pool's "don't evict me" counter ŌĆö while
/// non-zero, `canEvict()` returns false.
class Page {
    expose Integer pageId;
    expose Integer pageType;
    expose BinaryBuffer data;
    expose Boolean dirty;
    expose Integer pinCount;

    /// @brief Zero-state init: unassigned id, DATA type, fresh
    ///        PAGE_SIZE buffer, clean, unpinned.
    expose func init() {
        pageId = INVALID_PAGE_ID;
        pageType = PAGE_TYPE_DATA;
        data = new BinaryBuffer();
        data.initWithCapacity(PAGE_SIZE);
        dirty = false;
        pinCount = 0;
    }

    /// @brief Init with a known id and type.  Used by
    ///        `BufferPool.newPage` when allocating a fresh page.
    expose func initWithId(pid: Integer, ptype: Integer) {
        pageId = pid;
        pageType = ptype;
        data = new BinaryBuffer();
        data.initWithCapacity(PAGE_SIZE);
        dirty = false;
        pinCount = 0;
    }

    /// @brief Mark the page modified.  Called by every write path
    ///        into `data` via `data_page.zia`, `schema_page.zia`,
    ///        etc.
    expose func markDirty() {
        dirty = true;
    }

    /// @brief Increment pin count ŌĆö caller has a live reference.
    expose func pin() {
        pinCount = pinCount + 1;
    }

    /// @brief Decrement pin count, clamped at 0.  Calling unpin
    ///        more times than pin is a bug, but we do not trap ŌĆö
    ///        just floor.
    expose func unpin() {
        if pinCount > 0 {
            pinCount = pinCount - 1;
        }
    }

    /// @brief "Is this page evictable right now?"  True when
    ///        nothing currently holds it via `pin`.
    expose func canEvict() -> Boolean {
        return pinCount == 0;
    }

    /// @brief Clear the byte buffer and dirty/pin state.  Used
    ///        when recycling a Page object onto a different
    ///        page id (rare; we mostly allocate fresh).
    expose func reset() {
        data = new BinaryBuffer();
        data.initWithCapacity(PAGE_SIZE);
        dirty = false;
        pinCount = 0;
    }
}

//=============================================================================
// PAGER
//=============================================================================

/// @brief The file-level I/O layer.  One instance per open file.
///
/// Tracks `pageCount` (how many pages are in the file),
/// `freeListHead` (page id of the first freed page, -1 if none),
/// and two immutable-after-open values (`fileVersion`,
/// `schemaPageId`).
class Pager {
    expose String filename;
    expose Integer pageCount;
    expose Integer freeListHead;
    expose Boolean isOpen;

    // Header cache ŌĆö read on open, written back on flushHeader.
    hide Integer fileVersion;
    hide Integer schemaPageId;

    /// @brief Init to "no file open".
    expose func init() {
        filename = "";
        pageCount = 0;
        freeListHead = INVALID_PAGE_ID;
        isOpen = false;
        fileVersion = FILE_VERSION;
        schemaPageId = 1;
    }

    //=========================================================================
    // FILE LIFECYCLE
    //=========================================================================

    /// @brief Create a fresh database file.
    ///
    /// Writes page 0 (the file header with magic + version + page
    /// size + pageCount=2 + schemaPageId=1 + freelistHead=-1) and
    /// page 1 (an empty schema page with 0 tables).  Leaves the
    /// pager in the open state ready for further I/O.
    ///
    /// Returns true on success.  Subsequent allocations start at
    /// page 2.
    expose func createDatabase(fname: String) -> Boolean {
        filename = fname;

        var header = new BinaryBuffer();
        header.initWithCapacity(PAGE_SIZE);

        writeHeaderMagic(header);

        header.seek(HEADER_VERSION_OFFSET);
        header.writeInt32(FILE_VERSION);

        header.seek(HEADER_PAGE_SIZE_OFFSET);
        header.writeInt32(PAGE_SIZE);

        // pageCount = 2: the header at 0 and the schema page at 1.
        header.seek(HEADER_PAGE_COUNT_OFFSET);
        header.writeInt64(2);

        header.seek(HEADER_SCHEMA_PAGE_OFFSET);
        header.writeInt64(1);

        header.seek(HEADER_FREELIST_HEAD_OFFSET);
        header.writeInt64(INVALID_PAGE_ID);

        writePageToFile(0, header);

        // Empty schema page at block 1.
        var schemaPage = new BinaryBuffer();
        schemaPage.initWithCapacity(PAGE_SIZE);
        schemaPage.writeByte(PAGE_TYPE_SCHEMA);
        schemaPage.writeInt32(0);  // table count
        writePageToFile(1, schemaPage);

        pageCount = 2;
        freeListHead = INVALID_PAGE_ID;
        schemaPageId = 1;
        isOpen = true;

        return true;
    }

    /// @brief Open an existing database file.
    ///
    /// Reads page 0 and validates magic + version, then populates
    /// cached header fields.  Returns false on: missing file, bad
    /// magic (not a ViperSQL file), unreadable.  Caller should
    /// fall back to `createDatabase` on "missing" errors.
    expose func openDatabase(fname: String) -> Boolean {
        filename = fname;

        if IO.File.Exists(fname) == false {
            return false;
        }

        var hdr = new BinaryBuffer();
        hdr.initWithCapacity(PAGE_SIZE);
        if readPageIntoBuffer(0, hdr) == false {
            return false;
        }

        hdr.seek(HEADER_MAGIC_OFFSET);
        if verifyHeaderMagic(hdr) == false {
            return false;
        }

        hdr.seek(HEADER_VERSION_OFFSET);
        fileVersion = hdr.readInt32();

        hdr.seek(HEADER_PAGE_COUNT_OFFSET);
        pageCount = hdr.readInt64();

        hdr.seek(HEADER_SCHEMA_PAGE_OFFSET);
        schemaPageId = hdr.readInt64();

        hdr.seek(HEADER_FREELIST_HEAD_OFFSET);
        freeListHead = hdr.readInt64();

        isOpen = true;
        return true;
    }

    /// @brief Write the in-memory header (pageCount, freeListHead,
    ///        etc.) back to page 0.
    ///
    /// Called by the buffer pool on flushAll and closeDatabase.
    /// Idempotent ŌĆö calling repeatedly is harmless; writes the
    /// same magic + current counters every time.
    expose func flushHeader() {
        if isOpen == false { return; }
        var header = new BinaryBuffer();
        header.initWithCapacity(PAGE_SIZE);

        writeHeaderMagic(header);

        header.seek(HEADER_VERSION_OFFSET);
        header.writeInt32(fileVersion);

        header.seek(HEADER_PAGE_SIZE_OFFSET);
        header.writeInt32(PAGE_SIZE);

        header.seek(HEADER_PAGE_COUNT_OFFSET);
        header.writeInt64(pageCount);

        header.seek(HEADER_SCHEMA_PAGE_OFFSET);
        header.writeInt64(schemaPageId);

        header.seek(HEADER_FREELIST_HEAD_OFFSET);
        header.writeInt64(freeListHead);

        writePageToFile(0, header);
    }

    /// @brief Close the database.  Flushes the header one last
    ///        time so the counters on disk match RAM.
    expose func closeDatabase() {
        if isOpen {
            flushHeader();
        }
        isOpen = false;
    }

    //=========================================================================
    // PAGE ALLOCATION
    //=========================================================================

    /// @brief Allocate a new page id.
    ///
    /// Two strategies:
    ///   1. Pop the freelist if non-empty.  The head page's first
    ///      bytes are `[type | nextId]`; we read the next pointer
    ///      and take that head as our new page.
    ///   2. Extend the file: return `pageCount`, then bump it.
    ///      The page is not yet written; the caller fills it in
    ///      and eventually `writePage` emits it.
    expose func allocatePage() -> Integer {
        if freeListHead != INVALID_PAGE_ID {
            var pageId = freeListHead;
            var fp = new BinaryBuffer();
            fp.initWithCapacity(PAGE_SIZE);
            if readPageIntoBuffer(pageId, fp) {
                fp.seek(1);  // skip the type byte
                freeListHead = fp.readInt64();
            } else {
                // I/O failure ŌĆö defensively truncate the freelist.
                freeListHead = INVALID_PAGE_ID;
            }
            return pageId;
        }

        var newPageId = pageCount;
        pageCount = pageCount + 1;
        return newPageId;
    }

    /// @brief Push a page onto the freelist.
    ///
    /// Overwrites the page's first 9 bytes with
    /// `[ PAGE_TYPE_FREELIST | prev-head ]`, then installs this
    /// page id as the new head.  The rest of the page's bytes are
    /// untouched ŌĆö by convention, freed pages are trash until
    /// reallocated.
    expose func freePage(pageId: Integer) {
        var page = new BinaryBuffer();
        page.initWithCapacity(PAGE_SIZE);
        page.writeByte(PAGE_TYPE_FREELIST);
        page.writeInt64(freeListHead);
        writePageToFile(pageId, page);
        freeListHead = pageId;
    }

    //=========================================================================
    // PAGE I/O
    //=========================================================================

    /// @brief Read a page from disk into a fresh `Page` object.
    ///
    /// Returns null on out-of-range page id or I/O error.  The
    /// type byte (byte 0) is decoded into `page.pageType` so
    /// callers can cheaply dispatch without re-reading.
    expose func readPage(pageId: Integer) -> Page? {
        if pageId < 0 || pageId >= pageCount {
            return null;
        }

        var page = new Page();
        page.init();
        page.pageId = pageId;

        if readPageIntoBuffer(pageId, page.data) == false {
            return null;
        }

        page.data.seek(0);
        page.pageType = page.data.readByte();

        return page;
    }

    /// @brief Read PAGE_SIZE bytes at the given page's file offset
    ///        into an existing buffer.  Low-level helper used by
    ///        `readPage` and `openDatabase`.
    ///
    /// Opens the file, seeks, reads, closes ŌĆö one-shot.  Returns
    /// false on any I/O hiccup; callers treat that as a corrupt-
    /// file indicator.
    hide func readPageIntoBuffer(pageId: Integer, dest: BinaryBuffer) -> Boolean {
        if IO.File.Exists(filename) == false {
            return false;
        }

        var f = IO.BinFile.Open(filename, "r");
        var fileSize = f.Size;
        var startOffset = pageId * PAGE_SIZE;

        if startOffset + PAGE_SIZE > fileSize {
            f.Close();
            return false;
        }

        f.Seek(startOffset, 0);
        var raw = Collections.Bytes.New(PAGE_SIZE);
        var nread = f.Read(raw, 0, PAGE_SIZE);
        f.Close();

        if nread < PAGE_SIZE {
            return false;
        }

        // Copy raw bytes into the caller's BinaryBuffer, growing
        // the backing list if it was smaller than PAGE_SIZE.
        var bytes = dest.getBytes();
        while bytes.count() < PAGE_SIZE {
            bytes.add(0);
        }
        var i = 0;
        while i < PAGE_SIZE {
            bytes.set(i, Collections.Bytes.Get(raw, i));
            i = i + 1;
        }
        dest.seek(0);
        return true;
    }

    /// @brief Persist an in-memory `Page` to its file slot.
    ///
    /// Stamps the type byte at offset 0 (so it always matches
    /// `pageType`), writes the 4-KB buffer to disk, and clears
    /// the dirty flag.  Returns false for pages with
    /// INVALID_PAGE_ID (no slot to write to).
    expose func writePage(page: Page) -> Boolean {
        if page.pageId == INVALID_PAGE_ID {
            return false;
        }

        page.data.seek(0);
        page.data.writeByte(page.pageType);

        writePageToFile(page.pageId, page.data);
        page.dirty = false;
        return true;
    }

    //=========================================================================
    // LOW-LEVEL FILE I/O
    //=========================================================================

    /// @brief Write `buf`'s first PAGE_SIZE bytes to the file at
    ///        `pageId * PAGE_SIZE`.
    ///
    /// Handles three cases:
    ///   1. File doesn't exist yet ŌĆö `createDatabase`'s very first
    ///      call.  Open with mode `w`, pad with zero bytes if this
    ///      page is past offset 0, then write the payload.
    ///   2. File exists, but the target offset is past EOF ŌĆö pad
    ///      with zeros to extend, then write.
    ///   3. File exists and target offset is within EOF ŌĆö seek and
    ///      overwrite in place.
    ///
    /// Explicit `f.Flush()` before `Close` to push the write
    /// through OS buffers.  Not fsync ŌĆö that's more than we need
    /// for the demo's durability story.
    hide func writePageToFile(pageId: Integer, buf: BinaryBuffer) {
        var startOffset = pageId * PAGE_SIZE;

        // Convert our BinaryBuffer bytes into a Bytes object for
        // BinFile.Write.  Missing bytes (if `buf` is shorter than
        // PAGE_SIZE) become zeros.
        var raw = Collections.Bytes.New(PAGE_SIZE);
        var bytes = buf.getBytes();
        var i = 0;
        while i < PAGE_SIZE {
            var b = 0;
            if i < bytes.count() {
                b = bytes.get(i);
            }
            Collections.Bytes.Set(raw, i, b);
            i = i + 1;
        }

        if IO.File.Exists(filename) == false {
            var f = IO.BinFile.Open(filename, "w");
            if startOffset > 0 {
                var zeros = Collections.Bytes.New(startOffset);
                f.Write(zeros, 0, startOffset);
            }
            f.Write(raw, 0, PAGE_SIZE);
            f.Flush();
            f.Close();
        } else {
            var f = IO.BinFile.Open(filename, "rw");
            var fileSize = f.Size;
            if startOffset > fileSize {
                f.Seek(fileSize, 0);
                var padLen = startOffset - fileSize;
                var zeros = Collections.Bytes.New(padLen);
                f.Write(zeros, 0, padLen);
            }
            f.Seek(startOffset, 0);
            f.Write(raw, 0, PAGE_SIZE);
            f.Flush();
            f.Close();
        }
    }

    //=========================================================================
    // HEADER MAGIC
    //=========================================================================

    /// @brief Write the 8-byte magic string "VIPERSQL" at the
    ///        configured HEADER_MAGIC_OFFSET (= 0).  Hard-coded
    ///        bytes ŌĆö see design choice 5.
    hide func writeHeaderMagic(buf: BinaryBuffer) {
        buf.seek(HEADER_MAGIC_OFFSET);
        buf.writeByte(86);   // V
        buf.writeByte(73);   // I
        buf.writeByte(80);   // P
        buf.writeByte(69);   // E
        buf.writeByte(82);   // R
        buf.writeByte(83);   // S
        buf.writeByte(81);   // Q
        buf.writeByte(76);   // L
    }

    /// @brief Check that the next 8 bytes are "VIPERSQL".  Any
    ///        mismatch returns false ŌĆö `openDatabase` turns that
    ///        into a "not a ViperSQL file" error.
    hide func verifyHeaderMagic(buf: BinaryBuffer) -> Boolean {
        if buf.readByte() != 86 { return false; }
        if buf.readByte() != 73 { return false; }
        if buf.readByte() != 80 { return false; }
        if buf.readByte() != 69 { return false; }
        if buf.readByte() != 82 { return false; }
        if buf.readByte() != 83 { return false; }
        if buf.readByte() != 81 { return false; }
        if buf.readByte() != 76 { return false; }
        return true;
    }

    /// @brief Page id of the schema/catalog page.  Captured from
    ///        the header on open; referenced by the engine when
    ///        reconstructing table metadata.
    expose func getSchemaPageId() -> Integer {
        return schemaPageId;
    }
}
