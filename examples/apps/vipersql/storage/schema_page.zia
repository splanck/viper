// =============================================================================
// schema_page.zia — The catalog: table and index metadata on disk
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// The ViperSQL file format keeps the CREATE TABLE / CREATE INDEX
// catalog inline with the data in a dedicated `PAGE_TYPE_SCHEMA`
// page (page 1 by default; see `pager.zia`).  This file owns that
// page's layout and the operations on it:
//
//   * `TableMeta` / `IndexMeta` — in-memory records that mirror the
//                                 on-disk table/index entries.
//   * `SchemaPageManager`       — reads, writes, searches, adds,
//                                 and removes entries in the schema
//                                 page.
//
// Layout of a schema page:
//
//     [0]      PAGE_TYPE_SCHEMA (1 byte)
//     [1..4]   table count (int32)
//     [5..12]  next schema page id (int64, INVALID_PAGE_ID = none)
//     [13..]   table-meta entries (variable width)
//     ...      int32 index count (optional, back-compat safe)
//     ...      index-meta entries (variable width)
//
// WHERE THIS FITS
// ---------------
//     storage/engine.zia        (high-level facade — CREATE TABLE,
//                                DROP INDEX, etc. call us to
//                                persist metadata)
//         │
//         ▼
//     storage/schema_page.zia   (YOU ARE HERE)
//         │
//         ▼
//     storage/serializer.zia    (ColumnSerializer for per-column
//                                encode/decode)
//     storage/page.zia          (page-type constants)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Tables and indexes share one schema page.  That simplifies
//      "open this file" logic (we only need to find page 1) at the
//      cost of a single-point bottleneck: bulk CREATE TABLE / DROP
//      TABLE rewrites the whole page.  Fine for demo workloads.
//
//   2. `writeAllTables` reads indexes first, then delegates to
//      `writeAllWithIndexes` to preserve them.  We do NOT have a
//      way to update only the table region — the whole page is
//      rewritten — so we must reconstruct the index region each
//      time.
//
//   3. Back-compat safe index count.  `readAllIndexes` tolerates
//      old schema pages written before the index region existed:
//      `buf.readInt32()` past the written data returns 0 via
//      `BinaryBuffer.readByte`'s EOF-returns-0 behaviour, and
//      `indexCount <= 0` short-circuits.  So a database created
//      before indexes were added still opens.
//
//   4. Table ids are monotonic per database.  `addTable` scans
//      the existing entries, finds the max id, and assigns
//      `maxId + 1`.  Dropping a table does *not* free the id —
//      we never reuse, so WAL / backups do not need to chase
//      id-reassignment edge cases.  Same rule for index ids.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `IndexMeta` — thin data class.
//   2. `TableMeta` — with helpers `initFromTable` (Table → meta)
//      and `toTable` (meta → Table).
//   3. `SchemaPageManager` — header accessors, table CRUD, index
//      CRUD, and the combined `writeAllWithIndexes` used under the
//      covers.
//
// =============================================================================

module schema_page;

bind "./page";
bind "./serializer";
bind "./pager";
bind "../engine/table";
bind "../engine/schema";

//=============================================================================
// INDEX METADATA ENTITY
//=============================================================================

// Represents index metadata stored in schema pages (Phase 10)
/// @brief On-disk shape of one CREATE INDEX entry.
///
/// `btreeRootPageId` is the root page of the associated B-tree
/// (if any).  Today's build does not yet tie `CREATE INDEX` to
/// the B-tree implementation in `./btree.zia` — the field is kept
/// here so the plumbing is ready when that wiring happens.
class IndexMeta {
    expose Integer indexId;
    expose String indexName;
    expose String tableName;
    expose List[String] columnNames;
    expose Boolean isUnique;
    expose Integer btreeRootPageId;

    /// @brief Zero-state init.  Fields are populated directly by
    ///        the DDL path or by `deserializeIndexMeta`.
    expose func init() {
        indexId = 0;
        indexName = "";
        tableName = "";
        columnNames = [];
        isUnique = false;
        btreeRootPageId = INVALID_PAGE_ID;
    }
}

//=============================================================================
// TABLE METADATA ENTITY
//=============================================================================

// Represents table metadata stored in schema pages
/// @brief On-disk shape of one CREATE TABLE entry.
///
/// `firstDataPage` heads the linked list of data pages for this
/// table; `nextAutoIncrement` is the next value the sequence
/// would hand out (persists AUTOINCREMENT across restarts);
/// `rowCount` is a cached approximate count (refreshed at write
/// time — not transactionally consistent during replay).
class TableMeta {
    expose Integer tableId;
    expose String tableName;
    expose Integer firstDataPage;
    expose Integer columnCount;
    expose List[Column] columns;
    expose Integer rowCount;
    expose Integer nextAutoIncrement;

    /// @brief Empty meta: no columns, INVALID_PAGE_ID head,
    ///        AUTOINCREMENT starting at 1.
    expose func init() {
        tableId = 0;
        tableName = "";
        firstDataPage = INVALID_PAGE_ID;
        columnCount = 0;
        columns = [];
        rowCount = 0;
        nextAutoIncrement = 1;
    }

    /// @brief Snapshot an in-memory `Table` into a meta record.
    ///
    /// Copies columns by reference (they are immutable once a
    /// table is created), and captures the current autoIncrement
    /// counter so the persisted sequence resumes correctly.
    expose func initFromTable(id: Integer, table: Table) {
        tableId = id;
        tableName = table.name;
        firstDataPage = INVALID_PAGE_ID;
        columnCount = table.columnCount();
        columns = [];

        var i = 0;
        while i < table.columnCount() {
            var maybeCol = table.getColumn(i);
            if maybeCol != null {
                var col = maybeCol;
                columns.add(col);
            }
            i = i + 1;
        }

        rowCount = table.rowCount();
        nextAutoIncrement = table.autoIncrementValue;
    }

    /// @brief Rehydrate a `Table` from this meta on open.
    ///
    /// Columns and autoIncrement flow through; rows come later
    /// via the data-page walker — this method returns an empty
    /// table, not one pre-filled with data.
    expose func toTable() -> Table {
        var table = new Table();
        table.initWithName(tableName);

        var i = 0;
        while i < columns.count() {
            var col = columns.get(i);
            table.addColumn(col);
            i = i + 1;
        }

        table.autoIncrementValue = nextAutoIncrement;
        return table;
    }
}

//=============================================================================
// SCHEMA PAGE MANAGER
//=============================================================================

// Manages table catalog in schema pages
// Schema page layout:
//   [0]: Page type (1 byte) = PAGE_TYPE_SCHEMA
//   [1-4]: Table count (4 bytes)
//   [5-12]: Next schema page ID (8 bytes)
//   [13...]: Table metadata entries

/// @brief Read/write/update the schema-page table+index catalog.
///
/// Stateless except for a cached `ColumnSerializer`.  Every
/// operation takes a `Page` — the caller is the
/// `BufferPool`/`StorageEngine`, which fetched the schema page
/// first.
class SchemaPageManager {
    hide ColumnSerializer colSer;

    /// @brief Cache a `ColumnSerializer` for reuse across every
    ///        call.  Stateless; per-call allocation would be
    ///        wasteful on the hot DDL path.
    expose func init() {
        colSer = new ColumnSerializer();
        colSer.init();
    }

    //=========================================================================
    // PAGE INITIALIZATION
    //=========================================================================

    /// @brief Lay down the 13-byte header of an empty schema
    ///        page: type byte, zero tables, no next-page link.
    expose func initSchemaPage(page: Page) {
        page.pageType = PAGE_TYPE_SCHEMA;
        page.data.seek(0);

        // Page type
        page.data.writeByte(PAGE_TYPE_SCHEMA);

        // Table count
        page.data.writeInt32(0);

        // Next schema page ID (none)
        page.data.writeInt64(INVALID_PAGE_ID);

        page.markDirty();
    }

    //=========================================================================
    // PAGE METADATA
    //=========================================================================

    /// @brief Read the cached table count from bytes [1..5).
    expose func getTableCount(page: Page) -> Integer {
        page.data.seek(1);
        return page.data.readInt32();
    }

    /// @brief Write the table count.  Hidden — callers go
    ///        through `writeAllWithIndexes`, which owns the
    ///        page-rewrite sequencing.
    hide func setTableCount(page: Page, count: Integer) {
        page.data.seek(1);
        page.data.writeInt32(count);
        page.markDirty();
    }

    /// @brief Page id of the next schema page in the chain, or
    ///        INVALID_PAGE_ID if this is the last.  Today there
    ///        is only ever one schema page; the linkage is
    ///        reserved for future "schema pages that overflow".
    expose func getNextSchemaPage(page: Page) -> Integer {
        page.data.seek(5);
        return page.data.readInt64();
    }

    /// @brief Update the next-schema-page pointer.  Reserved for
    ///        the future overflow story described above.
    expose func setNextSchemaPage(page: Page, nextId: Integer) {
        page.data.seek(5);
        page.data.writeInt64(nextId);
        page.markDirty();
    }

    //=========================================================================
    // TABLE METADATA SERIALIZATION
    //=========================================================================

    /// @brief Write one `TableMeta` into a byte buffer.
    ///
    /// Layout (all little-endian):
    ///     int32 tableId | string tableName | int64 firstDataPage
    ///   | int32 columnCount | Column * columnCount
    ///   | int64 rowCount | int64 nextAutoIncrement
    expose func serializeTableMeta(meta: TableMeta, buf: BinaryBuffer) {
        buf.writeInt32(meta.tableId);
        buf.writeString(meta.tableName);
        buf.writeInt64(meta.firstDataPage);
        buf.writeInt32(meta.columnCount);

        // Serialize each column
        var i = 0;
        while i < meta.columns.count() {
            var col = meta.columns.get(i);
            colSer.serializeColumn(col, buf);
            i = i + 1;
        }

        buf.writeInt64(meta.rowCount);
        buf.writeInt64(meta.nextAutoIncrement);
    }

    /// @brief Inverse of `serializeTableMeta`.  Reads exactly the
    ///        same field sequence.
    expose func deserializeTableMeta(buf: BinaryBuffer) -> TableMeta {
        var meta = new TableMeta();
        meta.init();

        meta.tableId = buf.readInt32();
        meta.tableName = buf.readString();
        meta.firstDataPage = buf.readInt64();
        meta.columnCount = buf.readInt32();

        // Deserialize columns
        var i = 0;
        while i < meta.columnCount {
            var col = colSer.deserializeColumn(buf);
            meta.columns.add(col);
            i = i + 1;
        }

        meta.rowCount = buf.readInt64();
        meta.nextAutoIncrement = buf.readInt64();

        return meta;
    }

    //=========================================================================
    // SCHEMA PAGE OPERATIONS
    //=========================================================================

    /// @brief Load every TableMeta from the page.  Skips over
    ///        the 13-byte header, then deserialises `tableCount`
    ///        entries.  Stops before the index region.
    expose func readAllTables(page: Page) -> List[TableMeta] {
        var tables: List[TableMeta] = [];
        var tableCount = getTableCount(page);

        page.data.seek(13);  // Start of table entries

        var i = 0;
        while i < tableCount {
            var meta = deserializeTableMeta(page.data);
            tables.add(meta);
            i = i + 1;
        }

        return tables;
    }

    /// @brief Rewrite the page's table region, preserving index
    ///        metadata.
    ///
    /// Reads the existing indexes first so we can feed them back
    /// through `writeAllWithIndexes`.  Inefficient for single-
    /// table updates (whole page gets rebuilt), but simple and
    /// correct — design choice 2.
    expose func writeAllTables(page: Page, tables: List[TableMeta]) {
        // Read existing indexes before rewriting, so they are preserved
        var indexes = readAllIndexes(page);
        writeAllWithIndexes(page, tables, indexes);
    }

    /// @brief Linear name lookup.  Null if not present.  Used by
    ///        `engine/ddl.zia` to detect duplicate CREATE TABLE.
    expose func findTable(page: Page, tableName: String) -> TableMeta? {
        var tables = readAllTables(page);

        var i = 0;
        while i < tables.count() {
            var meta = tables.get(i);
            if meta.tableName == tableName {
                return meta;
            }
            i = i + 1;
        }

        return null;
    }

    /// @brief Linear id lookup.  Useful during data-page scans
    ///        which encode only the numeric table id.
    expose func findTableById(page: Page, tableId: Integer) -> TableMeta? {
        var tables = readAllTables(page);

        var i = 0;
        while i < tables.count() {
            var meta = tables.get(i);
            if meta.tableId == tableId {
                return meta;
            }
            i = i + 1;
        }

        return null;
    }

    /// @brief Register a new table.  Returns false if the name
    ///        is already taken.
    ///
    /// Assigns a fresh monotonic id (`maxExistingId + 1`) so the
    /// caller does not have to.  Rewrites the whole page via
    /// `writeAllTables`.
    expose func addTable(page: Page, meta: TableMeta) -> Boolean {
        var tables = readAllTables(page);

        // Check if table already exists
        var i = 0;
        while i < tables.count() {
            var existing = tables.get(i);
            if existing.tableName == meta.tableName {
                return false;  // Already exists
            }
            i = i + 1;
        }

        // Assign table ID
        var maxId = 0;
        i = 0;
        while i < tables.count() {
            var t = tables.get(i);
            if t.tableId > maxId {
                maxId = t.tableId;
            }
            i = i + 1;
        }
        meta.tableId = maxId + 1;

        tables.add(meta);
        writeAllTables(page, tables);
        return true;
    }

    /// @brief Replace the meta for a known table id.  False if
    ///        the id isn't present.  Used by ALTER TABLE and by
    ///        every DML commit that touches autoIncrement /
    ///        rowCount / firstDataPage.
    expose func updateTable(page: Page, meta: TableMeta) -> Boolean {
        var tables = readAllTables(page);

        var i = 0;
        while i < tables.count() {
            var existing = tables.get(i);
            if existing.tableId == meta.tableId {
                tables.set(i, meta);
                writeAllTables(page, tables);
                return true;
            }
            i = i + 1;
        }

        return false;  // Not found
    }

    /// @brief DROP TABLE.  Removes the entry by name, preserves
    ///        indexes (which the caller is expected to have
    ///        already dropped).  Returns true if anything was
    ///        removed.
    expose func removeTable(page: Page, tableName: String) -> Boolean {
        var tables = readAllTables(page);
        var newTables: List[TableMeta] = [];
        var found = false;

        var i = 0;
        while i < tables.count() {
            var meta = tables.get(i);
            if meta.tableName == tableName {
                found = true;
            } else {
                newTables.add(meta);
            }
            i = i + 1;
        }

        if found {
            writeAllTables(page, newTables);
        }
        return found;
    }

    /// @brief Compute the next available table id without
    ///        performing a write.  Useful to the DDL layer when
    ///        it needs an id before the `TableMeta` is finalised.
    expose func getNextTableId(page: Page) -> Integer {
        var tables = readAllTables(page);
        var maxId = 0;

        var i = 0;
        while i < tables.count() {
            var t = tables.get(i);
            if t.tableId > maxId {
                maxId = t.tableId;
            }
            i = i + 1;
        }

        return maxId + 1;
    }

    //=========================================================================
    // INDEX METADATA SERIALIZATION (Phase 10)
    //=========================================================================

    /// @brief Write one `IndexMeta`.
    ///
    /// Layout:
    ///     int32 indexId | string indexName | string tableName
    ///   | int32 columnCount | string * columnCount
    ///   | byte isUnique (0/1)
    ///   | int64 btreeRootPageId
    expose func serializeIndexMeta(meta: IndexMeta, buf: BinaryBuffer) {
        buf.writeInt32(meta.indexId);
        buf.writeString(meta.indexName);
        buf.writeString(meta.tableName);
        buf.writeInt32(meta.columnNames.count());
        var i = 0;
        while i < meta.columnNames.count() {
            buf.writeString(meta.columnNames.get(i));
            i = i + 1;
        }
        if meta.isUnique {
            buf.writeByte(1);
        } else {
            buf.writeByte(0);
        }
        buf.writeInt64(meta.btreeRootPageId);
    }

    /// @brief Inverse of `serializeIndexMeta`.
    expose func deserializeIndexMeta(buf: BinaryBuffer) -> IndexMeta {
        var meta = new IndexMeta();
        meta.init();
        meta.indexId = buf.readInt32();
        meta.indexName = buf.readString();
        meta.tableName = buf.readString();
        var colCount = buf.readInt32();
        var i = 0;
        while i < colCount {
            meta.columnNames.add(buf.readString());
            i = i + 1;
        }
        var uniqueByte = buf.readByte();
        meta.isUnique = uniqueByte == 1;
        meta.btreeRootPageId = buf.readInt64();
        return meta;
    }

    /// @brief Load every `IndexMeta` from the page.
    ///
    /// Positions past the table region by re-running
    /// `deserializeTableMeta` the appropriate number of times
    /// (we don't store byte offsets, only counts), then reads
    /// the int32 index count and `indexCount` entries.
    ///
    /// Backwards-compatible: old databases written before the
    /// index region existed will have EOF where the int32 count
    /// should be; `BinaryBuffer.readByte` returns 0 past EOF,
    /// so `indexCount` comes back 0 and we return an empty list.
    expose func readAllIndexes(page: Page) -> List[IndexMeta] {
        var indexes: List[IndexMeta] = [];
        var tableCount = getTableCount(page);

        // Seek past header and read tables to advance buffer position
        page.data.seek(13);
        var i = 0;
        while i < tableCount {
            deserializeTableMeta(page.data);
            i = i + 1;
        }

        // Now read index count and index entries (if present)
        // Check if there's data remaining (backwards-compatible with old schema pages)
        var indexCount = page.data.readInt32();
        if indexCount <= 0 {
            return indexes;
        }

        i = 0;
        while i < indexCount {
            var meta = deserializeIndexMeta(page.data);
            indexes.add(meta);
            i = i + 1;
        }

        return indexes;
    }

    /// @brief Full page rewrite: header, table entries, then
    ///        index entries.  The canonical "atomic" schema-page
    ///        update — every CRUD flow funnels through here so the
    ///        on-disk layout is always consistent.
    expose func writeAllWithIndexes(page: Page, tables: List[TableMeta], indexes: List[IndexMeta]) {
        initSchemaPage(page);
        setTableCount(page, tables.count());

        page.data.seek(13);

        // Write table entries
        var i = 0;
        while i < tables.count() {
            var meta = tables.get(i);
            serializeTableMeta(meta, page.data);
            i = i + 1;
        }

        // Write index entries
        page.data.writeInt32(indexes.count());
        i = 0;
        while i < indexes.count() {
            serializeIndexMeta(indexes.get(i), page.data);
            i = i + 1;
        }

        page.markDirty();
    }

    /// @brief CREATE INDEX.  Returns false on duplicate name.
    ///        Assigns a monotonic id like `addTable`, then
    ///        delegates to `writeAllWithIndexes` (caller passes
    ///        the current table list to preserve it).
    expose func addIndex(page: Page, meta: IndexMeta, tables: List[TableMeta]) -> Boolean {
        var indexes = readAllIndexes(page);

        // Check for duplicate
        var i = 0;
        while i < indexes.count() {
            var existing = indexes.get(i);
            if existing.indexName == meta.indexName {
                return false;
            }
            i = i + 1;
        }

        // Assign index ID
        var maxId = 0;
        i = 0;
        while i < indexes.count() {
            var idx = indexes.get(i);
            if idx.indexId > maxId {
                maxId = idx.indexId;
            }
            i = i + 1;
        }
        meta.indexId = maxId + 1;

        indexes.add(meta);
        writeAllWithIndexes(page, tables, indexes);
        return true;
    }

    /// @brief DROP INDEX.  Removes by name, preserving tables.
    ///        Symmetric to `removeTable`.
    expose func removeIndex(page: Page, indexName: String, tables: List[TableMeta]) -> Boolean {
        var indexes = readAllIndexes(page);
        var newIndexes: List[IndexMeta] = [];
        var found = false;

        var i = 0;
        while i < indexes.count() {
            var meta = indexes.get(i);
            if meta.indexName == indexName {
                found = true;
            } else {
                newIndexes.add(meta);
            }
            i = i + 1;
        }

        if found {
            writeAllWithIndexes(page, tables, newIndexes);
        }
        return found;
    }
}
