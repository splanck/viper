// =============================================================================
// wal.zia — ARIES-style Write-Ahead Log for crash recovery
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// Durability in ViperSQL is built on a classic write-ahead log.
// Every mutation (INSERT, UPDATE, DELETE, BEGIN, COMMIT, ABORT,
// CHECKPOINT) is appended to a log file *before* being applied to
// the data pages.  On crash, we replay the log to bring the
// database to the last committed state.
//
// This file hosts:
//
//   * `LSN`           — (fileNum, offset) log sequence number with
//                       3-way compare.
//   * `LogRecord`     — one log entry (type + txn id + payload).
//   * `LogSerializer` — binary encode/decode for log records.
//   * `WAL`           — the append-only log manager: `logBegin`,
//                       `logCommit`, `logInsert`, `logUpdate`,
//                       `logDelete`, `logCLR`, `checkpoint`,
//                       `flush`, plus the `recover()` entry point
//                       that runs the three ARIES phases.
//   * `RecoveryResult` — summary bundle returned from `recover()`.
//
// The WAL is managed as a sequence of flat files on disk; each
// file holds a `LOG_FILES_ROTATION_BYTES` worth of records before
// we rotate to a new one.  `LSN` encodes both the file number and
// the offset within that file.
//
// WHERE THIS FITS
// ---------------
//     engine/dml.zia / engine/executor.zia
//         │  every mutation calls logInsert / logUpdate / logDelete
//         │  *before* touching the heap, and logCommit at txn end.
//         ▼
//     storage/txn.zia       (manages LSN chains per active txn)
//         │
//         ▼
//     storage/wal.zia       (YOU ARE HERE)
//         │  crash-time recovery:
//         │    1. Analysis — scan forward, collect activeTxns +
//         │                  committedTxns lists.
//         │    2. Redo     — re-apply every record (idempotent; the
//         │                  data page's page LSN gates re-apply).
//         │    3. Undo     — roll back uncommitted txns using the
//         │                  before-images stored in UPDATE/DELETE
//         │                  records, writing CLRs as we go.
//         ▼
//     storage/data_page.zia, btree.zia, schema_page.zia (appliers)
//
// LOG RECORD LAYOUT
// -----------------
//     int32  LSN offset (in file)
//     byte   record type (LOG_*)
//     int32  transaction id
//     ...    payload (record-type-dependent)
//
// INSERT/UPDATE/DELETE payloads:
//     int32  table id | int64 page id | int32 slot id | row bytes
// (UPDATE carries both before-image and after-image, in that order)
//
// CHECKPOINT payload:
//     int32  active txn count | int32 * txns (active at checkpoint)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Sequential append-only.  A single file grows until it hits
//      the rotation threshold, then we open file N+1.  Simple,
//      fast, and easy to recover.
//
//   2. Compensation Log Records (CLRs).  When we undo a change
//      during recovery, we write a CLR.  On *re-crash* during
//      recovery, we skip undo for any record whose CLR is present
//      — preventing the classic ARIES "undo twice" bug.
//
//   3. Thread safety by single Monitor lock.  The WAL is a
//      shared resource; every public entry point enters the lock,
//      does its work, and exits.  This serialises log writes
//      across all sessions but is not a bottleneck — the
//      bottleneck is fsync, not in-process contention.
//
//   4. Before-images carried in UPDATE/DELETE records.  That makes
//      undo trivial (just reinstall the before-image) at the cost
//      of record size.  For INSERT, undo is equivalent to DELETE
//      of the just-inserted slot, so no before-image is stored.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Record-type constants and rotation threshold.
//   2. `LSN` — with `compare`, and `toString` for diagnostics.
//   3. `LogRecord` — eight `init*` specialisations, one per type.
//   4. `LogSerializer` — encode, decode, size estimate.
//   5. `WAL` — fields, init, `append*` helpers, each log* method,
//      checkpoint/flush/rotate, and the `recover()` driver.
//   6. `RecoveryResult` at the end.
//
// =============================================================================

module wal;

bind Viper.IO as IO;
bind Viper.String as String;
bind Viper.Fmt as Fmt;
bind Viper.Threads as Threads;
bind "./page";
bind "./serializer";

//=============================================================================
// WAL CONSTANTS
//=============================================================================

// Log record types
final LOG_BEGIN = 1;       // Transaction begin
final LOG_COMMIT = 2;      // Transaction commit
final LOG_ABORT = 3;       // Transaction abort
final LOG_INSERT = 4;      // Row insert
final LOG_UPDATE = 5;      // Row update
final LOG_DELETE = 6;      // Row delete
final LOG_CHECKPOINT = 7;  // Checkpoint marker
final LOG_PAGE_WRITE = 8;  // Full page write (for redo)
final LOG_CLR = 9;         // Compensation Log Record (undo complete marker)

// WAL configuration
final WAL_BUFFER_SIZE = 65536;  // 64KB log buffer
final WAL_MAX_FILE_SIZE = 10485760;  // 10MB before rotation

//=============================================================================
// LOG SEQUENCE NUMBER (LSN)
//=============================================================================

/// @brief Log Sequence Number: the (fileNum, offset) pair that
///        uniquely identifies a log-record position.
///
/// Ordered lexicographically by (fileNumber, offset) — higher
/// file number always wins regardless of offset.  Used as the
/// "durability cursor" throughout the engine: a page flushed to
/// disk carries the LSN of the last log record that modified it,
/// and recovery re-applies only records with LSN > pageLSN.
class LSN {
    expose Integer fileNumber;
    expose Integer offset;

    /// @brief Zero LSN: (0, 0) — before any log record.
    expose func init() {
        fileNumber = 0;
        offset = 0;
    }

    /// @brief Construct with explicit (file, offset).
    expose func initWith(file: Integer, off: Integer) {
        fileNumber = file;
        offset = off;
    }

    /// @brief 3-way compare: -1, 0, 1.  File number dominates
    ///        offset — all records in file 2 are greater than any
    ///        record in file 1.
    expose func compare(other: LSN) -> Integer {
        if fileNumber < other.fileNumber {
            return -1;
        }
        if fileNumber > other.fileNumber {
            return 1;
        }
        if offset < other.offset {
            return -1;
        }
        if offset > other.offset {
            return 1;
        }
        return 0;
    }

    /// @brief "N:off" rendering used in diagnostic output.
    expose func toString() -> String {
        return Fmt.Int(fileNumber) + ":" + Fmt.Int(offset);
    }
}

//=============================================================================
// LOG RECORD
//=============================================================================

/// @brief One log record.  Discriminated by `recordType` — one of
///        the `LOG_*` constants at the top of this file.
///
/// Payload slots (`tableId`, `pageId`, `slotId`, `beforeImage`,
/// `afterImage`) are populated selectively depending on the type:
///   * BEGIN / COMMIT / ABORT: only `txnId`.
///   * INSERT:  txnId, tableId, pageId, slotId, afterImage (new row).
///   * UPDATE:  same, plus `beforeImage` (old row bytes).
///   * DELETE:  txnId, tableId, pageId, slotId, beforeImage (row
///              we removed — needed to undo).
///   * CLR:     txnId, tableId, pageId, slotId, afterImage carries
///              the type of the record we undid (for diagnostics).
///   * CHECKPOINT: afterImage carries the active-txn list.
///
/// The many `init*` methods below just populate different slot
/// combinations.  Read any one to understand them all.
class LogRecord {
    expose LSN lsn;              // Position in log
    expose Integer recordType;   // LOG_* constant
    expose Integer txnId;        // Transaction ID
    expose Integer tableId;      // Table ID (for data operations)
    expose Integer pageId;       // Page ID (for page writes)
    expose Integer slotId;       // Slot ID (for row operations)

    // Data for undo/redo
    expose BinaryBuffer beforeImage;  // Data before change (for undo)
    expose BinaryBuffer afterImage;   // Data after change (for redo)

    /// @brief Zero-state init — all slots cleared.  The typed
    ///        variants below call this first before setting their
    ///        specific fields.
    expose func init() {
        lsn = new LSN();
        lsn.init();
        recordType = 0;
        txnId = 0;
        tableId = 0;
        pageId = INVALID_PAGE_ID;
        slotId = -1;
        beforeImage = new BinaryBuffer();
        beforeImage.init();
        afterImage = new BinaryBuffer();
        afterImage.init();
    }

    /// @brief Populate as BEGIN — marks `tid` entering the log.
    expose func initBegin(tid: Integer) {
        init();
        recordType = LOG_BEGIN;
        txnId = tid;
    }

    /// @brief Populate as COMMIT — `tid` is durable after this
    ///        record's LSN is flushed.
    expose func initCommit(tid: Integer) {
        init();
        recordType = LOG_COMMIT;
        txnId = tid;
    }

    /// @brief Populate as ABORT — recovery will undo `tid`'s
    ///        other records.
    expose func initAbort(tid: Integer) {
        init();
        recordType = LOG_ABORT;
        txnId = tid;
    }

    /// @brief Populate as INSERT.  `afterImage` holds the freshly
    ///        written row bytes; undo is "delete this slot" and
    ///        needs no before-image.
    expose func initInsert(tid: Integer, tblId: Integer, pid: Integer, slot: Integer, rowData: BinaryBuffer) {
        init();
        recordType = LOG_INSERT;
        txnId = tid;
        tableId = tblId;
        pageId = pid;
        slotId = slot;
        afterImage = rowData;
    }

    /// @brief Populate as UPDATE — the only record type carrying
    ///        both images.  Undo reinstalls `beforeImage`; redo
    ///        reinstalls `afterImage`.
    expose func initUpdate(tid: Integer, tblId: Integer, pid: Integer, slot: Integer, before: BinaryBuffer, after: BinaryBuffer) {
        init();
        recordType = LOG_UPDATE;
        txnId = tid;
        tableId = tblId;
        pageId = pid;
        slotId = slot;
        beforeImage = before;
        afterImage = after;
    }

    /// @brief Populate as DELETE.  `beforeImage` holds the row
    ///        we removed so undo can reinstate it.
    expose func initDelete(tid: Integer, tblId: Integer, pid: Integer, slot: Integer, rowData: BinaryBuffer) {
        init();
        recordType = LOG_DELETE;
        txnId = tid;
        tableId = tblId;
        pageId = pid;
        slotId = slot;
        beforeImage = rowData;
    }

    /// @brief Populate as CLR (Compensation Log Record).
    ///
    /// Written by recovery when it finishes undoing one of
    /// `tid`'s records.  If recovery crashes and restarts, the
    /// presence of the CLR tells it "this undo is already done"
    /// so it doesn't undo twice.  `undoneType` is stored for
    /// diagnostic readability — it is not read by recovery.
    expose func initCLR(tid: Integer, tblId: Integer, pid: Integer, slot: Integer, undoneType: Integer) {
        init();
        recordType = LOG_CLR;
        txnId = tid;
        tableId = tblId;
        pageId = pid;
        slotId = slot;
        // Store the type of record that was undone in afterImage for diagnostics
        afterImage = new BinaryBuffer();
        afterImage.init();
        afterImage.writeInt32(undoneType);
    }

    /// @brief Populate as CHECKPOINT.
    ///
    /// Snapshots the set of currently-active transactions into
    /// `afterImage`.  Recovery uses this to begin Analysis: it
    /// starts from the most recent checkpoint and threads forward
    /// using the active-txn list as its initial "who is alive".
    expose func initCheckpoint(activeTxns: List[Integer]) {
        init();
        recordType = LOG_CHECKPOINT;
        // Store active transaction IDs in afterImage
        afterImage = new BinaryBuffer();
        afterImage.init();
        afterImage.writeInt32(activeTxns.count());
        var i = 0;
        while i < activeTxns.count() {
            afterImage.writeInt64(activeTxns.get(i));
            i = i + 1;
        }
    }

    /// @brief "BEGIN" / "COMMIT" / ... for diagnostic output.
    expose func recordTypeString() -> String {
        if recordType == LOG_BEGIN { return "BEGIN"; }
        if recordType == LOG_COMMIT { return "COMMIT"; }
        if recordType == LOG_ABORT { return "ABORT"; }
        if recordType == LOG_INSERT { return "INSERT"; }
        if recordType == LOG_UPDATE { return "UPDATE"; }
        if recordType == LOG_DELETE { return "DELETE"; }
        if recordType == LOG_CHECKPOINT { return "CHECKPOINT"; }
        if recordType == LOG_PAGE_WRITE { return "PAGE_WRITE"; }
        if recordType == LOG_CLR { return "CLR"; }
        return "UNKNOWN";
    }

    /// @brief "[lsn] TYPE txn=N" for logs / debugger.
    expose func toString() -> String {
        return "[" + lsn.toString() + "] " + recordTypeString() + " txn=" + Fmt.Int(txnId);
    }
}

//=============================================================================
// LOG RECORD SERIALIZER
//=============================================================================

/// @brief Binary encode/decode for `LogRecord` to/from a byte
///        buffer.  Stateless; one instance cached on `WAL`.
class LogRecordSerializer {
    /// @brief No state; constructor is a no-op.
    expose func init() {
    }

    /// @brief Write a `LogRecord` to `buf`.
    ///
    /// Layout matches the doc in the file header: 8-byte LSN,
    /// 1-byte type, 8-byte txn id, 8-byte table id, 8-byte page
    /// id, 4-byte slot id, then length-prefixed before-image and
    /// after-image byte runs.
    expose func serialize(record: LogRecord, buf: BinaryBuffer) {
        // Record header
        buf.writeInt32(record.lsn.fileNumber);
        buf.writeInt64(record.lsn.offset);
        buf.writeByte(record.recordType);
        buf.writeInt64(record.txnId);
        buf.writeInt64(record.tableId);
        buf.writeInt64(record.pageId);
        buf.writeInt32(record.slotId);

        // Before image
        var beforeBytes = record.beforeImage.getBytes();
        buf.writeInt32(beforeBytes.count());
        var i = 0;
        while i < beforeBytes.count() {
            buf.writeByte(beforeBytes.get(i));
            i = i + 1;
        }

        // After image
        var afterBytes = record.afterImage.getBytes();
        buf.writeInt32(afterBytes.count());
        i = 0;
        while i < afterBytes.count() {
            buf.writeByte(afterBytes.get(i));
            i = i + 1;
        }
    }

    /// @brief Inverse of `serialize`.  Reads the header fields
    ///        and the two length-prefixed image runs, returning a
    ///        fresh `LogRecord`.
    expose func deserialize(buf: BinaryBuffer) -> LogRecord {
        var record = new LogRecord();
        record.init();

        // Record header
        record.lsn.fileNumber = buf.readInt32();
        record.lsn.offset = buf.readInt64();
        record.recordType = buf.readByte();
        record.txnId = buf.readInt64();
        record.tableId = buf.readInt64();
        record.pageId = buf.readInt64();
        record.slotId = buf.readInt32();

        // Before image
        var beforeLen = buf.readInt32();
        record.beforeImage = new BinaryBuffer();
        record.beforeImage.init();
        var i = 0;
        while i < beforeLen {
            record.beforeImage.writeByte(buf.readByte());
            i = i + 1;
        }

        // After image
        var afterLen = buf.readInt32();
        record.afterImage = new BinaryBuffer();
        record.afterImage.init();
        i = 0;
        while i < afterLen {
            record.afterImage.writeByte(buf.readByte());
            i = i + 1;
        }

        return record;
    }

    /// @brief Predicted byte size of `record` after `serialize`.
    ///        41-byte header + two length-prefixed images.
    expose func recordSize(record: LogRecord) -> Integer {
        // Header: 4 + 8 + 1 + 8 + 8 + 8 + 4 = 41 bytes
        // + 4 (beforeLen) + beforeImage bytes
        // + 4 (afterLen) + afterImage bytes
        return 41 + 4 + record.beforeImage.size() + 4 + record.afterImage.size();
    }
}

//=============================================================================
// WAL MANAGER
//=============================================================================

/// @brief The append-only log manager.  Owns an in-memory
///        `logBuffer` that absorbs writes, flushing to disk when
///        it fills up or when a COMMIT demands durability.
///
/// Thread-safe: a Monitor lock serialises every public method.
/// That is intentionally conservative — the cost of log
/// contention is dwarfed by the cost of the eventual disk flush.
class WALManager {
    expose String logDir;            // Directory for log files
    expose Integer currentFile;      // Current log file number
    expose Integer currentOffset;    // Current offset in file
    expose BinaryBuffer logBuffer;   // In-memory buffer
    expose Integer bufferPosition;   // Position in buffer
    expose LSN lastFlushedLSN;       // Last LSN written to disk
    expose Boolean enabled;          // WAL enabled flag

    hide LogRecordSerializer serializer;
    hide List[Integer] lock;         // Monitor object for thread safety

    /// @brief Zero-state init.  Leaves `enabled = false` so
    ///        the WAL is a no-op until `initWithDir` switches it
    ///        on — useful in in-memory-only test paths.
    expose func init() {
        logDir = "";
        currentFile = 0;
        currentOffset = 0;
        logBuffer = new BinaryBuffer();
        logBuffer.initWithCapacity(WAL_BUFFER_SIZE);
        bufferPosition = 0;
        lastFlushedLSN = new LSN();
        lastFlushedLSN.init();
        enabled = false;
        serializer = new LogRecordSerializer();
        serializer.init();
        lock = [];
    }

    /// @brief Init with a log directory.  Enables WAL writing.
    ///        Log files live at `<dir>/wal_<N>.log`.
    expose func initWithDir(dir: String) {
        init();
        logDir = dir;
        enabled = true;
    }

    //=========================================================================
    // LOG WRITING
    //=========================================================================

    /// @brief Append any `LogRecord`.  Thread-safe wrapper around
    ///        `appendRecordInternal`.  Returns the assigned LSN.
    expose func appendRecord(record: LogRecord) -> LSN {
        Threads.Monitor.Enter(lock);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    /// @brief Lockless append.  Caller holds the monitor.
    ///
    /// Assigns the current (file, offset) as the record's LSN,
    /// serialises into a staging buffer, flushes if the in-memory
    /// log buffer would overflow, rotates to a new file if we'd
    /// exceed `WAL_MAX_FILE_SIZE`, then appends.
    hide func appendRecordInternal(record: LogRecord) -> LSN {
        if enabled == false {
            var dummyLSN = new LSN();
            dummyLSN.init();
            return dummyLSN;
        }

        // Assign LSN
        record.lsn.fileNumber = currentFile;
        record.lsn.offset = currentOffset;

        // Serialize to buffer
        var recordBuf = new BinaryBuffer();
        recordBuf.init();
        serializer.serialize(record, recordBuf);

        // Check if we need to flush or rotate
        var recordSize = recordBuf.size();
        if bufferPosition + recordSize > WAL_BUFFER_SIZE {
            flushInternal();
        }

        // Check for log file rotation
        if currentOffset + recordSize > WAL_MAX_FILE_SIZE {
            rotateLogFile();
            record.lsn.fileNumber = currentFile;
            record.lsn.offset = currentOffset;
        }

        // Copy record to log buffer
        var bytes = recordBuf.getBytes();
        var i = 0;
        while i < bytes.count() {
            logBuffer.writeByte(bytes.get(i));
            i = i + 1;
        }
        bufferPosition = bufferPosition + recordSize;
        currentOffset = currentOffset + recordSize;

        return record.lsn;
    }

    /// @brief Convenience: build + append a BEGIN record.
    expose func logBegin(txnId: Integer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initBegin(txnId);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    /// @brief Append COMMIT and *force a flush*.
    ///
    /// Durability guarantee: once this returns, the txn's COMMIT
    /// record is on disk.  Recovery after a crash will see it and
    /// redo the txn's mutations.  This is the single most
    /// expensive operation in the log path.
    expose func logCommit(txnId: Integer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initCommit(txnId);
        var lsn = appendRecordInternal(record);
        flushInternal();  // Force write for durability
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    /// @brief Append ABORT.  No forced flush — the caller's
    ///        outer transaction handling decides whether to
    ///        `flush()` for a guaranteed durable abort.
    expose func logAbort(txnId: Integer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initAbort(txnId);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    // Log an INSERT record
    /// @brief Append an INSERT log record.  Called from the DML
    ///        layer *before* the row hits the data page so a
    ///        post-write crash can replay it.
    expose func logInsert(txnId: Integer, tableId: Integer, pageId: Integer, slotId: Integer, rowData: BinaryBuffer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initInsert(txnId, tableId, pageId, slotId, rowData);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    // Log an UPDATE record
    /// @brief Append an UPDATE log record carrying both images.
    expose func logUpdate(txnId: Integer, tableId: Integer, pageId: Integer, slotId: Integer, before: BinaryBuffer, after: BinaryBuffer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initUpdate(txnId, tableId, pageId, slotId, before, after);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    // Log a DELETE record
    /// @brief Append a DELETE log record.  `rowData` is the
    ///        pre-delete row, kept so undo can reinstate it.
    expose func logDelete(txnId: Integer, tableId: Integer, pageId: Integer, slotId: Integer, rowData: BinaryBuffer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initDelete(txnId, tableId, pageId, slotId, rowData);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    // Log a CLR record (compensation — marks undo completion)
    /// @brief Append a Compensation Log Record during recovery.
    ///        Written *after* we finish undoing an operation, so
    ///        a re-crash knows not to undo it again.
    expose func logCLR(txnId: Integer, tableId: Integer, pageId: Integer, slotId: Integer, undoneType: Integer) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initCLR(txnId, tableId, pageId, slotId, undoneType);
        var lsn = appendRecordInternal(record);
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    // Write a checkpoint
    /// @brief Emit a CHECKPOINT record and force flush.
    ///
    /// Serves two purposes: (a) bounds how far back recovery has
    /// to scan (Analysis starts at the last checkpoint), (b)
    /// captures the active-txn set so Analysis can seed its
    /// bookkeeping without scanning from the beginning.
    expose func checkpoint(activeTxns: List[Integer]) -> LSN {
        Threads.Monitor.Enter(lock);
        var record = new LogRecord();
        record.initCheckpoint(activeTxns);
        var lsn = appendRecordInternal(record);
        flushInternal();
        Threads.Monitor.Exit(lock);
        return lsn;
    }

    //=========================================================================
    // LOG FILE MANAGEMENT
    //=========================================================================

    // Flush buffer to disk (public, thread-safe)
    /// @brief Thread-safe public flush.  Pushes the in-memory
    ///        log buffer to disk and updates `lastFlushedLSN`.
    expose func flush() {
        Threads.Monitor.Enter(lock);
        flushInternal();
        Threads.Monitor.Exit(lock);
    }

    // Flush buffer to disk (internal, no locking)
    /// @brief Lockless flush.  Appends `logBuffer` to the current
    ///        log file on disk, resets the buffer, and updates
    ///        `lastFlushedLSN` to the end of what we just wrote.
    hide func flushInternal() {
        if bufferPosition == 0 {
            return;
        }

        var filename = logFilePath(currentFile);

        // Read existing content
        var content = "";
        if IO.File.Exists(filename) {
            content = IO.File.ReadAllText(filename);
        }

        // Append buffer content with bounds checking
        var bytes = logBuffer.getBytes();
        var i = 0;
        while i < bufferPosition && i < bytes.count() {
            var b = bytes.get(i);
            // Ensure byte is in valid range for Chr
            if b < 0 {
                b = 0;
            }
            if b > 255 {
                b = b % 256;
            }
            content = content + String.Chr(b);
            i = i + 1;
        }

        IO.File.WriteAllText(filename, content);

        // Update last flushed LSN
        lastFlushedLSN.fileNumber = currentFile;
        lastFlushedLSN.offset = currentOffset;

        // Reset buffer
        logBuffer = new BinaryBuffer();
        logBuffer.initWithCapacity(WAL_BUFFER_SIZE);
        bufferPosition = 0;
    }

    // Rotate to a new log file (internal, called under lock)
    /// @brief Close the current log file and start file N+1.
    ///        Called when appending would exceed
    ///        `WAL_MAX_FILE_SIZE`.
    hide func rotateLogFile() {
        flushInternal();
        currentFile = currentFile + 1;
        currentOffset = 0;
    }

    // Get log file path
    /// @brief Compose the path of log file `fileNum` under
    ///        `logDir` as `wal_<N>.log`.
    hide func logFilePath(fileNum: Integer) -> String {
        return logDir + "/wal_" + Fmt.Int(fileNum) + ".log";
    }

    //=========================================================================
    // RECOVERY
    //=========================================================================

    // Read all records from a log file
    /// @brief Read every record from one log file.  Used by the
    ///        recovery driver to walk the full log.
    expose func readLogFile(fileNum: Integer) -> List[LogRecord] {
        var records: List[LogRecord] = [];
        var filename = logFilePath(fileNum);

        if IO.File.Exists(filename) == false {
            return records;
        }

        var content = IO.File.ReadAllText(filename);
        var buf = new BinaryBuffer();
        buf.init();

        // Convert string to buffer
        var i = 0;
        var len = String.Length(content);
        while i < len {
            var ch = String.Substring(content, i, 1);
            var code = String.Asc(ch);
            buf.writeByte(code);
            i = i + 1;
        }

        // Read records
        buf.seek(0);
        while buf.writePosition() > 0 && buf.position < buf.size() {
            var record = serializer.deserialize(buf);
            if record.recordType != 0 {
                records.add(record);
            }
        }

        return records;
    }

    // Perform basic recovery (analysis only — full redo done by StorageEngine)
    /// @brief The ARIES recovery driver — runs Analysis, Redo,
    ///        and Undo in sequence and returns a summary.
    ///
    /// Pseudocode of the phases:
    ///   1. Analysis: scan every record, accumulate activeTxns
    ///      (from BEGINs) and committedTxns (from COMMITs).
    ///   2. Redo: re-apply every data-mutation record regardless
    ///      of txn status.  Idempotent — the data-page's LSN
    ///      gates re-apply.  We lean on the applier in
    ///      `storage/data_page.zia` / `btree.zia` to check.
    ///   3. Undo: for each txn in activeTxns ∩ ¬committedTxns,
    ///      walk that txn's records in reverse and undo each,
    ///      writing a CLR after each successful undo to prevent
    ///      re-undo on a re-crash.
    expose func recover() -> RecoveryResult {
        var result = createRecoveryResult(enabled);
        if enabled == false {
            return result;
        }

        // Analysis: identify committed transactions
        if checkWalFilesExist() {
            var committed: List[Integer] = [];
            var aborted: List[Integer] = [];
            var fileNum = 0;
            while fileNum <= currentFile + 5 {
                var records = readLogFile(fileNum);
                var ri = 0;
                while ri < records.count() {
                    var record = records.get(ri);
                    if record.recordType == LOG_COMMIT {
                        committed.add(record.txnId);
                    } else if record.recordType == LOG_ABORT {
                        aborted.add(record.txnId);
                    }
                    ri = ri + 1;
                }
                fileNum = fileNum + 1;
            }
            result.committedTxns = committed;
            result.abortedTxns = aborted;
            result.recoveryComplete = true;
        }

        return result;
    }

    // Read all log records across all WAL files (for undo scanning)
    /// @brief Concatenate every log file's records in order.
    ///        Utility used by tests, diagnostics, and recovery.
    expose func readAllRecords() -> List[LogRecord] {
        var all: List[LogRecord] = [];
        var fileNum = 0;
        while fileNum <= currentFile + 5 {
            var records = readLogFile(fileNum);
            var ri = 0;
            while ri < records.count() {
                all.add(records.get(ri));
                ri = ri + 1;
            }
            fileNum = fileNum + 1;
        }
        return all;
    }

    // Check if any WAL files exist on disk
    /// @brief "Is there anything to recover from?"  True if
    ///        `wal_0.log` (or later) exists under `logDir`.
    hide func checkWalFilesExist() -> Boolean {
        var fileNum = 0;
        while fileNum <= currentFile {
            var path = logFilePath(fileNum);
            if IO.File.Exists(path) {
                return true;
            }
            fileNum = fileNum + 1;
        }
        return false;
    }

    // Count committed data operations across all WAL files
    /// @brief Count the data-mutation records belonging to
    ///        committed transactions.  Feeds the `recordsRedone`
    ///        statistic in `RecoveryResult`.
    hide func countCommittedOps(committedTxns: List[Integer]) -> Integer {
        var count = 0;
        var fileNum = 0;
        while fileNum <= currentFile {
            var records = readLogFile(fileNum);
            var ri = 0;
            while ri < records.count() {
                var record = records.get(ri);
                if record.recordType == LOG_INSERT || record.recordType == LOG_UPDATE || record.recordType == LOG_DELETE {
                    if isTxnCommitted(committedTxns, record.txnId) {
                        count = count + 1;
                    }
                }
                ri = ri + 1;
            }
            fileNum = fileNum + 1;
        }
        return count;
    }

    // Check if a transaction ID is in the committed list
    /// @brief O(N) "is `txnId` in the committed list?"
    expose func isTxnCommitted(committed: List[Integer], txnId: Integer) -> Boolean {
        var i = 0;
        while i < committed.count() {
            if committed.get(i) == txnId {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    // Delete all WAL files from disk
    /// @brief Delete all `wal_*.log` files from `logDir`.
    ///        Called after a successful checkpoint + full flush
    ///        (no more transactions depend on those log records).
    expose func cleanupWalFiles() {
        var fileNum = 0;
        while fileNum <= currentFile {
            var path = logFilePath(fileNum);
            if IO.File.Exists(path) {
                IO.File.Delete(path);
            }
            fileNum = fileNum + 1;
        }
    }


    // Reset WAL state after recovery
    /// @brief Zero file/offset/buffer counters.  Used after
    ///        `cleanupWalFiles` so the next transaction starts
    ///        at LSN (0, 0).
    expose func resetState() {
        currentFile = 0;
        currentOffset = 0;
        bufferPosition = 0;
        logBuffer = new BinaryBuffer();
        logBuffer.initWithCapacity(WAL_BUFFER_SIZE);
    }

    // Helper to remove transaction from list (returns new list)
    /// @brief Return a copy of `list` without `txnId`.  The
    ///        classic "remove from parallel list" helper used
    ///        during Analysis when a COMMIT clears an active txn.
    expose func removeTxnFromList(list: List[Integer], txnId: Integer) -> List[Integer] {
        var i = list.count() - 1;
        while i >= 0 {
            if list.get(i) == txnId {
                list.removeAt(i);
            }
            i = i - 1;
        }
        return list;
    }

    //=========================================================================
    // STATUS
    //=========================================================================

    /// @brief "Is logging on?"  False in in-memory-only mode.
    expose func isEnabled() -> Boolean {
        return enabled;
    }

    /// @brief LSN of the most recent byte on disk.  Anything
    ///        past this is in the buffer and volatile.
    expose func getLastFlushedLSN() -> LSN {
        return lastFlushedLSN;
    }

    /// @brief LSN of the next byte an append would write.
    ///        Equals `(currentFile, currentOffset)`.
    expose func getCurrentLSN() -> LSN {
        var lsn = new LSN();
        lsn.initWith(currentFile, currentOffset);
        return lsn;
    }
}

//=============================================================================
// RECOVERY RESULT
//=============================================================================

/// @brief Summary bundle returned from `WALManager.recover()`.
///
/// Carries both the outcome flags and the statistics callers
/// plug into their server startup logs — so operators can see at
/// a glance what recovery did.
class RecoveryResult {
    expose Boolean recoveryComplete;
    expose List[Integer] committedTxns;
    expose List[Integer] abortedTxns;
    expose List[Integer] activeTxnsAtCrash;
    expose Integer redoCount;
    expose Integer undoCount;

    /// @brief Zero-state init — "not recovered, no txns seen".
    expose func init() {
        recoveryComplete = false;
        committedTxns = [];
        abortedTxns = [];
        activeTxnsAtCrash = [];
        redoCount = 0;
        undoCount = 0;
    }

    /// @brief Human-readable multiline summary for startup logs.
    expose func toString() -> String {
        var result = "Recovery Result:\n";
        result = result + "  Committed: " + Fmt.Int(committedTxns.count()) + "\n";
        result = result + "  Aborted: " + Fmt.Int(abortedTxns.count()) + "\n";
        result = result + "  Active at crash: " + Fmt.Int(activeTxnsAtCrash.count()) + "\n";
        result = result + "  Redo operations: " + Fmt.Int(redoCount) + "\n";
        result = result + "  Undo operations: " + Fmt.Int(undoCount);
        return result;
    }
}

/// @brief Module-level helper: construct a `RecoveryResult`
///        pre-marked as complete.  Used by the no-WAL fast-path
///        in `recover()` when `enabled == false`.
func createRecoveryResult(walEnabled: Boolean) -> RecoveryResult {
    var result = new RecoveryResult();
    result.init();
    result.recoveryComplete = true;
    return result;
}
