// =============================================================================
// data_page.zia — The slotted-heap data-page manager
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// One class, `DataPageManager`, which knows how to lay out, read, and
// write rows inside the 4-KB DATA pages defined in `./page.zia`.  It
// implements the classic slotted-page design:
//
//     [ fixed header ][ slot directory → ][ free ][ ← row payloads ]
//
// The slot directory grows forward from byte 17; row payloads grow
// backward from byte PAGE_SIZE.  When they meet, the page is full.
// Individual slots carry `(offset, length, deleted)` so deletions
// can tombstone a row without physically moving anything else.
// `compactPage` reclaims space from tombstones by rebuilding the
// page from its live rows.
//
// WHERE THIS FITS
// ---------------
//     storage/page.zia         (layout constants)
//     storage/serializer.zia   (Row ↔ bytes)
//     storage/pager.zia        (page-level I/O)
//         │
//         ▼
//     storage/data_page.zia   (YOU ARE HERE)  ←── row-on-page API
//         │
//         ▼
//     storage/engine.zia, engine/dml.zia
//
// KEY DESIGN CHOICES
// ------------------
//   1. Slotted layout.  Classic PG/SQLite design: slot directory at
//      the top, payloads at the bottom, meeting in the middle.  Lets
//      us address a row by its stable slot id even as payload bytes
//      shuffle (on UPDATE or VACUUM).
//
//   2. Tombstones, not immediate removal.  `deleteRow` flips the
//      `deleted` flag on the slot but leaves the bytes in place.
//      Benefits: the row slot index remains valid (indexes don't
//      need rewriting), MVCC readers can still see the old tuple,
//      and compaction can batch reclaim many tombstones at once.
//
//   3. In-place update when possible.  `updateRow` writes into the
//      existing payload space if the new row is the same size or
//      smaller.  If it's larger, we return false and the caller
//      (DML executor) falls back to delete+insert.  This favours
//      small fixed-width updates (the common case for hot rows).
//
//   4. 6-byte slot entries: `int16 offset | int16 length | int16
//      flags`.  The low bit of flags is the tombstone.  Keeping
//      offsets and lengths as 16-bit matches the 4-KB page — the
//      maximum valid offset is 4096 which comfortably fits.
//
//   5. `getFreeSpace` reserves SLOT_ENTRY_SIZE for the next entry.
//      That way `canFitRow` is honest about whether we can add the
//      payload *and* its required slot.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Page initialisation: `initDataPage`.
//   2. Header accessors: `getTableId`, `getRowCount`,
//      `getFreeSpacePointer`, `getNextPageId` and their setters.
//   3. Slot directory: `slotOffset`, `readSlot`, `writeSlot`.
//   4. Free-space calc: `getFreeSpace`, `canFitRow`.
//   5. Row operations: `insertRow`, `readRow`, `deleteRow`,
//      `updateRow`.
//   6. Whole-page helpers: `forEachRow`, `compactPage`.
//
// =============================================================================

module data_page;

bind "./page";
bind "./serializer";
bind "./pager";
bind "../engine/table";
bind "../engine/types";

/// @brief Size of one slot-directory entry on disk.
///
/// Mirrors the on-disk layout: `int16 offset | int16 length | int16
/// flags`.  Duplicated (as a bare `6`) in `page.zia`'s
/// `calculateFreeSpace`; keep them in sync.
final SLOT_ENTRY_SIZE = 6;

//=============================================================================
// DATA PAGE MANAGER
//=============================================================================

/// @brief The slotted-page layout + slot-directory manager.
///
/// Stateless except for a cached `RowSerializer`.  All operations
/// take a `Page` as their first argument — the manager mutates the
/// page's `data` byte buffer and flips `markDirty` so the pager
/// knows to write it back on eviction or flush.
class DataPageManager {
    hide RowSerializer rowSer;

    /// @brief Construct and cache a row serializer.
    ///
    /// We keep one `RowSerializer` instance so per-insert paths do
    /// not re-allocate.  It carries no mutable state — the
    /// stateless style matches how `DataPageManager` is used.
    expose func init() {
        rowSer = new RowSerializer();
        rowSer.init();
    }

    //=========================================================================
    // PAGE INITIALISATION
    //=========================================================================

    /// @brief Overwrite `page` with a fresh empty DATA page.
    ///
    /// Lays down the 17-byte header: type byte, 4-byte table id,
    /// 2-byte row count (0), 2-byte free-space pointer (PAGE_SIZE),
    /// 8-byte next-page pointer (INVALID_PAGE_ID).  Marks the page
    /// dirty so the pager flushes it.  Called on first use of a
    /// newly-allocated page, and by `compactPage` when rebuilding
    /// after VACUUM.
    expose func initDataPage(page: Page, tableId: Integer) {
        page.pageType = PAGE_TYPE_DATA;
        page.data.seek(0);

        page.data.writeByte(PAGE_TYPE_DATA);
        page.data.writeInt32(tableId);
        page.data.writeInt16(0);              // row count
        page.data.writeInt16(PAGE_SIZE);      // free-space ptr starts at end
        page.data.writeInt64(INVALID_PAGE_ID); // no next page yet

        page.markDirty();
    }

    //=========================================================================
    // HEADER ACCESSORS
    //=========================================================================

    /// @brief Read the 4-byte table id from the page header.
    expose func getTableId(page: Page) -> Integer {
        page.data.seek(DATA_TABLE_ID_OFFSET);
        return page.data.readInt32();
    }

    /// @brief Read the 2-byte row count (includes tombstoned rows).
    expose func getRowCount(page: Page) -> Integer {
        page.data.seek(DATA_ROW_COUNT_OFFSET);
        return page.data.readInt16();
    }

    /// @brief Update the stored row count.  Always goes through
    ///        this helper (hidden from external callers) so the
    ///        dirty bit flips on every row-count change.
    hide func setRowCount(page: Page, count: Integer) {
        page.data.seek(DATA_ROW_COUNT_OFFSET);
        page.data.writeInt16(count);
        page.markDirty();
    }

    /// @brief Read the current free-space pointer (byte offset
    ///        below which payload bytes start).  Smaller values
    ///        mean more rows packed in.
    expose func getFreeSpacePointer(page: Page) -> Integer {
        page.data.seek(DATA_FREE_SPACE_OFFSET);
        return page.data.readInt16();
    }

    /// @brief Update the free-space pointer.  Hidden so all writers
    ///        flow through `insertRow`/`compactPage`.
    hide func setFreeSpacePointer(page: Page, ptr: Integer) {
        page.data.seek(DATA_FREE_SPACE_OFFSET);
        page.data.writeInt16(ptr);
        page.markDirty();
    }

    /// @brief Read the linked-list pointer to the next data page
    ///        for this table.  -1 (INVALID_PAGE_ID) means "this is
    ///        the last page".
    expose func getNextPageId(page: Page) -> Integer {
        page.data.seek(DATA_NEXT_PAGE_OFFSET);
        return page.data.readInt64();
    }

    /// @brief Update the next-page pointer.  Public because the
    ///        pager needs to splice new pages into the linked list
    ///        when the current page fills up.
    expose func setNextPageId(page: Page, nextId: Integer) {
        page.data.seek(DATA_NEXT_PAGE_OFFSET);
        page.data.writeInt64(nextId);
        page.markDirty();
    }

    //=========================================================================
    // SLOT DIRECTORY
    //=========================================================================

    /// @brief Compute the byte offset of slot `slotIdx`.  First slot
    ///        lives at DATA_SLOT_DIR_OFFSET; each subsequent slot
    ///        is SLOT_ENTRY_SIZE bytes later.
    hide func slotOffset(slotIdx: Integer) -> Integer {
        return DATA_SLOT_DIR_OFFSET + (slotIdx * SLOT_ENTRY_SIZE);
    }

    /// @brief Read one slot-directory entry.
    ///
    /// Slot layout on disk:
    ///     int16 offset | int16 length | int16 flags
    /// where `flags & 1` is the tombstone bit.
    expose func readSlot(page: Page, slotIdx: Integer) -> SlotEntry {
        var entry = new SlotEntry();
        entry.init();

        page.data.seek(slotOffset(slotIdx));
        entry.offset = page.data.readInt16();
        entry.length = page.data.readInt16();
        var flags = page.data.readInt16();
        entry.deleted = (flags % 2) == 1;  // low bit = tombstone

        return entry;
    }

    /// @brief Write one slot-directory entry.  Flips the dirty bit
    ///        on the page.  Hidden because callers should go
    ///        through the higher-level row operations.
    hide func writeSlot(page: Page, slotIdx: Integer, entry: SlotEntry) {
        page.data.seek(slotOffset(slotIdx));
        page.data.writeInt16(entry.offset);
        page.data.writeInt16(entry.length);
        var flags = 0;
        if entry.deleted { flags = 1; }
        page.data.writeInt16(flags);
        page.markDirty();
    }

    //=========================================================================
    // FREE-SPACE CALCULATION
    //=========================================================================

    /// @brief Bytes available for a new row.
    ///
    /// Subtracts both the existing slot directory and the slot
    /// entry we would *add* for the new row from the payload start.
    /// That pre-reservation is what makes `canFitRow` honest.
    expose func getFreeSpace(page: Page) -> Integer {
        var rowCount = getRowCount(page);
        var slotDirEnd = slotOffset(rowCount);
        var freePtr = getFreeSpacePointer(page);
        return freePtr - slotDirEnd - SLOT_ENTRY_SIZE;
    }

    /// @brief "Will this row fit without spilling to another page?"
    expose func canFitRow(page: Page, row: Row) -> Boolean {
        var rowSize = rowSer.rowSize(row);
        var freeSpace = getFreeSpace(page);
        return rowSize <= freeSpace;
    }

    //=========================================================================
    // ROW OPERATIONS
    //=========================================================================

    /// @brief Insert a row.  Returns the new slot index, or -1 if
    ///        the page is full.
    ///
    /// Steps:
    ///   1. Refuse if `canFitRow` says no.
    ///   2. Reserve the payload bytes by subtracting from the
    ///      free-space pointer.
    ///   3. Serialise the row into those bytes.
    ///   4. Append a new slot entry pointing at the payload.
    ///   5. Bump row count.
    ///
    /// The caller (usually `engine/dml.zia` or `storage/engine.zia`)
    /// chains pages via `next` when a row will not fit — that
    /// linkage uses `setNextPageId`, not this method.
    expose func insertRow(page: Page, row: Row) -> Integer {
        var rowSize = rowSer.rowSize(row);

        if canFitRow(page, row) == false {
            return -1;
        }

        var rowCount = getRowCount(page);
        var freePtr = getFreeSpacePointer(page);
        var newFreePtr = freePtr - rowSize;

        // Serialise at the new payload position.
        page.data.seek(newFreePtr);
        rowSer.serializeRow(row, page.data);

        // Add the slot entry (SlotEntry defined in page.zia).
        var slot = new SlotEntry();
        slot.initWithValues(newFreePtr, rowSize);
        writeSlot(page, rowCount, slot);

        setRowCount(page, rowCount + 1);
        setFreeSpacePointer(page, newFreePtr);

        return rowCount;
    }

    /// @brief Read a row by slot index.  Returns null on
    ///        out-of-range *or* on tombstoned slots.
    ///
    /// The null-on-tombstone behaviour means callers doing full
    /// page scans can simply skip nulls without separately
    /// inspecting the tombstone flag.  If you *want* to see
    /// tombstones (e.g. for VACUUM), read the raw slot via
    /// `readSlot` instead.
    expose func readRow(page: Page, slotIdx: Integer) -> Row? {
        var rowCount = getRowCount(page);
        if slotIdx < 0 || slotIdx >= rowCount {
            return null;
        }

        var slot = readSlot(page, slotIdx);
        if slot.deleted {
            return null;
        }

        page.data.seek(slot.offset);
        return rowSer.deserializeRow(page.data);
    }

    /// @brief Tombstone a row.  Returns true on success, false if
    ///        the slot is already dead or out-of-range.
    ///
    /// Does not reclaim the payload bytes — that is `compactPage`'s
    /// job.  Kept as two steps so DELETE can be cheap and VACUUM
    /// can run on its own schedule.
    expose func deleteRow(page: Page, slotIdx: Integer) -> Boolean {
        var rowCount = getRowCount(page);
        if slotIdx < 0 || slotIdx >= rowCount {
            return false;
        }

        var slot = readSlot(page, slotIdx);
        if slot.deleted {
            return false;
        }

        slot.deleted = true;
        writeSlot(page, slotIdx, slot);
        return true;
    }

    /// @brief Update a row in place when the new serialised form
    ///        fits the existing payload slot.  Returns false if it
    ///        doesn't — the caller is expected to fall back to
    ///        delete+insert and tolerate the resulting fragmentation
    ///        until VACUUM.
    ///
    /// "Fits" is size-based: equal-or-smaller succeeds.  We update
    /// `slot.length` to the actual new size so `getFreeSpace`
    /// accounting stays honest.
    expose func updateRow(page: Page, slotIdx: Integer, newRow: Row) -> Boolean {
        var rowCount = getRowCount(page);
        if slotIdx < 0 || slotIdx >= rowCount {
            return false;
        }

        var slot = readSlot(page, slotIdx);
        var newSize = rowSer.rowSize(newRow);

        if newSize <= slot.length {
            page.data.seek(slot.offset);
            rowSer.serializeRow(newRow, page.data);
            slot.length = newSize;
            writeSlot(page, slotIdx, slot);
            return true;
        }

        return false;
    }

    //=========================================================================
    // PAGE ITERATION
    //=========================================================================

    /// @brief Return every live (non-tombstoned) row on the page.
    ///
    /// Used by the DML executor's sequential-scan path and by the
    /// compactor below.  Tombstones are transparently filtered out
    /// because `readRow` returns null for them.
    expose func forEachRow(page: Page) -> List[Row] {
        var rows: List[Row] = [];
        var rowCount = getRowCount(page);

        var i = 0;
        while i < rowCount {
            var maybeRow = readRow(page, i);
            if maybeRow != null {
                var row = maybeRow;
                rows.add(row);
            }
            i = i + 1;
        }

        return rows;
    }

    //=========================================================================
    // COMPACTION (VACUUM-ish)
    //=========================================================================

    /// @brief Rebuild the page from its live rows, discarding
    ///        tombstones and recovering their bytes.
    ///
    /// Algorithm: snapshot live rows, reinitialise the page via
    /// `initDataPage` (which resets row count and free-space
    /// pointer), then re-insert.  This renumbers slot ids —
    /// callers must NOT rely on slot indices across a compact.
    /// Indexes that reference rows by slot id should be rebuilt.
    ///
    /// VACUUM at the table level (`engine/executor.zia`) iterates
    /// all data pages and calls this on each.
    expose func compactPage(page: Page) {
        var rowCount = getRowCount(page);
        var tableId = getTableId(page);

        var liveRows: List[Row] = [];
        var i = 0;
        while i < rowCount {
            var maybeRow = readRow(page, i);
            if maybeRow != null {
                var row = maybeRow;
                liveRows.add(row);
            }
            i = i + 1;
        }

        initDataPage(page, tableId);

        i = 0;
        while i < liveRows.count() {
            insertRow(page, liveRows.get(i));
            i = i + 1;
        }
    }
}
