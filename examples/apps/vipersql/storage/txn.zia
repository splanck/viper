// =============================================================================
// txn.zia — ACID transactions: locks, txn state, commit/abort/undo
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// ViperSQL supports multi-statement transactions with two-phase
// locking and ARIES-style durability.  This file builds the pieces
// the executor and WAL coordinate around:
//
//   * `TableLockManager` — per-table S/X locks (shared + exclusive).
//                          Blocking-with-timeout for concurrent
//                          multi-session workloads.
//   * `RowLockManager`   — fine-grained per-row locks for SELECT
//                          FOR UPDATE / FOR SHARE.
//   * `Transaction`      — one in-flight txn's state: id,
//                          timestamp, list of modified pages and
//                          inserted rows, status.
//   * `Lock` + `LockManager` — a lower-level lock record + registry
//                          used by the transaction manager.
//   * `TransactionManager` — the driver: `begin`, `commit`, `abort`,
//                          plus the DML helpers that log + lock.
//                          Also does `performUndo` on abort using
//                          the WAL's before-images.
//
// WHERE THIS FITS
// ---------------
//     engine/executor.zia / engine/dml.zia
//         │  calls begin()/commit()/abort() and the lock helpers
//         │  before every mutation.
//         ▼
//     storage/txn.zia  (YOU ARE HERE)
//         │
//         ▼
//     storage/wal.zia        (log records, recovery)
//     storage/buffer.zia     (dirty page writeback on commit)
//     storage/data_page.zia  (physical undo applier)
//
// LOCK MODES & COMPATIBILITY
// --------------------------
//     LOCK_SHARED  (1) — compatible with other shared locks.
//     LOCK_EXCLUSIVE (2) — incompatible with any other lock.
//
//     S+S = OK         S+X = conflict         X+X = conflict
//
// Acquisition blocks with a `LOCK_TIMEOUT_MS` cap and a
// `LOCK_RETRY_INTERVAL_MS` sleep between retries — simple, no
// deadlock detection.  A victim timeout is treated as an abortable
// txn failure by the caller.
//
// KEY DESIGN CHOICES
// ------------------
//   1. Two lock managers, not one.  Table-level locks are grabbed
//      by almost every statement; row-level locks are reserved for
//      `SELECT … FOR UPDATE/SHARE`.  Keeping the hot table-lock
//      path in its own structure means it doesn't pay the price of
//      row-granular bookkeeping.
//
//   2. Busy-wait with timeout.  Lock contention on a database this
//      size is not going to benefit from a proper futex-style
//      wait queue; we sleep-poll.  Simplifies implementation
//      dramatically.
//
//   3. Physical undo via WAL before-images.  `abort` walks the
//      txn's log records in reverse and reinstates each
//      `beforeImage` via `DataPageManager` + `BufferPool`.  CLRs
//      are written so a re-crash during undo doesn't re-undo.
//
//   4. AutoCommit-mode toggle.  `setAutoCommit(true)` makes each
//      DML statement its own implicit begin/commit/abort, which is
//      the PG/psql default mode.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `TableLockManager` — acquire/release/tryAcquire.
//   2. `RowLockManager` — same shape, per-row.
//   3. `Transaction` — per-txn state record.
//   4. `Lock` / `LockManager` — lower-level lock API.
//   5. `TransactionManager` — the driver with begin/commit/abort,
//      DML helpers, and checkpointing.
//
// =============================================================================

module txn;

bind Viper.Fmt as Fmt;
bind Viper.Threads as Threads;
bind Viper.Time as Time;
bind "./page";
bind "./wal";
bind "./serializer";
bind "./data_page";
bind "./buffer";

//=============================================================================
// TABLE LOCK MANAGER (Multi-User Concurrency Control)
//=============================================================================

// Lock acquisition timeout and retry interval (milliseconds)
final LOCK_TIMEOUT_MS = 5000;
final LOCK_RETRY_INTERVAL_MS = 10;

/// @brief Table-level S/X lock manager with blocking acquisition.
///
/// Uses three parallel lists to store every live lock:
/// `lockTableNames[i]` is held by `lockSessionIds[i]` in mode
/// `lockModes[i]`.  Acquisition busy-waits with a timeout —
/// simple and adequate for demo concurrency.  S+S compatible,
/// S+X and X+X incompatible.
class TableLockManager {
    hide List[String] lockTableNames;
    hide List[Integer] lockSessionIds;
    hide List[Integer] lockModes;
    hide List[Integer] monitor;

    expose func init() {
        lockTableNames = [];
        lockSessionIds = [];
        lockModes = [];
        monitor = [];
    }

    /// @brief Blocking acquire.  Polls every
    ///        `LOCK_RETRY_INTERVAL_MS` until the lock becomes
    ///        available or `LOCK_TIMEOUT_MS` elapses.  Timeout
    ///        returns false — caller aborts its txn.
    ///
    /// An already-held lock of adequate mode short-circuits true
    /// (reentrant acquisition is free).
    expose func acquireTableLock(sessionId: Integer, tableName: String, mode: Integer) -> Boolean {
        var waited = 0;
        while waited < LOCK_TIMEOUT_MS {
            Threads.Monitor.Enter(monitor);

            // Check if this session already holds an adequate lock
            var alreadyHeld = false;
            var i = 0;
            while i < lockTableNames.count() {
                if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName {
                    if lockModes.get(i) >= mode {
                        alreadyHeld = true;
                    }
                }
                i = i + 1;
            }

            if alreadyHeld {
                Threads.Monitor.Exit(monitor);
                return true;
            }

            // Check for conflicts with other sessions
            var conflict = false;
            i = 0;
            while i < lockTableNames.count() {
                if lockTableNames.get(i) == tableName && lockSessionIds.get(i) != sessionId {
                    if mode == LOCK_EXCLUSIVE || lockModes.get(i) == LOCK_EXCLUSIVE {
                        conflict = true;
                    }
                }
                i = i + 1;
            }

            if conflict == false {
                // Grant the lock
                lockTableNames.add(tableName);
                lockSessionIds.add(sessionId);
                lockModes.add(mode);
                Threads.Monitor.Exit(monitor);
                return true;
            }

            Threads.Monitor.Exit(monitor);

            // Wait and retry
            Time.SleepMs(LOCK_RETRY_INTERVAL_MS);
            waited = waited + LOCK_RETRY_INTERVAL_MS;
        }

        return false;  // Timeout
    }

    // Release all locks held by a session
    /// @brief Release every lock this session holds.  Called at
    ///        commit and abort so another waiter can proceed.
    expose func releaseAllLocks(sessionId: Integer) {
        Threads.Monitor.Enter(monitor);
        var newNames: List[String] = [];
        var newSessions: List[Integer] = [];
        var newModes: List[Integer] = [];
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) != sessionId {
                newNames.add(lockTableNames.get(i));
                newSessions.add(lockSessionIds.get(i));
                newModes.add(lockModes.get(i));
            }
            i = i + 1;
        }
        lockTableNames = newNames;
        lockSessionIds = newSessions;
        lockModes = newModes;
        Threads.Monitor.Exit(monitor);
    }

    // Release a specific table lock held by a session
    /// @brief Release one table's lock for this session.  No-op
    ///        if we never held one.  Used by targeted LOCK TABLE
    ///        escape paths.
    expose func releaseTableLock(sessionId: Integer, tableName: String) {
        Threads.Monitor.Enter(monitor);
        var newNames: List[String] = [];
        var newSessions: List[Integer] = [];
        var newModes: List[Integer] = [];
        var i = 0;
        while i < lockTableNames.count() {
            var skip = false;
            if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName {
                skip = true;
            }
            if skip == false {
                newNames.add(lockTableNames.get(i));
                newSessions.add(lockSessionIds.get(i));
                newModes.add(lockModes.get(i));
            }
            i = i + 1;
        }
        lockTableNames = newNames;
        lockSessionIds = newSessions;
        lockModes = newModes;
        Threads.Monitor.Exit(monitor);
    }

    /// @brief Total active table-lock count — diagnostic only.
    expose func lockCount() -> Integer {
        Threads.Monitor.Enter(monitor);
        var count = lockTableNames.count();
        Threads.Monitor.Exit(monitor);
        return count;
    }

    /// @brief Per-session table-lock count — diagnostic.
    expose func sessionLockCount(sessionId: Integer) -> Integer {
        Threads.Monitor.Enter(monitor);
        var count = 0;
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) == sessionId {
                count = count + 1;
            }
            i = i + 1;
        }
        Threads.Monitor.Exit(monitor);
        return count;
    }

    // Non-blocking lock attempt. Returns true if lock granted, false if conflict.
    // Does NOT retry or sleep. Useful for testing and try-lock semantics.
    /// @brief Non-blocking variant.  Returns immediately — true
    ///        if the lock was granted, false on any conflict.
    ///        Used by SELECT … NOWAIT.
    expose func tryAcquireTableLock(sessionId: Integer, tableName: String, mode: Integer) -> Boolean {
        Threads.Monitor.Enter(monitor);

        // Check if already held
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName {
                if lockModes.get(i) >= mode {
                    Threads.Monitor.Exit(monitor);
                    return true;
                }
            }
            i = i + 1;
        }

        // Check for conflicts
        i = 0;
        while i < lockTableNames.count() {
            if lockTableNames.get(i) == tableName && lockSessionIds.get(i) != sessionId {
                if mode == LOCK_EXCLUSIVE || lockModes.get(i) == LOCK_EXCLUSIVE {
                    Threads.Monitor.Exit(monitor);
                    return false;  // Conflict
                }
            }
            i = i + 1;
        }

        // Grant lock
        lockTableNames.add(tableName);
        lockSessionIds.add(sessionId);
        lockModes.add(mode);
        Threads.Monitor.Exit(monitor);
        return true;
    }
}

//=============================================================================
// ROW LOCK MANAGER (Phase 14: Row-Level Locking)
//=============================================================================

// Row lock acquisition timeout (milliseconds)
final ROW_LOCK_TIMEOUT_MS = 5000;
final ROW_LOCK_RETRY_MS = 10;

// Thread-safe row-level lock manager for concurrent access.
// Uses parallel lists to track lock ownership (tableName + rowIndex → sessionId → mode).
// Lock modes: LOCK_SHARED (1) for FOR SHARE, LOCK_EXCLUSIVE (2) for FOR UPDATE.
// Compatibility: S+S = OK, S+X = conflict, X+X = conflict.
/// @brief Row-granular lock manager used by SELECT FOR
///        UPDATE/SHARE.  Same internal structure as the table
///        manager but keys on (tableName, rowIndex).  More
///        expensive per-row but avoids whole-table escalation.
class RowLockManager {
    hide List[String] lockTableNames;
    hide List[Integer] lockRowIndices;
    hide List[Integer] lockSessionIds;
    hide List[Integer] lockModes;
    hide List[Integer] monitor;

    expose func init() {
        lockTableNames = [];
        lockRowIndices = [];
        lockSessionIds = [];
        lockModes = [];
        monitor = [];
    }

    // Acquire a row lock (blocking with timeout).
    // Returns true if acquired, false on timeout.
    /// @brief Blocking per-row acquire with timeout.  Symmetric
    ///        to `TableLockManager.acquireTableLock`.
    expose func acquireRowLock(sessionId: Integer, tableName: String, rowIndex: Integer, mode: Integer) -> Boolean {
        var waited = 0;
        while waited < ROW_LOCK_TIMEOUT_MS {
            Threads.Monitor.Enter(monitor);

            // Check if this session already holds an adequate lock on this row
            var alreadyHeld = false;
            var i = 0;
            while i < lockTableNames.count() {
                if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName && lockRowIndices.get(i) == rowIndex {
                    if lockModes.get(i) >= mode {
                        alreadyHeld = true;
                    }
                }
                i = i + 1;
            }

            if alreadyHeld {
                Threads.Monitor.Exit(monitor);
                return true;
            }

            // Check for conflicts with other sessions
            var conflict = false;
            i = 0;
            while i < lockTableNames.count() {
                if lockTableNames.get(i) == tableName && lockRowIndices.get(i) == rowIndex && lockSessionIds.get(i) != sessionId {
                    if mode == LOCK_EXCLUSIVE || lockModes.get(i) == LOCK_EXCLUSIVE {
                        conflict = true;
                    }
                }
                i = i + 1;
            }

            if conflict == false {
                // Grant the lock
                lockTableNames.add(tableName);
                lockRowIndices.add(rowIndex);
                lockSessionIds.add(sessionId);
                lockModes.add(mode);
                Threads.Monitor.Exit(monitor);
                return true;
            }

            Threads.Monitor.Exit(monitor);

            // Wait and retry
            Time.SleepMs(ROW_LOCK_RETRY_MS);
            waited = waited + ROW_LOCK_RETRY_MS;
        }

        return false;  // Timeout
    }

    // Non-blocking lock attempt. Returns true if lock granted, false if conflict.
    /// @brief Non-blocking per-row acquire.  Used by SELECT …
    ///        FOR UPDATE SKIP LOCKED to walk past contested rows.
    expose func tryAcquireRowLock(sessionId: Integer, tableName: String, rowIndex: Integer, mode: Integer) -> Boolean {
        Threads.Monitor.Enter(monitor);

        // Check if already held
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName && lockRowIndices.get(i) == rowIndex {
                if lockModes.get(i) >= mode {
                    Threads.Monitor.Exit(monitor);
                    return true;
                }
            }
            i = i + 1;
        }

        // Check for conflicts
        i = 0;
        while i < lockTableNames.count() {
            if lockTableNames.get(i) == tableName && lockRowIndices.get(i) == rowIndex && lockSessionIds.get(i) != sessionId {
                if mode == LOCK_EXCLUSIVE || lockModes.get(i) == LOCK_EXCLUSIVE {
                    Threads.Monitor.Exit(monitor);
                    return false;  // Conflict
                }
            }
            i = i + 1;
        }

        // Grant lock
        lockTableNames.add(tableName);
        lockRowIndices.add(rowIndex);
        lockSessionIds.add(sessionId);
        lockModes.add(mode);
        Threads.Monitor.Exit(monitor);
        return true;
    }

    // Release all row locks held by a session
    /// @brief Drop every row lock held by `sessionId`.
    expose func releaseAllRowLocks(sessionId: Integer) {
        Threads.Monitor.Enter(monitor);
        var newNames: List[String] = [];
        var newRows: List[Integer] = [];
        var newSessions: List[Integer] = [];
        var newModes: List[Integer] = [];
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) != sessionId {
                newNames.add(lockTableNames.get(i));
                newRows.add(lockRowIndices.get(i));
                newSessions.add(lockSessionIds.get(i));
                newModes.add(lockModes.get(i));
            }
            i = i + 1;
        }
        lockTableNames = newNames;
        lockRowIndices = newRows;
        lockSessionIds = newSessions;
        lockModes = newModes;
        Threads.Monitor.Exit(monitor);
    }

    // Release all row locks on a specific table held by a session
    /// @brief Drop every row lock on `tableName` held by
    ///        `sessionId`.  Used when DROP TABLE cascades.
    expose func releaseTableRowLocks(sessionId: Integer, tableName: String) {
        Threads.Monitor.Enter(monitor);
        var newNames: List[String] = [];
        var newRows: List[Integer] = [];
        var newSessions: List[Integer] = [];
        var newModes: List[Integer] = [];
        var i = 0;
        while i < lockTableNames.count() {
            var skip = false;
            if lockSessionIds.get(i) == sessionId && lockTableNames.get(i) == tableName {
                skip = true;
            }
            if skip == false {
                newNames.add(lockTableNames.get(i));
                newRows.add(lockRowIndices.get(i));
                newSessions.add(lockSessionIds.get(i));
                newModes.add(lockModes.get(i));
            }
            i = i + 1;
        }
        lockTableNames = newNames;
        lockRowIndices = newRows;
        lockSessionIds = newSessions;
        lockModes = newModes;
        Threads.Monitor.Exit(monitor);
    }

    // Get total active row lock count (for diagnostics)
    /// @brief Total live row locks — diagnostic.
    expose func rowLockCount() -> Integer {
        Threads.Monitor.Enter(monitor);
        var count = lockTableNames.count();
        Threads.Monitor.Exit(monitor);
        return count;
    }

    // Get row lock count for a specific session
    /// @brief Per-session row-lock count — diagnostic.
    expose func sessionRowLockCount(sessionId: Integer) -> Integer {
        Threads.Monitor.Enter(monitor);
        var count = 0;
        var i = 0;
        while i < lockTableNames.count() {
            if lockSessionIds.get(i) == sessionId {
                count = count + 1;
            }
            i = i + 1;
        }
        Threads.Monitor.Exit(monitor);
        return count;
    }
}

//=============================================================================
// TRANSACTION CONSTANTS
//=============================================================================

// Transaction states
final TXN_ACTIVE = 1;      // Transaction is running
final TXN_COMMITTED = 2;   // Transaction committed successfully
final TXN_ABORTED = 3;     // Transaction was rolled back
final TXN_PREPARED = 4;    // Transaction prepared (for 2PC)

// Isolation levels
final ISOLATION_READ_UNCOMMITTED = 1;
final ISOLATION_READ_COMMITTED = 2;
final ISOLATION_REPEATABLE_READ = 3;
final ISOLATION_SERIALIZABLE = 4;

// Lock modes
final LOCK_SHARED = 1;     // Read lock (S)
final LOCK_EXCLUSIVE = 2;  // Write lock (X)

//=============================================================================
// TRANSACTION ENTITY
//=============================================================================

/// @brief In-flight transaction state.
///
/// Carries the txn id, wall-clock timestamp (for MVCC snapshot
/// ordering), status (active/committed/aborted), and tracking
/// lists for modified pages + inserted rows so abort can undo
/// them.  Owned by `TransactionManager.activeTxns`.
class Transaction {
    expose Integer txnId;
    expose Integer state;
    expose Integer isolationLevel;
    expose LSN startLSN;
    expose LSN lastLSN;
    expose Integer startTimestamp;
    expose Integer commitTimestamp;

    // Tracking for rollback
    expose List[Integer] modifiedPages;
    expose List[Integer] insertedRows;  // For undo on abort

    // Locks held by this transaction
    expose List[Lock] heldLocks;

    expose func init() {
        txnId = 0;
        state = TXN_ACTIVE;
        isolationLevel = ISOLATION_READ_COMMITTED;
        startLSN = new LSN();
        startLSN.init();
        lastLSN = new LSN();
        lastLSN.init();
        startTimestamp = 0;
        commitTimestamp = 0;
        modifiedPages = [];
        insertedRows = [];
        heldLocks = [];
    }

    expose func initWithId(id: Integer, ts: Integer) {
        init();
        txnId = id;
        startTimestamp = ts;
    }

    expose func isActive() -> Boolean {
        return state == TXN_ACTIVE;
    }

    expose func isCommitted() -> Boolean {
        return state == TXN_COMMITTED;
    }

    expose func isAborted() -> Boolean {
        return state == TXN_ABORTED;
    }

    expose func addModifiedPage(pageId: Integer) {
        // Check if already tracked
        var i = 0;
        while i < modifiedPages.count() {
            if modifiedPages.get(i) == pageId {
                return;
            }
            i = i + 1;
        }
        modifiedPages.add(pageId);
    }

    expose func addInsertedRow(tableId: Integer, rowId: Integer) {
        // Encode as single integer: tableId * 1000000 + rowId
        insertedRows.add(tableId * 1000000 + rowId);
    }

    expose func toString() -> String {
        var stateStr = "UNKNOWN";
        if state == TXN_ACTIVE { stateStr = "ACTIVE"; }
        if state == TXN_COMMITTED { stateStr = "COMMITTED"; }
        if state == TXN_ABORTED { stateStr = "ABORTED"; }
        if state == TXN_PREPARED { stateStr = "PREPARED"; }
        return "Transaction[" + Fmt.Int(txnId) + "] " + stateStr;
    }
}

//=============================================================================
// LOCK ENTITY
//=============================================================================

/// @brief A single lock record.  Three lock shapes:
///        table, page, row.  `isCompatible` implements the
///        lock-compatibility table used by `LockManager`.
class Lock {
    expose Integer resourceType;   // 0=table, 1=page, 2=row
    expose Integer resourceId;     // ID of the locked resource
    expose Integer tableId;        // Table ID (for row locks)
    expose Integer mode;           // LOCK_SHARED or LOCK_EXCLUSIVE
    expose Integer txnId;          // Owning transaction

    expose func init() {
        resourceType = 0;
        resourceId = 0;
        tableId = 0;
        mode = LOCK_SHARED;
        txnId = 0;
    }

    expose func initTableLock(tblId: Integer, lockMode: Integer, tid: Integer) {
        resourceType = 0;
        resourceId = tblId;
        tableId = tblId;
        mode = lockMode;
        txnId = tid;
    }

    expose func initPageLock(pageId: Integer, lockMode: Integer, tid: Integer) {
        resourceType = 1;
        resourceId = pageId;
        tableId = 0;
        mode = lockMode;
        txnId = tid;
    }

    expose func initRowLock(tblId: Integer, rowId: Integer, lockMode: Integer, tid: Integer) {
        resourceType = 2;
        resourceId = rowId;
        tableId = tblId;
        mode = lockMode;
        txnId = tid;
    }

    /// @brief Two-lock compatibility check.  S+S ok, anything
    ///        with X conflicts.  Locks on different resources
    ///        never conflict (different table / page / row).
    expose func isCompatible(other: Lock) -> Boolean {
        // Same resource?
        if resourceType != other.resourceType {
            return true;
        }
        if resourceId != other.resourceId {
            return true;
        }
        if resourceType == 2 && tableId != other.tableId {
            return true;  // Different tables
        }

        // Same resource - check mode compatibility
        // S + S = compatible
        // S + X = incompatible
        // X + X = incompatible
        if mode == LOCK_SHARED && other.mode == LOCK_SHARED {
            return true;
        }
        return false;
    }

    expose func toString() -> String {
        var typeStr = "TABLE";
        if resourceType == 1 { typeStr = "PAGE"; }
        if resourceType == 2 { typeStr = "ROW"; }
        var modeStr = "S";
        if mode == LOCK_EXCLUSIVE { modeStr = "X"; }
        return typeStr + "[" + Fmt.Int(resourceId) + "] " + modeStr + " (txn=" + Fmt.Int(txnId) + ")";
    }
}

//=============================================================================
// LOCK MANAGER
//=============================================================================

/// @brief Registry of live `Lock` records, with compatibility
///        checks on acquire.  The lower-level engine used
///        internally by `TransactionManager`; the public
///        lock API lives on the TableLockManager/RowLockManager
///        pair above.
class LockManager {
    expose List[Lock] activeLocks;

    expose func init() {
        activeLocks = [];
    }

    // Acquire a lock (returns true if successful)
    /// @brief Non-blocking acquire.  Scans existing locks, checks
    ///        each for compatibility via `lock.isCompatible`.
    ///        Returns true on success.
    expose func acquireLock(lock: Lock) -> Boolean {
        // Check for conflicts
        var i = 0;
        while i < activeLocks.count() {
            var existing = activeLocks.get(i);
            if existing.txnId != lock.txnId {
                if existing.isCompatible(lock) == false {
                    return false;  // Conflict
                }
            }
            i = i + 1;
        }

        // No conflict - grant lock
        activeLocks.add(lock);
        return true;
    }

    // Release a specific lock
    /// @brief Remove a matching lock record.
    expose func releaseLock(lock: Lock) {
        var i = 0;
        while i < activeLocks.count() {
            var existing = activeLocks.get(i);
            if existing.txnId == lock.txnId &&
               existing.resourceType == lock.resourceType &&
               existing.resourceId == lock.resourceId {
                activeLocks.removeAt(i);
                return;
            }
            i = i + 1;
        }
    }

    // Release all locks held by a transaction
    /// @brief Drop every lock held by `txnId`.  Called at commit
    ///        and abort.
    expose func releaseAllLocks(txnId: Integer) {
        var newLocks: List[Lock] = [];
        var i = 0;
        while i < activeLocks.count() {
            var lock = activeLocks.get(i);
            if lock.txnId != txnId {
                newLocks.add(lock);
            }
            i = i + 1;
        }
        activeLocks = newLocks;
    }

    /// @brief "Does txn hold lock on (type, id)?"  Used before
    ///        reacquiring to short-circuit reentrancy.
    expose func holdsLock(txnId: Integer, resourceType: Integer, resourceId: Integer) -> Boolean {
        var i = 0;
        while i < activeLocks.count() {
            var lock = activeLocks.get(i);
            if lock.txnId == txnId && lock.resourceType == resourceType && lock.resourceId == resourceId {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    // Get lock count
    expose func lockCount() -> Integer {
        return activeLocks.count();
    }

    // Get locks for a transaction
    expose func getLocksForTxn(txnId: Integer) -> List[Lock] {
        var result: List[Lock] = [];
        var i = 0;
        while i < activeLocks.count() {
            var lock = activeLocks.get(i);
            if lock.txnId == txnId {
                result.add(lock);
            }
            i = i + 1;
        }
        return result;
    }
}

//=============================================================================
// TRANSACTION MANAGER
//=============================================================================

/// @brief The top-level driver.  Owns the list of in-flight
///        transactions, the lock manager, the WAL, and (when
///        enabled) the buffer-pool references needed for undo.
///
/// Public API:
///   * begin/commit/abort          — transaction lifecycle
///   * lockTable*/lockRow*         — lock-acquisition helpers
///   * logInsert/logUpdate/logDelete — WAL helpers paired with
///                                     in-memory bookkeeping
///   * checkpoint                  — snapshot active txns +
///                                    flush everything
///   * setAutoCommit/isAutoCommit  — toggle per-statement implicit
///                                    transactions
class TransactionManager {
    expose Integer nextTxnId;
    expose Integer timestampCounter;
    expose List[Transaction] activeTransactions;
    expose LockManager lockMgr;
    expose WALManager wal;
    expose Boolean autoCommit;

    // Storage references for undo support (optional, set via initWithStorage)
    hide BufferPool undoPool;
    hide DataPageManager undoDataMgr;
    hide RowSerializer undoSerializer;
    hide Boolean undoEnabled;

    expose func init() {
        nextTxnId = 1;
        timestampCounter = 1;
        activeTransactions = [];
        lockMgr = new LockManager();
        lockMgr.init();
        wal = new WALManager();
        wal.init();
        autoCommit = true;  // Default SQL behavior
        undoPool = new BufferPool();
        undoPool.init();
        undoDataMgr = new DataPageManager();
        undoDataMgr.init();
        undoSerializer = new RowSerializer();
        undoSerializer.init();
        undoEnabled = false;
    }

    expose func initWithWAL(walManager: WALManager) {
        init();
        wal = walManager;
    }

    // Initialize with storage references for undo on abort
    expose func initWithStorage(walManager: WALManager, pool: BufferPool, dataMgr: DataPageManager) {
        init();
        wal = walManager;
        undoPool = pool;
        undoDataMgr = dataMgr;
        undoEnabled = true;
    }

    //=========================================================================
    // TRANSACTION LIFECYCLE
    //=========================================================================

    // Begin a new transaction
    /// @brief Start a new transaction.  Allocates a fresh id and
    ///        timestamp, emits a BEGIN log record, and adds to
    ///        `activeTransactions`.  The txn stays "active" until
    ///        `commit` or `abort`.
    expose func begin() -> Transaction {
        var txn = new Transaction();
        txn.initWithId(nextTxnId, timestampCounter);
        nextTxnId = nextTxnId + 1;
        timestampCounter = timestampCounter + 1;

        // Log BEGIN
        txn.startLSN = wal.logBegin(txn.txnId);
        txn.lastLSN = txn.startLSN;

        activeTransactions.add(txn);
        return txn;
    }

    // Commit a transaction
    /// @brief Finalise a transaction as committed.
    ///
    /// Writes COMMIT to the WAL (which forces a flush — durable
    /// after this returns), releases all locks, removes from
    /// `activeTransactions`.  Returns false if `txn` isn't
    /// active.
    expose func commit(txn: Transaction) -> Boolean {
        if txn.state != TXN_ACTIVE {
            return false;
        }

        // Log COMMIT (forces flush for durability)
        txn.lastLSN = wal.logCommit(txn.txnId);
        txn.commitTimestamp = timestampCounter;
        timestampCounter = timestampCounter + 1;
        txn.state = TXN_COMMITTED;

        // Release all locks
        lockMgr.releaseAllLocks(txn.txnId);

        // Remove from active list
        removeFromActive(txn.txnId);

        return true;
    }

    // Abort/rollback a transaction
    /// @brief Roll back a transaction.
    ///
    /// If undo is enabled (the caller provided a buffer pool via
    /// `initWithStorage`), calls `performUndo` to reinstate
    /// before-images.  Then writes ABORT to the WAL, drops locks,
    /// and removes the txn from the active list.
    expose func abort(txn: Transaction) -> Boolean {
        if txn.state != TXN_ACTIVE {
            return false;
        }

        // Undo changes by scanning WAL backwards for this transaction
        if undoEnabled && wal.isEnabled() {
            performUndo(txn.txnId);
        }

        // Log ABORT
        txn.lastLSN = wal.logAbort(txn.txnId);
        txn.state = TXN_ABORTED;

        // Release all locks
        lockMgr.releaseAllLocks(txn.txnId);

        // Remove from active list
        removeFromActive(txn.txnId);

        return true;
    }

    // Perform undo for a single transaction by scanning WAL backwards
    /// @brief Walk `txnId`'s log records in reverse and reinstate
    ///        each before-image.  After each undo, emits a CLR so
    ///        a re-crash during abort doesn't re-undo.
    ///
    /// This is the main cost of ABORT — O(N) in the number of
    /// records the txn wrote.  For very long-running txns, a
    /// COMMIT is cheap; an ABORT may take a while.
    hide func performUndo(txnId: Integer) {
        // Flush WAL buffer so we can read all records
        wal.flush();
        var allRecords = wal.readAllRecords();

        // Scan backwards, undoing this transaction's data operations
        var ri = allRecords.count() - 1;
        while ri >= 0 {
            var record = allRecords.get(ri);
            if record.txnId == txnId {
                if record.recordType == LOG_INSERT {
                    // Undo INSERT = delete the inserted row
                    if record.pageId != INVALID_PAGE_ID {
                        var page = undoPool.fetchPage(record.pageId);
                        if page != null {
                            var p = page;
                            var slotCount = undoDataMgr.getRowCount(p);
                            if record.slotId < slotCount {
                                undoDataMgr.deleteRow(p, record.slotId);
                                undoPool.unpinPage(record.pageId, true);
                                wal.logCLR(txnId, record.tableId, record.pageId, record.slotId, LOG_INSERT);
                            } else {
                                undoPool.unpinPage(record.pageId, false);
                            }
                        }
                    }
                } else if record.recordType == LOG_UPDATE {
                    // Undo UPDATE = restore before-image
                    if record.pageId != INVALID_PAGE_ID && record.beforeImage.size() > 0 {
                        var page = undoPool.fetchPage(record.pageId);
                        if page != null {
                            var p = page;
                            record.beforeImage.seek(0);
                            var oldRow = undoSerializer.deserializeRow(record.beforeImage);
                            undoDataMgr.updateRow(p, record.slotId, oldRow);
                            undoPool.unpinPage(record.pageId, true);
                            wal.logCLR(txnId, record.tableId, record.pageId, record.slotId, LOG_UPDATE);
                        }
                    }
                } else if record.recordType == LOG_DELETE {
                    // Undo DELETE = re-insert the before-image
                    if record.pageId != INVALID_PAGE_ID && record.beforeImage.size() > 0 {
                        var page = undoPool.fetchPage(record.pageId);
                        if page != null {
                            var p = page;
                            record.beforeImage.seek(0);
                            var oldRow = undoSerializer.deserializeRow(record.beforeImage);
                            undoDataMgr.insertRow(p, oldRow);
                            undoPool.unpinPage(record.pageId, true);
                            wal.logCLR(txnId, record.tableId, record.pageId, record.slotId, LOG_DELETE);
                        }
                    }
                }
            }
            ri = ri - 1;
        }
    }

    // Helper to remove transaction from active list
    /// @brief Remove `txnId` from `activeTransactions`.  Shared
    ///        cleanup used by commit and abort.
    hide func removeFromActive(txnId: Integer) {
        var newActive: List[Transaction] = [];
        var i = 0;
        while i < activeTransactions.count() {
            var t = activeTransactions.get(i);
            if t.txnId != txnId {
                newActive.add(t);
            }
            i = i + 1;
        }
        activeTransactions = newActive;
    }

    //=========================================================================
    // LOCK OPERATIONS
    //=========================================================================

    // Acquire a shared (read) lock on a table
    /// @brief Acquire a SHARED table lock on behalf of a txn.
    ///        Returns false on conflict.
    expose func lockTableShared(txn: Transaction, tableId: Integer) -> Boolean {
        var lock = new Lock();
        lock.initTableLock(tableId, LOCK_SHARED, txn.txnId);
        if lockMgr.acquireLock(lock) {
            txn.heldLocks.add(lock);
            return true;
        }
        return false;
    }

    // Acquire an exclusive (write) lock on a table
    /// @brief Acquire an EXCLUSIVE table lock.  Returns false on
    ///        any pre-existing lock.
    expose func lockTableExclusive(txn: Transaction, tableId: Integer) -> Boolean {
        var lock = new Lock();
        lock.initTableLock(tableId, LOCK_EXCLUSIVE, txn.txnId);
        if lockMgr.acquireLock(lock) {
            txn.heldLocks.add(lock);
            return true;
        }
        return false;
    }

    // Acquire a shared lock on a row
    /// @brief Acquire a SHARED row lock.
    expose func lockRowShared(txn: Transaction, tableId: Integer, rowId: Integer) -> Boolean {
        var lock = new Lock();
        lock.initRowLock(tableId, rowId, LOCK_SHARED, txn.txnId);
        if lockMgr.acquireLock(lock) {
            txn.heldLocks.add(lock);
            return true;
        }
        return false;
    }

    // Acquire an exclusive lock on a row
    /// @brief Acquire an EXCLUSIVE row lock.
    expose func lockRowExclusive(txn: Transaction, tableId: Integer, rowId: Integer) -> Boolean {
        var lock = new Lock();
        lock.initRowLock(tableId, rowId, LOCK_EXCLUSIVE, txn.txnId);
        if lockMgr.acquireLock(lock) {
            txn.heldLocks.add(lock);
            return true;
        }
        return false;
    }

    //=========================================================================
    // LOGGING OPERATIONS
    //=========================================================================

    // Log an insert operation
    /// @brief WAL an INSERT and note the affected page on the
    ///        transaction.
    expose func logInsert(txn: Transaction, tableId: Integer, pageId: Integer, slotId: Integer, rowData: BinaryBuffer) {
        txn.lastLSN = wal.logInsert(txn.txnId, tableId, pageId, slotId, rowData);
        txn.addModifiedPage(pageId);
        txn.addInsertedRow(tableId, slotId);
    }

    // Log an update operation
    /// @brief WAL an UPDATE (both images) and mark the page
    ///        modified.
    expose func logUpdate(txn: Transaction, tableId: Integer, pageId: Integer, slotId: Integer, before: BinaryBuffer, after: BinaryBuffer) {
        txn.lastLSN = wal.logUpdate(txn.txnId, tableId, pageId, slotId, before, after);
        txn.addModifiedPage(pageId);
    }

    // Log a delete operation
    /// @brief WAL a DELETE carrying the before-image so undo can
    ///        reinstate it.
    expose func logDelete(txn: Transaction, tableId: Integer, pageId: Integer, slotId: Integer, rowData: BinaryBuffer) {
        txn.lastLSN = wal.logDelete(txn.txnId, tableId, pageId, slotId, rowData);
        txn.addModifiedPage(pageId);
    }

    //=========================================================================
    // QUERY METHODS
    //=========================================================================

    // Get transaction by ID
    /// @brief Look up a live transaction by id.  Null if it has
    ///        already committed or aborted.
    expose func getTransaction(txnId: Integer) -> Transaction? {
        var i = 0;
        while i < activeTransactions.count() {
            var txn = activeTransactions.get(i);
            if txn.txnId == txnId {
                return txn;
            }
            i = i + 1;
        }
        return null;
    }

    // Get number of active transactions
    /// @brief Number of in-flight transactions.
    expose func activeCount() -> Integer {
        return activeTransactions.count();
    }

    // Get list of active transaction IDs (for checkpointing)
    /// @brief Snapshot of in-flight txn ids.  Used by
    ///        `checkpoint` to record who was alive at the moment
    ///        of the snapshot, and by MVCC readers to determine
    ///        which writers are still pending.
    expose func getActiveTxnIds() -> List[Integer] {
        var result: List[Integer] = [];
        var i = 0;
        while i < activeTransactions.count() {
            result.add(activeTransactions.get(i).txnId);
            i = i + 1;
        }
        return result;
    }

    // Create a checkpoint
    /// @brief Emit a CHECKPOINT WAL record containing the current
    ///        active-txn list.  Returns the LSN.  Recovery uses
    ///        this to bound how far back it needs to scan.
    expose func checkpoint() -> LSN {
        return wal.checkpoint(getActiveTxnIds());
    }

    //=========================================================================
    // AUTO-COMMIT MODE
    //=========================================================================

    // Set auto-commit mode
    /// @brief Toggle auto-commit mode.  When true, each DML
    ///        statement wraps itself in an implicit BEGIN/COMMIT
    ///        (PG default).  When false, statements stay part of
    ///        the current txn until the session calls COMMIT.
    expose func setAutoCommit(enabled: Boolean) {
        autoCommit = enabled;
    }

    // Get auto-commit mode
    /// @brief Current auto-commit mode.
    expose func isAutoCommit() -> Boolean {
        return autoCommit;
    }
}
