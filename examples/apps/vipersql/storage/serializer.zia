// =============================================================================
// serializer.zia — `BinaryBuffer` + `ValueSerializer` + `RowSerializer` +
//                  `ColumnSerializer`: the bytes ↔ objects boundary
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// Everywhere else in the engine deals in high-level objects
// (`SqlValue`, `Row`, `Column`).  The storage layer deals in raw bytes
// on 4-KB pages.  This file is where the two meet.  Four collaborating
// classes:
//
//   * `BinaryBuffer`   — a tiny append/read/seek byte buffer.  The
//                        "mini file-like object" used everywhere we
//                        need to emit or consume a byte stream.
//   * `ValueSerializer`— one `SqlValue` ↔ its tagged byte form.
//   * `RowSerializer`  — a whole `Row` (just column-count-prefixed
//                        sequence of values).
//   * `ColumnSerializer`— column metadata (used by schema pages only).
//
// WHERE THIS FITS
// ---------------
//     storage/page.zia       — VAL_TYPE_* and layout constants
//         │
//         ▼
//     storage/serializer.zia  (YOU ARE HERE)
//         │
//         ▼
//     storage/data_page.zia   (calls RowSerializer)
//     storage/schema_page.zia (calls ColumnSerializer)
//     storage/btree_node.zia  (calls ValueSerializer for index keys)
//
// KEY DESIGN CHOICES
// ------------------
//   1. Little-endian everywhere.  All multi-byte writes emit
//      least-significant-byte first; reads reassemble the same way.
//      Matches SQLite and PostgreSQL on common hardware and avoids
//      cross-platform surprises.
//
//   2. Two's-complement for signed ints.  Negative 32- and 64-bit
//      values are pre-shifted by the width's unsigned max before
//      writing, then detected and sign-extended on read.  Zia's
//      `Integer` is 64-bit signed, so round-tripping a negative
//      INT64 through `writeInt64`/`readInt64` gives back the same
//      value.
//
//   3. REAL stored as the *source text*.  Zia does not currently
//      expose IEEE 754 byte views, so we round-trip REALs as
//      length-prefixed strings.  This is inefficient (variable
//      width, parse required on read) but *correct* in the exact-
//      round-trip sense — the text is the same text the lexer
//      captured, so the value comes back with no double-rounding.
//
//   4. Strings are length-prefixed UTF-8-ish byte sequences.  A
//      4-byte length prefix means we can serialise strings up to
//      ~4 GB, which is plenty given a page is only 4 KB.
//
//   5. Column flags packed into a single byte.  Six bits for
//      primary/autoincrement/notnull/unique/foreign-key/hasDefault
//      plus two unused — fits comfortably in one byte.  FK and
//      default bytes follow conditionally.  This compactness
//      matters on schema pages, which may hold dozens of columns.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `BinaryBuffer` — the byte-level primitives: writeByte,
//      writeInt16/32/64, writeString, and their read counterparts.
//   2. `hexDigit` — small helper used by BinaryBuffer.toHexString
//      (diagnostic only).
//   3. `ValueSerializer` — per-kind encode/decode + size estimate.
//   4. `RowSerializer` — wraps ValueSerializer with a column-count
//      prefix.
//   5. `ColumnSerializer` — schema-level: name, type, flag byte,
//      optional FK and DEFAULT.
//
// =============================================================================

module serializer;

bind Viper.String as String;
bind "../engine/types";
bind "../engine/table";
bind "./page";

//=============================================================================
// BINARY BUFFER
//=============================================================================

/// @brief Append/read/seek byte buffer.
///
/// Backed by a `List[Integer]` of byte values.  `position` is a
/// shared read-and-write cursor — seek moves it, writes bump it,
/// reads consume it.  The buffer grows on write past the end.
/// Not thread-safe; each page gets its own.
class BinaryBuffer {
    expose List[Integer] bytes;
    expose Integer position;

    /// @brief Empty buffer at position 0.
    expose func init() {
        bytes = [];
        position = 0;
    }

    /// @brief Pre-allocate a buffer of the given byte count, all
    ///        zero-filled.  Used when we know the final size
    ///        (e.g. a 4-KB page buffer) so writes do not cascade
    ///        into list growth.
    expose func initWithCapacity(capacity: Integer) {
        bytes = [];
        position = 0;
        var i = 0;
        while i < capacity {
            bytes.add(0);
            i = i + 1;
        }
        position = 0;
    }

    /// @brief Current buffer length in bytes.
    expose func size() -> Integer {
        return bytes.count();
    }

    /// @brief Current cursor position.
    expose func writePosition() -> Integer {
        return position;
    }

    /// @brief Write a single byte (value modded to 0..255).
    ///
    /// If the cursor is past the end, the buffer grows.  Otherwise
    /// we overwrite in place.  This two-mode behaviour is what
    /// lets the pager scribble into the middle of a pre-allocated
    /// 4-KB buffer without shuffling anything.
    expose func writeByte(b: Integer) {
        if position < bytes.count() {
            bytes.set(position, b % 256);
        } else {
            bytes.add(b % 256);
        }
        position = position + 1;
    }

    /// @brief Write a 2-byte little-endian integer.
    expose func writeInt16(val: Integer) {
        writeByte(val % 256);
        writeByte((val / 256) % 256);
    }

    /// @brief Write a 4-byte little-endian integer (two's-complement
    ///        for negatives).
    ///
    /// The `+4294967296` for negatives is how we fake unsigned
    /// interpretation on top of Zia's signed integers — reading
    /// back as an unsigned magnitude yields the same 32-bit
    /// pattern.
    expose func writeInt32(val: Integer) {
        var v = val;
        if v < 0 { v = v + 4294967296; }
        writeByte(v % 256);
        writeByte((v / 256) % 256);
        writeByte((v / 65536) % 256);
        writeByte((v / 16777216) % 256);
    }

    /// @brief Write an 8-byte little-endian integer.
    ///
    /// Splits into lo/hi 32-bit halves; negative lo borrows from
    /// hi.  Then recurses through `writeInt32` which handles the
    /// per-half negative-to-unsigned conversion.
    expose func writeInt64(val: Integer) {
        var lo = val % 4294967296;
        var hi = val / 4294967296;
        if lo < 0 {
            lo = lo + 4294967296;
            hi = hi - 1;
        }
        if hi < 0 {
            hi = hi + 4294967296;
        }
        writeInt32(lo);
        writeInt32(hi);
    }

    /// @brief Write a length-prefixed string.
    ///
    /// Format: 4-byte length, then `length` raw bytes (one per
    /// character from `String.Substring(_, i, 1)`).  No encoding
    /// conversion — bytes go out as `String.Asc` reports them.
    expose func writeString(s: String) {
        var len = String.Length(s);
        writeInt32(len);
        var i = 0;
        while i < len {
            var ch = String.Substring(s, i, 1);
            var code = String.Asc(ch);
            writeByte(code);
            i = i + 1;
        }
    }

    /// @brief Read one byte; advances position.  Returns 0 past EOF
    ///        so callers never trap on truncated buffers — a defect
    ///        file still round-trips into NULL values.
    expose func readByte() -> Integer {
        if position >= bytes.count() {
            return 0;
        }
        var b = bytes.get(position);
        position = position + 1;
        return b;
    }

    /// @brief Read a 2-byte little-endian integer.
    expose func readInt16() -> Integer {
        var b0 = readByte();
        var b1 = readByte();
        return b0 + (b1 * 256);
    }

    /// @brief Read a 4-byte little-endian integer.
    ///
    /// Returns an unsigned interpretation — the caller is expected
    /// to know the field's expected range.  If you wrote a negative
    /// 32-bit value and read it back, you'll see the two's-
    /// complement unsigned value unless you post-process.
    expose func readInt32() -> Integer {
        var b0 = readByte();
        var b1 = readByte();
        var b2 = readByte();
        var b3 = readByte();
        return b0 + (b1 * 256) + (b2 * 65536) + (b3 * 16777216);
    }

    /// @brief Read an 8-byte little-endian integer, sign-extended.
    ///
    /// If the high word's MSB is set, we treat the whole thing as a
    /// negative two's-complement number and return the signed
    /// value.  This is the symmetric read of `writeInt64`.
    expose func readInt64() -> Integer {
        var lo = readInt32();
        var hi = readInt32();
        if hi >= 2147483648 {
            var signedHi = hi - 4294967296;
            return lo + (signedHi * 4294967296);
        }
        return lo + (hi * 4294967296);
    }

    /// @brief Read a length-prefixed string.  Matches `writeString`.
    expose func readString() -> String {
        var len = readInt32();
        var result = "";
        var i = 0;
        while i < len {
            var code = readByte();
            result = result + String.Chr(code);
            i = i + 1;
        }
        return result;
    }

    /// @brief Rewind the cursor to 0 (for sequential re-read).
    expose func resetPosition() {
        position = 0;
    }

    /// @brief Random-access seek.  Used everywhere slotted-page
    ///        manipulation happens — you seek to the slot offset,
    ///        read three int16s, seek to the payload, deserialize.
    expose func seek(pos: Integer) {
        position = pos;
    }

    /// @brief Underlying byte list.  Exposed primarily so the pager
    ///        can hand bytes straight to `File.Write`.  Treat as
    ///        read-only unless you are the pager.
    expose func getBytes() -> List[Integer] {
        return bytes;
    }

    /// @brief Debug-only hex dump (e.g. "00 01 ff 7e ...").
    expose func toHexString() -> String {
        var result = "";
        var i = 0;
        while i < bytes.count() {
            var b = bytes.get(i);
            var hi = b / 16;
            var lo = b % 16;
            result = result + hexDigit(hi) + hexDigit(lo) + " ";
            i = i + 1;
        }
        return result;
    }
}

/// @brief One nibble → one hex character.  Private helper for
///        `toHexString`; `'0'`=48 and `'A'`=65 in ASCII.
func hexDigit(n: Integer) -> String {
    if n < 10 {
        return String.Chr(48 + n);
    }
    return String.Chr(65 + n - 10);
}

//=============================================================================
// SQLVALUE SERIALIZER
//=============================================================================

/// @brief Tagged encoder/decoder for a single `SqlValue`.
///
/// Every cell on disk is prefixed with a `VAL_TYPE_*` byte
/// (see `page.zia`) followed by the kind-specific payload.  This
/// class is the authoritative owner of that encoding — if you
/// change the layout here, data files written by older binaries
/// become unreadable, so bump `FILE_VERSION` in `page.zia` first.
class ValueSerializer {
    /// @brief No state; constructor is a no-op.
    expose func init() {
    }

    /// @brief Write one value to a buffer.
    ///
    /// Dispatch-by-kind with a VAL_TYPE_NULL default so a corrupt
    /// `kind` (outside the known tags) degrades to a NULL cell
    /// rather than writing garbage.
    expose func serializeValue(val: SqlValue, buf: BinaryBuffer) {
        if val.kind == SQL_NULL {
            buf.writeByte(VAL_TYPE_NULL);
            return;
        }

        if val.kind == SQL_INTEGER {
            buf.writeByte(VAL_TYPE_INT);
            buf.writeInt64(val.intValue);
            return;
        }

        if val.kind == SQL_REAL {
            buf.writeByte(VAL_TYPE_REAL);
            // See design choice 3 — REAL as preserved source text.
            buf.writeString(val.textValue);
            return;
        }

        if val.kind == SQL_TEXT {
            buf.writeByte(VAL_TYPE_TEXT);
            buf.writeString(val.textValue);
            return;
        }

        if val.kind == SQL_BOOLEAN {
            buf.writeByte(VAL_TYPE_BOOL);
            buf.writeByte(val.intValue);  // 0 or 1
            return;
        }

        if val.kind == SQL_DATE {
            buf.writeByte(VAL_TYPE_DATE);
            buf.writeInt64(val.intValue);
            return;
        }

        if val.kind == SQL_TIMESTAMP {
            buf.writeByte(VAL_TYPE_TIMESTAMP);
            buf.writeInt64(val.intValue);
            return;
        }

        if val.kind == SQL_JSON {
            buf.writeByte(VAL_TYPE_JSON);
            buf.writeString(val.textValue);
            return;
        }

        // Fallback for unknown kinds — safer than writing nothing.
        buf.writeByte(VAL_TYPE_NULL);
    }

    /// @brief Read one value.  Symmetric to `serializeValue`; an
    ///        unknown tag yields `sqlNull()` so corrupt data doesn't
    ///        trap the page read.
    expose func deserializeValue(buf: BinaryBuffer) -> SqlValue {
        var typeTag = buf.readByte();

        if typeTag == VAL_TYPE_NULL {
            return sqlNull();
        }

        if typeTag == VAL_TYPE_INT {
            var intVal = buf.readInt64();
            return sqlInteger(intVal);
        }

        if typeTag == VAL_TYPE_REAL {
            // Preserved source text in `textValue`; `realValue` is
            // 0.0 because the producer already rendered it. The
            // executor recomputes on demand via stringToNumber.
            var realText = buf.readString();
            return sqlReal(0.0, realText);
        }

        if typeTag == VAL_TYPE_TEXT {
            var textVal = buf.readString();
            return sqlText(textVal);
        }

        if typeTag == VAL_TYPE_BOOL {
            var boolByte = buf.readByte();
            return sqlBoolean(boolByte != 0);
        }

        if typeTag == VAL_TYPE_DATE {
            var dateVal = buf.readInt64();
            return sqlDate(dateVal);
        }

        if typeTag == VAL_TYPE_TIMESTAMP {
            var tsVal = buf.readInt64();
            return sqlTimestamp(tsVal);
        }

        if typeTag == VAL_TYPE_JSON {
            var jsonVal = buf.readString();
            return sqlJson(jsonVal);
        }

        return sqlNull();
    }

    /// @brief Compute how many bytes `serializeValue` would write.
    ///
    /// Used by the slotted-page manager to check "does this row
    /// fit?" before committing to an insert.  Matches the layout
    /// above byte-for-byte.
    expose func valueSize(val: SqlValue) -> Integer {
        if val.kind == SQL_NULL {
            return 1;
        }

        if val.kind == SQL_INTEGER {
            return 1 + 8;
        }

        if val.kind == SQL_REAL {
            return 1 + 4 + String.Length(val.textValue);
        }

        if val.kind == SQL_TEXT {
            return 1 + 4 + String.Length(val.textValue);
        }

        if val.kind == SQL_BOOLEAN {
            return 1 + 1;
        }

        if val.kind == SQL_DATE {
            return 1 + 8;
        }

        if val.kind == SQL_TIMESTAMP {
            return 1 + 8;
        }

        if val.kind == SQL_JSON {
            return 1 + 4 + String.Length(val.textValue);
        }

        return 1;
    }
}

//=============================================================================
// ROW SERIALIZER
//=============================================================================

/// @brief Whole-row encode/decode: a column-count prefix plus one
///        `ValueSerializer` dump per cell.
///
/// Every row on a data page is stored this way; `data_page.zia`'s
/// `insertRow` calls `rowSize` to pre-check space then
/// `serializeRow` to emit bytes.  `deserializeRow` is the inverse,
/// called by `readRow`.
class RowSerializer {
    hide ValueSerializer valSer;

    /// @brief Cache a `ValueSerializer`.  The inner type has no
    ///        state, so reusing one instance is a cosmetic win —
    ///        we don't allocate per serialize call.
    expose func init() {
        valSer = new ValueSerializer();
        valSer.init();
    }

    /// @brief Write a row: int16 column count, then each value.
    expose func serializeRow(row: Row, buf: BinaryBuffer) {
        buf.writeInt16(row.columnCount());

        var i = 0;
        while i < row.columnCount() {
            var val = row.getValue(i);
            valSer.serializeValue(val, buf);
            i = i + 1;
        }
    }

    /// @brief Inverse of `serializeRow`.  Reads int16 column count
    ///        then that many values, appending each to a fresh
    ///        `Row`.
    expose func deserializeRow(buf: BinaryBuffer) -> Row {
        var row = new Row();
        row.init();

        var colCount = buf.readInt16();

        var i = 0;
        while i < colCount {
            var val = valSer.deserializeValue(buf);
            row.addValue(val);
            i = i + 1;
        }

        return row;
    }

    /// @brief Row size: 2 bytes for column count plus the sum of
    ///        each value's serialised size.  Called by
    ///        `data_page.canFitRow`.
    expose func rowSize(row: Row) -> Integer {
        var size = 2;  // column count prefix

        var i = 0;
        while i < row.columnCount() {
            size = size + valSer.valueSize(row.getValue(i));
            i = i + 1;
        }

        return size;
    }
}

//=============================================================================
// COLUMN SERIALIZER (schema pages only)
//=============================================================================

/// @brief Encode/decode a `Column` metadata object.
///
/// Used exclusively by `storage/schema_page.zia` to persist
/// CREATE TABLE columns into the catalog page.  Row serialisation
/// (above) does not use this — rows store *values*, not types;
/// types are recovered from the table's schema on read.
class ColumnSerializer {
    /// @brief No state.
    expose func init() {
    }

    /// @brief Write a column definition.
    ///
    /// Layout:
    ///     string  name
    ///     int32   typeCode                (one of SQL_*)
    ///     byte    flags bit-field
    ///         bit 0: primaryKey
    ///         bit 1: autoIncrement
    ///         bit 2: notNull
    ///         bit 3: unique
    ///         bit 4: isForeignKey
    ///         bit 5: hasDefault
    ///     string  refTableName  — only if isForeignKey
    ///     string  refColumnName — only if isForeignKey
    ///     <value> defaultValue  — only if hasDefault (uses
    ///                             ValueSerializer)
    expose func serializeColumn(col: Column, buf: BinaryBuffer) {
        buf.writeString(col.name);
        buf.writeInt32(col.typeCode);

        var flags = 0;
        if col.primaryKey { flags = flags + 1; }
        if col.autoIncrement { flags = flags + 2; }
        if col.notNull { flags = flags + 4; }
        if col.unique { flags = flags + 8; }
        if col.isForeignKey { flags = flags + 16; }
        if col.hasDefault { flags = flags + 32; }
        buf.writeByte(flags);

        if col.isForeignKey {
            buf.writeString(col.refTableName);
            buf.writeString(col.refColumnName);
        }

        if col.hasDefault {
            var valSer = new ValueSerializer();
            valSer.init();
            valSer.serializeValue(col.defaultValue, buf);
        }
    }

    /// @brief Inverse of `serializeColumn`.  Reads exactly the same
    ///        sequence of fields; conditional FK / default blocks
    ///        are decoded only when their flag bit is set.
    expose func deserializeColumn(buf: BinaryBuffer) -> Column {
        var col = new Column();
        col.init();

        col.name = buf.readString();
        col.typeCode = buf.readInt32();

        var flags = buf.readByte();
        col.primaryKey = (flags % 2) == 1;
        col.autoIncrement = ((flags / 2) % 2) == 1;
        col.notNull = ((flags / 4) % 2) == 1;
        col.unique = ((flags / 8) % 2) == 1;
        col.isForeignKey = ((flags / 16) % 2) == 1;
        col.hasDefault = ((flags / 32) % 2) == 1;

        if col.isForeignKey {
            col.refTableName = buf.readString();
            col.refColumnName = buf.readString();
        }

        if col.hasDefault {
            var valSer = new ValueSerializer();
            valSer.init();
            col.defaultValue = valSer.deserializeValue(buf);
        }

        return col;
    }
}
