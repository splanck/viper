// =============================================================================
// buffer.zia â€” LRU-evicting, pin-aware, thread-safe page cache
// Part of ViperSQL  (package: storage)
// =============================================================================
//
// PURPOSE
// -------
// The `Pager` (`./pager.zia`) knows how to read and write 4-KB pages
// to a file.  Every read-through would be slow and every caller has
// the same access pattern (read a page, mutate it, maybe write it
// back).  The `BufferPool` in this file caches the hot pages in
// memory so repeat access is free, evicts cold ones when it fills up,
// and tracks "pins" so a caller with a live reference is never
// evicted out from under it.
//
// Thread-safe: a `Threads.Monitor` guards every public method.
// Internal helpers follow a `*Internal` naming convention and assume
// the caller already holds the lock.
//
// WHERE THIS FITS
// ---------------
//     storage/pager.zia        (raw file-level I/O)
//         â”‚
//         â–¼
//     storage/buffer.zia       (YOU ARE HERE â€” cache, LRU, pinning)
//         â”‚
//         â–¼
//     storage/engine.zia, data_page.zia, btree.zia, schema_page.zia
//         (use fetchPage / newPage / unpinPage)
//
// KEY DESIGN CHOICES
// ------------------
//   1. LRU by logical clock.  Instead of a linked list, we keep a
//      parallel `accessOrder` list: every fetch/create bumps a
//      monotonically-increasing `accessCounter` and stamps the
//      entry.  Eviction picks the entry with the *lowest* stamp.
//      O(N) per decision; N is the pool size (100 by default) so
//      this is sub-millisecond.
//
//   2. Pin-count eviction protection.  `fetchPage` / `newPage` both
//      call `page.pin()`; callers must `unpinPage` when done.  Only
//      unpinned pages are eviction candidates (via
//      `page.canEvict()`).  This prevents the classic "cache
//      eviction during in-flight modification" bug without a heavy
//      ref-counted page wrapper.
//
//   3. Writeback on eviction + explicit flush.  Dirty pages get
//      written to disk when evicted OR when `flushAll` is called.
//      `flushAll` is invoked on close and can be invoked manually
//      (e.g. on a checkpoint) to flush the pool.  This pushes
//      through `pager.writePage`, not `pager.fsync` â€” the WAL
//      layer's job is durability; we just get the bytes onto the
//      page.
//
//   4. Three constructors, three scopes.  `init` + default size,
//      `initWithSize` for a custom pool (used by the server for
//      larger deployments), `initWithPager` when the caller wants
//      us to share an existing pager (e.g. a child BufferPool
//      backed by the same file).
//
//   5. `flushAllInternal` also calls `pager.flushHeader`.  This
//      keeps the file header (page count, schema-page pointer,
//      freelist head) on disk in lockstep with the data, which
//      means a crash between `flushAll` calls still recovers a
//      consistent snapshot.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Fields and the three `init*` overloads.
//   2. DB-file lifecycle: `createDatabase`, `openDatabase`,
//      `closeDatabase` (all thin wrappers around `pager` with the
//      lock held).
//   3. Hot-path page access: `fetchPage` / `newPage` and their
//      lockless `*Internal` helpers.
//   4. Lifetime control: `unpinPage`, `flushPage`, `flushAll`,
//      `deletePage`.
//   5. Cache bookkeeping: `findInCache`, `updateAccessOrder`,
//      `findEvictCandidate`, `evictPage`, `removeFromCache`.
//   6. Utility accessors at the bottom.
//
// =============================================================================

module buffer;

bind Viper.Threads as Threads;
bind "./page";
bind "./pager";
bind "./serializer";

//=============================================================================
// CONSTANTS
//=============================================================================

/// @brief Default cache size â€” 100 pages â‰ˆ 400 KB of working set.
///
/// Tuned for the demo's workloads; production deployments should
/// pick a larger size via `initWithSize`.  PG's default
/// `shared_buffers` is ~128 MB worth of 8-KB pages (~16384).
final DEFAULT_POOL_SIZE = 100;

//=============================================================================
// BUFFER POOL
//=============================================================================

/// @brief The page cache.
///
/// Holds up to `maxSize` pages.  Internal state:
///   * `pages` / `pageIds` â€” parallel lists, same length as
///     `accessOrder`.
///   * `accessOrder` â€” clock stamp per cache slot for LRU.
///   * `accessCounter` â€” monotonically-increasing global clock.
///   * `lock` â€” Monitor object; `Threads.Monitor.Enter/Exit` on
///     every public method.
///
/// The pool owns a `Pager` (public via `pager` / `getPager`).  The
/// `initWithPager` constructor shares a pager with another pool â€”
/// useful for the case where multiple logical caches want to live
/// against the same physical file.
class BufferPool {
    expose Pager pager;
    hide List[Page] pages;
    hide List[Integer] pageIds;
    hide List[Integer] accessOrder;    // per-slot clock stamp
    hide Integer maxSize;
    hide Integer accessCounter;
    hide List[Integer] lock;           // Monitor target

    /// @brief Default-size pool with a fresh pager.
    expose func init() {
        pager = new Pager();
        pager.init();
        pages = [];
        pageIds = [];
        accessOrder = [];
        maxSize = DEFAULT_POOL_SIZE;
        accessCounter = 0;
        lock = [];
    }

    /// @brief Custom-size pool.  `poolSize` is the max number of
    ///        pages kept in memory simultaneously.  More = fewer
    ///        disk reads at the cost of higher RAM.
    expose func initWithSize(poolSize: Integer) {
        pager = new Pager();
        pager.init();
        pages = [];
        pageIds = [];
        accessOrder = [];
        maxSize = poolSize;
        accessCounter = 0;
        lock = [];
    }

    /// @brief Share an existing pager.  Useful when two logical
    ///        caches (e.g. index-only vs heap-only) want to hit
    ///        the same underlying file.
    expose func initWithPager(existingPager: Pager) {
        pager = existingPager;
        pages = [];
        pageIds = [];
        accessOrder = [];
        maxSize = DEFAULT_POOL_SIZE;
        accessCounter = 0;
        lock = [];
    }

    //=========================================================================
    // DATABASE-FILE OPERATIONS
    //=========================================================================

    /// @brief Create (overwrite) a database file.  Returns false on
    ///        failure (disk full, permission denied, etc.).
    expose func createDatabase(filename: String) -> Boolean {
        Threads.Monitor.Enter(lock);
        var result = pager.createDatabase(filename);
        Threads.Monitor.Exit(lock);
        return result;
    }

    /// @brief Open an existing database file.  Returns false on
    ///        missing file, wrong magic, unknown version.
    expose func openDatabase(filename: String) -> Boolean {
        Threads.Monitor.Enter(lock);
        var result = pager.openDatabase(filename);
        Threads.Monitor.Exit(lock);
        return result;
    }

    /// @brief Close the database.  Flushes every dirty page and
    ///        clears the cache so a subsequent `openDatabase` on a
    ///        different file starts fresh.
    expose func closeDatabase() {
        Threads.Monitor.Enter(lock);
        flushAllInternal();
        pager.closeDatabase();
        pages = [];
        pageIds = [];
        accessOrder = [];
        Threads.Monitor.Exit(lock);
    }

    //=========================================================================
    // PAGE ACCESS
    //=========================================================================

    /// @brief Fetch a page, from cache if present or disk if not.
    ///        Pins the returned page â€” caller must `unpinPage`.
    ///
    /// Null return = I/O error (pager couldn't read the page).
    /// Thread-safe wrapper; the real work is in `*Internal`.
    expose func fetchPage(pageId: Integer) -> Page? {
        Threads.Monitor.Enter(lock);
        var result = fetchPageInternal(pageId);
        Threads.Monitor.Exit(lock);
        return result;
    }

    /// @brief Lock-free fetch.  Caller must hold `lock`.
    ///
    /// Two paths: cache hit (bump access stamp, pin, return) or
    /// cache miss (read from pager, evict if full, insert, pin,
    /// return).
    hide func fetchPageInternal(pageId: Integer) -> Page? {
        var cacheIdx = findInCache(pageId);
        if cacheIdx >= 0 {
            updateAccessOrder(cacheIdx);
            var page = pages.get(cacheIdx);
            page.pin();
            return page;
        }

        // Cache miss â€” fetch from disk.
        var page = pager.readPage(pageId);
        if page == null {
            return null;
        }
        var p = page;

        if pages.count() >= maxSize {
            evictPage();
        }

        pages.add(p);
        pageIds.add(pageId);
        accessOrder.add(accessCounter);
        accessCounter = accessCounter + 1;

        p.pin();
        return p;
    }

    /// @brief Allocate a fresh page.  Pins and returns it, marked
    ///        dirty so it is flushed on next flush/eviction.
    ///
    /// The pager picks the page id (freelist head if non-empty,
    /// else extends the file).  We put the newly-initialised page
    /// straight into cache â€” the caller almost certainly wants to
    /// write to it next.
    expose func newPage(pageType: Integer) -> Page {
        Threads.Monitor.Enter(lock);
        var result = newPageInternal(pageType);
        Threads.Monitor.Exit(lock);
        return result;
    }

    /// @brief Lock-free newPage.  Caller must hold `lock`.
    hide func newPageInternal(pageType: Integer) -> Page {
        var pageId = pager.allocatePage();

        var page = new Page();
        page.initWithId(pageId, pageType);
        page.markDirty();

        if pages.count() >= maxSize {
            evictPage();
        }

        pages.add(page);
        pageIds.add(pageId);
        accessOrder.add(accessCounter);
        accessCounter = accessCounter + 1;

        page.pin();
        return page;
    }

    /// @brief Release a caller's reference to a page.  If the
    ///        caller made changes, pass `isDirty = true` so the
    ///        page goes through the writeback path.
    ///
    /// Unpinning does NOT evict â€” the page stays in cache and may
    /// be re-served for free on next fetch.  Only eviction (via
    /// `evictPage`) writes + removes.
    expose func unpinPage(pageId: Integer, isDirty: Boolean) {
        Threads.Monitor.Enter(lock);
        var cacheIdx = findInCache(pageId);
        if cacheIdx >= 0 {
            var page = pages.get(cacheIdx);
            page.unpin();
            if isDirty {
                page.markDirty();
            }
        }
        Threads.Monitor.Exit(lock);
    }

    /// @brief Force a specific page to disk right now.  Returns
    ///        false if the page is not in cache (then the caller
    ///        has nothing to flush).
    expose func flushPage(pageId: Integer) -> Boolean {
        Threads.Monitor.Enter(lock);
        var cacheIdx = findInCache(pageId);
        if cacheIdx < 0 {
            Threads.Monitor.Exit(lock);
            return false;
        }

        var page = pages.get(cacheIdx);
        if page.dirty {
            pager.writePage(page);
        }
        Threads.Monitor.Exit(lock);
        return true;
    }

    /// @brief Force every dirty page out.  Public wrapper around
    ///        `flushAllInternal`; grabs the lock.
    expose func flushAll() {
        Threads.Monitor.Enter(lock);
        flushAllInternal();
        Threads.Monitor.Exit(lock);
    }

    /// @brief Lock-free flush-all.  Walks the cache, writes every
    ///        dirty entry, then updates the file header.
    ///
    /// Header flush is important: it persists
    /// (pageCount, schemaPageId, freelistHead) so a crash between
    /// flushAlls still recovers an internally consistent file.
    hide func flushAllInternal() {
        var i = 0;
        while i < pages.count() {
            var page = pages.get(i);
            if page.dirty {
                pager.writePage(page);
            }
            i = i + 1;
        }
        pager.flushHeader();
    }

    /// @brief Free a page: drop from cache (writing back if dirty)
    ///        and hand to the pager's freelist for reuse.
    ///
    /// Called by DROP TABLE / DROP INDEX / VACUUM to reclaim
    /// no-longer-needed pages.  The freed page may immediately be
    /// handed back out by the next `newPage` call, so callers must
    /// have dropped every live reference first.
    expose func deletePage(pageId: Integer) {
        Threads.Monitor.Enter(lock);
        var cacheIdx = findInCache(pageId);
        if cacheIdx >= 0 {
            removeFromCache(cacheIdx);
        }

        pager.freePage(pageId);
        Threads.Monitor.Exit(lock);
    }

    //=========================================================================
    // INTERNAL CACHE BOOKKEEPING
    //=========================================================================

    /// @brief Linear scan for a pageId in the cache.  Returns the
    ///        slot index, -1 if absent.  The pool is small (~100
    ///        pages) so O(N) is faster than a hash map.
    hide func findInCache(pageId: Integer) -> Integer {
        var i = 0;
        while i < pageIds.count() {
            if pageIds.get(i) == pageId {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Bump a cache slot's access stamp.  Called on every
    ///        cache hit so the LRU ordering reflects real access.
    hide func updateAccessOrder(cacheIdx: Integer) {
        accessOrder.set(cacheIdx, accessCounter);
        accessCounter = accessCounter + 1;
    }

    /// @brief Pick the least-recently-used *unpinned* cache slot.
    ///        Returns -1 if every slot is pinned â€” in practice
    ///        this should not happen unless the workload's live
    ///        working set exceeds `maxSize`.
    hide func findEvictCandidate() -> Integer {
        var minAccess = accessCounter + 1;  // sentinel above any real stamp
        var minIdx = -1;

        var i = 0;
        while i < pages.count() {
            var page = pages.get(i);
            if page.canEvict() {
                var access = accessOrder.get(i);
                if access < minAccess {
                    minAccess = access;
                    minIdx = i;
                }
            }
            i = i + 1;
        }

        return minIdx;
    }

    /// @brief Evict one LRU page.  Silent no-op if nothing is
    ///        evictable (see `findEvictCandidate`).  Writes back
    ///        dirty pages before removal.
    hide func evictPage() {
        var evictIdx = findEvictCandidate();
        if evictIdx < 0 {
            return;
        }

        var page = pages.get(evictIdx);

        if page.dirty {
            pager.writePage(page);
        }

        removeFromCache(evictIdx);
    }

    /// @brief Drop one cache slot across all three parallel lists.
    hide func removeFromCache(idx: Integer) {
        pages.removeAt(idx);
        pageIds.removeAt(idx);
        accessOrder.removeAt(idx);
    }

    //=========================================================================
    // UTILITY
    //=========================================================================

    /// @brief Current pages-in-cache count (0..maxSize).
    expose func cacheSize() -> Integer {
        return pages.count();
    }

    /// @brief Raw pager handle.  Used by modules that need to
    ///        bypass the cache (e.g. the WAL, which writes its own
    ///        pages sequentially).
    expose func getPager() -> Pager {
        return pager;
    }

    /// @brief Page id of the schema/catalog page.  Convenience
    ///        accessor used by `storage/engine.zia` after open.
    expose func getSchemaPageId() -> Integer {
        return pager.getSchemaPageId();
    }
}
