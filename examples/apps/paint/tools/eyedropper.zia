//
// File: examples/apps/paint/tools/eyedropper.zia
// Purpose: Click to sample a pixel's colour into the foreground. Instant tool.
// Key invariants:
//   - Alpha-aware: samples the COMPOSITE via DrawingCanvas.sampleColor, which
//     returns -1 for fully transparent pixels (skipped) instead of guessing
//     with a "color != 0" heuristic.
//   - Read-only: does not push an undo snapshot.
// Ownership/Lifetime:
//   - Stateless except the last picked colour (for status display).
// Links: tool.zia, ../canvas.zia (sampleColor)
//
//===----------------------------------------------------------------------===//

// eyedropper.zia - Eyedropper (colour picker) tool for Zanna Paint
module eyedropper;

bind Zanna.Graphics;

bind "../config";
bind "../canvas";
bind "../colors";
bind "../viewport";
bind "./tool";

/// @brief Click-to-sample colour picker (alpha-aware, samples composite).
class EyedropperTool implements Tool {
    expose Integer lastPickedColor;

    expose func init() {
        lastPickedColor = 0;
    }

    expose func id() -> Integer { return config.TOOL_EYEDROPPER; }
    expose func name() -> String { return "Eyedropper"; }
    expose func icon() -> String { return "I"; }
    expose func isFreehand() -> Integer { return 0; }
    expose func isDrawing() -> Integer { return 0; }
    expose func snapshotsBeforePress() -> Integer { return 0; }

    expose func onPress(x: Integer, y: Integer, ctx: ToolContext) {
        var color = ctx.dc.sampleColor(x, y);
        if color >= 0 {
            ctx.colors.setForeground(color);
            lastPickedColor = color;
        }
    }

    expose func onDrag(_x: Integer, _y: Integer, _ctx: ToolContext) {
    }

    expose func onRelease(_x: Integer, _y: Integer, _ctx: ToolContext) {
    }

    expose func drawPreview(_gfx: Canvas, _view: CanvasViewport, _ctx: ToolContext) {
    }
}
