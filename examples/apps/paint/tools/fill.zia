//
// File: examples/apps/paint/tools/fill.zia
// Purpose: Single-click flood fill. Instant (no drag, no preview); all work is
//          in DrawingCanvas.floodFill (iterative scanline fill).
// Key invariants:
//   - isDrawing always 0; the fill completes within onPress.
// Ownership/Lifetime:
//   - Stateless.
// Links: tool.zia, ../canvas.zia
//
//===----------------------------------------------------------------------===//

// fill.zia - Flood fill tool for Viper Paint
module fill;

bind Viper.Graphics;

bind "../config";
bind "../canvas";
bind "../colors";
bind "../viewport";
bind "./tool";

/// @brief Instant flood-fill tool (click to fill connected region).
class FillTool implements Tool {
    expose func init() {
    }

    expose func id() -> Integer { return config.TOOL_FILL; }
    expose func name() -> String { return "Fill"; }
    expose func icon() -> String { return "F"; }
    expose func isFreehand() -> Integer { return 0; }
    expose func isDrawing() -> Integer { return 0; }
    expose func snapshotsBeforePress() -> Integer { return 1; }

    expose func onPress(x: Integer, y: Integer, ctx: ToolContext) {
        ctx.dc.floodFill(x, y, ctx.colors.foreground);
    }

    expose func onDrag(x: Integer, y: Integer, ctx: ToolContext) {
    }

    expose func onRelease(x: Integer, y: Integer, ctx: ToolContext) {
    }

    expose func drawPreview(gfx: Canvas, view: CanvasViewport, ctx: ToolContext) {
    }
}
