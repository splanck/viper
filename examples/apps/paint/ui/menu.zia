//
// File: examples/apps/paint/ui/menu.zia
// Purpose: Immediate-mode in-canvas menu bar (File / Edit / Image / Layer /
//          View / Help). Each item carries an action string; handleMouse
//          returns the fired action so the app can dispatch it.
// Key invariants:
//   - Only one dropdown is open at a time (openIndex; -1 = none).
//   - Layout (per-menu x/width) is recomputed on demand from title widths.
// Ownership/Lifetime:
//   - Owned by PaintApp; menus/items built once at startup.
// Links: app.zia (dispatchMenuAction)
//
//===----------------------------------------------------------------------===//

// menu.zia - In-canvas menu bar for Zanna Paint
module menu;

bind Zanna.Graphics;
bind Zanna.Collections;

bind "../config";

final ITEM_H = 20;
final TITLE_PAD = 12;
final ITEM_PAD = 14;

/// @brief One dropdown entry: a label + the action string it fires.
class MenuItem {
    expose String label;
    expose String action;

    expose func init() {
        label = "";
        action = "";
    }

    expose func setup(l: String, a: String) {
        label = l;
        action = a;
    }
}

/// @brief A top-level menu (title + items).
class Menu {
    expose String title;
    expose List[MenuItem] items;
    expose Integer x;
    expose Integer width;

    expose func init() {
        title = "";
        items = [];
        x = 0;
        width = 0;
    }

    expose func setup(t: String) {
        title = t;
        items = [];
        x = 0;
        width = 0;
    }

    expose func addItem(label: String, action: String) {
        var it = new MenuItem();
        it.setup(label, action);
        items.add(it);
    }

    expose func itemCount() -> Integer {
        return items.count();
    }

    expose func dropdownWidth() -> Integer {
        var w = 80;
        var i = 0;
        while i < items.count() {
            var it = items.get(i);
            var lw = Canvas.TextWidth(it.label) + ITEM_PAD * 2;
            if lw > w {
                w = lw;
            }
            i = i + 1;
        }
        return w;
    }
}

/// @brief The menu bar: a row of menus with at most one open dropdown.
class MenuBar {
    hide List[Menu] menus;
    hide Integer openIndex;
    expose Integer height;

    expose func init() {
        menus = [];
        openIndex = -1;
        height = 22;
    }

    expose func addMenu(title: String) -> Menu {
        var m = new Menu();
        m.setup(title);
        menus.add(m);
        return m;
    }

    expose func isOpen() -> Integer {
        if openIndex >= 0 {
            return 1;
        }
        return 0;
    }

    expose func closeAll() {
        openIndex = -1;
    }

    // Recompute each menu's x/width from its title.
    hide func layout() {
        var cx = 6;
        var i = 0;
        while i < menus.count() {
            var m = menus.get(i);
            m.x = cx;
            m.width = Canvas.TextWidth(m.title) + TITLE_PAD * 2;
            cx = cx + m.width;
            i = i + 1;
        }
    }

    /// @brief Process a click; returns the fired action string, or "".
    expose func handleMouse(mx: Integer, my: Integer, pressed: Integer) -> String {
        layout();
        if pressed == 0 {
            return "";
        }

        // Click on a top-level title toggles its dropdown.
        if my >= 0 and my < height {
            var i = 0;
            while i < menus.count() {
                var m = menus.get(i);
                if mx >= m.x and mx < m.x + m.width {
                    if openIndex == i {
                        openIndex = -1;
                    } else {
                        openIndex = i;
                    }
                    return "";
                }
                i = i + 1;
            }
            openIndex = -1;
            return "";
        }

        // Click within the open dropdown selects an item.
        if openIndex >= 0 {
            var m = menus.get(openIndex);
            var dw = m.dropdownWidth();
            var dy = height;
            var n = m.itemCount();
            if mx >= m.x and mx < m.x + dw and my >= dy and my < dy + n * ITEM_H {
                var idx = (my - dy) / ITEM_H;
                if idx >= 0 and idx < n {
                    var it = m.items.get(idx);
                    openIndex = -1;
                    return it.action;
                }
            }
            openIndex = -1;
        }
        return "";
    }

    // Draw the bar + titles (called early in the frame).
    expose func drawBar(gfx: Canvas, barWidth: Integer) {
        layout();
        gfx.GradientV(0, 0, barWidth, height, config.UI_BG_PANEL_HI, config.UI_BG_PANEL_LO);
        gfx.Line(0, height - 1, barWidth, height - 1, config.UI_BORDER);

        var ty = (height - 8) / 2;
        var i = 0;
        while i < menus.count() {
            var m = menus.get(i);
            if openIndex == i {
                gfx.Box(m.x, 0, m.width, height, config.UI_ACCENT);
            }
            gfx.Text(m.x + TITLE_PAD, ty, m.title, config.UI_TEXT);
            i = i + 1;
        }
    }

    // Draw the open dropdown (called late so it sits above the canvas/panels).
    expose func drawOverlay(gfx: Canvas, mx: Integer, my: Integer) {
        if openIndex >= 0 {
            layout();
            drawDropdown(gfx, mx, my);
        }
    }

    hide func drawDropdown(gfx: Canvas, mx: Integer, my: Integer) {
        var m = menus.get(openIndex);
        var dw = m.dropdownWidth();
        var dy = height;
        var n = m.itemCount();
        var dh = n * ITEM_H + 4;
        gfx.Box(m.x + 3, dy + 3, dw, dh, config.UI_SHADOW);
        gfx.Box(m.x, dy, dw, dh, config.UI_BG_BUTTON);
        gfx.Frame(m.x, dy, dw, dh, config.UI_BORDER);

        var i = 0;
        while i < n {
            var it = m.items.get(i);
            var iy = dy + 2 + i * ITEM_H;
            if mx >= m.x and mx < m.x + dw and my >= iy and my < iy + ITEM_H {
                gfx.Box(m.x + 1, iy, dw - 2, ITEM_H, config.UI_ACCENT);
            }
            gfx.Text(m.x + ITEM_PAD, iy + 6, it.label, config.UI_TEXT);
            i = i + 1;
        }
    }
}
