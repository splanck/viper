// ============================================================================
// MODULE: entity_gfx_test (class + graphics bring-up)
// PURPOSE: Combines OOP (a class) with a graphics call (Canvas.New).
//          Used to test that class fields can hold graphics handles —
//          a combination that broke during native codegen bring-up.
// ============================================================================

module entity_gfx_test;

bind Viper.Graphics;

/// @brief Class that owns a Canvas handle — the regression target.
class TestEntity {
    expose Integer value;
    expose ptr canvas;

    expose func init() {
        value = 42;
        canvas = Canvas.New("Entity Test", 100, 100);
    }

    expose func cleanup() {
        // Just set value to show we got here
        value = 99;
    }
}

func main() {
    var entity = new TestEntity();
    entity.cleanup();
    // Return entity.value which should be 99
}
