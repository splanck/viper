//===----------------------------------------------------------------------===//
//
// File: examples/apps/paint/layer_panel.zia
// Purpose: Layer list sidebar. Shows each layer (visibility, name, opacity,
//          blend mode) top-down, plus an active-layer control strip with a
//          click-to-cycle blend label and a click-to-set opacity bar.
// Key invariants:
//   - Rows are drawn top (count-1) down to 0 to match the composited stack.
//   - Left-click a row selects; right-click toggles visibility; the control
//     strip edits the active layer's blend mode / opacity.
// Ownership/Lifetime:
//   - Stateless view over DrawingCanvas; positioned by PaintApp each frame.
// Links: canvas.zia (layer accessors), layers.zia (blend names)
//
//===----------------------------------------------------------------------===//

// layer_panel.zia - Layer list rendering and interaction for Paint
module layer_panel;

bind Viper.Graphics;
bind Str = Viper.String;

bind "./canvas";
bind "./config";

/// @brief Layer-list sidebar with active-layer blend + opacity controls.
class LayerPanel {
    expose Integer x;
    expose Integer y;
    expose Integer width;
    expose Integer height;
    hide Integer rowHeight;

    expose func init() {
        x = 0;
        y = 0;
        width = 0;
        height = 0;
        rowHeight = 26;
    }

    expose func setup(px: Integer, py: Integer, pw: Integer, ph: Integer) {
        x = px;
        y = py;
        width = pw;
        height = ph;
        if width < 80 { width = 80; }
        if height < 80 { height = 80; }
    }

    hide func ctrlY() -> Integer { return y + 26; }
    hide func blendX() -> Integer { return x + 6; }
    hide func blendW() -> Integer { return 46; }
    hide func opBarX() -> Integer { return x + 56; }
    hide func opBarW() -> Integer { return width - 62; }
    hide func rowsTop() -> Integer { return y + 50; }

    expose func draw(gfx: Canvas, doc: canvas.DrawingCanvas) {
        gfx.RoundBox(x, y, width, height, 6, config.UI_BG_PANEL);
        gfx.RoundFrame(x, y, width, height, 6, config.UI_BORDER);
        gfx.Text(x + 8, y + 8, "Layers", config.UI_TEXT);

        // Active-layer control strip: blend label + opacity bar.
        var cy = ctrlY();
        gfx.RoundBox(blendX(), cy, blendW(), 16, 3, config.UI_BG_BUTTON);
        gfx.RoundFrame(blendX(), cy, blendW(), 16, 3, config.UI_BORDER);
        gfx.Text(blendX() + 5, cy + 4, doc.activeBlendName(), config.UI_TEXT);

        var op = doc.layerOpacityAt(doc.activeLayerIndex());
        gfx.RoundBox(opBarX(), cy + 2, opBarW(), 12, 3, config.UI_BG_DARK);
        var fill = op * opBarW() / 100;
        if fill > 0 {
            gfx.RoundBox(opBarX(), cy + 2, fill, 12, 3, config.UI_ACCENT);
        }
        gfx.RoundFrame(opBarX(), cy + 2, opBarW(), 12, 3, config.UI_BORDER);

        var rowY = rowsTop();
        var i = doc.layerCount() - 1;
        while i >= 0 {
            drawLayerRow(gfx, doc, i, rowY);
            rowY = rowY + rowHeight;
            i = i - 1;
        }
    }

    expose func handleMouse(mx: Integer,
                            my: Integer,
                            leftDown: Integer,
                            rightDown: Integer,
                            lastLeftDown: Integer,
                            lastRightDown: Integer,
                            doc: canvas.DrawingCanvas) -> String {
        if mx < x or mx >= x + width or my < y or my >= y + height {
            return "";
        }

        var pressed = 0;
        if leftDown == 1 and lastLeftDown == 0 {
            pressed = 1;
        }

        // Active-layer control strip.
        var cy = ctrlY();
        if leftDown == 1 and my >= cy and my < cy + 16 {
            if pressed == 1 and mx >= blendX() and mx < blendX() + blendW() {
                doc.cycleActiveBlendMode();
                return "Blend: " + doc.activeBlendName();
            }
            if mx >= opBarX() and mx < opBarX() + opBarW() {
                var pct = (mx - opBarX()) * 100 / opBarW();
                if pct < 0 { pct = 0; }
                if pct > 100 { pct = 100; }
                doc.setActiveLayerOpacity(pct);
                return "Opacity " + pct;
            }
        }

        // Layer rows.
        var row = (my - rowsTop()) / rowHeight;
        if row < 0 {
            return "";
        }
        var layerIndex = doc.layerCount() - 1 - row;
        if layerIndex < 0 or layerIndex >= doc.layerCount() {
            return "";
        }

        if pressed == 1 {
            doc.selectLayer(layerIndex);
            return "Selected " + doc.activeLayerName();
        }

        if rightDown == 1 and lastRightDown == 0 {
            doc.toggleLayerVisible(layerIndex);
            if doc.layerVisibleAt(layerIndex) == 1 {
                return "Layer visible: " + doc.layerNameAt(layerIndex);
            }
            return "Layer hidden: " + doc.layerNameAt(layerIndex);
        }

        return "";
    }

    hide func drawLayerRow(gfx: Canvas, doc: canvas.DrawingCanvas, layerIndex: Integer, rowY: Integer) {
        var selected = 0;
        if layerIndex == doc.activeLayerIndex() {
            selected = 1;
        }

        var bg = config.UI_BG_DARK;
        if selected == 1 {
            bg = config.UI_BG_BUTTON_ACTIVE;
        }
        gfx.RoundBox(x + 4, rowY, width - 8, rowHeight - 2, 3, bg);
        gfx.RoundFrame(x + 4, rowY, width - 8, rowHeight - 2, 3, config.UI_BORDER);

        // Visibility dot.
        var eyeColor = config.UI_TEXT_DIM;
        if doc.layerVisibleAt(layerIndex) == 1 {
            eyeColor = config.UI_ACCENT_HI;
        }
        gfx.Disc(x + 12, rowY + 8, 4, eyeColor);

        // Name (truncated).
        var label = doc.layerNameAt(layerIndex);
        var maxChars = (width - 36) / 8;
        if maxChars < 3 { maxChars = 3; }
        if Str.get_Length(label) > maxChars {
            label = Str.Left(label, maxChars - 1) + ".";
        }
        gfx.Text(x + 22, rowY + 3, label, config.UI_TEXT);

        // Opacity % + blend label (second line, dim).
        var info = doc.layerOpacityAt(layerIndex) + "% " + doc.blendNameAt(layerIndex);
        gfx.Text(x + 22, rowY + 13, info, config.UI_TEXT_DIM);
    }
}
