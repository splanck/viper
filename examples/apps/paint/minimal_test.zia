// ============================================================================
// MODULE: minimal_test (native OOP bring-up)
// PURPOSE: Counter class with increment + getter. Smaller than
//          simple_class.zia — used to bisect OOP regressions without
//          any graphics dependencies.
// ============================================================================

module minimal_test;

/// @brief Minimal counter class for OOP bring-up testing.
class Counter {
    expose Integer value;

    expose func init() {
        value = 0;
    }

    expose func increment() {
        value = value + 1;
    }

    expose func get() -> Integer {
        return value;
    }
}

func main() {
    var c = new Counter();
    c.increment();
    c.increment();
    c.increment();
    var result = c.get();
    // Should return 3
}
