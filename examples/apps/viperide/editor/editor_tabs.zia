module editor_tabs;

bind "../core/document";
bind Viper.GUI as GUI;

// ============================================================================
// MODULE: editor_tabs
// PURPOSE: Manages the tab bar widget and the per-tab title / tooltip /
//          modified-marker state. Operations are indexed by tab position
//          to match the parallel ordering used by `DocumentManager`.
//
// WHERE-THIS-FITS: Bridge between DocumentManager (model) and the
//          GUI.TabBar widget (view). Owned by main.zia. Operates by
//          looking up tabs through `tabBar.GetTabAt(index)`.
//
// KEY-DESIGN-CHOICES:
//   * NO PARALLEL TAB LIST. We don't keep our own `List[Tab]` mirroring
//     the tab bar. C-allocated Tab handles can't be safely stored in
//     Zia runtime Lists (heap-header validation rejects them), so we
//     re-fetch them each operation via `GetTabAt`. The trade-off is one
//     extra runtime call per operation; the benefit is no double-free
//     hazard on tab close.
//   * AUTO-CLOSE DISABLED. `tabBar.SetAutoClose(0)` disables the
//     widget's built-in close-on-click handling so the IDE can route
//     close requests through `DocumentManager.CloseDocument` (which
//     handles dirty-buffer prompts).
//   * INDEX-BASED API. Every method takes a tab index. This keeps the
//     calling code symmetric with DocumentManager which also uses
//     indices. Out-of-range indices silently no-op.
// ============================================================================

/// @brief Tab bar wrapper with index-addressable tab operations.
class EditorTabs {
    expose GUI.TabBar tabBar;        // TabBar widget handle.
    expose Integer lastActiveIndex;  // Cache for detecting tab switches in the main loop.

    expose func init() {
        lastActiveIndex = -1;
    }

    /// @brief Inject the TabBar widget and disable auto-close.
    /// @note Auto-close is disabled because the IDE intercepts close to
    ///       prompt for unsaved changes.
    expose func Setup(tabBarWidget: GUI.TabBar) {
        tabBar = tabBarWidget;
        tabBar.SetAutoClose(0);
    }

    /// @brief Append a new tab.
    /// @param closeable 1 to show the close button, 0 to hide it.
    expose func AddTab(name: String, closeable: Integer) {
        tabBar.AddTab(name, closeable);
    }

    /// @brief Remove the tab at `index`. Out-of-range no-ops.
    expose func RemoveTab(index: Integer) {
        if index < 0 or index >= tabBar.TabCount {
            return;
        }
        var tab: GUI.Tab = tabBar.GetTabAt(index);
        tabBar.RemoveTab(tab);
    }

    /// @brief Activate the tab at `index`. Updates `lastActiveIndex`.
    expose func SetActive(index: Integer) {
        if index < 0 or index >= tabBar.TabCount {
            return;
        }
        var tab: GUI.Tab = tabBar.GetTabAt(index);
        tabBar.SetActive(tab);
        lastActiveIndex = index;
    }

    /// @brief Update tab title (e.g., after Save As renames the file).
    expose func SetTitle(index: Integer, title: String) {
        if index < 0 or index >= tabBar.TabCount {
            return;
        }
        var tab: GUI.Tab = tabBar.GetTabAt(index);
        tab.SetTitle(title);
    }

    /// @brief Update tab tooltip — usually the full file path so a
    ///        truncated tab title is still discoverable.
    expose func SetTooltip(index: Integer, tooltip: String) {
        if index < 0 or index >= tabBar.TabCount {
            return;
        }
        var tab: GUI.Tab = tabBar.GetTabAt(index);
        tab.SetTooltip(tooltip);
    }

    /// @brief Show or clear the modified-indicator dot on a tab.
    expose func SetModified(index: Integer, modified: Boolean) {
        if index < 0 or index >= tabBar.TabCount {
            return;
        }
        var tab: GUI.Tab = tabBar.GetTabAt(index);
        if modified {
            tab.SetModified(1);
        } else {
            tab.SetModified(0);
        }
    }

    /// @brief Number of open tabs.
    expose func GetCount() -> Integer {
        return tabBar.TabCount;
    }
}
