// Test that SQL keywords can be used as column names
module test_keyword_columns;

bind Terminal = Viper.Terminal;
bind Fmt = Viper.Fmt;

bind "../executor";
bind "../types";

var passed = 0;
var failed = 0;

func check(result: QueryResult, msg: String) {
    if result.success {
        passed = passed + 1;
        Terminal.Say("  PASS: " + msg);
    } else {
        failed = failed + 1;
        Terminal.Say("  FAIL: " + msg + " => " + result.message);
    }
}

func checkFail(result: QueryResult, msg: String) {
    if result.success == false {
        passed = passed + 1;
        Terminal.Say("  PASS: " + msg);
    } else {
        failed = failed + 1;
        Terminal.Say("  FAIL: " + msg + " (expected failure)");
    }
}

func main() -> Integer {
    Terminal.Say("=== Keyword as Column Name Tests ===");

    var exec = new Executor();
    exec.init();

    // Test 1: PASSWORD as column name
    Terminal.Say("Test 1: PASSWORD as column name");
    var r = exec.executeSql("CREATE TABLE users (id INTEGER, password TEXT, name TEXT)");
    check(r, "1a: CREATE TABLE with PASSWORD column");

    r = exec.executeSql("INSERT INTO users VALUES (1, 'secret123', 'alice')");
    check(r, "1b: INSERT with password value");

    r = exec.executeSql("SELECT password FROM users WHERE id = 1");
    check(r, "1c: SELECT password column");

    r = exec.executeSql("UPDATE users SET password = 'newpass' WHERE id = 1");
    check(r, "1d: UPDATE password column");

    r = exec.executeSql("SELECT password FROM users WHERE id = 1");
    check(r, "1e: SELECT updated password");

    // Test 2: USER as column name
    Terminal.Say("Test 2: USER as column name");
    r = exec.executeSql("CREATE TABLE audit_log (id INTEGER, user TEXT, action TEXT)");
    check(r, "2a: CREATE TABLE with USER column");

    r = exec.executeSql("INSERT INTO audit_log VALUES (1, 'admin', 'login')");
    check(r, "2b: INSERT with user value");

    r = exec.executeSql("SELECT user FROM audit_log WHERE id = 1");
    check(r, "2c: SELECT user column");

    // Test 3: Multiple keyword columns
    Terminal.Say("Test 3: Multiple keyword columns");
    r = exec.executeSql("CREATE TABLE configs (key TEXT, value TEXT, user TEXT, password TEXT)");
    check(r, "3a: CREATE TABLE with KEY, VALUE, USER, PASSWORD columns");

    r = exec.executeSql("INSERT INTO configs VALUES ('db_host', 'localhost', 'root', 'pass')");
    check(r, "3b: INSERT into keyword columns");

    r = exec.executeSql("SELECT key, value, user, password FROM configs");
    check(r, "3c: SELECT all keyword columns");

    // Test 4: table.column syntax with keyword column
    Terminal.Say("Test 4: Qualified keyword column references");
    r = exec.executeSql("SELECT users.password FROM users WHERE users.id = 1");
    check(r, "4a: SELECT table.password");

    // Test 5: SHOW TABLES (singular and plural)
    Terminal.Say("Test 5: SHOW TABLE variants");
    r = exec.executeSql("SHOW TABLES");
    check(r, "5a: SHOW TABLES (plural)");

    r = exec.executeSql("SHOW TABLE");
    check(r, "5b: SHOW TABLE (singular)");

    // Test 6: CREATE USER still works with PASSWORD keyword
    Terminal.Say("Test 6: CREATE USER with PASSWORD keyword");
    r = exec.executeSql("CREATE USER testuser PASSWORD 'mypass'");
    check(r, "6a: CREATE USER still works");

    Terminal.Say("");
    Terminal.Say("Results: " + Fmt.Int(passed) + " passed, " + Fmt.Int(failed) + " failed");
    return failed;
}
