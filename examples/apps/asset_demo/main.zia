module AssetDemo;

bind Viper.IO;
bind Viper.Terminal;

func start() {
    Say("=== Asset Embedding Demo ===");

    // Test 1: Check if embedded asset exists
    if Assets.Exists("assets/greeting.txt") != 0 {
        Say("PASS: assets/greeting.txt exists");
    } else {
        Say("FAIL: assets/greeting.txt not found");
    }

    // Test 2: Check size
    var sz = Assets.Size("assets/greeting.txt");
    if sz > 0 {
        Say("PASS: size > 0");
    } else {
        Say("FAIL: size is 0");
    }

    // Test 3: Load as bytes
    var data = Assets.LoadBytes("assets/greeting.txt");
    if data != null {
        Say("PASS: loaded greeting.txt as bytes");
    } else {
        Say("FAIL: could not load greeting.txt");
    }

    // Test 4: Load config.json
    var config = Assets.LoadBytes("assets/config.json");
    if config != null {
        Say("PASS: loaded config.json as bytes");
    } else {
        Say("FAIL: could not load config.json");
    }

    // Test 5: Non-existent asset returns null
    var missing = Assets.Load("does_not_exist.xyz");
    if missing == null {
        Say("PASS: non-existent asset returns null");
    } else {
        Say("FAIL: expected null for missing asset");
    }

    // Test 6: List all assets
    var names = Assets.List();
    if names != null {
        Say("PASS: listed assets");
    }

    Say("=== All tests complete ===");
}