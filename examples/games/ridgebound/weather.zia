// weather.zia - Dynamic rain/snow that drifts in and out over a weather cycle.
//
// A camera-following particle volume: rain at low altitude, snow up on the
// peaks, with intensity oscillating over WEATHER_PERIOD_SEC so the world cycles
// clear -> overcast -> storm -> clear. Purely additive over the existing scene;
// the day/night fog stays owned by worldsim.
module weather;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";
bind "./mathutil";

class RidgeboundWeather {
    hide Particles3D rain;
    hide Particles3D snow;
    hide Float clock;
    hide Float intensity;
    hide Float cloudCover;
    hide Float wetness;

    expose func setup(softParticles: Boolean) {
        rain = Particles3D.New(config.WEATHER_RAIN_COUNT);
        Particles3D.SetDirection(rain, 0.08, -1.0, 0.05, 0.12);
        Particles3D.SetSpeed(rain, 16.0, 22.0);
        Particles3D.SetLifetime(rain, 1.1, 1.7);
        Particles3D.SetSize(rain, 0.045, 0.03);
        Particles3D.SetGravity(rain, 0.0, -9.0, 0.0);
        Particles3D.SetColor(rain, 0x9FB4CC, 0x6E86A6);
        Particles3D.SetAlpha(rain, 0.55, 0.0);
        Particles3D.SetEmitterShape(rain, 1);
        Particles3D.SetEmitterSize(rain, 48.0, 2.0, 48.0);
        Particles3D.SetRate(rain, 0.0);
        // Soft particles fade the streaks/flakes where they meet terrain and trees
        // instead of hard-clipping (GPU backends with a depth snapshot only).
        if (softParticles) { Particles3D.SetSoftness(rain, config.WEATHER_SOFT_FADE); }
        Particles3D.Start(rain);

        snow = Particles3D.New(config.WEATHER_SNOW_COUNT);
        Particles3D.SetDirection(snow, 0.0, -1.0, 0.0, 0.7);
        Particles3D.SetSpeed(snow, 0.8, 2.0);
        Particles3D.SetLifetime(snow, 4.0, 7.0);
        Particles3D.SetSize(snow, 0.11, 0.09);
        Particles3D.SetGravity(snow, 0.0, -0.4, 0.0);
        Particles3D.SetColor(snow, 0xFFFFFF, 0xDDE8F5);
        Particles3D.SetAlpha(snow, 0.85, 0.0);
        Particles3D.SetEmitterShape(snow, 1);
        Particles3D.SetEmitterSize(snow, 48.0, 2.0, 48.0);
        Particles3D.SetRate(snow, 0.0);
        if (softParticles) { Particles3D.SetSoftness(snow, config.WEATHER_SOFT_FADE); }
        Particles3D.Start(snow);

        clock = 0.0;
        intensity = 0.0;
        cloudCover = 0.0;
        wetness = 0.0;
    }

    // Advance the weather clock, follow the camera, and route the current
    // intensity to rain (low) or snow (up on the peaks) based on player altitude.
    expose func update(dt: Float, camera: Camera3D, playerY: Float) {
        clock = clock + dt;
        var phase = clock / config.WEATHER_PERIOD_SEC;
        phase = phase - (Convert.NumToInt(phase) + 0.0);
        if (phase < 0.0) { phase = phase + 1.0; }
        // Dry for most of the cycle, ramping to a full storm at the peak. Cloud
        // cover uses the same curve but a wider window (bias vs the -0.3 precip
        // bias) so overcast builds before the rain and lingers after it stops.
        var raw = Sin(phase * 6.2831853);
        intensity = mathutil.clampFloat(raw * 1.4 - 0.3, 0.0, 1.0);
        cloudCover = mathutil.clampFloat(raw * 1.15 + config.WEATHER_CLOUD_LEAD, 0.0, 1.0);

        var camPos = camera.Position;
        var cx = Vec3.get_X(camPos);
        var cy = Vec3.get_Y(camPos);
        var cz = Vec3.get_Z(camPos);

        var snowy = playerY > config.WATER_HEIGHT + config.WEATHER_SNOW_ALTITUDE;
        if (snowy) {
            Particles3D.SetRate(snow, intensity * config.WEATHER_SNOW_RATE);
            Particles3D.SetRate(rain, 0.0);
        } else {
            Particles3D.SetRate(rain, intensity * config.WEATHER_RAIN_RATE);
            Particles3D.SetRate(snow, 0.0);
        }
        Particles3D.SetPosition(rain, cx, cy + 24.0, cz);
        Particles3D.SetPosition(snow, cx, cy + 24.0, cz);
        Particles3D.Update(rain, dt);
        Particles3D.Update(snow, dt);

        // Ground soaks while rain falls (snow doesn't wet it) and dries slowly after.
        if (intensity > 0.05 && snowy == false) {
            wetness = mathutil.clampFloat(wetness + config.WEATHER_WET_RISE * intensity * dt, 0.0, 1.0);
        } else {
            wetness = mathutil.clampFloat(wetness - config.WEATHER_WET_DECAY * dt, 0.0, 1.0);
        }
    }

    expose func draw(canvas: Canvas3D, camera: Camera3D) {
        if (rain != null) { Particles3D.Draw(rain, canvas, camera); }
        if (snow != null) { Particles3D.Draw(snow, canvas, camera); }
    }

    // 0 (clear) .. 1 (full storm); the HUD reads this for a weather readout.
    expose func getIntensity() -> Float { return intensity; }
    // 0 (clear sky) .. 1 (full overcast); drives the day/night lighting dimming.
    expose func getCloudCover() -> Float { return cloudCover; }
    // 0 (bone dry) .. 1 (soaked); drives the wet-ground look (darker + glossier).
    expose func getWetness() -> Float { return wetness; }
}
