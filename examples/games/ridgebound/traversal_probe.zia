//
// File: examples/games/ridgebound/traversal_probe.zia
// Purpose: Proves ordinary forward input can traverse every authored route without jumping.
// Key invariants:
//   - Movement uses Input3D and the production CharacterController3D path.
//   - The probe never presses jump and bounds stalls, progress, and ground contact.
// Ownership/Lifetime:
//   - The probe owns one RidgeboundGame for the duration of main.
// Links: game.zia, terrain.zia, playerctl.zia
//
//===----------------------------------------------------------------------===//

module traversal_probe;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Input.Key as Key;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind Viper.Text.Fmt as Fmt;
bind "./config";
bind "./game";

func fixed(value: Float) -> String {
    return Fmt.NumFixed(value, 2);
}

func absFloat(value: Float) -> Float {
    if (value < 0.0) { return 0.0 - value; }
    return value;
}

func settle(game: RidgeboundGame, canvas: Canvas3D) {
    Canvas3D.ClearSyntheticInput(canvas);
    var i = 0;
    while (i < 8) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);
        i = i + 1;
    }
}

func walkForward(game: RidgeboundGame, canvas: Canvas3D,
                 frames: Integer, minimumProgress: Float, label: String) -> Boolean {
    var startX = game.debugPlayerX();
    var startZ = game.debugPlayerZ();
    var previousX = startX;
    var previousZ = startZ;
    var stallRun = 0;
    var longestStall = 0;
    var supportedFrames = 0;
    var worstDryGroundGap = 0.0;

    Canvas3D.PushSyntheticKey(canvas, Key.W, true);
    var i = 0;
    while (i < frames) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);

        var x = game.debugPlayerX();
        var z = game.debugPlayerZ();
        var dx = x - previousX;
        var dz = z - previousZ;
        var frameMove = Sqrt(dx * dx + dz * dz);
        if (frameMove < 0.025) {
            stallRun = stallRun + 1;
            if (stallRun > longestStall) { longestStall = stallRun; }
        } else {
            stallRun = 0;
        }

        if (game.debugPlayerGrounded() || game.debugPlayerSwimming()) {
            supportedFrames = supportedFrames + 1;
        }
        if (game.debugPlayerSwimming() == false) {
            var gap = absFloat(game.debugPlayerY() - game.debugGroundY());
            if (gap > worstDryGroundGap) { worstDryGroundGap = gap; }
        }
        previousX = x;
        previousZ = z;
        i = i + 1;
    }
    Canvas3D.PushSyntheticKey(canvas, Key.W, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);

    var dx = game.debugPlayerX() - startX;
    var dz = game.debugPlayerZ() - startZ;
    var progress = Sqrt(dx * dx + dz * dz);
    Terminal.Say("METRIC: " + label + " progress_m=" + fixed(progress)
        + " longest_stall_frames=" + toString(longestStall)
        + " supported_frames=" + toString(supportedFrames)
        + " max_ground_gap_m=" + fixed(worstDryGroundGap));

    if (progress < minimumProgress) {
        Terminal.Say("RESULT: fail " + label + " progress below " + fixed(minimumProgress) + "m");
        return false;
    }
    if (longestStall > 24) {
        Terminal.Say("RESULT: fail " + label + " blocked for more than 1.2 seconds");
        return false;
    }
    if (supportedFrames * 2 < frames) {
        Terminal.Say("RESULT: fail " + label + " lost terrain/water support");
        return false;
    }
    if (worstDryGroundGap > 1.35) {
        Terminal.Say("RESULT: fail " + label + " lifted away from dry terrain");
        return false;
    }
    return true;
}

func beginRoute(game: RidgeboundGame, canvas: Canvas3D, dx: Float, dz: Float) {
    game.debugRespawnForProbe();
    game.debugSetTravelDirectionForProbe(dx, dz);
    settle(game, canvas);
}

func main() {
    Diagnostics3D.Reset();
    var game = new RidgeboundGame();
    game.setup("Ridgebound Traversal Probe", 480, 270);
    var canvas = game.getCanvas();
    Canvas3D.SetInputSource(canvas, 1);
    Canvas3D.SetClockSource(canvas, 1);
    Canvas3D.SetSyntheticDeltaTimeSec(canvas, 0.05);
    game.startGameplayForSmoke();
    settle(game, canvas);

    beginRoute(game, canvas, config.BEACON_0_X - 0.50, config.BEACON_0_Z - 0.50);
    if (walkForward(game, canvas, 120, 43.0, "windbreak_route") == false) {
        game.destroy(); return;
    }

    beginRoute(game, canvas, config.BEACON_1_X - 0.50, config.BEACON_1_Z - 0.50);
    if (walkForward(game, canvas, 120, 43.0, "mirror_route") == false) {
        game.destroy(); return;
    }

    beginRoute(game, canvas, config.BEACON_4_X - 0.50, config.BEACON_4_Z - 0.50);
    if (walkForward(game, canvas, 55, 18.0, "relay_route") == false) {
        game.destroy(); return;
    }

    beginRoute(game, canvas, config.BEACON_4_X - 0.50, config.BEACON_4_Z - 0.50);
    if (walkForward(game, canvas, 55, 18.0, "sunstep_relay_leg") == false) {
        game.destroy(); return;
    }
    game.debugSetTravelDirectionForProbe(
        config.BEACON_2_X - config.BEACON_4_X,
        config.BEACON_2_Z - config.BEACON_4_Z);
    if (walkForward(game, canvas, 105, 38.0, "sunstep_branch") == false) {
        game.destroy(); return;
    }

    beginRoute(game, canvas, config.BEACON_4_X - 0.50, config.BEACON_4_Z - 0.50);
    if (walkForward(game, canvas, 55, 18.0, "ember_relay_leg") == false) {
        game.destroy(); return;
    }
    game.debugSetTravelDirectionForProbe(
        config.BEACON_3_X - config.BEACON_4_X,
        config.BEACON_3_Z - config.BEACON_4_Z);
    if (walkForward(game, canvas, 105, 38.0, "ember_branch") == false) {
        game.destroy(); return;
    }

    // Deliberately leave the dry network without jumping. The controller must
    // continue moving and transition to the explicit surface-swim state rather
    // than walking invisibly on the basin floor or stalling at the shoreline.
    beginRoute(game, canvas, 0.0, -1.0);
    if (walkForward(game, canvas, 80, 16.0, "off_route_swim") == false ||
        game.debugPlayerSwimming() == false) {
        Terminal.Say("RESULT: fail off-route water did not enter surface swimming");
        game.destroy(); return;
    }

    var diagnostics = Diagnostics3D.Summary();
    game.destroy();
    if (diagnostics != "") {
        Terminal.Say("RESULT: fail diagnostics " + diagnostics);
        return;
    }
    Terminal.Say("RESULT: ok no_jump_route_network");
}
