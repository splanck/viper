// survival.zia - Warmth, campfires, and forage: a light survival layer on top of
// the day/night cycle. Warmth drains at night and under overcast when you are out
// in the open, and recovers next to a campfire; low warmth slows stamina regen.
// Forage motes scattered across the valley top up warmth when collected.
//
// Standalone system with its own update/draw and a small query surface the HUD
// and player controller read. Owns three campfire point lights (slots 10..12).
module survival;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Math;
bind "./config";
bind "./terrain";
bind "./mathutil";

class RidgeboundSurvival {
    hide List[Float] fireXs;
    hide List[Float] fireYs;
    hide List[Float] fireZs;
    hide List[Light3D] fireLights;
    hide Mesh3D fireMesh;
    hide Material3D fireMat;
    hide Particles3D embers;
    hide List[Float] forageXs;
    hide List[Float] forageYs;
    hide List[Float] forageZs;
    hide List[Boolean] forageTaken;
    hide Mesh3D moteMesh;
    hide Material3D moteMat;
    hide Float warmth;
    hide Integer foragedCount;
    hide Float nearestFireDist;
    hide Float regenScale;
    hide Float clock;

    expose func setup(world: World3D, land: Terrain3D) {
        warmth = 1.0;
        foragedCount = 0;
        nearestFireDist = 999.0;
        regenScale = 1.0;
        clock = 0.0;

        var maxX = terrain.terrainWorldMaxX();
        var maxZ = terrain.terrainWorldMaxZ();

        // Three campfires ringed around the interior (percent positions), each with
        // a warm flickering point light and a small emissive fire mesh.
        fireMesh = Mesh3D.Cylinder(0.5, 0.9, 10);
        fireMat = Materials.Emissive(1.0, 0.55, 0.18, 1.0);
        Material3D.SetEmissiveColor(fireMat, 0.9, 0.42, 0.12);
        fireXs = [];
        fireYs = [];
        fireZs = [];
        fireLights = [];
        // South of the lake (which sits center-north) on dry interior land, clear
        // of the home island and the mountain band.
        addCampfire(world, land, maxX * 0.35, maxZ * 0.67, 0);
        addCampfire(world, land, maxX * 0.65, maxZ * 0.67, 1);
        addCampfire(world, land, maxX * 0.50, maxZ * 0.72, 2);

        embers = Particles3D.New(config.EMBER_COUNT);
        Particles3D.SetDirection(embers, 0.0, 1.0, 0.0, 0.35);
        Particles3D.SetSpeed(embers, 1.2, 2.6);
        Particles3D.SetLifetime(embers, 0.7, 1.4);
        Particles3D.SetSize(embers, 0.10, 0.02);
        Particles3D.SetGravity(embers, 0.0, 0.9, 0.0);
        Particles3D.SetColor(embers, 0xFFC864, 0xFF5A14);
        Particles3D.SetAlpha(embers, 0.9, 0.0);
        Particles3D.SetRate(embers, 45.0);
        Particles3D.set_Additive(embers, true);
        Particles3D.Start(embers);

        // Forage motes scattered on the terrain via a hash so they spread out.
        moteMesh = Mesh3D.Sphere(0.22, 10);
        moteMat = Materials.Emissive(0.60, 1.0, 0.72, 1.0);
        Material3D.SetEmissiveColor(moteMat, 0.30, 0.72, 0.42);
        forageXs = [];
        forageYs = [];
        forageZs = [];
        forageTaken = [];
        var i = 0;
        while (i < config.FORAGE_COUNT) {
            var fx = config.TERRAIN_MARGIN + mathutil.hash01(i * 7 + 3, 41) * (maxX - config.TERRAIN_MARGIN * 2.0);
            var fz = config.TERRAIN_MARGIN + mathutil.hash01(i * 5 + 9, 53) * (maxZ - config.TERRAIN_MARGIN * 2.0);
            forageXs.add(fx);
            forageYs.add(terrain.sampleGround(land, fx, fz) + 0.5);
            forageZs.add(fz);
            forageTaken.add(false);
            i = i + 1;
        }
    }

    hide func addCampfire(world: World3D, land: Terrain3D, x: Float, z: Float, index: Integer) {
        var y = terrain.sampleGround(land, x, z);
        fireXs.add(x);
        fireYs.add(y);
        fireZs.add(z);
        var lp = Light3D.Point(new Vec3(x, y + 1.2, z), 1.0, 0.62, 0.26, config.CAMPFIRE_LIGHT_RANGE);
        Light3D.SetIntensity(lp, config.CAMPFIRE_LIGHT_INTENSITY);
        world.AddLight(config.CAMPFIRE_LIGHT_SLOT + index, lp);
        fireLights.add(lp);
    }

    expose func update(dt: Float, playerX: Float, playerZ: Float,
                       isNight: Boolean, cloudCover: Float) {
        clock = clock + dt;

        // Nearest campfire distance (XZ) drives both warmth recovery and where the
        // shared ember emitter sits.
        nearestFireDist = 999.0;
        var nearIdx = 0;
        for i in 0..fireXs.count() {
            var dxf = fireXs.get(i) - playerX;
            var dzf = fireZs.get(i) - playerZ;
            var d = Sqrt(dxf * dxf + dzf * dzf);
            if (d < nearestFireDist) { nearestFireDist = d; nearIdx = i; }
        }

        // Flicker the fire lights so the campfires feel alive.
        for i in 0..fireLights.count() {
            var flick = 0.82 + 0.18 * Sin(clock * 9.0 + (i + 0.0) * 2.1) * Cos(clock * 5.3 + (i + 0.0));
            Light3D.SetIntensity(fireLights.get(i), config.CAMPFIRE_LIGHT_INTENSITY * flick);
        }

        // Warmth: cold pressure at night + under cloud when away from a fire; a
        // fire nearby overrides it and warms you back up.
        var cold = 0.0;
        if (isNight) { cold = config.WARMTH_NIGHT_DRAIN; }
        cold = cold + mathutil.clampFloat(cloudCover, 0.0, 1.0) * config.WARMTH_CLOUD_DRAIN;
        var gain = 0.0;
        if (nearestFireDist < config.CAMPFIRE_WARM_RADIUS) {
            gain = config.WARMTH_FIRE_GAIN * (1.0 - nearestFireDist / config.CAMPFIRE_WARM_RADIUS);
        }
        warmth = mathutil.clampFloat(warmth + (gain - cold) * dt, 0.0, 1.0);

        // Reposition the shared ember emitter at the nearest fire.
        if (fireXs.count() > 0) {
            Particles3D.SetPosition(embers, fireXs.get(nearIdx), fireYs.get(nearIdx) + 0.4, fireZs.get(nearIdx));
            Particles3D.Update(embers, dt);
        }

        // Forage pickups: collecting one restores warmth.
        for i in 0..forageXs.count() {
            if (forageTaken.get(i) == false) {
                var dxg = forageXs.get(i) - playerX;
                var dzg = forageZs.get(i) - playerZ;
                if (dxg * dxg + dzg * dzg < config.FORAGE_PICKUP_RADIUS * config.FORAGE_PICKUP_RADIUS) {
                    forageTaken.set(i, true);
                    foragedCount = foragedCount + 1;
                    warmth = mathutil.clampFloat(warmth + config.FORAGE_WARMTH, 0.0, 1.0);
                }
            }
        }

        // Stamina regen slows when cold; a fire's warmth restores full regen.
        regenScale = config.WARMTH_MIN_REGEN + (1.0 - config.WARMTH_MIN_REGEN) * warmth;
    }

    expose func draw(canvas: Canvas3D, camera: Camera3D) {
        for i in 0..fireXs.count() {
            var pulse = 0.9 + 0.1 * Sin(clock * 7.0 + (i + 0.0) * 1.7);
            var xform = Mat4.Mul(
                Mat4.Translate(fireXs.get(i), fireYs.get(i) + 0.45, fireZs.get(i)),
                Mat4.Scale(0.7, 0.7 * pulse, 0.7));
            Canvas3D.DrawMesh(canvas, fireMesh, xform, fireMat);
        }
        for i in 0..forageXs.count() {
            if (forageTaken.get(i) == false) {
                var bob = Sin(clock * 2.2 + (i + 0.0) * 1.3) * 0.14;
                var xform = Mat4.Translate(forageXs.get(i), forageYs.get(i) + bob, forageZs.get(i));
                Canvas3D.DrawMesh(canvas, moteMesh, xform, moteMat);
            }
        }
        Particles3D.Draw(embers, canvas, camera);
    }

    expose func getWarmth() -> Float { return warmth; }
    expose func getForagedCount() -> Integer { return foragedCount; }
    expose func getRegenScale() -> Float { return regenScale; }
    expose func nearestCampfireDist() -> Float { return nearestFireDist; }
}
