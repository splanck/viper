// postfx.zia - Post-processing chain plus particles and decals.
module postfx;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";
bind "./terrain";
bind "./mathutil";

/// @brief Build the default cinematic Ridgebound post-FX chain.
func buildPostFX(canvas: Canvas3D) {
    buildPostFXForQuality(canvas, 2);
}

/// @brief Build the authored Ridgebound post-FX chain for a menu quality preset.
func buildPostFXForQuality(canvas: Canvas3D, quality: Integer) {
    var fx = PostFX3D.New();
    var q = quality;
    if (q < 0) { q = 0; }
    if (q > 2) { q = 2; }
    // GPU-only screen-space ambient occlusion — the biggest single depth cue here,
    // grounding trees/props/creases with contact darkening. Gated on the valid
    // "gpu_postfx" capability (the old "ssao" string was never recognized, so SSAO
    // never actually ran). DOF + motion blur are intentionally omitted: they soften
    // the distant snow-capped peaks and read poorly under constant mouse-look.
    if (q >= 1 && Canvas3D.BackendSupports(canvas, "gpu_postfx")) {
        PostFX3D.AddSSAO(fx, 0.70, 0.90, 16);
    }
    // Screen-space reflections add local shoreline/tree detail to reflective
    // water where the GPU path supports them; the cubemap remains the fallback.
    if (q >= 2 && Canvas3D.BackendSupports(canvas, "ssr")) {
        PostFX3D.AddSSR(fx, 0.55, 0.35);
    }
    // CPU-safe chain — runs on every backend, software included.
    var exposure = config.POSTFX_EXPOSURE;
    var bloomIntensity = config.POSTFX_BLOOM_INTENSITY;
    var bloomPasses = 4;
    if (q == 0) {
        exposure = exposure * 0.94;
        bloomIntensity = bloomIntensity * 0.45;
        bloomPasses = 1;
    } else if (q == 1) {
        exposure = exposure * 0.98;
        bloomIntensity = bloomIntensity * 0.70;
        bloomPasses = 2;
    }
    PostFX3D.AddTonemap(fx, 2, exposure);
    PostFX3D.AddBloom(fx, config.POSTFX_BLOOM_THRESHOLD, bloomIntensity, bloomPasses);
    PostFX3D.AddColorGrade(
        fx, config.POSTFX_COLORGRADE_BRIGHT, config.POSTFX_COLORGRADE_CONTRAST,
        config.POSTFX_COLORGRADE_SAT);
    PostFX3D.AddVignette(fx, config.POSTFX_VIGNETTE_RADIUS, config.POSTFX_VIGNETTE_SOFT);
    // FXAA (not TAA): Ridgebound is a fast free-look game, and TAA's temporal
    // reprojection ghosts the dense foliage under quick camera rotation (the same
    // reason DOF/motion-blur are omitted above). TAA is showcased on the slower
    // cinematic bowling camera instead, where it converges cleanly.
    PostFX3D.AddFXAA(fx);
    Canvas3D.SetPostFX(canvas, fx);
}

class RidgeboundEffects {
    hide Particles3D sprintDust;
    hide List[Decal3D] decals;
    hide Pixels scorchTex;

    expose func setup() {
        // Full-screen ambient billboards obscured the scene on the software
        // renderer. Atmosphere now comes from fog, weather, reeds, and localized
        // interaction bursts; no perpetual camera-facing discs are spawned.
        sprintDust = Particles3D.New(config.DUST_COUNT);
        Particles3D.SetDirection(sprintDust, 0.0, 1.0, 0.0, 0.5);
        Particles3D.SetSpeed(sprintDust, 0.4, 1.2);
        Particles3D.SetLifetime(sprintDust, 0.3, 0.7);
        Particles3D.SetSize(sprintDust, 0.18, 0.02);
        Particles3D.SetGravity(sprintDust, 0.0, -0.6, 0.0);
        Particles3D.SetColor(sprintDust, 0x9C8C6E, 0x6E5E44);
        Particles3D.SetAlpha(sprintDust, 0.5, 0.0);
        Particles3D.SetEmitterShape(sprintDust, 0);

        scorchTex = createScorchTexture(20);
        decals = [];
    }

    expose func reset() {
        if (sprintDust != null) { Particles3D.Clear(sprintDust); }
        decals = [];
    }

    expose func update(dt: Float) {
        if (sprintDust != null) { Particles3D.Update(sprintDust, dt); }
        updateDecals(dt);
    }

    expose func draw(canvas: Canvas3D, camera: Camera3D) {
        if (sprintDust != null) { Particles3D.Draw(sprintDust, canvas, camera); }
    }

    expose func drawDecals(canvas: Canvas3D) {
        for i in 0..decals.count() {
            Canvas3D.DrawDecal(canvas, decals.get(i));
        }
    }

    expose func burstSprintDust(x: Float, y: Float, z: Float) {
        if (sprintDust != null) {
            Particles3D.SetPosition(sprintDust, x, y + 0.1, z);
            Particles3D.Burst(sprintDust, 8);
        }
    }

    expose func stampScorch(x: Float, y: Float, z: Float) {
        if (scorchTex == null) { return; }
        var decal = Decal3D.New(new Vec3(x, y + 0.05, z), new Vec3(0.0, 1.0, 0.0), 1.8, scorchTex);
        Decal3D.SetLifetime(decal, config.SCORCH_LIFETIME);
        decals.add(decal);
        if (decals.count() > config.DECAL_MAX) { decals.removeAt(0); }
    }

    hide func updateDecals(dt: Float) {
        var i = 0;
        while (i < decals.count()) {
            Decal3D.Update(decals.get(i), dt);
            if (Decal3D.get_Expired(decals.get(i)) != false) {
                decals.removeAt(i);
            } else {
                i = i + 1;
            }
        }
    }

    hide func createScorchTexture(size: Integer) -> Pixels {
        var buf = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var dx = (px - cx + 0.0) / (size + 0.0);
                var dy = (py - cy + 0.0) / (size + 0.0);
                var dist = Sqrt(dx * dx + dy * dy);
                var alpha = 1.0 - dist * 2.4;
                if (alpha > 0.0) {
                    buf.Set(px, py, mathutil.packPixel(30, 22, 16, mathutil.clampByte(Convert.NumToInt(alpha * 150.0))));
                } else {
                    buf.Set(px, py, mathutil.packPixel(0, 0, 0, 0));
                }
            }
        }

        return buf;
    }
}
