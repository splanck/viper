//===----------------------------------------------------------------------===//
//
// File: examples/games/ridgebound/topology_probe.zia
// Purpose: Validates Ridgebound lake, causeway, route, pad, and navigation topology.
// Key invariants:
//   - Every beacon is connected to spawn by a dry, walkable authored route.
//   - The visible lake has a genuinely submerged floor away from its causeways.
// Ownership/Lifetime:
//   - Terrain and material resources live for the standalone probe process.
// Links: terrain.zia, worldsim.zia, config.zia
//
//===----------------------------------------------------------------------===//

module topology_probe;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind Zanna.Text.Fmt as Fmt;
bind "./config";
bind "./terrain";
bind "./worldsim";

func fixed(value: Float) -> String {
    return Fmt.NumFixed(value, 3);
}

func worldX(percent: Float) -> Float { return percent * terrain.terrainWorldMaxX(); }
func worldZ(percent: Float) -> Float { return percent * terrain.terrainWorldMaxZ(); }

func checkRoute(land: Terrain3D, ax: Float, az: Float, bx: Float, bz: Float,
                label: String) -> Boolean {
    var samples = 56;
    var previousHeight = terrain.sampleGround(land, worldX(ax), worldZ(az));
    var maxStep = 0.0;
    var minNormalY = 1.0;
    var minHeight = previousHeight;
    var i = 1;
    while (i <= samples) {
        var t = (i + 0.0) / (samples + 0.0);
        var nx = ax + (bx - ax) * t;
        var nz = az + (bz - az) * t;
        var x = worldX(nx);
        var z = worldZ(nz);
        var height = terrain.sampleGround(land, x, z);
        var step = height - previousHeight;
        if (step < 0.0) { step = 0.0 - step; }
        if (step > maxStep) { maxStep = step; }
        if (height < minHeight) { minHeight = height; }
        var normalY = Vec3.get_Y(Terrain3D.GetNormalAt(land, x, z));
        if (normalY < minNormalY) { minNormalY = normalY; }
        previousHeight = height;
        i = i + 1;
    }
    Terminal.Say("METRIC: " + label + " min_height_m=" + fixed(minHeight)
        + " max_sample_step_m=" + fixed(maxStep)
        + " min_normal_y=" + fixed(minNormalY));
    if (minHeight < config.WATER_HEIGHT + 0.42) {
        Terminal.Say("RESULT: fail " + label + " drops below dry causeway height");
        return false;
    }
    if (maxStep > 1.20) {
        Terminal.Say("RESULT: fail " + label + " has an abrupt height transition");
        return false;
    }
    if (minNormalY < 0.68) {
        Terminal.Say("RESULT: fail " + label + " exceeds the walkable grade");
        return false;
    }
    return true;
}

func checkPad(land: Terrain3D, nx: Float, nz: Float, label: String) -> Boolean {
    var radius = 3.0;
    var center = terrain.sampleGround(land, worldX(nx), worldZ(nz));
    var minHeight = center;
    var maxHeight = center;
    var ix = -1;
    while (ix <= 1) {
        var iz = -1;
        while (iz <= 1) {
            var h = terrain.sampleGround(
                land, worldX(nx) + (ix + 0.0) * radius,
                worldZ(nz) + (iz + 0.0) * radius);
            if (h < minHeight) { minHeight = h; }
            if (h > maxHeight) { maxHeight = h; }
            iz = iz + 1;
        }
        ix = ix + 1;
    }
    var normalY = Vec3.get_Y(Terrain3D.GetNormalAt(land, worldX(nx), worldZ(nz)));
    Terminal.Say("METRIC: " + label + " pad_relief_m=" + fixed(maxHeight - minHeight)
        + " normal_y=" + fixed(normalY));
    if (maxHeight - minHeight > 0.75 || normalY < 0.92) {
        Terminal.Say("RESULT: fail " + label + " arrival pad is not level");
        return false;
    }
    return true;
}

func main() {
    var terrainSystem = new RidgeboundTerrain();
    var material = Material3D.PBR(0.42, 0.52, 0.30);
    var land = terrainSystem.build(material);

    if (checkRoute(land, 0.50, 0.50, config.BEACON_0_X, config.BEACON_0_Z,
                   "spawn_to_windbreak") == false) { return; }
    if (checkRoute(land, 0.50, 0.50, config.BEACON_1_X, config.BEACON_1_Z,
                   "spawn_to_mirror") == false) { return; }
    if (checkRoute(land, 0.50, 0.50, config.BEACON_4_X, config.BEACON_4_Z,
                   "spawn_to_relay") == false) { return; }
    if (checkRoute(land, config.BEACON_4_X, config.BEACON_4_Z,
                   config.BEACON_2_X, config.BEACON_2_Z,
                   "relay_to_sunstep") == false) { return; }
    if (checkRoute(land, config.BEACON_4_X, config.BEACON_4_Z,
                   config.BEACON_3_X, config.BEACON_3_Z,
                   "relay_to_ember") == false) { return; }

    if (checkPad(land, 0.50, 0.50, "spawn") == false) { return; }
    if (checkPad(land, config.BEACON_0_X, config.BEACON_0_Z, "windbreak") == false) { return; }
    if (checkPad(land, config.BEACON_1_X, config.BEACON_1_Z, "mirror") == false) { return; }
    if (checkPad(land, config.BEACON_2_X, config.BEACON_2_Z, "sunstep") == false) { return; }
    if (checkPad(land, config.BEACON_3_X, config.BEACON_3_Z, "ember") == false) { return; }
    if (checkPad(land, config.BEACON_4_X, config.BEACON_4_Z, "relay") == false) { return; }

    // Measure a grid in the inner basin, excluding the full soft shoulder of
    // every authored causeway. This checks lake coverage rather than relying on
    // a few hand-picked points that might sit in a route's blend fringe.
    var deepSamples = 0;
    var eligibleSamples = 0;
    var minimumLakeHeight = 9999.0;
    var maximumLakeHeight = -9999.0;
    var gx = -10;
    while (gx <= 10) {
        var gz = -7;
        while (gz <= 7) {
            var nx = 0.50 + (gx + 0.0) * 0.020;
            var nz = 0.43 + (gz + 0.0) * 0.018;
            if (terrain.lakeDistanceNormalized(nx, nz) < 0.72 &&
                terrain.authoredRouteDistance(nx, nz) >
                    config.LAKE_CAUSEWAY_HALF_WIDTH * 2.85) {
                var lakeHeight = terrain.sampleGround(land, worldX(nx), worldZ(nz));
                eligibleSamples = eligibleSamples + 1;
                if (lakeHeight < minimumLakeHeight) { minimumLakeHeight = lakeHeight; }
                if (lakeHeight > maximumLakeHeight) { maximumLakeHeight = lakeHeight; }
                if (lakeHeight <= config.WATER_HEIGHT - 1.8) {
                    deepSamples = deepSamples + 1;
                }
            }
            gz = gz + 1;
        }
        gx = gx + 1;
    }
    Terminal.Say("METRIC: submerged_lake_samples=" + toString(deepSamples) + "/"
        + toString(eligibleSamples) + " floor_range_m=" + fixed(minimumLakeHeight)
        + ".." + fixed(maximumLakeHeight));
    if (eligibleSamples < 20 || deepSamples * 100 < eligibleSamples * 90) {
        Terminal.Say("RESULT: fail lake floor is not consistently submerged away from routes");
        return;
    }

    var sim = new RidgeboundWorldSim();
    sim.init();
    sim.reset(land);
    if (sim.getBeaconCount() != 5) {
        Terminal.Say("RESULT: fail beacon network count"); return;
    }
    if (sim.nearestDormantBeaconName(worldX(0.50), worldZ(0.50)) != "Home Relay" ||
        sim.nearestDormantBeaconDirection(worldX(0.50), worldZ(0.50)) != "S") {
        Terminal.Say("RESULT: fail initial navigation target"); return;
    }

    Terminal.Say("RESULT: ok connected_dry_route_network");
}
