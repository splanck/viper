// menu3d.zia - In-world title, pause, options, and controls menus for Ridgebound.
module menu3d;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind Zanna.Input.Key as Key;
bind Zanna.Math;
bind "./config";
bind "./terrain";
bind "./mathutil";

var CMD_NONE: Integer = -1;
var CMD_START: Integer = 0;
var CMD_OPTIONS: Integer = 1;
var CMD_CONTROLS: Integer = 2;
var CMD_QUIT: Integer = 3;
var CMD_BACK: Integer = 4;
var CMD_RESUME: Integer = 5;
var CMD_RESTART: Integer = 6;
var CMD_TITLE: Integer = 7;
var CMD_SETTINGS_CHANGED: Integer = 8;
var CMD_TOGGLE_FULLSCREEN: Integer = 9;

var MENU_TITLE: Integer = 0;
var MENU_PAUSE: Integer = 1;
var MENU_OPTIONS: Integer = 2;
var MENU_CONTROLS: Integer = 3;

class RidgeboundMenu3D {
    hide Integer mode;
    hide Integer selected;
    hide Integer titleSelected;
    hide Integer pauseSelected;
    hide Integer optionsSelected;
    hide Integer fovPreset;
    hide Integer sensitivityPreset;
    hide Integer qualityPreset;
    hide Boolean invertY;
    hide Float clock;

    expose func init() {
        mode = MENU_TITLE;
        selected = 0;
        titleSelected = 0;
        pauseSelected = 0;
        optionsSelected = 0;
        fovPreset = 1;
        sensitivityPreset = 1;
        qualityPreset = 2;
        invertY = config.CAMERA_INVERT_Y;
        clock = 0.0;
    }

    expose func openTitle() {
        mode = MENU_TITLE;
        selected = titleSelected;
    }

    expose func openPause() {
        mode = MENU_PAUSE;
        selected = pauseSelected;
    }

    expose func openOptions() {
        mode = MENU_OPTIONS;
        selected = optionsSelected;
    }

    expose func openControls() {
        mode = MENU_CONTROLS;
        selected = 0;
    }

    expose func getMode() -> Integer { return mode; }
    expose func getQualityPreset() -> Integer { return qualityPreset; }
    expose func getFovPreset() -> Integer { return fovPreset; }
    expose func getSensitivityPreset() -> Integer { return sensitivityPreset; }
    expose func getInvertY() -> Boolean { return invertY; }

    expose func setQualityPreset(value: Integer) {
        qualityPreset = value;
        if (qualityPreset < 0) { qualityPreset = 0; }
        if (qualityPreset > 2) { qualityPreset = 2; }
    }

    expose func update(dt: Float, input: Input3D) -> Integer {
        clock = clock + dt;
        if (mode == MENU_TITLE) { return updateTitle(input); }
        if (mode == MENU_PAUSE) { return updatePause(input); }
        if (mode == MENU_OPTIONS) { return updateOptions(input); }
        if (mode == MENU_CONTROLS) { return updateControls(input); }
        return CMD_NONE;
    }

    expose func drawTitle3D(canvas: Canvas3D, land: Terrain3D, cubeMesh: Mesh3D, beaconMesh: Mesh3D,
                            pedestalMat: Material3D, dimMat: Material3D,
                            activeMat: Material3D, glowMat: Material3D) {
        if (mode == MENU_PAUSE) { return; }

        var cx = terrain.terrainWorldMaxX() * 0.50;
        var cz = terrain.terrainWorldMaxZ() * 0.50 - 9.0;
        var i = 0;
        while (i < 4) {
            var fi = i + 0.0;
            var offset = (fi - 1.5) * 5.3;
            var arc = mathutil.absFloat(fi - 1.5) * 1.1;
            var x = cx + offset;
            var z = cz + arc;
            var y = terrain.sampleGround(land, x, z);
            var selectedItem = titleSelected;
            if (mode == MENU_OPTIONS) { selectedItem = 1; }
            if (mode == MENU_CONTROLS) { selectedItem = 2; }
            drawPylon(canvas, cubeMesh, beaconMesh, x, y, z, i, selectedItem,
                pedestalMat, dimMat, activeMat, glowMat);
            i = i + 1;
        }
    }

    expose func drawOverlay(canvas: Canvas3D, fullscreenOn: Boolean) {
        var w = canvas.Width;
        var h = canvas.Height;
        if (mode == MENU_TITLE) {
            drawTitleOverlay(canvas, h);
        } else if (mode == MENU_PAUSE) {
            drawPauseOverlay(canvas, w, h);
        } else if (mode == MENU_OPTIONS) {
            drawOptionsOverlay(canvas, w, h, fullscreenOn);
        } else if (mode == MENU_CONTROLS) {
            drawControlsOverlay(canvas, w, h);
        }
    }

    hide func updateTitle(input: Input3D) -> Integer {
        nav(input, 4);
        titleSelected = selected;
        if (input.Pressed(Key.Escape)) { return CMD_QUIT; }
        if (confirm(input)) {
            if (selected == 0) { return CMD_START; }
            if (selected == 1) { return CMD_OPTIONS; }
            if (selected == 2) { return CMD_CONTROLS; }
            if (selected == 3) { return CMD_QUIT; }
        }
        return CMD_NONE;
    }

    hide func updatePause(input: Input3D) -> Integer {
        nav(input, 5);
        pauseSelected = selected;
        if (input.Pressed(Key.Escape)) { return CMD_RESUME; }
        if (confirm(input)) {
            if (selected == 0) { return CMD_RESUME; }
            if (selected == 1) { return CMD_RESTART; }
            if (selected == 2) { return CMD_OPTIONS; }
            if (selected == 3) { return CMD_CONTROLS; }
            if (selected == 4) { return CMD_TITLE; }
        }
        return CMD_NONE;
    }

    hide func updateOptions(input: Input3D) -> Integer {
        nav(input, 6);
        optionsSelected = selected;
        if (input.Pressed(Key.Escape)) { return CMD_BACK; }
        var cycleForward = confirm(input) || input.Pressed(Key.Right) || input.Pressed(Key.D);
        var cycleBack = input.Pressed(Key.Left) || input.Pressed(Key.A);
        if (cycleForward || cycleBack) {
            if (selected == 0) {
                fovPreset = cycleIndex(fovPreset, 3, cycleBack);
                return CMD_SETTINGS_CHANGED;
            }
            if (selected == 1) {
                sensitivityPreset = cycleIndex(sensitivityPreset, 3, cycleBack);
                return CMD_SETTINGS_CHANGED;
            }
            if (selected == 2) {
                if (invertY) { invertY = false; } else { invertY = true; }
                return CMD_SETTINGS_CHANGED;
            }
            if (selected == 3) {
                qualityPreset = cycleIndex(qualityPreset, 3, cycleBack);
                return CMD_SETTINGS_CHANGED;
            }
            if (selected == 4) { return CMD_TOGGLE_FULLSCREEN; }
            if (selected == 5) { return CMD_BACK; }
        }
        return CMD_NONE;
    }

    hide func updateControls(input: Input3D) -> Integer {
        if (input.Pressed(Key.Escape) || input.Pressed(Key.Backspace) || confirm(input)) {
            return CMD_BACK;
        }
        return CMD_NONE;
    }

    hide func nav(input: Input3D, count: Integer) {
        if (input.Pressed(Key.Up) || input.Pressed(Key.W)) {
            selected = selected - 1;
            if (selected < 0) { selected = count - 1; }
        }
        if (input.Pressed(Key.Down) || input.Pressed(Key.S)) {
            selected = selected + 1;
            if (selected >= count) { selected = 0; }
        }
    }

    hide func confirm(input: Input3D) -> Boolean {
        return input.Pressed(Key.Enter) || input.Pressed(Key.Space) || input.Pressed(Key.NumpadEnter);
    }

    hide func cycleIndex(value: Integer, count: Integer, backwards: Boolean) -> Integer {
        var next = value;
        if (backwards) { next = next - 1; } else { next = next + 1; }
        if (next < 0) { next = count - 1; }
        if (next >= count) { next = 0; }
        return next;
    }

    hide func drawPylon(canvas: Canvas3D, cubeMesh: Mesh3D, beaconMesh: Mesh3D,
                        x: Float, y: Float, z: Float, index: Integer, selectedItem: Integer,
                        pedestalMat: Material3D, dimMat: Material3D,
                        activeMat: Material3D, glowMat: Material3D) {
        var mat = dimMat;
        var capMat = dimMat;
        var height = 1.55;
        if (index == selectedItem) {
            mat = pedestalMat;
            capMat = activeMat;
            height = 2.05 + Sin(clock * 3.0) * 0.10;
        }

        drawBlock(canvas, cubeMesh, x, y + 0.24, z, 1.85, 0.48, 1.85, pedestalMat);
        drawBlock(canvas, cubeMesh, x, y + 0.78 + height * 0.5, z, 0.82, height, 0.82, mat);
        Canvas3D.DrawMesh(canvas, beaconMesh, Mat4.Translate(x, y + height + 1.52, z), capMat);

        if (index == selectedItem) {
            var beamH = 3.4 + Sin(clock * 4.2) * 0.25;
            drawBlock(canvas, cubeMesh, x, y + height + 2.7, z, 0.15, beamH, 0.15, glowMat);
        }
    }

    hide func drawBlock(canvas: Canvas3D, cubeMesh: Mesh3D,
                        x: Float, y: Float, z: Float, sx: Float, sy: Float, sz: Float,
                        mat: Material3D) {
        var xform = Mat4.Mul(Mat4.Translate(x, y, z), Mat4.Scale(sx, sy, sz));
        Canvas3D.DrawMesh(canvas, cubeMesh, xform, mat);
    }

    hide func drawTitleOverlay(canvas: Canvas3D, h: Integer) {
        var w = canvas.Width;
        var cardW = 374;
        if (w < 430) { cardW = w - 32; }
        var x = 24;
        var y = 24;
        var cardH = 150;
        var titleScale = 5;
        var compact = w < 520 || h < 420;
        if (compact) {
            x = 14;
            y = 14;
            cardW = w - 28;
            if (cardW > 374) { cardW = 374; }
            cardH = 124;
            titleScale = 4;
        }
        Canvas3D.DrawRect2D(canvas, x, y, cardW, cardH, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, x, y, 4, cardH, config.HUD_ACCENT);
        drawTitleMark(canvas, x + 18, y + 16, titleScale);
        var subtitleY = y + 88;
        var taglineY = y + 112;
        if (compact) { subtitleY = y + 69; taglineY = y + 93; }
        Canvas3D.DrawText2D(canvas, x + 22, subtitleY,
            "THE FIVE BEACONS", config.HUD_WARN);
        Canvas3D.DrawText2D(canvas, x + 22, taglineY,
            "Restore the five beacons.", config.HUD_MUTED);

        var menuY = h - 202;
        if (menuY < 184) { menuY = 184; }
        var rowH = 39;
        if (compact) {
            menuY = y + cardH + 8;
            rowH = (h - menuY - 6) / 4;
            if (rowH < 24) { rowH = 24; }
        }
        drawMenuRows(canvas, x + 4, menuY, cardW - 8, rowH,
            4, titleSelected, MENU_TITLE, false);
    }

    hide func drawPauseOverlay(canvas: Canvas3D, w: Integer, h: Integer) {
        var cardW = 344;
        var cardH = 278;
        if (cardW > w - 24) { cardW = w - 24; }
        if (cardH > h - 20) { cardH = h - 20; }
        var x = w / 2 - cardW / 2;
        var y = h / 2 - cardH / 2;
        Canvas3D.DrawRect2D(canvas, x, y, cardW, cardH, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, x, y, cardW, 3, config.HUD_ACCENT);
        drawTextShadow(canvas, x + 24, y + 18, "PAUSED", config.HUD_TEXT);
        var rowH = (cardH - 62) / 5;
        drawMenuRows(canvas, x + 24, y + 56, cardW - 48, rowH,
            5, pauseSelected, MENU_PAUSE, false);
    }

    hide func drawOptionsOverlay(canvas: Canvas3D, w: Integer, h: Integer, fullscreenOn: Boolean) {
        var cardW = 420;
        var cardH = 298;
        if (cardW > w - 24) { cardW = w - 24; }
        if (cardH > h - 20) { cardH = h - 20; }
        var x = w / 2 - cardW / 2;
        var y = h / 2 - cardH / 2;
        Canvas3D.DrawRect2D(canvas, x, y, cardW, cardH, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, x, y, cardW, 3, config.HUD_ACCENT);
        drawTextShadow(canvas, x + 24, y + 18, "OPTIONS", config.HUD_TEXT);
        var rowH = (cardH - 58) / 6;
        drawMenuRows(canvas, x + 24, y + 52, cardW - 48, rowH,
            6, optionsSelected, MENU_OPTIONS, fullscreenOn);
    }

    hide func drawControlsOverlay(canvas: Canvas3D, w: Integer, h: Integer) {
        var cardW = 420;
        var cardH = 296;
        if (cardW > w - 24) { cardW = w - 24; }
        if (cardH > h - 20) { cardH = h - 20; }
        var x = w / 2 - cardW / 2;
        var y = h / 2 - cardH / 2;
        Canvas3D.DrawRect2D(canvas, x, y, cardW, cardH, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, x, y, cardW, 3, config.HUD_ACCENT);
        drawTextShadow(canvas, x + 24, y + 18, "CONTROLS", config.HUD_TEXT);
        var firstY = y + 58;
        var lineH = 22;
        if (cardH < 280) { firstY = y + 48; lineH = 20; }
        Canvas3D.DrawText2D(canvas, x + 28, firstY, "Move            WASD / arrows", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH, "Look            mouse", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 2, "Jump            Space", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 3, "Sprint          Shift", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 4, "Link beacon     hold E", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 5, "View            V", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 6, "Quality         right mouse", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, firstY + lineH * 7, "Pause           Esc", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 28, y + cardH - 28, "Back", config.HUD_GOOD);
    }

    hide func drawTitleMark(canvas: Canvas3D, x: Integer, y: Integer, scale: Integer) {
        drawBlockTitle(canvas, x + 3, y + 4, scale, 0x06101A);
        drawBlockTitle(canvas, x + 1, y + 2, scale, 0x123049);
        drawBlockTitle(canvas, x, y, scale, config.HUD_TEXT);
        Canvas3D.DrawRect2D(canvas, x, y + scale * 9 + 1, scale * 46, 3, config.HUD_ACCENT);
    }

    hide func drawBlockTitle(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        var step = s * 6;
        var lx = x;
        drawR(canvas, lx, y, s, color); lx = lx + step;
        drawI(canvas, lx, y, s, color); lx = lx + step;
        drawD(canvas, lx, y, s, color); lx = lx + step;
        drawG(canvas, lx, y, s, color); lx = lx + step;
        drawE(canvas, lx, y, s, color); lx = lx + step;
        drawB(canvas, lx, y, s, color); lx = lx + step;
        drawO(canvas, lx, y, s, color); lx = lx + step;
        drawU(canvas, lx, y, s, color); lx = lx + step;
        drawN(canvas, lx, y, s, color); lx = lx + step;
        drawD(canvas, lx, y, s, color);
    }

    hide func hbar(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, row: Integer, color: Integer) {
        Canvas3D.DrawRect2D(canvas, x, y + row * s, s * 5, s, color);
    }

    hide func vbar(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, col: Integer,
                   row: Integer, rows: Integer, color: Integer) {
        Canvas3D.DrawRect2D(canvas, x + col * s, y + row * s, s, rows * s, color);
    }

    hide func dot(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, col: Integer, row: Integer, color: Integer) {
        Canvas3D.DrawRect2D(canvas, x + col * s, y + row * s, s, s, color);
    }

    hide func drawR(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 7, color);
        hbar(canvas, x, y, s, 0, color);
        hbar(canvas, x, y, s, 3, color);
        vbar(canvas, x, y, s, 4, 1, 2, color);
        dot(canvas, x, y, s, 2, 4, color);
        dot(canvas, x, y, s, 3, 5, color);
        dot(canvas, x, y, s, 4, 6, color);
    }

    hide func drawI(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        hbar(canvas, x, y, s, 0, color);
        vbar(canvas, x, y, s, 2, 0, 7, color);
        hbar(canvas, x, y, s, 6, color);
    }

    hide func drawD(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 7, color);
        hbar(canvas, x, y, s, 0, color);
        hbar(canvas, x, y, s, 6, color);
        vbar(canvas, x, y, s, 4, 1, 5, color);
    }

    hide func drawG(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        hbar(canvas, x, y, s, 0, color);
        vbar(canvas, x, y, s, 0, 0, 7, color);
        hbar(canvas, x, y, s, 6, color);
        Canvas3D.DrawRect2D(canvas, x + s * 2, y + s * 3, s * 3, s, color);
        vbar(canvas, x, y, s, 4, 3, 4, color);
    }

    hide func drawE(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 7, color);
        hbar(canvas, x, y, s, 0, color);
        hbar(canvas, x, y, s, 3, color);
        hbar(canvas, x, y, s, 6, color);
    }

    hide func drawB(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 7, color);
        hbar(canvas, x, y, s, 0, color);
        hbar(canvas, x, y, s, 3, color);
        hbar(canvas, x, y, s, 6, color);
        vbar(canvas, x, y, s, 4, 1, 2, color);
        vbar(canvas, x, y, s, 4, 4, 2, color);
    }

    hide func drawO(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        hbar(canvas, x, y, s, 0, color);
        hbar(canvas, x, y, s, 6, color);
        vbar(canvas, x, y, s, 0, 0, 7, color);
        vbar(canvas, x, y, s, 4, 0, 7, color);
    }

    hide func drawU(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 6, color);
        vbar(canvas, x, y, s, 4, 0, 6, color);
        hbar(canvas, x, y, s, 6, color);
    }

    hide func drawN(canvas: Canvas3D, x: Integer, y: Integer, s: Integer, color: Integer) {
        vbar(canvas, x, y, s, 0, 0, 7, color);
        vbar(canvas, x, y, s, 4, 0, 7, color);
        dot(canvas, x, y, s, 1, 1, color);
        dot(canvas, x, y, s, 2, 2, color);
        dot(canvas, x, y, s, 2, 3, color);
        dot(canvas, x, y, s, 3, 4, color);
        dot(canvas, x, y, s, 3, 5, color);
    }

    hide func drawMenuRows(canvas: Canvas3D, x: Integer, y: Integer, rowW: Integer, rowH: Integer,
                           count: Integer, active: Integer, page: Integer, fullscreenOn: Boolean) {
        var i = 0;
        while (i < count) {
            var rowY = y + i * rowH;
            var fill = config.HUD_CARD;
            var color = config.HUD_MUTED;
            if (i == active) {
                fill = config.HUD_ACCENT;
                color = config.HUD_TEXT;
            }
            Canvas3D.DrawRect2D(canvas, x, rowY, rowW, rowH - 6, fill);
            Canvas3D.DrawRect2D(canvas, x, rowY, rowW, 1, config.HUD_PANEL);
            var textY = rowY + 11;
            if (rowH < 34) { textY = rowY + 7; }
            Canvas3D.DrawText2D(canvas, x + 14, textY, rowLabel(i, page, fullscreenOn), color);
            if (i == active) {
                var markerH = rowH - 18;
                if (markerH < 4) { markerH = 4; }
                Canvas3D.DrawRect2D(canvas, x - 10, rowY + 7, 5, markerH, config.HUD_WARN);
            }
            i = i + 1;
        }
    }

    hide func rowLabel(i: Integer, page: Integer, fullscreenOn: Boolean) -> String {
        if (page == MENU_TITLE) {
            if (i == 0) { return "Start"; }
            if (i == 1) { return "Options"; }
            if (i == 2) { return "Controls"; }
            return "Quit";
        }
        if (page == MENU_PAUSE) {
            if (i == 0) { return "Resume"; }
            if (i == 1) { return "Restart Run"; }
            if (i == 2) { return "Options"; }
            if (i == 3) { return "Controls"; }
            return "Quit to Title";
        }
        if (page == MENU_OPTIONS) {
            if (i == 0) { return "FOV: " + fovName(); }
            if (i == 1) { return "Look: " + sensitivityName(); }
            if (i == 2) {
                if (invertY) { return "Invert Y: On"; }
                return "Invert Y: Off";
            }
            if (i == 3) { return "Quality: " + qualityName(); }
            if (i == 4) {
                if (fullscreenOn) { return "Fullscreen: On"; }
                return "Fullscreen: Off";
            }
            return "Back";
        }
        return "Back";
    }

    hide func fovName() -> String {
        if (fovPreset == 0) { return "Focused"; }
        if (fovPreset == 2) { return "Wide"; }
        return "Standard";
    }

    hide func sensitivityName() -> String {
        if (sensitivityPreset == 0) { return "Precise"; }
        if (sensitivityPreset == 2) { return "Fast"; }
        return "Standard";
    }

    hide func qualityName() -> String {
        if (qualityPreset == 0) { return "Performance"; }
        if (qualityPreset == 1) { return "Balanced"; }
        return "Cinematic";
    }

    hide func drawTextShadow(canvas: Canvas3D, x: Integer, y: Integer, text: String, color: Integer) {
        Canvas3D.DrawText2D(canvas, x + 2, y + 2, text, 0x06101A);
        Canvas3D.DrawText2D(canvas, x, y, text, color);
    }
}
