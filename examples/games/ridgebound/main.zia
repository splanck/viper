// main.zia - Entry point for Ridgebound.
module main;

bind Viper.System.Environment as Env;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./game";

func hasArg(wanted: String) -> Boolean {
    var count = Env.GetArgumentCount();
    var i = 0;
    while (i < count) {
        if (Env.GetArgument(i) == wanted) { return true; }
        i = i + 1;
    }
    return false;
}

// Headless self-test: build the world, render a few frames, report. Lets a
// packaged binary verify (incl. embedded-asset loading) without opening the
// interactive window or capturing the mouse.
func runSmoke() {
    var game = new RidgeboundGame();
    game.setup(config.WINDOW_TITLE, 960, 540);
    game.step(0.016);
    game.renderFrame();
    game.startGameplayForSmoke();
    var i = 0;
    while (i < 3) {
        game.step(0.016);
        game.renderFrame();
        i = i + 1;
    }
    Terminal.Say("RESULT: ok");
    game.destroy();
    Env.Exit(0);
}

func start() {
    if (hasArg("--smoke") || Env.GetVariable("VIPER_GAME3D_SMOKE") == "1") {
        runSmoke();
        return;
    }
    var game = new RidgeboundGame();
    game.setup(config.WINDOW_TITLE, config.WINDOW_WIDTH, config.WINDOW_HEIGHT);
    game.run();
    game.destroy();
}
