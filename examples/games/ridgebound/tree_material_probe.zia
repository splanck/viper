// tree_material_probe.zia - Validate imported maple bark/canopy material detail.
module tree_material_probe;

bind Viper.Game3D;
bind Viper.Graphics3D.Material3D as Material3D;
bind Viper.Graphics3D.SceneNode as SceneNode;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind "./game";

func fail(game: RidgeboundGame, msg: String) {
    Terminal.Say("FAIL: " + msg);
    game.destroy();
}

func matHasSurfaceDetail(mat: Material3D) -> Boolean {
    if (mat == null) { return false; }
    if (mat.HasTexture) { return true; }
    if (mat.HasNormalMap) { return true; }
    return false;
}

func absFloat(value: Float) -> Float {
    if (value < 0.0) { return 0.0 - value; }
    return value;
}

func colorDistance(a: Material3D, b: Material3D) -> Float {
    var ac = a.Color;
    var bc = b.Color;
    return absFloat(Vec3.get_X(ac) - Vec3.get_X(bc))
        + absFloat(Vec3.get_Y(ac) - Vec3.get_Y(bc))
        + absFloat(Vec3.get_Z(ac) - Vec3.get_Z(bc));
}

func main() {
    Diagnostics3D.Reset();

    var game = new RidgeboundGame();
    game.setup("Ridgebound Tree Material Probe", 320, 180);

    var world = game.getWorld();
    var barkNodeOption = world.FindNodeOption("mesh_0_material_0");
    var canopyNodeOption = world.FindNodeOption("mesh_1_material_1");
    if (barkNodeOption.IsNone) {
        fail(game, "imported maple bark material node was not spawned");
        return;
    }
    if (canopyNodeOption.IsNone) {
        fail(game, "imported maple canopy material node was not spawned");
        return;
    }
    var barkNode = barkNodeOption.Unwrap();
    var canopyNode = canopyNodeOption.Unwrap();

    var canopyMat = SceneNode.get_Material(canopyNode);
    var barkMat = SceneNode.get_Material(barkNode);
    if (matHasSurfaceDetail(canopyMat) == false) {
        fail(game, "canopy material has no albedo/normal texture detail");
        return;
    }
    if (matHasSurfaceDetail(barkMat) == false) {
        fail(game, "bark material has no albedo/normal texture detail");
        return;
    }
    if (colorDistance(canopyMat, barkMat) < 0.12) {
        fail(game, "canopy and bark materials collapsed to the same color");
        return;
    }

    var barkColor = barkMat.Color;
    if (Vec3.get_X(barkColor) <= Vec3.get_Y(barkColor) ||
            Vec3.get_Y(barkColor) <= Vec3.get_Z(barkColor)) {
        fail(game, "bark material is not brown-toned");
        return;
    }
    var canopyColor = canopyMat.Color;
    if (Vec3.get_Y(canopyColor) < 0.30 ||
            Vec3.get_X(canopyColor) + Vec3.get_Y(canopyColor) + Vec3.get_Z(canopyColor) <=
            Vec3.get_X(barkColor) + Vec3.get_Y(barkColor) + Vec3.get_Z(barkColor)) {
        fail(game, "canopy material is not foliage-toned");
        return;
    }

    var diagSummary = Diagnostics3D.Summary();
    if (diagSummary != "") {
        fail(game, "diagnostics recorded degradation: " + diagSummary);
        return;
    }

    game.destroy();
    Terminal.Say("RESULT: ok");
}
