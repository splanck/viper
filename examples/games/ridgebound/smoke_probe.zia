//
// File: examples/games/ridgebound/smoke_probe.zia
// Purpose: Captures and measures Ridgebound title, gameplay, night, and compact layouts.
// Key invariants:
//   - Final frames retain scene structure, readable night values, and crisp HUD overlays.
//   - Cinematic 960x540 rendering remains inside the backend-specific frame budget.
// Ownership/Lifetime:
//   - The probe owns and destroys one RidgeboundGame instance and its captures.
// Links: game.zia, config.zia, README.md
//
//===----------------------------------------------------------------------===//

module smoke_probe;

bind Zanna.Core.Convert as Convert;
bind Zanna.Game3D;
bind Zanna.Graphics.Pixels as Pixels;
bind Zanna.Graphics3D;
bind Zanna.Input.Key as Key;
bind Zanna.Math as Math;
bind Zanna.System.Environment as Environment;
bind Zanna.Terminal as Terminal;
bind Zanna.Text.Fmt as Fmt;
bind Zanna.Time.Clock as Clock;
bind "./config";
bind "./game";

class FrameStats {
    expose Integer samples;
    expose Integer sumLuma;
    expose Integer minLuma;
    expose Integer maxLuma;
    expose Integer litSamples;
    expose Integer whiteSamples;
    expose Integer maxWhiteRun;
}

func red(px: Integer) -> Integer { return Math.Bits.And(px >> 24, 0xFF); }
func green(px: Integer) -> Integer { return Math.Bits.And(px >> 16, 0xFF); }
func blue(px: Integer) -> Integer { return Math.Bits.And(px >> 8, 0xFF); }

func luminance(px: Integer) -> Integer {
    return (red(px) * 30 + green(px) * 59 + blue(px) * 11) / 100;
}

func ms(us: Integer) -> Float { return us / 1000.0; }
func fmt(value: Float) -> String { return Fmt.NumFixed(value, 3); }

func performanceBudget(variable: String, fallback: Float) -> Float {
    if (Environment.HasVariable(variable)) {
        var configured = Convert.ToDouble(Environment.GetVariable(variable));
        if (configured > 0.0) { return configured; }
    }
    return fallback;
}

func absInt(value: Integer) -> Integer {
    if (value < 0) { return 0 - value; }
    return value;
}

func nearChannel(value: Integer, target: Integer) -> Boolean {
    return value >= target - 2 && value <= target + 2;
}

func nearColor(px: Integer, r: Integer, g: Integer, b: Integer) -> Boolean {
    return nearChannel(red(px), r) && nearChannel(green(px), g) && nearChannel(blue(px), b);
}

func isHudTextPixel(px: Integer) -> Boolean {
    if (nearColor(px, 242, 240, 231)) { return true; } // text
    if (nearColor(px, 105, 200, 191)) { return true; } // accent
    if (nearColor(px, 170, 184, 181)) { return true; } // muted
    if (nearColor(px, 141, 214, 160)) { return true; } // good
    if (nearColor(px, 230, 183, 101)) { return true; } // warning
    return false;
}

func isNeutralWhite(px: Integer) -> Boolean {
    var r = red(px);
    var g = green(px);
    var b = blue(px);
    return luminance(px) >= 238 && absInt(r - g) <= 12 && absInt(g - b) <= 12;
}

func objectivePanelWidth(width: Integer, height: Integer) -> Integer {
    var compact = width < 760 || height < 520;
    var panelWidth = 404;
    if (compact) { panelWidth = width - 28; }
    if (panelWidth > 404) { panelWidth = 404; }
    if (panelWidth < 292) { panelWidth = 292; }
    return panelWidth;
}

func isOverlayRegion(x: Integer, y: Integer, width: Integer, height: Integer) -> Boolean {
    var panelWidth = objectivePanelWidth(width, height);
    var panelHeight = 112;
    if (width < 760 || height < 520) { panelHeight = 102; }
    if (x >= 12 && x <= 16 + panelWidth && y >= 12 && y <= 16 + panelHeight) {
        return true;
    }
    var mapSize = 124;
    if (width < 760 || height < 520) { mapSize = 92; }
    if (width < 420) { mapSize = 76; }
    if (x >= width - mapSize - 18 && y >= height - mapSize - 18) { return true; }
    return false;
}

func measureScene(img: Pixels) -> FrameStats {
    var stats = new FrameStats();
    stats.samples = 0;
    stats.sumLuma = 0;
    stats.minLuma = 9999;
    stats.maxLuma = -1;
    stats.litSamples = 0;
    stats.whiteSamples = 0;
    stats.maxWhiteRun = 0;
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    var y = height / 6;
    while (y < height - 10) {
        var whiteRun = 0;
        var x = 8;
        while (x < width - 8) {
            if (isOverlayRegion(x, y, width, height) == false) {
                var px = Pixels.Get(img, x, y);
                var lum = luminance(px);
                stats.samples = stats.samples + 1;
                stats.sumLuma = stats.sumLuma + lum;
                if (lum < stats.minLuma) { stats.minLuma = lum; }
                if (lum > stats.maxLuma) { stats.maxLuma = lum; }
                if (lum >= 26) { stats.litSamples = stats.litSamples + 1; }
                if (isNeutralWhite(px)) {
                    stats.whiteSamples = stats.whiteSamples + 1;
                    whiteRun = whiteRun + 1;
                    if (whiteRun > stats.maxWhiteRun) { stats.maxWhiteRun = whiteRun; }
                } else {
                    whiteRun = 0;
                }
            } else {
                whiteRun = 0;
            }
            x = x + 3;
        }
        y = y + 3;
    }
    return stats;
}

func meanLuma(stats: FrameStats) -> Float {
    if (stats.samples <= 0) { return 0.0; }
    return (stats.sumLuma + 0.0) / (stats.samples + 0.0);
}

func reportFrameStats(label: String, stats: FrameStats) {
    var whitePercent = 0.0;
    var litPercent = 0.0;
    if (stats.samples > 0) {
        whitePercent = (stats.whiteSamples + 0.0) * 100.0 / (stats.samples + 0.0);
        litPercent = (stats.litSamples + 0.0) * 100.0 / (stats.samples + 0.0);
    }
    Terminal.Say("METRIC: " + label + " mean_luma=" + fmt(meanLuma(stats))
        + " range=" + toString(stats.minLuma) + ".." + toString(stats.maxLuma)
        + " lit_percent=" + fmt(litPercent)
        + " neutral_white_percent=" + fmt(whitePercent)
        + " max_white_run_px=" + toString(stats.maxWhiteRun * 3));
}

func assertNoBrightBillboardDominance(stats: FrameStats, label: String) -> Boolean {
    if (stats.samples <= 0) {
        Terminal.Say("FAIL: " + label + " had no measurable scene pixels"); return false;
    }
    var whitePercent = (stats.whiteSamples + 0.0) * 100.0 / (stats.samples + 0.0);
    if (whitePercent > config.PERF_MAX_BRIGHT_SCENE_PERCENT || stats.maxWhiteRun * 3 > 150) {
        Terminal.Say("FAIL: " + label + " is dominated by broad neutral-white blobs");
        return false;
    }
    return true;
}

func assertScenicStructure(img: Pixels, label: String) -> Boolean {
    if (img == null) {
        Terminal.Say("FAIL: " + label + " capture returned null"); return false;
    }
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    var minLuma = 9999;
    var maxLuma = -1;
    var sumLuma = 0;
    var samples = 0;
    var y = 8;
    while (y < height - 8) {
        var x = width * 44 / 100;
        while (x < width - 8) {
            var lum = luminance(Pixels.Get(img, x, y));
            if (lum < minLuma) { minLuma = lum; }
            if (lum > maxLuma) { maxLuma = lum; }
            sumLuma = sumLuma + lum;
            samples = samples + 1;
            x = x + 6;
        }
        y = y + 6;
    }
    if (samples <= 0 || maxLuma - minLuma < 24 || sumLuma / samples < 18) {
        Terminal.Say("FAIL: " + label + " scenic background lost readable structure");
        return false;
    }
    return true;
}

func assertRidgeboundTitleFrame(img: Pixels, expectedWidth: Integer, expectedHeight: Integer) -> Boolean {
    if (img == null) {
        Terminal.Say("FAIL: Ridgebound title capture returned null"); return false;
    }
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    if (width != expectedWidth || height != expectedHeight) {
        Terminal.Say("FAIL: Ridgebound title capture size mismatch"); return false;
    }

    var titleHits = 0;
    var y = 24;
    while (y < 132 && y < height - 4) {
        var x = 24;
        while (x < 360 && x < width - 4) {
            var px = Pixels.Get(img, x, y);
            if (luminance(px) > 132 ||
                (green(px) > 120 && blue(px) > 125 && red(px) < 150) ||
                (red(px) > 175 && green(px) > 140 && blue(px) < 130)) {
                titleHits = titleHits + 1;
            }
            x = x + 4;
        }
        y = y + 4;
    }
    if (titleHits < 18) {
        Terminal.Say("FAIL: Ridgebound title/menu overlay was not visible"); return false;
    }

    var menuHits = 0;
    var menuY = height / 2 - 54;
    if (menuY < 0) { menuY = 0; }
    y = menuY;
    while (y < menuY + 190 && y < height - 4) {
        var mx = 40;
        while (mx < 370 && mx < width - 4) {
            var mp = Pixels.Get(img, mx, y);
            if (green(mp) > 115 && blue(mp) > 120) { menuHits = menuHits + 1; }
            mx = mx + 8;
        }
        y = y + 8;
    }
    if (menuHits < 8) {
        Terminal.Say("FAIL: Ridgebound title menu highlight was not visible"); return false;
    }
    return assertScenicStructure(img, "title");
}

func assertStartupState(game: RidgeboundGame) -> Boolean {
    var ground = game.debugGroundY();
    var maxPlayerY = game.debugPlayerY();
    var maxCameraY = game.debugCameraY();
    var i = 0;
    while (i < 120) {
        game.step(0.016);
        if (game.debugPlayerY() > maxPlayerY) { maxPlayerY = game.debugPlayerY(); }
        if (game.debugCameraY() > maxCameraY) { maxCameraY = game.debugCameraY(); }
        i = i + 1;
    }
    ground = game.debugGroundY();
    if (maxPlayerY > ground + 1.2 || game.debugPlayerY() > ground + 0.6) {
        Terminal.Say("FAIL: Ridgebound player drifted above terrain during startup"); return false;
    }
    if (maxCameraY > ground + 22.0) {
        Terminal.Say("FAIL: Ridgebound camera followed runaway player height"); return false;
    }
    if (game.isPlaying() == false) {
        Terminal.Say("FAIL: Ridgebound did not enter gameplay from title"); return false;
    }
    return true;
}

func assertHudFits(img: Pixels) -> Boolean {
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    var accent = Pixels.Get(img, 20, 15);
    if (green(accent) < 150 || blue(accent) < 145 || green(accent) - red(accent) < 55) {
        Terminal.Say("FAIL: Ridgebound final HUD overlay was not composited"); return false;
    }

    // Sample every pixel in each semantic line. The bitmap font's opaque cores
    // can land entirely between a two-pixel sampling grid at some baselines,
    // which made a complete line look missing even though it was rendered.
    var line0 = 0;
    var line1 = 0;
    var line2 = 0;
    var sampleY = 24;
    while (sampleY < 98 && sampleY < height) {
        var sampleX = 24;
        while (sampleX < 408 && sampleX < width) {
            if (isHudTextPixel(Pixels.Get(img, sampleX, sampleY))) {
                if (sampleY < 47) {
                    line0 = line0 + 1;
                } else if (sampleY < 73) {
                    line1 = line1 + 1;
                } else {
                    line2 = line2 + 1;
                }
            }
            sampleX = sampleX + 1;
        }
        sampleY = sampleY + 1;
    }
    if (line0 < 30 || line1 < 30 || line2 < 30) {
        Terminal.Say("FAIL: Ridgebound objective text was only partially composited"); return false;
    }

    var panelWidth = objectivePanelWidth(width, height);
    var panelRight = 14 + panelWidth;
    var panelHeight = 112;
    if (width < 760 || height < 520) { panelHeight = 102; }
    var overflow = 0;
    var y = 20;
    while (y < 14 + panelHeight - 6) {
        var x = panelRight + 2;
        while (x < panelRight + 64 && x < width - 2) {
            if (isHudTextPixel(Pixels.Get(img, x, y))) { overflow = overflow + 1; }
            x = x + 1;
        }
        y = y + 1;
    }
    if (overflow > 6) {
        Terminal.Say("FAIL: Ridgebound HUD text overflows the objective card"); return false;
    }
    return true;
}

func assertMinimapFilled(img: Pixels) -> Boolean {
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    var mapSize = 124;
    if (width < 760 || height < 520) { mapSize = 92; }
    if (width < 420) { mapSize = 76; }
    var filled = 0;
    var samples = 0;
    var y = height - mapSize - 14;
    while (y < height - 18) {
        var x = width - mapSize - 14;
        while (x < width - 18) {
            if (luminance(Pixels.Get(img, x, y)) > 24) { filled = filled + 1; }
            samples = samples + 1;
            x = x + 4;
        }
        y = y + 4;
    }
    if (samples <= 0 || filled * 100 < samples * 65) {
        Terminal.Say("FAIL: Ridgebound minimap image was only partially composited"); return false;
    }
    return true;
}

func assertGameplayFrame(img: Pixels, label: String, night: Boolean) -> Boolean {
    if (img == null) {
        Terminal.Say("FAIL: " + label + " capture returned null"); return false;
    }
    if (assertHudFits(img) == false) { return false; }
    if (assertMinimapFilled(img) == false) { return false; }
    var stats = measureScene(img);
    reportFrameStats(label, stats);
    if (stats.maxLuma - stats.minLuma < 20) {
        Terminal.Say("FAIL: " + label + " lost visible scene structure"); return false;
    }
    if (night) {
        if (meanLuma(stats) < config.PERF_MIN_NIGHT_LUMA ||
            stats.litSamples * 5 < stats.samples) {
            Terminal.Say("FAIL: Ridgebound night is too dark to navigate"); return false;
        }
    } else {
        if (meanLuma(stats) < 20.0 || meanLuma(stats) > 170.0) {
            Terminal.Say("FAIL: Ridgebound daylight exposure is outside the readable band"); return false;
        }
    }
    return assertNoBrightBillboardDominance(stats, label);
}

func assertCompactMinimap(img: Pixels) -> Boolean {
    var width = Pixels.get_Width(img);
    var height = Pixels.get_Height(img);
    var minLuma = 9999;
    var maxLuma = -1;
    var y = height - 104;
    while (y < height - 14) {
        var x = width - 104;
        while (x < width - 14) {
            var lum = luminance(Pixels.Get(img, x, y));
            if (lum < minLuma) { minLuma = lum; }
            if (lum > maxLuma) { maxLuma = lum; }
            x = x + 5;
        }
        y = y + 5;
    }
    if (maxLuma - minLuma < 18) {
        Terminal.Say("FAIL: Ridgebound compact minimap was not visible"); return false;
    }
    return true;
}

func assertCompactMenuFrame(img: Pixels, label: String) -> Boolean {
    if (img == null || Pixels.get_Width(img) != 480 || Pixels.get_Height(img) != 270) {
        Terminal.Say("FAIL: Ridgebound " + label + " compact menu capture mismatch");
        return false;
    }
    if (nearColor(Pixels.Get(img, 240, 12), 105, 200, 191) == false) {
        Terminal.Say("FAIL: Ridgebound " + label + " card was not viewport-contained");
        return false;
    }
    var textHits = 0;
    var y = 18;
    while (y < 252) {
        var x = 80;
        while (x < 424) {
            if (isHudTextPixel(Pixels.Get(img, x, y))) { textHits = textHits + 1; }
            x = x + 2;
        }
        y = y + 2;
    }
    if (textHits < 80) {
        Terminal.Say("FAIL: Ridgebound " + label + " menu text was incomplete");
        return false;
    }
    return true;
}

func tapKey(game: RidgeboundGame, canvas: Canvas3D, key: Integer) {
    Canvas3D.PushSyntheticKey(canvas, key, true);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    game.step(0.016);
    Canvas3D.PushSyntheticKey(canvas, key, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    game.step(0.016);
}

func renderAndCapture(game: RidgeboundGame, path: String) -> Pixels {
    game.renderFrame();
    var frame = game.getWorld().CaptureFinalFrame();
    if (frame != null) { Pixels.SavePng(frame, path); }
    return frame;
}

func main() {
    Diagnostics3D.Reset();
    var game = new RidgeboundGame();
    game.setup("Ridgebound Smoke", 960, 540);

    game.step(0.016);
    var titleFrame = renderAndCapture(game, "/tmp/ridgebound_title.png");
    if (assertRidgeboundTitleFrame(titleFrame, 960, 540) == false) {
        game.destroy(); return;
    }

    game.getWorld().OnResize(480, 270);
    game.step(0.016);
    var compactTitle = renderAndCapture(game, "/tmp/ridgebound_title_compact.png");
    if (assertRidgeboundTitleFrame(compactTitle, 480, 270) == false) {
        game.destroy(); return;
    }
    game.getWorld().OnResize(960, 540);

    game.startGameplayForSmoke();
    if (assertStartupState(game) == false) { game.destroy(); return; }

    game.debugSetQualityForProbe(0);
    game.renderFrame();
    if (game.getCanvas().QualityActive != 0) {
        Terminal.Say("FAIL: Ridgebound low quality preset was not active"); game.destroy(); return;
    }
    game.debugSetQualityForProbe(2);
    game.renderFrame(); // cinematic warm-up frame
    if (game.getCanvas().QualityActive != 2) {
        Terminal.Say("FAIL: Ridgebound cinematic quality preset was not active"); game.destroy(); return;
    }

    var renderStart = Clock.NowMicros();
    var perfFrames = 3;
    var perfIndex = 0;
    while (perfIndex < perfFrames) {
        game.renderFrame();
        perfIndex = perfIndex + 1;
    }
    var renderMs = ms(Clock.NowMicros() - renderStart) / (perfFrames + 0.0);
    var budgetMs = performanceBudget(
        "ZANNA_RIDGEBOUND_PERF_BUDGET_GPU_MS", config.PERF_BUDGET_GPU_MS);
    if (game.getCanvas().Backend == "software") {
        budgetMs = performanceBudget(
            "ZANNA_RIDGEBOUND_PERF_BUDGET_SOFTWARE_MS", config.PERF_BUDGET_SOFTWARE_MS);
    }
    Terminal.Say("METRIC: cinematic_960x540_render_ms=" + fmt(renderMs)
        + " budget_ms=" + fmt(budgetMs));
    if (renderMs > budgetMs) {
        Terminal.Say("FAIL: Ridgebound cinematic render exceeded its frame budget");
        game.destroy(); return;
    }

    var dayFrame = game.getWorld().CaptureFinalFrame();
    if (dayFrame != null) { Pixels.SavePng(dayFrame, "/tmp/ridgebound_current.png"); }
    if (assertGameplayFrame(dayFrame, "day", false) == false) {
        game.destroy(); return;
    }
    var dayMean = meanLuma(measureScene(dayFrame));

    var deepNightTime = config.DAY_LENGTH_SEC * (0.75 - config.DAY_START_PHASE);
    game.debugSetWorldTimeForProbe(deepNightTime);
    game.renderFrame(); // settle skybox/reflection uploads before measuring the keyframe
    var nightFrame = renderAndCapture(game, "/tmp/ridgebound_night.png");
    if (assertGameplayFrame(nightFrame, "night", true) == false) {
        game.destroy(); return;
    }
    var nightMean = meanLuma(measureScene(nightFrame));
    if (nightMean >= dayMean * 1.05) {
        Terminal.Say("FAIL: Ridgebound deep night is not visually distinct from day");
        game.destroy(); return;
    }

    game.debugSetWorldTimeForProbe(0.0);
    game.getWorld().OnResize(480, 270);
    var compactFrame = renderAndCapture(game, "/tmp/ridgebound_compact.png");
    if (compactFrame == null || Pixels.get_Width(compactFrame) != 480 ||
        Pixels.get_Height(compactFrame) != 270 ||
        assertGameplayFrame(compactFrame, "compact", false) == false ||
        assertCompactMinimap(compactFrame) == false) {
        game.destroy(); return;
    }

    // Drive the real menu state machine at the compact resolution and capture
    // every card whose old fixed layout extended beyond a 270 px viewport.
    var canvas = game.getCanvas();
    Canvas3D.ClearSyntheticInput(canvas);
    Canvas3D.SetInputSource(canvas, 1);
    Canvas3D.SetSyntheticDeltaTimeSec(canvas, 0.016);
    tapKey(game, canvas, Key.Escape);
    game.renderFrame();
    var pauseFrame = renderAndCapture(game, "/tmp/ridgebound_pause_compact.png");
    if (game.isPaused() == false || assertCompactMenuFrame(pauseFrame, "pause") == false) {
        game.destroy(); return;
    }
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Enter);
    game.renderFrame();
    var optionsFrame = renderAndCapture(game, "/tmp/ridgebound_options_compact.png");
    if (game.isOptions() == false || assertCompactMenuFrame(optionsFrame, "options") == false) {
        game.destroy(); return;
    }
    tapKey(game, canvas, Key.Escape);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Enter);
    game.renderFrame();
    var controlsFrame = renderAndCapture(game, "/tmp/ridgebound_controls_compact.png");
    if (game.isControls() == false || assertCompactMenuFrame(controlsFrame, "controls") == false) {
        game.destroy(); return;
    }

    var diagSummary = Diagnostics3D.Summary();
    Terminal.Say("Game3D.Diagnostics3D.Summary=" + diagSummary);
    if (diagSummary != "") {
        Terminal.Say("FAIL: Ridgebound diagnostics recorded degradation");
        Terminal.Say(diagSummary);
        game.destroy(); return;
    }
    var activeBackend = game.getCanvas().Backend;
    game.getWorld().Present();
    game.destroy();
    Terminal.Say("RESULT: ok backend=" + activeBackend);
}
