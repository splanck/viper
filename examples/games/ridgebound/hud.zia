// hud.zia - Ridgebound overlay and debug panel.
module hud;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Sound;
bind Viper.Core.Convert as Convert;
bind "./config";
bind "./minimap";
bind "./worldsim";

class RidgeboundHud {
    expose func draw(canvas: Canvas3D, map: RidgeboundMinimap, sim: RidgeboundWorldSim,
                     playerX: Float, playerZ: Float, stamina: Float,
                     warmth: Float, helpOn: Boolean, debugOn: Boolean) {
        var w = canvas.Width;
        var h = canvas.Height;
        var total = sim.getBeaconCount();
        var statusColor = config.HUD_WARN;
        var statusText = "Find a beacon. Aim + hold E.";

        if (sim.getBeaconsLit() >= total) {
            statusColor = config.HUD_GOOD;
            statusText = "All linked. Return to sanctuary.";
        }
        if (sim.getSanctuaryDone()) {
            statusColor = config.HUD_GOOD;
            statusText = "SANCTUARY RESTORED";
        }

        var compact = w < 760 || h < 520;
        var panelX = 14;
        var panelY = 14;
        var panelW = 404;
        var panelH = 112;
        if (compact) { panelW = w - 28; panelH = 102; }
        if (panelW > 404) { panelW = 404; }
        if (panelW < 292) { panelW = 292; }

        Canvas3D.DrawRect2D(canvas, panelX, panelY, panelW, panelH, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, panelX, panelY, panelW, 3, config.HUD_ACCENT);
        Canvas3D.DrawText2D(canvas, panelX + 12, panelY + 13,
            "RIDGEBOUND   SIGNAL " + toString(sim.getBeaconsLit()) + " / " + toString(total),
            statusColor);
        Canvas3D.DrawText2D(canvas, panelX + 12, panelY + 38, statusText, config.HUD_TEXT);

        var od = sim.nearestDormantBeaconDist(playerX, playerZ);
        if (od >= 0.0) {
            Canvas3D.DrawText2D(canvas, panelX + 12, panelY + 66,
                "NEXT  " + sim.nearestDormantBeaconDirection(playerX, playerZ) + "  "
                    + sim.nearestDormantBeaconName(playerX, playerZ) + "  "
                    + toString(Convert.NumToInt(od)) + "m",
                config.HUD_ACCENT);
        } else {
            Canvas3D.DrawText2D(canvas, panelX + 12, panelY + 66,
                "NEXT  HOME  Central Sanctuary", config.HUD_GOOD);
        }
        if (sim.getBeaconsLit() == 0 && compact == false) {
            Canvas3D.DrawText2D(canvas, panelX + 12, panelY + 88,
                "WASD move   Shift sprint   H help", config.HUD_MUTED);
        }

        var mapSize = 124;
        if (compact) { mapSize = 92; }
        if (w < 420) { mapSize = 76; }
        map.draw(canvas, w - mapSize - 16, h - mapSize - 16, mapSize, mapSize, playerX, playerZ,
            sim.getBeaconXs(), sim.getBeaconZs(), sim.getBeaconState());

        Canvas3D.DrawCrosshair(canvas, config.HUD_ACCENT, 10);
        if (sim.getScanLabel() != "") {
            Canvas3D.DrawRect2D(canvas, w / 2 - 150, h / 2 + 14, 300, 58, config.HUD_PANEL);
            Canvas3D.DrawText2D(
                canvas, w / 2 - 136, h / 2 + 24,
                sim.getScanLabel() + "  " + toString(Convert.NumToInt(sim.getScanDist())) + "m", config.HUD_TEXT);
        }
        if (sim.hasInteractTarget()) {
            var prog = sim.getScanProgress();
            if (prog > 0.0) {
                Canvas3D.DrawRect2D(canvas, w / 2 - 112, h / 2 + 52, 224, 8, config.HUD_CARD);
                Canvas3D.DrawRect2D(canvas, w / 2 - 112, h / 2 + 52,
                    Convert.NumToInt(224.0 * prog), 8, config.HUD_ACCENT);
            } else {
                Canvas3D.DrawText2D(canvas, w / 2 - 64, h / 2 + 50, "HOLD E TO LINK", config.HUD_GOOD);
            }
        }

        // One compact movement meter, anchored clear of the objective panel and
        // minimap at every supported aspect ratio.
        var meterX = 18;
        var meterY = h - 28;
        var meterW = 190;
        if (compact) { meterW = 132; }
        Canvas3D.DrawText2D(canvas, meterX, meterY - 1, "STAMINA", config.HUD_MUTED);
        Canvas3D.DrawRect2D(canvas, meterX + 76, meterY, meterW, 9, config.HUD_CARD);
        var scol = config.HUD_GOOD;
        if (stamina < 0.3) { scol = config.HUD_WARN; }
        Canvas3D.DrawRect2D(canvas, meterX + 76, meterY,
            Convert.NumToInt((meterW + 0.0) * stamina), 9, scol);

        if (config.ENABLE_SURVIVAL_LAYER) {
            var warmY = meterY - 18;
            Canvas3D.DrawText2D(canvas, meterX, warmY - 1, "WARMTH", config.HUD_MUTED);
            Canvas3D.DrawRect2D(canvas, meterX + 76, warmY, meterW, 9, config.HUD_CARD);
            var wcol = config.HUD_WARN;
            if (warmth < 0.3) { wcol = config.HUD_DANGER; }
            if (warmth > 0.7) { wcol = config.HUD_GOOD; }
            Canvas3D.DrawRect2D(canvas, meterX + 76, warmY,
                Convert.NumToInt((meterW + 0.0) * warmth), 9, wcol);
        }

        if (helpOn) { drawControlsOverlay(canvas, w, h); }
        if (debugOn) { drawDebugPanel(canvas, w); }
    }

    // Toggleable controls reference (H). A centered card listing every binding.
    hide func drawControlsOverlay(canvas: Canvas3D, w: Integer, h: Integer) {
        var cardW = 360;
        if (w < 400) { cardW = w - 24; }
        var px = w / 2 - cardW / 2;
        var py = h / 2 - 108;
        Canvas3D.DrawRect2D(canvas, px, py, cardW, 216, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, px, py, cardW, 3, config.HUD_ACCENT);
        Canvas3D.DrawText2D(canvas, px + 14, py + 18, "CONTROLS", config.HUD_TEXT);
        Canvas3D.DrawText2D(canvas, px + 14, py + 44, "WASD - move", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 64, "Mouse - look   (click to capture)", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 84, "Shift - sprint (stamina)", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 104, "Space - jump", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 124, "V - toggle first-person / orbit", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 144, "E - hold to scan a beacon", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 164, "Wheel - zoom   Ctrl - debug", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, px + 14, py + 188, "H - close help   Esc - pause", config.HUD_GOOD);
    }

    hide func drawDebugPanel(canvas: Canvas3D, w: Integer) {
        var x = w - 296;
        var y = 14;
        Canvas3D.DrawRect2D(canvas, x, y, 282, 262, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, x, y, 282, 3, config.HUD_ACCENT);
        Canvas3D.DrawText2D(canvas, x + 10, y + 16, "DEBUG  Ctrl=toggle  RMB=quality", config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, x + 10, y + 38, "Backend: " + canvas.Backend, config.HUD_TEXT);
        Canvas3D.DrawText2D(canvas, x + 10, y + 56, "FPS: " + toString(canvas.Fps), config.HUD_TEXT);
        Canvas3D.DrawText2D(canvas, x + 10, y + 74, "Draws: " + toString(canvas.DrawCount), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 92,
            "Lights: " + toString(canvas.LightCount) + " / "
                + toString(canvas.MaxActiveLights), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 110,
            "Quality: " + toString(canvas.QualityActive), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 128,
            "GL draws/drops: " + toString(canvas.BackendDrawCalls) + " / "
                + toString(canvas.BackendDroppedDraws), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 146,
            "Mesh cache H/M: " + toString(canvas.BackendMeshCacheHits) + " / "
                + toString(canvas.BackendMeshCacheMisses), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 164,
            "Stream/Fallback: " + toString(canvas.BackendMeshStreamUploads) + " / "
                + toString(canvas.BackendTextureFallbackBinds), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 182,
            "Present path: " + toString(canvas.BackendPresentPath), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 200,
            "Audio render/miss: " + toString(Audio.get_RenderCalls()) + " / "
                + toString(Audio.get_MixerLockMisses()), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 218,
            "ALSA xruns/fail: " + toString(Audio.get_BackendXruns()) + " / "
                + toString(Audio.get_BackendWriteFailures()), config.HUD_TEXT);
        Canvas3D.DrawText2D(
            canvas, x + 10, y + 236,
            "Cull frustum/occ: " + toString(canvas.FrustumCulledDrawCount) + " / "
                + toString(canvas.OccludedDrawCount), config.HUD_MUTED);
    }
}
