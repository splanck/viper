//
// File: examples/games/ridgebound/state_probe.zia
// Purpose: Validates Ridgebound clocks, lifecycle resets, weather, and quality contracts.
// Key invariants:
//   - Title and pause states never consume gameplay time.
//   - Restart and quit-to-title restore the authored clear-morning state.
// Ownership/Lifetime:
//   - The probe owns and destroys one RidgeboundGame instance.
// Links: game.zia, weather.zia, config.zia
//
//===----------------------------------------------------------------------===//

module state_probe;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind Zanna.Input.Key as Key;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./game";

func near(a: Float, b: Float, tolerance: Float) -> Boolean {
    var delta = a - b;
    if (delta < 0.0) { delta = 0.0 - delta; }
    return delta <= tolerance;
}

func tapKey(game: RidgeboundGame, canvas: Canvas3D, key: Integer) {
    Canvas3D.PushSyntheticKey(canvas, key, true);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    game.step(0.05);
    Canvas3D.PushSyntheticKey(canvas, key, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    game.step(0.05);
}

func main() {
    Diagnostics3D.Reset();
    var game = new RidgeboundGame();
    game.setup("Ridgebound State Probe", 480, 270);
    var canvas = game.getCanvas();
    Canvas3D.SetInputSource(canvas, 1);
    Canvas3D.SetClockSource(canvas, 1);
    Canvas3D.SetSyntheticDeltaTimeSec(canvas, 0.05);

    var i = 0;
    while (i < 180) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);
        i = i + 1;
    }
    if (near(game.debugWorldTime(), 0.0, 0.0001) == false || game.isTitle() == false) {
        Terminal.Say("RESULT: fail title consumed gameplay clock"); game.destroy(); return;
    }

    game.startGameplayForSmoke();
    i = 0;
    while (i < 20) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);
        i = i + 1;
    }
    if (near(game.debugWorldTime(), 1.0, 0.001) == false) {
        Terminal.Say("RESULT: fail gameplay clock rate"); game.destroy(); return;
    }
    if (game.debugWeatherIntensity() > 0.001) {
        Terminal.Say("RESULT: fail opening weather is not calm"); game.destroy(); return;
    }
    var spawnX = game.debugPlayerX();
    var spawnZ = game.debugPlayerZ();

    tapKey(game, canvas, Key.Escape);
    if (game.isPaused() == false) {
        Terminal.Say("RESULT: fail escape did not pause"); game.destroy(); return;
    }
    var pausedTime = game.debugWorldTime();
    i = 0;
    while (i < 120) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);
        i = i + 1;
    }
    if (near(game.debugWorldTime(), pausedTime, 0.0001) == false) {
        Terminal.Say("RESULT: fail pause consumed gameplay clock"); game.destroy(); return;
    }

    var secondsToDusk = (0.50 - config.DAY_START_PHASE) * config.DAY_LENGTH_SEC;
    if (secondsToDusk < 300.0) {
        Terminal.Say("RESULT: fail first dusk arrives too early"); game.destroy(); return;
    }
    game.debugSetWorldTimeForProbe(config.DAY_LENGTH_SEC * (0.75 - config.DAY_START_PHASE));
    game.debugRestartForProbe();
    if (game.isPlaying() == false || near(game.debugWorldTime(), 0.0, 0.0001) == false ||
        near(game.debugWeatherIntensity(), 0.0, 0.0001) == false) {
        Terminal.Say("RESULT: fail restart did not restore clear morning"); game.destroy(); return;
    }

    game.debugSetQualityForProbe(0);
    if (canvas.QualityActive != 0) {
        Terminal.Say("RESULT: fail low quality preset did not apply"); game.destroy(); return;
    }
    game.debugSetQualityForProbe(2);
    if (canvas.QualityActive != 2) {
        Terminal.Say("RESULT: fail cinematic quality preset did not restore"); game.destroy(); return;
    }

    Canvas3D.PushSyntheticKey(canvas, Key.W, true);
    i = 0;
    while (i < 20) {
        Canvas3D.AdvanceSyntheticFrame(canvas);
        game.step(0.05);
        i = i + 1;
    }
    Canvas3D.PushSyntheticKey(canvas, Key.W, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    game.step(0.05);
    var dx = game.debugPlayerX() - spawnX;
    var dz = game.debugPlayerZ() - spawnZ;
    if (dx * dx + dz * dz < 1.0) {
        Terminal.Say("RESULT: fail state probe could not leave spawn"); game.destroy(); return;
    }

    game.debugSetWorldTimeForProbe(config.DAY_LENGTH_SEC * 0.75);
    tapKey(game, canvas, Key.Escape);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Down);
    tapKey(game, canvas, Key.Enter);
    if (game.isTitle() == false || near(game.debugWorldTime(), 0.0, 0.0001) == false ||
        near(game.debugWeatherIntensity(), 0.0, 0.0001) == false ||
        near(game.debugPlayerX(), spawnX, 0.05) == false ||
        near(game.debugPlayerZ(), spawnZ, 0.05) == false) {
        Terminal.Say("RESULT: fail quit-to-title did not abandon and reset the run");
        game.destroy(); return;
    }

    var diagnostics = Diagnostics3D.Summary();
    game.destroy();
    if (diagnostics != "") {
        Terminal.Say("RESULT: fail diagnostics " + diagnostics); return;
    }
    Terminal.Say("METRIC: seconds_to_first_dusk=" + toString(secondsToDusk));
    Terminal.Say("RESULT: ok deterministic_clock_weather_lifecycle_reset");
}
