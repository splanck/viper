// water_sky.zia - Skybox, water, and wind-swayed reed rendering.
module water_sky;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";
bind "./terrain";
bind "./mathutil";

class RidgeboundWaterSky {
    hide Water3D water;
    hide CubeMap3D skybox;
    hide List[CubeMap3D] phaseSkies;
    hide Mesh3D shoreMesh;
    hide Material3D shoreMat;
    hide Mesh3D saplingMesh;
    hide Material3D saplingMat;
    hide List[Float] reedXs;
    hide List[Float] reedZs;
    hide List[Float] reedPhase;
    hide List[Float] reedY;

    expose func setup(land: Terrain3D) {
        // Four keyframed skies (DAY / DUSK / NIGHT / DAWN). DAY stays pixel-exact
        // to the original outdoor sky; the game crossfades between them by swapping
        // at sun-elevation crossings (see game.updateSkybox). Dusk/dawn keyframes
        // halve the colour delta of the old binary day<->night pop.
        phaseSkies = [];
        phaseSkies.add(createPhaseSkybox(config.SKY_PHASE_DAY));
        phaseSkies.add(createPhaseSkybox(config.SKY_PHASE_DUSK));
        phaseSkies.add(createPhaseSkybox(config.SKY_PHASE_NIGHT));
        phaseSkies.add(createPhaseSkybox(config.SKY_PHASE_DAWN));
        skybox = phaseSkies.get(config.SKY_PHASE_DAY);

        var waterTex = createWaterSurfaceTexture(config.WATER_TEXTURE_SIZE);
        var waterNormal = createWaterNormalTexture(config.WATER_TEXTURE_SIZE);

        // One bounded water body, sized to the authored lake. The rectangle's
        // corners sit under the raised elliptical shore and are depth-occluded;
        // unlike the former world-sized plane + duplicate disc, water can no
        // longer appear through low terrain elsewhere in the valley.
        var lakeWidth = terrain.terrainWorldMaxX() * config.LAKE_RADIUS_X * 2.04;
        var lakeDepth = terrain.terrainWorldMaxZ() * config.LAKE_RADIUS_Z * 2.04;
        water = Water3D.New(lakeWidth, lakeDepth);
        Water3D.SetHeight(water, config.WATER_HEIGHT);
        Water3D.SetPosition(
            water,
            terrain.terrainWorldMaxX() * config.LAKE_CENTER_X,
            config.WATER_HEIGHT,
            terrain.terrainWorldMaxZ() * config.LAKE_CENTER_Z);
        Water3D.SetColor(water, config.WATER_R, config.WATER_G, config.WATER_B, config.WATER_A);
        Water3D.SetResolution(water, 120);
        Water3D.SetTexture(water, waterTex);
        Water3D.SetNormalMap(water, waterNormal);
        Water3D.SetEnvMap(water, skybox);
        Water3D.SetReflectivity(water, config.WATER_REFLECTIVITY);
        Water3D.AddWave(water, 1.0, 0.30, 1.5, 0.09, 18.0);
        Water3D.AddWave(water, -0.35, 0.82, 1.15, 0.05, 11.0);
        Water3D.AddWave(water, 0.55, -0.25, 1.8, 0.025, 6.5);

        // A narrow translucent edge softens the geometric water/land seam. It
        // is shoreline dressing, not a second water surface.
        shoreMesh = createShoreRingMesh(72, 0.91);
        shoreMat = Material3D.PBR(0.62, 0.72, 0.66);
        shoreMat.Roughness = 0.72;
        shoreMat.Metallic = 0.0;
        shoreMat.Alpha = 0.42;
        shoreMat.AlphaMode = 2;
        shoreMat.DoubleSided = true;

        setupReeds(land);
    }

    expose func getSkybox() -> CubeMap3D {
        return skybox;
    }

    expose func getPhaseSkybox(phase: Integer) -> CubeMap3D {
        if (phase < 0 || phase >= phaseSkies.count()) { return skybox; }
        return phaseSkies.get(phase);
    }

    // Point the water's environment reflection at the live sky so the lake mirrors
    // whichever keyframe is currently up (blue by day, warm at twilight, stars at night).
    expose func setPhaseReflections(phase: Integer) {
        var env = getPhaseSkybox(phase);
        Water3D.SetEnvMap(water, env);
    }

    expose func getWater() -> Water3D {
        return water;
    }

    expose func update(dt: Float) {
        Water3D.Update(water, dt);
    }

    expose func applyQuality(level: Integer) {
        if (water == null) { return; }
        if (level <= 0) {
            Water3D.SetResolution(water, 56);
            Water3D.SetReflectivity(water, 0.34);
        } else if (level == 1) {
            Water3D.SetResolution(water, 84);
            Water3D.SetReflectivity(water, 0.46);
        } else {
            Water3D.SetResolution(water, 120);
            Water3D.SetReflectivity(water, config.WATER_REFLECTIVITY);
        }
    }

    expose func drawWater(canvas: Canvas3D, camera: Camera3D) {
        Canvas3D.DrawWater(canvas, water, camera);
        if (shoreMesh != null && shoreMat != null) {
            var x = terrain.terrainWorldMaxX() * config.LAKE_CENTER_X;
            var z = terrain.terrainWorldMaxZ() * config.LAKE_CENTER_Z;
            var sx = terrain.terrainWorldMaxX() * config.LAKE_RADIUS_X;
            var sz = terrain.terrainWorldMaxZ() * config.LAKE_RADIUS_Z;
            var xform = Mat4.Mul(
                Mat4.Translate(x, config.WATER_HEIGHT + 0.035, z),
                Mat4.Scale(sx, 1.0, sz));
            Canvas3D.DrawMesh(canvas, shoreMesh, xform, shoreMat);
        }
    }

    // Reed ground heights are cached at setup (reeds never move), so this hot
    // per-frame path skips the terrain heightmap sampling it used to do.
    expose func drawReeds(canvas: Canvas3D, worldTime: Float) {
        if (saplingMesh == null) { return; }
        var windDirX = Sin(config.FOLIAGE_WIND_DIR);
        var windDirZ = Cos(config.FOLIAGE_WIND_DIR);
        for i in 0..reedXs.count() {
            var x = reedXs.get(i);
            var z = reedZs.get(i);
            var gy = reedY.get(i);
            var xform = Mat4.Translate(x, gy, z);
            var phase = worldTime * config.REED_WIND_FREQ * 6.0 + reedPhase.get(i);
            Canvas3D.DrawMeshWind(
                canvas, saplingMesh, xform, saplingMat, windDirX, windDirZ,
                config.REED_WIND_STRENGTH, phase);
        }
    }

    // Build one keyframed skybox. NIGHT keeps the px/py starfield generator; DAY
    // (and the DUSK/DAWN twilight keyframes) go through the direction sampler.
    hide func createPhaseSkybox(phase: Integer) -> CubeMap3D {
        if (phase == config.SKY_PHASE_NIGHT) {
            return CubeMap3D.New(
                createNightSkyFace(0), createNightSkyFace(1), createNightSkyFace(2),
                createNightSkyFace(3), createNightSkyFace(4), createNightSkyFace(5));
        }
        return CubeMap3D.New(
            createPhaseSkyFace(0, phase), createPhaseSkyFace(1, phase), createPhaseSkyFace(2, phase),
            createPhaseSkyFace(3, phase), createPhaseSkyFace(4, phase), createPhaseSkyFace(5, phase));
    }

    hide func phaseFaceSize(phase: Integer) -> Integer {
        if (phase == config.SKY_PHASE_DAY) { return config.SKYBOX_FACE_SIZE; }
        return config.SKY_TWILIGHT_FACE_SIZE;
    }

    hide func createNightSkyFace(faceId: Integer) -> Pixels {
        var size = config.SKYBOX_FACE_SIZE;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                // Vertical factor: 1 toward the zenith, 0 at the horizon band.
                var up = 0.5;
                if (faceId == 2) {
                    up = 1.0;
                } else {
                    if (faceId == 3) {
                        up = 0.0;
                    } else {
                        up = 1.0 - (py + 0.0) / (size + 0.0);
                    }
                }
                var r = mathutil.clampByte(Convert.NumToInt(mathutil.lerpFloat(20.0, 6.0, up)));
                var g = mathutil.clampByte(Convert.NumToInt(mathutil.lerpFloat(26.0, 9.0, up)));
                var b = mathutil.clampByte(Convert.NumToInt(mathutil.lerpFloat(44.0, 22.0, up)));

                // Sparse single-texel stars: enough to read as a night sky after
                // cubemap filtering, without turning into large white bloom discs.
                if (faceId != 3) {
                    var s = mathutil.hash01(px * 131 + faceId * 17, py * 71 + faceId * 29);
                    if (s > 0.992) {
                        var t = (s - 0.992) / 0.008;
                        var bright = mathutil.clampByte(70 + Convert.NumToInt(t * 110.0));
                        r = mathutil.clampByte(r + bright);
                        g = mathutil.clampByte(g + bright);
                        b = mathutil.clampByte(b + bright + 12);
                    }
                }
                face.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return face;
    }

    hide func createPhaseSkyFace(faceId: Integer, phase: Integer) -> Pixels {
        var size = phaseFaceSize(phase);
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var u = (((px + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                var v = (((py + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                face.Set(px, py, sampleSkyPixelForFace(faceId, u, v, phase));
            }
        }

        return face;
    }

    hide func sampleSkyPixelForFace(faceId: Integer, u: Float, v: Float, phase: Integer) -> Integer {
        var dx = 0.0;
        var dy = 0.0;
        var dz = 0.0;

        if (faceId == 0) {
            dx = 1.0;
            dy = 0.0 - v;
            dz = 0.0 - u;
        } else {
            if (faceId == 1) {
                dx = -1.0;
                dy = 0.0 - v;
                dz = u;
            } else {
                if (faceId == 2) {
                    dx = u;
                    dy = 1.0;
                    dz = v;
                } else {
                    if (faceId == 3) {
                        dx = u;
                        dy = -1.0;
                        dz = 0.0 - v;
                    } else {
                        if (faceId == 4) {
                            dx = u;
                            dy = 0.0 - v;
                            dz = 1.0;
                        } else {
                            dx = 0.0 - u;
                            dy = 0.0 - v;
                            dz = -1.0;
                        }
                    }
                }
            }
        }

        var len = Sqrt(dx * dx + dy * dy + dz * dz);
        if (len <= 0.0001) {
            return mathutil.packPixel(132, 174, 220, 255);
        }

        return sampleSkyForPhase(dx / len, dy / len, dz / len, phase);
    }

    hide func sampleSkyForPhase(dx: Float, dy: Float, dz: Float, phase: Integer) -> Integer {
        var up = mathutil.clampFloat((dy + 0.10) / 1.10, 0.0, 1.0);
        // Tighter, brighter horizon haze band + a warm sun-side glow, over a deeper
        // saturated zenith blue for a more dramatic sky gradient.
        var haze = mathutil.clampFloat(1.0 - mathutil.absFloat(dy) * 2.4, 0.0, 1.0);
        haze = haze * haze;
        var sun = mathutil.clampFloat((dx * 0.55 - dz * 0.35 + 1.0) / 2.0, 0.0, 1.0);
        // DAY base — kept byte-identical to the original outdoor sky.
        var r = mathutil.lerpFloat(150.0, 58.0, up) + haze * (30.0 + sun * 22.0);
        var g = mathutil.lerpFloat(196.0, 116.0, up) + haze * (24.0 + sun * 14.0);
        var b = mathutil.lerpFloat(242.0, 208.0, up) + haze * 10.0;

        if (phase != config.SKY_PHASE_DAY) {
            // Twilight: dim the whole sky toward a dusky base and paint a warm
            // sun-side horizon glow. Dusk runs orange; dawn is cooler and rosier.
            var warmR = 236.0;
            var warmG = 128.0;
            var warmB = 92.0;
            if (phase == config.SKY_PHASE_DAWN) {
                warmR = 206.0;
                warmG = 142.0;
                warmB = 162.0;
            }
            var glow = mathutil.clampFloat(haze * (0.60 + sun * 0.50), 0.0, 1.0);
            r = mathutil.lerpFloat(r * 0.42, warmR, glow);
            g = mathutil.lerpFloat(g * 0.42, warmG, glow);
            b = mathutil.lerpFloat(b * 0.58, warmB, glow);
        }

        if (dy < -0.18) {
            var ground = mathutil.clampFloat((0.0 - dy - 0.18) / 0.82, 0.0, 1.0);
            r = mathutil.lerpFloat(r, 77.0, ground);
            g = mathutil.lerpFloat(g, 94.0, ground);
            b = mathutil.lerpFloat(b, 82.0, ground);
        }

        return mathutil.packPixel(
            mathutil.clampByte(Convert.NumToInt(r)),
            mathutil.clampByte(Convert.NumToInt(g)),
            mathutil.clampByte(Convert.NumToInt(b)),
            255);
    }

    hide func createWaterSurfaceTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var ripple = ((px * 5 + py * 11 + px * py * 3) % 30) - 15;
                var longLine = absInt(((px * 3 + py * 2) % 37) - 18);
                var shortLine = absInt(((px - py * 4 + size * 4) % 29) - 14);
                var foam = 0;
                if (longLine <= 1) { foam = foam + 24; }
                if (shortLine == 0) { foam = foam + 12; }
                tex.Set(px, py, mathutil.packPixel(
                    mathutil.clampByte(10 + ripple / 3 + foam / 5),
                    mathutil.clampByte(92 + ripple / 2 + foam),
                    mathutil.clampByte(154 + ripple + foam),
                    255));
            }
        }

        return tex;
    }

    hide func createWaterNormalTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var sx = ((px * 3 + py * 5) % 17) - 8;
                var sz = ((px * 7 - py * 2 + size * 2) % 19) - 9;
                var crest = absInt(((px * 2 + py * 3) % 23) - 11);
                var ny = 238;
                if (crest <= 1) { ny = 248; }
                tex.Set(px, py, mathutil.packPixel(
                    mathutil.clampByte(128 + sx * 5),
                    mathutil.clampByte(128 + sz * 4),
                    ny,
                    255));
            }
        }

        return tex;
    }

    hide func createShoreRingMesh(segments: Integer, innerRadius: Float) -> Mesh3D {
        var mesh = Mesh3D.New();
        Mesh3D.Reserve(mesh, segments * 2, segments * 2);

        var i = 0;
        while (i < segments) {
            var ang = (i + 0.0) / (segments + 0.0) * 6.2831853;
            var x = Sin(ang);
            var z = Cos(ang);
            Mesh3D.AddVertex(mesh, x * innerRadius, 0.0, z * innerRadius,
                0.0, 1.0, 0.0, (i + 0.0) / (segments + 0.0), 0.0);
            Mesh3D.AddVertex(mesh, x, 0.0, z,
                0.0, 1.0, 0.0, (i + 0.0) / (segments + 0.0), 1.0);
            i = i + 1;
        }

        i = 0;
        while (i < segments) {
            var next = i + 1;
            if (next >= segments) { next = 0; }
            var innerA = i * 2;
            var outerA = innerA + 1;
            var innerB = next * 2;
            var outerB = innerB + 1;
            Mesh3D.AddTriangle(mesh, innerA, outerA, outerB);
            Mesh3D.AddTriangle(mesh, innerA, outerB, innerB);
            i = i + 1;
        }

        Mesh3D.CalculateTangents(mesh);
        return mesh;
    }

    hide func setupReeds(land: Terrain3D) {
        saplingMesh = Mesh3D.Cylinder(config.REED_RADIUS, config.REED_HEIGHT, 6);
        saplingMat = Materials.Rubber(0.21, 0.38, 0.16);
        Material3D.SetEmissiveColor(saplingMat, 0.004, 0.010, 0.003);
        reedXs = [];
        reedZs = [];
        reedPhase = [];
        reedY = [];
        var cx = terrain.terrainWorldMaxX() * config.LAKE_CENTER_X;
        var cz = terrain.terrainWorldMaxZ() * config.LAKE_CENTER_Z;
        var rx = terrain.terrainWorldMaxX() * config.LAKE_RADIUS_X;
        var rz = terrain.terrainWorldMaxZ() * config.LAKE_RADIUS_Z;
        var i = 0;
        while (i < config.REED_COUNT) {
            var ang = (i + 0.0) / (config.REED_COUNT + 0.0) * 6.2831853 + mathutil.hash01(i, 41);
            var radius = 0.88 + mathutil.hash01(i, 43) * 0.28;
            var wx = cx + Sin(ang) * rx * radius;
            var wz = cz + Cos(ang) * rz * radius;
            if (wx > config.TERRAIN_MARGIN && wx < terrain.terrainWorldMaxX() - config.TERRAIN_MARGIN
                    && wz > config.TERRAIN_MARGIN && wz < terrain.terrainWorldMaxZ() - config.TERRAIN_MARGIN) {
                var ground = terrain.sampleGround(land, wx, wz);
                if (ground > config.WATER_HEIGHT - 0.7 && ground < config.WATER_HEIGHT + 2.0) {
                    reedXs.add(wx);
                    reedZs.add(wz);
                    reedPhase.add(mathutil.hash01(i, 47) * 6.2831853);
                    reedY.add(ground + config.REED_HEIGHT * 0.5);
                }
            }
            i = i + 1;
        }
    }

    hide func absInt(value: Integer) -> Integer {
        if (value < 0) { return 0 - value; }
        return value;
    }
}
