// assets.zia - Shared meshes and materials for Ridgebound.
module assets;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind "./config";
bind "./terrain";

class RidgeboundAssets {
    hide Mesh3D cubeMesh;
    hide Mesh3D beaconMesh;
    hide Mesh3D playerBodyMesh;
    hide Mesh3D playerCoreMesh;
    hide Mesh3D playerLimbMesh;
    hide Mesh3D playerPackMesh;
    hide Material3D terrainMat;
    hide Material3D stoneMat;
    hide Material3D pedestalMat;
    hide Material3D playerMat;
    hide Material3D playerTrimMat;
    hide Material3D playerShadowMat;
    hide Material3D beaconOffMat;
    hide Material3D beaconOnMat;
    hide Material3D archiveMat;
    hide Material3D waterMarkerMat;

    expose func setup() {
        cubeMesh = Mesh3D.Box(1.0, 1.0, 1.0);
        beaconMesh = Mesh3D.Sphere(0.54, 22);
        playerBodyMesh = Mesh3D.Box(0.58, 0.72, 0.34);
        playerCoreMesh = Mesh3D.Sphere(0.23, 12);
        playerLimbMesh = Mesh3D.Cylinder(0.075, 0.58, 8);
        playerPackMesh = Mesh3D.Box(0.44, 0.55, 0.20);
        Mesh3D.CalculateTangents(cubeMesh);

        var stoneAlbedo = terrain.createStoneAlbedo(config.PBR_TEXTURE_SIZE);
        var metalAlbedo = terrain.createMetalAlbedo(config.PBR_TEXTURE_SIZE);
        var rockNormal = terrain.createNormalMap(config.PBR_TEXTURE_SIZE, config.PBR_NORMAL_STRENGTH);

        terrainMat = Material3D.PBR(0.42, 0.52, 0.30);
        terrainMat.Roughness = config.TERRAIN_DRY_ROUGH;
        terrainMat.Metallic = 0.0;
        Material3D.SetEmissiveColor(terrainMat, 0.002, 0.003, 0.001);

        stoneMat = Material3D.PBR(0.38, 0.40, 0.42);
        Material3D.SetAlbedoMap(stoneMat, stoneAlbedo);
        Material3D.SetNormalMap(stoneMat, rockNormal);
        stoneMat.Roughness = 0.80;
        stoneMat.Metallic = 0.05;
        Material3D.SetEmissiveColor(stoneMat, 0.010, 0.012, 0.016);

        pedestalMat = Material3D.PBR(0.31, 0.30, 0.26);
        Material3D.SetAlbedoMap(pedestalMat, stoneAlbedo);
        Material3D.SetNormalMap(pedestalMat, rockNormal);
        pedestalMat.Roughness = 0.90;
        pedestalMat.Metallic = 0.0;
        Material3D.SetEmissiveColor(pedestalMat, 0.004, 0.004, 0.003);

        playerMat = Material3D.PBR(0.18, 0.34, 0.31);
        playerMat.Roughness = 0.82;
        Material3D.SetEmissiveColor(playerMat, 0.003, 0.006, 0.005);
        playerTrimMat = Material3D.PBR(0.72, 0.46, 0.20);
        playerTrimMat.Roughness = 0.70;
        Material3D.SetEmissiveColor(playerTrimMat, 0.015, 0.007, 0.002);
        playerShadowMat = Material3D.PBR(0.035, 0.045, 0.045);
        playerShadowMat.Roughness = 1.0;
        playerShadowMat.Alpha = 0.48;
        playerShadowMat.AlphaMode = 2;
        beaconOffMat = Materials.Plastic(0.20, 0.28, 0.32);
        Material3D.SetEmissiveColor(beaconOffMat, 0.008, 0.012, 0.015);
        beaconOnMat = Materials.Emissive(0.96, 0.60, 0.18, 1.25);

        archiveMat = Material3D.PBR(0.48, 0.45, 0.37);
        Material3D.SetAlbedoMap(archiveMat, metalAlbedo);
        Material3D.SetNormalMap(archiveMat, rockNormal);
        archiveMat.Roughness = 0.34;
        archiveMat.Metallic = 0.55;

        waterMarkerMat = Materials.Emissive(0.20, 0.68, 0.74, 1.10);
    }

    expose func applyEnvReflections(skybox: CubeMap3D) {
        Material3D.SetEnvMap(stoneMat, skybox);
        stoneMat.Reflectivity = 0.16;
        Material3D.SetEnvMap(pedestalMat, skybox);
        pedestalMat.Reflectivity = 0.10;
        Material3D.SetEnvMap(archiveMat, skybox);
        archiveMat.Reflectivity = 0.45;
    }

    expose func getCubeMesh() -> Mesh3D { return cubeMesh; }
    expose func getBeaconMesh() -> Mesh3D { return beaconMesh; }
    expose func getPlayerBodyMesh() -> Mesh3D { return playerBodyMesh; }
    expose func getPlayerCoreMesh() -> Mesh3D { return playerCoreMesh; }
    expose func getPlayerLimbMesh() -> Mesh3D { return playerLimbMesh; }
    expose func getPlayerPackMesh() -> Mesh3D { return playerPackMesh; }
    expose func getTerrainMat() -> Material3D { return terrainMat; }

    // Wet-ground look: as the terrain soaks (0..1) it darkens toward wet earth and
    // turns glossier (lower roughness), then dries back. Owns the base terrain
    // colour so the wetness math stays consistent with setup above.
    expose func applyTerrainWetness(wet: Float) {
        if (terrainMat == null) { return; }
        var w = wet;
        if (w < 0.0) { w = 0.0; }
        if (w > 1.0) { w = 1.0; }
        var darken = 1.0 + (config.TERRAIN_WET_DARKEN - 1.0) * w;
        Material3D.SetColor(terrainMat, 0.42 * darken, 0.52 * darken, 0.30 * darken);
        terrainMat.Roughness = config.TERRAIN_DRY_ROUGH + (config.TERRAIN_WET_ROUGH - config.TERRAIN_DRY_ROUGH) * w;
    }
    expose func getStoneMat() -> Material3D { return stoneMat; }
    expose func getPedestalMat() -> Material3D { return pedestalMat; }
    expose func getPlayerMat() -> Material3D { return playerMat; }
    expose func getPlayerTrimMat() -> Material3D { return playerTrimMat; }
    expose func getPlayerShadowMat() -> Material3D { return playerShadowMat; }
    expose func getBeaconOffMat() -> Material3D { return beaconOffMat; }
    expose func getBeaconOnMat() -> Material3D { return beaconOnMat; }
    expose func getArchiveMat() -> Material3D { return archiveMat; }
    expose func getWaterMarkerMat() -> Material3D { return waterMarkerMat; }
}
