// mathutil.zia - Shared numeric, hashing, and pixel-packing helpers.
//
// These are pure utilities with no terrain dependency. They used to live in
// terrain.zia, which forced every module that only needed a clamp or a pixel
// pack to depend on the whole terrain system. Keeping them here lets each
// module bind just this file.
module mathutil;

func packPixel(r: Integer, g: Integer, b: Integer, a: Integer) -> Integer {
    return (((r * 256) + g) * 256 + b) * 256 + a;
}

func clampByte(value: Integer) -> Integer {
    if (value < 0) { return 0; }
    if (value > 255) { return 255; }
    return value;
}

func clampFloat(value: Float, lo: Float, hi: Float) -> Float {
    if (value < lo) { return lo; }
    if (value > hi) { return hi; }
    return value;
}

func absFloat(value: Float) -> Float {
    if (value < 0.0) { return 0.0 - value; }
    return value;
}

func lerpFloat(a: Float, b: Float, t: Float) -> Float {
    return a + (b - a) * t;
}

func maxf(a: Float, b: Float) -> Float {
    if (a > b) { return a; }
    return b;
}

func minf(a: Float, b: Float) -> Float {
    if (a < b) { return a; }
    return b;
}

func smoothStep(edge0: Float, edge1: Float, value: Float) -> Float {
    if (edge1 <= edge0) {
        if (value >= edge1) { return 1.0; }
        return 0.0;
    }

    var t = clampFloat((value - edge0) / (edge1 - edge0), 0.0, 1.0);
    return t * t * (3.0 - 2.0 * t);
}

func hash01(a: Integer, b: Integer) -> Float {
    var h = (a * 374761393 + b * 668265263) % 2147483647;
    if (h < 0) { h = 0 - h; }
    h = (h * 1103515245 + 12345) % 2147483647;
    if (h < 0) { h = 0 - h; }
    return (h % 100000 + 0.0) / 100000.0;
}
