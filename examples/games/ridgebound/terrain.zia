// terrain.zia - Terrain generation, procedural textures, and ground queries.
module terrain;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";
bind "./mathutil";

// Shared numeric, pixel, and hash helpers moved to mathutil.zia (bound above).

func noise01(noise: PerlinNoise, x: Float, z: Float, octaves: Integer, persistence: Float) -> Float {
    return mathutil.clampFloat((PerlinNoise.Octave2D(noise, x, z, octaves, persistence) + 1.0) * 0.5, 0.0, 1.0);
}

func heightPixel(value: Float) -> Integer {
    var h = mathutil.clampFloat(value, 0.0, 1.0);
    var h16 = Convert.NumToInt(h * 65535.0);
    if (h16 < 0) { h16 = 0; }
    if (h16 > 65535) { h16 = 65535; }
    return mathutil.packPixel(h16 / 256, h16 % 256, 0, 255);
}

func terrainWorldMaxX() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_X;
}

func terrainWorldMaxZ() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_Z;
}

func sampleGround(land: Terrain3D, x: Float, z: Float) -> Float {
    var sx = x;
    var sz = z;

    if (sx < 0.0) { sx = 0.0; }
    if (sz < 0.0) { sz = 0.0; }
    if (sx > terrainWorldMaxX()) { sx = terrainWorldMaxX(); }
    if (sz > terrainWorldMaxZ()) { sz = terrainWorldMaxZ(); }

    return Terrain3D.GetHeightAt(land, sx, sz);
}

func lakeDistanceNormalized(nx: Float, nz: Float) -> Float {
    var dx = (nx - config.LAKE_CENTER_X) / config.LAKE_RADIUS_X;
    var dz = (nz - config.LAKE_CENTER_Z) / config.LAKE_RADIUS_Z;
    return Sqrt(dx * dx + dz * dz);
}

func distanceToSegmentNormalized(px: Float, pz: Float,
                                 ax: Float, az: Float, bx: Float, bz: Float) -> Float {
    var vx = bx - ax;
    var vz = bz - az;
    var lenSq = vx * vx + vz * vz;
    if (lenSq <= 0.0000001) {
        var dx = px - ax;
        var dz = pz - az;
        return Sqrt(dx * dx + dz * dz);
    }
    var t = ((px - ax) * vx + (pz - az) * vz) / lenSq;
    t = mathutil.clampFloat(t, 0.0, 1.0);
    var qx = ax + vx * t;
    var qz = az + vz * t;
    var dx = px - qx;
    var dz = pz - qz;
    return Sqrt(dx * dx + dz * dz);
}

// Distance in normalized terrain coordinates to the authored path network.
// Every system that needs route clearance calls this one definition.
func authoredRouteDistance(nx: Float, nz: Float) -> Float {
    var best = distanceToSegmentNormalized(
        nx, nz, 0.50, 0.50, config.BEACON_0_X, config.BEACON_0_Z);
    best = mathutil.minf(best, distanceToSegmentNormalized(
        nx, nz, 0.50, 0.50, config.BEACON_1_X, config.BEACON_1_Z));
    best = mathutil.minf(best, distanceToSegmentNormalized(
        nx, nz, 0.50, 0.50, config.BEACON_4_X, config.BEACON_4_Z));
    best = mathutil.minf(best, distanceToSegmentNormalized(
        nx, nz, config.BEACON_4_X, config.BEACON_4_Z, config.BEACON_2_X, config.BEACON_2_Z));
    best = mathutil.minf(best, distanceToSegmentNormalized(
        nx, nz, config.BEACON_4_X, config.BEACON_4_Z, config.BEACON_3_X, config.BEACON_3_Z));
    return best;
}

func isAuthoredRouteWorld(x: Float, z: Float) -> Boolean {
    var nx = x / terrainWorldMaxX();
    var nz = z / terrainWorldMaxZ();
    return authoredRouteDistance(nx, nz) < config.ROUTE_HALF_WIDTH * 2.2;
}

func isDeepWater(land: Terrain3D, x: Float, z: Float) -> Boolean {
    var nx = x / terrainWorldMaxX();
    var nz = z / terrainWorldMaxZ();
    return lakeDistanceNormalized(nx, nz) < 1.02
        && sampleGround(land, x, z) < config.WATER_HEIGHT - 0.35;
}

func createStoneAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 13 + py * 7 + px * py * 3) % 40) - 20;
            var base = mathutil.clampByte(120 + n);
            var cool = mathutil.clampByte(126 + n / 2);
            tex.Set(px, py, mathutil.packPixel(base, base, cool, 255));
        }
    }

    return tex;
}

func createMetalAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 9 + py * 11) % 24) - 12;
            var brush = ((py * 5) % 14) - 7;
            var r = mathutil.clampByte(150 + n + brush);
            var g = mathutil.clampByte(140 + n + brush);
            var b = mathutil.clampByte(118 + n);
            tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func createNormalMap(size: Integer, strength: Float) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var hl = bumpHeight(px - 1, py, size);
            var hr = bumpHeight(px + 1, py, size);
            var hd = bumpHeight(px, py - 1, size);
            var hu = bumpHeight(px, py + 1, size);
            var nx = (hl - hr) * strength;
            var nz = (hd - hu) * strength;
            var ny = 1.0;
            var len = Sqrt(nx * nx + ny * ny + nz * nz);
            if (len <= 0.0001) { len = 1.0; }
            nx = nx / len;
            ny = ny / len;
            nz = nz / len;
            var r = mathutil.clampByte(Convert.NumToInt((nx * 0.5 + 0.5) * 255.0));
            var g = mathutil.clampByte(Convert.NumToInt((nz * 0.5 + 0.5) * 255.0));
            var b = mathutil.clampByte(Convert.NumToInt((ny * 0.5 + 0.5) * 255.0));
            tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func bumpHeight(x: Integer, y: Integer, size: Integer) -> Float {
    if (size <= 0) { return 0.0; }
    var xx = x;
    while (xx < 0) { xx = xx + size; }
    while (xx >= size) { xx = xx - size; }
    var yy = y;
    while (yy < 0) { yy = yy + size; }
    while (yy >= size) { yy = yy - size; }
    var n = (xx * 13 + yy * 7 + xx * yy * 3) % 23;
    return (n + 0.0) / 23.0;
}

class RidgeboundTerrain {
    hide Terrain3D land;
    hide Pixels splatMap;
    hide Pixels heightmap;
    hide Vegetation3D grass;

    expose func build(terrainMat: Material3D) -> Terrain3D {
        land = Terrain3D.New(config.TERRAIN_SIZE, config.TERRAIN_SIZE);
        // Retain the heightmap Pixels so a matching physics heightfield collider
        // can be built from the exact same data (see game.zia setup).
        heightmap = createRidgeboundHeightmap(config.TERRAIN_SIZE, config.TERRAIN_SIZE);
        Terrain3D.SetHeightmap(land, heightmap);
        Terrain3D.SetScale(
            land, config.TERRAIN_SCALE_X, config.TERRAIN_SCALE_Y, config.TERRAIN_SCALE_Z);
        Terrain3D.SetMaterial(land, terrainMat);

        var grassTex = createGrassTexture(config.TERRAIN_TEXTURE_SIZE);
        Terrain3D.SetLayerTexture(land, 0, grassTex);
        Terrain3D.SetLayerTexture(land, 1, createRockTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 2, createDirtTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 3, createSnowTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerScale(land, 0, 11.0);
        Terrain3D.SetLayerScale(land, 1, 9.0);
        Terrain3D.SetLayerScale(land, 2, 8.0);
        Terrain3D.SetLayerScale(land, 3, 6.0);
        splatMap = createTerrainSplatMap(land, config.SPLAT_SIZE, config.SPLAT_SIZE);
        Terrain3D.SetSplatMap(land, splatMap);
        Terrain3D.SetLODDistances(land, config.TERRAIN_LOD_NEAR, config.TERRAIN_LOD_FAR);
        Terrain3D.SetSkirtDepth(land, config.TERRAIN_SKIRT_DEPTH);

        return land;
    }

    // The 16-bit heightmap Pixels used to build the terrain, reused to spawn a
    // matching physics heightfield collider so the character walks the terrain.
    expose func getHeightmap() -> Pixels { return heightmap; }

    expose func buildVegetation() {
        grass = Vegetation3D.New(createGrassBladeTexture());
        Vegetation3D.SetBladeSize(grass, config.GRASS_BLADE_W, config.GRASS_BLADE_H, config.GRASS_BLADE_VAR);
        Vegetation3D.SetWindParams(grass, config.GRASS_WIND_SPEED, config.GRASS_WIND_STRENGTH, config.GRASS_WIND_TURBULENCE);
        Vegetation3D.SetLODDistances(grass, config.GRASS_LOD_NEAR, config.GRASS_LOD_FAR);
        Vegetation3D.SetDensityMap(grass, createVegetationDensity(config.SPLAT_SIZE, config.SPLAT_SIZE));
        Vegetation3D.Populate(grass, land, config.GRASS_BLADE_COUNT);
    }

    expose func updateVegetation(dt: Float, camera: Camera3D) {
        if (grass == null) { return; }
        var camPos = camera.Position;
        Vegetation3D.Update(grass, dt, Vec3.get_X(camPos), Vec3.get_Y(camPos), Vec3.get_Z(camPos));
    }

    expose func drawVegetation(canvas: Canvas3D) {
        if (grass != null) {
            Canvas3D.DrawVegetation(canvas, grass);
        }
    }

    expose func applyQuality(level: Integer) {
        if (grass == null) { return; }
        if (level <= 0) {
            Vegetation3D.SetLODDistances(grass, 22.0, 52.0);
        } else if (level == 1) {
            Vegetation3D.SetLODDistances(grass, 30.0, 74.0);
        } else {
            Vegetation3D.SetLODDistances(grass, config.GRASS_LOD_NEAR, config.GRASS_LOD_FAR);
        }
    }

    expose func getTerrain() -> Terrain3D {
        return land;
    }

    hide func grassPixel(px: Integer, py: Integer) -> Integer {
        // Wider tonal spread + soft patches for a richer, less uniform green.
        var noise = ((px * 7 + py * 11 + px * py) % 40) - 20;
        var patch = ((px / 9 + py / 7) % 3) * 10 - 10;
        var r = mathutil.clampByte(58 + noise / 2 + patch / 2);
        var g = mathutil.clampByte(104 + noise + patch);
        var b = mathutil.clampByte(42 + noise / 3 + patch / 3);
        return mathutil.packPixel(r, g, b, 255);
    }

    hide func createGrassTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                tex.Set(px, py, grassPixel(px, py));
            }
        }

        return tex;
    }

    hide func createRockTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                // Darker, higher-contrast stone: strata bands + dark cracks + a
                // faint warm-grey cast so mountain flanks read as real rock.
                var noise = ((px * 13 + py * 9 + px * py * 3) % 54) - 27;
                var strata = ((py / 3) % 2) * 14 - 7;
                var crack = 0;
                if (((px * 3 + py * 7) % 29) < 2) { crack = -28; }
                var base = mathutil.clampByte(94 + noise + strata + crack);
                var r = mathutil.clampByte(base + 12);
                var g = mathutil.clampByte(base + 4);
                var b = mathutil.clampByte(base - 6);
                tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createDirtTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 9 + py * 5 + px * py) % 22) - 11;
                var r = mathutil.clampByte(142 + noise);
                var g = mathutil.clampByte(108 + noise / 2);
                var b = mathutil.clampByte(66 + noise / 3);
                tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createSnowTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                // Cool blue-grey snow with wind-drift noise. Keep the albedo below
                // pure white so daylight/IBL can brighten the field without
                // blowing out the smoke-probe foreground.
                var noise = ((px * 5 + py * 3 + px * py) % 16) - 8;
                var sparkle = 0;
                if (((px * 7 + py * 13) % 37) == 0) { sparkle = 12; }
                var r = mathutil.clampByte(144 + noise / 2 + sparkle);
                var g = mathutil.clampByte(160 + noise / 2 + sparkle);
                var b = mathutil.clampByte(184 + noise / 3 + sparkle);
                tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createRidgeboundHeightmap(width: Integer, depth: Integer) -> Pixels {
        var heights = Pixels.New(width, depth);
        var noise = PerlinNoise.New(42);
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var pz: Integer = 0; pz < depth; pz = pz + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var nx = (px + 0.0) / (lastX + 0.0);
                var nz = (pz + 0.0) / (lastZ + 0.0);
                heights.Set(px, pz, heightPixel(sampleRidgeboundHeight(noise, nx, nz)));
            }
        }

        return heights;
    }

    hide func sampleRidgeboundHeight(noise: PerlinNoise, nx: Float, nz: Float) -> Float {
        var rolling = noise01(
            noise,
            nx * config.TERRAIN_NOISE_SCALE,
            nz * config.TERRAIN_NOISE_SCALE,
            config.TERRAIN_NOISE_OCTAVES,
            config.TERRAIN_NOISE_PERSIST);
        var broad = noise01(noise, nx * 1.65 + 13.0, nz * 1.65 - 4.0, 3, 0.56);
        var detail = noise01(noise, nx * 15.0 + 2.0, nz * 15.0 + 9.0, 3, 0.48);
        // A restrained rolling valley keeps local slopes readable and walkable.
        // Fine noise is surface character, never the dominant topology.
        var h = 0.165 + rolling * 0.105 + broad * 0.035 + detail * 0.012;

        // Preserve a genuinely submerged basin. The old mountain smooth-max had
        // a 0.16 floor everywhere, silently filling this bowl to water level.
        var lakeDist = lakeDistanceNormalized(nx, nz);
        var basin = 1.0 - mathutil.smoothStep(
            config.LAKE_SHORE_INNER, config.LAKE_SHORE_OUTER, lakeDist);
        var lakeFloor = config.LAKE_FLOOR_HEIGHT / config.TERRAIN_SCALE_Y
            + (detail - 0.5) * 0.006;
        h = mathutil.lerpFloat(h, lakeFloor, basin);

        // Raw border distance (0 at any edge, 0.5 at center) — used ONLY by the
        // containment rim, which must stay a hard square guarantee.
        var edge = mathutil.minf(mathutil.minf(nx, 1.0 - nx), mathutil.minf(nz, 1.0 - nz));

        // --- Organic range shaping ---------------------------------------------
        // 1. Domain-warp the coords that define the band SHAPE (not the rim), so
        //    the mountain foot meanders instead of tracing a straight square.
        var warpX = (noise01(noise, nx * 2.6 + 51.0, nz * 2.6 - 37.0, 3, 0.5) - 0.5) * config.MOUNTAIN_WARP_AMP;
        var warpZ = (noise01(noise, nx * 2.6 - 23.0, nz * 2.6 + 44.0, 3, 0.5) - 0.5) * config.MOUNTAIN_WARP_AMP;
        var wx = nx + warpX;
        var wz = nz + warpZ;
        // 2. Superellipse border metric on the warped coords: p=inf is today's
        //    square, p=4 rounds the corners so the range curves around the valley.
        var cx = mathutil.absFloat(2.0 * wx - 1.0);
        var cz = mathutil.absFloat(2.0 * wz - 1.0);
        var sMetric = Pow(
            Pow(cx, config.MOUNTAIN_EDGE_POW) + Pow(cz, config.MOUNTAIN_EDGE_POW),
            1.0 / config.MOUNTAIN_EDGE_POW);
        var edgeW = (1.0 - mathutil.clampFloat(sMetric, 0.0, 1.0)) * 0.5;

        var mountainBand = 1.0 - mathutil.smoothStep(0.045, config.MOUNTAIN_RING_FADE, edgeW);
        var crestBand = 1.0 - mathutil.smoothStep(0.0, config.MOUNTAIN_CREST_FADE, edgeW);
        var ridgeNoise = noise01(noise, nx * 7.7 + 5.0, nz * 7.7 - 3.0, 5, 0.54);
        var cragNoise = noise01(noise, nx * 27.0 - 11.0, nz * 27.0 + 4.0, 4, 0.50);
        // Ridged noise: fold the smooth field into sharp crests (peaks where it
        // crosses its midpoint) so the range gets ridgelines + V-valleys, not
        // rounded blobs. Squaring sharpens the summits.
        var ridge = 1.0 - mathutil.absFloat(ridgeNoise * 2.0 - 1.0);
        ridge = ridge * ridge;
        var crag = 1.0 - mathutil.absFloat(cragNoise * 2.0 - 1.0);
        // 3. Massif modulation: a low-frequency field scales peak amplitude so the
        //    skyline is tall massifs separated by low saddle passes, not one crest.
        var massif = config.MOUNTAIN_MASSIF_BASE
            + config.MOUNTAIN_MASSIF_RANGE * noise01(noise, wx * 2.1 + 7.0, wz * 2.1 - 9.0, 2, 0.55);
        var mountainRaise = mountainBand * massif * (0.24 + ridge * 0.50 + crag * 0.16)
            + crestBand * massif * (ridge * 0.22 + crag * 0.12);
        // Keep mountains and foothills outside the entire shoreline transition.
        var lakeProtection = mathutil.smoothStep(0.94, 1.24, lakeDist);
        mountainRaise = mountainRaise * lakeProtection;
        var mountain = 0.19 + mountainRaise;

        // 4. A wide, low foothill skirt reaching further into the interior, then a
        //    smooth-max blend so the range grows out of the rolling terrain with a
        //    natural shoulder instead of the knife-edge a hard max leaves.
        var foothill = (1.0 - mathutil.smoothStep(
            config.MOUNTAIN_RING_FADE,
            config.MOUNTAIN_RING_FADE + config.MOUNTAIN_FOOTHILL_FADE,
            edgeW)) * (0.04 + broad * config.MOUNTAIN_FOOTHILL_HEIGHT) * lakeProtection;
        h = h + foothill;
        var mountainSurface = mathutil.smoothMax(h, mountain, config.MOUNTAIN_BLEND_K);
        h = mathutil.lerpFloat(h, mountainSurface, mountainBand * lakeProtection);

        // Containment rim just beyond the player's bounds: guaranteed tall enough
        // to enclose the world. Kept on the RAW (unwarped) edge with a hard floor
        // and hard max so containment is a guarantee, not an aesthetic; the rim top
        // carries ridge/crag/massif variance so it reads as a range, not a wall,
        // and (WARP_AMP < guardEdge) keeps it hidden behind the warped peaks.
        var guardEdge = mathutil.minf(
            config.PLAYER_BOUNDS_MARGIN / terrainWorldMaxX(),
            config.PLAYER_BOUNDS_MARGIN / terrainWorldMaxZ());
        var blocker = 1.0 - mathutil.smoothStep(0.0, guardEdge, edge);
        if (blocker > 0.0) {
            var rim = config.MOUNTAIN_RIM_FLOOR + blocker * 0.10 + ridge * 0.36 + crag * 0.12
                + massif * config.MOUNTAIN_RIM_MASSIF;
            // Blend the containment mass by its falloff. The previous hard max
            // applied the rim's 0.50 base even when blocker was almost zero,
            // creating a vertical inner wall at the bounds line.
            var rimSurface = mathutil.smoothMax(h, rim, config.MOUNTAIN_BLEND_K);
            h = mathutil.lerpFloat(h, rimSurface, blocker * blocker);
        }

        // Grade one connected path network across the valley. Inside the basin
        // it becomes a broad dry causeway; on land it gently levels noisy grades
        // and becomes the dirt trail painted by createTerrainSplatMap.
        var routeWidth = config.ROUTE_HALF_WIDTH;
        if (lakeDist < 1.18) { routeWidth = config.LAKE_CAUSEWAY_HALF_WIDTH; }
        var route = 1.0 - mathutil.smoothStep(
            routeWidth, routeWidth * 2.5, authoredRouteDistance(nx, nz));
        var routeTarget = 0.205 + (broad - 0.5) * 0.012;
        if (lakeDist < 1.18) {
            routeTarget = config.WATER_HEIGHT / config.TERRAIN_SCALE_Y + 0.032;
        }
        h = mathutil.lerpFloat(h, routeTarget, route * 0.92);

        // Stable, nearly-flat arrival pads prevent beacon pedestals and the
        // player spawn from landing on local noise or cross-slope terrain.
        h = flattenSite(h, nx, nz, 0.50, 0.50, 0.055, 0.205);
        h = flattenSite(h, nx, nz, config.BEACON_0_X, config.BEACON_0_Z,
            config.BEACON_SITE_RADIUS, 0.225);
        h = flattenSite(h, nx, nz, config.BEACON_1_X, config.BEACON_1_Z,
            config.BEACON_SITE_RADIUS, 0.225);
        h = flattenSite(h, nx, nz, config.BEACON_2_X, config.BEACON_2_Z,
            config.BEACON_SITE_RADIUS, 0.215);
        h = flattenSite(h, nx, nz, config.BEACON_3_X, config.BEACON_3_Z,
            config.BEACON_SITE_RADIUS, 0.215);
        h = flattenSite(h, nx, nz, config.BEACON_4_X, config.BEACON_4_Z,
            config.BEACON_SITE_RADIUS, 0.205);

        return mathutil.clampFloat(h, 0.0, 1.0);
    }

    hide func flattenSite(h: Float, nx: Float, nz: Float,
                          cx: Float, cz: Float, radius: Float, target: Float) -> Float {
        var dx = nx - cx;
        var dz = nz - cz;
        var dist = Sqrt(dx * dx + dz * dz) / radius;
        var amount = 1.0 - mathutil.smoothStep(0.58, 1.0, dist);
        return mathutil.lerpFloat(h, target, amount);
    }

    hide func createTerrainSplatMap(srcTerrain: Terrain3D, width: Integer, depth: Integer) -> Pixels {
        var splat = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var normal = Terrain3D.GetNormalAt(srcTerrain, wx, wz);
                var ny = Vec3.get_Y(normal);
                var h = Terrain3D.GetHeightAt(srcTerrain, wx, wz);
                var nx = wx / maxX;
                var nz = wz / maxZ;
                var lakeDist = lakeDistanceNormalized(nx, nz);
                var routeAmount = 1.0 - mathutil.smoothStep(
                    config.ROUTE_HALF_WIDTH * 0.75,
                    config.ROUTE_HALF_WIDTH * 2.4,
                    authoredRouteDistance(nx, nz));
                var grassLayer = 0;
                var rockLayer = 0;
                var dirtLayer = 0;
                var snowLayer = 0;

                var snowLine = config.WATER_HEIGHT + 20.0;
                var rockLine = config.WATER_HEIGHT + 12.0;
                var steep = ny < 0.80;

                if (h < config.WATER_HEIGHT + 0.9) {
                    dirtLayer = 255;                              // muddy shoreline
                } else if (routeAmount > 0.05) {
                    // A soft dirt/grass trail reads at a glance without looking
                    // like a painted road. Causeways use the same material.
                    dirtLayer = mathutil.clampByte(Convert.NumToInt(90.0 + routeAmount * 150.0));
                    grassLayer = 255 - dirtLayer;
                    if (lakeDist < 1.20) { dirtLayer = 220; grassLayer = 35; }
                } else {
                    if (h > snowLine && ny > 0.58) {
                        // Snow cap blended over rock: accumulates toward the summit
                        // and on flatter ledges, thins on steep faces, never on cliffs.
                        var snowAmt = mathutil.clampFloat((h - snowLine) / 9.0, 0.0, 1.0);
                        var slopeKeep = mathutil.clampFloat((ny - 0.58) / 0.34, 0.0, 1.0);
                        snowAmt = snowAmt * slopeKeep;
                        snowLayer = mathutil.clampByte(Convert.NumToInt(snowAmt * 255.0));
                        rockLayer = 255 - snowLayer;
                    } else {
                        if (h > rockLine || steep) {
                            rockLayer = 255;                      // rocky flanks + cliffs
                        } else {
                            if (ny > 0.90) {
                                grassLayer = 255;                 // lush valley flats
                            } else {
                                if (((px / 6) + (py / 5)) % 5 <= 1) {
                                    dirtLayer = 255;
                                } else {
                                    grassLayer = 255;
                                }
                            }
                        }
                    }
                }

                splat.Set(px, py, mathutil.packPixel(grassLayer, rockLayer, dirtLayer, snowLayer));
            }
        }

        return splat;
    }

    hide func createVegetationDensity(width: Integer, depth: Integer) -> Pixels {
        var density = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var ny = Vec3.get_Y(Terrain3D.GetNormalAt(land, wx, wz));
                var h = Terrain3D.GetHeightAt(land, wx, wz);
                var nx = wx / maxX;
                var nz = wz / maxZ;
                var v = 0;
                if (ny > 0.84 && h > config.WATER_HEIGHT + 0.6) {
                    v = mathutil.clampByte(Convert.NumToInt((ny - 0.84) / 0.16 * 255.0));
                }
                if (lakeDistanceNormalized(nx, nz) < 1.18
                        || authoredRouteDistance(nx, nz) < config.ROUTE_HALF_WIDTH * 1.8) {
                    v = 0;
                }
                density.Set(px, py, mathutil.packPixel(v, v, v, v));
            }
        }

        return density;
    }

    hide func createGrassBladeTexture() -> Pixels {
        var w = 16;
        var h = 32;
        var tex = Pixels.New(w, h);

        for (var py: Integer = 0; py < h; py = py + 1) {
            for (var px: Integer = 0; px < w; px = px + 1) {
                var halfW = 1 + py / 6;
                if (halfW < 1) { halfW = 1; }
                var dx = px - 8;
                if (dx < 0) { dx = 0 - dx; }
                if (dx <= halfW) {
                    var noise = ((px * 7 + py * 13) % 20) - 10;
                    var r = mathutil.clampByte(40 + noise / 2);
                    var g = mathutil.clampByte(118 + noise + (h - py) / 3);
                    var b = mathutil.clampByte(30 + noise / 3);
                    var alpha = 255;
                    if (py < 4) { alpha = mathutil.clampByte(110 + py * 36); }
                    tex.Set(px, py, mathutil.packPixel(r, g, b, alpha));
                } else {
                    tex.Set(px, py, mathutil.packPixel(0, 0, 0, 0));
                }
            }
        }

        return tex;
    }
}
