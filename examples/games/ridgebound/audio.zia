// audio.zia - Spatial audio setup and authored one-shot sounds.
module audio;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Audio;
bind "./config";
bind "./terrain";

class RidgeboundAudio {
    hide Sound3D audio;
    hide Sound chimeClip;
    hide Sound humClip;
    hide Sound stepGrassClip;
    hide Sound stepTrailClip;
    hide Sound stepStoneClip;
    hide Sound splashClip;
    hide Sound resonanceClip;
    hide Sound victoryClip;
    hide Float ambientTimer;
    hide Vec3 ambientSoundPos;
    hide Vec3 footfallPos;
    hide Vec3 beaconSoundPos;

    expose func setup(world: World3D) {
        audio = world.Audio;
        audio.ListenerFollowCamera(true);
        audio.SetAttenuation(config.AUDIO_REF_DIST, config.AUDIO_MAX_DIST);
        chimeClip = Synth.Sweep(520, 1040, 280, 45);
        humClip = Synth.Tone(146, 900, 12);
        stepGrassClip = Synth.Noise(64, 15);
        stepTrailClip = Synth.Noise(78, 20);
        stepStoneClip = Synth.Noise(48, 24);
        splashClip = Synth.Noise(150, 18);
        resonanceClip = Synth.Tone(260, 520, 20);
        victoryClip = Synth.Sweep(440, 1320, 620, 55);
        ambientSoundPos = new Vec3(0.0, 0.0, 0.0);
        footfallPos = new Vec3(0.0, 0.0, 0.0);
        beaconSoundPos = new Vec3(0.0, 0.0, 0.0);
        reset();
    }

    expose func reset() {
        if (audio != null) { audio.ClearSources(); }
        ambientTimer = 14.0;
    }

    expose func updateAmbient(dt: Float) {
        ambientTimer = ambientTimer - dt;
        if (ambientTimer <= 0.0 && audio != null) {
            ambientTimer = 19.0;
            ambientSoundPos.Set(
                terrain.terrainWorldMaxX() * 0.5,
                config.WATER_HEIGHT + 1.5,
                terrain.terrainWorldMaxZ() * 0.5);
            audio.PlayAt(humClip, ambientSoundPos);
        }
    }

    expose func playFootfall(x: Float, y: Float, z: Float, surface: Integer) {
        if (audio != null) {
            footfallPos.Set(x, y, z);
            var clip = stepGrassClip;
            if (surface == 1) { clip = stepTrailClip; }
            if (surface == 2) { clip = stepStoneClip; }
            audio.PlayAt(clip, footfallPos);
        }
    }

    expose func playSplash(x: Float, y: Float, z: Float) {
        if (audio != null) {
            footfallPos.Set(x, y, z);
            audio.PlayAt(splashClip, footfallPos);
        }
    }

    expose func playBeacon(x: Float, y: Float, z: Float) {
        if (audio != null) {
            beaconSoundPos.Set(x, y + 2.0, z);
            audio.PlayAt(chimeClip, beaconSoundPos);
            audio.PlayAt(resonanceClip, beaconSoundPos);
        }
    }

    expose func playVictory() {
        if (audio != null) {
            audio.Play2D(victoryClip);
            audio.Play2D(resonanceClip);
        }
    }
}
