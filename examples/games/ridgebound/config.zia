// config.zia - Tunables for Ridgebound, the Game3D open-world sample.
module config;

var WINDOW_TITLE: String = "Ridgebound: The Five Beacons";
var WINDOW_WIDTH: Integer = 1280;
var WINDOW_HEIGHT: Integer = 720;

var CLEAR_R: Float = 0.50;
var CLEAR_G: Float = 0.66;
var CLEAR_B: Float = 0.88;

var DT_MAX_MS: Integer = 50;
var DT_MAX_SEC: Float = 0.05;

var CAMERA_FOV: Float = 66.0;
var CAMERA_NEAR: Float = 0.1;
var CAMERA_FAR: Float = 420.0;
var CAMERA_DISTANCE: Float = 10.4;
var CAMERA_DISTANCE_MIN: Float = 5.8;
var CAMERA_DISTANCE_MAX: Float = 18.0;
var CAMERA_TARGET_HEIGHT: Float = 1.35;
var CAMERA_LOOK_AHEAD: Float = 3.6;
var CAMERA_MIN_CLEARANCE: Float = 1.3;
var CAMERA_COLLISION_RADIUS: Float = 0.42;
var CAMERA_POSITION_DAMP: Float = 10.0;
var CAMERA_TARGET_DAMP: Float = 14.0;
var CAMERA_PITCH_START: Float = 0.24;
// Orbit pitch clamp. Widened from the old -0.30..0.82 (~64 deg total) to a much
// larger arc so the third-person camera can swing from near-overhead down to a
// strong upward tilt. Kept clear of +-pi/2 to avoid LookAt up-vector degeneracy.
var CAMERA_PITCH_MIN: Float = -0.72;   // ~-41 deg (eye drops low/behind, view tilts up)
var CAMERA_PITCH_MAX: Float = 1.30;    // ~74 deg (near-overhead bird's-eye)
var CAMERA_MOUSE_SENS: Float = 0.010;  // degrees-per-pixel look sensitivity (was 0.0065)
var CAMERA_WHEEL_SPEED: Float = 1.0;
var CAMERA_INVERT_Y: Boolean = false;  // set true to invert vertical mouse look

// --- First-person / free-look mode (toggle with CAMERA_TOGGLE_KEY) -----------
// The orbit rig fundamentally can't look straight up (the eye orbits a pivot and
// the ground-clearance clamp forces it back up). First-person places the eye at
// the player's head and aims a free look vector, so you can look right at the sky.
var CAMERA_FP_EYE_HEIGHT: Float = 1.55; // eye height above the player's ground Y
var CAMERA_FP_PITCH_LIMIT: Float = 1.50; // ~+-86 deg free-look pitch clamp
// The view toggle is bound to the V key in game.zia via Viper.Input.Key.V.

var PLAYER_MOVE_SPEED: Float = 9.2;
var PLAYER_SPRINT_MULT: Float = 1.75;
var PLAYER_RADIUS: Float = 0.42;
var PLAYER_BODY_HEIGHT: Float = 1.05;
var PLAYER_GROUND_OFFSET: Float = 0.54;
var PLAYER_JUMP_SPEED: Float = 8.0;    // upward launch velocity (world units/sec)
var PLAYER_GRAVITY: Float = 22.0;      // downward accel while airborne (units/sec^2)
var PLAYER_CAPSULE_HEIGHT: Float = 1.8; // CharacterController3D capsule height
var PLAYER_MASS: Float = 70.0;          // CharacterController3D mass (kg)
var PLAYER_STEP_HEIGHT: Float = 0.48;    // curbs, roots, and heightfield cell transitions
var PLAYER_SLOPE_LIMIT: Float = 52.0;    // authored routes stay below this grade
var STAMINA_DRAIN_SEC: Float = 6.0;     // seconds of continuous sprint to fully drain
var STAMINA_REGEN_SEC: Float = 9.0;     // seconds walking to fully regenerate

// --- Environment collision (recommendation #10) -----------------------------
var TREE_COLLIDE_RADIUS: Float = 0.7;  // trunk collision radius pushed against the player

var TERRAIN_SIZE: Integer = 144;
var TERRAIN_SCALE_X: Float = 1.75;
var TERRAIN_SCALE_Y: Float = 36.0;
var TERRAIN_SCALE_Z: Float = 1.75;
var TERRAIN_NOISE_SCALE: Float = 3.9;
var TERRAIN_NOISE_OCTAVES: Integer = 6;
var TERRAIN_NOISE_PERSIST: Float = 0.48;
var TERRAIN_MARGIN: Float = 4.5;
var PLAYER_BOUNDS_MARGIN: Float = 34.0;
var TERRAIN_LOD_NEAR: Float = 110.0;
var TERRAIN_LOD_FAR: Float = 260.0;
var TERRAIN_SKIRT_DEPTH: Float = 6.0;

var SKYBOX_FACE_SIZE: Integer = 256;   // 256 (vs 64) removes visible sky banding
// Day/night v2: four keyframed skies. DAY/NIGHT keep the full face size; the
// transient DUSK/DAWN keyframes render at half size (the haze hides banding and
// they're only on screen briefly) to keep the extra load-time generation cheap.
var SKY_PHASE_DAY: Integer = 0;
var SKY_PHASE_DUSK: Integer = 1;
var SKY_PHASE_NIGHT: Integer = 2;
var SKY_PHASE_DAWN: Integer = 3;
var SKY_TWILIGHT_FACE_SIZE: Integer = 128;
// Sun-elevation thresholds that pick the active sky keyframe.
var SKY_DAY_ELEV: Float = 0.22;        // above this = full day
var SKY_NIGHT_ELEV: Float = 0.10;      // below -this = full night; between = dusk/dawn
// Terrain layer albedo resolution. 128 (vs 64) softens the visible tiling of the
// procedural grass/rock/dirt layers on close-up ground. Generated once at setup.
var TERRAIN_TEXTURE_SIZE: Integer = 128;
var SPLAT_SIZE: Integer = 128;

var MOUNTAIN_RING_FADE: Float = 0.31;
var MOUNTAIN_CREST_FADE: Float = 0.13;
// Organic mountain shaping (Phase 1). The range used to be a square edge-distance
// band, which read as a flat green wall. These break that up:
//  - WARP_AMP domain-warps the band-shape coords so iso-lines meander.
//  - EDGE_POW is the superellipse exponent for the border metric (higher = more
//    square; 4 rounds the corners so the range curves around the valley).
//  - MASSIF_* modulate peak amplitude so the skyline has tall massifs + low passes.
//  - FOOTHILL_* add a wide low skirt that smooth-maxes into the rolling interior.
var MOUNTAIN_WARP_AMP: Float = 0.12;
var MOUNTAIN_EDGE_POW: Float = 3.2;
var MOUNTAIN_MASSIF_BASE: Float = 0.32;
var MOUNTAIN_MASSIF_RANGE: Float = 0.68;
var MOUNTAIN_FOOTHILL_FADE: Float = 0.18;
var MOUNTAIN_FOOTHILL_HEIGHT: Float = 0.07;
var MOUNTAIN_BLEND_K: Float = 0.035;
// Guard-rim floor: lowered from a flat 0.58 and given stronger ridged/massif
// variance so the containment ring's base undulates instead of reading as a
// uniform wall foot. Still tall enough to enclose the world (player bounds sit
// well below even the saddles).
var MOUNTAIN_RIM_FLOOR: Float = 0.50;
var MOUNTAIN_RIM_MASSIF: Float = 0.20;
var LAKE_CENTER_X: Float = 0.50;
var LAKE_CENTER_Z: Float = 0.43;
var LAKE_RADIUS_X: Float = 0.26;
var LAKE_RADIUS_Z: Float = 0.19;
var LAKE_FLOOR_HEIGHT: Float = 2.15;
var LAKE_SHORE_INNER: Float = 0.84;
var LAKE_SHORE_OUTER: Float = 1.16;
var LAKE_CAUSEWAY_HALF_WIDTH: Float = 0.030;

var WATER_HEIGHT: Float = 5.4;
var WATER_R: Float = 0.05;
var WATER_G: Float = 0.40;
var WATER_B: Float = 0.60;
var WATER_A: Float = 0.72;
var WATER_REFLECTIVITY: Float = 0.58;
var WATER_TEXTURE_SIZE: Integer = 64;
var BEACON_TRIGGER_RADIUS: Float = 2.8;
// Authored beacon sites double as terrain pads and route endpoints. Keeping the
// coordinates in one module prevents visual ground, navigation, and objectives
// from drifting apart.
var BEACON_0_X: Float = 0.24;
var BEACON_0_Z: Float = 0.29;
var BEACON_1_X: Float = 0.76;
var BEACON_1_Z: Float = 0.28;
var BEACON_2_X: Float = 0.73;
var BEACON_2_Z: Float = 0.72;
var BEACON_3_X: Float = 0.28;
var BEACON_3_Z: Float = 0.73;
var BEACON_4_X: Float = 0.50;
var BEACON_4_Z: Float = 0.61;
var BEACON_SITE_RADIUS: Float = 0.038;
var ROUTE_HALF_WIDTH: Float = 0.018;
// Interact-to-scan (aim + hold E) beacon activation.
var INTERACT_RANGE: Float = 12.0;      // max distance to scan-activate a beacon
var INTERACT_SCAN_SEC: Float = 0.9;    // hold-E charge time to link a beacon

// Flat global ambient kept low so the directional sun + cool fill actually model
// the terrain (a high uniform ambient is what flattened the scene). See worldsim.
var AMBIENT_R: Float = 0.12;
var AMBIENT_G: Float = 0.13;
var AMBIENT_B: Float = 0.14;
// Fog day-target stays cool but below the sky horizon brightness so first-frame
// terrain keeps visible contrast after consistent environment/direct lighting.
var FOG_R: Float = 0.40;
var FOG_G: Float = 0.52;
var FOG_B: Float = 0.66;
var FOG_NEAR: Float = 280.0;
var FOG_FAR: Float = 520.0;
var SHADOW_BIAS: Float = 0.006;

var HUD_PANEL_X: Integer = 14;
var HUD_PANEL_Y: Integer = 14;
var HUD_PANEL_W: Integer = 404;
var HUD_PANEL_H: Integer = 112;

var HUD_PANEL: Integer = 0x101922;
var HUD_CARD: Integer = 0x26343B;
var HUD_ACCENT: Integer = 0x69C8BF;
var HUD_TEXT: Integer = 0xF2F0E7;
var HUD_MUTED: Integer = 0xAAB8B5;
var HUD_GOOD: Integer = 0x8DD6A0;
var HUD_WARN: Integer = 0xE6B765;
var HUD_DANGER: Integer = 0xE37A68;

// --- Forest (recommendation #1: imported FBX model) ------------------------
// MapleTree_1.fbx native AABB is ~623 x 664 x 490 model units, base at Y~=0,
// so a uniform scale near 0.013 yields an ~8.6 world-unit-tall tree.
// Two candidate paths so the model resolves whether the demo is run from the
// repo root (`viper run examples/games/ridgebound/`) or from this folder.
var TREE_MODEL_PATH: String = "MapleTree_1.fbx";
var TREE_MODEL_PATH_ALT: String = "examples/games/ridgebound/MapleTree_1.fbx";
// Relative to the executable's own directory (examples/bin -> examples/games/...),
// so a standalone binary resolves the model no matter the working directory.
var TREE_MODEL_PATH_FROM_BIN: String = "../games/ridgebound/MapleTree_1.fbx";
var FOREST_CELL: Float = 11.0;         // candidate-site grid spacing (world units)
var FOREST_MARGIN: Float = 10.0;       // keep trees away from the terrain edge
var FOREST_MAX: Integer = 72;          // clustered silhouettes without a collider maze
var FOREST_DENSITY: Float = 0.46;      // 0..1 probability a candidate cell plants
var FOREST_SCALE_MIN: Float = 0.011;   // ~7.3 world units tall
var FOREST_SCALE_MAX: Float = 0.016;   // ~10.6 world units tall
var FOREST_MIN_GROUND: Float = 6.2;    // remain above the actual 5.4 waterline
var FOREST_MIN_NORMALY: Float = 0.86;  // keep trunks upright on readable ground
var FOREST_BEACON_CLEAR: Float = 196.0; // squared 14m clearing around beacon sites
var FOREST_PLAYER_CLEAR: Float = 324.0; // squared 18m clearing around the spawn point

// Guaranteed grove ringing the spawn so trees are visible the moment the demo
// opens (relaxed rules — anywhere above the waterline).
var GROVE_COUNT: Integer = 10;
var GROVE_RADIUS_MIN: Float = 23.0;
var GROVE_RADIUS_MAX: Float = 42.0;
// Screen-size-driven auto-LOD for the FBX maples: distant trees simplify to a
// target screen error (in pixels), cutting triangle load in the open world.
var FOREST_LOD_ERROR_PX: Float = 3.0;

// --- Ground vegetation (recommendation #8: instanced grass + wind) ----------
var GRASS_BLADE_COUNT: Integer = 6000;
var GRASS_WIND_SPEED: Float = 0.85;
var GRASS_WIND_STRENGTH: Float = 0.11;
var GRASS_WIND_TURBULENCE: Float = 1.15;
var GRASS_LOD_NEAR: Float = 35.0;
var GRASS_LOD_FAR: Float = 95.0;
var GRASS_BLADE_W: Float = 0.34;
var GRASS_BLADE_H: Float = 0.86;
var GRASS_BLADE_VAR: Float = 0.35;
var FOLIAGE_WIND_DIR: Float = 0.6;
var REED_WIND_FREQ: Float = 0.25;

// --- PBR material textures (recommendation #2) ------------------------------
var PBR_TEXTURE_SIZE: Integer = 64;
var PBR_NORMAL_STRENGTH: Float = 0.65;

// --- 3D spatial audio (recommendation #4) -----------------------------------
var AUDIO_REF_DIST: Float = 6.0;       // full-volume radius
var AUDIO_MAX_DIST: Float = 95.0;      // silence beyond this
var STEP_DISTANCE: Float = 2.4;        // world units between footstep sounds

// --- Dynamic lights (recommendation #5) -------------------------------------
var BEACON_LIGHT_SLOT: Integer = 3;    // beacons occupy slots 3..7 (16 max)
var BEACON_LIGHT_RANGE: Float = 42.0;
var BEACON_LIGHT_INTENSITY: Float = 1.6;
var BEACON_FADE_SEC: Float = 0.6;      // glow-in time when a beacon is activated
var PLAYER_LIGHT_SLOT: Integer = 8;
var PLAYER_LIGHT_RANGE: Float = 27.0;
var PLAYER_LIGHT_INTENSITY: Float = 1.20;
var PLAYER_LIGHT_DAY_SCALE: Float = 0.32;

// --- Full day <-> night cycle (recommendation #9) ---------------------------
// Sun elevation follows a sine over one cycle: dawn -> noon -> dusk -> night ->
// dawn. It now crosses below the horizon, so the world actually gets dark and a
// cool moon light + starfield sky take over through the night half.
var DAY_LENGTH_SEC: Float = 900.0;     // fifteen-minute cycle; dusk starts well after a normal run
var DAY_START_PHASE: Float = 0.12;     // clear morning, with roughly six minutes before sunset
var MOON_INTENSITY: Float = 0.82;      // readable blue moonlight at deep night
// Keep the startup frame inside the smoke probe's exposure band. The runtime now
// applies first-frame environment/direct lighting consistently, so the old
// high-daylight values overexposed the snow-heavy foreground.
var SUN_INTENSITY_DAY: Float = 0.82;
var DAY_AMBIENT_R: Float = 0.10;
var DAY_AMBIENT_G: Float = 0.105;
var DAY_AMBIENT_B: Float = 0.115;
var NIGHT_AMBIENT_R: Float = 0.18;
var NIGHT_AMBIENT_G: Float = 0.22;
var NIGHT_AMBIENT_B: Float = 0.32;
// Day/night v2: the sun rides a real east->west arc (azimuth sweeps with the
// cycle) instead of a fixed heading, so shadows track across the valley.
var SUN_ARC_XZ: Float = 0.80;          // horizontal reach of the sun's arc
var SUN_ARC_Z: Float = 0.30;           // north/south tilt of the arc plane
var SUN_DIP_BASE: Float = 0.18;        // downward component near the horizon
var SUN_DIP_DAY: Float = 0.62;         // extra downward pull toward noon
var SUN_MIN_ELEV: Float = 0.03;        // cut sun light out just before it grazes the horizon
// Shadows soften as the sun lowers (long low-angle shadows read as grey, not ink).
var SHADOW_STRENGTH_NIGHT: Float = 0.30;
var SHADOW_STRENGTH_DAY: Float = 0.90;
// Image-based lighting intensity floor/ceiling across the cycle (GPU window backends).
var IBL_INTENSITY_NIGHT: Float = 0.38;
var IBL_INTENSITY_DAY: Float = 0.34;
// IBL supplies sky-driven ambient, so the flat ambient term is scaled back when
// IBL is active to avoid double-counting (which over-brightened the foreground).
var IBL_AMBIENT_SCALE: Float = 0.45;

// --- Particles + decals (recommendation #6) ---------------------------------
var DUST_COUNT: Integer = 36;
var SCORCH_LIFETIME: Float = 45.0;
var DECAL_MAX: Integer = 16;

// --- Dynamic weather (rain/snow over a slow cycle) --------------------------
var WEATHER_RAIN_COUNT: Integer = 560;   // rain particle pool
var WEATHER_SNOW_COUNT: Integer = 360;   // snow particle pool
var WEATHER_RAIN_RATE: Float = 430.0;    // drops/sec at full storm (low altitude)
var WEATHER_SNOW_RATE: Float = 120.0;    // flakes/sec at full storm (on the peaks)
var WEATHER_PERIOD_SEC: Float = 600.0;   // ten-minute clear->storm->clear front
var WEATHER_START_PHASE: Float = 0.72;   // begins deep in the calm part of the curve
var WEATHER_SNOW_ALTITUDE: Float = 16.0; // metres above the waterline that turn rain to snow
// Weather fronts v2: clouds build ahead of the rain and linger after; the ground
// darkens/wets during precip and dries over ~a minute. Cloud cover feeds the
// lighting (overcast dims + greys the scene); wetness drives the ground look.
var WEATHER_CLOUD_LEAD: Float = 0.16;    // clouds precede precip by this fraction of the cycle
var WEATHER_WET_RISE: Float = 0.45;      // wetness gained per second while raining
var WEATHER_WET_DECAY: Float = 0.017;    // wetness lost per second when dry (~60s to dry out)
var WEATHER_SUN_DIM: Float = 0.62;       // sun/fill reduction at full cloud cover
var WEATHER_FOG_GREY: Float = 0.55;      // how far fog shifts toward grey under full cloud
var WEATHER_SOFT_FADE: Float = 1.3;      // soft-particle fade distance (GPU only)
// Wet ground: the terrain darkens and turns glossier (lower roughness) as it soaks.
var TERRAIN_DRY_ROUGH: Float = 0.92;
var TERRAIN_WET_ROUGH: Float = 0.42;
var TERRAIN_WET_DARKEN: Float = 0.68;    // colour multiplier at full wetness (wet earth is darker)

// --- Raycast scanner + camera feel (recommendation #9) ----------------------
var SCAN_MAX_DIST: Float = 140.0;
var SHAKE_BEACON: Float = 0.22;
var SHAKE_ALL: Float = 0.55;

// --- Authored post-FX + quality + debug (recommendation #10) ----------------
// NOTE: AddColorGrade's first arg (brightness) is an ADDITIVE offset near 0.0,
// not a multiplier — values like 1.0 blow the frame out to pure white.
var POSTFX_BLOOM_THRESHOLD: Float = 0.86;
var POSTFX_BLOOM_INTENSITY: Float = 0.11;
var POSTFX_EXPOSURE: Float = 0.56;
var POSTFX_COLORGRADE_BRIGHT: Float = 0.0;
var POSTFX_COLORGRADE_CONTRAST: Float = 1.06;
var POSTFX_COLORGRADE_SAT: Float = 1.04;
var POSTFX_VIGNETTE_RADIUS: Float = 0.985;
var POSTFX_VIGNETTE_SOFT: Float = 0.36;

// Release probe budgets measure a warmed cinematic frame at 960x540. GPU
// backends should hold a comfortable 20 FPS floor; the deterministic software
// fallback gets a much wider ceiling because it rasterizes the full upgraded
// scene (terrain + instanced forest + water/sky + weather + effects + HUD) on the
// CPU. Measured software cost is ~2.6 s/frame here — a ~50x GPU ratio, which is
// normal for CPU 3D rasterization; the software path is an explicit fallback, not
// a real-time target (see vgfx3d_backend_sw_texture.inc). The ceiling below keeps
// enough headroom for machine/parallel-load variance while still catching a real
// >2x regression. The original 250 ms was aspirational and never achievable for
// this scene in software.
var PERF_BUDGET_GPU_MS: Float = 50.0;
var PERF_BUDGET_SOFTWARE_MS: Float = 5000.0;
var PERF_MAX_BRIGHT_SCENE_PERCENT: Float = 7.0;
var PERF_MIN_NIGHT_LUMA: Float = 14.0;

// Optional showcase systems stay out of the critical five-beacon route. Ambient
// wildlife remains enabled; survival meters and the physics toy pile are opt-in.
var ENABLE_AMBIENT_CRITTERS: Boolean = true;
var ENABLE_SURVIVAL_LAYER: Boolean = false;
var ENABLE_PHYSICS_TOYS: Boolean = false;

// Sprint FOV "kick" target (resting FOV is CAMERA_FOV).
var CAMERA_FOV_SPRINT: Float = 74.0;

// --- Wind-swayed reeds (recommendation #9, uses Canvas3D.DrawMeshWind) ---------
var REED_COUNT: Integer = 28;
var REED_RADIUS: Float = 0.032;
var REED_HEIGHT: Float = 1.35;
var REED_WIND_STRENGTH: Float = 0.16;

// --- Render-to-image minimap (recommendation #6, uses Canvas3D.DrawImage2D) -----
var MINIMAP_SIZE: Integer = 128;

// --- Rigid-body physics props (recommendation #2) ------------------------------
var PHYS_BALL_COUNT: Integer = 6;
// Player-driven boulder physics (walk-into push + F kick).
var PUSH_RANGE: Float = 1.5;     // radius within which walking shoves a boulder
var PUSH_FORCE: Float = 34.0;    // continuous shove force (scaled by dt)
var KICK_RANGE: Float = 3.6;     // radius a kick launches boulders
var KICK_FORCE: Float = 7.5;     // outward kick impulse
var KICK_UP: Float = 4.2;        // upward kick impulse

// --- Wandering sentinels (recommendation #4) -----------------------------------
var CRITTER_SPEED: Float = 2.4;
var CRITTER_FLEE_RADIUS: Float = 7.0;  // player distance that makes a critter bolt
var CRITTER_FLEE_MULT: Float = 2.4;    // flee-speed multiple of the wander speed

// --- Nav-mesh pathfinding (critters path around trees/landmarks) -------------
var NAV_AGENT_RADIUS: Float = 0.5;     // bake clearance radius
var NAV_AGENT_HEIGHT: Float = 1.8;     // bake agent height
var NAV_MAX_SLOPE: Float = 52.0;       // max walkable slope (degrees)
var NAV_CELL_SIZE: Float = 1.4;        // bake voxel cell size (world units)
var CRITTER_FLEE_DIST: Float = 16.0;   // how far a fleeing critter paths away
// Curiosity: when the player is in this band and calm (not sprinting), a critter
// edges closer instead of fleeing, settling at CRITTER_CURIOUS_KEEP distance.
var CRITTER_CURIOUS_RADIUS: Float = 20.0;
var CRITTER_CURIOUS_KEEP: Float = 9.0;
var CRITTER_SPOT_RADIUS: Float = 14.0; // getting this close logs the critter as "spotted"

// --- Survival: warmth, campfires, forage (recommendation, day/night driven) --
var CAMPFIRE_LIGHT_SLOT: Integer = 10;  // campfires occupy slots 10..12
var CAMPFIRE_WARM_RADIUS: Float = 12.0; // within this of a fire, warmth recovers
var CAMPFIRE_LIGHT_RANGE: Float = 16.0;
var CAMPFIRE_LIGHT_INTENSITY: Float = 1.8;
var WARMTH_NIGHT_DRAIN: Float = 0.045;  // warmth/sec lost at night away from fire
var WARMTH_CLOUD_DRAIN: Float = 0.020;  // extra warmth/sec lost under full overcast
var WARMTH_FIRE_GAIN: Float = 0.30;     // warmth/sec regained right next to a fire
var WARMTH_MIN_REGEN: Float = 0.35;     // stamina-regen multiplier when frozen (warmth 0)
var FORAGE_COUNT: Integer = 7;          // collectible restoratives scattered on the map
var FORAGE_PICKUP_RADIUS: Float = 2.4;
var FORAGE_WARMTH: Float = 0.28;        // warmth restored per forage picked up
var EMBER_COUNT: Integer = 60;          // ember particles at the nearest active fire
