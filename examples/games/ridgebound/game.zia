// game.zia - Ridgebound orchestrator.
module game;

bind Zanna.Game3D;
bind Zanna.Graphics3D;
bind Zanna.Input.Key as Key;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./terrain";
bind "./assets";
bind "./water_sky";
bind "./forest";
bind "./critters";
bind "./audio";
bind "./postfx";
bind "./weather";
bind "./minimap";
bind "./hud";
bind "./worldsim";
bind "./playerctl";
bind "./camctl";
bind "./menu3d";
bind "./survival";

var STATE_TITLE: Integer = 0;
var STATE_PLAYING: Integer = 1;
var STATE_PAUSED: Integer = 2;
var STATE_OPTIONS: Integer = 3;
var STATE_CONTROLS: Integer = 4;

class RidgeboundGame {
    hide World3D world;
    hide Canvas3D canvas;
    hide Camera3D camera;
    hide Input3D input;
    hide Terrain3D land;
    hide RidgeboundTerrain terrainSys;
    hide RidgeboundAssets assets;
    hide RidgeboundWaterSky waterSky;
    hide RidgeboundForest forestSys;
    hide RidgeboundCritters crittersSys;
    hide RidgeboundAudio audioSys;
    hide RidgeboundEffects effectsSys;
    hide RidgeboundWeather weatherSys;
    hide RidgeboundSurvival survivalSys;
    hide RidgeboundMinimap minimapSys;
    hide RidgeboundHud hudSys;
    hide RidgeboundWorldSim sim;
    hide RidgeboundPlayer player;
    hide RidgeboundCamera camCtl;
    hide RidgeboundMenu3D menuSys;

    hide Float worldTime;
    hide Float presentationTime;
    hide Integer qualityLevel;
    hide Integer screenState;
    hide Integer previousMenuState;
    hide Boolean debugOn;
    hide Boolean helpOn;
    hide Boolean fullscreenOn;
    hide Boolean quitRequested;
    hide Integer skyPhaseCurrent;
    hide Boolean mouseCaptured;

    expose func setup(title: String, width: Integer, height: Integer) {
        world = World3D.WithHorizontalCamera(
            title, width, height, config.CAMERA_FOV, config.CAMERA_NEAR, config.CAMERA_FAR);
        canvas = world.Canvas;
        camera = world.Camera;
        input = world.Input;
        input.LookSensitivity = config.CAMERA_MOUSE_SENS;
        Canvas3D.SetMaxDeltaTime(canvas, config.DT_MAX_MS);
        validateConfig();

        player = new RidgeboundPlayer();
        camCtl = new RidgeboundCamera();
        camCtl.setup(camera, world.Physics);
        menuSys = new RidgeboundMenu3D();
        menuSys.init();

        Quality.Apply(world, QualityLevel.get_Cinematic());
        Lighting.Outdoor(world, new Vec3(-0.36, -1.0, -0.22));
        sim = new RidgeboundWorldSim();
        sim.init();
        sim.installOutdoorFillLight(world);
        // Build the post-FX chain whenever the backend has CPU-safe post-FX (true on
        // software too), not only on GPU backends — otherwise software rendered raw
        // and unlit. Only then fall back to dimmed direct lighting if there is no
        // post-FX at all (so the tonemap/bloom can't compress the HDR range).
        var hasPostFx = Canvas3D.BackendSupports(canvas, "postfx");
        if (hasPostFx) {
            postfx.buildPostFX(canvas);
        }
        sim.setDirectLightingFallback(hasPostFx == false);
        Canvas3D.SetShadowBias(canvas, config.SHADOW_BIAS);
        // View-frustum + CPU occlusion culling: skip drawing the trees, landmarks,
        // and scene props that are off-screen or hidden behind terrain/monoliths.
        // A clear win for this open world (130+ trees + landmarks + props).
        Canvas3D.SetFrustumCulling(canvas, true);
        Canvas3D.SetOcclusionCulling(canvas, true);
        world.SetAmbient(config.AMBIENT_R, config.AMBIENT_G, config.AMBIENT_B);
        world.SetFog(config.FOG_R, config.FOG_G, config.FOG_B, config.FOG_NEAR, config.FOG_FAR);

        assets = new RidgeboundAssets();
        assets.setup();
        terrainSys = new RidgeboundTerrain();
        land = terrainSys.build(assets.getTerrainMat());
        // Physics collision for the terrain so the CharacterController3D walks it.
        // The heightfield is centered on its entity; place it at the terrain's
        // center (the visual terrain's corner sits at the world origin).
        world.SpawnHeightfieldCollider(
            terrainSys.getHeightmap(),
            config.TERRAIN_SCALE_X, config.TERRAIN_SCALE_Y, config.TERRAIN_SCALE_Z,
            terrain.terrainWorldMaxX() * 0.5, 0.0, terrain.terrainWorldMaxZ() * 0.5);
        waterSky = new RidgeboundWaterSky();
        waterSky.setup(land);
        world.SetSkybox(waterSky.getSkybox());
        skyPhaseCurrent = -1;
        assets.applyEnvReflections(waterSky.getSkybox());

        minimapSys = new RidgeboundMinimap();
        minimapSys.build(land);
        resetWorld();
        sim.spawnLandmarks(world, land, assets.getStoneMat(), assets.getArchiveMat(), assets.getWaterMarkerMat());
        forestSys = new RidgeboundForest();
        forestSys.spawn(world, land, sim.getBeaconXs(), sim.getBeaconZs());
        terrainSys.buildVegetation();
        sim.setupSun(world, canvas);
        audioSys = new RidgeboundAudio();
        audioSys.setup(world);
        sim.setupBeaconLights(world);
        sim.setupPlayerLight(world, player.getX(), player.getY(), player.getZ());
        effectsSys = new RidgeboundEffects();
        effectsSys.setup();
        weatherSys = new RidgeboundWeather();
        weatherSys.setup(Canvas3D.BackendSupports(canvas, "soft-particles"));
        if (config.ENABLE_PHYSICS_TOYS) {
            sim.setupPhysicsProps(world, land, assets.getPedestalMat(), assets.getBeaconOnMat());
        }
        crittersSys = new RidgeboundCritters();
        // Bake a nav-mesh from the spawned world (terrain + tree/landmark
        // colliders) so critters path around obstacles instead of walking
        // straight lines through them.
        if (config.ENABLE_AMBIENT_CRITTERS) {
            var navMesh = world.BakeNavMesh(
                config.NAV_AGENT_RADIUS, config.NAV_AGENT_HEIGHT,
                config.NAV_MAX_SLOPE, config.NAV_CELL_SIZE);
            crittersSys.setup(navMesh, land);
        }
        survivalSys = new RidgeboundSurvival();
        if (config.ENABLE_SURVIVAL_LAYER) {
            survivalSys.setup(world, land);
        } else {
            survivalSys.setupDisabled();
        }
        sim.setupObjective(land);
        hudSys = new RidgeboundHud();
        screenState = STATE_TITLE;
        previousMenuState = STATE_TITLE;
        menuSys.openTitle();
        applyMenuSettings();
        camCtl.titleView(worldTime, land);
        Terminal.Say("Backend: " + canvas.Backend);
    }

    expose func getWorld() -> World3D { return world; }
    expose func getCanvas() -> Canvas3D { return canvas; }
    expose func getForest() -> RidgeboundForest { return forestSys; }
    expose func isPlaying() -> Boolean { return screenState == STATE_PLAYING; }
    expose func isTitle() -> Boolean { return screenState == STATE_TITLE; }
    expose func isPaused() -> Boolean { return screenState == STATE_PAUSED; }
    expose func isOptions() -> Boolean { return screenState == STATE_OPTIONS; }
    expose func isControls() -> Boolean { return screenState == STATE_CONTROLS; }
    expose func debugPlayerX() -> Float { return player.getX(); }
    expose func debugPlayerY() -> Float { return player.getY(); }
    expose func debugPlayerZ() -> Float { return player.getZ(); }
    expose func debugGroundY() -> Float { return terrain.sampleGround(land, player.getX(), player.getZ()); }
    expose func debugCameraY() -> Float { return camCtl.getEyeY(); }
    expose func debugPlayerGrounded() -> Boolean { return player.isGrounded(); }
    expose func debugPlayerSwimming() -> Boolean { return player.isSwimming(); }
    expose func debugWorldTime() -> Float { return worldTime; }
    expose func debugWeatherIntensity() -> Float { return weatherSys.getIntensity(); }

    // Probe-only controls keep long-running validation deterministic while all
    // production movement still goes through Input3D and CharacterController3D.
    expose func debugRespawnForProbe() {
        player.respawn(land);
        camCtl.reset();
        camCtl.follow(player.getX(), player.getY(), player.getZ(), land, 0.016);
    }

    expose func debugSetTravelDirectionForProbe(dx: Float, dz: Float) {
        camCtl.setTravelDirectionForProbe(dx, dz);
        camCtl.follow(player.getX(), player.getY(), player.getZ(), land, 0.016);
    }

    expose func debugSetWorldTimeForProbe(value: Float) {
        worldTime = value;
        if (worldTime < 0.0) { worldTime = 0.0; }
        sim.updateTimeOfDay(world, worldTime, weatherSys.getCloudCover());
        updateSkybox();
    }

    expose func debugSetQualityForProbe(level: Integer) {
        qualityLevel = level;
        if (qualityLevel < 0) { qualityLevel = 0; }
        if (qualityLevel > 2) { qualityLevel = 2; }
        menuSys.setQualityPreset(qualityLevel);
        applyQualityPreset();
    }

    expose func debugRestartForProbe() {
        restartGameplay();
    }

    expose func startGameplayForSmoke() {
        startGameplay();
    }

    expose func step(dt: Float) {
        var stepDt = dt;
        if (stepDt <= 0.0) { stepDt = 0.016; }
        if (stepDt > config.DT_MAX_SEC) { stepDt = config.DT_MAX_SEC; }
        if (screenState != STATE_PLAYING) {
            stepMenu(stepDt);
            return;
        }

        // Gameplay simulation owns this clock. Menus and pause never consume
        // daylight, weather, warmth, or objective time.
        worldTime = worldTime + stepDt;

        if (input.Pressed(Key.Escape)) { pauseGameplay(); return; }
        handleToggles();
        camCtl.updateLook(input);
        camCtl.updateFov(input);
        // Orient the camera first: CharacterController3D.update moves relative to
        // the camera basis, so the camera must reflect this frame's look before
        // the character moves. Re-follow afterwards to track the moved character.
        camCtl.follow(player.getX(), player.getY(), player.getZ(), land, stepDt);
        player.update(stepDt, input, camera, audioSys, effectsSys);
        camCtl.follow(player.getX(), player.getY(), player.getZ(), land, stepDt);

        // Scanner first so the interact target (crosshair-on-beacon) is current
        // before updateBeacons reads it for the hold-E scan-to-activate.
        sim.updateScanner(canvas, camera);
        sim.updateBeacons(stepDt, world, camera, input, player.getX(), player.getY(), player.getZ(), audioSys, effectsSys);
        if (config.ENABLE_PHYSICS_TOYS) {
            sim.pushBoulders(stepDt, player.getX(), player.getZ(), input.Pressed(Key.F));
        }
        sim.updateDynamicLights(player.getX(), player.getY(), player.getZ());
        sim.updateTimeOfDay(world, worldTime, weatherSys.getCloudCover());
        updateSkybox();
        waterSky.update(stepDt);
        terrainSys.updateVegetation(stepDt, camera);
        effectsSys.update(stepDt);
        weatherSys.update(stepDt, camera, player.getY());
        assets.applyTerrainWetness(weatherSys.getWetness());
        if (config.ENABLE_AMBIENT_CRITTERS) {
            crittersSys.update(stepDt, player.getX(), player.getZ(), player.isSprinting() == false);
        }
        if (config.ENABLE_SURVIVAL_LAYER) {
            survivalSys.update(stepDt, player.getX(), player.getZ(),
                sim.isNight(), weatherSys.getCloudCover());
            player.setRegenScale(survivalSys.getRegenScale());
        } else {
            player.setRegenScale(1.0);
        }
        audioSys.updateAmbient(stepDt);
        sim.updateObjective(camera, player.getX(), player.getY(), player.getZ(), audioSys);
        world.StepSimulation(stepDt);
    }

    expose func renderFrame() {
        world.BeginFrame();
        Canvas3D.DrawTerrain(canvas, land);
        terrainSys.drawVegetation(canvas);
        waterSky.drawWater(canvas, camera);
        world.DrawScene();
        forestSys.drawInstanced(canvas);
        sim.drawBeacons(canvas, assets.getCubeMesh(), assets.getBeaconMesh(), assets.getPedestalMat(),
            assets.getBeaconOffMat(), assets.getBeaconOnMat(), worldTime);
        if (screenState != STATE_TITLE && screenState != STATE_OPTIONS && screenState != STATE_CONTROLS) {
            drawPlayer();
        }
        if (config.ENABLE_AMBIENT_CRITTERS) { crittersSys.draw(canvas, land); }
        if (config.ENABLE_SURVIVAL_LAYER) { survivalSys.draw(canvas, camera); }
        waterSky.drawReeds(canvas, worldTime);
        effectsSys.drawDecals(canvas);
        effectsSys.draw(canvas, camera);
        weatherSys.draw(canvas, camera);
        world.DrawEffects();
        world.EndScene();

        Canvas3D.BeginOverlay(canvas);
        if (screenState == STATE_PLAYING) {
            hudSys.draw(canvas, minimapSys, sim, player.getX(), player.getZ(),
                player.getStamina(), survivalSys.getWarmth(), helpOn, debugOn);
        } else if (screenState == STATE_PAUSED) {
            hudSys.draw(canvas, minimapSys, sim, player.getX(), player.getZ(),
                player.getStamina(), survivalSys.getWarmth(), helpOn, debugOn);
            menuSys.drawOverlay(canvas, fullscreenOn);
        } else {
            menuSys.drawOverlay(canvas, fullscreenOn);
        }
        Canvas3D.EndOverlay(canvas);
    }

    expose func run() {
        while (quitRequested == false && world.Update()) {
            if (screenState == STATE_PLAYING && mouseCaptured == false && input.MousePressed(MouseButtons.get_Left())) {
                input.CaptureMouse();
                mouseCaptured = true;
            }
            if (screenState != STATE_PLAYING && mouseCaptured) {
                input.ReleaseMouse();
                mouseCaptured = false;
            }
            step(world.DeltaTime);
            if (screenState != STATE_PLAYING && mouseCaptured) {
                input.ReleaseMouse();
                mouseCaptured = false;
            }
            renderFrame();
            world.Present();
        }
        if (mouseCaptured) {
            input.ReleaseMouse();
        }
    }

    expose func destroy() {
        if (mouseCaptured) {
            input.ReleaseMouse();
            mouseCaptured = false;
        }
        world.Destroy();
    }

    hide func resetWorld() {
        player.spawn(world, land);
        camCtl.reset();
        worldTime = 0.0;
        presentationTime = 0.0;
        quitRequested = false;
        qualityLevel = 2;
        screenState = STATE_TITLE;
        previousMenuState = STATE_TITLE;
        debugOn = false;
        helpOn = false;
        fullscreenOn = false;
        mouseCaptured = false;
        sim.reset(land);
    }

    // Cheap startup sanity check for the hand-tuned config: warns (does not
    // abort) on obviously-inverted ranges so a bad edit is caught immediately.
    hide func validateConfig() {
        if (config.CAMERA_PITCH_MIN >= config.CAMERA_PITCH_MAX) {
            Terminal.Say("config warning: CAMERA_PITCH_MIN must be < CAMERA_PITCH_MAX");
        }
        if (config.CAMERA_DISTANCE_MIN >= config.CAMERA_DISTANCE_MAX) {
            Terminal.Say("config warning: CAMERA_DISTANCE_MIN must be < CAMERA_DISTANCE_MAX");
        }
        if (config.STAMINA_DRAIN_SEC <= 0.0 || config.STAMINA_REGEN_SEC <= 0.0) {
            Terminal.Say("config warning: stamina drain/regen seconds must be > 0");
        }
        if (config.INTERACT_SCAN_SEC <= 0.0) {
            Terminal.Say("config warning: INTERACT_SCAN_SEC must be > 0");
        }
    }

    hide func handleToggles() {
        if (input.MousePressed(MouseButtons.get_Right())) {
            qualityLevel = qualityLevel + 1;
            if (qualityLevel > 2) { qualityLevel = 0; }
            menuSys.setQualityPreset(qualityLevel);
            applyQualityPreset();
        }
        if (input.Pressed(Key.LeftControl)) {
            if (debugOn) { debugOn = false; } else { debugOn = true; }
        }
        if (input.Pressed(Key.F11)) {
            Canvas3D.ToggleFullscreen(canvas);
            fullscreenOn = canvas.IsFullscreen;
        }
        if (input.Pressed(Key.V)) {
            camCtl.toggleMode();
        }
        if (input.Pressed(Key.H)) {
            if (helpOn) { helpOn = false; } else { helpOn = true; }
        }
    }

    hide func stepMenu(stepDt: Float) {
        var cmd = menuSys.update(stepDt, input);
        handleMenuCommand(cmd);

        if (screenState == STATE_TITLE || screenState == STATE_OPTIONS || screenState == STATE_CONTROLS) {
            presentationTime = presentationTime + stepDt;
            camCtl.titleView(presentationTime, land);
            // The title is a stable authored morning tableau, not a hidden live
            // simulation that can start the run at night or in a storm.
            sim.updateTimeOfDay(world, 0.0, 0.0);
            updateSkybox();
            waterSky.update(stepDt);
            terrainSys.updateVegetation(stepDt, camera);
            effectsSys.update(stepDt);
            audioSys.updateAmbient(stepDt);
        }
    }

    hide func handleMenuCommand(cmd: Integer) {
        if (cmd == menu3d.CMD_NONE) { return; }
        if (cmd == menu3d.CMD_START) {
            startGameplay();
        } else if (cmd == menu3d.CMD_RESUME) {
            resumeGameplay();
        } else if (cmd == menu3d.CMD_RESTART) {
            restartGameplay();
        } else if (cmd == menu3d.CMD_OPTIONS) {
            previousMenuState = screenState;
            screenState = STATE_OPTIONS;
            menuSys.openOptions();
        } else if (cmd == menu3d.CMD_CONTROLS) {
            previousMenuState = screenState;
            screenState = STATE_CONTROLS;
            menuSys.openControls();
        } else if (cmd == menu3d.CMD_BACK) {
            backFromSubmenu();
        } else if (cmd == menu3d.CMD_TITLE) {
            returnToTitle();
        } else if (cmd == menu3d.CMD_QUIT) {
            quitRequested = true;
        } else if (cmd == menu3d.CMD_SETTINGS_CHANGED) {
            applyMenuSettings();
        } else if (cmd == menu3d.CMD_TOGGLE_FULLSCREEN) {
            Canvas3D.ToggleFullscreen(canvas);
            fullscreenOn = canvas.IsFullscreen;
        }
    }

    hide func startGameplay() {
        restartGameplay();
    }

    hide func restartGameplay() {
        player.respawn(land);
        camCtl.reset();
        applyMenuSettings();
        sim.resetProgress();
        worldTime = 0.0;
        weatherSys.reset();
        survivalSys.reset();
        effectsSys.reset();
        audioSys.reset();
        assets.applyTerrainWetness(0.0);
        skyPhaseCurrent = -1;
        sim.updateTimeOfDay(world, worldTime, 0.0);
        updateSkybox();
        helpOn = false;
        screenState = STATE_PLAYING;
        camCtl.follow(player.getX(), player.getY(), player.getZ(), land, 0.016);
    }

    hide func pauseGameplay() {
        screenState = STATE_PAUSED;
        menuSys.openPause();
        if (mouseCaptured) {
            input.ReleaseMouse();
            mouseCaptured = false;
        }
    }

    hide func resumeGameplay() {
        applyMenuSettings();
        screenState = STATE_PLAYING;
    }

    hide func returnToTitle() {
        // Returning to the front end abandons the run and restores the same
        // authored clear-morning tableau used at initial startup. Otherwise a
        // late-game storm, wet ground, particles, or linked beacons could leak
        // into the title scene even though its clock is intentionally frozen.
        worldTime = 0.0;
        presentationTime = 0.0;
        player.respawn(land);
        camCtl.reset();
        sim.resetProgress();
        weatherSys.reset();
        survivalSys.reset();
        effectsSys.reset();
        audioSys.reset();
        assets.applyTerrainWetness(0.0);
        skyPhaseCurrent = -1;
        sim.updateTimeOfDay(world, 0.0, 0.0);
        updateSkybox();
        screenState = STATE_TITLE;
        previousMenuState = STATE_TITLE;
        helpOn = false;
        menuSys.openTitle();
        camCtl.titleView(presentationTime, land);
        if (mouseCaptured) {
            input.ReleaseMouse();
            mouseCaptured = false;
        }
    }

    hide func backFromSubmenu() {
        if (previousMenuState == STATE_PAUSED) {
            screenState = STATE_PAUSED;
            menuSys.openPause();
        } else {
            screenState = STATE_TITLE;
            previousMenuState = STATE_TITLE;
            menuSys.openTitle();
        }
        applyMenuSettings();
    }

    hide func applyMenuSettings() {
        var fovPreset = menuSys.getFovPreset();
        if (fovPreset == 0) {
            config.CAMERA_FOV = 62.0;
            config.CAMERA_FOV_SPRINT = 70.0;
        } else if (fovPreset == 2) {
            config.CAMERA_FOV = 70.0;
            config.CAMERA_FOV_SPRINT = 78.0;
        } else {
            config.CAMERA_FOV = 66.0;
            config.CAMERA_FOV_SPRINT = 74.0;
        }

        var sensPreset = menuSys.getSensitivityPreset();
        if (sensPreset == 0) {
            config.CAMERA_MOUSE_SENS = 0.0065;
        } else if (sensPreset == 2) {
            config.CAMERA_MOUSE_SENS = 0.014;
        } else {
            config.CAMERA_MOUSE_SENS = 0.010;
        }
        config.CAMERA_INVERT_Y = menuSys.getInvertY();
        input.LookSensitivity = config.CAMERA_MOUSE_SENS;

        qualityLevel = menuSys.getQualityPreset();
        applyQualityPreset();
        if (screenState == STATE_PLAYING) { camCtl.applyFovNow(); }
    }

    /// @brief Apply the current quality preset while preserving Ridgebound's authored post-FX.
    hide func applyQualityPreset() {
        Canvas3D.SetQuality(canvas, qualityLevel);
        postfx.buildPostFXForQuality(canvas, qualityLevel);
        terrainSys.applyQuality(qualityLevel);
        waterSky.applyQuality(qualityLevel);
        weatherSys.applyQuality(qualityLevel);
        sim.applyQuality(qualityLevel);
        Canvas3D.SetFrustumCulling(canvas, true);
        Canvas3D.SetOcclusionCulling(canvas, qualityLevel > 0);
    }

    // Swap between the day and starfield night skyboxes when the sun crosses the
    // horizon. Only fires on a state change, so it costs nothing per frame otherwise.
    hide func updateSkybox() {
        // Swap the keyframed sky (DAY / DUSK / NIGHT / DAWN) whenever the sun's
        // elevation crosses into a new phase. Adjacent keyframes differ far less
        // than the old binary day<->night jump, so the crossing reads as a fade
        // rather than a pop; the continuously-lerped fog/ambient carry the rest.
        var phase = sim.getSkyPhase();
        if (phase != skyPhaseCurrent) {
            skyPhaseCurrent = phase;
            world.SetSkybox(waterSky.getPhaseSkybox(phase));
            waterSky.setPhaseReflections(phase);
        }
    }

    hide func drawPlayer() {
        // In first-person the camera sits at the player's head, so drawing the
        // body/core would fill the view — skip it entirely.
        if (camCtl.isFirstPerson()) { return; }
        var px = player.getX();
        var py = player.getY();
        var pz = player.getZ();
        var yaw = player.getFacingYaw();
        var moveAmount = player.getMoveAmount();
        var stride = Sin(player.getGaitPhase()) * moveAmount;
        var bob = mathutil.absFloat(Sin(player.getGaitPhase())) * 0.035 * moveAmount;
        if (moveAmount < 0.02) { bob = Sin(worldTime * 1.5) * 0.006; }
        if (player.isSwimming()) { bob = Sin(worldTime * 2.8) * 0.035; stride = 0.0; }

        // A grounded contact shadow keeps the silhouette attached even on low
        // shadow presets.
        Canvas3D.DrawMesh(canvas, assets.getPlayerCoreMesh(),
            Mat4.Mul(Mat4.Translate(px, py + 0.025, pz), Mat4.Scale(2.7, 0.10, 1.9)),
            assets.getPlayerShadowMat());

        var torso = Mat4.Mul(
            Mat4.Translate(px, py + 1.02 + bob, pz), Mat4.RotateY(yaw));
        Canvas3D.DrawMesh(canvas, assets.getPlayerBodyMesh(), torso, assets.getPlayerMat());

        // Head + luminous signal lens establish a recognizable explorer rather
        // than the former capsule-and-ball debug pawn.
        Canvas3D.DrawMesh(canvas, assets.getPlayerCoreMesh(),
            Mat4.Mul(Mat4.Translate(px, py + 1.57 + bob, pz), Mat4.Scale(1.06, 1.10, 1.06)),
            assets.getPlayerTrimMat());
        var fwdX = Sin(yaw);
        var fwdZ = Cos(yaw);
        Canvas3D.DrawMesh(canvas, assets.getPlayerCoreMesh(),
            Mat4.Mul(
                Mat4.Translate(px + fwdX * 0.19, py + 1.56 + bob, pz + fwdZ * 0.19),
                Mat4.Scale(0.34, 0.34, 0.22)),
            assets.getWaterMarkerMat());

        // Backpack, arms, and alternating legs give the pawn readable facing
        // and a distance-driven walk cycle without requiring an external rig.
        Canvas3D.DrawMesh(canvas, assets.getPlayerPackMesh(),
            Mat4.Mul(
                Mat4.Translate(px - fwdX * 0.25, py + 1.02 + bob, pz - fwdZ * 0.25),
                Mat4.RotateY(yaw)),
            assets.getPlayerTrimMat());
        drawPlayerLimb(px, py + 0.39 + bob, pz, yaw, -0.16, stride * 0.13, assets.getPlayerMat());
        drawPlayerLimb(px, py + 0.39 + bob, pz, yaw, 0.16, 0.0 - stride * 0.13, assets.getPlayerMat());
        drawPlayerLimb(px, py + 1.04 + bob, pz, yaw, -0.38, 0.0 - stride * 0.10, assets.getPlayerTrimMat());
        drawPlayerLimb(px, py + 1.04 + bob, pz, yaw, 0.38, stride * 0.10, assets.getPlayerTrimMat());
    }

    hide func drawPlayerLimb(px: Float, py: Float, pz: Float, yaw: Float,
                             side: Float, forward: Float, mat: Material3D) {
        var wx = px + Cos(yaw) * side + Sin(yaw) * forward;
        var wz = pz - Sin(yaw) * side + Cos(yaw) * forward;
        Canvas3D.DrawMesh(canvas, assets.getPlayerLimbMesh(),
            Mat4.Translate(wx, py, wz), mat);
    }
}
