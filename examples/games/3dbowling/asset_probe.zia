// ============================================================================
// MODULE: asset_probe
// PURPOSE: Verify release-owned visual assets decode from project and package
//          working directories before the procedural fallback is needed.
// ============================================================================

module asset_probe;

bind Zanna.Graphics.Pixels as Pixels;
bind Zanna.Terminal;

func main() {
    var art = Pixels.Load("examples/games/3dbowling/assets/art/title-key-art.png");
    if (art == null || art.Width < 1280 || art.Height < 720) {
        Say("RESULT: fail title key art");
        return;
    }
    var sample = art.Get(art.Width / 3, art.Height / 2);
    if (sample == 0) {
        Say("RESULT: fail empty title key art");
        return;
    }
    var lane = Pixels.Load("examples/games/3dbowling/assets/textures/lane-maple.png");
    if (lane == null || lane.Width < 1024 || lane.Height < 1024) {
        Say("RESULT: fail lane texture");
        return;
    }
    var icon = Pixels.Load("examples/games/3dbowling/packaging/icon.png");
    if (icon == null || icon.Width != 512 || icon.Height != 512) {
        Say("RESULT: fail package icon");
        return;
    }
    Say("RESULT: ok");
}
