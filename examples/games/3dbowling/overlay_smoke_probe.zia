module overlay_smoke_probe;

bind Viper.Graphics3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./engine/renderer";
bind "./engine/camera";
bind "./lane/lane";
bind "./lane/pins";
bind "./lane/ball";

func drawFrame(render: Renderer, laneObj: LaneBuilder, pinMgr: PinManager, ballObj: Ball) {
    render.beginFrame();
    laneObj.draw(render.getCanvas());
    pinMgr.draw(render.getCanvas());
    ballObj.draw(render.getCanvas());
    render.endFrame();
}

func main() {
    var render = new Renderer();
    render.initRenderer(config.QUALITY_CINEMATIC);

    var camCtrl = new CameraController();
    camCtrl.initCamera(render.getCamera());
    camCtrl.setTitleMode();

    var world = Physics3DWorld.New(0.0, config.GRAVITY_Y, 0.0);

    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);

    var pinMgr = new PinManager();
    pinMgr.initPins(world);

    var ballObj = new Ball();
    ballObj.initBall(world);

    var env = render.getSkybox();
    laneObj.applyEnvironment(env);
    pinMgr.applyEnvironment(env);
    ballObj.applyEnvironment(env);

    render.poll();
    drawFrame(render, laneObj, pinMgr, ballObj);
    Canvas3D.DrawRect2D(render.getCanvas(), 0, 0, render.getWidth(), render.getHeight(), 0xFF00FF);
    render.flip();

    render.poll();
    drawFrame(render, laneObj, pinMgr, ballObj);
    Canvas3D.DrawRect2D(render.getCanvas(), 8, 8, 32, 32, 0xFFFFFF);

    var snap = render.getCanvas().Screenshot();
    var center = Pixels.Get(snap, render.getWidth() / 2, render.getHeight() / 2);
    if (center == 0xFF00FFFF) {
        Terminal.Say("RESULT: fail stale overlay");
        return;
    }

    render.flip();
    Terminal.Say("RESULT: ok");
}
