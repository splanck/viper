// =========================================================================
// Pin Layout
// =========================================================================
var PIN_COUNT: Integer = 10;
var PIN_SPACING: Float = 0.305;
var PIN_RADIUS: Float = 0.055;
var PIN_HEIGHT: Float = 0.38;
var PIN_CAPSULE_HEIGHT: Float = PIN_HEIGHT;
var PIN_BODY_RADIUS: Float = PIN_RADIUS * 1.08;
var PIN_BODY_CENTER_Y: Float = PIN_CAPSULE_HEIGHT / 2.0;
var PIN_DRAW_Y_OFFSET: Float = 0.0;
var PIN_MASS: Float = 2.35;
var PIN_RESTITUTION: Float = 0.08;
var PIN_FRICTION: Float = 0.82;
// Lower than the old 0.26/0.72: pins now tumble and slide into neighbors
// instead of resisting the topple, so a good pocket hit carries the rack.
// Angular damping is calibrated for the solver's world-space inertia and
// body-local CCD paths: pins tip about the correct axes while marginal rack
// cascades still leave realistic corner-pin outcomes.
var PIN_LINEAR_DAMPING: Float = 0.34;
var PIN_ANGULAR_DAMPING: Float = 0.76;
var PIN_Z_OFFSET: Float = 15.5;
var PIN_KNOCKDOWN_SPEED: Float = 0.62;
var PIN_KNOCKDOWN_DISPLACEMENT: Float = 0.062;
var PIN_KNOCKDOWN_SPEED_DISPLACEMENT: Float = 0.018;
var PIN_KNOCKDOWN_ANGULAR_SPEED: Float = 1.20;
var PIN_IMPACT_KNOCKDOWN_IMPULSE: Float = 0.36;
var PIN_IMPACT_KNOCKDOWN_SPEED: Float = 0.95;
var PIN_REST_SNAP_DISPLACEMENT: Float = 0.012;
var PIN_SETTLE_SNAP_SPEED: Float = 0.045;
var PIN_TILT_SPEED: Float = 5.8;
var PIN_TILT_MAX: Float = 1.57;
var PIN_DOWN_TILT_COS: Float = 0.72;
var PIN_DOWN_CENTER_Y: Float = 0.145;
var PIN_DOWN_DISPLACEMENT: Float = 0.105;
var PIN_DOWN_DWELL: Float = 0.10;
// Deterministic legal-rack variation is wide enough to preserve corner-pin
// outcomes under body-local CCD. Harder play retains the largest variation.
var RACK_JITTER_CASUAL: Float = 0.0020;
var RACK_JITTER_STANDARD: Float = 0.0055;
var RACK_JITTER_LEAGUE: Float = 0.0070;

var SWEEP_SPEED: Float = 3.0;
var SWEEP_Y_START: Float = 2.0;
var SWEEP_Y_END: Float = 0.1;
var SWEEP_DURATION: Float = 1.05;

var RESET_DURATION: Float = 1.0;
var RESET_DROP_HEIGHT: Float = 2.6;

// =========================================================================
// Ball
// =========================================================================
var BALL_RADIUS: Float = 0.109;
// Runtime sphere/capsule impulses need a gameplay scale below catalog kg so
// pin carry is earned by pocket geometry instead of every head-on collision.
var BALL_MASS_PHYSICS_SCALE: Float = 0.34;
var BALL_RESTITUTION: Float = 0.12;
var BALL_FRICTION: Float = 0.38;
var BALL_SHININESS: Float = 200.0;
var BALL_REFLECTIVITY: Float = 0.42;

var BALL_CATALOG_COUNT: Integer = 6;

// =========================================================================
// Throw Mechanics
// =========================================================================
var THROW_SPEED_MIN: Float = 2.35;
var THROW_POWER_RATE: Float = 0.34;
var THROW_POWER_MAX: Float = 1.0;
var RELEASE_ERROR_X: Float = 0.052;
var RELEASE_ASSIST_OFF: Float = 0.08;
var RELEASE_ASSIST_STANDARD: Float = 0.38;
var RELEASE_ASSIST_FULL: Float = 0.72;
var POWER_NEEDLE_RATE: Float = 0.78;
var ACCURACY_NEEDLE_RATE: Float = 7.35;
var ACCURACY_NEEDLE_PHASE: Float = 1.17;
var RELEASE_CONFIRM_TIMEOUT: Float = 1.10;
var RELEASE_ANGLE_ERROR_MAX: Float = 0.030;
var RELEASE_SPEED_ERROR_MAX: Float = 0.22;
var RELEASE_AXIS_ERROR_MAX: Float = 0.16;
var DIFFICULTY_ERROR_CASUAL: Float = 0.72;
var DIFFICULTY_ERROR_STANDARD: Float = 1.00;
var DIFFICULTY_ERROR_LEAGUE: Float = 1.22;
var STANCE_SPEED: Float = 0.42;
var STANCE_MAX: Float = 0.30;
var TARGET_SPEED: Float = 0.46;
var TARGET_MAX: Float = 0.42;
var SPIN_RATE: Float = 0.48;
var SPIN_MAX: Float = 0.32;
var SPIN_VISUAL_SPEED: Float = 7.0;
var BALL_AXIS_SPIN_SPEED: Float = 2.6;
// Hook forces are what curve the ball into the pocket. The dry backend
// (past oilEndZ) is where the ball "wakes up" and hooks hardest; the oiled
// front skids straight. These were ~25x too weak before (spin was a no-op).
var BACKEND_HOOK_FORCE: Float = 9.0;
var EARLY_HOOK_FORCE: Float = 2.5;
var SPIN_DECAY_OIL: Float = 0.07;
var SPIN_DECAY_DRY: Float = 0.38;
var SIDE_DRAG: Float = 0.40;
var LANE_ASSIST_EDGE_RATIO: Float = 0.34;
var LANE_ASSIST_FORCE: Float = 54.0;
var LANE_ASSIST_DAMP: Float = 4.8;
var LANE_SAFE_HALF_WIDTH: Float = 0.34;
var LANE_STABILIZE_END_Z: Float = PIN_Z_OFFSET - 0.18;
// Gutters are a real failure state: with BUMPERS_ENABLED=0 the ball obeys
// physics and rolls off the lane into the gutter troughs (built in lane.zia).
// BUMPERS_ENABLED=1 restores the old always-on arcade rail (edge assist +
// hard X clamp) so the ball cannot gutter — an optional easy/accessibility mode.
var GUTTER_ENABLED: Integer = 1;
var BUMPERS_ENABLED: Integer = 0;

var BALL_START_X: Float = 0.0;
var BALL_START_Y_OFFSET: Float = 0.026;
var BALL_START_Z: Float = -1.5;
var BALL_THROW_Z: Float = -0.85;
var BALL_TARGET_Z: Float = PIN_Z_OFFSET - 0.95;
// Runtime sphere-floor coupling amplifies lateral velocity during a roll. The
// shared solver and preview both apply this calibrated conversion factor.
var BALL_SIDE_SPEED_SCALE: Float = 0.18;
var BALL_SIDE_SPEED_MAX: Float = 0.62;
// Z just short of the head pin where we sample the ball's entry angle for
// the shot-feedback HUD readout (teaches pocket-angle cause/effect).
var ENTRY_CAPTURE_Z: Float = PIN_Z_OFFSET - 0.6;
// Predicted-curve aim guide: a read-only forward projection of the hook model
// (ball weight + spin + oil pattern), never touches physics. SCALE maps the
// accumulated hook-force shape to lateral world-X displacement.
var HOOK_GUIDE_SEGMENTS: Integer = 22;
var HOOK_GUIDE_SCALE: Float = 0.0135;
// Ball trail: fading ground streak behind a rolling ball (visual only).
var TRAIL_MAX: Integer = 40;
var TRAIL_MIN_SPEED: Float = 0.6;
var TRAIL_FADE: Float = 2.4;
var TRAIL_SAMPLE_SECONDS: Float = 0.024;
var BALL_ROLL_MIN_SPEED: Float = 2.40;
var BALL_DECK_IMPACT_SLOWDOWN: Float = 0.86;
var BALL_DECK_IMPACT_SIDE_DAMP: Float = 0.82;
var CARRY_POWER_FLOOR: Float = 0.44;
var CARRY_POWER_PEAK_END: Float = 0.90;

var GUTTER_Y: Float = -0.11;
var GUTTER_TRIGGER_WIDTH: Float = 0.04;
var GUTTER_EXIT_Z: Float = PIN_Z_OFFSET + 2.8;
var GUTTER_DETECT_Z: Float = 0.80;
var GUTTER_DETECT_END_Z: Float = PIN_Z_OFFSET - 2.80;
var GUTTER_DETECT_OVERHANG: Float = 0.28;

