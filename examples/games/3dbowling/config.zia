// Shadows + PostFX per quality tier (Plan 06/10 features). Cinematic pushes a
// 2048 cascaded shadow map with Poisson PCF, screen-space reflections on the
// glossy lane, and TAA (bowling's camera is slow, so TAA doesn't ghost);
// Performance drops to a 1024 map, cheaper PCF, and FXAA.
var SHADOW_MAP_CINEMATIC: Integer = 2048;
var SHADOW_MAP_PERFORMANCE: Integer = 1024;
var SHADOW_CASCADES: Integer = 3;
