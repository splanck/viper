//
// File: examples/games/3dbowling/oil_grid_probe.zia
// Purpose: Verifies bounded two-dimensional oil wear and carry-down behavior.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: oil_grid_probe
// PURPOSE: Standalone contract for bounded two-dimensional lane breakdown and
//          two-cell carry-down. This probe is intentionally outside CTest.
// ============================================================================

module oil_grid_probe;

bind Zanna.Graphics3D;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./lane/lane";

func main() {
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);

    if (laneObj.getOilGridCellCount() != config.OIL_GRID_X * config.OIL_GRID_Z) {
        Terminal.Say("RESULT: fail oil grid is not 13 by 24");
        return;
    }

    var trackX = 0.0;
    var trackZ = 5.0;
    var before = laneObj.getFrictionAt(trackX, trackZ);
    var sideBefore = laneObj.getFrictionAt(0.30, trackZ);
    for (var pass: Integer = 0; pass < 80; pass = pass + 1) {
        laneObj.recordBallTrack(trackX, trackZ, config.SPIN_MAX, 0.5);
    }
    var after = laneObj.getFrictionAt(trackX, trackZ);
    var sideAfter = laneObj.getFrictionAt(0.30, trackZ);

    if (after <= before || laneObj.getWearAt(trackX, trackZ) <= 0.0) {
        Terminal.Say("RESULT: fail repeated track did not break down its X/Z cell");
        return;
    }
    if (Abs(sideAfter - sideBefore) > 0.000001) {
        Terminal.Say("RESULT: fail oil wear leaked into a different X cell");
        return;
    }

    var cellLength = (config.LANE_LENGTH - config.OIL_START_Z) /
        (config.OIL_GRID_Z + 0.0);
    var carryOne = laneObj.getCarryAt(trackX, trackZ + cellLength);
    var carryTwo = laneObj.getCarryAt(trackX, trackZ + cellLength * 2.0);
    var carryThree = laneObj.getCarryAt(trackX, trackZ + cellLength * 3.0);
    if (carryOne <= 0.0 || carryTwo <= 0.0 || Abs(carryThree) > 0.000001) {
        Terminal.Say("RESULT: fail carry-down escaped its two-cell bound");
        return;
    }
    if (laneObj.getOilConcentration(trackX, trackZ + cellLength) <= 0.0) {
        Terminal.Say("RESULT: fail carried oil vanished from the visual oil map");
        return;
    }

    laneObj.resetOilGrid();
    if (Abs(laneObj.getWearAt(trackX, trackZ)) > 0.000001 ||
        Abs(laneObj.getCarryAt(trackX, trackZ + cellLength)) > 0.000001 ||
        laneObj.getOilWearPercent() != 0) {
        Terminal.Say("RESULT: fail oil reset retained match state");
        return;
    }

    Terminal.Say("RESULT: ok");
}
