//
// File: examples/games/3dbowling/feedback_probe.zia
// Purpose: Verifies measured audio and particle feedback layer selection.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: feedback_probe
// PURPOSE: Standalone outcome-scaled visual/audio feedback contract.
// ============================================================================

module feedback_probe;

bind Viper.Terminal as Terminal;
bind "./gameplay/feedback_model";

func main() {
    var model = new FeedbackModel();
    if (model.rollLayer(2.5) != "roll_soft" ||
        model.rollLayer(4.4) != "roll_medium" ||
        model.rollLayer(6.0) != "roll_hard") {
        Terminal.Say("RESULT: fail roll audio is not speed-layered");
        return;
    }
    if (model.impactLayer(0.22) != "pins_soft" ||
        model.impactLayer(0.75) != "pins_medium" ||
        model.impactLayer(1.8) != "pins_hard") {
        Terminal.Say("RESULT: fail pin audio is not impact-layered");
        return;
    }
    if (model.impactParticleCount(0.22) >= model.impactParticleCount(0.75) ||
        model.impactParticleCount(0.75) >= model.impactParticleCount(1.8)) {
        Terminal.Say("RESULT: fail crash debris does not scale with impact");
        return;
    }
    if (model.dustScale(0.18) >= model.dustScale(0.82)) {
        Terminal.Say("RESULT: fail low-power lane dust is not restrained");
        return;
    }
    Terminal.Say("RESULT: ok");
}
