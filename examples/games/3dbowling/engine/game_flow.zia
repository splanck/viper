//
// File: examples/games/3dbowling/engine/game_flow.zia
// Purpose: Runs input dispatch, fixed-step gameplay, watchdogs, and collision handling.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: engine/game_flow
// PURPOSE: Main loop, input dispatch, fixed-step physics, and impacts.
// ============================================================================

// game_flow.zia — Per-frame state machine and physics step policy.
module game_flow;

bind Viper.Graphics3D;
bind Viper.Input;
bind "../config";
bind "../menu";
bind "../util/mathutil";
bind "./camera";
bind "./game_setup";

/// @brief Per-frame flow and physics layer for the bowling controller.
class BowlingGameFlow extends BowlingGameSetup {
    /// @brief The main per-frame loop. Branches on screenState then
    ///        gameState; runs fixed-step physics; renders.
    override expose func gameLoop() {
        while (render.shouldClose() == false && quitRequested == false) {
            render.poll();
            if (render.shouldClose()) {
                break;
            }
            if (render.syncViewport()) {
                camCtrl.replaceCamera(render.getCamera());
            }
            var dt = render.getDeltaTime();

            if (screenState != config.SCREEN_PAUSED && lightFlashTimer > 0.0) {
                lightFlashTimer = lightFlashTimer - dt;
                if (lightFlashTimer <= 0.0) {
                    render.resetPinLight();
                }
            }

            if (screenState == config.SCREEN_TITLE) {
                camCtrl.updateTitle(dt);
                handleTitleInput(dt);
            } else if (screenState == config.SCREEN_OPTIONS) {
                camCtrl.updateTitle(dt);
                handleOptionsInput();
            } else if (screenState == config.SCREEN_PLAYING) {
                handlePlayingInput(dt);
            } else if (screenState == config.SCREEN_PAUSED) {
                handlePauseInput();
            } else if (screenState == config.SCREEN_RESULTS) {
                camCtrl.updateTitle(dt);
                handleResultsInput();
            }

            if (screenState != config.SCREEN_PAUSED) {
                particleMgr.update(dt);
                if (gameState == config.STATE_CELEBRATING) { celebMgr.update(dt); }
                hudObj.update(dt);
                bowlerAvatar.update(dt, aimX, charging);
            }
            updateAudioListener();

            render.beginFrame();
            drawScene();
            render.endFrame();
            drawOverlays();
            render.flip();
        }
    }

    /// @brief Title-screen menu dispatch.
    hide func handleTitleInput(dt: Float) {
        var cmd = menuObj.updateTitle(dt);
        if (menuObj.consumeUiEvent()) { playSound("ui"); }
        if (cmd == menu.CMD_START_MATCH) {
            startNewMatchMode(menuObj.getStartPlayerCount(), menuObj.getStartMode());
        } else if (cmd == menu.CMD_OPEN_OPTIONS) {
            optionsReturnScreen = config.SCREEN_TITLE;
            screenState = config.SCREEN_OPTIONS;
        } else if (cmd == menu.CMD_QUIT) {
            quitRequested = true;
        }
    }

    /// @brief Options-screen menu dispatch.
    hide func handleOptionsInput() {
        var cmd = menuObj.updateOptions();
        if (menuObj.consumeUiEvent()) { playSound("ui"); }
        applyMenuSettings();
        pinMgr.applyHighContrast(menuObj.getHighContrast());
        if (cmd == menu.CMD_BACK) {
            setupActions();
            if (optionsReturnScreen == config.SCREEN_PAUSED) {
                refreshMusic(1);
                screenState = config.SCREEN_PAUSED;
            } else {
                refreshMusic(0);
                showTitleScreen();
            }
        }
    }

    /// @brief Pause-screen menu dispatch (resume / restart / main menu).
    hide func handlePauseInput() {
        var cmd = menuObj.updatePause();
        if (menuObj.consumeUiEvent()) { playSound("ui"); }
        if (cmd == menu.CMD_RESUME) {
            screenState = config.SCREEN_PLAYING;
        } else if (cmd == menu.CMD_RESTART) {
            restartCurrentMatch();
        } else if (cmd == menu.CMD_OPEN_OPTIONS) {
            optionsReturnScreen = config.SCREEN_PAUSED;
            screenState = config.SCREEN_OPTIONS;
        } else if (cmd == menu.CMD_MAIN_MENU) {
            showTitleScreen();
        }
    }

    /// @brief Results-screen menu dispatch (play again / main menu).
    hide func handleResultsInput() {
        var cmd = menuObj.updateResults();
        if (menuObj.consumeUiEvent()) { playSound("ui"); }
        if (cmd == menu.CMD_PLAY_AGAIN) {
            startNewMatchMode(playerCount, currentMode);
        } else if (cmd == menu.CMD_MAIN_MENU) {
            showTitleScreen();
        }
    }

    /// @brief In-game input handler (aim / spin / throw / camera / pause).
    hide func handlePlayingInput(dt: Float) {
        if (gameState == config.STATE_CELEBRATING && Action.Pressed(config.ACT_CONFIRM)) {
            pendingReplayDuration = 0.0;
            replayRecorder.stop();
            celebMgr.skip();
            scoreTimer = 0.0;
        }
        if (Action.Pressed(config.ACT_PAUSE) || Action.Pressed(config.ACT_BACK)) {
            throwResumeGate.block();
            screenState = config.SCREEN_PAUSED;
            return;
        }
        if (Action.Pressed(config.ACT_RESET)) {
            if (gameState == config.STATE_AIMING) {
                stanceX = 0.0;
                targetX = 0.0;
                aimX = 0.0;
                spin = 0.0;
                spareRelease = false;
                releaseMeter.cancel();
                releaseMeter.reset(getReleaseAssist());
                charging = false;
                power = 0.0;
                hudObj.showMessage("SETUP RESET", config.HUD_COLOR_CYAN,
                    config.MSG_DURATION_SHORT);
            } else {
                restartCurrentMatch();
            }
            return;
        }
        if (Action.Pressed(config.ACT_CAMERA)) {
            cycleCameraMode();
        }

        if (gameState == config.STATE_AIMING) {
            updateAiming(dt);
        } else if (gameState == config.STATE_ROLLING) {
            runFixedStep(dt, true);
        } else if (gameState == config.STATE_SETTLING) {
            runFixedStep(dt, false);
        } else if (gameState == config.STATE_SCORING) {
            updateScoring();
        } else if (gameState == config.STATE_SWEEPING) {
            updateSweeping(dt);
        } else if (gameState == config.STATE_RESETTING) {
            updateResetting(dt);
        } else if (gameState == config.STATE_CELEBRATING) {
            updateCelebrating(dt);
        }
    }

    /// @brief Run runtime-owned fixed-step physics and matching game logic.
    hide func runFixedStep(dt: Float, rolling: Boolean) {
        var steps = PhysicsWorld3D.StepFixed(physWorld, dt, config.PHYSICS_DT, config.MAX_FIXED_STEPS);
        var i = 0;
        while (i < steps) {
            if (rolling && gameState == config.STATE_ROLLING) {
                updateRollingStep(config.PHYSICS_DT);
            } else if (rolling == false && gameState == config.STATE_SETTLING) {
                updateSettlingStep(config.PHYSICS_DT);
            } else {
                i = steps;
                continue;
            }
            i = i + 1;
        }

        fixedStepAlpha = PhysicsWorld3D.get_FixedStepAlpha(physWorld);
        if (steps > 0 || fixedStepAlpha > 0.0) {
            camCtrl.updateBallFollow(ballObj.getPosition(),
                config.PHYSICS_DT * ((steps + 0.0) + fixedStepAlpha));
        }
    }

    /// @brief STATE_AIMING update: aim/spin axis input + power charge + throw.
    hide func updateAiming(dt: Float) {
        if (isAiTurn()) {
            updateAiAiming(dt);
            return;
        }

        // A pause can hide a release edge from polling. Consume a neutral
        // frame first; an interrupted power charge restarts, while an already
        // locked accuracy stage remains exactly where it was paused.
        if (throwResumeGate.isBlocked()) {
            throwResumeGate.allowsCharge(Action.Held(config.ACT_THROW));
            if (throwResumeGate.isBlocked() == false && charging &&
                releaseMeter.isAwaitingAccuracy() == false) {
                releaseMeter.cancel();
                releaseMeter.reset(getReleaseAssist());
                charging = false;
                power = 0.0;
            }
            ballObj.setSetupPosition(stanceX);
            camCtrl.updateAim(stanceX, dt);
            return;
        }

        stanceX = stanceX + Action.Axis(config.ACT_STANCE_X) * config.STANCE_SPEED * dt;
        if (stanceX < -config.STANCE_MAX) { stanceX = -config.STANCE_MAX; }
        if (stanceX > config.STANCE_MAX) { stanceX = config.STANCE_MAX; }
        targetX = targetX + Action.Axis(config.ACT_TARGET_X) * config.TARGET_SPEED * dt;
        if (targetX < -config.TARGET_MAX) { targetX = -config.TARGET_MAX; }
        if (targetX > config.TARGET_MAX) { targetX = config.TARGET_MAX; }
        aimX = stanceX;

        spin = spin + Action.Axis(config.ACT_SPIN_X) * config.SPIN_RATE * dt;
        if (spin < -config.SPIN_MAX) { spin = -config.SPIN_MAX; }
        if (spin > config.SPIN_MAX) { spin = config.SPIN_MAX; }
        if (Action.Pressed(config.ACT_SPARE_RELEASE)) {
            spareRelease = !spareRelease;
            if (spareRelease) {
                hudObj.showMessage("SPARE RELEASE", config.HUD_COLOR_AMBER,
                    config.MSG_DURATION_SHORT);
            } else {
                hudObj.showMessage("HOOK RELEASE", config.HUD_COLOR_CYAN,
                    config.MSG_DURATION_SHORT);
            }
        }
        updateTutorialCoach();

        if (Action.Pressed(config.ACT_BALL_PREV)) {
            ballObj.cycleBall(-1);
            playerProfiles.get(activePlayer).setSelectedBall(ballObj.getBallType());
            menuObj.setSelectedBall(ballObj.getBallType());
            playSound("ui");
        }
        if (Action.Pressed(config.ACT_BALL_NEXT)) {
            ballObj.cycleBall(1);
            playerProfiles.get(activePlayer).setSelectedBall(ballObj.getBallType());
            menuObj.setSelectedBall(ballObj.getBallType());
            playSound("ui");
        }

        if (releaseMeter.isAwaitingAccuracy()) {
            releaseMeter.update(dt);
            if (Action.Pressed(config.ACT_THROW) || releaseMeter.confirmTimedOut()) {
                var needle = releaseMeter.getNeedle();
                lastReleaseOffset = (needle - 0.5) * 2.0;
                lastReleaseAccuracy = releaseMeter.release();
                launchBall(stanceX, targetX, power, lastReleaseOffset);
            }
        } else if (Action.Held(config.ACT_THROW)) {
            if (charging == false) {
                charging = true;
                releaseMeter.beginCharge();
            }
            releaseMeter.update(dt);
            power = releaseMeter.getPower();
        } else if (charging) {
            charging = false;
            releaseMeter.lockPower();
            hudObj.showMessage("POWER LOCKED  TAP THROW FOR RELEASE",
                config.HUD_COLOR_GREEN, config.MSG_DURATION_SHORT);
        }

        ballObj.setSetupPosition(stanceX);
        camCtrl.updateAim(stanceX, dt);
    }

    hide func updateTutorialCoach() {
        if (tutorialStep == 0 && (Abs(stanceX) > 0.025 || Abs(targetX) > 0.025)) {
            tutorialStep = 1;
            hudObj.showMessage("GOOD  Add curve with Q / E or the bumpers.",
                config.HUD_COLOR_CYAN, config.MSG_DURATION_LONG);
        } else if (tutorialStep == 1 && Abs(spin) > 0.045) {
            tutorialStep = 2;
            hudObj.showMessage("NOW HOLD SPACE / A  Build power, then tap again for timing.",
                config.HUD_COLOR_AMBER, config.MSG_DURATION_LONG);
        } else if (tutorialStep == 2 && charging) {
            tutorialStep = 3;
            hudObj.showMessage("TAP again near the green center for an accurate release.",
                config.HUD_COLOR_GREEN, config.MSG_DURATION_LONG);
        }
    }

    /// @brief Championship rival uses the same ball physics and scoring path.
    hide func updateAiAiming(dt: Float) {
        aiThinkTimer = aiThinkTimer - dt;
        var current = scoreKeepers.get(activePlayer);
        var plan = aiDeliveryModel.solve(current.getFrame(),
            current.getRollInFrame(), careerTier, difficulty);
        stanceX = plan.stanceX;
        targetX = plan.targetX;
        aimX = stanceX;
        spin = plan.hook;
        ballObj.setSetupPosition(stanceX);
        camCtrl.updateAim(stanceX, dt);
        power = plan.power;
        if (aiThinkTimer <= 0.0) {
            lastReleaseOffset = plan.releaseOffset;
            launchBallWithAssist(stanceX, targetX, power,
                lastReleaseOffset, 0.0);
        }
    }

    hide func isAiTurn() -> Boolean {
        return currentMode == config.MODE_CHAMPIONSHIP && activePlayer == 1;
    }

    /// @brief Commit one human or AI release and initialize roll feedback.
    hide func launchBall(releaseStance: Float, releaseTarget: Float,
                         releasePower: Float, releaseOffset: Float) {
        launchBallWithAssist(releaseStance, releaseTarget, releasePower,
            releaseOffset, getReleaseAssist());
    }

    /// @brief Commit a delivery with explicit timing assistance.
    hide func launchBallWithAssist(releaseStance: Float, releaseTarget: Float,
                                   releasePower: Float, releaseOffset: Float,
                                   assist: Float) {
        ballObj.setSpin(spin);
        ballObj.doDelivery(releaseStance, releaseTarget, releasePower,
            releaseOffset, assist, difficulty, oilPattern, spareRelease);
        lastReleaseAccuracy = ballObj.getLastDeliveryAccuracy();
        lastShotSpeed = ballObj.getLastDeliverySpeed();
        bowlerAvatar.onRelease();
        if (tutorialStep >= 0) { tutorialStep = -1; }
        replayRecorder.beginCapture();
        pendingReplayDuration = 0.0;
        replayRecorder.captureScene(ballObj.getPosition(), pinMgr);
        particleMgr.startLaneDust(releaseStance, config.BALL_THROW_Z, releasePower);
        playSound("release");
        playSpatialSound(feedbackModel.rollLayer(lastShotSpeed),
            ballObj.getPosition(), 12.0, 72);
        gutterLatched = false;
        ballHitPinsThisRoll = false;
        watchdogResetShot = false;
        shotWatchdog.reset(config.BALL_THROW_Z);
        entryCaptured = false;
        hasLastEntry = false;
        impactCooldown = 0.0;
        skidMarkTimer = 0.0;
        fixedStepAlpha = 0.0;
        gameState = config.STATE_ROLLING;
        camCtrl.setRollMode();
    }

    /// @brief STATE_ROLLING per-step update: ball motion + dust + skids.
    hide func updateRollingStep(dt: Float) {
        impactCooldown = impactCooldown - dt;
        skidMarkTimer = skidMarkTimer - dt;

        var watchdogPos = ballObj.getPosition();
        if (shotWatchdog.update(dt, Vec3.get_X(watchdogPos),
            Vec3.get_Y(watchdogPos), Vec3.get_Z(watchdogPos))) {
            watchdogResetShot = true;
            ballObj.stopAtSafePosition(shotWatchdog.getSafeX(), shotWatchdog.getSafeZ());
            particleMgr.stopLaneDust();
            fixedStepAlpha = 0.0;
            settleTimer = 0.0;
            hudObj.showMessage("SHOT RESET: ball stalled", config.HUD_COLOR_AMBER,
                config.MSG_DURATION_LONG);
            gameState = config.STATE_SETTLING;
            return;
        }

        var friction = laneObj.getFrictionAt(ballObj.getPosX(), ballObj.getPosZ());
        ballObj.updateMotion(dt, friction, laneObj.getOilEndZ());
        laneObj.recordBallTrack(ballObj.getPosX(), ballObj.getPosZ(), Abs(ballObj.getSpin()), dt);
        replayRecorder.captureScene(ballObj.getPosition(), pinMgr);
        ballObj.stabilizeLaneRoll();
        ballObj.sampleTrail(dt);
        pinMgr.updateKnockdowns(dt);
        handlePinImpacts();
        updateTriggerZones();

        // Sample the ball's entry angle just before the head pin (once, and
        // only if it stayed on the lane) for the shot-feedback HUD readout.
        if (entryCaptured == false && ballObj.gutterBall() == false &&
            ballObj.getPosZ() >= config.ENTRY_CAPTURE_Z) {
            lastEntryAngle = ballObj.getTravelAngleDeg();
            lastShotSpeed = ballObj.getSpeed();
            entryCaptured = true;
            hasLastEntry = true;
        }

        if (friction > config.OIL_FRICTION_BLEND && Abs(ballObj.getSpin()) > 0.16 && skidMarkTimer <= 0.0) {
            particleMgr.spawnSkidMark(ballObj.getPosX(), ballObj.getPosZ());
            skidMarkTimer = 0.16;
        }

        particleMgr.updateLaneDust(ballObj.getPosX(), ballObj.getPosZ());

        if (ballObj.hasPastPins() ||
            (ballHitPinsThisRoll && ballObj.getPosZ() > config.PIN_Z_OFFSET - 1.2) ||
            ballObj.isSlow() ||
            ballObj.getPosZ() > config.GUTTER_EXIT_Z) {
            particleMgr.stopLaneDust();
            fixedStepAlpha = 0.0;
            settleTimer = config.SETTLE_TIME;
            gameState = config.STATE_SETTLING;
            camCtrl.setRollMode();
        }
    }

    /// @brief STATE_SETTLING per-step update: wait for pins/ball to come to rest.
    hide func updateSettlingStep(dt: Float) {
        impactCooldown = impactCooldown - dt;
        replayRecorder.captureScene(ballObj.getPosition(), pinMgr);
        pinMgr.updateKnockdowns(dt);
        handlePinImpacts();

        settleTimer = settleTimer - dt;
        if (pinMgr.allSettled() && settleTimer < config.SETTLE_TIME - 0.4) {
            settleTimer = 0.0;
        }

        if (settleTimer <= 0.0) {
            fixedStepAlpha = 0.0;
            gameState = config.STATE_SCORING;
        }
    }

    /// @brief Poll the gutter + pin-deck triggers; update ball state accordingly.
    hide func updateTriggerZones() {
        if (ballObj.thrown() == false) { return; }
        if (config.GUTTER_ENABLED == 0) { return; }
        if (ballHitPinsThisRoll) { return; }

        var pos = ballObj.getPosition();
        var px = Vec3.get_X(pos);
        var py = Vec3.get_Y(pos);
        var pz = Vec3.get_Z(pos);
        var laneHalf = config.LANE_WIDTH / 2.0;
        // Committed to the gutter once the ball's centre crosses the lane edge,
        // or once it has dropped off the lane surface into the trough near an
        // edge. Physics carries the ball there; we only latch after it commits.
        var edgeCommit = laneHalf + config.BALL_RADIUS * 0.15;
        var dropEdge = laneHalf - config.BALL_RADIUS * 0.35;
        var inLeftGutter = false;
        var inRightGutter = false;
        if (pz > config.GUTTER_DETECT_Z && pz < config.GUTTER_DETECT_END_Z) {
            if (px < -edgeCommit) { inLeftGutter = true; }
            if (px > edgeCommit) { inRightGutter = true; }
            if (py < config.BALL_RADIUS * 0.72) {
                if (px < -dropEdge) { inLeftGutter = true; }
                if (px > dropEdge) { inRightGutter = true; }
            }
        }
        var inGutter = inLeftGutter || inRightGutter;
        if (inGutter && gutterLatched == false) {
            gutterLatched = true;
            var gutterSide = 1;
            if (inLeftGutter || px < 0.0) {
                gutterSide = -1;
            }
            ballObj.markGutter(gutterSide);
            particleMgr.stopLaneDust();
            particleMgr.spawnGutterSplash(ballObj.getPosX(), ballObj.getPosZ());
            playSpatialSound("gutter", pos, 14.0, 90);
            hudObj.showMessage("Gutter ball", config.HUD_COLOR_GRAY, config.MSG_DURATION_SHORT);
        }

        if (Abs(px) < 1.25 && pz > config.PIN_Z_OFFSET - 0.8 && pz < config.PIN_Z_OFFSET + 1.8) {
            render.flashPinLight(1.8);
            lightFlashTimer = 0.15;
        }
    }

    /// @brief Spawn sparks + sounds + camera shake on each pin-pin / ball-pin impact.
    hide func handlePinImpacts() {
        var collisionCount = PhysicsWorld3D.get_CollisionEventCount(physWorld);
        var bestStrength = 0.0;
        var bestPos = new Vec3(0.0, 0.0, 0.0);
        var ballPinImpact = false;
        impactBatch.reset(ballHitPinsThisRoll);

        // Pass one makes pin-pin cascade eligibility independent of the
        // runtime's collision-event ordering for this fixed step.
        for (var ci: Integer = 0; ci < collisionCount; ci = ci + 1) {
            var evt = PhysicsWorld3D.GetCollisionEvent(physWorld, ci);
            var bodyA = CollisionEvent3D.get_BodyA(evt);
            var bodyB = CollisionEvent3D.get_BodyB(evt);
            var layerA = PhysicsBody3D.get_CollisionLayer(bodyA);
            var layerB = PhysicsBody3D.get_CollisionLayer(bodyB);
            impactBatch.scanPair(layerA, layerB,
                CollisionEvent3D.get_IsTrigger(evt));
        }
        impactBatch.finishScan();

        for (var ci: Integer = 0; ci < collisionCount; ci = ci + 1) {
            var evt = PhysicsWorld3D.GetCollisionEvent(physWorld, ci);
            if (CollisionEvent3D.get_IsTrigger(evt)) { continue; }
            var bodyA = CollisionEvent3D.get_BodyA(evt);
            var bodyB = CollisionEvent3D.get_BodyB(evt);
            var layerA = PhysicsBody3D.get_CollisionLayer(bodyA);
            var layerB = PhysicsBody3D.get_CollisionLayer(bodyB);
            var posA = PhysicsBody3D.get_Position(bodyA);
            var posB = PhysicsBody3D.get_Position(bodyB);
            var point = mathutil.vec3Mid(posA, posB);
            if (CollisionEvent3D.get_ContactCount(evt) > 0) {
                var cp = CollisionEvent3D.GetContactPoint(evt, 0);
                point = new Vec3(Vec3.get_X(cp), Vec3.get_Y(cp), Vec3.get_Z(cp));
            }
            var impulse = CollisionEvent3D.get_NormalImpulse(evt);
            var relativeSpeed = CollisionEvent3D.get_RelativeSpeed(evt);
            var strength = impulse + relativeSpeed * 0.18;
            var isBallPinPair = impactBatch.isBallPinPair(layerA, layerB);

            if (impactBatch.shouldRegisterPin(layerA, layerB)) {
                pinMgr.registerImpact(bodyA, point, impulse, relativeSpeed);
            }
            if (impactBatch.shouldRegisterPin(layerB, layerA)) {
                pinMgr.registerImpact(bodyB, point, impulse, relativeSpeed);
            }

            if (strength <= bestStrength) { continue; }

            if ((layerA == config.LAYER_BALL || layerA == config.LAYER_PINS) && isImpactBodyInPinDeck(posA)) {
                bestStrength = strength;
                bestPos = point;
                ballPinImpact = isBallPinPair;
            }
            if ((layerB == config.LAYER_BALL || layerB == config.LAYER_PINS) &&
                isImpactBodyInPinDeck(posB) && strength > bestStrength) {
                bestStrength = strength;
                bestPos = point;
                ballPinImpact = isBallPinPair;
            }
        }

        if (impactBatch.sawBallPinContact()) {
            ballHitPinsThisRoll = true;
        }

        if (impactCooldown > 0.0) { return; }

        if (bestStrength > 0.18) {
            impactCooldown = config.IMPACT_COOLDOWN;
            // Bumper mode keeps the softer "absorbed" deck feel; skill play
            // lets the ball drive through so the rack carries (real pin action).
            if (ballPinImpact && config.BUMPERS_ENABLED == 1) {
                ballObj.dampForPinDeckImpact(bestStrength * 0.006);
            }
            particleMgr.spawnCrashSparks(Vec3.get_X(bestPos), Vec3.get_Y(bestPos),
                Vec3.get_Z(bestPos), bestStrength);
            playSpatialSound(feedbackModel.impactLayer(bestStrength),
                bestPos, 16.0, 90);
            camCtrl.shake(config.SHAKE_PIN_INTENSITY *
                (menuObj.getCameraShake() + 0.0) / 100.0, config.SHAKE_PIN_DURATION);
            render.flashPinLight(1.25 + bestStrength * 0.35);
            lightFlashTimer = 0.08;
        }
    }

    /// @brief True if a position is inside the pin-deck Z range.
    hide func isImpactBodyInPinDeck(pos: Vec3) -> Boolean {
        var z = Vec3.get_Z(pos);
        return z > config.PIN_Z_OFFSET - 1.0 && z < config.PIN_Z_OFFSET + 3.0;
    }
}
