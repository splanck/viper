// ============================================================================
// MODULE: renderer (Renderer)
// PURPOSE: Wraps Canvas3D + Camera3D setup, the procedurally-generated
//          alley skybox, the five-light setup (sun, fill, pin spot,
//          lane glow, deck fill), and the PostFX3D effect chain.
//          Provides a Performance / Cinematic quality toggle.
//
// WHERE-THIS-FITS: Constructed first by BowlingGame.init(); every other
//          renderable subsystem (lane / pins / ball / particles)
//          consults getCanvas() and getCamera().
//
// KEY-DESIGN-CHOICES:
//   * FIVE LIGHTS. Directional sun + directional fill (key + bounce
//     simulation), spot light over the pins (CAM_SPOT_*), point lane
//     glow (warm tone over the foul line), point deck fill (cool
//     tone behind the pins). The combination is what gives the
//     "bowling alley" mood.
//   * PROCEDURAL SKYBOX. createAlleySkybox builds 6 64x64 Pixels
//     buffers in code (gradients + ceiling tile pattern + floor
//     stripe pattern), then assembles them as a CubeMap3D. No
//     external textures needed; the skybox subtly reflects in the
//     ball + lane oil for depth.
//   * QUALITY MODE. Cinematic adds tonemap + bloom + FXAA + colour
//     grade + vignette. Performance trims to a lighter pipeline.
//     applyQuality clears + rebuilds the chain on the fly so the
//     player can switch from the options menu mid-game.
//   * DT CLAMP. getDeltaTime clamps to DT_CLAMP (50 ms) so a hitch
//     doesn't produce a giant physics step that tunnels the ball
//     through pins.
// ============================================================================

// renderer.zia — Canvas3D setup, lighting, post-processing, shadows
module renderer;

bind Viper.Graphics3D;
bind Viper.Graphics;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind "../config";

/// @brief Canvas + camera + lighting + post-FX wrapper for 3D Bowling.
class Renderer {
    hide Canvas3D canvas;
    hide Camera3D cam;
    hide CubeMap3D alleySkybox;
    hide PostFX3D postfx;
    hide Light3D sunLight;
    hide Light3D fillLight;
    hide Light3D pinSpot;
    hide Light3D lanePractical;
    hide Light3D deckFill;
    hide Integer qualityMode;

    /// @brief Pack 0..255 RGBA into a single 32-bit pixel int.
    hide func packPixel(r: Integer, g: Integer, b: Integer, a: Integer) -> Integer {
        return (((r * 256) + g) * 256 + b) * 256 + a;
    }

    /// @brief One-time setup: window, camera, lights, skybox, post-FX.
    expose func initRenderer(startQuality: Integer) {
        initRendererWithSize(startQuality, config.WINDOW_WIDTH, config.WINDOW_HEIGHT);
    }

    /// @brief One-time setup with explicit dimensions for headless smoke probes.
    expose func initRendererWithSize(startQuality: Integer, width: Integer, height: Integer) {
        canvas = Canvas3D.New(config.WINDOW_TITLE, width, height);
        Canvas3D.SetMaxDeltaTime(canvas, 50);
        Canvas3D.SetOcclusionCulling(canvas, true);
        Say("Backend: " + canvas.Backend);

        var aspect: Float = (width + 0.0) / (height + 0.0);
        cam = Camera3D.New(config.CAMERA_FOV, aspect, config.CAMERA_NEAR, config.CAMERA_FAR);
        alleySkybox = createAlleySkybox();
        Canvas3D.SetSkybox(canvas, alleySkybox);

        var mainDir = new Vec3(config.LIGHT_MAIN_DIR_X, config.LIGHT_MAIN_DIR_Y, config.LIGHT_MAIN_DIR_Z);
        sunLight = Light3D.Directional(mainDir,
            config.LIGHT_MAIN_R, config.LIGHT_MAIN_G, config.LIGHT_MAIN_B);
        Light3D.SetIntensity(sunLight, 1.08);
        Canvas3D.SetLight(canvas, 0, sunLight);

        var fillDir = new Vec3(config.LIGHT_FILL_DIR_X, config.LIGHT_FILL_DIR_Y, config.LIGHT_FILL_DIR_Z);
        fillLight = Light3D.Directional(fillDir,
            config.LIGHT_FILL_R, config.LIGHT_FILL_G, config.LIGHT_FILL_B);
        Light3D.SetIntensity(fillLight, 0.84);
        Canvas3D.SetLight(canvas, 1, fillLight);

        var spotPos = new Vec3(config.LIGHT_SPOT_X, config.LIGHT_SPOT_Y, config.LIGHT_SPOT_Z);
        var spotDir = new Vec3(0.0, -0.55, 1.0);
        pinSpot = Light3D.Spot(spotPos, spotDir,
            config.LIGHT_SPOT_R, config.LIGHT_SPOT_G, config.LIGHT_SPOT_B,
            config.LIGHT_SPOT_ATTENUATION,
            config.LIGHT_SPOT_INNER_ANGLE, config.LIGHT_SPOT_OUTER_ANGLE);
        Light3D.SetIntensity(pinSpot, 2.05);
        Canvas3D.SetLight(canvas, 2, pinSpot);

        var laneGlowPos = new Vec3(0.0, 4.35, 6.2);
        lanePractical = Light3D.Point(laneGlowPos, 0.92, 0.96, 1.0, 0.035);
        Light3D.SetIntensity(lanePractical, 0.78);
        Canvas3D.SetLight(canvas, 3, lanePractical);

        var deckFillPos = new Vec3(-0.78, 2.9, 16.2);
        deckFill = Light3D.Point(deckFillPos, 0.78, 0.90, 1.0, 0.045);
        Light3D.SetIntensity(deckFill, 1.22);
        Canvas3D.SetLight(canvas, 4, deckFill);

        Canvas3D.SetAmbient(canvas, config.AMBIENT_R, config.AMBIENT_G, config.AMBIENT_B);
        Canvas3D.SetShadowBias(canvas, 0.002);
        Canvas3D.SetShadowCascades(canvas, config.SHADOW_CASCADES);
        Canvas3D.SetFog(canvas, 25.0, 80.0, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);

        postfx = PostFX3D.New();
        applyQuality(startQuality);
    }

    /// @brief Rebuild the post-FX chain for QUALITY_PERFORMANCE or
    ///        QUALITY_CINEMATIC. Safe to call mid-game.
    expose func applyQuality(mode: Integer) {
        qualityMode = mode;
        PostFX3D.Clear(postfx);

        if (mode == config.QUALITY_CINEMATIC) {
            Canvas3D.EnableShadows(canvas, config.SHADOW_MAP_CINEMATIC);
            Canvas3D.SetShadowQuality(canvas, config.SHADOW_QUALITY_CINEMATIC);
            Canvas3D.SetShadowStrength(canvas, config.SHADOW_STRENGTH_CINEMATIC);

            PostFX3D.AddTonemap(postfx, 1, 1.20);
            PostFX3D.AddBloom(postfx, 0.88, 0.08, 3);
            // Screen-space reflections on the glossy lane, GPU-gated.
            if (Canvas3D.BackendSupports(canvas, "ssr")) {
                PostFX3D.AddSSR(postfx, config.SSR_INTENSITY, config.SSR_ROUGHNESS_CUTOFF);
            }
            // TAA on the slow bowling camera (no ghosting) — replaces FXAA when
            // available; otherwise fall back to FXAA so the SW probe still AAs.
            if (Canvas3D.BackendSupports(canvas, "taa")) {
                PostFX3D.AddTAA(postfx, config.TAA_BLEND);
            } else {
                PostFX3D.AddFXAA(postfx);
            }
            PostFX3D.AddColorGrade(postfx, 0.005, 1.06, 1.04);
            PostFX3D.AddVignette(postfx, 0.96, 0.28);
        } else {
            Canvas3D.EnableShadows(canvas, config.SHADOW_MAP_PERFORMANCE);
            Canvas3D.SetShadowQuality(canvas, config.SHADOW_QUALITY_PERFORMANCE);
            Canvas3D.SetShadowStrength(canvas, config.SHADOW_STRENGTH_PERFORMANCE);

            PostFX3D.AddTonemap(postfx, 1, 1.18);
            PostFX3D.AddBloom(postfx, 0.90, 0.06, 1);
            PostFX3D.AddFXAA(postfx);
            PostFX3D.AddColorGrade(postfx, 0.015, 1.04, 1.02);
        }

        Canvas3D.SetPostFX(canvas, postfx);
    }

    /// @brief Active quality mode.
    expose func getQualityMode() -> Integer {
        return qualityMode;
    }

    /// @brief 3D drawing canvas.
    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    /// @brief Active camera (managed by CameraController).
    expose func getCamera() -> Camera3D {
        return cam;
    }

    /// @brief Procedurally-generated alley skybox (for cubemap reflections).
    expose func getSkybox() -> CubeMap3D {
        return alleySkybox;
    }

    /// @brief Pump window events.
    expose func poll() {
        Canvas3D.Poll(canvas);
    }

    /// @brief Clear back buffer + Begin scene with the active camera.
    expose func beginFrame() {
        Canvas3D.Clear(canvas, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);
        Canvas3D.Begin(canvas, cam);
    }

    /// @brief End scene (post-FX, etc.).
    expose func endFrame() {
        Canvas3D.End(canvas);
    }

    /// @brief Swap to front buffer.
    expose func flip() {
        Canvas3D.Flip(canvas);
    }

    /// @brief True if the user closed the window.
    expose func shouldClose() -> Boolean {
        return canvas.ShouldClose;
    }

    /// @brief Frame delta in seconds, clamped to DT_CLAMP to prevent
    ///        physics tunneling on hitches.
    expose func getDeltaTime() -> Float {
        var raw: Float = (canvas.DeltaTime + 0.0) / 1000.0;
        if (raw > config.DT_CLAMP) { raw = config.DT_CLAMP; }
        return raw;
    }

    /// @brief Recent frame rate for HUD display.
    expose func getFps() -> Integer {
        return canvas.Fps;
    }

    /// @brief Window pixel width.
    expose func getWidth() -> Integer {
        return canvas.Width;
    }

    /// @brief Window pixel height.
    expose func getHeight() -> Integer {
        return canvas.Height;
    }

    /// @brief Bump the pin spotlight intensity (used for strike celebrations).
    expose func flashPinLight(intensity: Float) {
        Light3D.SetIntensity(pinSpot, intensity);
        Canvas3D.SetLight(canvas, 2, pinSpot);
    }

    /// @brief Restore pin spotlight to default intensity.
    expose func resetPinLight() {
        Light3D.SetIntensity(pinSpot, 2.05);
        Canvas3D.SetLight(canvas, 2, pinSpot);
    }

    hide func createAlleySkybox() -> CubeMap3D {
        var right = createGradientFace(20, 28, 36, 58, 72, 82, true);
        var left = createGradientFace(18, 26, 34, 52, 66, 78, true);
        var top = createCeilingFace();
        var bottom = createFloorFace();
        var front = createGradientFace(18, 26, 36, 70, 82, 92, true);
        var back = createGradientFace(14, 22, 30, 44, 56, 66, false);
        return CubeMap3D.New(right, left, top, bottom, front, back);
    }

    hide func createGradientFace(topR: Integer, topG: Integer, topB: Integer,
                                 botR: Integer, botG: Integer, botB: Integer,
                                 addLights: Boolean) -> Pixels {
        var size = 64;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            var t = (py + 0.0) / ((size - 1) + 0.0);
            var rr = Convert.NumToInt(topR + (botR - topR) * t);
            var gg = Convert.NumToInt(topG + (botG - topG) * t);
            var bb = Convert.NumToInt(topB + (botB - topB) * t);

            for (var px: Integer = 0; px < size; px = px + 1) {
                var r = rr;
                var g = gg;
                var b = bb;
                if (addLights && py >= 18 && py <= 25 && ((px + 5) % 16) <= 4) {
                    r = 235;
                    g = 238;
                    b = 218;
                }
                face.Set(px, py, packPixel(r, g, b, 255));
            }
        }
        return face;
    }

    hide func createCeilingFace() -> Pixels {
        var size = 64;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var r = 34;
                var g = 42;
                var b = 50;
                if (((px + 2) % 16) <= 5 && ((py + 4) % 16) <= 4) {
                    r = 226;
                    g = 232;
                    b = 210;
                }
                face.Set(px, py, packPixel(r, g, b, 255));
            }
        }
        return face;
    }

    hide func createFloorFace() -> Pixels {
        var size = 64;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var stripe = ((px / 3) + (py / 5)) % 2;
                var r = 34;
                var g = 42;
                var b = 44;
                if (stripe == 0) {
                    r = 60;
                    g = 48;
                    b = 34;
                }
                face.Set(px, py, packPixel(r, g, b, 255));
            }
        }
        return face;
    }
}
