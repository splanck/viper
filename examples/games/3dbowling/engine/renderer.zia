// renderer.zia — Canvas3D setup, lighting, post-processing, shadows
module renderer;

bind Viper.Graphics3D;
bind Viper.Graphics;
bind Color = Viper.Graphics.Color;
bind Viper.Terminal;
bind Convert = Viper.Core.Convert;
bind "../config";

class Renderer {
    hide Canvas3D canvas;
    hide Camera3D cam;
    hide CubeMap3D alleySkybox;
    hide PostFX3D postfx;
    hide Light3D sunLight;
    hide Light3D fillLight;
    hide Light3D pinSpot;
    hide Integer qualityMode;

    expose func initRenderer(startQuality: Integer) {
        canvas = Canvas3D.New(config.WINDOW_TITLE, config.WINDOW_WIDTH, config.WINDOW_HEIGHT);
        Canvas3D.SetDTMax(canvas, 50);
        Canvas3D.SetOcclusionCulling(canvas, true);
        Say("Backend: " + Canvas3D.get_Backend(canvas));

        var aspect: Float = (config.WINDOW_WIDTH + 0.0) / (config.WINDOW_HEIGHT + 0.0);
        cam = Camera3D.New(config.CAMERA_FOV, aspect, config.CAMERA_NEAR, config.CAMERA_FAR);
        alleySkybox = createAlleySkybox();
        Canvas3D.SetSkybox(canvas, alleySkybox);

        var mainDir = new Vec3(config.LIGHT_MAIN_DIR_X, config.LIGHT_MAIN_DIR_Y, config.LIGHT_MAIN_DIR_Z);
        sunLight = Light3D.NewDirectional(mainDir,
            config.LIGHT_MAIN_R, config.LIGHT_MAIN_G, config.LIGHT_MAIN_B);
        Canvas3D.SetLight(canvas, 0, sunLight);

        var fillDir = new Vec3(config.LIGHT_FILL_DIR_X, config.LIGHT_FILL_DIR_Y, config.LIGHT_FILL_DIR_Z);
        fillLight = Light3D.NewDirectional(fillDir,
            config.LIGHT_FILL_R, config.LIGHT_FILL_G, config.LIGHT_FILL_B);
        Canvas3D.SetLight(canvas, 1, fillLight);

        var spotPos = new Vec3(config.LIGHT_SPOT_X, config.LIGHT_SPOT_Y, config.LIGHT_SPOT_Z);
        pinSpot = Light3D.NewPoint(spotPos,
            config.LIGHT_SPOT_R, config.LIGHT_SPOT_G, config.LIGHT_SPOT_B,
            config.LIGHT_SPOT_RANGE);
        Canvas3D.SetLight(canvas, 2, pinSpot);

        Canvas3D.SetAmbient(canvas, config.AMBIENT_R, config.AMBIENT_G, config.AMBIENT_B);
        Canvas3D.EnableShadows(canvas, 1);
        Canvas3D.SetShadowBias(canvas, 0.002);
        Canvas3D.SetFog(canvas, 25.0, 80.0, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);

        postfx = PostFX3D.New();
        applyQuality(startQuality);
    }

    expose func applyQuality(mode: Integer) {
        qualityMode = mode;
        PostFX3D.Clear(postfx);

        if (mode == config.QUALITY_CINEMATIC) {
            PostFX3D.AddTonemap(postfx, 1, 1.15);
            PostFX3D.AddBloom(postfx, 0.68, 0.42, 4);
            PostFX3D.AddFXAA(postfx);
            PostFX3D.AddSSAO(postfx, 0.55, 0.6, 16);
            PostFX3D.AddDOF(postfx, 0.8, 2.5, 0.22);
            PostFX3D.AddMotionBlur(postfx, 0.18, 6);
            PostFX3D.AddVignette(postfx, 0.55, 0.35);
            PostFX3D.AddColorGrade(postfx, 1.02, 1.08, 1.04);
        } else {
            PostFX3D.AddTonemap(postfx, 0, 1.0);
            PostFX3D.AddBloom(postfx, 0.72, 0.22, 2);
            PostFX3D.AddFXAA(postfx);
            PostFX3D.AddColorGrade(postfx, 1.0, 1.04, 1.02);
            PostFX3D.AddVignette(postfx, 0.60, 0.30);
        }

        Canvas3D.SetPostFX(canvas, postfx);
    }

    expose func getQualityMode() -> Integer {
        return qualityMode;
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func getCamera() -> Camera3D {
        return cam;
    }

    expose func getSkybox() -> CubeMap3D {
        return alleySkybox;
    }

    expose func beginFrame() {
        Canvas3D.Poll(canvas);
        Canvas3D.Clear(canvas, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);
        Canvas3D.Begin(canvas, cam);
    }

    expose func endFrame() {
        Canvas3D.End(canvas);
    }

    expose func flip() {
        Canvas3D.Flip(canvas);
    }

    expose func shouldClose() -> Boolean {
        return Canvas3D.get_ShouldClose(canvas) != 0;
    }

    expose func getDeltaTime() -> Float {
        var raw: Float = (Canvas3D.get_DeltaTime(canvas) + 0.0) / 1000.0;
        if (raw > config.DT_CLAMP) { raw = config.DT_CLAMP; }
        return raw;
    }

    expose func getFps() -> Integer {
        return Canvas3D.get_Fps(canvas);
    }

    expose func getWidth() -> Integer {
        return Canvas3D.get_Width(canvas);
    }

    expose func getHeight() -> Integer {
        return Canvas3D.get_Height(canvas);
    }

    expose func flashPinLight(intensity: Float) {
        Light3D.SetIntensity(pinSpot, intensity);
        Canvas3D.SetLight(canvas, 2, pinSpot);
    }

    expose func resetPinLight() {
        Light3D.SetIntensity(pinSpot, 1.0);
        Canvas3D.SetLight(canvas, 2, pinSpot);
    }

    hide func createAlleySkybox() -> CubeMap3D {
        var right = createGradientFace(24, 16, 24, 108, 82, 44, true);
        var left = createGradientFace(22, 15, 24, 92, 76, 40, true);
        var top = createCeilingFace();
        var bottom = createFloorFace();
        var front = createGradientFace(16, 20, 30, 120, 88, 48, true);
        var back = createGradientFace(12, 18, 26, 84, 66, 38, false);
        return CubeMap3D.New(right, left, top, bottom, front, back);
    }

    hide func createGradientFace(topR: Integer, topG: Integer, topB: Integer,
                                 botR: Integer, botG: Integer, botB: Integer,
                                 addLights: Boolean) -> Pixels {
        var size = 24;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            var t = (py + 0.0) / ((size - 1) + 0.0);
            var rr = Convert.NumToInt(topR + (botR - topR) * t);
            var gg = Convert.NumToInt(topG + (botG - topG) * t);
            var bb = Convert.NumToInt(topB + (botB - topB) * t);

            for (var px: Integer = 0; px < size; px = px + 1) {
                var r = rr;
                var g = gg;
                var b = bb;
                if (addLights && py >= 7 && py <= 10 && ((px + 2) % 6) <= 1) {
                    r = 245;
                    g = 198;
                    b = 112;
                }
                face.Set(px, py, Color.RGBA(r, g, b, 255));
            }
        }
        return face;
    }

    hide func createCeilingFace() -> Pixels {
        var size = 24;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var r = 30;
                var g = 34;
                var b = 42;
                if (((px + 1) % 8) <= 2 && ((py + 3) % 8) <= 2) {
                    r = 236;
                    g = 204;
                    b = 144;
                }
                face.Set(px, py, Color.RGBA(r, g, b, 255));
            }
        }
        return face;
    }

    hide func createFloorFace() -> Pixels {
        var size = 24;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var stripe = ((px / 3) + (py / 5)) % 2;
                var r = 26;
                var g = 18;
                var b = 10;
                if (stripe == 0) {
                    r = 38;
                    g = 26;
                    b = 14;
                }
                face.Set(px, py, Color.RGBA(r, g, b, 255));
            }
        }
        return face;
    }
}
