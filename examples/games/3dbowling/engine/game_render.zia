// ============================================================================
// MODULE: engine/game_render
// PURPOSE: 3D scene and 2D overlay drawing for 3D Bowling.
// ============================================================================

// game_render.zia — Rendering pass composition.
module game_render;

bind "../config";
bind "../menu";
bind "./game_scoring";

/// @brief Render layer for the bowling controller.
class BowlingGameRender extends BowlingGameScoring {
    /// @brief 3D pass: draw lane / pins / sweep bar / ball / particles.
    override expose func drawScene() {
        if (scoreKeepers.count() > activePlayer && activePlayer >= 0) {
            laneObj.updateMonitor(getPlayerLabel(activePlayer),
                scoreKeepers.get(activePlayer).getFrame(),
                scoreKeepers.get(activePlayer).getTotalScore());
        }
        laneObj.draw(render.getCanvas());
        if (screenState == config.SCREEN_PLAYING || screenState == config.SCREEN_PAUSED) {
            bowlerAvatar.draw(render.getCanvas());
        }
        if (gameState == config.STATE_AIMING && screenState == config.SCREEN_PLAYING) {
            var previewPower = power;
            if (previewPower < 0.68) { previewPower = 0.78; }
            var previewOffset = 0.0;
            if (releaseMeter.isAwaitingAccuracy()) {
                previewOffset = (releaseMeter.getNeedle() - 0.5) * 2.0;
            }
            ballObj.drawDeliveryPreview(render.getCanvas(), stanceX, targetX,
                spin, previewPower, previewOffset, getReleaseAssist(), difficulty,
                oilPattern, laneObj.getOilEndZ(), spareRelease,
                menuObj.getHighContrast());
        }
        if (pinMgr.isSweeping()) {
            laneObj.drawSweepBar(render.getCanvas(), pinMgr.getSweepY());
        }
        // A replay owns the visible scene transforms; hiding the reset live
        // rack prevents fresh pins from showing through recorded pinfall.
        if (replayRecorder.isActive() == false) {
            pinMgr.draw(render.getCanvas());
            ballObj.drawTrail(render.getCanvas());
            ballObj.draw(render.getCanvas());
        }
        replayRecorder.draw(render.getCanvas());
        particleMgr.draw(render.getCanvas(), render.getCamera());
    }

    /// @brief 2D pass: HUD + active menu + celebration overlay.
    override expose func drawOverlays() {
        var canvas = render.getCanvas();
        var cw = render.getWidth();
        var ch = render.getHeight();
        var displayName = "Player";
        if (playerNames.count() > activePlayer && activePlayer >= 0) {
            displayName = playerNames.get(activePlayer);
        }
        hudObj.setShotContext(releaseMeter.getNeedle(), lastReleaseAccuracy, lastShotSpeed,
            displayName, lastLeaveName, lastLeaveDifficulty);
        hudObj.setSetupContext(stanceX, targetX, spareRelease);

        if (screenState == config.SCREEN_PLAYING) {
            if (replayRecorder.isActive()) {
                Canvas3D.DrawRoundRect2D(canvas, cw / 2 - 118, 156, 236, 30, 8,
                    config.HUD_COLOR_CORAL, 0.86);
                Canvas3D.DrawText2DScaled(canvas, cw / 2 - 96, 164,
                    "HIGHLIGHT REPLAY  /  A SKIP", 0xFFFFFF, 0.82);
            }
            if (gameState == config.STATE_CELEBRATING) { celebMgr.draw(canvas, cw, ch); }
            hudObj.draw(canvas, getActiveScoreKeeper(), power, charging, spin,
                ballObj.getBallType(), gameState, playerCount, activePlayer,
                scoreKeepers, laneObj.getOilPatternName() + " oil  " +
                    toString(laneObj.getOilWearPercent()) + "% wear");
            if (gameState == config.STATE_AIMING && cw >= 760) {
                laneObj.drawOilPreview(canvas, cw - 232, 182, 132, 60);
            }
            drawModeObjective(canvas, cw);
            if (hasLastEntry && gameState != config.STATE_AIMING) {
                hudObj.drawShotFeedback(canvas, lastEntryAngle, cw);
            }
        } else if (screenState == config.SCREEN_PAUSED) {
            hudObj.draw(canvas, getActiveScoreKeeper(), power, charging, spin,
                ballObj.getBallType(), gameState, playerCount, activePlayer,
                scoreKeepers, laneObj.getOilPatternName() + " oil  " +
                    toString(laneObj.getOilWearPercent()) + "% wear");
            menuObj.drawPause(canvas, cw, ch);
        } else if (screenState == config.SCREEN_OPTIONS) {
            menuObj.drawOptions(canvas, cw, ch);
        } else if (screenState == config.SCREEN_RESULTS) {
            var headline = "Game Complete";
            var subtitle = "Final Score: " + toString(resultsScores.get(0));
            var detail = "Best score: " + toString(menuObj.getBestScore());

            if (playerCount > 1) {
                headline = "Match Complete";
                if (resultsWinner < 0) {
                    subtitle = "Tie game";
                } else {
                    subtitle = getPlayerLabel(resultsWinner) + " wins";
                }
                detail = buildStandingsLine();
            } else if (resultsNewHigh) {
                detail = "New high score";
            }

            if (currentMode == config.MODE_CHALLENGE) {
                headline = "Challenge Complete";
                var medal = "No medal - retry the event";
                if (resultsChallengeTier == 1) { medal = "Bronze medal earned"; }
                if (resultsChallengeTier == 2) { medal = "Silver medal earned"; }
                if (resultsChallengeTier == 3) { medal = "Gold medal earned"; }
                detail = medal;
                if (challengeId == 1) {
                    subtitle = "Spare conversions: " + toString(matchSpares);
                }
            } else if (currentMode == config.MODE_PRACTICE) {
                headline = "Practice Session Complete";
                detail = "Keep experimenting with line and equipment";
            } else if (currentMode == config.MODE_PARTY) {
                headline = "Cosmic Session Complete";
                if (partyId == 0) { detail = "Strike Rush  /  maximum 30"; }
                else if (partyId == 1) { detail = "Low Ball  /  lowest clean score wins"; }
                else { detail = "Target Bowling  /  precision wins"; }
            }

            menuObj.drawResults(canvas, cw, ch, headline, subtitle, detail);
        } else {
            menuObj.drawTitle(canvas, cw, ch);
        }
    }

    /// @brief "P1 120  |  P3 98  |  P2 85" — seats in finishing order.
    hide func buildStandingsLine() -> String {
        var line = "";
        for (var r: Integer = 0; r < resultsRanking.count(); r = r + 1) {
            var idx = resultsRanking.get(r);
            if (r > 0) { line = line + "  |  "; }
            line = line + "P" + toString(idx + 1) + " " + toString(resultsScores.get(idx));
        }
        return line;
    }

    /// @brief Persistent rule/goal ribbon for every non-standard mode.
    hide func drawModeObjective(canvas: Canvas3D, cw: Integer) {
        if (currentMode == config.MODE_SINGLE || cw < 720) { return; }
        if (hasLastEntry && gameState != config.STATE_AIMING) { return; }

        var heading = "LOCAL MATCH";
        var objective = getPlayerLabel(activePlayer) + " on the approach";
        var accent = config.HUD_COLOR_CYAN;
        if (currentMode == config.MODE_CHAMPIONSHIP) {
            heading = "CHAMPIONSHIP  /  " + getPlayerLabel(1);
            objective = "YOU " + toString(scoreKeepers.get(0).getTotalScore()) +
                "     RIVAL " + toString(scoreKeepers.get(1).getTotalScore());
            accent = config.HUD_COLOR_AMBER;
        } else if (currentMode == config.MODE_CHALLENGE) {
            heading = "CHALLENGE TOUR";
            if (challengeId == 0) {
                objective = "POCKET MASTER   140 BRONZE  /  180 SILVER  /  220 GOLD";
            } else if (challengeId == 1) {
                objective = "SPARE SCHOOL   " + toString(matchSpares) +
                    " CONVERTED   /   MEDALS AT 3 - 5 - 7";
            } else {
                objective = "CLUTCH TENTH   20 BRONZE  /  25 SILVER  /  30 GOLD";
            }
            accent = config.HUD_COLOR_GOLD;
        } else if (currentMode == config.MODE_PRACTICE) {
            heading = "PRACTICE LAB";
            objective = "FREE BOWLING   change line, shape, and equipment";
            if (practiceId == 1) { objective = "7-10 SPLIT   clear both corners to convert"; }
            if (practiceId == 2) { objective = "10-PIN CORNER   flatten the hook and cover the pin"; }
            if (practiceId == 3) { objective = "3-6-10 BUCKET   drive through all three pins"; }
        } else if (currentMode == config.MODE_PARTY) {
            heading = "COSMIC PARTY";
            objective = "STRIKE RUSH   one pressure tenth frame  /  maximum 30";
            if (partyId == 1) { objective = "LOW BALL   lowest score wins; gutters cost ten"; }
            if (partyId == 2) { objective = "TARGET BOWLING   pins + timing + pocket angle"; }
            accent = config.HUD_COLOR_CORAL;
        }

        var width = 510;
        Canvas3D.DrawRoundRect2D(canvas, 24, 86, width, 48, 10,
            config.HUD_COLOR_NAVY, 0.91);
        Canvas3D.DrawRect2D(canvas, 24, 86, 5, 48, accent);
        Canvas3D.DrawText2DScaled(canvas, 42, 96, heading, accent, 0.82);
        Canvas3D.DrawText2DScaled(canvas, 42, 116, objective, 0xD9E5EB, 0.72);
    }
}
