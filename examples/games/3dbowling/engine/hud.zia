//
// File: examples/games/3dbowling/engine/hud.zia
// Purpose: Renders the responsive score, setup, release, coaching, and toast hierarchy.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: hud (HUD)
// PURPOSE: 2D in-game overlay: 10-frame scoreboard, status panel,
//          power meter, spin indicator, aim guide, controls cheatsheet,
//          toast message, FPS counter.
//
// WHERE-THIS-FITS: Drawn each frame after the 3D scene. Reads from the
//          ScoreKeeper plus a few BowlingGame parameters; owns no
//          gameplay state of its own besides the toast message timer.
//
// KEY-DESIGN-CHOICES:
//   * 2D OVERLAY VIA Canvas3D.DrawText2D / DrawRect2D. The 3D canvas
//     also supports orthographic 2D draws — the HUD lives on top of
//     the rendered scene without needing a separate 2D backbuffer.
//   * COLOUR-CODED ROLL TEXT. drawRollText routes the glyph color via
//     the value: "X" → red, "/" → green, "-" → gray, digits → white.
//   * METER COLOR PROGRESSION. drawPowerMeter switches color through
//     LOW (green) → MID (orange) → HIGH (red) at the threshold values
//     in config — a visual "you're charging too much" signal.
//   * PRIORITIZED TOAST QUEUE. Gameplay coaching can replace immediately;
//     achievements queue behind it so simultaneous unlocks are never lost.
// ============================================================================

// hud.zia — Bowling scoreboard, meters, player summary, and toast messages
module hud;

bind Zanna.Graphics3D;
bind Zanna.Core.Convert as Convert;
bind Zanna.Math;
bind "../config";
bind "../scoring/scoring";
bind "../content/ball_catalog";

/// @brief 2D HUD overlay (scoreboard + meters + toast).
class HUD {
    hide Float messageTimer;
    hide List[String] messageText;
    hide List[Integer] messageColors;
    hide List[Float] messageDurations;
    hide BallCatalog ballCatalog;
    hide Float releaseNeedle;
    hide Float releaseAccuracy;
    hide Float shotSpeed;
    hide String activeName;
    hide String leaveName;
    hide Integer leaveDifficulty;
    hide Float setupStance;
    hide Float setupTarget;
    hide Boolean spareRelease;
    hide Boolean highContrast;
    hide Boolean largeHud;

    /// @brief Initialize empty prioritized-toast state.
    expose func initHUD() {
        messageTimer = 0.0;
        messageText = [];
        messageColors = [];
        messageDurations = [];
        ballCatalog = new BallCatalog();
        releaseNeedle = 0.5;
        releaseAccuracy = 1.0;
        shotSpeed = 0.0;
        activeName = "Player";
        leaveName = "Fresh rack";
        leaveDifficulty = 0;
        setupStance = 0.0;
        setupTarget = 0.0;
        spareRelease = false;
        highContrast = false;
        largeHud = false;
    }

    expose func setAccessibility(contrast: Boolean, useLargeHud: Boolean) {
        highContrast = contrast;
        largeHud = useLargeHud;
    }

    expose func getHighContrast() -> Boolean { return highContrast; }
    expose func getLargeHud() -> Boolean { return largeHud; }

    expose func setSetupContext(stance: Float, target: Float, spare: Boolean) {
        setupStance = stance;
        setupTarget = target;
        spareRelease = spare;
    }

    /// @brief Push transient release and leave context without widening draw().
    expose func setShotContext(needle: Float, accuracy: Float, speed: Float, playerName: String,
                               currentLeave: String, difficulty: Integer) {
        releaseNeedle = needle;
        releaseAccuracy = accuracy;
        shotSpeed = speed;
        activeName = playerName;
        leaveName = currentLeave;
        leaveDifficulty = difficulty;
    }

    /// @brief Show a centered toast message for `duration` seconds.
    expose func showMessage(msg: String, color: Integer, duration: Float) {
        messageText.clear();
        messageColors.clear();
        messageDurations.clear();
        messageText.add(msg);
        messageColors.add(color);
        messageDurations.add(duration);
        messageTimer = duration;
    }

    /// @brief Queue a secondary toast without hiding the current gameplay cue.
    expose func queueMessage(msg: String, color: Integer, duration: Float) {
        if (messageText.count() >= 5) { return; }
        messageText.add(msg);
        messageColors.add(color);
        messageDurations.add(duration);
        if (messageText.count() == 1) { messageTimer = duration; }
    }

    expose func getQueuedMessageCount() -> Integer { return messageText.count(); }

    /// @brief Tick the toast message timer.
    expose func update(dt: Float) {
        if (messageText.count() == 0) { return; }
        messageTimer = messageTimer - dt;
        if (messageTimer > 0.0) { return; }
        messageText.removeAt(0);
        messageColors.removeAt(0);
        messageDurations.removeAt(0);
        if (messageText.count() > 0) { messageTimer = messageDurations.get(0); }
        else { messageTimer = 0.0; }
    }

    /// @brief Render the full HUD overlay each frame.
    expose func draw(canvas: Canvas3D, scoreKeeper: ScoreKeeper,
                     power: Float, charging: Boolean,
                     spin: Float,
                     ballType: Integer, gameState: Integer,
                     playerCount: Integer, activePlayer: Integer,
                     scoreKeepers: List[ScoreKeeper],
                     oilName: String) {
        var cw: Integer = canvas.Width;
        var ch: Integer = canvas.Height;

        if (cw < 1260) {
            drawCompactScoreboard(canvas, scoreKeeper, cw, oilName, ballType);
        } else {
            drawScoreboard(canvas, scoreKeeper, cw);
            drawStatusPanel(canvas, cw, playerCount, activePlayer, scoreKeepers, oilName, ballType);
        }

        if (gameState == config.STATE_AIMING) {
            if (ch < 360) { drawCompactControls(canvas, power, spin, cw, ch); }
            else { drawControlPanel(canvas, power, charging, spin, ch); }
        }

        if (messageTimer > 0.0 && messageText.count() > 0) {
            var msg = messageText.get(0);
            var msgScale = 1.25;
            if (largeHud) { msgScale = 1.52; }
            var msgW = Canvas3D.MeasureText2D(canvas, msg, msgScale);
            var msgX = cw / 2 - msgW / 2;
            Canvas3D.DrawRoundRect2D(canvas, msgX - 22, ch / 2 + 38,
                msgW + 44, 46, 12, config.HUD_COLOR_NAVY, 0.88);
            Canvas3D.DrawText2DScaled(canvas, msgX, ch / 2 + 49, msg,
                messageColors.get(0), msgScale);
        }
    }

    /// @brief Post-throw readout: the ball's entry angle plus a pocket-quality
    ///        cue, so players learn that angle (hook), not just power, is what
    ///        drives strikes.
    expose func drawShotFeedback(canvas: Canvas3D, entryAngle: Float, cw: Integer) {
        var panelW = 420;
        var px = cw / 2 - panelW / 2;
        var py = 74;
        Canvas3D.DrawRoundRect2D(canvas, px, py, panelW, 70, 12, config.HUD_COLOR_NAVY, 0.90);
        Canvas3D.DrawRect2D(canvas, px + 16, py, panelW - 32, 2, config.HUD_COLOR_MENU_ACCENT);
        Canvas3D.DrawText2DScaled(canvas, px + 16, py + 12,
            "ENTRY " + toString(Convert.NumToInt(entryAngle)) + " deg", config.HUD_COLOR_WHITE, 1.05);
        Canvas3D.DrawText2DScaled(canvas, px + 164, py + 12,
            "RELEASE " + toString(Convert.NumToInt(releaseAccuracy * 100.0)) + "%",
            config.HUD_COLOR_CYAN, 1.05);
        Canvas3D.DrawText2DScaled(canvas, px + 310, py + 12,
            "SPEED " + toString(Convert.NumToInt(shotSpeed)) + "m/s",
            config.HUD_COLOR_AMBER, 0.88);

        var tag = "Straight-in - tough to strike";
        var tagColor = config.HUD_COLOR_GRAY;
        var entryMagnitude = Abs(entryAngle);
        if (entryMagnitude >= 4.0) {
            tag = "Strong pocket angle";
            tagColor = config.HUD_COLOR_GOLD;
        } else if (entryMagnitude >= 2.0) {
            tag = "Shallow angle";
            tagColor = config.HUD_COLOR_WHITE;
        }
        var leaveColor = config.HUD_COLOR_WHITE;
        if (leaveDifficulty >= 2) { leaveColor = config.HUD_COLOR_CORAL; }
        Canvas3D.DrawText2DScaled(canvas, px + 16, py + 39, tag, tagColor, 0.92);
        Canvas3D.DrawText2DScaled(canvas, px + 250, py + 39, leaveName, leaveColor, 0.92);
    }

    hide func drawControlPanel(canvas: Canvas3D, power: Float, charging: Boolean,
                               spin: Float,
                               ch: Integer) {
        var panelW = 352;
        var panelH = 124;
        if (largeHud) { panelW = 390; panelH = 148; }
        var panelX = 24;
        var panelY = ch - panelH - 22;
        if (panelY < 166) { panelY = 166; }

        Canvas3D.DrawRoundRect2D(canvas, panelX, panelY, panelW, panelH, 14,
            config.HUD_COLOR_NAVY, 0.90);
        Canvas3D.DrawRect2D(canvas, panelX + 16, panelY, panelW - 32, 2, config.HUD_COLOR_MENU_ACCENT);

        var meterX = panelX + 18;
        var meterY = panelY + 30;
        var labelScale = 1.0;
        if (largeHud) { labelScale = 1.18; }
        Canvas3D.DrawText2DScaled(canvas, meterX, panelY + 12,
            "POWER", config.HUD_COLOR_WHITE, labelScale);
        var meterW = config.METER_W;
        if (largeHud) { meterW = config.METER_W + 38; }
        Canvas3D.DrawRect2D(canvas, meterX - 1, meterY - 1,
            meterW + 2, config.METER_H + 2, config.HUD_COLOR_DARK);

        var displayPower = power / config.THROW_POWER_MAX;
        if (displayPower < 0.0) { displayPower = 0.0; }
        if (displayPower > 1.0) { displayPower = 1.0; }

        var sweetX = meterX + Convert.NumToInt(meterW * 0.58);
        var sweetW = Convert.NumToInt(meterW * 0.24);
        Canvas3D.DrawRect2D(canvas, sweetX, meterY + 2, sweetW, config.METER_H - 4, 0x285C3C);

        var fillW = Convert.NumToInt(displayPower * (meterW + 0.0));
        var meterColor = config.METER_COLOR_LOW;
        if (displayPower > config.METER_THRESHOLD_MID) { meterColor = config.METER_COLOR_MID; }
        if (displayPower > config.METER_THRESHOLD_HIGH) { meterColor = config.METER_COLOR_HIGH; }
        Canvas3D.DrawRect2D(canvas, meterX, meterY, fillW, config.METER_H, meterColor);

        var pct = "--";
        if (charging || power > 0.0) {
            pct = toString(Convert.NumToInt(displayPower * 100.0)) + "%";
        }
        Canvas3D.DrawText2DScaled(canvas, meterX + meterW + 18,
            meterY + 1, pct, config.HUD_COLOR_WHITE, labelScale);

        var spinX = panelX + 18;
        var spinY = panelY + 68;
        Canvas3D.DrawText2DScaled(canvas, spinX, spinY - 17, "CURVE", config.HUD_COLOR_GRAY, 0.88);
        var spinBarW = config.SPIN_INDICATOR_W + 34;
        var spinBarX = spinX + 66;
        Canvas3D.DrawRect2D(canvas, spinBarX, spinY - 3,
            spinBarW, config.SPIN_INDICATOR_H, config.HUD_COLOR_DARK);
        var centerX = spinBarX + spinBarW / 2;

        var spinPct = spin / config.SPIN_MAX;
        if (spinPct < -1.0) { spinPct = -1.0; }
        if (spinPct > 1.0) { spinPct = 1.0; }
        var spinOffset = Convert.NumToInt(spinPct * ((spinBarW / 2) + 0.0));
        var markerColor = config.HUD_COLOR_CYAN;
        if (spin < 0.0) { markerColor = 0xFF8844; }
        if (highContrast) { markerColor = config.HUD_COLOR_GOLD; }

        // Directional fill from the centre toward the marker = hook magnitude.
        if (spinOffset >= 0) {
            Canvas3D.DrawRect2D(canvas, centerX, spinY - 1, spinOffset, config.SPIN_INDICATOR_H - 4, markerColor);
        } else {
            Canvas3D.DrawRect2D(canvas, centerX + spinOffset, spinY - 1, -spinOffset, config.SPIN_INDICATOR_H - 4, markerColor);
        }
        Canvas3D.DrawRect2D(canvas, centerX, spinY - 3, 1, config.SPIN_INDICATOR_H, config.HUD_COLOR_GRAY);
        var markerX = centerX + spinOffset;
        Canvas3D.DrawRect2D(canvas, markerX - 2, spinY - 4, 4,
            config.SPIN_INDICATOR_H + 2, markerColor);

        // Direction + magnitude readout beneath the bar.
        var hookLabel = "STRAIGHT";
        if (spin > 0.02) { hookLabel = "HOOK R " + toString(Convert.NumToInt(spinPct * 100.0)) + "%"; }
        else if (spin < -0.02) { hookLabel = "HOOK L " + toString(Convert.NumToInt(-spinPct * 100.0)) + "%"; }
        Canvas3D.DrawText2DScaled(canvas, spinBarX, spinY + 11, hookLabel, markerColor, 0.76);

        var setupColor = config.HUD_COLOR_CYAN;
        if (highContrast) { setupColor = config.HUD_COLOR_GOLD; }
        Canvas3D.DrawText2DScaled(canvas, panelX + 228, spinY - 17,
            "STANCE B" + toString(boardNumber(setupStance)), setupColor, 0.82);
        Canvas3D.DrawText2DScaled(canvas, panelX + 228, spinY + 2,
            "TARGET B" + toString(boardNumber(setupTarget)), setupColor, 0.82);
        if (spareRelease) {
            Canvas3D.DrawText2DScaled(canvas, panelX + 228, spinY + 21,
                "SPARE RELEASE", config.HUD_COLOR_AMBER, 0.74);
        }

        // Release timing strip: center is perfect, cyan marker is live timing.
        var timingX = panelX + 18;
        var timingY = panelY + 108;
        if (largeHud) { timingY = panelY + 132; }
        var timingW = panelW - 36;
        Canvas3D.DrawText2DScaled(canvas, timingX, timingY - 13, "RELEASE", config.HUD_COLOR_GRAY, 0.78);
        Canvas3D.DrawRect2D(canvas, timingX + 62, timingY - 4, timingW - 62, 7, 0x172A36);
        var zoneX = timingX + 62 + (timingW - 62) / 2 - 18;
        Canvas3D.DrawRect2D(canvas, zoneX, timingY - 4, 36, 7, 0x2B694F);
        var needleX = timingX + 62 + Convert.NumToInt(releaseNeedle * ((timingW - 62) + 0.0));
        var needleColor = config.HUD_COLOR_CYAN;
        if (highContrast) { needleColor = config.HUD_COLOR_GOLD; }
        Canvas3D.DrawRect2D(canvas, needleX - 2, timingY - 8, 4, 15, needleColor);
    }

    hide func boardNumber(x: Float) -> Integer {
        var pct = (x + config.LANE_WIDTH / 2.0) / config.LANE_WIDTH;
        if (pct < 0.0) { pct = 0.0; }
        if (pct > 1.0) { pct = 1.0; }
        return 1 + Convert.NumToInt(pct * 38.0);
    }

    hide func drawCompactScoreboard(canvas: Canvas3D, sk: ScoreKeeper, cw: Integer,
                                    oilName: String, ballType: Integer) {
        var panelW = cw - 24;
        if (panelW > 520) { panelW = 520; }
        var x = cw / 2 - panelW / 2;
        Canvas3D.DrawRoundRect2D(canvas, x, 10, panelW, 64, 10, config.HUD_COLOR_NAVY, 0.92);
        Canvas3D.DrawText2DScaled(canvas, x + 16, 20, activeName, config.HUD_COLOR_AMBER, 1.0);
        Canvas3D.DrawText2DScaled(canvas, x + 16, 40,
            "FRAME " + toString(sk.getFrame()) + "  ROLL " + toString(sk.getRollInFrame()),
            0x91A8B6, 0.85);
        Canvas3D.DrawText2DScaled(canvas, x + 16, 56,
            oilName + "  /  " + getBallName(ballType), getBallColor(ballType), 0.66);
        var score = "" + toString(sk.getTotalScore());
        var scoreScale = 2.1;
        if (largeHud) { scoreScale = 2.48; }
        var sw = Canvas3D.MeasureText2D(canvas, score, scoreScale);
        Canvas3D.DrawText2DScaled(canvas, x + panelW - sw - 18,
            18, score, 0xF7FBFF, scoreScale);
    }

    hide func drawCompactControls(canvas: Canvas3D, power: Float, spin: Float,
                                  cw: Integer, ch: Integer) {
        var x = 12;
        var y = ch - 42;
        var width = cw - 24;
        Canvas3D.DrawRoundRect2D(canvas, x, y, width, 32, 9, config.HUD_COLOR_NAVY, 0.92);
        var powerPct = power / config.THROW_POWER_MAX;
        if (powerPct < 0.0) { powerPct = 0.0; }
        if (powerPct > 1.0) { powerPct = 1.0; }
        Canvas3D.DrawText2DScaled(canvas, x + 12, y + 9,
            "POWER " + toString(Convert.NumToInt(powerPct * 100.0)) + "%", 0xF7FBFF, 0.72);
        var barX = x + 90;
        var barW = width - 174;
        Canvas3D.DrawRect2D(canvas, barX, y + 12, barW, 6, 0x17303D);
        Canvas3D.DrawRect2D(canvas, barX, y + 12,
            Convert.NumToInt(powerPct * (barW + 0.0)), 6, config.HUD_COLOR_CYAN);
        var hook = "STRAIGHT";
        if (spin > 0.02) { hook = "HOOK R"; }
        if (spin < -0.02) { hook = "HOOK L"; }
        Canvas3D.DrawText2DScaled(canvas, x + width - 72, y + 9, hook, config.HUD_COLOR_AMBER, 0.66);
    }

    hide func drawScoreboard(canvas: Canvas3D, sk: ScoreKeeper, cw: Integer) {
        var totalW: Integer = config.SCORE_FRAME_W * 9 + config.SCORE_FRAME_10_W;
        var startX: Integer = (cw - totalW) / 2;
        var startY: Integer = config.SCORE_Y;
        var curFrame: Integer = sk.getFrame();
        var x: Integer = startX;

        Canvas3D.DrawText2D(canvas, startX, startY - 2, "NEON LANES", config.HUD_COLOR_GOLD);

        for (var f: Integer = 0; f < config.FRAMES_PER_GAME; f = f + 1) {
            var fw: Integer = config.SCORE_FRAME_W;
            if (f == 9) { fw = config.SCORE_FRAME_10_W; }

            var bgColor = config.HUD_COLOR_FRAME_BG;
            if (f == curFrame - 1) { bgColor = config.HUD_COLOR_FRAME_ACTIVE; }
            Canvas3D.DrawRect2D(canvas, x, startY + 12, fw, config.SCORE_FRAME_H, bgColor);
            Canvas3D.DrawRect2D(canvas, x, startY + 12, fw, 1, config.HUD_COLOR_FRAME_BORDER);
            Canvas3D.DrawRect2D(canvas, x, startY + 12 + config.SCORE_FRAME_H - 1, fw, 1, config.HUD_COLOR_FRAME_BORDER);
            Canvas3D.DrawRect2D(canvas, x, startY + 12, 1, config.SCORE_FRAME_H, config.HUD_COLOR_FRAME_BORDER);
            Canvas3D.DrawRect2D(canvas, x + fw - 1, startY + 12, 1, config.SCORE_FRAME_H, config.HUD_COLOR_FRAME_BORDER);
            Canvas3D.DrawText2D(canvas, x + fw / 2 - 3, startY + 14, toString(f + 1), config.HUD_COLOR_GRAY);

            var rollY: Integer = startY + 26;
            drawRollText(canvas, x + fw - 38, rollY, sk.getFrameRoll1(f));
            drawRollText(canvas, x + fw - 20, rollY, sk.getFrameRoll2(f));
            if (f == 9) {
                drawRollText(canvas, x + fw - 4, rollY, sk.getFrameRoll3(f));
            }

            var total = sk.getFrameTotal(f);
            if (total >= 0) {
                var totalStr = toString(total);
                Canvas3D.DrawText2D(canvas, x + fw / 2 - totalStr.Length * 3, startY + 42, totalStr, config.HUD_COLOR_GOLD);
            }
            x = x + fw;
        }
    }

    hide func drawRollText(canvas: Canvas3D, x: Integer, y: Integer, text: String) {
        if (text == "") { return; }
        var color = config.HUD_COLOR_WHITE;
        if (text == "X") { color = config.HUD_COLOR_RED; }
        if (text == "/") { color = config.HUD_COLOR_GREEN; }
        if (text == "-") { color = config.HUD_COLOR_GRAY; }
        Canvas3D.DrawText2D(canvas, x, y, text, color);
    }

    hide func drawStatusPanel(canvas: Canvas3D, cw: Integer,
                              playerCount: Integer, activePlayer: Integer,
                              scoreKeepers: List[ScoreKeeper],
                              oilName: String, ballType: Integer) {
        var panelX = cw - 216;
        // Grow the panel for a second score row when 3-4 players are in.
        var panelH = 104;
        if (playerCount > 2) { panelH = 126; }
        Canvas3D.DrawRoundRect2D(canvas, panelX, 42, 208, panelH, 12,
            config.HUD_COLOR_NAVY, 0.90);
        Canvas3D.DrawRect2D(canvas, panelX + 14, 42, 180, 2, config.HUD_COLOR_MENU_ACCENT);
        Canvas3D.DrawText2DScaled(canvas, panelX + 12, 56, activeName, config.HUD_COLOR_AMBER, 1.0);
        Canvas3D.DrawText2DScaled(canvas, panelX + 12, 78,
            oilName + "  /  " + getBallName(ballType), getBallColor(ballType), 0.88);

        if (playerCount <= 1) {
            Canvas3D.DrawText2DScaled(canvas, panelX + 12, 104,
                "SCORE " + toString(scoreKeepers.get(0).getTotalScore()), config.HUD_COLOR_CYAN, 0.95);
        } else {
            // Up to four seats laid out in a 2x2 grid; the active seat glows gold.
            for (var i: Integer = 0; i < playerCount; i = i + 1) {
                var col = i % 2;
                var row = i / 2;
                var tx = panelX + 12 + col * 96;
                var ty = 104 + row * 20;
                var seatColor = config.HUD_COLOR_WHITE;
                if (i == activePlayer) { seatColor = config.HUD_COLOR_GOLD; }
                Canvas3D.DrawText2DScaled(canvas, tx, ty,
                    "P" + toString(i + 1) + " " + toString(scoreKeepers.get(i).getTotalScore()), seatColor, 0.82);
            }
        }
    }

    hide func getBallName(ballType: Integer) -> String {
        return ballCatalog.get(ballType).getName();
    }

    hide func getBallColor(ballType: Integer) -> Integer {
        return ballCatalog.get(ballType).getColor();
    }
}
