// ============================================================================
// MODULE: engine/game_setup
// PURPOSE: Startup, menu settings, action bindings, audio, and world creation.
// ============================================================================

// game_setup.zia — Game startup and subsystem construction.
module game_setup;

bind Viper.Graphics3D;
bind Viper.Input;
bind Viper.Input.Key as Key;
bind Viper.Audio;
bind Viper.Terminal;
bind "../config";
bind "../menu";
bind "./renderer";
bind "./camera";
bind "./hud";
bind "./game_state";
bind "../lane/lane";
bind "../lane/pins";
bind "../lane/ball";
bind "../effects/particles";
bind "../effects/celebrations";
bind "../scoring/scoring";
bind "../gameplay/release_meter";
bind "../gameplay/shot_watchdog";
bind "../gameplay/feedback_model";
bind "../gameplay/ai_delivery";
bind "../gameplay/impact_batch";
bind "../gameplay/leaves";
bind "../presentation/replay";
bind "../progression/profile";
bind "../presentation/bowler";

/// @brief Startup layer for the bowling controller.
class BowlingGameSetup extends BowlingGameState {
    /// @brief Main entry. Print banner, initialize, enter loop, exit cleanly.
    expose func run() {
        printBanner();
        initSubsystems();
        gameLoop();
        if (soundReady) { Mixer.Shutdown(); }
        Say("Thanks for playing Neon Lanes Championship!");
    }

    /// @brief Boxed splash text printed to the terminal at startup.
    hide func printBanner() {
        Say("╔══════════════════════════════════════╗");
        Say("║       NEON LANES CHAMPIONSHIP        ║");
        Say("║  Arcade precision. Ten-pin physics.  ║");
        Say("╚══════════════════════════════════════╝");
        Say("");
    }

    /// @brief Construct every subsystem in dependency order; show title.
    hide func initSubsystems() {
        menuObj = new BowlingMenu();
        oilPattern = menuObj.getOilPattern();
        qualityMode = menuObj.getQualityMode();
        currentMode = menuObj.getPreferredMode();

        render = new Renderer();
        render.initRenderer(qualityMode);

        camCtrl = new CameraController();
        camCtrl.initCamera(render.getCamera());

        hudObj = new HUD();
        hudObj.initHUD();

        releaseMeter = new ReleaseMeter();
        releaseMeter.reset(getReleaseAssist());
        shotWatchdog = new ShotWatchdog();
        shotWatchdog.reset(config.BALL_THROW_Z);
        throwResumeGate = new ThrowResumeGate();
        throwResumeGate.reset();
        feedbackModel = new FeedbackModel();
        impactBatch = new ImpactBatch();
        impactBatch.reset(false);
        aiDeliveryModel = new AiDeliveryModel();
        leaveAnalyzer = new LeaveAnalyzer();
        replayRecorder = new ReplayRecorder();
        bowlerAvatar = new BowlerAvatar();

        initSound();
        setupActions();
        showTitleScreen();
    }

    /// @brief Bind every named action to keys + gamepad inputs.
    hide func setupActions() {
        Action.Clear();
        Action.LoadPreset("menu_navigation");
        Action.BindKey(config.ACT_MENU_UP, Key.W);
        Action.BindKey(config.ACT_MENU_UP, Key.Up);
        Action.BindKey(config.ACT_MENU_DOWN, Key.S);
        Action.BindKey(config.ACT_MENU_DOWN, Key.Down);
        Action.BindKey(config.ACT_CONFIRM, Key.Enter);
        Action.BindKey(config.ACT_CONFIRM, Key.Space);
        Action.BindKey(config.ACT_BACK, Key.Escape);
        Action.BindPadButton(config.ACT_MENU_UP, -1, Pad.get_ButtonUp());
        Action.BindPadButton(config.ACT_MENU_DOWN, -1, Pad.get_ButtonDown());
        Action.BindPadButton(config.ACT_CONFIRM, -1, Pad.get_ButtonA());
        Action.BindPadButton(config.ACT_BACK, -1, Pad.get_ButtonB());
        Action.BindPadButton(config.ACT_BACK, -1, Pad.get_ButtonStart());

        Action.DefineAxis(config.ACT_STANCE_X);
        Action.BindKeyAxis(config.ACT_STANCE_X, Key.A, -1.0);
        Action.BindKeyAxis(config.ACT_STANCE_X, Key.D, 1.0);
        Action.BindPadAxis(config.ACT_STANCE_X, -1, Action.get_AxisLeftX(), 0.16);

        Action.DefineAxis(config.ACT_TARGET_X);
        Action.BindKeyAxis(config.ACT_TARGET_X, Key.Left, -1.0);
        Action.BindKeyAxis(config.ACT_TARGET_X, Key.Right, 1.0);
        Action.BindPadButtonAxis(config.ACT_TARGET_X, -1, Pad.get_ButtonLeft(), -1.0);
        Action.BindPadButtonAxis(config.ACT_TARGET_X, -1, Pad.get_ButtonRight(), 1.0);

        Action.DefineAxis(config.ACT_SPIN_X);
        if (menuObj.getControlPreset() == 1) {
            Action.BindKeyAxis(config.ACT_SPIN_X, Key.Q, 1.0);
            Action.BindKeyAxis(config.ACT_SPIN_X, Key.E, -1.0);
            Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_ButtonLeftBumper(), 1.0);
            Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_ButtonRightBumper(), -1.0);
        } else {
            Action.BindKeyAxis(config.ACT_SPIN_X, Key.Q, -1.0);
            Action.BindKeyAxis(config.ACT_SPIN_X, Key.E, 1.0);
            Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_ButtonLeftBumper(), -1.0);
            Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_ButtonRightBumper(), 1.0);
        }

        Action.Define(config.ACT_THROW);
        Action.BindKey(config.ACT_THROW, Key.Space);
        Action.BindPadButton(config.ACT_THROW, -1, Pad.get_ButtonA());

        Action.Define(config.ACT_SPARE_RELEASE);
        Action.BindKey(config.ACT_SPARE_RELEASE, Key.F);
        Action.BindPadButton(config.ACT_SPARE_RELEASE, -1, Pad.get_ButtonX());

        Action.Define(config.ACT_BALL_PREV);
        Action.BindKey(config.ACT_BALL_PREV, Key.Digit1);
        Action.BindPadButton(config.ACT_BALL_PREV, -1, Pad.get_ButtonLeftStick());

        Action.Define(config.ACT_BALL_NEXT);
        Action.BindKey(config.ACT_BALL_NEXT, Key.Digit3);
        Action.BindPadButton(config.ACT_BALL_NEXT, -1, Pad.get_ButtonRightStick());

        Action.Define(config.ACT_RESET);
        Action.BindKey(config.ACT_RESET, Key.R);

        Action.Define(config.ACT_PAUSE);
        Action.BindKey(config.ACT_PAUSE, Key.P);
        Action.BindPadButton(config.ACT_PAUSE, -1, Pad.get_ButtonStart());

        Action.Define(config.ACT_CAMERA);
        Action.BindKey(config.ACT_CAMERA, Key.C);
        Action.BindPadButton(config.ACT_CAMERA, -1, Pad.get_ButtonY());
    }

    /// @brief Initialize the audio system and load the SFX bank.
    /// @note Gracefully degrades on systems without audio.
    hide func initSound() {
        var ok = Mixer.Init();
        if (ok == 0) {
            Say("Audio unavailable — continuing without sound");
            return;
        }

        Mixer.SetMasterVolume(menuObj.getMasterVolume());
        soundBank = SoundBank.New();
        soundBank.RegisterSound("roll_soft", Synth.Noise(360, 12));
        soundBank.RegisterSound("roll_medium", Synth.Noise(520, 24));
        soundBank.RegisterSound("roll_hard", Synth.Noise(680, 38));
        soundBank.RegisterSound("pins_soft", Synth.Noise(120, 34));
        soundBank.RegisterSound("pins_medium", Synth.Noise(210, 72));
        soundBank.RegisterSound("pins_hard", Synth.Noise(280, 108));
        soundBank.RegisterSound("strike", Synth.Sweep(420, 1480, 520, 1));
        soundBank.RegisterSound("spare", Synth.Sweep(520, 1080, 280, 1));
        soundBank.RegisterSound("gutter", Synth.Sweep(240, 90, 340, 2));
        soundBank.RegisterSound("ui", Synth.Tone(680, 48, 1));
        soundBank.RegisterSound("release", Synth.Sweep(180, 480, 90, 0));
        soundBank.RegisterSound("perfect", Synth.Tone(1040, 110, 1));
        soundBank.RegisterSound("victory", Synth.Sweep(360, 1420, 620, 1));
        soundBank.RegisterSound("defeat", Synth.Sweep(460, 120, 520, 2));
        soundBank.RegisterSound("crowd_strike", Synth.Noise(720, 58));
        soundBank.RegisterSound("crowd_spare", Synth.Noise(420, 34));
        soundBank.RegisterSound("sweep", Synth.Noise(620, 18));
        soundBank.RegisterSound("pinsetter", Synth.Sweep(110, 260, 240, 0));
        soundBank.RegisterSound("venue_ambience", Synth.Noise(4800, 8));
        buildMusic();
        soundReady = true;
        startMusic(0);
    }

    /// @brief Build original menu/gameplay loops with the dependency-free synth.
    hide func buildMusic() {
        var menuSong = MusicGen.New(92);
        var pad = menuSong.AddChannel(0);
        var pulse = menuSong.AddChannel(3);
        menuSong.SetEnvelope(pad, 220, 180, 65, 320);
        menuSong.SetEnvelope(pulse, 8, 55, 40, 70);
        menuSong.SetPan(pad, -18);
        menuSong.SetPan(pulse, 22);
        menuSong.AddNote(pad, 0, 48, 800);
        menuSong.AddNote(pad, 800, 44, 800);
        menuSong.AddNote(pad, 1600, 51, 800);
        menuSong.AddNote(pad, 2400, 46, 800);
        var p = 0;
        while (p < 3200) {
            menuSong.AddNote(pulse, p, 72 + (p / 100) % 5, 42);
            p = p + 100;
        }
        menuSong.Length = 3200;
        menuSong.SetLoopable(true);
        var menuTrack = menuSong.Build();
        if (menuTrack != null) { soundBank.RegisterSound("music_menu", menuTrack); }

        var gameSong = MusicGen.New(118);
        var bass = gameSong.AddChannel(2);
        var keys = gameSong.AddChannel(3);
        gameSong.SetEnvelope(bass, 8, 80, 70, 90);
        gameSong.SetEnvelope(keys, 5, 70, 45, 100);
        gameSong.SetSwing(54);
        var beat = 0;
        while (beat < 2400) {
            gameSong.AddNote(bass, beat, 36 + (beat / 600) * 2, 180);
            gameSong.AddNote(keys, beat + 50, 60 + (beat / 200) % 7, 90);
            beat = beat + 200;
        }
        gameSong.Length = 2400;
        gameSong.SetLoopable(true);
        var gameTrack = gameSong.Build();
        if (gameTrack != null) { soundBank.RegisterSound("music_game", gameTrack); }
    }

    hide func startMusic(state: Integer) {
        if (soundReady == false || state == musicState) { return; }
        Mixer.StopAllSounds();
        var trackName = "music_menu";
        if (state == 1) { trackName = "music_game"; }
        if (soundBank.Has(trackName)) {
            var track = soundBank.Get(trackName);
            track.PlayLoop(menuObj.getMusicVolume(), 0);
        }
        if (soundBank.Has("venue_ambience")) {
            var ambience = soundBank.Get("venue_ambience");
            ambience.PlayLoop(menuObj.getEffectsVolume() / 7, 0);
        }
        musicState = state;
    }

    hide func refreshMusic(state: Integer) {
        musicState = -1;
        startMusic(state);
    }

    /// @brief Play a 2D SFX. No-op if audio failed to initialize.
    hide func playSound(name: String) {
        if (soundReady) {
            soundBank.Play(name, menuObj.getEffectsVolume(), 0);
        }
    }

    /// @brief Play a 3D positional SFX with distance falloff.
    hide func playSpatialSound(name: String, pos: Vec3, maxDistance: Float, volume: Integer) {
        if (soundReady == false) { return; }
        var scaled = volume * menuObj.getEffectsVolume() / 100;
        SpatialAudio3D.PlayAt(soundBank.Get(name), pos, maxDistance, scaled);
    }

    /// @brief Sync the 3D audio listener to the camera each frame.
    hide func updateAudioListener() {
        if (soundReady == false) { return; }
        SpatialAudio3D.SetListener(render.getCamera().Position,
            render.getCamera().Forward);
    }

    /// @brief Build a fresh physics world plus lane / pins / ball /
    ///        particle / celebration managers; wire up env reflections.
    hide func createGameplayWorld() {
        clearGameplayWorld();
        physWorld = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
        // More solver passes stabilize the 10-pin contact island so a hit
        // rack resolves cleanly and pins carry into each other (default 6).
        PhysicsWorld3D.set_SolverIterations(physWorld, 12);

        laneObj = new LaneBuilder();
        laneObj.initLane(physWorld, oilPattern);

        pinMgr = new PinManager();
        pinMgr.initPins(physWorld);
        pinMgr.applyHighContrast(menuObj.getHighContrast());
        pinMgr.savePinState();

        ballObj = new Ball();
        ballObj.initBall(physWorld);
        ballObj.setUnlockScore(menuObj.getBestScore());
        ballObj.selectBall(menuObj.getSelectedBall());

        particleMgr = new ParticleManager();
        particleMgr.initParticles();
        particleMgr.applySoftParticles(render.getCanvas().BackendSupports("soft-particles"));

        celebMgr = new CelebrationManager();
        celebMgr.initCelebrations();
        celebMgr.setReducedFlash(menuObj.getReducedFlash());

        var env = render.getSkybox();
        laneObj.applyEnvironment(env);
        pinMgr.applyEnvironment(env);
        ballObj.applyEnvironment(env);
    }

    /// @brief Drop all references owned by the previous gameplay world.
    hide func clearGameplayWorld() {
        if (replayRecorder != null) { replayRecorder.clear(); }
        if (particleMgr != null) { particleMgr.clear(); }
        if (celebMgr != null) { celebMgr.clear(); }
        ballObj = null;
        pinMgr = null;
        laneObj = null;
        particleMgr = null;
        celebMgr = null;
        physWorld = null;
    }

    /// @brief Allocate one fresh ScoreKeeper (and default name) per player.
    hide func initScoreKeepers() {
        scoreKeepers = [];
        playerNames = [];
        playerProfiles = [];
        for (var i: Integer = 0; i < playerCount; i = i + 1) {
            var keeper = new ScoreKeeper();
            keeper.init();
            if ((currentMode == config.MODE_CHALLENGE && challengeId == 2) ||
                currentMode == config.MODE_PARTY) {
                keeper.startAtTenthFrame();
            }
            scoreKeepers.add(keeper);
            var profileName = defaultProfileName(i);
            if (currentMode == config.MODE_CHAMPIONSHIP && i == 1) {
                profileName = championshipOpponent();
            }
            playerNames.add(profileName);
            var profileColor = 0x56CFE1;
            if (i == 1) { profileColor = 0xFFB547; }
            if (i == 2) { profileColor = 0xEF476F; }
            if (i == 3) { profileColor = 0x2EDB9B; }
            var profile = new PlayerProfile(profileName, i, profileColor,
                menuObj.getControlPreset() == 1,
                menuObj.getAssistLevel());
            profile.setSelectedBall(menuObj.getSelectedBall());
            playerProfiles.add(profile);
        }
    }

    hide func defaultProfileName(index: Integer) -> String {
        if (index == 1) { return "Blake"; }
        if (index == 2) { return "Casey"; }
        if (index == 3) { return "Devon"; }
        return "Avery";
    }

    hide func championshipOpponent() -> String {
        if (careerTier >= 2) { return "Nova King"; }
        if (careerTier == 1) { return "Mateo Cruz"; }
        return "Riley Chen";
    }

    /// @brief Pull oilPattern / qualityMode from the menu and apply.
    hide func applyMenuSettings() {
        oilPattern = menuObj.getOilPattern();
        difficulty = menuObj.getDifficulty();
        if (menuObj.getBumpers()) { config.BUMPERS_ENABLED = 1; }
        else { config.BUMPERS_ENABLED = 0; }
        qualityMode = menuObj.getQualityMode();
        render.applyQuality(qualityMode);
        if (camCtrl != null) { camCtrl.setReducedMotion(menuObj.getReducedMotion()); }
        if (replayRecorder != null) { replayRecorder.setReducedMotion(menuObj.getReducedMotion()); }
        if (celebMgr != null) { celebMgr.setReducedFlash(menuObj.getReducedFlash()); }
        if (hudObj != null) {
            hudObj.setAccessibility(menuObj.getHighContrast(), menuObj.getLargeHud());
        }
        if (bowlerAvatar != null) {
            bowlerAvatar.setReducedMotion(menuObj.getReducedMotion());
        }
        if (soundReady) { Mixer.SetMasterVolume(menuObj.getMasterVolume()); }
    }

    /// @brief Reset to TITLE-screen state with a fresh presentation world.
    hide func showTitleScreen() {
        applyMenuSettings();
        createGameplayWorld();
        screenState = config.SCREEN_TITLE;
        gameState = config.STATE_AIMING;
        aimX = 0.0;
        stanceX = 0.0;
        targetX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        spareRelease = false;
        gutterLatched = false;
        ballHitPinsThisRoll = false;
        watchdogResetShot = false;
        throwResumeGate.reset();
        fixedStepAlpha = 0.0;
        camCtrl.setTitleMode();
        render.applyVenueTheme(config.MODE_SINGLE);
        startMusic(0);
        hudObj.showMessage("Welcome to Neon Lanes.", config.HUD_COLOR_WHITE, config.MSG_DURATION_LONG);
    }

    /// @brief Begin a new match for @p count players (1 = single, 2-4 = versus).
    ///        Resets scoring + per-throw state; keeper count follows playerCount.
    hide func startNewMatch(count: Integer) {
        var mode = config.MODE_SINGLE;
        if (count > 1) { mode = config.MODE_VERSUS; }
        startNewMatchMode(count, mode);
    }

    /// @brief Start an explicit release mode without conflating mode and seats.
    hide func startNewMatchMode(count: Integer, mode: Integer) {
        applyMenuSettings();
        createGameplayWorld();
        laneObj.enableAuthoredSurface(render.getCanvas());

        playerCount = count;
        if (playerCount < 1) { playerCount = 1; }
        if (playerCount > config.MAX_PLAYERS) { playerCount = config.MAX_PLAYERS; }
        currentMode = mode;
        careerTier = 0;
        if (menuObj.getCareerPoints() >= 600) { careerTier = 1; }
        if (menuObj.getCareerPoints() >= 1500) { careerTier = 2; }
        challengeId = menuObj.getChallengeId();
        partyId = menuObj.getPartyId();
        practiceId = menuObj.getPracticeId();
        activePlayer = 0;
        initScoreKeepers();
        matchSeed = 97 + menuObj.getGamesPlayed() * 31 + currentMode * 101;
        rackNumber = 0;
        pinMgr.setRackSeed(currentRackSeed(), difficulty);
        pinMgr.savePinState();
        bowlerAvatar.setColor(playerProfiles.get(0).getColor());
        bowlerAvatar.setLeftHanded(playerProfiles.get(0).getLeftHanded());
        partyScores = [];
        for (var psi: Integer = 0; psi < playerCount; psi = psi + 1) { partyScores.add(0); }

        aimX = 0.0;
        stanceX = 0.0;
        targetX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        spareRelease = false;
        fixedStepAlpha = 0.0;
        settleTimer = 0.0;
        scoreTimer = 0.0;
        impactCooldown = 0.0;
        skidMarkTimer = 0.0;
        lightFlashTimer = 0.0;
        gutterLatched = false;
        ballHitPinsThisRoll = false;
        watchdogResetShot = false;
        throwResumeGate.reset();
        cinematicStarted = false;
        lastReleaseAccuracy = 1.0;
        lastShotSpeed = 0.0;
        lastLeaveName = "Fresh rack";
        lastLeaveDifficulty = 0;
        aiThinkTimer = 0.9;
        matchStrikes = 0;
        matchSpares = 0;
        matchGutters = 0;
        resultsChallengeTier = 0;
        tutorialStep = -1;
        pendingReplayDuration = 0.0;
        if (currentMode == config.MODE_SINGLE && menuObj.getGamesPlayed() == 0) {
            tutorialStep = 0;
        }
        pendingFrameAdvance = false;
        pendingPlayerSwitch = false;
        pendingResults = false;

        screenState = config.SCREEN_PLAYING;
        gameState = config.STATE_AIMING;
        camCtrl.setAimMode(0.0);
        releaseMeter.reset(getReleaseAssist());
        applyPracticeLeave();
        render.applyVenueTheme(currentMode);
        startMusic(1);

        if (currentMode == config.MODE_CHAMPIONSHIP) {
            hudObj.showMessage("Championship match: you versus " + playerNames.get(1) + ".",
                config.HUD_COLOR_GOLD, config.MSG_DURATION_LONG);
        } else if (currentMode == config.MODE_CHALLENGE) {
            hudObj.showMessage("Challenge started. Clean shots earn medals.", config.HUD_COLOR_GOLD, config.MSG_DURATION_LONG);
        } else if (currentMode == config.MODE_PRACTICE) {
            hudObj.showMessage("Practice Lab: experiment with line, ball, and hook.", config.HUD_COLOR_CYAN, config.MSG_DURATION_LONG);
        } else if (currentMode == config.MODE_PARTY) {
            hudObj.showMessage("Cosmic Party: fast frames under neon lights.", config.HUD_COLOR_GOLD, config.MSG_DURATION_LONG);
        } else if (playerCount > 1) {
            hudObj.showMessage("Versus match start. " + playerNames.get(0) + " up.", config.HUD_COLOR_GOLD, config.MSG_DURATION_LONG);
        } else {
            if (tutorialStep == 0) {
                hudObj.showMessage("WELCOME  Move left or right to choose your starting board.",
                    config.HUD_COLOR_CYAN, config.MSG_DURATION_LONG);
            } else {
                hudObj.showMessage("Aim and throw!", config.HUD_COLOR_WHITE, config.MSG_DURATION_LONG);
            }
        }
    }

    /// @brief Re-call startNewMatch with the current player count.
    hide func restartCurrentMatch() {
        startNewMatchMode(playerCount, currentMode);
    }

    hide func getReleaseAssist() -> Float {
        if (menuObj.getAssistLevel() == 0) { return config.RELEASE_ASSIST_OFF; }
        if (menuObj.getAssistLevel() == 2) { return config.RELEASE_ASSIST_FULL; }
        return config.RELEASE_ASSIST_STANDARD;
    }

    hide func currentRackSeed() -> Integer {
        var frame = 1;
        if (scoreKeepers.count() > activePlayer && activePlayer >= 0) {
            frame = scoreKeepers.get(activePlayer).getFrame();
        }
        return matchSeed + activePlayer * 211 + frame * 37 + rackNumber * 73;
    }

    hide func applyPracticeLeave() {
        if (currentMode != config.MODE_PRACTICE || practiceId == 0) { return; }
        var mask = (1 << 6) + (1 << 9);
        if (practiceId == 2) { mask = 1 << 9; }
        if (practiceId == 3) { mask = (1 << 2) + (1 << 5) + (1 << 9); }
        pinMgr.setStandingMask(mask);
        lastLeaveName = leaveAnalyzer.describe(mask);
        lastLeaveDifficulty = leaveAnalyzer.difficulty(mask);
    }
}
