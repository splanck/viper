// ============================================================================
// MODULE: engine/game_scoring
// PURPOSE: Scoring, turn advancement, results, and camera-mode transitions.
// ============================================================================

// game_scoring.zia — Score and match-flow state transitions.
module game_scoring;

bind Viper.Graphics3D;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "../config";
bind "./camera";
bind "./game_flow";
bind "../effects/celebrations";
bind "../scoring/scoring";

/// @brief Scoring and turn flow layer for the bowling controller.
class BowlingGameScoring extends BowlingGameFlow {
    /// @brief STATE_SCORING handler: count pins, fire celebrations, advance state.
    override expose func updateScoring() {
        var current = getActiveScoreKeeper();
        var newlyKnocked = pinMgr.countNewlyKnocked();
        var scoredKnocked = newlyKnocked;
        var trueGutter = ballObj.gutterBall() && ballHitPinsThisRoll == false;
        var forcedWatchdogZero = watchdogResetShot && ballHitPinsThisRoll == false;
        var convertedLeaveDifficulty = lastLeaveDifficulty;
        if (trueGutter || forcedWatchdogZero) {
            scoredKnocked = 0;
            if (newlyKnocked > 0) {
                pinMgr.restoreSavedPinState();
            }
        }
        // In Low Ball a miss is penalized as ten, preventing deliberate gutters.
        if (currentMode == config.MODE_PARTY && partyId == 1 && trueGutter) {
            scoredKnocked = 10;
        }
        if (currentMode == config.MODE_PRACTICE && practiceId > 0) {
            updatePracticeScoring(scoredKnocked, trueGutter, convertedLeaveDifficulty);
            return;
        }
        var frameComplete = current.recordRoll(scoredKnocked);
        var earnedStrike = current.wasStrike();
        if (currentMode == config.MODE_PARTY && partyId == 1 && trueGutter) {
            earnedStrike = false;
        }
        var standingMask = pinMgr.getStandingMask();
        lastLeaveName = leaveAnalyzer.describe(standingMask);
        lastLeaveDifficulty = leaveAnalyzer.difficulty(standingMask);
        if (current.wasSpare()) { lastLeaveName = "Spare converted"; }

        if (trueGutter) {
            celebMgr.onGutter();
        } else if (earnedStrike) {
            celebMgr.onStrike(current.getConsecutiveStrikes());
            bowlerAvatar.celebrate();
            particleMgr.spawnFireworks();
            camCtrl.shake(config.SHAKE_STRIKE_INTENSITY *
                (menuObj.getCameraShake() + 0.0) / 100.0, config.SHAKE_STRIKE_DURATION);
            render.flashPinLight(3.0);
            lightFlashTimer = 0.40;
            playSound("strike");
            playSound("crowd_strike");
            if (menuObj.getReplayMode() != 0) { pendingReplayDuration = 2.15; }
            if (current.isGameOver() && current.getTotalScore() == config.MAX_SCORE) {
                celebMgr.onPerfectGame();
                playSound("perfect");
            }
        } else if (current.wasSpare()) {
            celebMgr.onSpare();
            bowlerAvatar.celebrate();
            playSound("spare");
            playSound("crowd_spare");
            if (menuObj.getReplayMode() != 0 && convertedLeaveDifficulty >= 1) {
                pendingReplayDuration = 1.35;
            }
        } else {
            celebMgr.onOpenFrame();
        }

        if (activePlayer == 0) {
            var statsPins = scoredKnocked;
            if (trueGutter) { statsPins = 0; }
            menuObj.recordRollStats(statsPins, earnedStrike, current.wasSpare(), trueGutter);
        }
        if (currentMode == config.MODE_PARTY && partyId == 2 && trueGutter == false) {
            var precision = Convert.NumToInt(lastReleaseAccuracy * 10.0);
            var pocket = 0;
            var angleMagnitude = Abs(lastEntryAngle);
            if (angleMagnitude >= 2.0 && angleMagnitude <= 6.5) { pocket = 10; }
            partyScores.set(activePlayer,
                partyScores.get(activePlayer) + scoredKnocked + precision + pocket);
        }
        if (earnedStrike) { matchStrikes = matchStrikes + 1; }
        if (current.wasSpare()) { matchSpares = matchSpares + 1; }
        if (trueGutter) { matchGutters = matchGutters + 1; }
        if (activePlayer == 0) {
            if (earnedStrike) { unlockAchievement(0, "FIRST STRIKE"); }
            if (current.wasSpare()) { unlockAchievement(1, "SPARE ARTIST"); }
            if (current.getConsecutiveStrikes() >= 3) { unlockAchievement(2, "TURKEY TIME"); }
            if (current.getTotalScore() >= 100) { unlockAchievement(3, "CENTURY CLUB"); }
            if (current.wasSpare() && convertedLeaveDifficulty >= 2) {
                unlockAchievement(4, "SPLIT DECISION");
            }
        }

        pinMgr.savePinState();
        // Bonus balls after a tenth-frame strike or spare require a fresh rack
        // even though the frame itself remains active.
        pendingFrameAdvance = frameComplete || current.needsFullReset();
        pendingPlayerSwitch = frameComplete && playerCount > 1;
        pendingResults = frameComplete && allPlayersFinished();
        scoreTimer = 0.75;
        cinematicStarted = false;

        Say(getPlayerLabel(activePlayer) + "  Frame " + toString(current.getFrame())
            + "  Total " + toString(current.getTotalScore()));

        pinMgr.startSweep();
        playSound("sweep");
        gameState = config.STATE_SWEEPING;
    }

    /// @brief Resolve one repeatable spare drill without advancing ten-frame scoring.
    hide func updatePracticeScoring(pinsDown: Integer, gutter: Boolean,
                                    drillDifficulty: Integer) {
        var target = 2;
        if (practiceId == 2) { target = 1; }
        if (practiceId == 3) { target = 3; }
        var converted = gutter == false && pinsDown >= target;
        if (converted) {
            celebMgr.onSpare();
            bowlerAvatar.celebrate();
            playSound("spare");
            playSound("crowd_spare");
            hudObj.showMessage("DRILL CONVERTED  " + lastLeaveName,
                config.HUD_COLOR_GREEN, config.MSG_DURATION_LONG);
            if (menuObj.getReplayMode() != 0 && drillDifficulty >= 2) {
                pendingReplayDuration = 1.55;
            }
            if (drillDifficulty >= 2) { unlockAchievement(4, "SPLIT DECISION"); }
            matchSpares = matchSpares + 1;
        } else if (gutter) {
            celebMgr.onGutter();
        } else {
            celebMgr.onOpenFrame();
            hudObj.showMessage("RESETTING DRILL  adjust the spare line",
                config.HUD_COLOR_GRAY, config.MSG_DURATION_SHORT);
        }
        if (activePlayer == 0) {
            menuObj.recordRollStats(pinsDown, false, converted, gutter);
        }
        pendingFrameAdvance = true;
        pendingPlayerSwitch = false;
        pendingResults = false;
        scoreTimer = 0.55;
        cinematicStarted = false;
        pinMgr.startSweep();
        playSound("sweep");
        gameState = config.STATE_SWEEPING;
    }

    /// @brief STATE_SWEEPING update: advance sweep bar, transition when done.
    override expose func updateSweeping(dt: Float) {
        if (pinMgr.updateSweep(dt)) {
            if (pendingFrameAdvance) {
                if (currentMode != config.MODE_PRACTICE) {
                    rackNumber = rackNumber + 1;
                }
                pinMgr.setRackSeed(currentRackSeed(), difficulty);
                pinMgr.startFullReset();
                playSound("pinsetter");
                gameState = config.STATE_RESETTING;
            } else {
                pinMgr.prepareSecondRoll();
                playSound("pinsetter");
                gameState = config.STATE_CELEBRATING;
            }
        }
    }

    /// @brief STATE_RESETTING update: rack-drop animation.
    override expose func updateResetting(dt: Float) {
        if (pinMgr.updateReset(dt)) {
            applyPracticeLeave();
            gameState = config.STATE_CELEBRATING;
        }
    }

    /// @brief STATE_CELEBRATING update: tick celebration manager + cinematic camera.
    override expose func updateCelebrating(dt: Float) {
        if (pendingReplayDuration > 0.0) {
            replayRecorder.start(pendingReplayDuration);
            pendingReplayDuration = 0.0;
        }
        replayRecorder.update(dt);
        if (celebMgr.isActive()) {
            var ctype = celebMgr.getType();
            if (cinematicStarted == false &&
                (ctype == celebrations.STRIKE || ctype == celebrations.TURKEY || ctype == celebrations.PERFECT)) {
                camCtrl.startCinematic(0.0, config.PIN_Z_OFFSET);
                cinematicStarted = true;
            }
            if (cinematicStarted) {
                camCtrl.updateCinematic(dt);
            }
        }

        scoreTimer = scoreTimer - dt;
        if (scoreTimer <= 0.0 && celebMgr.isActive() == false) {
            render.resetPinLight();
            if (pendingResults && allPlayersFinished()) {
                openResultsScreen();
                return;
            }

            if (pendingPlayerSwitch) {
                advanceToNextPlayer();
            }
            prepareNextTurn();
        }
    }

    /// @brief Reset ball + camera + per-throw flags for the next roll.
    hide func prepareNextTurn() {
        ballObj.resetBall();
        applyPracticeLeave();
        power = 0.0;
        charging = false;
        releaseMeter.reset(getReleaseAssist());
        aiThinkTimer = 0.75;
        fixedStepAlpha = 0.0;
        gutterLatched = false;
        ballHitPinsThisRoll = false;
        watchdogResetShot = false;
        throwResumeGate.reset();
        cinematicStarted = false;
        pendingReplayDuration = 0.0;
        pendingFrameAdvance = false;
        pendingPlayerSwitch = false;
        pendingResults = false;
        gameState = config.STATE_AIMING;
        ballObj.setSetupPosition(stanceX);
        camCtrl.setAimMode(stanceX);

        var current = getActiveScoreKeeper();
        hudObj.showMessage(getPlayerLabel(activePlayer) + "  Frame " + toString(current.getFrame())
            + "  Roll " + toString(current.getRollInFrame()), config.HUD_COLOR_WHITE, config.MSG_DURATION_SHORT);
    }

    /// @brief Hot-seat handover: advance round-robin to the next seat that is
    ///        still bowling. Skipping finished players keeps the rotation correct
    ///        when someone completes their 10th frame before the others (the
    ///        bonus-ball desync case). If everyone else is done the seat holds
    ///        and the results screen takes over.
    hide func advanceToNextPlayer() {
        if (playerCount <= 1) {
            activePlayer = 0;
            return;
        }
        for (var step: Integer = 1; step <= playerCount; step = step + 1) {
            var candidate = (activePlayer + step) % playerCount;
            if (scoreKeepers.get(candidate).isGameOver() == false) {
                activePlayer = candidate;
                ballObj.selectBall(playerProfiles.get(activePlayer).getSelectedBall());
                bowlerAvatar.setColor(playerProfiles.get(activePlayer).getColor());
                bowlerAvatar.setLeftHanded(playerProfiles.get(activePlayer).getLeftHanded());
                return;
            }
        }
    }

    /// @brief True when every active player has completed all 10 frames.
    hide func allPlayersFinished() -> Boolean {
        for (var i: Integer = 0; i < playerCount; i = i + 1) {
            if (scoreKeepers.get(i).isGameOver() == false) {
                return false;
            }
        }
        return true;
    }

    /// @brief Compute final standings, persist stats, transition to results.
    /// @details Snapshots each seat's total, ranks the seats best-first, and
    ///          decides a winner (or tie for first). Best-score stat still tracks
    ///          Player 1's single-game total only, matching the pre-hot-seat rule.
    hide func openResultsScreen() {
        resultsScores = [];
        for (var i: Integer = 0; i < playerCount; i = i + 1) {
            if (currentMode == config.MODE_PARTY && partyId == 2) {
                resultsScores.add(partyScores.get(i));
            } else {
                resultsScores.add(scoreKeepers.get(i).getTotalScore());
            }
        }

        // Selection-sort seat indices into best-first order via a used mask.
        resultsRanking = [];
        var used: List[Boolean] = [];
        for (var i: Integer = 0; i < playerCount; i = i + 1) { used.add(false); }
        for (var r: Integer = 0; r < playerCount; r = r + 1) {
            var bestIdx = -1;
            var bestScore = -1;
            var lowBall = currentMode == config.MODE_PARTY && partyId == 1;
            if (lowBall) { bestScore = 10000; }
            for (var i: Integer = 0; i < playerCount; i = i + 1) {
                var better = resultsScores.get(i) > bestScore;
                if (lowBall) { better = resultsScores.get(i) < bestScore; }
                if (used.get(i) == false && better) {
                    bestScore = resultsScores.get(i);
                    bestIdx = i;
                }
            }
            used.set(bestIdx, true);
            resultsRanking.add(bestIdx);
        }

        var topPlayer = resultsRanking.get(0);
        var topScore = resultsScores.get(topPlayer);
        var previousBest = menuObj.getBestScore();
        var p1Score = scoreKeepers.get(0).getTotalScore();

        menuObj.recordFinishedMatch(p1Score, currentMode);
        resultsNewHigh = (currentMode == config.MODE_SINGLE) && (p1Score > previousBest);
        if (p1Score == config.MAX_SCORE) { unlockAchievement(5, "PERFECT 300"); }

        resultsChallengeTier = 0;
        if (currentMode == config.MODE_CHALLENGE) {
            if (challengeId == 0) {
                if (p1Score >= 140) { resultsChallengeTier = 1; }
                if (p1Score >= 180) { resultsChallengeTier = 2; }
                if (p1Score >= 220) { resultsChallengeTier = 3; }
            } else if (challengeId == 1) {
                if (matchSpares >= 3) { resultsChallengeTier = 1; }
                if (matchSpares >= 5) { resultsChallengeTier = 2; }
                if (matchSpares >= 7) { resultsChallengeTier = 3; }
            } else {
                if (p1Score >= 20) { resultsChallengeTier = 1; }
                if (p1Score >= 25) { resultsChallengeTier = 2; }
                if (p1Score >= 30) { resultsChallengeTier = 3; }
            }
            if (menuObj.awardChallenge(challengeId, resultsChallengeTier)) {
                unlockAchievement(6, "CHALLENGE MEDAL");
            }
        }

        // Winner is the top seat unless it ties the runner-up.
        resultsWinner = topPlayer;
        if (playerCount > 1 && resultsScores.get(resultsRanking.get(1)) == topScore) {
            resultsWinner = -1;
        }

        var resultsToast = "Final score: " + toString(p1Score);
        if (playerCount > 1) {
            if (resultsWinner < 0) {
                resultsToast = "Tie game";
            } else {
                resultsToast = getPlayerLabel(resultsWinner) + " wins";
            }
        } else if (resultsNewHigh) {
            resultsToast = "New high score";
        }
        if (currentMode == config.MODE_CHAMPIONSHIP && resultsWinner == 0) {
            menuObj.recordCareerWin();
            unlockAchievement(7, "TOUR VICTORY");
        }

        var positiveResult = true;
        if (currentMode == config.MODE_CHAMPIONSHIP && resultsWinner != 0) {
            positiveResult = false;
        }
        if (currentMode == config.MODE_CHALLENGE && resultsChallengeTier == 0) {
            positiveResult = false;
        }
        if (positiveResult) { playSound("victory"); }
        else { playSound("defeat"); }

        screenState = config.SCREEN_RESULTS;
        camCtrl.setTitleMode();
        hudObj.showMessage(resultsToast, config.HUD_COLOR_GOLD, config.MSG_DURATION_RESULTS);
    }

    /// @brief Cycle through aim/follow/overhead camera presets.
    override expose func cycleCameraMode() {
        if (gameState == config.STATE_AIMING) {
            if (camCtrl.getMode() == camera.MODE_OVERHEAD) {
                camCtrl.setAimMode(aimX);
                hudObj.showMessage("Approach camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            } else {
                camCtrl.setOverheadMode();
                hudObj.showMessage("Overhead preview", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            }
            return;
        }

        if (gameState == config.STATE_ROLLING || gameState == config.STATE_SETTLING || gameState == config.STATE_CELEBRATING) {
            if (camCtrl.getMode() == camera.MODE_OVERHEAD) {
                camCtrl.setRollMode();
                hudObj.showMessage("Lane camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            } else {
                camCtrl.setOverheadMode();
                hudObj.showMessage("Overhead camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            }
        }
    }

    hide func unlockAchievement(id: Integer, title: String) {
        if (menuObj.unlockAchievement(id)) {
            hudObj.queueMessage("ACHIEVEMENT  " + title,
                config.HUD_COLOR_AMBER, config.MSG_DURATION_LONG);
        }
    }

    /// @brief ScoreKeeper for the player currently on the lane.
    hide func getActiveScoreKeeper() -> ScoreKeeper {
        return scoreKeepers.get(activePlayer);
    }

    /// @brief Display label ("Player N") for a seat index.
    hide func getPlayerLabel(index: Integer) -> String {
        if (index < 0 || index >= playerNames.count()) { return "Player"; }
        return playerNames.get(index);
    }
}
