//
// File: examples/games/3dbowling/lifecycle_probe.zia
// Purpose: Stress-tests repeated world construction and bounded presentation resources.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: lifecycle_probe
// PURPOSE: Standalone 50-transition stress contract for bounded replay/effect
//          state and explicit gameplay-world reference replacement.
// ============================================================================

module lifecycle_probe;

bind Viper.Graphics3D;
bind Viper.Audio;
bind Viper.Terminal;
bind "./config";
bind "./menu";
bind "./game";

class LifecycleBowlingProbe extends BowlingGame {
    expose func verifyTransitions() -> Boolean {
        initSubsystems();
        for (var cycle: Integer = 0; cycle < 50; cycle = cycle + 1) {
            var mode = cycle % 6;
            var seats = 1;
            if (mode == config.MODE_CHAMPIONSHIP) { seats = 2; }
            startNewMatchMode(seats, mode);
            if (replayRecorder.getSampleCount() != 0 ||
                particleMgr.getDecalCount() != 0) {
                Say("FAIL: fresh gameplay world retained bounded state");
                return false;
            }

            replayRecorder.beginCapture();
            replayRecorder.captureScene(ballObj.getPosition(), pinMgr);
            replayRecorder.captureScene(ballObj.getPosition(), pinMgr);
            particleMgr.spawnSkidMark(0.0, 4.0);

            if (cycle % 2 == 0) { showTitleScreen(); }
            else { restartCurrentMatch(); }
            if (replayRecorder.getSampleCount() != 0 ||
                particleMgr.getDecalCount() != 0) {
                Say("FAIL: world transition did not clear capture/effects");
                return false;
            }
        }
        clearGameplayWorld();
        return true;
    }
}

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var probe = new LifecycleBowlingProbe();
    if (probe.verifyTransitions() == false) {
        Say("RESULT: fail");
        return;
    }
    Mixer.Shutdown();
    Say("RESULT: ok");
}
