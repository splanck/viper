//
// File: examples/games/3dbowling/trajectory_probe.zia
// Purpose: Calibrates physical delivery outcomes across rack, line, power, and timing matrices.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
module trajectory_probe;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./lane/lane";
bind "./lane/pins";
bind "./lane/ball";
bind "./gameplay/impact_batch";

var impactBatch = new ImpactBatch();
var lastShotMask: Integer = 0;
var lastLaunchVX: Float = 0.0;
var lastLaunchVZ: Float = 0.0;

func processImpacts(world: PhysicsWorld3D, pinMgr: PinManager, rackArmed: Boolean) -> Boolean {
    var count = PhysicsWorld3D.get_CollisionEventCount(world);
    impactBatch.reset(rackArmed);
    // Pass one establishes cascade eligibility for the whole step. Event
    // ordering may never decide whether an earlier pin-pin hit is accepted.
    for (var i: Integer = 0; i < count; i = i + 1) {
        var evt = PhysicsWorld3D.GetCollisionEvent(world, i);
        var bodyA = CollisionEvent3D.get_BodyA(evt);
        var bodyB = CollisionEvent3D.get_BodyB(evt);
        var layerA = PhysicsBody3D.get_CollisionLayer(bodyA);
        var layerB = PhysicsBody3D.get_CollisionLayer(bodyB);
        impactBatch.scanPair(layerA, layerB,
            CollisionEvent3D.get_IsTrigger(evt));
    }
    impactBatch.finishScan();
    for (var i: Integer = 0; i < count; i = i + 1) {
        var evt = PhysicsWorld3D.GetCollisionEvent(world, i);
        if (CollisionEvent3D.get_IsTrigger(evt)) { continue; }
        var bodyA = CollisionEvent3D.get_BodyA(evt);
        var bodyB = CollisionEvent3D.get_BodyB(evt);
        var layerA = PhysicsBody3D.get_CollisionLayer(bodyA);
        var layerB = PhysicsBody3D.get_CollisionLayer(bodyB);
        var posA = PhysicsBody3D.get_Position(bodyA);
        var posB = PhysicsBody3D.get_Position(bodyB);
        var point = new Vec3(
            (Vec3.get_X(posA) + Vec3.get_X(posB)) * 0.5,
            (Vec3.get_Y(posA) + Vec3.get_Y(posB)) * 0.5,
            (Vec3.get_Z(posA) + Vec3.get_Z(posB)) * 0.5);
        if (CollisionEvent3D.get_ContactCount(evt) > 0) {
            var cp = CollisionEvent3D.GetContactPoint(evt, 0);
            point = new Vec3(Vec3.get_X(cp), Vec3.get_Y(cp), Vec3.get_Z(cp));
        }
        var impulse = CollisionEvent3D.get_NormalImpulse(evt);
        var speed = CollisionEvent3D.get_RelativeSpeed(evt);
        if (impactBatch.shouldRegisterPin(layerA, layerB)) {
            pinMgr.registerImpact(bodyA, point, impulse, speed);
        }
        if (impactBatch.shouldRegisterPin(layerB, layerA)) {
            pinMgr.registerImpact(bodyB, point, impulse, speed);
        }
    }
    return impactBatch.sawBallPinContact();
}

func updateGutter(ballObj: Ball, sawBallPin: Boolean) {
    if (ballObj.thrown() == false || ballObj.gutterBall()) { return; }
    if (config.GUTTER_ENABLED == 0) { return; }
    if (sawBallPin) { return; }
    var pos = ballObj.getPosition();
    var px = Vec3.get_X(pos);
    var py = Vec3.get_Y(pos);
    var pz = Vec3.get_Z(pos);
    // Mirror game_flow.updateTriggerZones: gutter once the ball's centre
    // crosses the lane edge, or it drops off the surface into the trough.
    var laneHalf = config.LANE_WIDTH / 2.0;
    var edgeCommit = laneHalf + config.BALL_RADIUS * 0.15;
    var dropEdge = laneHalf - config.BALL_RADIUS * 0.35;
    var side = 0;
    if (pz > config.GUTTER_DETECT_Z && pz < config.GUTTER_DETECT_END_Z) {
        if (px < -edgeCommit) { side = -1; }
        if (px > edgeCommit) { side = 1; }
        if (py < config.BALL_RADIUS * 0.72) {
            if (px < -dropEdge) { side = -1; }
            if (px > dropEdge) { side = 1; }
        }
    }
    if (side != 0) {
        ballObj.markGutter(side);
    }
}

func checkIdleRack() -> Boolean {
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);
    var pinMgr = new PinManager();
    pinMgr.initPins(world);

    for (var step: Integer = 0; step < 240; step = step + 1) {
        PhysicsWorld3D.Step(world, config.PHYSICS_DT);
        pinMgr.updateKnockdowns(config.PHYSICS_DT);
    }

    var knocked = pinMgr.countTotalKnocked();
    var maxDisp = pinMgr.maxStandingDisplacement();
    var maxSpeed = pinMgr.maxBodySpeed();
    Terminal.Say("idle-rack: knocked=" + toString(knocked)
        + " maxDisp=" + toString(maxDisp)
        + " maxSpeed=" + toString(maxSpeed));
    if (knocked != 0) { return false; }
    if (maxDisp > 0.012) { return false; }
    if (maxSpeed > 0.04) { return false; }
    return true;
}

func checkBallRoll() -> Boolean {
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);
    var ballObj = new Ball();
    ballObj.initBall(world);
    ballObj.setSpin(0.0);
    ballObj.doDelivery(0.0, 0.0, 0.82, 0.0,
        config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        config.OIL_HOUSE, false);

    for (var step: Integer = 0; step < 80; step = step + 1) {
        var friction = laneObj.getFrictionAt(ballObj.getPosX(), ballObj.getPosZ());
        ballObj.updateMotion(config.PHYSICS_DT, friction, laneObj.getOilEndZ());
        PhysicsWorld3D.Step(world, config.PHYSICS_DT);
        ballObj.stabilizeLaneRoll();
    }

    var vel = ballObj.getVelocity();
    var ang = PhysicsBody3D.get_AngularVelocity(ballObj.getBody());
    var vx = Vec3.get_X(vel);
    var vz = Vec3.get_Z(vel);
    var ax = Vec3.get_X(ang);
    var ay = Vec3.get_Y(ang);
    var az = Vec3.get_Z(ang);
    var expectedX = vz / config.BALL_RADIUS;
    var expectedZ = -vx / config.BALL_RADIUS;
    Terminal.Say("ball-roll: ax=" + toString(ax)
        + " ay=" + toString(ay)
        + " az=" + toString(az)
        + " expectedX=" + toString(expectedX)
        + " expectedZ=" + toString(expectedZ));
    if (Abs(ax - expectedX) > 2.5) { return false; }
    if (Abs(az - expectedZ) > 2.5) { return false; }
    if (Abs(ay) > 0.6) { return false; }
    return true;
}

func runShot(label: String, stance: Float, target: Float, power: Float,
             spin: Float, releaseOffset: Float, rackSeed: Integer) -> Integer {
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);
    var pinMgr = new PinManager();
    pinMgr.initPins(world);
    pinMgr.setRackSeed(rackSeed, config.DIFFICULTY_STANDARD);
    pinMgr.savePinState();
    var ballObj = new Ball();
    ballObj.initBall(world);
    ballObj.setSpin(spin);
    ballObj.doDelivery(stance, target, power, releaseOffset,
        config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        config.OIL_HOUSE, false);
    var launchVelocity = ballObj.getVelocity();
    lastLaunchVX = Vec3.get_X(launchVelocity);
    lastLaunchVZ = Vec3.get_Z(launchVelocity);
    Terminal.Say(label + " launch vx=" + toString(Vec3.get_X(launchVelocity)) +
        " vz=" + toString(Vec3.get_Z(launchVelocity)));

    var sawBallPin = false;
    var step = 0;
    var minLaneY = 999.0;
    var entryX = 99.0;
    var entryAngle = 0.0;
    while (step < 1800 && ballObj.getPosZ() < config.PIN_Z_OFFSET + 2.0 && ballObj.gutterBall() == false) {
        var friction = laneObj.getFrictionAt(ballObj.getPosX(), ballObj.getPosZ());
        ballObj.updateMotion(config.PHYSICS_DT, friction, laneObj.getOilEndZ());
        PhysicsWorld3D.Step(world, config.PHYSICS_DT);
        ballObj.stabilizeLaneRoll();
        var lanePos = ballObj.getPosition();
        if (ballObj.getPosZ() < config.LANE_STABILIZE_END_Z && Vec3.get_Y(lanePos) < minLaneY) {
            minLaneY = Vec3.get_Y(lanePos);
        }
        if (entryX > 90.0 && ballObj.getPosZ() >= config.ENTRY_CAPTURE_Z) {
            entryX = ballObj.getPosX();
            entryAngle = ballObj.getTravelAngleDeg();
        }
        if (processImpacts(world, pinMgr, sawBallPin)) { sawBallPin = true; }
        updateGutter(ballObj, sawBallPin);
        pinMgr.updateKnockdowns(config.PHYSICS_DT);
        step = step + 1;
        if (sawBallPin && step > 90) {
            step = 1800;
        }
    }

    var settle = 0;
    while (settle < 360) {
        PhysicsWorld3D.Step(world, config.PHYSICS_DT);
        processImpacts(world, pinMgr, sawBallPin);
        pinMgr.updateKnockdowns(config.PHYSICS_DT);
        settle = settle + 1;
    }

    var knocked = pinMgr.countTotalKnocked();
    lastShotMask = pinMgr.getKnockedMask();
    Terminal.Say(label + ": knocked=" + toString(knocked)
        + " sawBallPin=" + toString(sawBallPin)
        + " gutter=" + toString(ballObj.gutterBall())
        + " minLaneY=" + toString(minLaneY)
        + " entryX=" + toString(entryX)
        + " entryDeg=" + toString(entryAngle)
        + " ballX=" + toString(ballObj.getPosX())
        + " ballZ=" + toString(ballObj.getPosZ()));
    if (ballObj.gutterBall() && sawBallPin == false) {
        return -100;
    }
    // The ball now rests on the lane floor at its natural radius height
    // (no artificial rail). A value well below that means it fell through.
    if (minLaneY < config.BALL_RADIUS - 0.03) {
        return -200;
    }
    return knocked;
}

func main() {
    if (checkIdleRack() == false) {
        Terminal.Say("RESULT: fail idle rack moved before impact");
        return;
    }
    if (checkBallRoll() == false) {
        Terminal.Say("RESULT: fail ball roll axis drifted away from velocity");
        return;
    }

    // Skill contract: well-placed shots carry the rack; a shot aimed at the
    // edge with compounding spin actually reaches the gutter (real failure
    // state, previously impossible). Pocket shots use aim + opposite hook.
    var pocketTarget = 0.065;
    var center = runShot("center-power", 0.0, 0.0, 0.82, 0.0, 0.0, 37);
    var leftPocket = runShot("left-pocket", 0.0, -pocketTarget, 0.82, 0.0, 0.0, 37);
    var rightPocket = runShot("right-pocket", 0.0, pocketTarget, 0.82, 0.0, 0.0, 37);
    var deterministicMask = lastShotMask;
    var deterministicVX = lastLaunchVX;
    var deterministicVZ = lastLaunchVZ;
    var deterministicRepeat = runShot("right-pocket-repeat", 0.0,
        pocketTarget, 0.82, 0.0, 0.0, 37);
    if (deterministicRepeat != rightPocket || lastShotMask != deterministicMask ||
        Abs(lastLaunchVX - deterministicVX) > 0.000001 ||
        Abs(lastLaunchVZ - deterministicVZ) > 0.000001) {
        Terminal.Say("RESULT: fail identical delivery and rack seed changed launch, mask, or score");
        return;
    }
    var pocketSeed11 = runShot("pocket-seed-11", 0.0, pocketTarget, 0.82, 0.0, 0.0, 11);
    var pocketSeed23 = runShot("pocket-seed-23", 0.0, pocketTarget, 0.82, 0.0, 0.0, 23);
    var pocketSeed53 = runShot("pocket-seed-53", 0.0, pocketTarget, 0.82, 0.0, 0.0, 53);
    var pocketSeed73 = runShot("pocket-seed-73", 0.0, pocketTarget, 0.82, 0.0, 0.0, 73);
    var pocketSeed89 = runShot("pocket-seed-89", 0.0, pocketTarget, 0.82, 0.0, 0.0, 89);
    var pocketSeed101 = runShot("pocket-seed-101", 0.0, pocketTarget, 0.82, 0.0, 0.0, 101);
    var pocketSeed127 = runShot("pocket-seed-127", 0.0, pocketTarget, 0.82, 0.0, 0.0, 127);
    var pocketSeed149 = runShot("pocket-seed-149", 0.0, pocketTarget, 0.82, 0.0, 0.0, 149);
    var pocketSeed173 = runShot("pocket-seed-173", 0.0, pocketTarget, 0.82, 0.0, 0.0, 173);
    var pocketSeed197 = runShot("pocket-seed-197", 0.0, pocketTarget, 0.82, 0.0, 0.0, 197);
    var pocketSeed223 = runShot("pocket-seed-223", 0.0, pocketTarget, 0.82, 0.0, 0.0, 223);
    var poorEarly = runShot("pocket-poor-early", 0.0, pocketTarget, 0.82, 0.0, -0.72, 37);
    var poorLate = runShot("pocket-poor-late", 0.0, pocketTarget, 0.82, 0.0, 0.72, 37);
    var poorFarEarly = runShot("pocket-poor-far-early", 0.0, pocketTarget, 0.82, 0.0, -0.94, 37);
    var poorFarLate = runShot("pocket-poor-far-late", 0.0, pocketTarget, 0.82, 0.0, 0.94, 37);
    var softRoll = runShot("soft-roll", 0.0, 0.0, 0.18, 0.0, 0.0, 37);
    var gutterMiss = runShot("gutter-miss", config.STANCE_MAX, config.TARGET_MAX,
        0.72, config.SPIN_MAX, 0.0, 37);
    var centerSeed11 = runShot("center-seed-11", 0.0, 0.0, 0.82, 0.0, 0.0, 11);
    var centerSeed73 = runShot("center-seed-73", 0.0, 0.0, 0.82, 0.0, 0.0, 73);
    var centerSeed101 = runShot("center-seed-101", 0.0, 0.0, 0.82, 0.0, 0.0, 101);
    var centerSeed149 = runShot("center-seed-149", 0.0, 0.0, 0.82, 0.0, 0.0, 149);

    if (center < 5) {
        Terminal.Say("RESULT: fail center power shot did not carry the rack");
        return;
    }
    if (leftPocket < 6) {
        Terminal.Say("RESULT: fail left pocket shot underperformed");
        return;
    }
    if (rightPocket < 6) {
        Terminal.Say("RESULT: fail right pocket shot underperformed");
        return;
    }
    if (softRoll < 2 || softRoll > 7) {
        Terminal.Say("RESULT: fail minimum-power carry left the two-to-seven pin band");
        return;
    }
    if (gutterMiss != -100) {
        Terminal.Say("RESULT: fail gutter miss no longer reaches the gutter");
        return;
    }
    var centerStrikes = 0;
    if (center == 10) { centerStrikes = centerStrikes + 1; }
    if (centerSeed11 == 10) { centerStrikes = centerStrikes + 1; }
    if (centerSeed73 == 10) { centerStrikes = centerStrikes + 1; }
    if (centerSeed101 == 10) { centerStrikes = centerStrikes + 1; }
    if (centerSeed149 == 10) { centerStrikes = centerStrikes + 1; }
    if (centerStrikes > 1) {
        Terminal.Say("RESULT: fail straight center line remains an automatic strike");
        return;
    }

    var pocketStrikes = 0;
    var pocketSevenPlus = 0;
    if (rightPocket == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed11 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed23 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed53 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed73 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed89 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed101 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed127 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed149 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed173 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed197 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (pocketSeed223 == 10) { pocketStrikes = pocketStrikes + 1; }
    if (rightPocket >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed11 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed23 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed53 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed73 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed89 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed101 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed127 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed149 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed173 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed197 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    if (pocketSeed223 >= 7) { pocketSevenPlus = pocketSevenPlus + 1; }
    Terminal.Say("pocket-matrix: strikes=" + toString(pocketStrikes)
        + "/12 seven-plus=" + toString(pocketSevenPlus) + "/12");
    if (pocketStrikes < 5 || pocketStrikes > 9) {
        Terminal.Say("RESULT: fail pocket strike rate left the 40-to-80 percent band");
        return;
    }
    if (pocketSevenPlus < 10) {
        Terminal.Say("RESULT: fail pocket carry fell below 80 percent");
        return;
    }

    var poorStrikes = 0;
    if (poorEarly == 10) { poorStrikes = poorStrikes + 1; }
    if (poorLate == 10) { poorStrikes = poorStrikes + 1; }
    if (poorFarEarly == 10) { poorStrikes = poorStrikes + 1; }
    if (poorFarLate == 10) { poorStrikes = poorStrikes + 1; }
    Terminal.Say("poor-release-matrix: strikes=" + toString(poorStrikes) + "/4");
    if (poorStrikes > 2) {
        Terminal.Say("RESULT: fail poor releases remain automatic strikes");
        return;
    }

    Terminal.Say("RESULT: ok");
}
