//
// File: examples/games/3dbowling/release_upgrade_probe.zia
// Purpose: Verifies deterministic release, equipment, scoring, progression, and HUD contracts.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: release_upgrade_probe
// PURPOSE: Deterministic contract probe for the commercial-quality gameplay
//          systems that do not require a graphics or audio device.
// ============================================================================

module release_upgrade_probe;

bind Zanna.Terminal;
bind "./content/ball_catalog";
bind "./gameplay/release_meter";
bind "./gameplay/delivery_model";
bind "./gameplay/leaves";
bind "./progression/profile";
bind "./scoring/scoring";
bind "./engine/hud";
bind "./effects/celebrations";
bind "./config";
bind "./menu";

var failureCount: Integer = 0;

func require(ok: Boolean, message: String) {
    if (ok == false) {
        Say("FAIL: " + message);
        failureCount = failureCount + 1;
    }
}

func advanceMeter(meter: ReleaseMeter, seconds: Float) {
    var remaining = seconds;
    while (remaining > 0.000001) {
        var dt = remaining;
        if (dt > 0.05) { dt = 0.05; }
        meter.update(dt);
        remaining = remaining - dt;
    }
}

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var catalog = new BallCatalog();
    require(catalog.count() == 6, "release catalog must contain six tactical balls");
    require(catalog.get(0).getName() == "House Control", "starter ball must remain stable");
    require(catalog.get(5).getHook() > catalog.get(0).getHook(),
        "advanced pearl ball must create more hook than starter ball");
    require(catalog.firstUnlockedFrom(0, 1, 99) == 0,
        "locked equipment must be skipped");
    require(catalog.firstUnlockedFrom(0, 1, 100) == 1,
        "equipment must unlock at its stated score");
    for (var candidate: Integer = 0; candidate < catalog.count(); candidate = candidate + 1) {
        var bestSpeed = true;
        var bestHook = true;
        var bestControl = true;
        var bestOilFit = true;
        for (var other: Integer = 0; other < catalog.count(); other = other + 1) {
            if (catalog.get(candidate).getMaxSpeed() < catalog.get(other).getMaxSpeed()) {
                bestSpeed = false;
            }
            if (catalog.get(candidate).getHook() < catalog.get(other).getHook()) {
                bestHook = false;
            }
            if (catalog.get(candidate).getControl() < catalog.get(other).getControl()) {
                bestControl = false;
            }
            if (catalog.get(candidate).getOilFit() < catalog.get(other).getOilFit()) {
                bestOilFit = false;
            }
        }
        require((bestSpeed && bestHook && bestControl && bestOilFit) == false,
            "equipment catalog must not contain an all-category best ball");
    }

    var meter = new ReleaseMeter();
    meter.reset(config.RELEASE_ASSIST_STANDARD);
    meter.beginCharge();
    advanceMeter(meter, 0.50);
    require(meter.getPower() > 0.0, "charging must build power");
    var lockedPower = meter.getPower();
    meter.lockPower();
    require(meter.isAwaitingAccuracy(), "first release must lock power and start accuracy");
    advanceMeter(meter, 0.11);
    require(Abs(meter.getPower() - lockedPower) < 0.0001,
        "accuracy timing must not change locked power");
    var firstAccuracy = meter.release();
    require(firstAccuracy >= 0.0 && firstAccuracy <= 1.0,
        "release accuracy must be normalized");
    meter.reset(config.RELEASE_ASSIST_STANDARD);
    require(meter.getPower() < 0.0001, "reset must clear the meter");

    var earlyPower = new ReleaseMeter();
    earlyPower.reset(0.0);
    earlyPower.beginCharge();
    advanceMeter(earlyPower, 0.20);
    earlyPower.lockPower();
    advanceMeter(earlyPower, 0.17);
    var earlyNeedle = earlyPower.getNeedle();

    var latePower = new ReleaseMeter();
    latePower.reset(0.0);
    latePower.beginCharge();
    advanceMeter(latePower, 0.73);
    latePower.lockPower();
    advanceMeter(latePower, 0.17);
    require(Abs(earlyNeedle - latePower.getNeedle()) < 0.0001,
        "accuracy oscillator must be independent of power charge duration");
    advanceMeter(latePower, config.RELEASE_CONFIRM_TIMEOUT);
    require(latePower.confirmTimedOut(), "second-stage release must have a bounded timeout");

    var delivery = new DeliveryModel();
    var perfectLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    var repeatedLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    require(Abs(perfectLine.sideSpeed - repeatedLine.sideSpeed) < 0.000001 &&
        Abs(perfectLine.forwardSpeed - repeatedLine.forwardSpeed) < 0.000001,
        "delivery solver must be deterministic");
    require(Abs(perfectLine.projectedTargetX - perfectLine.targetX) < 0.0001,
        "perfect preview projection must reach the selected target board");

    var poorLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.92, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    require(poorLine.forwardSpeed < perfectLine.forwardSpeed,
        "poor timing must reduce launch speed");
    require(Abs(poorLine.sideSpeed - perfectLine.sideSpeed) > 0.025,
        "poor timing must alter launch angle");
    require(Abs(poorLine.projectedTargetX - perfectLine.projectedTargetX) > 0.10,
        "preview projection must expose the physical timing miss");
    require(poorLine.uncertaintyWidth > perfectLine.uncertaintyWidth,
        "poor timing must widen the preview corridor");

    var casualLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.92, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_CASUAL,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    var leagueLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.92, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_LEAGUE,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    require(casualLine.uncertaintyWidth < leagueLine.uncertaintyWidth,
        "difficulty must scale delivery uncertainty");

    var controlLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.92, 0.0, config.DIFFICULTY_STANDARD, 96, 2,
        config.OIL_HOUSE, "Solid", 5.9, false);
    var angularLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.92, 0.0, config.DIFFICULTY_STANDARD, 66, 2,
        config.OIL_HOUSE, "Pearl", 5.9, false);
    require(controlLine.uncertaintyWidth < angularLine.uncertaintyWidth,
        "catalog control must physically narrow error");

    var dryFitLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, 0.0, config.DIFFICULTY_STANDARD, 82, 0,
        config.OIL_DRY, "Solid", 5.9, false);
    var heavyFitOnDry = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, 0.0, config.DIFFICULTY_STANDARD, 82, 3,
        config.OIL_DRY, "Solid", 5.9, false);
    require(dryFitLine.oilResponse > heavyFitOnDry.oilResponse,
        "oil-fit rating must change physical cover response by pattern");

    var plasticLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, 0.0, config.DIFFICULTY_STANDARD, 82, 1,
        config.OIL_HOUSE, "Plastic", 5.9, false);
    var pearlLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, 0.0, config.DIFFICULTY_STANDARD, 82, 1,
        config.OIL_HOUSE, "Pearl", 5.9, false);
    require(Abs(pearlLine.axisRotation) > Abs(plasticLine.axisRotation) * 2.5,
        "cover family must physically change axis retention");

    var spareLine = delivery.solve(0.12, -0.08, 0.78, -0.16,
        0.0, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, true);
    require(Abs(spareLine.effectiveHook) < Abs(perfectLine.effectiveHook) * 0.25,
        "spare release must flatten hook by at least seventy-five percent");

    var softLine = delivery.solve(0.12, -0.08, 0.24, -0.16,
        0.0, config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        82, 2, config.OIL_HOUSE, "Solid", 5.9, false);
    require(softLine.forwardSpeed < perfectLine.forwardSpeed * 0.82,
        "low power must materially reduce ball speed and carry");

    var leaves = new LeaveAnalyzer();
    require(leaves.describe(1) == "Head pin", "pin-one leave name");
    require(leaves.describe((1 << 6) + (1 << 9)) == "7-10 split", "7-10 split name");
    require(leaves.difficulty((1 << 6) + (1 << 9)) == 3, "7-10 is elite difficulty");

    var profile = new PlayerProfile("Player 1", 0, 0x56CFE1, false, 2);
    profile.recordGame(187, 5, 2, 1);
    require(profile.getBestScore() == 187, "profile best score");
    require(profile.getGamesPlayed() == 1, "profile game count");
    require(profile.getTotalStrikes() == 5, "profile strike count");

    var hud = new HUD();
    hud.initHUD();
    hud.showMessage("primary", 0xFFFFFF, 0.5);
    hud.queueMessage("achievement", 0xFFD166, 1.0);
    require(hud.getQueuedMessageCount() == 2, "achievement toast must queue");
    hud.update(0.6);
    require(hud.getQueuedMessageCount() == 1, "toast queue must advance in order");

    var celebration = new CelebrationManager();
    celebration.initCelebrations();
    celebration.onStrike(1);
    celebration.onStrike(1);
    require(celebration.getType() == celebrations.STRIKE,
        "different players' strikes must not combine into a turkey");
    celebration.onStrike(3);
    require(celebration.getType() == celebrations.TURKEY,
        "one player's three-strike streak must trigger turkey celebration");

    var progression = new BowlingMenu();
    require(progression.awardChallenge(0, 1), "first challenge medal must award");
    require(progression.awardChallenge(0, 1) == false, "same medal must not award twice");
    require(progression.awardChallenge(0, 3), "higher challenge medal must upgrade");
    require(progression.getChallengeMedal(0) == 3, "highest medal tier must persist in memory");
    require(progression.unlockAchievement(0), "first achievement must unlock");
    require(progression.unlockAchievement(0) == false, "achievement unlock must be idempotent");

    var clutch = new ScoreKeeper();
    clutch.startAtTenthFrame();
    require(clutch.getFrame() == 10, "clutch mode must begin in frame ten");
    clutch.recordRoll(10);
    require(clutch.wasStrike(), "opening tenth-frame strike classification");
    require(clutch.wasSpare() == false, "opening tenth-frame strike is not a spare");
    require(clutch.needsFullReset(), "tenth-frame strike needs a fresh bonus rack");
    clutch.recordRoll(10);
    require(clutch.needsFullReset(), "second tenth-frame strike needs a fresh rack");
    clutch.recordRoll(10);
    require(clutch.isGameOver(), "clutch mode must finish after tenth-frame bonuses");
    require(clutch.getTotalScore() == 30, "clutch perfect frame is worth thirty");

    var clutchSpare = new ScoreKeeper();
    clutchSpare.startAtTenthFrame();
    clutchSpare.recordRoll(9);
    clutchSpare.recordRoll(1);
    require(clutchSpare.wasSpare(), "tenth-frame spare classification");
    require(clutchSpare.needsFullReset(), "tenth-frame spare needs a fresh bonus rack");
    clutchSpare.recordRoll(10);
    require(clutchSpare.getTotalScore() == 20, "tenth-frame spare plus strike scores twenty");

    var perfect = new ScoreKeeper();
    for (var roll: Integer = 0; roll < 12; roll = roll + 1) { perfect.recordRoll(10); }
    require(perfect.isGameOver(), "twelve strikes must close a game");
    require(perfect.getTotalScore() == 300, "perfect game scoring");

    var opens = new ScoreKeeper();
    for (var frame: Integer = 0; frame < 10; frame = frame + 1) {
        opens.recordRoll(9); opens.recordRoll(0);
    }
    require(opens.getTotalScore() == 90, "ten open nine frames score ninety");

    if (failureCount > 0) {
        Say("RESULT: fail " + toString(failureCount));
    } else {
        Say("RESULT: ok");
    }
}
