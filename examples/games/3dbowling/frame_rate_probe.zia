//
// File: examples/games/3dbowling/frame_rate_probe.zia
// Purpose: Verifies timestep-equivalent meters, bowler motion, trails, and oil wear.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: frame_rate_probe
// PURPOSE: Standalone 30/60/144 Hz equivalence for timestep-driven release,
//          trail, bowler, menu animation, and oil wear systems.
// ============================================================================

module frame_rate_probe;

bind Zanna.Graphics3D;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./gameplay/release_meter";
bind "./lane/ball";
bind "./lane/lane";
bind "./presentation/bowler";
bind "./menu";

class CadenceResult {
    expose Float power;
    expose Float needle;
    expose Integer trailSamples;
    expose Float bowlerPhase;
    expose Float menuTime;
    expose Float oilWear;
}

func simulate(hz: Integer) -> CadenceResult {
    var result = new CadenceResult();
    var dt = 1.0 / (hz + 0.0);
    var frames = hz * 3;
    var meter = new ReleaseMeter();
    meter.reset(config.RELEASE_ASSIST_STANDARD);
    meter.beginCharge();

    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var ball = new Ball();
    ball.initBall(world);
    ball.doDelivery(0.0, 0.0, 0.78, 0.0,
        config.RELEASE_ASSIST_STANDARD, config.DIFFICULTY_STANDARD,
        config.OIL_HOUSE, false);
    var laneObj = new LaneBuilder();
    laneObj.initLane(world, config.OIL_HOUSE);
    var bowler = new BowlerAvatar();
    var menuObj = new BowlingMenu();

    for (var i: Integer = 0; i < frames; i = i + 1) {
        meter.update(dt);
        ball.sampleTrail(dt);
        bowler.update(dt, 0.0, true);
        menuObj.advanceAnimation(dt);
        laneObj.recordBallTrack(0.0, 5.0, 0.5, dt);
    }
    result.power = meter.getPower();
    result.needle = meter.getNeedle();
    result.trailSamples = ball.getTrailSampleCount();
    result.bowlerPhase = bowler.getPhase();
    result.menuTime = menuObj.getAnimationTime();
    result.oilWear = laneObj.getWearAt(0.0, 5.0);
    return result;
}

func close(a: Float, b: Float) -> Boolean { return Abs(a - b) < 0.0001; }

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var at30 = simulate(30);
    var at60 = simulate(60);
    var at144 = simulate(144);
    if (close(at30.power, at60.power) == false ||
        close(at60.power, at144.power) == false ||
        close(at30.needle, at144.needle) == false) {
        Terminal.Say("RESULT: fail release meter changed with refresh rate");
        return;
    }
    if (Abs((at30.trailSamples - at60.trailSamples) + 0.0) > 1.0 ||
        Abs((at60.trailSamples - at144.trailSamples) + 0.0) > 1.0) {
        Terminal.Say("RESULT: fail trail samples changed with refresh rate");
        return;
    }
    if (close(at30.bowlerPhase, at144.bowlerPhase) == false ||
        close(at30.menuTime, at144.menuTime) == false ||
        close(at30.oilWear, at144.oilWear) == false) {
        Terminal.Say("RESULT: fail visual/oil timestep integration diverged");
        return;
    }
    Terminal.Say("RESULT: ok");
}
