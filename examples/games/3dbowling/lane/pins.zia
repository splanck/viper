//
// File: examples/games/3dbowling/lane/pins.zia
// Purpose: Owns seeded pin bodies, physical pinfall, settling, resets, and rendering.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: pins (PinManager)
// PURPOSE: Owns the ten bowling pins: their physics bodies, knock-down
//          state machine (upright → tilting → sweep), the sweep bar
//          animation, and the full-rack reset drop.
//
// WHERE-THIS-FITS: Constructed by BowlingGame.init(). Updated each
//          physics step via updateKnockdowns; sweep/reset transitions
//          driven by game.zia at end of frame.
//
// KEY-DESIGN-CHOICES:
//   * CAPSULE PHYSICS, PIN-SHAPED VISUALS. The pin body is a vertical
//     capsule that matches the visible pin height closely enough for
//     ball/pin contacts to feel honest.
//   * HYBRID KNOCKDOWN. A pin is "knocked" when EITHER its
//     displacement from home exceeds PIN_KNOCKDOWN_DISPLACEMENT, OR
//     its speed exceeds PIN_KNOCKDOWN_SPEED with a smaller
//     displacement threshold. This catches both "shoved sideways"
//     and "tapped lightly but knocked off-axis" cases.
//   * TILT ANIMATION. Once knocked, the pin tilts about an axis
//     perpendicular to its displacement from home, building up to
//     PIN_TILT_MAX (~90°). The visual cylinder's rotate matrix
//     reflects this — a falling pin without needing per-frame physics
//     work.
//   * STANDING SNAP. Pins close to home with low speed get their
//     position SNAPPED back to home and velocity zeroed. This stops
//     micro-jitter from making "good rack" pins look unsteady.
//   * SAVE / RESTORE STATE. After roll 1 we save the current standing
//     pin positions; before roll 2 we knock down the just-fallen pins
//     for good (drop them off the playing field) and restore the
//     others. This avoids the "double-fall" bug where pins toppled by
//     ricochet in roll 1 get re-knocked in roll 2.
//   * SWEEP + RESET. Sweep brings the bar down across the deck and
//     drops all knocked pins below the deck. Full reset (after a strike
//     or end of frame 2) drops all pins from RESET_DROP_HEIGHT —
//     visible "rack reset" effect.
// ============================================================================

// pins.zia — Pin manager: capsule collisions, impact knockdown model, sweep/reset visuals
module pins;

bind Viper.Graphics3D;
bind Viper.Math;
bind "../config";

/// @brief Owns the 10 pin bodies and their knock-down state machine.
class PinManager {
    hide List[PhysicsBody3D] bodies;
    hide PhysicsWorld3D world;

    hide List[Float] homeX;
    hide List[Float] homeZ;
    hide List[Boolean] knocked;
    hide List[Boolean] previousKnocked;
    hide List[Boolean] impacted;
    hide List[Float] downDwell;
    hide List[Float] savedX;
    hide List[Float] savedY;
    hide List[Float] savedZ;

    hide List[Float] tiltAngle;
    hide List[Float] tiltAxisX;
    hide List[Float] tiltAxisZ;

    hide Boolean sweeping;
    hide Float sweepY;
    hide Float sweepTimer;

    hide Boolean resetting;
    hide Float resetTimer;
    hide Float rackQuietTime;
    hide Integer rackSeed;
    hide Integer rackDifficulty;

    hide Mesh3D pinBodyMesh;
    hide Mesh3D pinBellyMesh;
    hide Mesh3D pinBaseMesh;
    hide Mesh3D pinShoulderMesh;
    hide Mesh3D pinHeadMesh;
    hide Mesh3D pinNeckMesh;
    hide Mesh3D pinBandMesh;
    hide Material3D pinMat;
    hide Material3D pinNeckMat;

    /// @brief Build the 10-pin rack: meshes, materials, physics bodies,
    ///        home positions in the standard equilateral-triangle layout.
    expose func initPins(physWorld: PhysicsWorld3D) {
        world = physWorld;
        bodies = [];
        homeX = [];
        homeZ = [];
        knocked = [];
        previousKnocked = [];
        impacted = [];
        downDwell = [];
        savedX = [];
        savedY = [];
        savedZ = [];
        tiltAngle = [];
        tiltAxisX = [];
        tiltAxisZ = [];
        sweeping = false;
        sweepY = config.SWEEP_Y_START;
        sweepTimer = 0.0;
        resetting = false;
        resetTimer = 0.0;
        rackQuietTime = 0.0;
        rackSeed = 1;
        rackDifficulty = config.DIFFICULTY_STANDARD;

        pinBodyMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 0.72, config.PIN_HEIGHT * 0.78, 24);
        pinBellyMesh = Mesh3D.Sphere(config.PIN_RADIUS * 1.18, 16);
        pinBaseMesh = Mesh3D.Sphere(config.PIN_RADIUS * 1.10, 14);
        pinShoulderMesh = Mesh3D.Sphere(config.PIN_RADIUS * 0.86, 14);
        pinHeadMesh = Mesh3D.Sphere(config.PIN_RADIUS * 0.78, 14);
        pinNeckMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 0.58, config.PIN_HEIGHT * 0.34, 18);
        pinBandMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 0.78, 0.018, 18);
        pinMat = Material3D.FromColor(config.PIN_COLOR_R, config.PIN_COLOR_G, config.PIN_COLOR_B);
        Material3D.SetShininess(pinMat, config.PIN_SHININESS);
        Material3D.SetEmissiveColor(pinMat,
            config.PIN_EMISSIVE, config.PIN_EMISSIVE, config.PIN_EMISSIVE * 0.9);
        pinNeckMat = Material3D.FromColor(config.PIN_NECK_R, config.PIN_NECK_G, config.PIN_NECK_B);
        Material3D.SetEmissiveColor(pinNeckMat,
            config.PIN_NECK_EMISSIVE, config.PIN_NECK_EMISSIVE * 0.18, config.PIN_NECK_EMISSIVE * 0.18);

        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var px = computePinX(i);
            var pz = computePinZ(i);
            homeX.add(px);
            homeZ.add(pz);
            knocked.add(false);
            previousKnocked.add(false);
            impacted.add(false);
            downDwell.add(0.0);
            savedX.add(px);
            savedY.add(config.PIN_BODY_CENTER_Y);
            savedZ.add(pz);
            tiltAngle.add(0.0);
            tiltAxisX.add(0.0);
            tiltAxisZ.add(1.0);

            var body = PhysicsBody3D.NewCapsule(config.PIN_BODY_RADIUS, config.PIN_CAPSULE_HEIGHT, config.PIN_MASS);
            PhysicsBody3D.SetPosition(body, px, config.PIN_BODY_CENTER_Y, pz);
            PhysicsBody3D.set_Restitution(body, config.PIN_RESTITUTION);
            PhysicsBody3D.set_Friction(body, config.PIN_FRICTION);
            PhysicsBody3D.set_LinearDamping(body, config.PIN_LINEAR_DAMPING);
            PhysicsBody3D.set_AngularDamping(body, config.PIN_ANGULAR_DAMPING);
            PhysicsBody3D.set_CanSleep(body, true);
            PhysicsBody3D.set_UseCcd(body, true);
            PhysicsBody3D.set_CollisionLayer(body, config.LAYER_PINS);
            PhysicsBody3D.set_CollisionMask(body, config.MASK_PINS);
            PhysicsWorld3D.Add(world, body);
            PhysicsBody3D.Sleep(body);
            bodies.add(body);
        }
    }

    /// @brief Per-pin X coordinate for the standard 1/2/3/4 row layout.
    /// @details Pin 0 = head pin (centre); 1+2 = row 2; 3+4+5 = row 3
    ///          (centre pin "5" plus two outer); 6..9 = back row.
    hide func computePinX(index: Integer) -> Float {
        if (index == 0) { return 0.0; }
        if (index == 1) { return -config.PIN_SPACING / 2.0; }
        if (index == 2) { return config.PIN_SPACING / 2.0; }
        if (index == 3) { return -config.PIN_SPACING; }
        if (index == 4) { return 0.0; }
        if (index == 5) { return config.PIN_SPACING; }
        if (index == 6) { return -config.PIN_SPACING * 1.5; }
        if (index == 7) { return -config.PIN_SPACING / 2.0; }
        if (index == 8) { return config.PIN_SPACING / 2.0; }
        if (index == 9) { return config.PIN_SPACING * 1.5; }
        return 0.0;
    }

    /// @brief Per-pin Z coordinate. Each row sits PIN_SPACING * sin(60°)
    ///        further back than the previous (equilateral triangle).
    hide func computePinZ(index: Integer) -> Float {
        var row: Integer = 0;
        if (index >= 1) { row = 1; }
        if (index >= 3) { row = 2; }
        if (index >= 6) { row = 3; }
        return config.PIN_Z_OFFSET + (row + 0.0) * config.PIN_SPACING * 0.866;
    }

    hide func rackJitter() -> Float {
        if (rackDifficulty == config.DIFFICULTY_CASUAL) {
            return config.RACK_JITTER_CASUAL;
        }
        if (rackDifficulty == config.DIFFICULTY_LEAGUE) {
            return config.RACK_JITTER_LEAGUE;
        }
        return config.RACK_JITTER_STANDARD;
    }

    hide func seededUnit(index: Integer, salt: Integer) -> Float {
        var value = (rackSeed * 31 + index * 73 + salt * 97 + 1009000) % 1009;
        return (value + 0.0) / 504.0 - 1.0;
    }

    /// @brief Rebuild legal home positions from a bounded deterministic seed.
    expose func setRackSeed(seed: Integer, difficulty: Integer) {
        rackSeed = seed;
        if (rackSeed < 0) { rackSeed = 0 - rackSeed; }
        rackDifficulty = difficulty;
        if (rackDifficulty < config.DIFFICULTY_CASUAL ||
            rackDifficulty > config.DIFFICULTY_LEAGUE) {
            rackDifficulty = config.DIFFICULTY_STANDARD;
        }
        var amount = rackJitter();
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var px = computePinX(i) + seededUnit(i, 3) * amount;
            var pz = computePinZ(i) + seededUnit(i, 7) * amount;
            homeX.set(i, px);
            homeZ.set(i, pz);
            savedX.set(i, px);
            savedY.set(i, config.PIN_BODY_CENTER_Y);
            savedZ.set(i, pz);
            knocked.set(i, false);
            previousKnocked.set(i, false);
            impacted.set(i, false);
            downDwell.set(i, 0.0);
            PhysicsBody3D.SetPosition(bodies.get(i), px,
                config.PIN_BODY_CENTER_Y, pz);
            PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetOrientation(bodies.get(i), Quat.Identity());
            PhysicsBody3D.Sleep(bodies.get(i));
        }
        rackQuietTime = 0.0;
    }

    /// @brief Count only a sustained physical topple or legal deck displacement.
    expose func updateKnockdowns(dt: Float) {
        var rackQuiet = true;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var body = bodies.get(i);
            var pos = PhysicsBody3D.get_Position(body);
            var vel = PhysicsBody3D.get_Velocity(body);
            var ang = PhysicsBody3D.get_AngularVelocity(body);

            var px = Vec3.get_X(pos);
            var pz = Vec3.get_Z(pos);
            var vx = Vec3.get_X(vel);
            var vy = Vec3.get_Y(vel);
            var vz = Vec3.get_Z(vel);
            var ax = Vec3.get_X(ang);
            var ay = Vec3.get_Y(ang);
            var az = Vec3.get_Z(ang);
            var speed = Sqrt(vx * vx + vy * vy + vz * vz);
            var angularSpeed = Sqrt(ax * ax + ay * ay + az * az);
            var dx = px - homeX.get(i);
            var dz = pz - homeZ.get(i);
            var disp = Sqrt(dx * dx + dz * dz);

            var orientation = PhysicsBody3D.get_Orientation(body);
            var up = Quat.RotateVec3(orientation, new Vec3(0.0, 1.0, 0.0));
            var upY = Abs(Vec3.get_Y(up));
            var physicallyDown = upY < config.PIN_DOWN_TILT_COS ||
                Vec3.get_Y(pos) < config.PIN_DOWN_CENTER_Y ||
                disp > config.PIN_DOWN_DISPLACEMENT;
            if (knocked.get(i) == false && physicallyDown) {
                downDwell.set(i, downDwell.get(i) + dt);
                if (downDwell.get(i) >= config.PIN_DOWN_DWELL) {
                    markKnocked(i, dx, dz, vx, vz, ax, az);
                }
            } else if (knocked.get(i) == false) {
                downDwell.set(i, 0.0);
            }

            if (knocked.get(i) == false && physicallyDown == false &&
                speed < config.PIN_SETTLE_SNAP_SPEED &&
                angularSpeed < config.SETTLE_ANGULAR_THRESHOLD && upY > 0.985) {
                PhysicsBody3D.SetVelocity(body, 0.0, 0.0, 0.0);
                PhysicsBody3D.SetAngularVelocity(body, 0.0, 0.0, 0.0);
                if (disp < config.PIN_REST_SNAP_DISPLACEMENT) {
                    PhysicsBody3D.SetPosition(body, homeX.get(i), config.PIN_BODY_CENTER_Y, homeZ.get(i));
                    PhysicsBody3D.SetOrientation(body, Quat.Identity());
                    PhysicsBody3D.Sleep(body);
                }
            }

            if (speed > config.SETTLE_SPEED_THRESHOLD ||
                angularSpeed > config.SETTLE_ANGULAR_THRESHOLD) {
                rackQuiet = false;
            }
        }
        if (rackQuiet) { rackQuietTime = rackQuietTime + dt; }
        else { rackQuietTime = 0.0; }
    }

    hide func markKnocked(index: Integer, dx: Float, dz: Float,
                          vx: Float, vz: Float, ax: Float, az: Float) {
        if (knocked.get(index)) { return; }
        knocked.set(index, true);

        var disp = Sqrt(dx * dx + dz * dz);
        var speed = Sqrt(vx * vx + vz * vz);
        var angular = Sqrt(ax * ax + az * az);
        if (disp > 0.018) {
            tiltAxisX.set(index, dz / (disp + 0.0001));
            tiltAxisZ.set(index, -dx / (disp + 0.0001));
        } else if (speed > 0.018) {
            tiltAxisX.set(index, vz / (speed + 0.0001));
            tiltAxisZ.set(index, -vx / (speed + 0.0001));
        } else if (angular > 0.018) {
            tiltAxisX.set(index, az / (angular + 0.0001));
            tiltAxisZ.set(index, -ax / (angular + 0.0001));
        }
    }

    expose func registerImpact(body: Any, point: Vec3,
                               impulse: Float, relativeSpeed: Float) -> Boolean {
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (bodies.get(i) == body) {
                if (impulse > 0.04 || relativeSpeed > 0.20) {
                    impacted.set(i, true);
                    PhysicsBody3D.Wake(bodies.get(i));
                    var pos = PhysicsBody3D.get_Position(bodies.get(i));
                    var ix = Vec3.get_X(point) - Vec3.get_X(pos);
                    var iz = Vec3.get_Z(point) - Vec3.get_Z(pos);
                    var ilen = Sqrt(ix * ix + iz * iz);
                    if (ilen > 0.0001) {
                        tiltAxisX.set(i, iz / ilen);
                        tiltAxisZ.set(i, -ix / ilen);
                    }
                }
                return true;
            }
        }
        return false;
    }

    /// @brief Pins knocked since the last savePinState call (= this roll's pin count).
    expose func countNewlyKnocked() -> Integer {
        var count = 0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (knocked.get(i) && previousKnocked.get(i) == false) {
                count = count + 1;
            }
        }
        return count;
    }

    /// @brief Total pins down across the current frame (both rolls).
    expose func countTotalKnocked() -> Integer {
        var count = 0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (knocked.get(i)) { count = count + 1; }
        }
        return count;
    }

    /// @brief Stable ten-bit signature of physically fallen pins.
    expose func getKnockedMask() -> Integer {
        var mask = 0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (knocked.get(i)) { mask = mask | (1 << i); }
        }
        return mask;
    }

    expose func maxStandingDisplacement() -> Float {
        var maxDisp = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (knocked.get(i) == false) {
                var pos = PhysicsBody3D.get_Position(bodies.get(i));
                var dx = Vec3.get_X(pos) - homeX.get(i);
                var dz = Vec3.get_Z(pos) - homeZ.get(i);
                var disp = Sqrt(dx * dx + dz * dz);
                if (disp > maxDisp) { maxDisp = disp; }
            }
        }
        return maxDisp;
    }

    expose func maxBodySpeed() -> Float {
        var maxSpeed = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var vel = PhysicsBody3D.get_Velocity(bodies.get(i));
            var vx = Vec3.get_X(vel);
            var vy = Vec3.get_Y(vel);
            var vz = Vec3.get_Z(vel);
            var speed = Sqrt(vx * vx + vy * vy + vz * vz);
            if (speed > maxSpeed) { maxSpeed = speed; }
        }
        return maxSpeed;
    }

    /// @brief Snapshot the standing pins (positions) and which were knocked.
    /// @note Called after a settled roll so the next roll can restore.
    expose func savePinState() {
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            previousKnocked.set(i, knocked.get(i));
            impacted.set(i, false);
            downDwell.set(i, 0.0);
            if (knocked.get(i)) {
                savedX.set(i, 0.0);
                savedY.set(i, -10.0);
                savedZ.set(i, 0.0);
            } else {
                var pos = PhysicsBody3D.get_Position(bodies.get(i));
                savedX.set(i, Vec3.get_X(pos));
                savedY.set(i, config.PIN_BODY_CENTER_Y);
                savedZ.set(i, Vec3.get_Z(pos));
            }
        }
    }

    /// @brief Restore standing pins to their saved positions; knocked pins
    ///        get pushed below the deck (Y = -10).
    expose func restoreSavedPinState() {
        rackQuietTime = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            knocked.set(i, previousKnocked.get(i));
            impacted.set(i, false);
            downDwell.set(i, 0.0);
            tiltAngle.set(i, 0.0);
            PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetOrientation(bodies.get(i), Quat.Identity());
            PhysicsBody3D.SetPosition(bodies.get(i), savedX.get(i), savedY.get(i), savedZ.get(i));
            PhysicsBody3D.Sleep(bodies.get(i));
        }
    }

    /// @brief True when every pin has come to rest (or fallen below the deck).
    expose func allSettled() -> Boolean {
        return rackQuietTime >= config.SETTLE_QUIET_DWELL;
    }

    /// @brief Begin the sweep-bar animation.
    expose func startSweep() {
        sweeping = true;
        sweepY = config.SWEEP_Y_START;
        sweepTimer = config.SWEEP_DURATION;
    }

    /// @brief Per-frame sweep advance. @return true when sweep finishes.
    expose func updateSweep(dt: Float) -> Boolean {
        if (sweeping == false) { return true; }

        sweepTimer = sweepTimer - dt;
        if (sweepY > config.SWEEP_Y_END) {
            sweepY = sweepY - dt * config.SWEEP_SPEED;
            if (sweepY < config.SWEEP_Y_END) { sweepY = config.SWEEP_Y_END; }
        }

        if (sweepTimer <= 0.0) {
            sweeping = false;
            for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
                if (knocked.get(i)) {
                    PhysicsBody3D.SetPosition(bodies.get(i), 0.0, -10.0, 0.0);
                    PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                    PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                    PhysicsBody3D.Sleep(bodies.get(i));
                }
            }
            return true;
        }
        return false;
    }

    /// @brief True while the sweep animation is mid-flight.
    expose func isSweeping() -> Boolean {
        return sweeping;
    }

    /// @brief Current sweep-bar Y for rendering.
    expose func getSweepY() -> Float {
        return sweepY;
    }

    /// @brief Begin the full-rack reset (10 fresh pins drop in).
    expose func startFullReset() {
        resetting = true;
        resetTimer = config.RESET_DURATION;
        rackQuietTime = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            knocked.set(i, false);
            previousKnocked.set(i, false);
            impacted.set(i, false);
            downDwell.set(i, 0.0);
            savedX.set(i, homeX.get(i));
            savedY.set(i, config.PIN_BODY_CENTER_Y);
            savedZ.set(i, homeZ.get(i));
            tiltAngle.set(i, 0.0);
            PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetOrientation(bodies.get(i), Quat.Identity());
            PhysicsBody3D.SetPosition(bodies.get(i), homeX.get(i), config.RESET_DROP_HEIGHT, homeZ.get(i));
        }
    }

    /// @brief Prepare for roll 2 of a frame: drop knocked pins below
    ///        the deck (out of physics), zero standing-pin velocities,
    ///        snapshot the new state.
    expose func prepareSecondRoll() {
        rackQuietTime = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            downDwell.set(i, 0.0);
            if (knocked.get(i)) {
                PhysicsBody3D.SetPosition(bodies.get(i), 0.0, -10.0, 0.0);
                PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                PhysicsBody3D.Sleep(bodies.get(i));
            } else {
                impacted.set(i, false);
                var pos = PhysicsBody3D.get_Position(bodies.get(i));
                PhysicsBody3D.SetPosition(bodies.get(i),
                    Vec3.get_X(pos), config.PIN_BODY_CENTER_Y, Vec3.get_Z(pos));
                PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
                PhysicsBody3D.SetOrientation(bodies.get(i), Quat.Identity());
                PhysicsBody3D.Sleep(bodies.get(i));
            }
        }
        savePinState();
    }

    /// @brief Per-frame full-reset advance. @return true when reset finishes.
    /// @details Pins linearly interpolate from RESET_DROP_HEIGHT down
    ///          to PIN_BODY_CENTER_Y over RESET_DURATION seconds.
    expose func updateReset(dt: Float) -> Boolean {
        if (resetting == false) { return true; }

        resetTimer = resetTimer - dt;
        var progress = 1.0 - (resetTimer / config.RESET_DURATION);
        if (progress > 1.0) { progress = 1.0; }

        var currentY = config.RESET_DROP_HEIGHT +
            (config.PIN_BODY_CENTER_Y - config.RESET_DROP_HEIGHT) * progress;

        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            PhysicsBody3D.SetPosition(bodies.get(i), homeX.get(i), currentY, homeZ.get(i));
            PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetOrientation(bodies.get(i), Quat.Identity());
        }

        if (resetTimer <= 0.0) {
            resetting = false;
            for (var i2: Integer = 0; i2 < config.PIN_COUNT; i2 = i2 + 1) {
                PhysicsBody3D.SetPosition(bodies.get(i2), homeX.get(i2), config.PIN_BODY_CENTER_Y, homeZ.get(i2));
                PhysicsBody3D.SetVelocity(bodies.get(i2), 0.0, 0.0, 0.0);
                PhysicsBody3D.SetAngularVelocity(bodies.get(i2), 0.0, 0.0, 0.0);
                PhysicsBody3D.SetOrientation(bodies.get(i2), Quat.Identity());
                PhysicsBody3D.Sleep(bodies.get(i2));
            }
            savePinState();
            return true;
        }
        return false;
    }

    /// @brief True while the full-reset drop animation is in progress.
    expose func isResetting() -> Boolean {
        return resetting;
    }

    /// @brief Wire up env-map reflections on the pin materials.
    expose func applyEnvironment(env: CubeMap3D) {
        Material3D.SetEnvMap(pinMat, env);
        pinMat.Reflectivity = config.PIN_REFLECTIVITY;
        Material3D.SetEnvMap(pinNeckMat, env);
        pinNeckMat.Reflectivity = config.PIN_NECK_REFLECTIVITY;
    }

    /// @brief Increase pin/deck separation for the accessibility preset.
    expose func applyHighContrast(enabled: Boolean) {
        if (enabled) {
            Material3D.SetColor(pinMat, 1.0, 1.0, 0.88);
            Material3D.SetEmissiveColor(pinMat, 0.20, 0.20, 0.12);
            Material3D.SetColor(pinNeckMat, 1.0, 0.02, 0.02);
            Material3D.SetEmissiveColor(pinNeckMat, 0.38, 0.01, 0.01);
        } else {
            Material3D.SetColor(pinMat, config.PIN_COLOR_R, config.PIN_COLOR_G, config.PIN_COLOR_B);
            Material3D.SetEmissiveColor(pinMat,
                config.PIN_EMISSIVE, config.PIN_EMISSIVE, config.PIN_EMISSIVE * 0.9);
            Material3D.SetColor(pinNeckMat, config.PIN_NECK_R, config.PIN_NECK_G, config.PIN_NECK_B);
            Material3D.SetEmissiveColor(pinNeckMat,
                config.PIN_NECK_EMISSIVE, config.PIN_NECK_EMISSIVE * 0.18,
                config.PIN_NECK_EMISSIVE * 0.18);
        }
    }

    /// @brief Render every pin using its real rigid-body orientation.
    expose func draw(canvas: Canvas3D) {
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var pos = PhysicsBody3D.get_Position(bodies.get(i));
            var px = Vec3.get_X(pos);
            var py = Vec3.get_Y(pos);
            var pz = Vec3.get_Z(pos);
            if (py < -5.0) { continue; }

            var base = makePinTransform(i, px, py, pz);
            drawPinPart(canvas, base, pinBodyMesh, 0.0, -0.010, 0.0, 1.0, 1.0, 1.0, pinMat);
            drawPinPart(canvas, base, pinBellyMesh, 0.0, -0.070, 0.0, 1.0, 1.28, 1.0, pinMat);
            drawPinPart(canvas, base, pinBaseMesh, 0.0, -0.172, 0.0, 1.0, 0.34, 1.0, pinMat);
            drawPinPart(canvas, base, pinShoulderMesh, 0.0, 0.052, 0.0, 1.0, 0.62, 1.0, pinMat);
            drawPinPart(canvas, base, pinNeckMesh, 0.0, 0.116, 0.0, 1.0, 1.0, 1.0, pinMat);
            drawPinPart(canvas, base, pinHeadMesh, 0.0, 0.190, 0.0, 1.0, 0.92, 1.0, pinMat);
            if (knocked.get(i)) {
                drawPinPart(canvas, base, pinBandMesh, 0.0, 0.082, 0.0, 1.0, 1.0, 1.0, pinNeckMat);
            } else {
                drawPinPart(canvas, base, pinBandMesh, 0.0, 0.078, 0.0, 1.0, 1.0, 1.0, pinNeckMat);
                drawPinPart(canvas, base, pinBandMesh, 0.0, 0.108, 0.0, 1.0, 1.0, 1.0, pinNeckMat);
            }
        }
    }

    hide func makePinTransform(index: Integer, px: Float, py: Float, pz: Float) -> Mat4 {
        var translate = Mat4.Translate(px, py + config.PIN_DRAW_Y_OFFSET, pz);
        var orientation = PhysicsBody3D.get_Orientation(bodies.get(index));
        return Mat4.Mul(translate, Quat.ToMat4(orientation));
    }

    hide func drawPinPart(canvas: Canvas3D, base: Mat4, mesh: Mesh3D,
                          ox: Float, oy: Float, oz: Float,
                          sx: Float, sy: Float, sz: Float,
                          mat: Material3D) {
        var local = Mat4.Mul(Mat4.Translate(ox, oy, oz), Mat4.Scale(sx, sy, sz));
        Canvas3D.DrawMesh(canvas, mesh, Mat4.Mul(base, local), mat);
    }

    /// @brief World position of a specific pin (for trigger callbacks etc.).
    expose func getPinPosition(index: Integer) -> Vec3 {
        return PhysicsBody3D.get_Position(bodies.get(index));
    }

    expose func getPinOrientation(index: Integer) -> Quat {
        return PhysicsBody3D.get_Orientation(bodies.get(index));
    }

    expose func getPinBody(index: Integer) -> PhysicsBody3D {
        return bodies.get(index);
    }

    expose func getHomeX(index: Integer) -> Float { return homeX.get(index); }
    expose func getHomeZ(index: Integer) -> Float { return homeZ.get(index); }
    expose func getRackSeed() -> Integer { return rackSeed; }

    /// @brief Knock-down state for a specific pin.
    expose func isKnocked(index: Integer) -> Boolean {
        return knocked.get(index);
    }

    /// @brief Ten-bit mask of pins still standing (bit zero is the head pin).
    expose func getStandingMask() -> Integer {
        var mask = 0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            if (knocked.get(i) == false) { mask = mask | (1 << i); }
        }
        return mask;
    }

    /// @brief Replace the rack with a deterministic standing-pin practice mask.
    expose func setStandingMask(mask: Integer) {
        rackQuietTime = 0.0;
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var standing = (mask & (1 << i)) != 0;
            knocked.set(i, standing == false);
            previousKnocked.set(i, standing == false);
            impacted.set(i, false);
            downDwell.set(i, 0.0);
            tiltAngle.set(i, 0.0);
            PhysicsBody3D.SetVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            PhysicsBody3D.SetAngularVelocity(bodies.get(i), 0.0, 0.0, 0.0);
            if (standing) {
                PhysicsBody3D.SetPosition(bodies.get(i), homeX.get(i),
                    config.PIN_BODY_CENTER_Y, homeZ.get(i));
            } else {
                PhysicsBody3D.SetPosition(bodies.get(i), homeX.get(i), -4.0, homeZ.get(i));
            }
            PhysicsBody3D.Sleep(bodies.get(i));
        }
        savePinState();
    }
}
