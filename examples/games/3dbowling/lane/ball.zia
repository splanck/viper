// ============================================================================
// MODULE: ball
// PURPOSE: Bowling ball entity. Owns its 3D physics body + mesh +
//          material, the per-weight stats (mass / max speed / hook
//          multiplier / colour), spin state, gutter tracking, and the
//          throw release model.
//
// WHERE-THIS-FITS: Owned by BowlingGame. Updated each physics step via
//          updateMotion (applies hook + drag + spin decay) and rendered
//          each frame via draw.
//
// KEY-DESIGN-CHOICES:
//   * THREE WEIGHTS, ONE BALL TYPE. BALL_LIGHT/MEDIUM/HEAVY each carry
//     mass, max throw speed, hook strength, and colour. Selecting a
//     weight (selectBall / cycleBall) recreates the physics body and
//     repaints the material — no aliasing of stats.
//   * HOOK MODEL. The ball curves toward the pins as it travels: spin
//     creates a sideways force `hookForce = spin * multiplier *
//     (early + backend)` scaled by friction. Oiled portion gives
//     little hook; the ball "wakes up" on the dry backend (after
//     oilEndZ) and curves more aggressively. This mirrors real
//     bowling-ball physics.
//   * RELEASE GEOMETRY. doThrow computes a release position (close
//     to the centre line, scaled by aim), a target position (further
//     out, augmented by spin), and converts the (releaseX, targetX,
//     travelZ) triangle into (sideSpeed, forwardSpeed) so the throw
//     animates as a straight initial trajectory before the hook
//     kicks in.
//   * GUTTER LOCK. markGutter clamps the ball's X to the gutter
//     centre and reduces its collision mask so it can no longer
//     interact with pins. The ball still slides forward until it
//     exits at GUTTER_EXIT_Z.
//   * VISUAL SPIN VS PHYSICS SPIN. visualSpinAngle is purely cosmetic
//     (drives the rotation matrix in draw); spinAmount is the
//     physical hook coefficient. They evolve independently —
//     visualSpinAngle accumulates with speed, spinAmount decays with
//     friction.
// ============================================================================

// ball.zia — Ball entity: weight selection, release shaping, hook model, gutter state
module ball;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind "../config";

/// @brief Bowling ball entity with hook physics and weight-class stats.
class Ball {
    hide Physics3DBody body;
    hide Physics3DWorld world;
    hide Boolean inWorld;

    hide Float mass;
    hide Float maxSpeed;
    hide Float hookMultiplier;
    hide Float colorR;
    hide Float colorG;
    hide Float colorB;
    hide Integer ballType;

    hide Mesh3D ballMesh;
    hide Material3D ballMat;

    hide Float spinAmount;
    hide Float visualSpinAngle;
    hide Float launchAngle;
    hide Boolean isInGutter;
    hide Boolean hasBeenThrown;

    /// @brief One-time setup: physics body + mesh + material; defaults to MEDIUM weight.
    expose func initBall(physWorld: Physics3DWorld) {
        world = physWorld;
        inWorld = false;
        spinAmount = 0.0;
        visualSpinAngle = 0.0;
        launchAngle = 0.0;
        isInGutter = false;
        hasBeenThrown = false;

        ballType = config.BALL_MEDIUM;
        applyBallStats();

        ballMesh = Mesh3D.NewSphere(config.BALL_RADIUS, 16);
        ballMat = Material3D.NewColor(colorR, colorG, colorB);
        Material3D.SetShininess(ballMat, config.BALL_SHININESS);

        recreateBody();
    }

    /// @brief Copy weight-class stats (mass, max speed, hook, colour)
    ///        into the live `mass`/`maxSpeed`/etc. fields.
    hide func applyBallStats() {
        if (ballType == config.BALL_LIGHT) {
            mass = config.BALL_MASS_LIGHT;
            maxSpeed = config.BALL_SPEED_MAX_LIGHT;
            hookMultiplier = config.BALL_HOOK_LIGHT;
            colorR = config.BALL_COLOR_LIGHT_R;
            colorG = config.BALL_COLOR_LIGHT_G;
            colorB = config.BALL_COLOR_LIGHT_B;
        } else if (ballType == config.BALL_HEAVY) {
            mass = config.BALL_MASS_HEAVY;
            maxSpeed = config.BALL_SPEED_MAX_HEAVY;
            hookMultiplier = config.BALL_HOOK_HEAVY;
            colorR = config.BALL_COLOR_HEAVY_R;
            colorG = config.BALL_COLOR_HEAVY_G;
            colorB = config.BALL_COLOR_HEAVY_B;
        } else {
            mass = config.BALL_MASS_MEDIUM;
            maxSpeed = config.BALL_SPEED_MAX_MEDIUM;
            hookMultiplier = config.BALL_HOOK_MEDIUM;
            colorR = config.BALL_COLOR_MEDIUM_R;
            colorG = config.BALL_COLOR_MEDIUM_G;
            colorB = config.BALL_COLOR_MEDIUM_B;
        }
    }

    /// @brief Tear down + rebuild the physics body. Called on weight
    ///        change and on resetBall — the body's mass is baked in
    ///        at construction so we have to recreate it.
    hide func recreateBody() {
        if (inWorld) {
            Physics3DWorld.Remove(world, body);
        }
        body = Physics3DBody.NewSphere(config.BALL_RADIUS, mass);
        Physics3DBody.set_Restitution(body, config.BALL_RESTITUTION);
        Physics3DBody.set_Friction(body, config.BALL_FRICTION);
        Physics3DBody.set_CollisionLayer(body, config.LAYER_BALL);
        Physics3DBody.set_CollisionMask(body, config.MASK_BALL);
        Physics3DBody.SetPosition(body,
            config.BALL_START_X, config.BALL_RADIUS + config.BALL_START_Y_OFFSET, config.BALL_START_Z);
        Physics3DBody.SetVelocity(body, 0.0, 0.0, 0.0);
        inWorld = false;
    }

    /// @brief Switch to a specific weight (LIGHT/MEDIUM/HEAVY).
    expose func selectBall(btype: Integer) {
        ballType = btype;
        applyBallStats();
        Material3D.SetColor(ballMat, colorR, colorG, colorB);
        recreateBody();
    }

    /// @brief Cycle through the three weights; wraps at boundaries.
    expose func cycleBall(dir: Integer) {
        var nextType = ballType + dir;
        if (nextType < config.BALL_LIGHT) { nextType = config.BALL_HEAVY; }
        if (nextType > config.BALL_HEAVY) { nextType = config.BALL_LIGHT; }
        selectBall(nextType);
    }

    /// @brief Set spin amount, clamped to ±SPIN_MAX. Positive = right-curve.
    expose func setSpin(amount: Float) {
        spinAmount = amount;
        if (spinAmount > config.SPIN_MAX) { spinAmount = config.SPIN_MAX; }
        if (spinAmount < -config.SPIN_MAX) { spinAmount = -config.SPIN_MAX; }
    }

    /// @brief Current spin amount.
    expose func getSpin() -> Float {
        return spinAmount;
    }

    /// @brief Release the ball with the given aim and power.
    /// @param aimX Player's aim offset; clamped to ±AIM_MAX.
    /// @param power 0..1 fraction of weight-class max speed.
    /// @details Computes a release+target geometry to derive
    ///          (sideSpeed, forwardSpeed) such that the ball travels
    ///          in a straight line until the hook (in updateMotion)
    ///          curves it.
    expose func doThrow(aimX: Float, power: Float) {
        var throwSpeed = config.THROW_SPEED_MIN + power * (maxSpeed - config.THROW_SPEED_MIN);
        var clampedAimX = aimX;
        if (clampedAimX < -config.AIM_MAX) { clampedAimX = -config.AIM_MAX; }
        if (clampedAimX > config.AIM_MAX) { clampedAimX = config.AIM_MAX; }

        var aimPct = clampedAimX / config.AIM_MAX;
        if (aimPct < -1.0) { aimPct = -1.0; }
        if (aimPct > 1.0) { aimPct = 1.0; }

        var releaseClamp = config.LANE_WIDTH / 2.0 - config.BALL_RADIUS * 1.85;
        if (releaseClamp < 0.16) { releaseClamp = 0.16; }
        var targetClamp = config.LANE_WIDTH / 2.0 - config.BALL_RADIUS * 0.78;
        if (targetClamp < releaseClamp) { targetClamp = releaseClamp; }

        var releaseX = aimPct * releaseClamp * config.BALL_RELEASE_X_SCALE;
        var targetX = aimPct * targetClamp * config.BALL_TARGET_X_SCALE + spinAmount * 0.08;
        if (targetX < -targetClamp) { targetX = -targetClamp; }
        if (targetX > targetClamp) { targetX = targetClamp; }

        var travelZ = config.BALL_TARGET_Z - config.BALL_THROW_Z;
        if (travelZ < 5.0) { travelZ = 5.0; }
        var sideSpeed = throwSpeed * ((targetX - releaseX) / travelZ) * config.BALL_SIDE_SPEED_SCALE;
        if (sideSpeed < -config.BALL_SIDE_SPEED_MAX) { sideSpeed = -config.BALL_SIDE_SPEED_MAX; }
        if (sideSpeed > config.BALL_SIDE_SPEED_MAX) { sideSpeed = config.BALL_SIDE_SPEED_MAX; }
        var forwardSq = throwSpeed * throwSpeed - sideSpeed * sideSpeed;
        if (forwardSq < 1.0) { forwardSq = 1.0; }
        var forwardSpeed = Sqrt(forwardSq);
        launchAngle = Atan2(sideSpeed, forwardSpeed);

        Physics3DBody.SetPosition(body,
            releaseX, config.BALL_RADIUS + config.BALL_START_Y_OFFSET, config.BALL_THROW_Z);
        Physics3DBody.SetVelocity(body, sideSpeed, 0.0, forwardSpeed);

        if (inWorld == false) {
            Physics3DWorld.Add(world, body);
            inWorld = true;
        }

        isInGutter = false;
        hasBeenThrown = true;
        Say("Thrown! Power: " + toString(Convert.NumToInt(power * 100.0))
            + "%  Shape: " + toString(Convert.NumToInt(spinAmount * 100.0)));
    }

    /// @brief Per-physics-step in-flight update.
    /// @details Applies hook force (spin × multiplier × early/backend ×
    ///          friction), side drag, and decays spin based on
    ///          current friction (oiled ≪ dry).
    expose func updateMotion(dt: Float, laneFriction: Float, oilEndZ: Float) {
        if (hasBeenThrown == false || isInGutter) { return; }

        var pos = Physics3DBody.get_Position(body);
        var vel = Physics3DBody.get_Velocity(body);
        var x = Vec3.get_X(pos);
        var z = Vec3.get_Z(pos);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var speed = Sqrt(vx * vx + vz * vz);
        if (speed < 0.05) { return; }

        var backend = 0.0;
        if (z > oilEndZ) {
            backend = (z - oilEndZ) / 3.0;
            if (backend > 1.0) { backend = 1.0; }
        }
        var frictionPct = (laneFriction - config.OIL_FRICTION_OILED) /
            (config.OIL_FRICTION_DRY - config.OIL_FRICTION_OILED + 0.0001);
        if (frictionPct < 0.0) { frictionPct = 0.0; }
        if (frictionPct > 1.0) { frictionPct = 1.0; }

        var hookForce = spinAmount * hookMultiplier *
            (config.EARLY_HOOK_FORCE + backend * config.BACKEND_HOOK_FORCE) * frictionPct;
        hookForce = hookForce * (0.55 + frictionPct * 0.35);
        var dragForce = -vx * config.SIDE_DRAG * (0.8 + frictionPct);
        Physics3DBody.ApplyForce(body, hookForce + dragForce, 0.0, 0.0);

        var spinDecay = config.SPIN_DECAY_OIL + (config.SPIN_DECAY_DRY - config.SPIN_DECAY_OIL) * frictionPct;
        if (spinAmount > 0.0) {
            spinAmount = spinAmount - spinDecay * dt;
            if (spinAmount < 0.0) { spinAmount = 0.0; }
        } else if (spinAmount < 0.0) {
            spinAmount = spinAmount + spinDecay * dt;
            if (spinAmount > 0.0) { spinAmount = 0.0; }
        }

        visualSpinAngle = visualSpinAngle + speed * dt * config.SPIN_VISUAL_SPEED;
        if (x > config.LANE_WIDTH) {
            spinAmount = spinAmount * 0.95;
        }
    }

    /// @brief Apply a slight slowdown when the ball enters the pin deck
    ///        so collision energy looks "absorbed" rather than elastic.
    expose func dampForPinDeckImpact(depth: Float) {
        if (hasBeenThrown == false || isInGutter) { return; }

        var vel = Physics3DBody.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var slowdown = config.BALL_DECK_IMPACT_SLOWDOWN - depth * 8.0;
        if (slowdown < 0.62) { slowdown = 0.62; }
        if (slowdown > 0.90) { slowdown = 0.90; }
        vx = vx * config.BALL_DECK_IMPACT_SIDE_DAMP;
        vz = vz * slowdown;
        if (vz < 0.35) { vz = 0.35; }
        Physics3DBody.SetVelocity(body, vx, Vec3.get_Y(vel), vz);
    }

    /// @brief Lock the ball into the gutter (clamp X, reduce collision mask
    ///        so it can't hit pins). Continues sliding forward until exit.
    expose func markGutter(side: Integer) {
        isInGutter = true;
        var gutterSign = 1.0;
        if (side < 0) { gutterSign = -1.0; }

        var pos = Physics3DBody.get_Position(body);
        var vel = Physics3DBody.get_Velocity(body);
        var vz = Vec3.get_Z(vel);
        var safeX = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W * 0.68;
        Physics3DBody.SetPosition(body, gutterSign * safeX, Vec3.get_Y(pos), Vec3.get_Z(pos));
        Physics3DBody.SetVelocity(body, gutterSign * 0.22, 0.0, vz * 0.9);
        Physics3DBody.set_CollisionMask(body, config.LAYER_STATIC);
    }

    /// @brief Release the gutter lock (reset only).
    expose func clearGutter() {
        isInGutter = false;
    }

    /// @brief Underlying physics body (for trigger callbacks).
    expose func getBody() -> Physics3DBody {
        return body;
    }

    /// @brief Current world position.
    expose func getPosition() -> Vec3 {
        return Physics3DBody.get_Position(body);
    }

    /// @brief Current world velocity.
    expose func getVelocity() -> Vec3 {
        return Physics3DBody.get_Velocity(body);
    }

    /// @brief Speed magnitude (sqrt of vx² + vy² + vz²).
    expose func getSpeed() -> Float {
        var vel = Physics3DBody.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vy = Vec3.get_Y(vel);
        var vz = Vec3.get_Z(vel);
        return Sqrt(vx * vx + vy * vy + vz * vz);
    }

    /// @brief Current X coordinate.
    expose func getPosX() -> Float {
        return Vec3.get_X(Physics3DBody.get_Position(body));
    }

    /// @brief Current Z coordinate.
    expose func getPosZ() -> Float {
        return Vec3.get_Z(Physics3DBody.get_Position(body));
    }

    /// @brief True once the ball has crossed past the pin deck.
    expose func hasPastPins() -> Boolean {
        return getPosZ() > config.PIN_Z_OFFSET + 1.8;
    }

    /// @brief True when the ball has nearly stopped (settling check).
    expose func isSlow() -> Boolean {
        return getSpeed() < 0.45;
    }

    /// @brief True when the ball is locked in a gutter.
    expose func gutterBall() -> Boolean {
        return isInGutter;
    }

    /// @brief True after the first doThrow of a delivery cycle.
    expose func thrown() -> Boolean {
        return hasBeenThrown;
    }

    /// @brief Current ball weight (BALL_LIGHT/MEDIUM/HEAVY).
    expose func getBallType() -> Integer {
        return ballType;
    }

    /// @brief Wire up env-map reflections on the ball material.
    expose func applyEnvironment(env: CubeMap3D) {
        Material3D.SetEnvMap(ballMat, env);
        Material3D.set_Reflectivity(ballMat, config.BALL_REFLECTIVITY);
    }

    /// @brief Snap back to the spawn position; clear all per-throw state.
    expose func resetBall() {
        if (inWorld) {
            Physics3DWorld.Remove(world, body);
        }
        recreateBody();
        isInGutter = false;
        hasBeenThrown = false;
        spinAmount = 0.0;
        visualSpinAngle = 0.0;
        launchAngle = 0.0;
    }

    /// @brief Move the ball along the foul line for aim preview (pre-throw).
    expose func setAimPosition(aimX: Float) {
        var clampedAimX = aimX;
        if (clampedAimX < -config.AIM_MAX) { clampedAimX = -config.AIM_MAX; }
        if (clampedAimX > config.AIM_MAX) { clampedAimX = config.AIM_MAX; }
        var aimPct = clampedAimX / config.AIM_MAX;
        var releaseClamp = config.LANE_WIDTH / 2.0 - config.BALL_RADIUS * 1.85;
        if (releaseClamp < 0.16) { releaseClamp = 0.16; }
        var releaseX = aimPct * releaseClamp * config.BALL_RELEASE_X_SCALE;
        Physics3DBody.SetPosition(body,
            releaseX, config.BALL_RADIUS + config.BALL_START_Y_OFFSET, config.BALL_START_Z);
    }

    /// @brief Render the ball with translation + yaw + spin rotation.
    expose func draw(canvas: Canvas3D) {
        var pos = Physics3DBody.get_Position(body);
        var bx = Vec3.get_X(pos);
        var by = Vec3.get_Y(pos);
        var bz = Vec3.get_Z(pos);

        var translate = Mat4.Translate(bx, by, bz);
        var spinAxis = new Vec3(1.0, 0.0, 0.0);
        var rotateSpin = Mat4.RotateAxis(spinAxis, visualSpinAngle);
        var rotateYaw = Mat4.RotateAxis(new Vec3(0.0, 1.0, 0.0), launchAngle);
        Canvas3D.DrawMesh(canvas, ballMesh, Mat4.Mul(Mat4.Mul(translate, rotateYaw), rotateSpin), ballMat);
    }
}
