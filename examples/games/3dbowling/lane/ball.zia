//
// File: examples/games/3dbowling/lane/ball.zia
// Purpose: Owns catalog ball physics, delivery solving, trajectory feedback, and rendering.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: ball
// PURPOSE: Bowling ball entity. Owns its 3D physics body + mesh +
//          material, the per-weight stats (mass / max speed / hook
//          multiplier / colour), spin state, gutter tracking, and the
//          throw release model.
//
// WHERE-THIS-FITS: Owned by BowlingGame. Updated each physics step via
//          updateMotion (applies hook + drag + spin decay) and rendered
//          each frame via draw.
//
// KEY-DESIGN-CHOICES:
//   * SIX TACTICAL BALLS. The release catalog carries mass, speed, hook,
//     control, lane fit, unlock score, and colour. Selecting equipment
//     recreates the physics body and repaints its material.
//   * HOOK MODEL. The ball curves toward the pins as it travels: spin
//     creates a sideways force `hookForce = spin * multiplier *
//     (early + backend)` scaled by friction. Oiled portion gives
//     little hook; the ball "wakes up" on the dry backend (after
//     oilEndZ) and curves more aggressively. This mirrors real
//     bowling-ball physics.
//   * RELEASE GEOMETRY. doThrow computes a release position (close
//     to the centre line, scaled by aim), a target position (further
//     out, augmented by spin), and converts the (releaseX, targetX,
//     travelZ) triangle into (sideSpeed, forwardSpeed) so the throw
//     animates as a straight initial trajectory before the hook
//     kicks in.
//   * GUTTER LOCK. markGutter clamps the ball's X to the gutter
//     centre and reduces its collision mask so it can no longer
//     interact with pins. The ball still slides forward until it
//     exits at GUTTER_EXIT_Z.
//   * VISUAL SPIN VS PHYSICS SPIN. visualSpinAngle is purely cosmetic
//     (drives the rotation matrix in draw); spinAmount is the
//     physical hook coefficient. They evolve independently —
//     visualSpinAngle accumulates with speed, spinAmount decays with
//     friction.
// ============================================================================

// ball.zia — Ball entity: weight selection, release shaping, hook model, gutter state
module ball;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind "../config";
bind "../content/ball_catalog";
bind "../gameplay/delivery_model";
bind "../util/mathutil";

/// @brief Bowling ball entity with hook physics and weight-class stats.
class Ball {
    hide PhysicsBody3D body;
    hide PhysicsWorld3D world;
    hide Boolean inWorld;

    hide Float mass;
    hide Float maxSpeed;
    hide Float hookMultiplier;
    hide Integer control;
    hide Integer oilFit;
    hide String family;
    hide Float colorR;
    hide Float colorG;
    hide Float colorB;
    hide Integer ballType;
    hide Integer unlockScore;
    hide BallCatalog catalog;
    hide DeliveryModel deliveryModel;
    hide DeliverySolution lastDelivery;

    hide Mesh3D ballMesh;
    hide Mesh3D ballHoleMesh;
    hide Mesh3D targetHaloMesh;
    hide Mesh3D stripeMesh;
    hide Material3D ballMat;
    hide Material3D ballHoleMat;
    hide Material3D targetMat;
    hide Material3D stripeMat;

    hide Float spinAmount;
    hide Float visualSpinAngle;
    hide Float launchAngle;
    hide Float launchPower;
    hide List[Float] trailX;
    hide List[Float] trailZ;
    hide Float trailSampleTimer;
    hide Boolean isInGutter;
    hide Boolean hasBeenThrown;
    hide Boolean carryApplied;

    /// @brief One-time setup: physics body + mesh + material; defaults to MEDIUM weight.
    expose func initBall(physWorld: PhysicsWorld3D) {
        world = physWorld;
        inWorld = false;
        spinAmount = 0.0;
        visualSpinAngle = 0.0;
        launchAngle = 0.0;
        launchPower = 0.0;
        trailX = [];
        trailZ = [];
        trailSampleTimer = 0.0;
        isInGutter = false;
        hasBeenThrown = false;
        carryApplied = false;

        catalog = new BallCatalog();
        deliveryModel = new DeliveryModel();
        unlockScore = 0;
        ballType = 0;
        applyBallStats();

        ballMesh = Mesh3D.Sphere(config.BALL_RADIUS, 16);
        ballMat = Material3D.PBR(colorR, colorG, colorB);
        ballMat.Metallic = 0.04;
        ballMat.Roughness = 0.18;
        Material3D.SetShininess(ballMat, config.BALL_SHININESS);
        ballHoleMesh = Mesh3D.Sphere(config.BALL_RADIUS * 0.16, 8);
        ballHoleMat = Material3D.FromColor(0.015, 0.018, 0.022);
        Material3D.SetShininess(ballHoleMat, 18.0);
        targetHaloMesh = Mesh3D.Sphere(0.038, 8);
        targetMat = Material3D.FromColor(1.0, 0.82, 0.22);
        Material3D.SetEmissiveColor(targetMat, 0.18, 0.12, 0.02);
        stripeMesh = Mesh3D.Box(config.BALL_RADIUS * 1.45, 0.012, 0.026);
        stripeMat = Material3D.PBR(0.92, 0.96, 1.0);
        stripeMat.Metallic = 0.02;
        stripeMat.Roughness = 0.24;

        recreateBody();
    }

    /// @brief Copy weight-class stats (mass, max speed, hook, colour)
    ///        into the live `mass`/`maxSpeed`/etc. fields.
    hide func applyBallStats() {
        var spec = catalog.get(ballType);
        mass = spec.getMass();
        maxSpeed = spec.getMaxSpeed();
        hookMultiplier = spec.getHook();
        control = spec.getControl();
        oilFit = spec.getOilFit();
        family = spec.getFamily();
        var packed = spec.getColor();
        colorR = (((packed >> 16) & 255) + 0.0) / 255.0;
        colorG = (((packed >> 8) & 255) + 0.0) / 255.0;
        colorB = ((packed & 255) + 0.0) / 255.0;
    }

    /// @brief Tear down + rebuild the physics body. Called on weight
    ///        change and on resetBall — the body's mass is baked in
    ///        at construction so we have to recreate it.
    hide func recreateBody() {
        if (inWorld) {
            PhysicsWorld3D.Remove(world, body);
        }
        body = PhysicsBody3D.Sphere(config.BALL_RADIUS,
            mass * config.BALL_MASS_PHYSICS_SCALE);
        PhysicsBody3D.set_Restitution(body, config.BALL_RESTITUTION);
        PhysicsBody3D.set_Friction(body, config.BALL_FRICTION);
        PhysicsBody3D.set_LinearDamping(body, 0.015);
        PhysicsBody3D.set_AngularDamping(body, 0.025);
        PhysicsBody3D.set_UseCcd(body, true);
        PhysicsBody3D.set_CollisionLayer(body, config.LAYER_BALL);
        PhysicsBody3D.set_CollisionMask(body, config.MASK_BALL);
        PhysicsBody3D.SetPosition(body,
            config.BALL_START_X, config.BALL_RADIUS + config.BALL_START_Y_OFFSET, config.BALL_START_Z);
        PhysicsBody3D.SetVelocity(body, 0.0, 0.0, 0.0);
        inWorld = false;
    }

    /// @brief Switch to a specific weight (LIGHT/MEDIUM/HEAVY).
    expose func selectBall(btype: Integer) {
        var selected = btype;
        if (selected < 0) { selected = 0; }
        if (selected >= catalog.count()) { selected = catalog.count() - 1; }
        if (catalog.isUnlocked(selected, unlockScore) == false) { selected = 0; }
        ballType = selected;
        applyBallStats();
        Material3D.SetColor(ballMat, colorR, colorG, colorB);
        recreateBody();
    }

    /// @brief Cycle through every currently unlocked release ball.
    expose func cycleBall(dir: Integer) {
        var nextType = catalog.firstUnlockedFrom(ballType, dir, unlockScore);
        selectBall(nextType);
    }

    /// @brief Set the progression score used by equipment unlock checks.
    expose func setUnlockScore(score: Integer) { unlockScore = score; }

    expose func getBallName() -> String { return catalog.get(ballType).getName(); }
    expose func getBallFamily() -> String { return catalog.get(ballType).getFamily(); }
    expose func getBallControl() -> Integer { return catalog.get(ballType).getControl(); }
    expose func getBallOilFit() -> Integer { return catalog.get(ballType).getOilFit(); }
    expose func getBallColor() -> Integer { return catalog.get(ballType).getColor(); }

    /// @brief Set spin amount, clamped to ±SPIN_MAX. Positive = right-curve.
    expose func setSpin(amount: Float) {
        spinAmount = amount;
        if (spinAmount > config.SPIN_MAX) { spinAmount = config.SPIN_MAX; }
        if (spinAmount < -config.SPIN_MAX) { spinAmount = -config.SPIN_MAX; }
    }

    /// @brief Current spin amount.
    expose func getSpin() -> Float {
        return spinAmount;
    }

    /// @brief Commit a delivery produced by the shared deterministic solver.
    expose func doDelivery(stanceX: Float, targetX: Float, power: Float,
                           releaseOffset: Float, assist: Float,
                           difficulty: Integer, oilPattern: Integer,
                           spareRelease: Boolean) {
        lastDelivery = deliveryModel.solve(stanceX, targetX, power, spinAmount,
            releaseOffset, assist, difficulty, control, oilFit, oilPattern,
            family, maxSpeed, spareRelease);
        spinAmount = lastDelivery.axisRotation * hookMultiplier;
        launchPower = power;
        if (launchPower < 0.0) { launchPower = 0.0; }
        if (launchPower > 1.0) { launchPower = 1.0; }
        carryApplied = false;
        var sideSpeed = lastDelivery.sideSpeed;
        var forwardSpeed = lastDelivery.forwardSpeed;
        launchAngle = Atan2(sideSpeed, forwardSpeed);

        PhysicsBody3D.SetPosition(body,
            lastDelivery.releaseX, config.BALL_RADIUS + config.BALL_START_Y_OFFSET,
            config.BALL_THROW_Z);
        PhysicsBody3D.SetVelocity(body, sideSpeed, 0.0, forwardSpeed);
        PhysicsBody3D.SetAngularVelocity(body,
            lastDelivery.revRate,
            spinAmount * config.BALL_AXIS_SPIN_SPEED,
            -sideSpeed / config.BALL_RADIUS);

        if (inWorld == false) {
            PhysicsWorld3D.Add(world, body);
            inWorld = true;
        }

        isInGutter = false;
        hasBeenThrown = true;
        Say("Thrown! Power: " + toString(Convert.NumToInt(power * 100.0))
            + "%  Accuracy: " +
            toString(Convert.NumToInt(lastDelivery.effectiveAccuracy * 100.0))
            + "%  Shape: " + toString(Convert.NumToInt(spinAmount * 100.0)));
    }

    /// @brief Per-physics-step in-flight update.
    /// @details Applies hook force (spin × multiplier × early/backend ×
    ///          friction), side drag, and decays spin based on
    ///          current friction (oiled ≪ dry).
    expose func updateMotion(dt: Float, laneFriction: Float, oilEndZ: Float) {
        if (hasBeenThrown == false || isInGutter) { return; }

        var pos = PhysicsBody3D.get_Position(body);
        var vel = PhysicsBody3D.get_Velocity(body);
        var x = Vec3.get_X(pos);
        var z = Vec3.get_Z(pos);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var speed = Sqrt(vx * vx + vz * vz);
        if (speed < 0.05) { return; }

        // The simplified rigid-body solver otherwise gives minimum-power
        // deliveries nearly the same rack carry as useful releases. Apply the
        // power-dependent momentum loss once, immediately before the deck.
        if (carryApplied == false && z >= config.PIN_Z_OFFSET - 1.05) {
            var carry = 1.0;
            if (launchPower < config.CARRY_POWER_FLOOR) {
                carry = 0.48 + launchPower * 0.65;
            } else if (launchPower > config.CARRY_POWER_PEAK_END) {
                carry = 1.0 - (launchPower - config.CARRY_POWER_PEAK_END) * 0.25;
            }
            if (carry < 0.48) { carry = 0.48; }
            PhysicsBody3D.SetVelocity(body, vx * carry,
                Vec3.get_Y(vel), vz * carry);
            vx = vx * carry;
            vz = vz * carry;
            speed = speed * carry;
            carryApplied = true;
        }

        var backend = 0.0;
        if (z > oilEndZ) {
            backend = (z - oilEndZ) / 3.0;
            if (backend > 1.0) { backend = 1.0; }
        }
        var frictionPct = mathutil.normFrac(laneFriction,
            config.OIL_FRICTION_OILED, config.OIL_FRICTION_DRY);

        var hookForce = spinAmount * hookMultiplier *
            (config.EARLY_HOOK_FORCE + backend * config.BACKEND_HOOK_FORCE) * frictionPct;
        hookForce = hookForce * (0.55 + frictionPct * 0.35);
        var dragForce = -vx * config.SIDE_DRAG * (0.8 + frictionPct);
        var assistForce = 0.0;
        // Arcade rail (bumpers): a centering force near the edges plus a hard
        // X clamp so the ball can never gutter. Off by default so the ball
        // obeys physics and a badly aimed shot rolls into the gutter trough.
        if (config.BUMPERS_ENABLED == 1) {
            var laneHalf = config.LANE_WIDTH / 2.0;
            var edgeStart = laneHalf * config.LANE_ASSIST_EDGE_RATIO;
            var edgeLimit = laneHalf + config.GUTTER_DETECT_OVERHANG;
            if (z > config.GUTTER_DETECT_Z && z < config.GUTTER_DETECT_END_Z && Abs(x) > edgeStart) {
                var edgePct = (Abs(x) - edgeStart) / (edgeLimit - edgeStart + 0.0001);
                if (edgePct < 0.0) { edgePct = 0.0; }
                if (edgePct > 1.0) { edgePct = 1.0; }
                var edgeSign = 1.0;
                if (x < 0.0) { edgeSign = -1.0; }
                assistForce = -edgeSign * config.LANE_ASSIST_FORCE * edgePct * edgePct;
                dragForce = dragForce - vx * config.LANE_ASSIST_DAMP * edgePct;
            }
        }
        PhysicsBody3D.ApplyForce(body, hookForce + dragForce + assistForce, 0.0, 0.0);

        if (config.BUMPERS_ENABLED == 1 &&
            z > config.GUTTER_DETECT_Z && z < config.PIN_Z_OFFSET - 0.75 && Abs(x) > config.LANE_SAFE_HALF_WIDTH) {
            var safeSign = 1.0;
            if (x < 0.0) { safeSign = -1.0; }
            var safeX = safeSign * config.LANE_SAFE_HALF_WIDTH;
            var correctedVx = vx;
            if (correctedVx * safeSign > 0.0) {
                correctedVx = -correctedVx * 0.18;
            } else {
                correctedVx = correctedVx * 0.35;
            }
            PhysicsBody3D.SetPosition(body, safeX, Vec3.get_Y(pos), z);
            PhysicsBody3D.SetVelocity(body, correctedVx, Vec3.get_Y(vel), vz);
            x = safeX;
            vx = correctedVx;
        }

        var spinDecay = config.SPIN_DECAY_OIL + (config.SPIN_DECAY_DRY - config.SPIN_DECAY_OIL) * frictionPct;
        if (spinAmount > 0.0) {
            spinAmount = spinAmount - spinDecay * dt;
            if (spinAmount < 0.0) { spinAmount = 0.0; }
        } else if (spinAmount < 0.0) {
            spinAmount = spinAmount + spinDecay * dt;
            if (spinAmount > 0.0) { spinAmount = 0.0; }
        }

        visualSpinAngle = visualSpinAngle + speed * dt * config.SPIN_VISUAL_SPEED;
        PhysicsBody3D.SetAngularVelocity(body,
            vz / config.BALL_RADIUS,
            spinAmount * config.BALL_AXIS_SPIN_SPEED,
            -vx / config.BALL_RADIUS);
        if (x > config.LANE_WIDTH) {
            spinAmount = spinAmount * 0.95;
        }
    }

    /// @brief Arcade lane guard: keep normal throws rolling on the lane.
    /// @note Bumper-mode only. In skill play the ball rides real physics
    ///       (lane floor + gutter troughs) with no positional override.
    expose func stabilizeLaneRoll() {
        if (config.BUMPERS_ENABLED == 0) { return; }
        if (hasBeenThrown == false || isInGutter) { return; }

        var pos = PhysicsBody3D.get_Position(body);
        var x = Vec3.get_X(pos);
        var z = Vec3.get_Z(pos);
        if (z < config.BALL_THROW_Z - 0.08 || z > config.LANE_STABILIZE_END_Z) { return; }

        var vel = PhysicsBody3D.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var safeX = x;
        if (safeX < -config.LANE_SAFE_HALF_WIDTH) { safeX = -config.LANE_SAFE_HALF_WIDTH; }
        if (safeX > config.LANE_SAFE_HALF_WIDTH) { safeX = config.LANE_SAFE_HALF_WIDTH; }
        var wasClamped = Abs(safeX - x) > 0.0001;

        if (wasClamped) {
            vx = vx * 0.22;
            if (safeX < 0.0 && vx < 0.0) { vx = 0.0 - vx * 0.16; }
            if (safeX > 0.0 && vx > 0.0) { vx = 0.0 - vx * 0.16; }
        }

        var rollY = config.BALL_RADIUS + config.BALL_START_Y_OFFSET;
        PhysicsBody3D.SetPosition(body, safeX, rollY, z);

        if (vz < config.BALL_ROLL_MIN_SPEED) { vz = config.BALL_ROLL_MIN_SPEED; }
        if (vz > maxSpeed * 1.03) { vz = maxSpeed * 1.03; }
        PhysicsBody3D.SetVelocity(body, vx, 0.0, vz);
        PhysicsBody3D.SetAngularVelocity(body,
            vz / config.BALL_RADIUS,
            spinAmount * config.BALL_AXIS_SPIN_SPEED,
            -vx / config.BALL_RADIUS);
    }

    /// @brief Apply a slight slowdown when the ball enters the pin deck
    ///        so collision energy looks "absorbed" rather than elastic.
    expose func dampForPinDeckImpact(depth: Float) {
        if (hasBeenThrown == false || isInGutter) { return; }

        var vel = PhysicsBody3D.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var slowdown = config.BALL_DECK_IMPACT_SLOWDOWN - depth * 8.0;
        if (slowdown < 0.62) { slowdown = 0.62; }
        if (slowdown > 0.90) { slowdown = 0.90; }
        vx = vx * config.BALL_DECK_IMPACT_SIDE_DAMP;
        vz = vz * slowdown;
        if (vz < 0.35) { vz = 0.35; }
        PhysicsBody3D.SetVelocity(body, vx, Vec3.get_Y(vel), vz);
    }

    /// @brief Lock the ball into the gutter (clamp X, reduce collision mask
    ///        so it can't hit pins). Continues sliding forward until exit.
    expose func markGutter(side: Integer) {
        isInGutter = true;
        var gutterSign = 1.0;
        if (side < 0) { gutterSign = -1.0; }

        var pos = PhysicsBody3D.get_Position(body);
        var vel = PhysicsBody3D.get_Velocity(body);
        var vz = Vec3.get_Z(vel);
        var safeX = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W * 0.68;
        PhysicsBody3D.SetPosition(body, gutterSign * safeX, Vec3.get_Y(pos), Vec3.get_Z(pos));
        PhysicsBody3D.SetVelocity(body, gutterSign * 0.22, 0.0, vz * 0.9);
        PhysicsBody3D.set_CollisionMask(body, config.LAYER_STATIC);
    }

    /// @brief Release the gutter lock (reset only).
    expose func clearGutter() {
        isInGutter = false;
        PhysicsBody3D.set_CollisionMask(body, config.MASK_BALL);
    }

    /// @brief Underlying physics body (for trigger callbacks).
    expose func getBody() -> PhysicsBody3D {
        return body;
    }

    /// @brief Replace a stalled/corrupt trajectory with a quiet safe state.
    expose func stopAtSafePosition(x: Float, z: Float) {
        var safeX = x;
        var safeZ = z;
        if (safeX < -config.LANE_SAFE_HALF_WIDTH) { safeX = -config.LANE_SAFE_HALF_WIDTH; }
        if (safeX > config.LANE_SAFE_HALF_WIDTH) { safeX = config.LANE_SAFE_HALF_WIDTH; }
        if (safeZ < config.BALL_THROW_Z) { safeZ = config.BALL_THROW_Z; }
        if (safeZ > config.GUTTER_EXIT_Z) { safeZ = config.GUTTER_EXIT_Z; }
        PhysicsBody3D.SetPosition(body, safeX,
            config.BALL_RADIUS + config.BALL_START_Y_OFFSET, safeZ);
        PhysicsBody3D.SetVelocity(body, 0.0, 0.0, 0.0);
        PhysicsBody3D.SetAngularVelocity(body, 0.0, 0.0, 0.0);
    }

    /// @brief Current world position.
    expose func getPosition() -> Vec3 {
        return PhysicsBody3D.get_Position(body);
    }

    /// @brief Current world velocity.
    expose func getVelocity() -> Vec3 {
        return PhysicsBody3D.get_Velocity(body);
    }

    /// @brief Speed magnitude (sqrt of vx² + vy² + vz²).
    expose func getSpeed() -> Float {
        var vel = PhysicsBody3D.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vy = Vec3.get_Y(vel);
        var vz = Vec3.get_Z(vel);
        return Sqrt(vx * vx + vy * vy + vz * vz);
    }

    /// @brief Travel angle off the straight-down-lane axis, in degrees.
    /// @details 0° = dead straight; a real strike wants the ball entering
    ///          the pocket at roughly 4–6°. Sampled near the head pin for
    ///          the shot-feedback HUD readout.
    expose func getTravelAngleDeg() -> Float {
        var vel = PhysicsBody3D.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        if (vz < 0.05) { return 0.0; }
        return Atan2(Abs(vx), vz) * 57.29577951;
    }

    /// @brief Current X coordinate.
    expose func getPosX() -> Float {
        return PhysicsBody3D.get_Position(body).X;
    }

    /// @brief Current Z coordinate.
    expose func getPosZ() -> Float {
        return PhysicsBody3D.get_Position(body).Z;
    }

    /// @brief True once the ball has crossed past the pin deck.
    expose func hasPastPins() -> Boolean {
        return getPosZ() > config.PIN_Z_OFFSET + 1.8;
    }

    /// @brief True when the ball has nearly stopped (settling check).
    expose func isSlow() -> Boolean {
        return getSpeed() < 0.45;
    }

    /// @brief True when the ball is locked in a gutter.
    expose func gutterBall() -> Boolean {
        return isInGutter;
    }

    /// @brief True after the first doThrow of a delivery cycle.
    expose func thrown() -> Boolean {
        return hasBeenThrown;
    }

    /// @brief Current release-catalog ball index.
    expose func getBallType() -> Integer {
        return ballType;
    }

    expose func getLastDeliveryAccuracy() -> Float {
        if (lastDelivery == null) { return 1.0; }
        return lastDelivery.effectiveAccuracy;
    }

    expose func getLastDeliverySpeed() -> Float {
        if (lastDelivery == null) { return 0.0; }
        return lastDelivery.launchSpeed;
    }

    /// @brief Wire up env-map reflections on the ball material.
    expose func applyEnvironment(env: CubeMap3D) {
        Material3D.SetEnvMap(ballMat, env);
        ballMat.Reflectivity = config.BALL_REFLECTIVITY;
        Material3D.SetEnvMap(ballHoleMat, env);
        ballHoleMat.Reflectivity = 0.05;
    }

    /// @brief Snap back to the spawn position; clear all per-throw state.
    expose func resetBall() {
        recreateBody();
        isInGutter = false;
        hasBeenThrown = false;
        spinAmount = 0.0;
        visualSpinAngle = 0.0;
        launchAngle = 0.0;
        launchPower = 0.0;
        carryApplied = false;
        trailX.clear();
        trailZ.clear();
        trailSampleTimer = 0.0;
    }

    /// @brief Fixed-time trail sampling, independent of render refresh rate.
    expose func sampleTrail(dt: Float) {
        if (hasBeenThrown == false || isInGutter || dt <= 0.0) { return; }
        var step = dt;
        if (step > 0.05) { step = 0.05; }
        trailSampleTimer = trailSampleTimer + step;
        var emitted = 0;
        while (trailSampleTimer >= config.TRAIL_SAMPLE_SECONDS && emitted < 4) {
            trailSampleTimer = trailSampleTimer - config.TRAIL_SAMPLE_SECONDS;
            var pos = PhysicsBody3D.get_Position(body);
            var vel = PhysicsBody3D.get_Velocity(body);
            var vx = Vec3.get_X(vel);
            var vz = Vec3.get_Z(vel);
            var speed = Sqrt(vx * vx + vz * vz);
            if (speed > config.TRAIL_MIN_SPEED) {
                trailX.add(Vec3.get_X(pos));
                trailZ.add(Vec3.get_Z(pos));
                while (trailX.count() > config.TRAIL_MAX) {
                    trailX.removeAt(0);
                    trailZ.removeAt(0);
                }
            }
            emitted = emitted + 1;
        }
    }

    expose func getTrailSampleCount() -> Integer { return trailX.count(); }

    /// @brief Sample + draw a fading ground streak behind the rolling ball.
    /// @details Read-only w.r.t. physics — samples the body's position each
    ///          render frame into a capped ring buffer and paints age-faded
    ///          line segments. Only records while genuinely rolling so a
    ///          settled ball's trail decays away as the buffer is consumed.
    expose func drawTrail(canvas: Canvas3D) {
        if (hasBeenThrown == false || isInGutter) { return; }
        var n = trailX.count();
        for (var i: Integer = 1; i < n; i = i + 1) {
            var age = (i + 0.0) / (n + 0.0); // 0..1, newest brightest
            var shade = Convert.NumToInt(50.0 + age * 170.0);
            var glow = Convert.NumToInt(30.0 + age * 150.0);
            var col = (shade << 16) + (glow << 8) + Convert.NumToInt(60.0 + age * 120.0);
            Canvas3D.DrawLine3D(canvas,
                new Vec3(trailX.get(i - 1), 0.03, trailZ.get(i - 1)),
                new Vec3(trailX.get(i), 0.03, trailZ.get(i)), col);
        }
    }

    /// @brief Position the unthrown ball on the selected stance board.
    expose func setSetupPosition(stanceX: Float) {
        var releaseX = stanceX;
        if (releaseX < -config.STANCE_MAX) { releaseX = -config.STANCE_MAX; }
        if (releaseX > config.STANCE_MAX) { releaseX = config.STANCE_MAX; }
        PhysicsBody3D.SetPosition(body,
            releaseX, config.BALL_RADIUS + config.BALL_START_Y_OFFSET, config.BALL_THROW_Z);
    }

    /// @brief Draw the delivery corridor from the exact launch solver inputs.
    expose func drawDeliveryPreview(canvas: Canvas3D, stanceX: Float,
                                    targetX: Float, spinPreview: Float,
                                    powerPreview: Float, releaseOffset: Float,
                                    assist: Float, difficulty: Integer,
                                    oilPattern: Integer, oilEndZ: Float,
                                    spareRelease: Boolean, highContrast: Boolean) {
        var solution = deliveryModel.solve(stanceX, targetX, powerPreview,
            spinPreview, releaseOffset, assist, difficulty, control, oilFit,
            oilPattern, family, maxSpeed, spareRelease);
        var guideStartZ = config.BALL_THROW_Z + 0.24;
        var guideColor = 0x56CFE1;
        var edgeColor = 0x285866;
        if (highContrast) {
            guideColor = 0xFFFFFF;
            edgeColor = 0xFFD166;
        }
        var priorX = solution.releaseX;
        var priorLeft = priorX - solution.uncertaintyWidth;
        var priorRight = priorX + solution.uncertaintyWidth;
        var predEndX = priorX;
        for (var i: Integer = 1; i <= config.HOOK_GUIDE_SEGMENTS; i = i + 1) {
            var t = (i + 0.0) / (config.HOOK_GUIDE_SEGMENTS + 0.0);
            var z = guideStartZ + (config.BALL_TARGET_Z - guideStartZ) * t;
            var backend = 0.0;
            if (z > oilEndZ) {
                backend = (z - oilEndZ) / 3.0;
                if (backend > 1.0) { backend = 1.0; }
            }
            var baseX = solution.releaseX +
                (solution.projectedTargetX - solution.releaseX) * t;
            var hookShape = config.EARLY_HOOK_FORCE * t * t +
                config.BACKEND_HOOK_FORCE * backend * backend;
            var hook = solution.effectiveHook * hookMultiplier * hookShape *
                config.HOOK_GUIDE_SCALE;
            var x = baseX + hook;
            var corridor = solution.uncertaintyWidth * (0.35 + t * 0.65);
            if ((i % 2) == 0) {
                Canvas3D.DrawLine3D(canvas,
                    new Vec3(priorX, 0.047, guideStartZ +
                        (config.BALL_TARGET_Z - guideStartZ) * ((i - 1.0) /
                        (config.HOOK_GUIDE_SEGMENTS + 0.0))),
                    new Vec3(x, 0.047, z), guideColor);
            }
            Canvas3D.DrawLine3D(canvas,
                new Vec3(priorLeft, 0.041, guideStartZ +
                    (config.BALL_TARGET_Z - guideStartZ) * ((i - 1.0) /
                    (config.HOOK_GUIDE_SEGMENTS + 0.0))),
                new Vec3(x - corridor, 0.041, z), edgeColor);
            Canvas3D.DrawLine3D(canvas,
                new Vec3(priorRight, 0.041, guideStartZ +
                    (config.BALL_TARGET_Z - guideStartZ) * ((i - 1.0) /
                    (config.HOOK_GUIDE_SEGMENTS + 0.0))),
                new Vec3(x + corridor, 0.041, z), edgeColor);
            priorX = x;
            priorLeft = x - corridor;
            priorRight = x + corridor;
            predEndX = x;
        }
        Canvas3D.DrawMesh(canvas, targetHaloMesh,
            Mat4.Translate(predEndX, 0.045, config.BALL_TARGET_Z), targetMat);
    }

    /// @brief Render the ball with translation + yaw + spin rotation.
    expose func draw(canvas: Canvas3D) {
        var pos = PhysicsBody3D.get_Position(body);
        var bx = Vec3.get_X(pos);
        var by = Vec3.get_Y(pos);
        var bz = Vec3.get_Z(pos);

        var vel = PhysicsBody3D.get_Velocity(body);
        var vx = Vec3.get_X(vel);
        var vz = Vec3.get_Z(vel);
        var speed = Sqrt(vx * vx + vz * vz);
        var axisX = 1.0;
        var axisZ = 0.0;
        if (speed > 0.05) {
            axisX = vz / speed;
            axisZ = -vx / speed;
        }

        var translate = Mat4.Translate(bx, by, bz);
        var spinAxis = new Vec3(axisX, 0.0, axisZ);
        var rotateSpin = Mat4.RotateAxis(spinAxis, visualSpinAngle);
        var ballXform = Mat4.Mul(translate, rotateSpin);
        Canvas3D.DrawMesh(canvas, ballMesh, ballXform, ballMat);
        Canvas3D.DrawMesh(canvas, stripeMesh,
            Mat4.Mul(ballXform, Mat4.Translate(0.0, config.BALL_RADIUS * 0.88, 0.0)),
            stripeMat);
        Canvas3D.DrawMesh(canvas, ballHoleMesh,
            Mat4.Mul(ballXform, Mat4.Translate(-0.036, 0.048, -0.089)), ballHoleMat);
        Canvas3D.DrawMesh(canvas, ballHoleMesh,
            Mat4.Mul(ballXform, Mat4.Translate(0.010, 0.066, -0.084)), ballHoleMat);
        Canvas3D.DrawMesh(canvas, ballHoleMesh,
            Mat4.Mul(ballXform, Mat4.Translate(0.045, 0.024, -0.094)), ballHoleMat);
    }
}
