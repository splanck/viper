// ============================================================================
// MODULE: lane (LaneBuilder)
// PURPOSE: Build and own every static element of the lane scene: the
//          lane surface, oil pattern, pin deck, gutters, walls, room
//          floor + side panels + ceiling, foul line, sweep bar, arrow /
//          dot lane markers, ceiling lights, plus the matching physics
//          bodies and trigger zones for gutter / pin-deck detection.
//
// WHERE-THIS-FITS: Constructed once by BowlingGame.init(). Drawn each
//          frame via draw(). The friction model (getFrictionAt) is
//          consulted by ball.updateMotion every physics step.
//
// KEY-DESIGN-CHOICES:
//   * STATIC EVERYTHING. Every body is set_Static(true) so the physics
//     engine treats them as immovable. The ball and pins collide with
//     them but never push them.
//   * INSTANCED SCENE ITEMS. Lane arrows, dots, and ceiling lights
//     repeat with regular spacing — we batch them into
//     InstanceBatch3D so the GPU draws all instances of each mesh in
//     one DrawInstanced call.
//   * THREE OIL PATTERNS. HOUSE / SPORT / DRY differ in oil length
//     (oilEndZ) and the friction-vs-board curve. House: long oil
//     down the centre, dry edges → easy hook. Sport: short oil, less
//     edge differential → punishes off-line shots. Dry: minimal oil
//     → straight-ball play.
//   * FRICTION MODEL. getFrictionAt(x, z) computes a 2D friction value:
//     base oiled friction along the central oiled corridor, blended
//     to dry friction toward the edges (`boardPct² edge weighting`)
//     and toward the back of the lane (`backend` after oilEndZ).
//     This is what makes the hook physics feel realistic.
//   * THREE TRIGGER VOLUMES. leftGutter/rightGutter/pinDeck sense
//     when the ball enters those regions; BowlingGame's trigger
//     callback flags the ball's state accordingly.
// ============================================================================

// lane.zia — Lane geometry, batching, physics surfaces, oil model, trigger zones
module lane;

bind Viper.Graphics3D;
bind Viper.Graphics;
bind Viper.Math;
bind Viper.Core.Convert as Convert;
bind Viper.IO;
bind "../config";
bind "../util/mathutil";

var sharedLaneTexture: Pixels = null;

/// @brief Builds and owns every static lane mesh / body / trigger.
class LaneBuilder {
    hide Mesh3D laneMesh;
    hide Mesh3D boardMesh;
    hide Mesh3D oilMesh;
    hide Mesh3D pinDeckMesh;
    hide Mesh3D roomFloorMesh;
    hide Mesh3D sideLaneMesh;
    hide Mesh3D sideGutterMesh;
    hide Mesh3D gutterMesh;
    hide Mesh3D wallMesh;
    hide Mesh3D backWallMesh;
    hide Mesh3D ceilingMesh;
    hide Mesh3D sidePanelMesh;
    hide Mesh3D pinsetterMesh;
    hide Mesh3D approachMesh;
    hide Mesh3D foulLineMesh;
    hide Mesh3D sweepBarMesh;
    hide Mesh3D arrowMesh;
    hide Mesh3D dotMesh;
    hide Mesh3D lightMesh;
    hide Mesh3D monitorMesh;
    hide Mesh3D ballReturnMesh;
    hide Mesh3D ballReturnHoodMesh;
    hide Mesh3D seatMesh;
    hide Mesh3D tableMesh;
    hide Mesh3D neonStripMesh;
    hide Mesh3D spectatorBodyMesh;
    hide Mesh3D spectatorHeadMesh;
    hide Mesh3D venueSignMesh;
    hide Mesh3D venueSignBarMesh;
    hide Mesh3D decorPinBodyMesh;
    hide Mesh3D decorPinHeadMesh;
    hide Mesh3D decorPinBandMesh;
    hide Mesh3D rackBallMesh;

    hide Material3D laneMat;
    hide Material3D boardLightMat;
    hide Material3D boardDarkMat;
    hide Material3D oilMat;
    hide Material3D pinDeckMat;
    hide Material3D roomFloorMat;
    hide Material3D sideLaneMat;
    hide Material3D sideGutterMat;
    hide Material3D gutterMat;
    hide Material3D wallMat;
    hide Material3D backWallMat;
    hide Material3D ceilingMat;
    hide Material3D sidePanelMat;
    hide Material3D pinsetterMat;
    hide Material3D approachMat;
    hide Material3D foulLineMat;
    hide Material3D sweepBarMat;
    hide Material3D arrowMat;
    hide Material3D dotMat;
    hide Material3D lightMat;
    hide Material3D monitorMat;
    hide Material3D ballReturnMat;
    hide Material3D ballReturnHoodMat;
    hide Material3D seatMat;
    hide Material3D tableMat;
    hide Material3D neonCyanMat;
    hide Material3D neonCoralMat;
    hide Material3D spectatorMat;
    hide Material3D venueSignMat;
    hide Material3D decorPinMat;
    hide Material3D decorPinBandMat;
    hide Material3D rackBallCyanMat;
    hide Material3D rackBallCoralMat;
    hide Pixels laneTexture;
    hide Integer lanePreviewLight;
    hide Integer lanePreviewDark;

    hide Mat4 laneXform;
    hide Mat4 oilXform;
    hide Mat4 pinDeckXform;
    hide Mat4 roomFloorXform;
    hide Mat4 sideLaneLeftXform;
    hide Mat4 sideLaneRightXform;
    hide Mat4 sideGutterLeftXform;
    hide Mat4 sideGutterRightXform;
    hide Mat4 gutterLeftXform;
    hide Mat4 gutterRightXform;
    hide Mat4 wallLeftXform;
    hide Mat4 wallRightXform;
    hide Mat4 backWallXform;
    hide Mat4 ceilingXform;
    hide Mat4 sidePanelLeftXform;
    hide Mat4 sidePanelRightXform;
    hide Mat4 pinsetterXform;
    hide Mat4 approachXform;
    hide Mat4 foulLineXform;
    hide Mat4 venueSignXform;

    hide InstanceBatch3D arrowBatch;
    hide InstanceBatch3D dotBatch;
    hide InstanceBatch3D lightBatch;
    hide InstanceBatch3D monitorBatch;
    hide InstanceBatch3D ballReturnBatch;
    hide InstanceBatch3D ballReturnHoodBatch;
    hide InstanceBatch3D seatBatch;
    hide InstanceBatch3D tableBatch;
    hide InstanceBatch3D neonCyanBatch;
    hide InstanceBatch3D neonCoralBatch;
    hide InstanceBatch3D spectatorBodyBatch;
    hide InstanceBatch3D spectatorHeadBatch;
    hide InstanceBatch3D boardLightBatch;
    hide InstanceBatch3D boardDarkBatch;
    hide InstanceBatch3D signCyanBatch;
    hide InstanceBatch3D signAmberBatch;
    hide InstanceBatch3D decorPinBodyBatch;
    hide InstanceBatch3D decorPinHeadBatch;
    hide InstanceBatch3D decorPinBandBatch;
    hide InstanceBatch3D rackBallCyanBatch;
    hide InstanceBatch3D rackBallCoralBatch;

    hide Float oilEndZ;
    hide Integer oilPattern;
    hide Float laneCenterZ;
    hide List[Float] oilWear;

    hide Physics3DBody laneFloorBody;
    hide Physics3DBody gutterFloorL;
    hide Physics3DBody gutterFloorR;
    hide Physics3DBody wallBodyL;
    hide Physics3DBody wallBodyR;
    hide Physics3DBody backWallBody;

    hide Trigger3D leftGutterTrigger;
    hide Trigger3D rightGutterTrigger;
    hide Trigger3D pinDeckTrigger;

    /// @brief Build all meshes / transforms / batches / physics / triggers.
    /// @param pattern OIL_HOUSE / OIL_SPORT / OIL_DRY (sets oilEndZ).
    expose func initLane(world: Physics3DWorld, pattern: Integer) {
        oilPattern = pattern;
        if (pattern == config.OIL_SPORT) {
            oilEndZ = config.OIL_END_SPORT;
        } else if (pattern == config.OIL_DRY) {
            oilEndZ = config.OIL_END_DRY;
        } else {
            oilEndZ = config.OIL_END_HOUSE;
        }

        laneCenterZ = (config.LANE_LENGTH - config.LANE_APPROACH) / 2.0;
        oilWear = [];
        for (var wi: Integer = 0; wi < 9; wi = wi + 1) { oilWear.add(0.0); }
        lanePreviewLight = 0xD6A353;
        lanePreviewDark = 0xB97B35;
        buildMeshes();
        buildTransforms();
        buildBatches();
        buildPhysics(world);
        buildTriggers();
    }

    /// @brief Build every Mesh3D + Material3D pair for the static scene.
    hide func buildMeshes() {
        var totalLen = config.LANE_LENGTH + config.LANE_APPROACH;

        laneMesh = Mesh3D.Box(config.LANE_WIDTH, 0.05, totalLen);
        laneMat = Material3D.PBR(config.LANE_COLOR_R, config.LANE_COLOR_G, config.LANE_COLOR_B);
        laneMat.Metallic = 0.0;
        laneMat.Roughness = 0.32;
        laneMat.SsrEnabled = true;
        Material3D.SetShininess(laneMat, config.LANE_SHININESS);
        boardMesh = Mesh3D.Box(config.LANE_WIDTH / (config.LANE_BOARD_COUNT + 0.0) * 0.92, 0.006, totalLen);
        boardLightMat = Material3D.PBR(
            config.LANE_BOARD_LIGHT_R, config.LANE_BOARD_LIGHT_G, config.LANE_BOARD_LIGHT_B);
        boardLightMat.Metallic = 0.0;
        boardLightMat.Roughness = 0.36;
        Material3D.SetShininess(boardLightMat, config.LANE_SHININESS);
        boardDarkMat = Material3D.PBR(
            config.LANE_BOARD_DARK_R, config.LANE_BOARD_DARK_G, config.LANE_BOARD_DARK_B);
        boardDarkMat.Metallic = 0.0;
        boardDarkMat.Roughness = 0.42;
        Material3D.SetShininess(boardDarkMat, config.LANE_SHININESS * 0.82);

        var oilLen = oilEndZ - config.OIL_START_Z;
        if (oilLen < 0.5) { oilLen = 0.5; }
        oilMesh = Mesh3D.Box(config.LANE_WIDTH - 0.02, 0.005, oilLen);
        oilMat = Material3D.FromColor(config.LANE_OIL_COLOR_R, config.LANE_OIL_COLOR_G, config.LANE_OIL_COLOR_B);
        Material3D.SetShininess(oilMat, config.LANE_OIL_SHININESS);
        oilMat.Alpha = 0.11;
        oilMat.AlphaMode = 2;
        oilMat.SsrEnabled = true;

        pinDeckMesh = Mesh3D.Box(config.LANE_WIDTH - 0.02, 0.008, 1.9);
        pinDeckMat = Material3D.FromColor(config.PIN_DECK_COLOR_R, config.PIN_DECK_COLOR_G, config.PIN_DECK_COLOR_B);
        Material3D.SetShininess(pinDeckMat, config.PIN_DECK_SHININESS);

        roomFloorMesh = Mesh3D.Box(8.8, 0.05, totalLen + 6.0);
        roomFloorMat = Material3D.FromColor(config.ROOM_FLOOR_R, config.ROOM_FLOOR_G, config.ROOM_FLOOR_B);
        Material3D.SetShininess(roomFloorMat, 18.0);

        sideLaneMesh = Mesh3D.Box(config.LANE_WIDTH, 0.03, totalLen + 1.2);
        sideLaneMat = Material3D.FromColor(config.ROOM_SIDE_LANE_R, config.ROOM_SIDE_LANE_G, config.ROOM_SIDE_LANE_B);
        Material3D.SetShininess(sideLaneMat, 38.0);

        sideGutterMesh = Mesh3D.Box(config.LANE_GUTTER_W * 2.0 + 0.12, 0.03, totalLen + 1.2);
        sideGutterMat = Material3D.FromColor(config.ROOM_SIDE_GUTTER_R, config.ROOM_SIDE_GUTTER_G, config.ROOM_SIDE_GUTTER_B);

        gutterMesh = Mesh3D.Box(config.LANE_GUTTER_W, 0.04, totalLen);
        gutterMat = Material3D.FromColor(config.GUTTER_COLOR_R, config.GUTTER_COLOR_G, config.GUTTER_COLOR_B);

        wallMesh = Mesh3D.Box(0.05, config.LANE_WALL_H, totalLen);
        wallMat = Material3D.FromColor(config.WALL_COLOR_R, config.WALL_COLOR_G, config.WALL_COLOR_B);

        var backW = 8.8;
        backWallMesh = Mesh3D.Box(backW, 4.2, 0.18);
        backWallMat = Material3D.FromColor(config.ROOM_WALL_R, config.ROOM_WALL_G, config.ROOM_WALL_B);

        ceilingMesh = Mesh3D.Box(8.8, 0.08, totalLen + 2.8);
        ceilingMat = Material3D.FromColor(0.012, 0.024, 0.055);
        Material3D.SetShininess(ceilingMat, 10.0);

        sidePanelMesh = Mesh3D.Box(0.26, 3.8, totalLen + 2.8);
        sidePanelMat = Material3D.FromColor(config.ROOM_WALL_R, config.ROOM_WALL_G, config.ROOM_WALL_B);
        Material3D.SetShininess(sidePanelMat, 8.0);

        pinsetterMesh = Mesh3D.Box(backW, 0.34, 0.72);
        pinsetterMat = Material3D.FromColor(0.018, 0.032, 0.050);
        Material3D.SetShininess(pinsetterMat, 22.0);

        approachMesh = Mesh3D.Box(config.LANE_WIDTH + 1.0, 0.04, config.LANE_APPROACH);
        approachMat = Material3D.FromColor(config.APPROACH_COLOR_R, config.APPROACH_COLOR_G, config.APPROACH_COLOR_B);

        foulLineMesh = Mesh3D.Box(config.LANE_WIDTH + 0.12, 0.06, 0.02);
        foulLineMat = Material3D.FromColor(config.FOUL_LINE_R, config.FOUL_LINE_G, config.FOUL_LINE_B);
        Material3D.SetEmissiveColor(foulLineMat, config.FOUL_LINE_EMISSIVE, 0.02, 0.02);

        sweepBarMesh = Mesh3D.Box(config.LANE_WIDTH + config.LANE_GUTTER_W * 2.0, 0.08, 0.15);
        sweepBarMat = Material3D.FromColor(config.SWEEP_COLOR_R, config.SWEEP_COLOR_G, config.SWEEP_COLOR_B);
        Material3D.SetShininess(sweepBarMat, 40.0);

        arrowMesh = Mesh3D.Box(0.03, 0.055, 0.15);
        arrowMat = Material3D.FromColor(config.ARROW_COLOR_R, config.ARROW_COLOR_G, config.ARROW_COLOR_B);

        dotMesh = Mesh3D.Sphere(0.012, 6);
        dotMat = Material3D.FromColor(0.5, 0.4, 0.3);

        lightMesh = Mesh3D.Box(0.3, 0.06, 0.16);
        lightMat = Material3D.FromColor(config.LIGHT_FIXTURE_R, config.LIGHT_FIXTURE_G, config.LIGHT_FIXTURE_B);
        Material3D.SetEmissiveColor(lightMat, 0.25, 0.23, 0.18);

        monitorMesh = Mesh3D.Box(1.15, 0.58, 0.10);
        monitorMat = Material3D.PBR(0.035, 0.085, 0.12);
        monitorMat.Roughness = 0.28;
        Material3D.SetEmissiveColor(monitorMat, 0.05, 0.34, 0.42);

        ballReturnMesh = Mesh3D.Box(0.46, 0.42, 1.55);
        ballReturnMat = Material3D.PBR(0.09, 0.12, 0.15);
        ballReturnMat.Metallic = 0.62;
        ballReturnMat.Roughness = 0.32;
        ballReturnHoodMesh = Mesh3D.Sphere(0.34, 14);
        ballReturnHoodMat = Material3D.PBR(0.06, 0.09, 0.12);
        ballReturnHoodMat.Metallic = 0.44;
        ballReturnHoodMat.Roughness = 0.26;

        seatMesh = Mesh3D.Box(0.54, 0.48, 0.58);
        seatMat = Material3D.PBR(0.10, 0.24, 0.29);
        seatMat.Roughness = 0.78;
        tableMesh = Mesh3D.Cylinder(0.40, 0.52, 16);
        tableMat = Material3D.PBR(0.16, 0.13, 0.11);
        tableMat.Metallic = 0.18;
        tableMat.Roughness = 0.50;

        neonStripMesh = Mesh3D.Box(0.055, 0.055, 3.2);
        neonCyanMat = Material3D.FromColor(0.12, 0.82, 0.92);
        Material3D.SetEmissiveColor(neonCyanMat, 0.04, 0.38, 0.48);
        neonCoralMat = Material3D.FromColor(1.0, 0.23, 0.18);
        Material3D.SetEmissiveColor(neonCoralMat, 0.46, 0.035, 0.020);

        spectatorBodyMesh = Mesh3D.Cylinder(0.12, 0.52, 10);
        spectatorHeadMesh = Mesh3D.Sphere(0.12, 10);
        spectatorMat = Material3D.FromColor(0.004, 0.010, 0.024);

        venueSignMesh = Mesh3D.Box(4.40, 0.86, 0.08);
        venueSignMat = Material3D.PBR(0.012, 0.030, 0.050);
        venueSignMat.Metallic = 0.18;
        venueSignMat.Roughness = 0.28;
        Material3D.SetEmissiveColor(venueSignMat, 0.015, 0.055, 0.080);
        venueSignBarMesh = Mesh3D.Box(0.72, 0.065, 0.035);

        decorPinBodyMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 0.72,
            config.PIN_HEIGHT * 0.72, 14);
        decorPinHeadMesh = Mesh3D.Sphere(config.PIN_RADIUS * 0.78, 12);
        decorPinBandMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 0.78, 0.018, 12);
        decorPinMat = Material3D.PBR(0.92, 0.94, 0.95);
        decorPinMat.Roughness = 0.32;
        decorPinBandMat = Material3D.FromColor(0.92, 0.025, 0.045);
        Material3D.SetEmissiveColor(decorPinBandMat, 0.16, 0.002, 0.004);

        rackBallMesh = Mesh3D.Sphere(0.13, 12);
        rackBallCyanMat = Material3D.PBR(0.025, 0.58, 0.68);
        rackBallCyanMat.Metallic = 0.12;
        rackBallCyanMat.Roughness = 0.20;
        rackBallCoralMat = Material3D.PBR(0.72, 0.045, 0.11);
        rackBallCoralMat.Metallic = 0.10;
        rackBallCoralMat.Roughness = 0.22;
    }

    hide func loadLaneTexture() {
        if (sharedLaneTexture != null) {
            laneTexture = sharedLaneTexture;
            var sharedLight = laneTexture.Get(laneTexture.Width / 4, laneTexture.Height / 2);
            var sharedDark = laneTexture.Get(laneTexture.Width / 8, laneTexture.Height / 2);
            lanePreviewLight = (sharedLight >> 8) & 0xFFFFFF;
            lanePreviewDark = (sharedDark >> 8) & 0xFFFFFF;
            return;
        }
        var path = "assets/textures/lane-maple.png";
        if (File.Exists(path) == false) {
            path = "examples/games/3dbowling/assets/textures/lane-maple.png";
        }
        if (File.Exists(path) == false) {
            path = "../games/3dbowling/assets/textures/lane-maple.png";
        }
        if (File.Exists(path)) {
            laneTexture = Pixels.Load(path);
            sharedLaneTexture = laneTexture;
            var lightSample = laneTexture.Get(laneTexture.Width / 4, laneTexture.Height / 2);
            var darkSample = laneTexture.Get(laneTexture.Width / 8, laneTexture.Height / 2);
            lanePreviewLight = (lightSample >> 8) & 0xFFFFFF;
            lanePreviewDark = (darkSample >> 8) & 0xFFFFFF;
        }
    }

    /// @brief Enable the authored maple surface once gameplay leaves the title.
    expose func enableAuthoredSurface() { loadLaneTexture(); }

    /// @brief Pre-compute Mat4 transforms for every static mesh.
    hide func buildTransforms() {
        laneXform = Mat4.Translate(0.0, -0.025, laneCenterZ);

        var oilLen = oilEndZ - config.OIL_START_Z;
        if (oilLen < 0.5) { oilLen = 0.5; }
        oilXform = Mat4.Translate(0.0, 0.012, config.OIL_START_Z + oilLen / 2.0);
        pinDeckXform = Mat4.Translate(0.0, 0.004, config.PIN_Z_OFFSET + 0.12);
        roomFloorXform = Mat4.Translate(0.0, -0.045, laneCenterZ + 0.3);

        var sideLaneCenter = config.LANE_WIDTH + config.LANE_GUTTER_W * 2.0 + 0.92;
        sideLaneLeftXform = Mat4.Translate(-sideLaneCenter, -0.01, laneCenterZ + 0.1);
        sideLaneRightXform = Mat4.Translate(sideLaneCenter, -0.01, laneCenterZ + 0.1);
        sideGutterLeftXform = Mat4.Translate(-sideLaneCenter, config.GUTTER_Y * 0.4, laneCenterZ + 0.1);
        sideGutterRightXform = Mat4.Translate(sideLaneCenter, config.GUTTER_Y * 0.4, laneCenterZ + 0.1);

        var gLeft = -(config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W / 2.0);
        var gRight = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W / 2.0;
        gutterLeftXform = Mat4.Translate(gLeft, config.GUTTER_Y, laneCenterZ);
        gutterRightXform = Mat4.Translate(gRight, config.GUTTER_Y, laneCenterZ);

        var wLeft = -(config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W + 0.025);
        var wRight = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W + 0.025;
        wallLeftXform = Mat4.Translate(wLeft, config.LANE_WALL_H / 2.0, laneCenterZ);
        wallRightXform = Mat4.Translate(wRight, config.LANE_WALL_H / 2.0, laneCenterZ);

        backWallXform = Mat4.Translate(0.0, 1.6, config.PIN_Z_OFFSET + 2.55);
        ceilingXform = Mat4.Translate(0.0, 4.9, laneCenterZ);
        sidePanelLeftXform = Mat4.Translate(-4.48, 1.9, laneCenterZ);
        sidePanelRightXform = Mat4.Translate(4.48, 1.9, laneCenterZ);
        pinsetterXform = Mat4.Translate(0.0, 2.34, config.PIN_Z_OFFSET + 1.85);
        approachXform = Mat4.Translate(0.0, -0.02, -config.LANE_APPROACH / 2.0);
        foulLineXform = Mat4.Translate(0.0, 0.0, 0.0);
        venueSignXform = Mat4.Translate(0.0, 2.92, config.PIN_Z_OFFSET + 2.25);
    }

    /// @brief Build instance batches for the repeating arrows / dots / lights.
    hide func buildBatches() {
        arrowBatch = InstanceBatch3D.New(arrowMesh, arrowMat);
        dotBatch = InstanceBatch3D.New(dotMesh, dotMat);
        lightBatch = InstanceBatch3D.New(lightMesh, lightMat);
        monitorBatch = InstanceBatch3D.New(monitorMesh, monitorMat);
        ballReturnBatch = InstanceBatch3D.New(ballReturnMesh, ballReturnMat);
        ballReturnHoodBatch = InstanceBatch3D.New(ballReturnHoodMesh, ballReturnHoodMat);
        seatBatch = InstanceBatch3D.New(seatMesh, seatMat);
        tableBatch = InstanceBatch3D.New(tableMesh, tableMat);
        neonCyanBatch = InstanceBatch3D.New(neonStripMesh, neonCyanMat);
        neonCoralBatch = InstanceBatch3D.New(neonStripMesh, neonCoralMat);
        spectatorBodyBatch = InstanceBatch3D.New(spectatorBodyMesh, spectatorMat);
        spectatorHeadBatch = InstanceBatch3D.New(spectatorHeadMesh, spectatorMat);
        boardLightBatch = InstanceBatch3D.New(boardMesh, boardLightMat);
        boardDarkBatch = InstanceBatch3D.New(boardMesh, boardDarkMat);
        signCyanBatch = InstanceBatch3D.New(venueSignBarMesh, neonCyanMat);
        signAmberBatch = InstanceBatch3D.New(venueSignBarMesh, neonCoralMat);
        decorPinBodyBatch = InstanceBatch3D.New(decorPinBodyMesh, decorPinMat);
        decorPinHeadBatch = InstanceBatch3D.New(decorPinHeadMesh, decorPinMat);
        decorPinBandBatch = InstanceBatch3D.New(decorPinBandMesh, decorPinBandMat);
        rackBallCyanBatch = InstanceBatch3D.New(rackBallMesh, rackBallCyanMat);
        rackBallCoralBatch = InstanceBatch3D.New(rackBallMesh, rackBallCoralMat);

        var sideLaneCenter = config.LANE_WIDTH + config.LANE_GUTTER_W * 2.0 + 0.92;
        var boardW = config.LANE_WIDTH / (config.LANE_BOARD_COUNT + 0.0);
        for (var laneIndex: Integer = -1; laneIndex <= 1; laneIndex = laneIndex + 1) {
            var laneOffset = (laneIndex + 0.0) * sideLaneCenter;
            for (var bi: Integer = 0; bi < config.LANE_BOARD_COUNT; bi = bi + 1) {
                var bx = laneOffset - config.LANE_WIDTH / 2.0 + boardW / 2.0 +
                    (bi + 0.0) * boardW;
                var boardXform = Mat4.Translate(bx, 0.006, laneCenterZ);
                if (bi % 2 == 0) { boardLightBatch.Add(boardXform); }
                else { boardDarkBatch.Add(boardXform); }
            }
        }

        // A compact geometric NL monogram keeps the pin-deck facade branded
        // without relying on another texture or font upload.
        var signZ = config.PIN_Z_OFFSET + 2.20;
        signCyanBatch.Add(Mat4.Mul(Mat4.Translate(-0.96, 2.94, signZ), Mat4.RotateZ(1.5707963)));
        signCyanBatch.Add(Mat4.Mul(Mat4.Translate(-0.26, 2.94, signZ), Mat4.RotateZ(1.5707963)));
        signCyanBatch.Add(Mat4.Mul(Mat4.Translate(-0.61, 2.94, signZ), Mat4.RotateZ(-0.78)));
        signAmberBatch.Add(Mat4.Mul(Mat4.Translate(0.42, 2.94, signZ), Mat4.RotateZ(1.5707963)));
        signAmberBatch.Add(Mat4.Translate(0.76, 2.62, signZ));
        signAmberBatch.Add(Mat4.Translate(1.34, 2.62, signZ));

        for (var decorSide: Integer = -1; decorSide <= 1; decorSide = decorSide + 2) {
            var rackCenter = (decorSide + 0.0) * sideLaneCenter;
            for (var row: Integer = 0; row < 4; row = row + 1) {
                for (var col: Integer = 0; col <= row; col = col + 1) {
                    var pinX = rackCenter + ((col + 0.0) - (row + 0.0) * 0.5) * config.PIN_SPACING;
                    var pinZ = config.PIN_Z_OFFSET + (row + 0.0) * config.PIN_SPACING * 0.866;
                    decorPinBodyBatch.Add(Mat4.Translate(pinX, 0.15, pinZ));
                    decorPinHeadBatch.Add(Mat4.Translate(pinX, 0.34, pinZ));
                    decorPinBandBatch.Add(Mat4.Translate(pinX, 0.28, pinZ));
                }
            }
            rackBallCyanBatch.Add(Mat4.Translate((decorSide + 0.0) * 1.18, 0.72, -1.46));
            rackBallCoralBatch.Add(Mat4.Translate((decorSide + 0.0) * 1.18, 0.72, -1.15));
        }
        var halfArrows = config.LANE_ARROW_COUNT / 2;
        for (var ai: Integer = -halfArrows; ai <= halfArrows; ai = ai + 1) {
            var ax = (ai + 0.0) * config.LANE_ARROW_SPACING;
            arrowBatch.Add(Mat4.Translate(ax, 0.0, config.LANE_ARROW_Z));
        }

        var halfDots = config.LANE_DOT_COUNT / 2;
        for (var di: Integer = -halfDots; di <= halfDots; di = di + 1) {
            var dx = (di + 0.0) * config.LANE_DOT_SPACING;
            dotBatch.Add(Mat4.Translate(dx, 0.01, config.LANE_DOT_Z1));
            dotBatch.Add(Mat4.Translate(dx, 0.01, config.LANE_DOT_Z2));
        }

        for (var li: Integer = 0; li < 7; li = li + 1) {
            var lz = -1.0 + (li + 0.0) * 2.8;
            lightBatch.Add(Mat4.Translate(0.0, 4.8, lz));
        }

        monitorBatch.Add(Mat4.Translate(-1.60, 3.25, 1.7));
        monitorBatch.Add(Mat4.Translate(0.0, 3.25, 1.7));
        monitorBatch.Add(Mat4.Translate(1.60, 3.25, 1.7));

        ballReturnBatch.Add(Mat4.Translate(-1.18, 0.20, -1.55));
        ballReturnBatch.Add(Mat4.Translate(1.18, 0.20, -1.55));
        ballReturnHoodBatch.Add(Mat4.Translate(-1.18, 0.55, -1.02));
        ballReturnHoodBatch.Add(Mat4.Translate(1.18, 0.55, -1.02));
        for (var sideIndex: Integer = -1; sideIndex <= 1; sideIndex = sideIndex + 2) {
            for (var si: Integer = 0; si < 3; si = si + 1) {
                var sx = (sideIndex + 0.0) * (2.25 + (si + 0.0) * 0.62);
                seatBatch.Add(Mat4.Translate(sx, 0.22, -2.20 + (si % 2) * 0.64));
            }
            tableBatch.Add(Mat4.Translate((sideIndex + 0.0) * 2.72, 0.22, -1.20));
        }

        neonCyanBatch.Add(Mat4.Translate(-4.28, 2.25, 2.6));
        neonCyanBatch.Add(Mat4.Translate(4.28, 2.25, 9.0));
        neonCoralBatch.Add(Mat4.Translate(-4.28, 2.25, 10.6));
        neonCoralBatch.Add(Mat4.Translate(4.28, 2.25, 3.8));
        for (var ci: Integer = 0; ci < 8; ci = ci + 1) {
            var crowdSide = -1.0;
            if (ci % 2 == 1) { crowdSide = 1.0; }
            var cx = crowdSide * (2.65 + ((ci / 2) % 2) * 0.46);
            var cz = 11.4 + (ci / 4) * 0.72;
            spectatorBodyBatch.Add(Mat4.Translate(cx, 0.32, cz));
            spectatorHeadBatch.Add(Mat4.Translate(cx, 0.72, cz));
        }
    }

    /// @brief Spawn static physics bodies for floor / gutters / walls / back.
    hide func buildPhysics(world: Physics3DWorld) {
        var totalLenHalf = (config.LANE_LENGTH + config.LANE_APPROACH) / 2.0;
        laneFloorBody = Physics3DBody.NewAABB(config.LANE_WIDTH / 2.0, 0.06, totalLenHalf, 0.0);
        Physics3DBody.set_Static(laneFloorBody, true);
        Physics3DBody.SetPosition(laneFloorBody, 0.0, -0.06, laneCenterZ);
        Physics3DBody.set_Friction(laneFloorBody, 0.35);
        Physics3DBody.set_Restitution(laneFloorBody, 0.08);
        Physics3DBody.set_CollisionLayer(laneFloorBody, config.LAYER_STATIC);
        Physics3DWorld.Add(world, laneFloorBody);

        var gutterX = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W / 2.0;
        gutterFloorL = Physics3DBody.NewAABB(config.LANE_GUTTER_W / 2.0, 0.05, totalLenHalf, 0.0);
        Physics3DBody.set_Static(gutterFloorL, true);
        Physics3DBody.SetPosition(gutterFloorL, -gutterX, config.GUTTER_Y - 0.02, laneCenterZ);
        Physics3DBody.set_Friction(gutterFloorL, 0.22);
        Physics3DBody.set_CollisionLayer(gutterFloorL, config.LAYER_STATIC);
        Physics3DWorld.Add(world, gutterFloorL);

        gutterFloorR = Physics3DBody.NewAABB(config.LANE_GUTTER_W / 2.0, 0.05, totalLenHalf, 0.0);
        Physics3DBody.set_Static(gutterFloorR, true);
        Physics3DBody.SetPosition(gutterFloorR, gutterX, config.GUTTER_Y - 0.02, laneCenterZ);
        Physics3DBody.set_Friction(gutterFloorR, 0.22);
        Physics3DBody.set_CollisionLayer(gutterFloorR, config.LAYER_STATIC);
        Physics3DWorld.Add(world, gutterFloorR);

        var wallX = config.LANE_WIDTH / 2.0 + config.LANE_GUTTER_W + 0.025;
        wallBodyL = Physics3DBody.NewAABB(0.05, 0.5, totalLenHalf, 0.0);
        Physics3DBody.set_Static(wallBodyL, true);
        Physics3DBody.SetPosition(wallBodyL, -wallX, 0.25, laneCenterZ);
        Physics3DBody.set_Restitution(wallBodyL, 0.28);
        Physics3DBody.set_CollisionLayer(wallBodyL, config.LAYER_STATIC);
        Physics3DWorld.Add(world, wallBodyL);

        wallBodyR = Physics3DBody.NewAABB(0.05, 0.5, totalLenHalf, 0.0);
        Physics3DBody.set_Static(wallBodyR, true);
        Physics3DBody.SetPosition(wallBodyR, wallX, 0.25, laneCenterZ);
        Physics3DBody.set_Restitution(wallBodyR, 0.28);
        Physics3DBody.set_CollisionLayer(wallBodyR, config.LAYER_STATIC);
        Physics3DWorld.Add(world, wallBodyR);

        backWallBody = Physics3DBody.NewAABB(3.0, 1.5, 0.1, 0.0);
        Physics3DBody.set_Static(backWallBody, true);
        Physics3DBody.SetPosition(backWallBody, 0.0, 0.75, config.PIN_Z_OFFSET + 2.1);
        Physics3DBody.set_Restitution(backWallBody, 0.2);
        Physics3DBody.set_CollisionLayer(backWallBody, config.LAYER_STATIC);
        Physics3DWorld.Add(world, backWallBody);
    }

    /// @brief Spawn the three Trigger3D volumes (left/right gutter + pin deck).
    hide func buildTriggers() {
        var laneHalf = config.LANE_WIDTH / 2.0;
        var gutterInner = laneHalf - config.BALL_RADIUS * 0.55;
        if (gutterInner < laneHalf - config.GUTTER_TRIGGER_WIDTH) {
            gutterInner = laneHalf - config.GUTTER_TRIGGER_WIDTH;
        }
        leftGutterTrigger = Trigger3D.New(
            -(laneHalf + config.LANE_GUTTER_W), -1.0, -0.2,
            -gutterInner, 1.5, config.GUTTER_EXIT_Z);
        rightGutterTrigger = Trigger3D.New(
            gutterInner, -1.0, -0.2,
            laneHalf + config.LANE_GUTTER_W, 1.5, config.GUTTER_EXIT_Z);
        pinDeckTrigger = Trigger3D.New(-1.2, -0.2, config.PIN_Z_OFFSET - 0.8,
            1.2, 1.2, config.PIN_Z_OFFSET + 1.8);
    }

    /// @brief Draw every static lane element in z-order (room → lane →
    ///        oil → deck → gutters → walls → ceiling → panels →
    ///        back wall → pinsetter → approach → foul line → batches).
    expose func draw(canvas: Canvas3D) {
        Canvas3D.DrawMesh(canvas, roomFloorMesh, roomFloorXform, roomFloorMat);
        Canvas3D.DrawMesh(canvas, sideLaneMesh, sideLaneLeftXform, sideLaneMat);
        Canvas3D.DrawMesh(canvas, sideLaneMesh, sideLaneRightXform, sideLaneMat);
        Canvas3D.DrawMesh(canvas, sideGutterMesh, sideGutterLeftXform, sideGutterMat);
        Canvas3D.DrawMesh(canvas, sideGutterMesh, sideGutterRightXform, sideGutterMat);
        Canvas3D.DrawMesh(canvas, laneMesh, laneXform, laneMat);
        // Procedural boards remain a first-frame and missing-asset fallback;
        // narrow gaps let the authored grain read once its texture is resident.
        drawLaneBoards(canvas);
        // NL-VIPER-003: submitting this correctly configured AlphaMode=2
        // surface intermittently corrupts Metal final-overlay composition.
        // Keep oil gameplay/SSR on the glossy boards and the live HUD map
        // until the documented runtime issue can be fixed and verified.
        drawLaneBoardSeams(canvas);
        Canvas3D.DrawMesh(canvas, pinDeckMesh, pinDeckXform, pinDeckMat);
        Canvas3D.DrawMesh(canvas, gutterMesh, gutterLeftXform, gutterMat);
        Canvas3D.DrawMesh(canvas, gutterMesh, gutterRightXform, gutterMat);
        Canvas3D.DrawMesh(canvas, wallMesh, wallLeftXform, wallMat);
        Canvas3D.DrawMesh(canvas, wallMesh, wallRightXform, wallMat);
        Canvas3D.DrawMesh(canvas, ceilingMesh, ceilingXform, ceilingMat);
        Canvas3D.DrawMesh(canvas, sidePanelMesh, sidePanelLeftXform, sidePanelMat);
        Canvas3D.DrawMesh(canvas, sidePanelMesh, sidePanelRightXform, sidePanelMat);
        Canvas3D.DrawMesh(canvas, backWallMesh, backWallXform, backWallMat);
        Canvas3D.DrawMesh(canvas, venueSignMesh, venueSignXform, venueSignMat);
        Canvas3D.DrawMesh(canvas, pinsetterMesh, pinsetterXform, pinsetterMat);
        Canvas3D.DrawMesh(canvas, approachMesh, approachXform, approachMat);
        Canvas3D.DrawMesh(canvas, foulLineMesh, foulLineXform, foulLineMat);
        Canvas3D.DrawInstanced(canvas, arrowBatch);
        Canvas3D.DrawInstanced(canvas, dotBatch);
        Canvas3D.DrawInstanced(canvas, lightBatch);
        Canvas3D.DrawInstanced(canvas, monitorBatch);
        Canvas3D.DrawInstanced(canvas, ballReturnBatch);
        Canvas3D.DrawInstanced(canvas, ballReturnHoodBatch);
        Canvas3D.DrawInstanced(canvas, seatBatch);
        Canvas3D.DrawInstanced(canvas, tableBatch);
        Canvas3D.DrawInstanced(canvas, neonCyanBatch);
        Canvas3D.DrawInstanced(canvas, neonCoralBatch);
        Canvas3D.DrawInstanced(canvas, spectatorBodyBatch);
        Canvas3D.DrawInstanced(canvas, spectatorHeadBatch);
        Canvas3D.DrawInstanced(canvas, signCyanBatch);
        Canvas3D.DrawInstanced(canvas, signAmberBatch);
        Canvas3D.DrawInstanced(canvas, decorPinBodyBatch);
        Canvas3D.DrawInstanced(canvas, decorPinHeadBatch);
        Canvas3D.DrawInstanced(canvas, decorPinBandBatch);
        Canvas3D.DrawInstanced(canvas, rackBallCyanBatch);
        Canvas3D.DrawInstanced(canvas, rackBallCoralBatch);
    }

    hide func drawLaneBoards(canvas: Canvas3D) {
        Canvas3D.DrawInstanced(canvas, boardLightBatch);
        Canvas3D.DrawInstanced(canvas, boardDarkBatch);
    }

    hide func drawLaneBoardSeams(canvas: Canvas3D) {
        var boardW = config.LANE_WIDTH / (config.LANE_BOARD_COUNT + 0.0);
        for (var bi: Integer = 1; bi < config.LANE_BOARD_COUNT; bi = bi + 1) {
            var bx = -config.LANE_WIDTH / 2.0 + (bi + 0.0) * boardW;
            Canvas3D.DrawLine3D(canvas,
                new Vec3(bx, 0.026, -config.LANE_APPROACH),
                new Vec3(bx, 0.026, config.LANE_LENGTH),
                0x6E4A2B);
        }
    }

    /// @brief Draw the moving sweep bar at the given Y position.
    expose func drawSweepBar(canvas: Canvas3D, sweepY: Float) {
        Canvas3D.DrawMesh(canvas, sweepBarMesh,
            Mat4.Translate(0.0, sweepY, config.PIN_Z_OFFSET + 0.25), sweepBarMat);
    }

    /// @brief Wire up cube-map reflections on every shiny surface.
    expose func applyEnvironment(env: CubeMap3D) {
        Material3D.SetEnvMap(laneMat, env);
        laneMat.Reflectivity = config.LANE_REFLECTIVITY;
        Material3D.SetEnvMap(boardLightMat, env);
        boardLightMat.Reflectivity = config.LANE_REFLECTIVITY;
        Material3D.SetEnvMap(boardDarkMat, env);
        boardDarkMat.Reflectivity = config.LANE_REFLECTIVITY * 0.72;

        Material3D.SetEnvMap(oilMat, env);
        oilMat.Reflectivity = config.LANE_OIL_REFLECTIVITY;

        Material3D.SetEnvMap(pinDeckMat, env);
        pinDeckMat.Reflectivity = config.PIN_DECK_REFLECTIVITY;

        Material3D.SetEnvMap(roomFloorMat, env);
        roomFloorMat.Reflectivity = 0.03;

        Material3D.SetEnvMap(sideLaneMat, env);
        sideLaneMat.Reflectivity = 0.05;

        Material3D.SetEnvMap(sideGutterMat, env);
        sideGutterMat.Reflectivity = 0.02;

        Material3D.SetEnvMap(approachMat, env);
        approachMat.Reflectivity = config.LANE_REFLECTIVITY * 0.75;

        Material3D.SetEnvMap(ceilingMat, env);
        ceilingMat.Reflectivity = 0.02;

        Material3D.SetEnvMap(sidePanelMat, env);
        sidePanelMat.Reflectivity = 0.03;

        Material3D.SetEnvMap(pinsetterMat, env);
        pinsetterMat.Reflectivity = 0.05;

        Material3D.SetEnvMap(foulLineMat, env);
        foulLineMat.Reflectivity = 0.18;
        Material3D.SetEnvMap(monitorMat, env);
        monitorMat.Reflectivity = 0.16;
        Material3D.SetEnvMap(ballReturnMat, env);
        ballReturnMat.Reflectivity = 0.28;
        Material3D.SetEnvMap(ballReturnHoodMat, env);
        ballReturnHoodMat.Reflectivity = 0.34;
        Material3D.SetEnvMap(tableMat, env);
        tableMat.Reflectivity = 0.08;
        Material3D.SetEnvMap(venueSignMat, env);
        venueSignMat.Reflectivity = 0.16;
        Material3D.SetEnvMap(decorPinMat, env);
        decorPinMat.Reflectivity = 0.10;
        Material3D.SetEnvMap(rackBallCyanMat, env);
        rackBallCyanMat.Reflectivity = 0.30;
        Material3D.SetEnvMap(rackBallCoralMat, env);
        rackBallCoralMat.Reflectivity = 0.30;
    }

    /// @brief Sample friction at a 2D lane position.
    /// @details Combines z-axis blend (oiled vs blend vs dry depending
    ///          on whether we're in the oil corridor / past oilEndZ)
    ///          with x-axis edge weighting (boards near the gutter
    ///          are dry). The exact curve depends on oilPattern.
    expose func getFrictionAt(x: Float, z: Float) -> Float {
        if (z < config.OIL_START_Z) { return config.OIL_FRICTION_DRY; }
        if (z > config.LANE_LENGTH) { return config.OIL_FRICTION_DRY; }

        var laneHalf = config.LANE_WIDTH / 2.0;
        var boardPct = Abs(x) / laneHalf;
        if (boardPct > 1.0) { boardPct = 1.0; }

        var zBlend = 1.0;
        if (z <= oilEndZ) {
            zBlend = (z - config.OIL_START_Z) / (oilEndZ - config.OIL_START_Z + 0.0001);
            if (zBlend < 0.0) { zBlend = 0.0; }
            if (zBlend > 1.0) { zBlend = 1.0; }
        }

        var edgeDry = boardPct * boardPct;
        if (oilPattern == config.OIL_HOUSE) {
            edgeDry = edgeDry * 1.35;
        } else if (oilPattern == config.OIL_SPORT) {
            edgeDry = boardPct * 0.65;
        } else {
            edgeDry = 0.55 + boardPct * 0.75;
        }

        var friction = config.OIL_FRICTION_OILED +
            (config.OIL_FRICTION_BLEND - config.OIL_FRICTION_OILED) * zBlend +
            (config.OIL_FRICTION_DRY - config.OIL_FRICTION_BLEND) * edgeDry;

        if (z > oilEndZ) {
            var backend = (z - oilEndZ) / 3.0;
            if (backend > 1.0) { backend = 1.0; }
            friction = friction + (config.OIL_FRICTION_DRY - friction) * backend;
        }

        // Repeated shots open a slightly earlier friction window on their line;
        // carried oil just behind the pattern delays hook by the inverse amount.
        var wear = wearAtX(x);
        if (z <= oilEndZ) {
            friction = friction + wear * 0.10;
        } else if (z < oilEndZ + 2.0) {
            friction = friction - wear * 0.055 * (1.0 - (z - oilEndZ) / 2.0);
        }

        return mathutil.clampf(friction, config.OIL_FRICTION_OILED, config.OIL_FRICTION_DRY);
    }

    /// @brief Active oil pattern code.
    expose func getOilPattern() -> Integer {
        return oilPattern;
    }

    /// @brief Z coordinate where the oil ends (start of dry backend).
    expose func getOilEndZ() -> Float {
        return oilEndZ;
    }

    /// @brief Visual oil density 0..1 at (x, z), for HUD/preview rendering only.
    /// @details Deliberately DECOUPLED from getFrictionAt (which must stay
    ///          byte-identical for the deterministic trajectory). This is an
    ///          approximation of the oil footprint: full through the oiled
    ///          corridor, tapering past oilEndZ, with a per-pattern lateral
    ///          falloff so the three patterns read differently in the preview.
    expose func getOilConcentration(x: Float, z: Float) -> Float {
        if (z < config.OIL_START_Z) { return 0.0; }
        if (z > oilEndZ + 2.0) { return 0.0; }

        var laneHalf = config.LANE_WIDTH / 2.0;
        var boardPct = Abs(x) / laneHalf;
        if (boardPct > 1.0) { boardPct = 1.0; }

        var lengthwise = 1.0;
        if (z > oilEndZ) {
            lengthwise = 1.0 - (z - oilEndZ) / 2.0;
            if (lengthwise < 0.0) { lengthwise = 0.0; }
        }

        var center = 1.0 - boardPct * boardPct;
        if (oilPattern == config.OIL_SPORT) {
            center = 1.0 - boardPct;
        } else if (oilPattern == config.OIL_DRY) {
            center = (1.0 - boardPct) * 0.6;
        }
        if (center < 0.0) { center = 0.0; }
        var visibleWear = wearAtX(x);
        return center * lengthwise * (1.0 - visibleWear * 0.62);
    }

    /// @brief Accumulate gradual breakdown along the live ball track.
    expose func recordBallTrack(x: Float, z: Float, spinMagnitude: Float, dt: Float) {
        if (z < config.OIL_START_Z || z > oilEndZ + 1.2 || dt <= 0.0) { return; }
        var index = wearIndex(x);
        var value = oilWear.get(index) + dt * (0.012 + spinMagnitude * 0.020);
        if (value > 0.55) { value = 0.55; }
        oilWear.set(index, value);
    }

    expose func getOilWearPercent() -> Integer {
        var total = 0.0;
        for (var i: Integer = 0; i < oilWear.count(); i = i + 1) { total = total + oilWear.get(i); }
        return Convert.NumToInt(total / (oilWear.count() + 0.0) * 100.0);
    }

    hide func wearAtX(x: Float) -> Float { return oilWear.get(wearIndex(x)); }

    hide func wearIndex(x: Float) -> Integer {
        var pct = (x + config.LANE_WIDTH / 2.0) / config.LANE_WIDTH;
        if (pct < 0.0) { pct = 0.0; }
        if (pct > 0.999) { pct = 0.999; }
        var index = Convert.NumToInt(pct * 9.0);
        if (index < 0) { index = 0; }
        if (index > 8) { index = 8; }
        return index;
    }

    /// @brief Draw a top-down oil map in a HUD rect (px,py,w,h). Rows run down
    ///        the lane (foul line at top), columns span its width; cell tint
    ///        tracks getOilConcentration so the active pattern is legible.
    expose func drawOilPreview(canvas: Canvas3D, px: Integer, py: Integer, w: Integer, h: Integer) {
        Canvas3D.DrawRect2D(canvas, px - 2, py - 2, w + 4, h + 4, config.HUD_COLOR_FRAME_BG);
        Canvas3D.DrawRect2D(canvas, px, py, w, h, lanePreviewLight);
        var previewBoards = 13;
        var previewBoardW = w / previewBoards;
        for (var board: Integer = 0; board < previewBoards; board = board + 1) {
            if (board % 2 == 1) {
                Canvas3D.DrawRect2D(canvas, px + board * previewBoardW, py,
                    previewBoardW, h, lanePreviewDark);
            }
        }
        var cols = 9;
        var rows = 6;
        var laneHalf = config.LANE_WIDTH / 2.0;
        var cellW = w / cols;
        var cellH = h / rows;
        for (var r: Integer = 0; r < rows; r = r + 1) {
            var z = config.OIL_START_Z + (oilEndZ + 1.6 - config.OIL_START_Z) * ((r + 0.5) / (rows + 0.0));
            for (var c: Integer = 0; c < cols; c = c + 1) {
                var x = -laneHalf + config.LANE_WIDTH * ((c + 0.5) / (cols + 0.0));
                var dens = getOilConcentration(x, z);
                var blue = 64 + Convert.NumToInt(dens * 180.0);
                var green = 42 + Convert.NumToInt(dens * 138.0);
                var cell = (18 << 16) + (green << 8) + blue;
                if (dens > 0.025) {
                    var barW = 2 + Convert.NumToInt(dens * ((cellW - 4) + 0.0));
                    Canvas3D.DrawRect2D(canvas,
                        px + c * cellW + (cellW - barW) / 2,
                        py + r * cellH + cellH / 2 - 2, barW, 4, cell);
                }
            }
        }
        Canvas3D.DrawText2D(canvas, px, py + h + 3, getOilPatternName() + " oil", config.HUD_COLOR_CYAN);
    }

    /// @brief Display name for the oil pattern.
    expose func getOilPatternName() -> String {
        if (oilPattern == config.OIL_SPORT) { return "Sport"; }
        if (oilPattern == config.OIL_DRY) { return "Dry"; }
        return "House";
    }

    /// @brief Left-gutter trigger volume (for ball entry detection).
    expose func getLeftGutterTrigger() -> Trigger3D {
        return leftGutterTrigger;
    }

    /// @brief Right-gutter trigger volume.
    expose func getRightGutterTrigger() -> Trigger3D {
        return rightGutterTrigger;
    }

    /// @brief Pin-deck trigger (used to apply the deck-impact damping).
    expose func getPinDeckTrigger() -> Trigger3D {
        return pinDeckTrigger;
    }
}
