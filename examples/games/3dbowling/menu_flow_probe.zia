// ============================================================================
// MODULE: menu_flow_probe
// PURPOSE: Synthetic-input regression for release front-end commands and the
//          explicit separation between game mode and player count.
// ============================================================================

module menu_flow_probe;

bind Viper.Graphics3D;
bind Viper.Input;
bind Viper.Input.Key as Key;
bind Viper.Terminal;
bind "./config";
bind "./menu";

func bindMenuActions() {
    Action.Clear();
    Action.Define(config.ACT_MENU_UP);
    Action.Define(config.ACT_MENU_DOWN);
    Action.Define(config.ACT_CONFIRM);
    Action.Define(config.ACT_BACK);
    Action.BindKey(config.ACT_MENU_UP, Key.Up);
    Action.BindKey(config.ACT_MENU_DOWN, Key.Down);
    Action.BindKey(config.ACT_CONFIRM, Key.Enter);
    Action.BindKey(config.ACT_BACK, Key.Escape);
}

func tap(canvas: Canvas3D, key: Integer, menuObj: BowlingMenu) -> Integer {
    Canvas3D.PushSyntheticKey(canvas, key, true);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    var command = menuObj.updateTitle();
    Canvas3D.PushSyntheticKey(canvas, key, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    return command;
}

func tapOption(canvas: Canvas3D, key: Integer, menuObj: BowlingMenu) -> Integer {
    Canvas3D.PushSyntheticKey(canvas, key, true);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    var command = menuObj.updateOptions();
    Canvas3D.PushSyntheticKey(canvas, key, false);
    Canvas3D.AdvanceSyntheticFrame(canvas);
    return command;
}

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var canvas = Canvas3D.New("Bowling menu flow", 96, 64);
    Canvas3D.SetInputSource(canvas, 1);
    Canvas3D.SetClockSource(canvas, 1);
    Canvas3D.SetSyntheticDeltaTimeSec(canvas, 0.016);
    bindMenuActions();

    var quick = new BowlingMenu();
    var command = tap(canvas, Key.Enter, quick);
    if (command != menu.CMD_START_MATCH || quick.getStartPlayerCount() != 1 ||
        quick.getStartMode() != config.MODE_SINGLE) {
        Say("RESULT: fail quick game command"); return;
    }

    var championship = new BowlingMenu();
    tap(canvas, Key.Down, championship);
    tap(canvas, Key.Down, championship);
    command = tap(canvas, Key.Enter, championship);
    if (command != menu.CMD_NONE) {
        Say("RESULT: fail championship preview page"); return;
    }
    command = tap(canvas, Key.Enter, championship);
    if (command != menu.CMD_START_MATCH || championship.getStartPlayerCount() != 2 ||
        championship.getStartMode() != config.MODE_CHAMPIONSHIP) {
        Say("RESULT: fail championship command"); return;
    }

    var local = new BowlingMenu();
    tap(canvas, Key.Down, local);
    tap(canvas, Key.Enter, local);
    tap(canvas, Key.Down, local);
    command = tap(canvas, Key.Enter, local);
    if (command != menu.CMD_START_MATCH || local.getStartPlayerCount() != 3 ||
        local.getStartMode() != config.MODE_VERSUS) {
        Say("RESULT: fail local player count"); return;
    }

    var challenge = new BowlingMenu();
    tap(canvas, Key.Down, challenge); tap(canvas, Key.Down, challenge);
    tap(canvas, Key.Down, challenge); tap(canvas, Key.Enter, challenge);
    command = tap(canvas, Key.Enter, challenge);
    if (command != menu.CMD_START_MATCH || challenge.getStartMode() != config.MODE_CHALLENGE ||
        challenge.getChallengeId() != 0) {
        Say("RESULT: fail challenge command"); return;
    }

    var practice = new BowlingMenu();
    for (var practiceStep: Integer = 0; practiceStep < 4; practiceStep = practiceStep + 1) {
        tap(canvas, Key.Down, practice);
    }
    tap(canvas, Key.Enter, practice);
    command = tap(canvas, Key.Enter, practice);
    if (command != menu.CMD_START_MATCH || practice.getStartMode() != config.MODE_PRACTICE ||
        practice.getPracticeId() != 0) {
        Say("RESULT: fail practice command"); return;
    }

    var party = new BowlingMenu();
    for (var partyStep: Integer = 0; partyStep < 5; partyStep = partyStep + 1) {
        tap(canvas, Key.Down, party);
    }
    tap(canvas, Key.Enter, party);
    command = tap(canvas, Key.Enter, party);
    if (command != menu.CMD_START_MATCH || party.getStartMode() != config.MODE_PARTY ||
        party.getStartPlayerCount() < 2 || party.getPartyId() != 0) {
        Say("RESULT: fail party command"); return;
    }

    var settings = new BowlingMenu();
    settings.recordFinishedMatch(123, config.MODE_SINGLE);
    tapOption(canvas, Key.Up, settings);
    tapOption(canvas, Key.Up, settings);
    command = tapOption(canvas, Key.Enter, settings);
    if (command != menu.CMD_NONE || settings.getGamesPlayed() != 1) {
        Say("RESULT: fail reset confirmation arm"); return;
    }
    tapOption(canvas, Key.Enter, settings);
    if (settings.getGamesPlayed() != 0 || settings.getBestScore() != 0) {
        Say("RESULT: fail confirmed career reset"); return;
    }

    Say("RESULT: ok");
}
