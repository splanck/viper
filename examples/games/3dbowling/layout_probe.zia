//
// File: examples/games/3dbowling/layout_probe.zia
// Purpose: Verifies aspect-only camera rebinding and zero-height layout stability.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: layout_probe
// PURPOSE: Standalone viewport-aspect and compact-layout resize contract.
// ============================================================================

module layout_probe;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./engine/renderer";

func main() {
    var renderer = new Renderer();
    renderer.initRendererWithSize(config.QUALITY_PERFORMANCE, 800, 600);
    if (Abs(renderer.getLastValidAspect() - 4.0 / 3.0) > 0.0001 ||
        renderer.isCompactLayout()) {
        Terminal.Say("RESULT: fail initial viewport layout");
        return;
    }
    if (renderer.updateDimensions(1600, 900) == false ||
        Abs(renderer.getLastValidAspect() - 16.0 / 9.0) > 0.0001) {
        Terminal.Say("RESULT: fail wide resize did not rebuild camera aspect");
        return;
    }
    renderer.updateDimensions(620, 480);
    if (renderer.isCompactLayout() == false) {
        Terminal.Say("RESULT: fail compact resize was not detected");
        return;
    }
    var priorAspect = renderer.getLastValidAspect();
    if (renderer.updateDimensions(620, 0) ||
        Abs(renderer.getLastValidAspect() - priorAspect) > 0.000001) {
        Terminal.Say("RESULT: fail zero-height target discarded valid layout");
        return;
    }
    Terminal.Say("RESULT: ok");
}
