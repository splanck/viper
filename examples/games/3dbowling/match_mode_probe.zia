// ============================================================================
// MODULE: match_mode_probe
// PURPOSE: Controller-level regression for explicit mode/player-count state,
//          AI championship setup, short party scoring, and rematch fidelity.
// ============================================================================

module match_mode_probe;

bind Viper.Graphics3D;
bind Viper.Sound;
bind Viper.Terminal;
bind "./config";
bind "./game";

class BowlingMatchProbe extends BowlingGame {
    expose func verify() -> Boolean {
        initSubsystems();

        startNewMatchMode(2, config.MODE_CHAMPIONSHIP);
        if (playerCount != 2 || currentMode != config.MODE_CHAMPIONSHIP ||
            scoreKeepers.count() != 2 || playerNames.get(1) == "") {
            Say("FAIL: championship setup"); return false;
        }
        activePlayer = 1;
        aiThinkTimer = 0.01;
        updateAiAiming(0.02);
        if (gameState != config.STATE_ROLLING || ballObj.thrown() == false) {
            Say("FAIL: championship rival did not use the physics launch path"); return false;
        }
        restartCurrentMatch();
        if (playerCount != 2 || currentMode != config.MODE_CHAMPIONSHIP ||
            scoreKeepers.count() != 2) {
            Say("FAIL: championship rematch lost mode or players"); return false;
        }

        menuObj.recordFinishedMatch(600, config.MODE_CHAMPIONSHIP);
        startNewMatchMode(2, config.MODE_CHAMPIONSHIP);
        if (playerNames.get(1) != "Mateo Cruz") {
            Say("FAIL: second championship rival did not unlock"); return false;
        }
        menuObj.recordFinishedMatch(900, config.MODE_CHAMPIONSHIP);
        startNewMatchMode(2, config.MODE_CHAMPIONSHIP);
        if (playerNames.get(1) != "Nova King") {
            Say("FAIL: final championship rival did not unlock"); return false;
        }

        startNewMatchMode(3, config.MODE_PARTY);
        if (playerCount != 3 || currentMode != config.MODE_PARTY ||
            scoreKeepers.count() != 3 || scoreKeepers.get(0).getFrame() != 10) {
            Say("FAIL: party setup"); return false;
        }

        startNewMatchMode(1, config.MODE_PRACTICE);
        practiceId = 1;
        applyPracticeLeave();
        if (pinMgr.getStandingMask() != ((1 << 6) + (1 << 9))) {
            Say("FAIL: 7-10 practice rack"); return false;
        }
        practiceId = 2;
        applyPracticeLeave();
        if (pinMgr.getStandingMask() != (1 << 9)) {
            Say("FAIL: 10-pin practice rack"); return false;
        }
        practiceId = 3;
        applyPracticeLeave();
        if (pinMgr.getStandingMask() != ((1 << 2) + (1 << 5) + (1 << 9))) {
            Say("FAIL: 3-6-10 practice rack"); return false;
        }
        if (verifyOilBreakdown() == false) { return false; }
        if (verifyPartyRankings() == false) { return false; }
        if (verifyTenthFrameRackReset() == false) { return false; }
        return true;
    }

    hide func verifyOilBreakdown() -> Boolean {
        startNewMatchMode(1, config.MODE_SINGLE);
        var before = laneObj.getFrictionAt(0.0, 5.0);
        for (var pass: Integer = 0; pass < 80; pass = pass + 1) {
            laneObj.recordBallTrack(0.0, 5.0, config.SPIN_MAX, 0.5);
        }
        var after = laneObj.getFrictionAt(0.0, 5.0);
        if (after <= before || laneObj.getOilWearPercent() <= 0) {
            Say("FAIL: repeated shots did not alter the oil pattern"); return false;
        }
        return true;
    }

    hide func verifyPartyRankings() -> Boolean {
        startNewMatchMode(3, config.MODE_PARTY);
        partyId = 1;
        scoreKeepers.get(0).recordRoll(1); scoreKeepers.get(0).recordRoll(0);
        scoreKeepers.get(1).recordRoll(2); scoreKeepers.get(1).recordRoll(0);
        scoreKeepers.get(2).recordRoll(3); scoreKeepers.get(2).recordRoll(0);
        openResultsScreen();
        if (resultsWinner != 0 || resultsRanking.get(0) != 0) {
            Say("FAIL: Low Ball did not rank the lowest score first"); return false;
        }

        startNewMatchMode(3, config.MODE_PARTY);
        partyId = 2;
        partyScores.set(0, 12); partyScores.set(1, 30); partyScores.set(2, 20);
        for (var i: Integer = 0; i < 3; i = i + 1) {
            scoreKeepers.get(i).recordRoll(0); scoreKeepers.get(i).recordRoll(0);
        }
        openResultsScreen();
        if (resultsWinner != 1 || resultsScores.get(1) != 30) {
            Say("FAIL: Target Bowling did not rank precision score highest"); return false;
        }
        return true;
    }

    /// @brief Run an actual physics strike in a short tenth-frame mode and
    ///        verify that the bonus delivery receives a new ten-pin rack.
    hide func verifyTenthFrameRackReset() -> Boolean {
        startNewMatchMode(1, config.MODE_PARTY);
        launchBall(0.0, config.THROW_POWER_MAX);
        var steps = 0;
        while ((gameState == config.STATE_ROLLING || gameState == config.STATE_SETTLING) &&
               steps < 2600) {
            Physics3DWorld.Step(physWorld, config.PHYSICS_DT);
            if (gameState == config.STATE_ROLLING) {
                updateRollingStep(config.PHYSICS_DT);
            } else {
                updateSettlingStep(config.PHYSICS_DT);
            }
            steps = steps + 1;
        }
        if (gameState != config.STATE_SCORING) {
            Say("FAIL: tenth-frame physics shot did not settle"); return false;
        }
        updateScoring();
        var keeper = scoreKeepers.get(0);
        if (keeper.wasStrike() == false || keeper.getRollInFrame() != 2 ||
            pendingFrameAdvance == false) {
            Say("FAIL: tenth-frame strike did not request a bonus rack"); return false;
        }
        updateSweeping(config.SWEEP_DURATION + 0.1);
        if (gameState != config.STATE_RESETTING) {
            Say("FAIL: pinsetter skipped tenth-frame full reset"); return false;
        }
        updateResetting(config.RESET_DURATION + 0.1);
        if (pinMgr.getStandingMask() != (1 << config.PIN_COUNT) - 1) {
            Say("FAIL: bonus delivery did not receive ten standing pins"); return false;
        }
        return true;
    }
}

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var probe = new BowlingMatchProbe();
    if (probe.verify() == false) { Say("RESULT: fail"); return; }
    Audio.Shutdown();
    Say("RESULT: ok");
}
