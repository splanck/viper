// ============================================================================
// MODULE: util/mathutil
// PURPOSE: Tiny shared scalar/vector helpers used across the bowling demo so
//          the same clamp / normalize / midpoint patterns are not re-inlined
//          in ball, lane, and game_flow.
//
// WHERE-THIS-FITS: Leaf module with no game state; bound by the physics and
//          flow layers. Pure functions only.
// ============================================================================

module mathutil;

bind Viper.Math;

/// @brief Clamp v to the [0, 1] range.
func clamp01(v: Float) -> Float {
    if (v < 0.0) { return 0.0; }
    if (v > 1.0) { return 1.0; }
    return v;
}

/// @brief Clamp v to the [lo, hi] range.
func clampf(v: Float, lo: Float, hi: Float) -> Float {
    if (v < lo) { return lo; }
    if (v > hi) { return hi; }
    return v;
}

/// @brief Map v within [lo, hi] to a 0..1 fraction (clamped, divide-by-zero safe).
func normFrac(v: Float, lo: Float, hi: Float) -> Float {
    return clamp01((v - lo) / (hi - lo + 0.0001));
}

/// @brief Midpoint of two points.
func vec3Mid(a: Vec3, b: Vec3) -> Vec3 {
    return new Vec3(
        (Vec3.get_X(a) + Vec3.get_X(b)) * 0.5,
        (Vec3.get_Y(a) + Vec3.get_Y(b)) * 0.5,
        (Vec3.get_Z(a) + Vec3.get_Z(b)) * 0.5);
}
