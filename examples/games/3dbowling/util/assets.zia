//
// File: examples/games/3dbowling/util/assets.zia
// Purpose: Resolve optional demo assets consistently in source and packages.
// Key invariants:
//   - All consumers use the same four location classes in the same order.
//   - Each unavailable logical asset emits its fallback diagnostic once.
// Ownership/Lifetime:
//   - Module state owns only a bounded set of missing logical asset names.
// Links: ../menu.zia, ../lane/lane.zia, ../LONG_TERM_IMPROVEMENT_SPEC.md
//
//===----------------------------------------------------------------------===//

module assets;

bind Viper.IO.File as File;
bind Viper.IO.Path as Path;
bind Viper.Terminal as Terminal;

var missingAssetNames: List[String] = [];

hide func alreadyReported(name: String) -> Boolean {
    for (var i: Integer = 0; i < missingAssetNames.count(); i = i + 1) {
        if (missingAssetNames.get(i) == name) { return true; }
    }
    return false;
}

expose func reportOptionalMissing(name: String) {
    if (alreadyReported(name)) { return; }
    missingAssetNames.add(name);
    Terminal.Say("Neon Lanes: optional asset missing: " + name +
        "; using procedural fallback");
}

/// @brief Resolve repository, project, package, then demo-bin candidates.
expose func resolveOptionalAsset(relativePath: String, name: String) -> String {
    var repositoryPath = Path.Join("examples/games/3dbowling", relativePath);
    if (File.Exists(repositoryPath)) { return repositoryPath; }

    var projectPath = relativePath;
    if (File.Exists(projectPath)) { return projectPath; }

    var packagePath = Path.Join(Path.ExeDir(), relativePath);
    if (File.Exists(packagePath)) { return packagePath; }

    var directRelativePath = Path.Join("../games/3dbowling", relativePath);
    if (File.Exists(directRelativePath)) { return directRelativePath; }

    reportOptionalMissing(name);
    return "";
}

expose func getMissingLogCount(name: String) -> Integer {
    if (alreadyReported(name)) { return 1; }
    return 0;
}

expose func resetAssetDiagnostics() { missingAssetNames.clear(); }
