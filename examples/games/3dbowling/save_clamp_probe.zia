//
// File: examples/games/3dbowling/save_clamp_probe.zia
// Purpose: Injects corrupt save extremes and verifies schema-four range recovery.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: save_clamp_probe
// PURPOSE: Standalone below/above-range migration contract for every stored
//          menu enum, number, Boolean encoding, statistic, and bit mask.
// ============================================================================

module save_clamp_probe;

bind Zanna.Terminal as Terminal;
bind "./menu";

func main() {
    menu.PERSISTENCE_ENABLED = false;
    var below = new BowlingMenu();
    below.applyOutOfRangeForProbe(-99999999);
    if (below.settingsInRangeForProbe() == false) {
        Terminal.Say("RESULT: fail below-range settings escaped migration");
        return;
    }
    var above = new BowlingMenu();
    above.applyOutOfRangeForProbe(99999999);
    if (above.settingsInRangeForProbe() == false) {
        Terminal.Say("RESULT: fail above-range settings escaped migration");
        return;
    }
    Terminal.Say("RESULT: ok");
}
