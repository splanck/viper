//
// File: examples/games/3dbowling/gameplay/shot_watchdog.zia
// Purpose: Bound rolling-state lifetime and gate throw input after pause.
// Key invariants:
//   - A watchdog reports its terminal edge exactly once.
//   - A held throw control cannot cross a pause/resume boundary.
// Ownership/Lifetime:
//   - Both helpers contain value state and own no runtime resources.
// Links: ../engine/game_flow.zia, release_meter.zia, ../config.zia
//
//===----------------------------------------------------------------------===//

module shot_watchdog;

bind Viper.Math;
bind "../config";

/// @brief Fixed-step progress and lifetime guard for one rolling ball.
class ShotWatchdog {
    hide Float elapsed;
    hide Float noProgressElapsed;
    hide Float furthestZ;
    hide Float safeX;
    hide Float safeY;
    hide Float safeZ;
    hide Boolean tripped;
    hide String reason;

    expose func reset(startZ: Float) {
        elapsed = 0.0;
        noProgressElapsed = 0.0;
        furthestZ = startZ;
        safeX = 0.0;
        safeY = config.BALL_RADIUS + config.BALL_START_Y_OFFSET;
        safeZ = startZ;
        tripped = false;
        reason = "";
    }

    hide func inFiniteRange(value: Float) -> Boolean {
        // Ordered bounds reject NaN as well as infinities/escaped physics
        // coordinates without requiring a demo-specific runtime primitive.
        return value >= -1000000.0 && value <= 1000000.0;
    }

    /// @brief Advance the guard; true only on the first terminal edge.
    expose func update(dt: Float, x: Float, y: Float, z: Float) -> Boolean {
        if (tripped || dt <= 0.0) { return false; }
        if (inFiniteRange(x) == false || inFiniteRange(y) == false ||
            inFiniteRange(z) == false) {
            tripped = true;
            reason = "ball stalled";
            return true;
        }

        elapsed = elapsed + dt;
        noProgressElapsed = noProgressElapsed + dt;
        safeX = x;
        safeY = y;
        safeZ = z;
        if (z >= furthestZ + config.ROLL_PROGRESS_EPSILON) {
            furthestZ = z;
            noProgressElapsed = 0.0;
        }
        if (elapsed >= config.ROLL_WATCHDOG_SECONDS ||
            noProgressElapsed >= config.ROLL_PROGRESS_TIMEOUT) {
            tripped = true;
            reason = "ball stalled";
            return true;
        }
        return false;
    }

    expose func isTripped() -> Boolean { return tripped; }
    expose func getElapsed() -> Float { return elapsed; }
    expose func getReason() -> String { return reason; }
    expose func getSafeX() -> Float { return safeX; }
    expose func getSafeY() -> Float { return safeY; }
    expose func getSafeZ() -> Float { return safeZ; }
}

/// @brief Requires a neutral throw control before post-pause input is read.
class ThrowResumeGate {
    hide Boolean blocked;

    expose func block() { blocked = true; }
    expose func reset() { blocked = false; }
    expose func isBlocked() -> Boolean { return blocked; }

    expose func allowsCharge(held: Boolean) -> Boolean {
        if (blocked) {
            if (held == false) { blocked = false; }
            return false;
        }
        return held;
    }
}
