//
// File: examples/games/3dbowling/gameplay/delivery_model.zia
// Purpose: Pure, deterministic conversion from bowler setup and timing into
//          the launch values shared by the preview and rigid-body delivery.
// Key invariants:
//   - Equal inputs produce bit-for-bit equal scalar results.
//   - Assistance narrows human error but never alters pin or scoring rules.
// Ownership/Lifetime:
//   - DeliveryModel is stateless; each solve call owns its result object.
//   - DeliverySolution contains value fields and owns no native resources.
// Links: release_meter.zia, ../lane/ball.zia, ../config.zia
//
//===----------------------------------------------------------------------===//

module delivery_model;

bind Viper.Math;
bind "../config";

/// @brief Scalar launch contract consumed by preview and physical delivery.
class DeliverySolution {
    expose Float releaseX;
    expose Float targetX;
    expose Float projectedTargetX;
    expose Float sideSpeed;
    expose Float forwardSpeed;
    expose Float launchSpeed;
    expose Float effectiveHook;
    expose Float axisRotation;
    expose Float revRate;
    expose Float effectiveAccuracy;
    expose Float uncertaintyWidth;
    expose Float oilResponse;
}

/// @brief Stateless delivery solver with bounded assist and equipment effects.
class DeliveryModel {
    hide func clamp(value: Float, low: Float, high: Float) -> Float {
        if (value < low) { return low; }
        if (value > high) { return high; }
        return value;
    }

    hide func difficultyScale(difficulty: Integer) -> Float {
        if (difficulty == config.DIFFICULTY_CASUAL) {
            return config.DIFFICULTY_ERROR_CASUAL;
        }
        if (difficulty == config.DIFFICULTY_LEAGUE) {
            return config.DIFFICULTY_ERROR_LEAGUE;
        }
        return config.DIFFICULTY_ERROR_STANDARD;
    }

    hide func familyRetention(family: String) -> Float {
        if (family == "Plastic") { return 0.30; }
        if (family == "Urethane") { return 0.64; }
        if (family == "Solid") { return 0.88; }
        if (family == "Reactive") { return 0.98; }
        if (family == "Hybrid") { return 1.06; }
        if (family == "Pearl") { return 1.12; }
        return 0.84;
    }

    hide func oilResponseFor(oilFit: Integer, oilPattern: Integer) -> Float {
        var safeFit = oilFit;
        if (safeFit < 0) { safeFit = 0; }
        if (safeFit > 3) { safeFit = 3; }
        // Fit 1 is the deliberately universal house-ball cover. Other fits
        // favor dry (0), medium/house (2), or sport/heavy (3).
        if (safeFit == 1) { return 0.96; }
        var ideal = 2;
        if (oilPattern == config.OIL_DRY) { ideal = 0; }
        if (oilPattern == config.OIL_SPORT) { ideal = 3; }
        var distance = Abs((safeFit - ideal) + 0.0);
        return clamp(1.06 - distance * 0.10, 0.78, 1.06);
    }

    /// @brief Solve one release without reading time, input, physics, or RNG.
    /// @param stanceX Ball center at the foul line in world metres.
    /// @param targetX Desired board at BALL_TARGET_Z in world metres.
    /// @param normalizedPower Meter result in [0,1].
    /// @param hookInput Player hook setting in [-SPIN_MAX,+SPIN_MAX].
    /// @param releaseOffset Signed timing offset in [-1,+1], zero is perfect.
    expose func solve(stanceX: Float, targetX: Float, normalizedPower: Float,
                      hookInput: Float, releaseOffset: Float, assistAmount: Float,
                      difficulty: Integer, control: Integer, oilFit: Integer,
                      oilPattern: Integer, family: String, ballMaxSpeed: Float,
                      spareRelease: Boolean) -> DeliverySolution {
        var result = new DeliverySolution();
        var stance = clamp(stanceX, -config.STANCE_MAX, config.STANCE_MAX);
        var target = clamp(targetX, -config.TARGET_MAX, config.TARGET_MAX);
        var power = clamp(normalizedPower, 0.0, 1.0);
        var offset = clamp(releaseOffset, -1.0, 1.0);
        var assist = clamp(assistAmount, 0.0, 1.0);
        var controlPct = clamp((control + 0.0) / 100.0, 0.0, 1.0);

        var rawAccuracy = 1.0 - Abs(offset);
        var assisted = rawAccuracy + (1.0 - rawAccuracy) * assist;
        var controlRecovery = (1.0 - assisted) * controlPct * 0.18;
        var effectiveAccuracy = clamp(assisted + controlRecovery, 0.0, 1.0);
        var remainingError = 1.0 - effectiveAccuracy;
        var errorScale = difficultyScale(difficulty);
        var errorSign = 0.0;
        if (offset < 0.0) { errorSign = -1.0; }
        if (offset > 0.0) { errorSign = 1.0; }

        var maxSpeed = ballMaxSpeed;
        if (maxSpeed < config.THROW_SPEED_MIN + 0.2) {
            maxSpeed = config.THROW_SPEED_MIN + 0.2;
        }
        // The gentle lower end reaches the rack, but cannot carry like a shot
        // in the broad 68-88% scoring window.
        var powerCurve = power * power * (3.0 - 2.0 * power);
        var speed = config.THROW_SPEED_MIN +
            (maxSpeed - config.THROW_SPEED_MIN) * powerCurve;
        var speedLoss = remainingError * config.RELEASE_SPEED_ERROR_MAX * errorScale;
        speed = speed * (1.0 - speedLoss);
        if (speed < config.THROW_SPEED_MIN) { speed = config.THROW_SPEED_MIN; }

        var angleError = errorSign * remainingError *
            config.RELEASE_ANGLE_ERROR_MAX * errorScale;
        var travelZ = config.BALL_TARGET_Z - config.BALL_THROW_Z;
        if (travelZ < 5.0) { travelZ = 5.0; }
        var nominalSlope = (target - stance) / travelZ;
        var sideSpeed = speed *
            (nominalSlope * config.BALL_SIDE_SPEED_SCALE + angleError);
        if (sideSpeed < -config.BALL_SIDE_SPEED_MAX) {
            sideSpeed = -config.BALL_SIDE_SPEED_MAX;
        }
        if (sideSpeed > config.BALL_SIDE_SPEED_MAX) {
            sideSpeed = config.BALL_SIDE_SPEED_MAX;
        }
        var forwardSq = speed * speed - sideSpeed * sideSpeed;
        if (forwardSq < 1.0) { forwardSq = 1.0; }

        var oilResponse = oilResponseFor(oilFit, oilPattern);
        var shapedHook = hookInput * familyRetention(family) * oilResponse;
        if (spareRelease) { shapedHook = shapedHook * 0.18; }
        var axisError = errorSign * remainingError *
            config.RELEASE_AXIS_ERROR_MAX * errorScale;
        if (spareRelease) { axisError = axisError * 0.18; }

        result.releaseX = stance;
        result.targetX = target;
        result.sideSpeed = sideSpeed;
        result.forwardSpeed = Sqrt(forwardSq);
        // Graphics3D's rolling contact converts the deliberately damped
        // launch-side component back into board travel. Publish that same
        // projection so the guide and the rigid body share one contract.
        result.projectedTargetX = stance +
            (sideSpeed / result.forwardSpeed / config.BALL_SIDE_SPEED_SCALE) * travelZ;
        result.launchSpeed = speed;
        result.effectiveHook = shapedHook;
        result.axisRotation = shapedHook + axisError;
        result.revRate = speed / config.BALL_RADIUS *
            (0.86 + effectiveAccuracy * 0.14);
        result.effectiveAccuracy = effectiveAccuracy;
        result.uncertaintyWidth = 0.008 + remainingError * errorScale *
            (0.18 - controlPct * 0.09);
        result.oilResponse = oilResponse;
        return result;
    }
}
