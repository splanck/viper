// ============================================================================
// MODULE: gameplay/release_meter
// PURPOSE: Deterministic power-and-accuracy timing model for an accessible
//          arcade-simulation bowling release.
// ============================================================================

module release_meter;

bind Zanna.Math;
bind "../config";

/// @brief Two-signal release meter: oscillating power and centered accuracy.
class ReleaseMeter {
    hide Float power;
    hide Float powerDirection;
    hide Float needle;
    hide Float powerElapsed;
    hide Float accuracyElapsed;
    hide Float assist;
    // 0 = idle, 1 = power charge, 2 = accuracy confirmation.
    hide Integer stage;

    expose func init() { reset(0.35); }

    /// @param assistAmount Fraction of missed accuracy recovered, in [0,1].
    expose func reset(assistAmount: Float) {
        power = 0.0;
        powerDirection = 1.0;
        needle = (Sin(config.ACCURACY_NEEDLE_PHASE) + 1.0) * 0.5;
        powerElapsed = 0.0;
        accuracyElapsed = 0.0;
        assist = assistAmount;
        if (assist < 0.0) { assist = 0.0; }
        if (assist > 1.0) { assist = 1.0; }
        stage = 0;
    }

    expose func beginCharge() {
        if (stage == 0) { stage = 1; }
    }

    expose func update(dt: Float) {
        if (stage == 0 || dt <= 0.0) { return; }
        if (stage == 1) {
            var stepDt = dt;
            if (stepDt > 0.05) { stepDt = 0.05; }
            powerElapsed = powerElapsed + stepDt;
            power = power + powerDirection * stepDt * config.POWER_NEEDLE_RATE;
            // Reflect overshoot instead of discarding it at a bound. Losing
            // that fraction made identical elapsed time choose different power
            // at 30, 60, and 144 Hz.
            if (power > 1.0) {
                power = 1.0 - (power - 1.0);
                powerDirection = -1.0;
            } else if (power < 0.18 && powerDirection < 0.0) {
                power = 0.18 + (0.18 - power);
                powerDirection = 1.0;
            }
            return;
        }

        // Accuracy starts from a fixed phase after power is locked, so holding
        // power longer cannot also choose the release result.
        var accuracyDt = dt;
        if (accuracyDt > 0.05) { accuracyDt = 0.05; }
        accuracyElapsed = accuracyElapsed + accuracyDt;
        needle = (Sin(accuracyElapsed * config.ACCURACY_NEEDLE_RATE +
            config.ACCURACY_NEEDLE_PHASE) + 1.0) * 0.5;
    }

    /// @brief Lock the power result and enter the independent accuracy stage.
    expose func lockPower() {
        if (stage != 1) { return; }
        if (power < 0.18) { power = 0.18; }
        accuracyElapsed = 0.0;
        needle = (Sin(config.ACCURACY_NEEDLE_PHASE) + 1.0) * 0.5;
        stage = 2;
    }

    /// @return Assisted accuracy, where 1 is perfect and 0 is a full miss.
    expose func release() -> Float {
        if (stage == 1) { lockPower(); }
        stage = 0;
        var raw = 1.0 - Abs(needle - 0.5) * 2.0;
        if (raw < 0.0) { raw = 0.0; }
        return raw + (1.0 - raw) * assist;
    }

    /// @brief Abort a partial delivery without synthesizing a release.
    expose func cancel() { stage = 0; }

    expose func getPower() -> Float { return power; }
    expose func getNeedle() -> Float { return needle; }
    expose func getRawAccuracy() -> Float {
        var raw = 1.0 - Abs(needle - 0.5) * 2.0;
        if (raw < 0.0) { raw = 0.0; }
        return raw;
    }
    expose func isCharging() -> Boolean { return stage == 1; }
    expose func isAwaitingAccuracy() -> Boolean { return stage == 2; }
    expose func confirmTimedOut() -> Boolean {
        return stage == 2 && accuracyElapsed >= config.RELEASE_CONFIRM_TIMEOUT;
    }
}
