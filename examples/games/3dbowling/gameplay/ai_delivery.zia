//
// File: examples/games/3dbowling/gameplay/ai_delivery.zia
// Purpose: Deterministically plan AI inputs for the shared delivery solver.
// Key invariants:
//   - AI uses legal human stance, target, hook, power, and timing inputs.
//   - Difficulty/career tune input bands, never score or pinfall directly.
// Ownership/Lifetime:
//   - AiDeliveryModel is stateless and results own only scalar values.
// Links: delivery_model.zia, ../engine/game_flow.zia
//
//===----------------------------------------------------------------------===//

module ai_delivery;

bind Zanna.Math;
bind "../config";

class AiDeliveryPlan {
    expose Float stanceX;
    expose Float targetX;
    expose Float hook;
    expose Float power;
    expose Float releaseOffset;
}

class AiDeliveryModel {
    expose func solve(frame: Integer, roll: Integer, careerTier: Integer,
                      difficulty: Integer) -> AiDeliveryPlan {
        var plan = new AiDeliveryPlan();
        var tier = careerTier;
        if (tier < 0) { tier = 0; }
        if (tier > 2) { tier = 2; }
        var variation = ((frame * 7 + roll * 3) % 5) - 2;

        var spread = 0.017;
        var timingBand = 0.048;
        if (difficulty == config.DIFFICULTY_STANDARD) {
            spread = 0.012;
            timingBand = 0.035;
        } else if (difficulty == config.DIFFICULTY_LEAGUE) {
            spread = 0.008;
            timingBand = 0.024;
        }
        spread = spread * (1.0 - (tier + 0.0) * 0.16);
        timingBand = timingBand * (1.0 - (tier + 0.0) * 0.20);

        // The calibrated right pocket is ~board 23. Rivals add a small amount
        // of left axis at higher tiers but still pass every scalar through the
        // exact same DeliveryModel and rigid-body rack as the player.
        plan.stanceX = -0.012 + (variation + 0.0) * spread * 0.42;
        plan.targetX = 0.065 + (variation + 0.0) * spread;
        plan.hook = -0.008 - (tier + 0.0) * 0.012;
        plan.power = 0.74 + (tier + 0.0) * 0.045 +
            (variation + 0.0) * 0.008;
        plan.releaseOffset = (variation + 0.0) * timingBand;
        return plan;
    }
}
