//
// File: examples/games/3dbowling/gameplay/impact_batch.zia
// Purpose: Classify one fixed step's collision batch without order effects.
// Key invariants:
//   - Ball-pin contact is discovered before pin-pin eligibility is queried.
//   - Reordering a batch cannot change which pin contacts are accepted.
// Ownership/Lifetime:
//   - ImpactBatch owns value state only and is reused for every physics step.
// Links: ../engine/game_flow.zia, ../trajectory_probe.zia
//
//===----------------------------------------------------------------------===//

module impact_batch;

bind "../config";

/// @brief Two-pass collision classifier for a single fixed physics step.
class ImpactBatch {
    hide Boolean rackAlreadyArmed;
    hide Boolean sawBallPin;
    hide Boolean scanComplete;

    expose func reset(rackArmed: Boolean) {
        rackAlreadyArmed = rackArmed;
        sawBallPin = false;
        scanComplete = false;
    }

    /// @brief Pass-one observation. Trigger pairs never arm a rack.
    expose func scanPair(layerA: Integer, layerB: Integer,
                         isTrigger: Boolean) {
        if (scanComplete || isTrigger) { return; }
        if (isBallPinPair(layerA, layerB)) { sawBallPin = true; }
    }

    /// @brief Seal pass one before any registration decisions are made.
    expose func finishScan() { scanComplete = true; }

    expose func sawBallPinContact() -> Boolean { return sawBallPin; }

    expose func isBallPinPair(layerA: Integer, layerB: Integer) -> Boolean {
        return (layerA == config.LAYER_BALL && layerB == config.LAYER_PINS) ||
            (layerA == config.LAYER_PINS && layerB == config.LAYER_BALL);
    }

    /// @brief True when the first body is an eligible pin impact recipient.
    expose func shouldRegisterPin(layer: Integer, otherLayer: Integer) -> Boolean {
        if (scanComplete == false || layer != config.LAYER_PINS) { return false; }
        if (otherLayer == config.LAYER_BALL) { return true; }
        return otherLayer == config.LAYER_PINS &&
            (rackAlreadyArmed || sawBallPin);
    }
}
