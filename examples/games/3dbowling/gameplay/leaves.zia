// ============================================================================
// MODULE: gameplay/leaves
// PURPOSE: Names and difficulty ratings for recognizable standing-pin leaves.
// ============================================================================

module leaves;

/// @brief Converts a ten-bit standing-pin mask into broadcast-style feedback.
class LeaveAnalyzer {
    expose func describe(mask: Integer) -> String {
        if (mask == 0) { return "Strike"; }
        if (mask == 1) { return "Head pin"; }
        if (mask == (1 << 6)) { return "7 pin"; }
        if (mask == (1 << 9)) { return "10 pin"; }
        if (mask == ((1 << 6) + (1 << 9))) { return "7-10 split"; }
        if (mask == ((1 << 3) + (1 << 5))) { return "4-6 split"; }
        if (mask == ((1 << 0) + (1 << 6) + (1 << 9))) { return "Greek church"; }
        if (mask == ((1 << 2) + (1 << 5) + (1 << 9))) { return "3-6-10 bucket"; }
        if (mask == ((1 << 1) + (1 << 3) + (1 << 6))) { return "2-4-7 bucket"; }
        if (mask == ((1 << 4) + (1 << 7))) { return "5-8 sleeper"; }
        if (mask == ((1 << 4) + (1 << 8))) { return "5-9 sleeper"; }
        return toPinList(mask);
    }

    /// @return 0 easy, 1 moderate, 2 hard, 3 elite.
    expose func difficulty(mask: Integer) -> Integer {
        if (mask == 0) { return 0; }
        if (mask == ((1 << 6) + (1 << 9)) ||
            mask == ((1 << 0) + (1 << 6) + (1 << 9))) { return 3; }
        if (mask == ((1 << 3) + (1 << 5)) || countBits(mask) >= 5) { return 2; }
        if (countBits(mask) >= 2) { return 1; }
        return 0;
    }

    hide func countBits(mask: Integer) -> Integer {
        var count = 0;
        for (var i: Integer = 0; i < 10; i = i + 1) {
            if ((mask & (1 << i)) != 0) { count = count + 1; }
        }
        return count;
    }

    hide func toPinList(mask: Integer) -> String {
        var text = "";
        for (var i: Integer = 0; i < 10; i = i + 1) {
            if ((mask & (1 << i)) != 0) {
                if (text != "") { text = text + "-"; }
                text = text + toString(i + 1);
            }
        }
        if (text == "") { return "Deck cleared"; }
        return text + " leave";
    }
}

