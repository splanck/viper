//
// File: examples/games/3dbowling/gameplay/feedback_model.zia
// Purpose: Map measured delivery/impact energy to bounded feedback layers.
// Key invariants:
//   - Layer selection depends on measured values, never scoring shortcuts.
//   - Particle and dust outputs remain bounded at both extremes.
// Ownership/Lifetime:
//   - FeedbackModel is stateless and owns no runtime resources.
// Links: ../effects/particles.zia, ../engine/game_flow.zia
//
//===----------------------------------------------------------------------===//

module feedback_model;

bind "../config";

class FeedbackModel {
    expose func rollLayer(speed: Float) -> String {
        if (speed < 3.4) { return "roll_soft"; }
        if (speed < 5.25) { return "roll_medium"; }
        return "roll_hard";
    }

    expose func impactLayer(strength: Float) -> String {
        if (strength < 0.38) { return "pins_soft"; }
        if (strength < 1.15) { return "pins_medium"; }
        return "pins_hard";
    }

    expose func impactParticleCount(strength: Float) -> Integer {
        if (strength < 0.38) { return 8; }
        if (strength < 1.15) { return config.SPARK_COUNT; }
        return config.SPARK_COUNT * 2;
    }

    expose func dustScale(power: Float) -> Float {
        var safePower = power;
        if (safePower < 0.0) { safePower = 0.0; }
        if (safePower > 1.0) { safePower = 1.0; }
        return 0.22 + safePower * 0.70;
    }
}
