//===----------------------------------------------------------------------===//
//
// File: examples/games/3dbowling/impact_order_probe.zia
// Purpose: Prove fixed-step impact eligibility is independent of event order.
// Key invariants:
//   - Pass one observes the entire batch before pin-pin eligibility is tested.
//   - Trigger and static contacts cannot enter the impacted pin mask.
// Ownership/Lifetime:
//   - Each test order owns one short-lived impact classifier and pin world.
// Links: gameplay/impact_batch.zia, lane/pins.zia
//
//===----------------------------------------------------------------------===//

module impact_order_probe;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./gameplay/impact_batch";
bind "./lane/pins";

/// @return Low ten bits = impacted mask; next ten bits = physical down mask.
func runOrder(reverse: Boolean) -> Integer {
    // The first event is deliberately pin-pin. In a one-pass implementation
    // it would be rejected in forward order but accepted in reverse order.
    var layersA: List[Integer] = [config.LAYER_PINS, config.LAYER_STATIC,
        config.LAYER_BALL, config.LAYER_BALL, config.LAYER_PINS];
    var layersB: List[Integer] = [config.LAYER_PINS, config.LAYER_PINS,
        config.LAYER_PINS, config.LAYER_PINS, config.LAYER_PINS];
    var pinsA: List[Integer] = [2, -1, -1, -1, 3];
    var pinsB: List[Integer] = [3, 7, 0, 9, 4];
    var triggers: List[Integer] = [0, 0, 0, 1, 0];
    var count = layersA.length;

    var batch = new ImpactBatch();
    batch.reset(false);
    for (var step: Integer = 0; step < count; step = step + 1) {
        var index = step;
        if (reverse) { index = count - 1 - step; }
        batch.scanPair(layersA.get(index), layersB.get(index),
            triggers.get(index) == 1);
    }
    batch.finishScan();

    var impactedMask = 0;
    for (var step: Integer = 0; step < count; step = step + 1) {
        var index = step;
        if (reverse) { index = count - 1 - step; }
        if (triggers.get(index) == 1) { continue; }
        if (batch.shouldRegisterPin(layersA.get(index), layersB.get(index))) {
            impactedMask = impactedMask | (1 << pinsA.get(index));
        }
        if (batch.shouldRegisterPin(layersB.get(index), layersA.get(index))) {
            impactedMask = impactedMask | (1 << pinsB.get(index));
        }
    }

    // Score remains physical: only the selected sustained topples count, even
    // though other pins were eligible for impact feedback in this batch.
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var pins = new PinManager();
    pins.initPins(world);
    var physicalCandidates = (1 << 0) | (1 << 3);
    for (var pin: Integer = 0; pin < config.PIN_COUNT; pin = pin + 1) {
        if ((impactedMask & physicalCandidates & (1 << pin)) != 0) {
            PhysicsBody3D.SetOrientation(pins.getPinBody(pin),
                Quat.FromAxisAngle(new Vec3(1.0, 0.0, 0.0), 1.20));
        }
    }
    pins.updateKnockdowns(config.PIN_DOWN_DWELL * 0.55);
    pins.updateKnockdowns(config.PIN_DOWN_DWELL * 0.55);
    return impactedMask | (pins.getKnockedMask() << config.PIN_COUNT);
}

func main() {
    var forward = runOrder(false);
    var reverse = runOrder(true);
    var expectedImpacts = (1 << 0) | (1 << 2) | (1 << 3) | (1 << 4);
    var expectedDown = (1 << 0) | (1 << 3);
    var expected = expectedImpacts | (expectedDown << config.PIN_COUNT);
    if (forward != reverse) {
        Terminal.Say("RESULT: fail reversing events changed impact or pinfall masks");
        return;
    }
    if (forward != expected) {
        Terminal.Say("RESULT: fail collision batch admitted an ineligible contact");
        return;
    }
    Terminal.Say("RESULT: ok");
}
