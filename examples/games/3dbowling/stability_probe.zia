//
// File: examples/games/3dbowling/stability_probe.zia
// Purpose: Verifies pause input gating and every terminal shot-watchdog edge.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: stability_probe
// PURPOSE: Standalone contracts for delivery termination and pause/resume
//          release gating. This probe is intentionally outside CTest.
// ============================================================================

module stability_probe;

bind Zanna.Terminal as Terminal;
bind "./config";
bind "./gameplay/release_meter";
bind "./gameplay/shot_watchdog";

func main() {
    var stalled = new ShotWatchdog();
    stalled.reset(2.0);
    var stallTrips = 0;
    for (var i: Integer = 0; i < 180; i = i + 1) {
        if (stalled.update(1.0 / 60.0, 0.0, 0.1, 2.0)) {
            stallTrips = stallTrips + 1;
        }
    }
    if (stallTrips != 1 || stalled.getReason() != "ball stalled") {
        Terminal.Say("RESULT: fail stalled shot did not trip exactly once");
        return;
    }

    var overtime = new ShotWatchdog();
    overtime.reset(0.0);
    var overtimeTrips = 0;
    for (var i: Integer = 0; i < 900; i = i + 1) {
        var z = (i + 0.0) * 0.04;
        if (overtime.update(1.0 / 60.0, 0.0, 0.1, z)) {
            overtimeTrips = overtimeTrips + 1;
        }
    }
    if (overtimeTrips != 1 || overtime.getElapsed() < config.ROLL_WATCHDOG_SECONDS) {
        Terminal.Say("RESULT: fail overtime shot did not trip exactly once");
        return;
    }

    var invalid = new ShotWatchdog();
    invalid.reset(0.0);
    if (invalid.update(1.0 / 60.0, 100000000000000000000.0, 0.1, 0.1) == false) {
        Terminal.Say("RESULT: fail non-finite-range state was accepted");
        return;
    }

    var meter = new ReleaseMeter();
    meter.reset(config.RELEASE_ASSIST_STANDARD);
    meter.beginCharge();
    meter.update(0.31);
    meter.lockPower();
    meter.update(0.19);
    var pausedPower = meter.getPower();
    var pausedNeedle = meter.getNeedle();
    var gate = new ThrowResumeGate();
    gate.block();
    for (var poll: Integer = 0; poll < 120; poll = poll + 1) {
        if (gate.allowsCharge(true)) {
            Terminal.Say("RESULT: fail held throw bypassed resume gate");
            return;
        }
    }
    if (Abs(meter.getPower() - pausedPower) > 0.000001 ||
        Abs(meter.getNeedle() - pausedNeedle) > 0.000001) {
        Terminal.Say("RESULT: fail paused second-stage meter advanced");
        return;
    }
    if (gate.allowsCharge(false) || gate.isBlocked()) {
        Terminal.Say("RESULT: fail release edge did not arm resume gate cleanly");
        return;
    }
    if (gate.allowsCharge(true) == false) {
        Terminal.Say("RESULT: fail fresh throw press stayed blocked after resume");
        return;
    }

    Terminal.Say("RESULT: ok");
}
