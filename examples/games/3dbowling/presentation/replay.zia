//===----------------------------------------------------------------------===//
//
// File: examples/games/3dbowling/presentation/replay.zia
// Purpose: Record and render bounded, decimated scene-transform replays.
// Key invariants:
//   - Every accepted sample contains one ball and exactly ten pin transforms.
//   - Capture is capped at REPLAY_MAX and never mutates live physics.
// Ownership/Lifetime:
//   - ReplayRecorder owns scalar sample lists and lightweight ghost meshes.
//   - clear() releases all references to the preceding gameplay scene.
// Links: ../engine/game_flow.zia, ../lane/pins.zia, ../config.zia
//
//===----------------------------------------------------------------------===//

module replay;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Core.Convert as Convert;
bind "../config";
bind "../lane/pins";

/// @brief Records complete scene transforms and renders an instant replay.
class ReplayRecorder {
    hide List[Float] ballXs;
    hide List[Float] ballYs;
    hide List[Float] ballZs;
    hide List[Float] pinXs;
    hide List[Float] pinYs;
    hide List[Float] pinZs;
    hide List[Float] pinQXs;
    hide List[Float] pinQYs;
    hide List[Float] pinQZs;
    hide List[Float] pinQWs;
    hide Integer sampleCounter;
    hide Boolean active;
    hide Float timer;
    hide Float duration;
    hide Boolean reducedMotion;
    hide Mesh3D ballMesh;
    hide Mesh3D pinBodyMesh;
    hide Mesh3D pinHeadMesh;
    hide Mesh3D pinBandMesh;
    hide Material3D ballMat;
    hide Material3D pinMat;
    hide Material3D pinBandMat;

    expose func init() {
        ballXs = []; ballYs = []; ballZs = [];
        pinXs = []; pinYs = []; pinZs = [];
        pinQXs = []; pinQYs = []; pinQZs = []; pinQWs = [];
        sampleCounter = 0;
        active = false;
        timer = 0.0;
        duration = 2.0;
        reducedMotion = false;
        ballMesh = Mesh3D.Sphere(config.BALL_RADIUS, 14);
        ballMat = Material3D.PBR(0.10, 0.88, 0.98);
        ballMat.Metallic = 0.18;
        ballMat.Roughness = 0.20;
        Material3D.SetEmissiveColor(ballMat, 0.08, 0.48, 0.58);

        pinBodyMesh = Mesh3D.Cylinder(config.PIN_RADIUS,
            config.PIN_HEIGHT * 0.70, 14);
        pinHeadMesh = Mesh3D.Sphere(config.PIN_RADIUS * 0.91, 12);
        pinBandMesh = Mesh3D.Cylinder(config.PIN_RADIUS * 1.02, 0.018, 12);
        pinMat = Material3D.PBR(0.74, 0.93, 1.0);
        pinMat.Roughness = 0.36;
        Material3D.SetEmissiveColor(pinMat, 0.06, 0.22, 0.28);
        pinBandMat = Material3D.FromColor(1.0, 0.24, 0.12);
        Material3D.SetEmissiveColor(pinBandMat, 0.42, 0.035, 0.012);
    }

    expose func clear() {
        ballXs.clear(); ballYs.clear(); ballZs.clear();
        pinXs.clear(); pinYs.clear(); pinZs.clear();
        pinQXs.clear(); pinQYs.clear(); pinQZs.clear(); pinQWs.clear();
        sampleCounter = 0;
        active = false;
        timer = 0.0;
    }

    expose func beginCapture() { clear(); }

    /// @brief Capture one complete fixed-step scene every two calls.
    expose func captureScene(ballPosition: Vec3, pins: PinManager) {
        sampleCounter = sampleCounter + 1;
        if (sampleCounter % config.REPLAY_SAMPLE_STEPS != 0) { return; }
        if (ballXs.count() >= config.REPLAY_MAX) { return; }

        ballXs.add(Vec3.get_X(ballPosition));
        ballYs.add(Vec3.get_Y(ballPosition));
        ballZs.add(Vec3.get_Z(ballPosition));
        for (var i: Integer = 0; i < config.PIN_COUNT; i = i + 1) {
            var position = pins.getPinPosition(i);
            var orientation = pins.getPinOrientation(i);
            pinXs.add(Vec3.get_X(position));
            pinYs.add(Vec3.get_Y(position));
            pinZs.add(Vec3.get_Z(position));
            pinQXs.add(Quat.get_X(orientation));
            pinQYs.add(Quat.get_Y(orientation));
            pinQZs.add(Quat.get_Z(orientation));
            pinQWs.add(Quat.get_W(orientation));
        }
    }

    expose func hasCompleteScene() -> Boolean {
        var expectedPins = ballXs.count() * config.PIN_COUNT;
        return ballXs.count() > 0 && ballYs.count() == ballXs.count() &&
            ballZs.count() == ballXs.count() && pinXs.count() == expectedPins &&
            pinYs.count() == expectedPins && pinZs.count() == expectedPins &&
            pinQXs.count() == expectedPins && pinQYs.count() == expectedPins &&
            pinQZs.count() == expectedPins && pinQWs.count() == expectedPins;
    }

    expose func start(seconds: Float) -> Boolean {
        if (ballXs.count() < 5 || hasCompleteScene() == false) { return false; }
        duration = seconds;
        if (reducedMotion) { duration = duration * 0.55; }
        if (duration < 0.5) { duration = 0.5; }
        timer = duration;
        active = true;
        return true;
    }

    expose func update(dt: Float) {
        if (active == false || dt <= 0.0) { return; }
        timer = timer - dt;
        if (timer <= 0.0) { timer = 0.0; active = false; }
    }

    expose func isActive() -> Boolean { return active; }
    expose func setReducedMotion(enabled: Boolean) { reducedMotion = enabled; }
    expose func isReducedMotion() -> Boolean { return reducedMotion; }
    expose func stop() { active = false; timer = 0.0; }
    expose func getSampleCount() -> Integer { return ballXs.count(); }
    expose func getBallX(index: Integer) -> Float { return ballXs.get(index); }

    expose func getPinTransformCount(sample: Integer) -> Integer {
        if (sample < 0 || sample >= ballXs.count() || hasCompleteScene() == false) {
            return 0;
        }
        return config.PIN_COUNT;
    }

    expose func getPinPosition(sample: Integer, pin: Integer) -> Vec3 {
        var index = sample * config.PIN_COUNT + pin;
        return new Vec3(pinXs.get(index), pinYs.get(index), pinZs.get(index));
    }

    expose func getPinOrientation(sample: Integer, pin: Integer) -> Quat {
        var index = sample * config.PIN_COUNT + pin;
        return Quat.New(pinQXs.get(index), pinQYs.get(index),
            pinQZs.get(index), pinQWs.get(index));
    }

    hide func drawReplayPin(canvas: Canvas3D, sample: Integer, pin: Integer) {
        var position = getPinPosition(sample, pin);
        if (Vec3.get_Y(position) < -5.0) { return; }
        var translate = Mat4.Translate(Vec3.get_X(position),
            Vec3.get_Y(position) + config.PIN_DRAW_Y_OFFSET, Vec3.get_Z(position));
        var base = Mat4.Mul(translate, Quat.ToMat4(getPinOrientation(sample, pin)));
        Canvas3D.DrawMesh(canvas, pinBodyMesh,
            Mat4.Mul(base, Mat4.Translate(0.0, -0.03, 0.0)), pinMat);
        Canvas3D.DrawMesh(canvas, pinHeadMesh,
            Mat4.Mul(base, Mat4.Translate(0.0, 0.19, 0.0)), pinMat);
        Canvas3D.DrawMesh(canvas, pinBandMesh,
            Mat4.Mul(base, Mat4.Translate(0.0, 0.085, 0.0)), pinBandMat);
    }

    expose func draw(canvas: Canvas3D) {
        if (active == false || hasCompleteScene() == false || ballXs.count() < 2) {
            return;
        }
        var progress = 1.0 - timer / duration;
        if (progress < 0.0) { progress = 0.0; }
        if (progress > 1.0) { progress = 1.0; }
        var index = Convert.NumToInt(progress * ((ballXs.count() - 1) + 0.0));
        if (index < 0) { index = 0; }
        if (index >= ballXs.count()) { index = ballXs.count() - 1; }

        var start = index - 18;
        if (start < 1) { start = 1; }
        for (var i: Integer = start; i <= index; i = i + 1) {
            Canvas3D.DrawLine3D(canvas,
                new Vec3(ballXs.get(i - 1), 0.048, ballZs.get(i - 1)),
                new Vec3(ballXs.get(i), 0.048, ballZs.get(i)), 0x3DE0F0);
        }
        Canvas3D.DrawMesh(canvas, ballMesh,
            Mat4.Translate(ballXs.get(index), ballYs.get(index), ballZs.get(index)), ballMat);
        for (var pin: Integer = 0; pin < config.PIN_COUNT; pin = pin + 1) {
            drawReplayPin(canvas, index, pin);
        }
    }
}
