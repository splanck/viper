//
// File: examples/games/3dbowling/pinfall_contract_probe.zia
// Purpose: Verifies physical pinfall, seeded racks, and angular settling.
// Key invariants:
//   - A collision event alone cannot award a fallen pin.
//   - Rack seed and difficulty fully determine bounded home-position jitter.
// Ownership/Lifetime:
//   - The probe owns one short-lived physics world and pin manager.
// Links: lane/pins.zia, config.zia, LONG_TERM_IMPROVEMENT_SPEC.md
//
//===----------------------------------------------------------------------===//

module pinfall_contract_probe;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./lane/pins";

func fail(message: String) {
    Terminal.Say("RESULT: fail " + message);
}

func main() {
    var world = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var pins = new PinManager();
    pins.initPins(world);
    pins.setRackSeed(137, config.DIFFICULTY_STANDARD);
    var x1 = pins.getHomeX(4);
    pins.setRackSeed(137, config.DIFFICULTY_STANDARD);
    if (Abs(x1 - pins.getHomeX(4)) > 0.000001) {
        fail("same rack seed changed home positions"); return;
    }
    pins.setRackSeed(211, config.DIFFICULTY_STANDARD);
    var seedDelta = Abs(x1 - pins.getHomeX(4));
    if (seedDelta < 0.00001 || seedDelta > config.RACK_JITTER_STANDARD * 2.01) {
        fail("rack jitter is absent or out of bounds"); return;
    }

    var head = pins.getPinBody(0);
    var point = PhysicsBody3D.get_Position(head);
    pins.registerImpact(head, point, 20.0, 20.0);
    pins.updateKnockdowns(config.PHYSICS_DT);
    if (pins.isKnocked(0)) {
        fail("collision event directly marked an upright pin down"); return;
    }

    PhysicsBody3D.SetOrientation(head,
        Quat.FromAxisAngle(new Vec3(1.0, 0.0, 0.0), 1.20));
    pins.updateKnockdowns(config.PIN_DOWN_DWELL * 0.55);
    if (pins.isKnocked(0)) {
        fail("pinfall ignored the physical dwell"); return;
    }
    pins.updateKnockdowns(config.PIN_DOWN_DWELL * 0.55);
    if (pins.isKnocked(0) == false) {
        fail("sustained physical tilt was not counted"); return;
    }

    var quietWorld = PhysicsWorld3D.New(0.0, config.GRAVITY_Y, 0.0);
    var quietPins = new PinManager();
    quietPins.initPins(quietWorld);
    quietPins.updateKnockdowns(config.SETTLE_QUIET_DWELL * 0.45);
    if (quietPins.allSettled()) {
        fail("rack settled without the quiet dwell"); return;
    }
    quietPins.updateKnockdowns(config.SETTLE_QUIET_DWELL * 0.65);
    if (quietPins.allSettled() == false) {
        fail("quiet rack did not settle after the dwell"); return;
    }

    Terminal.Say("RESULT: ok");
}
