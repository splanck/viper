//
// File: examples/games/3dbowling/accessibility_probe.zia
// Purpose: Verifies high contrast, large HUD, reduced motion, and reduced flash propagation.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: accessibility_probe
// PURPOSE: Standalone propagation contract for high contrast, reduced motion,
//          reduced flash, and large gameplay HUD settings.
// ============================================================================

module accessibility_probe;

bind Viper.Graphics3D;
bind Viper.Terminal as Terminal;
bind "./engine/camera";
bind "./engine/hud";
bind "./effects/celebrations";
bind "./presentation/bowler";
bind "./presentation/replay";

func main() {
    var camera = Camera3D.New(60.0, 16.0 / 9.0, 0.1, 100.0);
    var controller = new CameraController();
    controller.initCamera(camera);
    controller.setReducedMotion(true);
    controller.startCinematic(0.0, 15.0);
    if (controller.isReducedMotion() == false ||
        controller.getCinematicDuration() >= 1.0) {
        Terminal.Say("RESULT: fail reduced-motion camera policy");
        return;
    }

    var replay = new ReplayRecorder();
    replay.setReducedMotion(true);
    if (replay.isReducedMotion() == false) {
        Terminal.Say("RESULT: fail replay reduced-motion policy");
        return;
    }
    var celebration = new CelebrationManager();
    celebration.initCelebrations();
    celebration.setReducedFlash(true);
    if (celebration.getReducedFlash() == false) {
        Terminal.Say("RESULT: fail reduced-flash policy");
        return;
    }
    var hud = new HUD();
    hud.initHUD();
    hud.setAccessibility(true, true);
    if (hud.getHighContrast() == false || hud.getLargeHud() == false) {
        Terminal.Say("RESULT: fail HUD accessibility policy");
        return;
    }
    var bowler = new BowlerAvatar();
    bowler.setReducedMotion(true);
    if (bowler.getReducedMotion() == false) {
        Terminal.Say("RESULT: fail bowler reduced-motion policy");
        return;
    }
    Terminal.Say("RESULT: ok");
}
