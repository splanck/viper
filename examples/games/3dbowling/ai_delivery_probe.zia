// File: examples/games/3dbowling/ai_delivery_probe.zia
// Purpose: Verifies AI planning bands and separation from human release assistance.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: ai_delivery_probe
// PURPOSE: Standalone shared-physics AI planning and difficulty-band contract.
// ============================================================================

module ai_delivery_probe;

bind Zanna.Terminal as Terminal;
bind "./config";
bind "./gameplay/ai_delivery";

func main() {
    var model = new AiDeliveryModel();
    var casual = model.solve(4, 1, 0, config.DIFFICULTY_CASUAL);
    var standard = model.solve(4, 1, 0, config.DIFFICULTY_STANDARD);
    var league = model.solve(4, 1, 0, config.DIFFICULTY_LEAGUE);
    if (Abs(casual.releaseOffset) <= Abs(standard.releaseOffset) ||
        Abs(standard.releaseOffset) <= Abs(league.releaseOffset)) {
        Terminal.Say("RESULT: fail AI release bands ignore difficulty");
        return;
    }
    var rookie = model.solve(8, 1, 0, config.DIFFICULTY_STANDARD);
    var elite = model.solve(8, 1, 2, config.DIFFICULTY_STANDARD);
    if (Abs(elite.releaseOffset) >= Abs(rookie.releaseOffset) ||
        elite.power <= rookie.power) {
        Terminal.Say("RESULT: fail career rivals do not improve gradually");
        return;
    }
    if (Abs(standard.stanceX) > config.STANCE_MAX ||
        Abs(standard.targetX) > config.TARGET_MAX ||
        standard.power < 0.68 || standard.power > 0.88) {
        Terminal.Say("RESULT: fail AI plan escaped human delivery bounds");
        return;
    }
    Terminal.Say("RESULT: ok");
}
