//
// File: examples/games/3dbowling/replay_scene_probe.zia
// Purpose: Verifies complete bounded ball-and-pin replay scene capture.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: replay_scene_probe
// PURPOSE: Standalone replay contract: decimated, bounded samples include the
//          actual ball and all ten pin transforms.
// ============================================================================

module replay_scene_probe;

bind Viper.Graphics3D;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./lane/pins";
bind "./presentation/replay";

func main() {
    var world = Physics3DWorld.New(0.0, config.GRAVITY_Y, 0.0);
    var pins = new PinManager();
    pins.initPins(world);
    var replay = new ReplayRecorder();
    replay.beginCapture();

    var ball = new Vec3(0.12, config.BALL_RADIUS, 6.5);
    replay.captureScene(ball, pins);
    replay.captureScene(ball, pins);
    if (replay.getSampleCount() != 1 || replay.hasCompleteScene() == false) {
        Terminal.Say("RESULT: fail one decimated scene sample was not complete");
        return;
    }
    if (replay.getPinTransformCount(0) != config.PIN_COUNT ||
        Abs(replay.getBallX(0) - 0.12) > 0.000001) {
        Terminal.Say("RESULT: fail replay omitted ball or pin transforms");
        return;
    }
    var actual = pins.getPinPosition(0);
    var captured = replay.getPinPosition(0, 0);
    if (Abs(Vec3.get_X(actual) - Vec3.get_X(captured)) > 0.000001 ||
        Abs(Vec3.get_Z(actual) - Vec3.get_Z(captured)) > 0.000001) {
        Terminal.Say("RESULT: fail replay pin position differs from physics");
        return;
    }
    var orientation = replay.getPinOrientation(0, 0);
    if (Abs(Quat.get_W(orientation) - 1.0) > 0.0001) {
        Terminal.Say("RESULT: fail replay pin orientation was not captured");
        return;
    }

    for (var i: Integer = 0; i < config.REPLAY_MAX * 3; i = i + 1) {
        replay.captureScene(ball, pins);
    }
    if (replay.getSampleCount() > config.REPLAY_MAX) {
        Terminal.Say("RESULT: fail replay samples exceeded their hard cap");
        return;
    }
    replay.clear();
    if (replay.getSampleCount() != 0 || replay.isActive()) {
        Terminal.Say("RESULT: fail replay clear retained world data");
        return;
    }

    Terminal.Say("RESULT: ok");
}
