// ============================================================================
// MODULE: content/ball_catalog
// PURPOSE: Data-driven bowling-ball catalog used by gameplay, the locker, and
//          player-facing equipment comparisons.
// ============================================================================

module ball_catalog;

/// @brief Immutable-at-runtime specification for one selectable bowling ball.
class BallSpec {
    hide String name;
    hide String family;
    hide String description;
    hide Float mass;
    hide Float maxSpeed;
    hide Float hook;
    hide Integer control;
    hide Integer oilFit;
    hide Integer color;
    hide Integer unlockScore;

    expose func init(specName: String, specFamily: String, specDescription: String,
                     specMass: Float, specMaxSpeed: Float, specHook: Float,
                     specControl: Integer, specOilFit: Integer,
                     specColor: Integer, requiredScore: Integer) {
        name = specName;
        family = specFamily;
        description = specDescription;
        mass = specMass;
        maxSpeed = specMaxSpeed;
        hook = specHook;
        control = specControl;
        oilFit = specOilFit;
        color = specColor;
        unlockScore = requiredScore;
    }

    expose func getName() -> String { return name; }
    expose func getFamily() -> String { return family; }
    expose func getDescription() -> String { return description; }
    expose func getMass() -> Float { return mass; }
    expose func getMaxSpeed() -> Float { return maxSpeed; }
    expose func getHook() -> Float { return hook; }
    expose func getControl() -> Integer { return control; }
    expose func getOilFit() -> Integer { return oilFit; }
    expose func getColor() -> Integer { return color; }
    expose func getUnlockScore() -> Integer { return unlockScore; }
}

/// @brief Six-ball release catalog with distinct lane-condition tradeoffs.
class BallCatalog {
    hide List[BallSpec] balls;

    expose func init() {
        balls = [];
        balls.add(new BallSpec(
            "House Control", "Plastic", "Straight and forgiving on every lane.",
            6.0, 5.95, 0.98, 96, 1, 0x39D5D0, 0));
        balls.add(new BallSpec(
            "Skyline Light", "Reactive", "Fast response with an easy backend turn.",
            4.7, 6.28, 1.04, 80, 1, 0x4D8DFF, 100));
        balls.add(new BallSpec(
            "Maple Solid", "Solid", "Smooth benchmark motion for medium oil.",
            6.2, 5.88, 1.14, 88, 2, 0x2EDB9B, 140));
        balls.add(new BallSpec(
            "Iron Urethane", "Urethane", "Heavy control piece for dry boards.",
            7.3, 5.66, 0.80, 94, 0, 0xD2A84A, 170));
        balls.add(new BallSpec(
            "Vector Hybrid", "Hybrid", "Angular shape for demanding sport oil.",
            6.4, 5.84, 1.26, 74, 3, 0xEF476F, 200));
        balls.add(new BallSpec(
            "Neon Pearl", "Pearl", "Length through the fronts and maximum recovery.",
            5.9, 6.06, 1.42, 66, 2, 0xB46CFF, 230));
    }

    expose func count() -> Integer { return balls.count(); }

    expose func get(index: Integer) -> BallSpec {
        var safe = index;
        if (safe < 0) { safe = 0; }
        if (safe >= balls.count()) { safe = balls.count() - 1; }
        return balls.get(safe);
    }

    expose func isUnlocked(index: Integer, bestScore: Integer) -> Boolean {
        return bestScore >= get(index).getUnlockScore();
    }

    expose func firstUnlockedFrom(index: Integer, direction: Integer,
                                  bestScore: Integer) -> Integer {
        var cursor = index;
        var checked = 0;
        while (checked < balls.count()) {
            cursor = cursor + direction;
            if (cursor < 0) { cursor = balls.count() - 1; }
            if (cursor >= balls.count()) { cursor = 0; }
            if (isUnlocked(cursor, bestScore)) { return cursor; }
            checked = checked + 1;
        }
        return 0;
    }
}
