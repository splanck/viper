//
// File: examples/games/3dbowling/asset_resolution_probe.zia
// Purpose: Verifies centralized optional-asset discovery and procedural fallback behavior.
// Key invariants:
//   - State and resource bounds follow LONG_TERM_IMPROVEMENT_SPEC.md.
//   - The implementation remains dependency-free and deterministic where specified.
// Ownership/Lifetime:
//   - Runtime resources are owned by the declaring game subsystem or probe scope.
// Links: LONG_TERM_IMPROVEMENT_SPEC.md, UPGRADE_AUDIT.md
//
//===----------------------------------------------------------------------===//
//
// ============================================================================
// MODULE: asset_resolution_probe
// PURPOSE: Standalone packaged/source asset lookup and log-once fallback
//          contract. It does not rename or remove repository assets.
// ============================================================================

module asset_resolution_probe;

bind Viper.IO.File as File;
bind Viper.Terminal as Terminal;
bind "./util/assets";

func main() {
    assets.resetAssetDiagnostics();
    var lanePath = assets.resolveOptionalAsset(
        "assets/textures/lane-maple.png", "lane-maple.png");
    var titlePath = assets.resolveOptionalAsset(
        "assets/art/title-key-art.png", "title-key-art.png");
    if (lanePath == "" || titlePath == "" ||
        File.Exists(lanePath) == false || File.Exists(titlePath) == false) {
        Terminal.Say("RESULT: fail authored assets were not resolved");
        return;
    }

    var missingA = assets.resolveOptionalAsset(
        "assets/not-present.png", "not-present.png");
    var missingB = assets.resolveOptionalAsset(
        "assets/not-present.png", "not-present.png");
    if (missingA != "" || missingB != "" ||
        assets.getMissingLogCount("not-present.png") != 1) {
        Terminal.Say("RESULT: fail missing optional asset did not log once");
        return;
    }

    Terminal.Say("RESULT: ok");
}
