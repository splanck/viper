// ============================================================================
// MODULE: scoring (ScoreKeeper)
// PURPOSE: Full 10-frame bowling score engine. Records each roll, builds
//          the per-frame display strings (X / / digits), and computes
//          running totals incorporating strike + spare bonuses.
//
// WHERE-THIS-FITS: Used by game.zia after every settled throw. The 3D
//          physics determines how many pins fell; that count is fed
//          into recordRoll, which updates the scoreboard.
//
// KEY-DESIGN-CHOICES:
//   * 10-FRAME RULES. Frames 1-9: at most 2 rolls (strike completes the
//     frame in 1). Frame 10: up to 3 rolls — bonus rolls awarded after
//     a strike or spare so the player can earn a "perfect" 30 in the
//     final frame.
//   * STRIKE = 10 + NEXT 2 ROLLS. Spare = 10 + NEXT 1 ROLL. Open frame
//     = pins down. recalcTotals walks all frames each call and computes
//     totals lazily — a frame's total stays -1 ("pending") until the
//     bonus rolls land.
//   * TURKEY TRACKING. consecutiveStrikes counts back-to-back strikes
//     for "turkey" celebrations (3+ strikes in a row). Reset on any
//     non-strike roll.
//   * DISPLAY STRINGS PRECOMPUTED. frameRoll1/2/3 hold the rendered
//     strings ("X", "/", "-", or pin count) so the HUD renderer just
//     prints them — no formatting in the hot draw path.
//   * CLAMP DEFENSIVE. recordRoll clamps `pinsDown` to [0, pinsStanding]
//     so the physics layer can pass a noisy count without breaking
//     the scoreboard's invariants.
// ============================================================================

// scoring.zia — Full 10-frame bowling scoring engine
// Handles strikes, spares, 10th frame bonus rolls, and running totals.
module scoring;

bind Viper.Terminal;
bind "../config";

/// @brief Bowling 10-frame score engine.
class ScoreKeeper {
    // Each roll records pins knocked down (0-10).
    // Up to 21 rolls possible (9 frames × 2 + 10th frame × 3).
    hide List[Integer] rolls;
    hide Integer rollCount;

    // Per-frame display data
    hide List[Integer] frameTotals;      // Running total per frame (-1 = pending)
    hide List[String] frameRoll1;        // Display string for roll 1
    hide List[String] frameRoll2;        // Display string for roll 2
    hide List[String] frameRoll3;        // Display string for roll 3 (10th only)

    // Current state
    hide Integer currentFrame;           // 1-based
    hide Integer currentRollInFrame;     // 1, 2, or 3 (10th only)
    hide Integer pinsStanding;           // Pins remaining this turn
    hide Integer consecutiveStrikes;     // For turkey tracking
    hide Boolean gameComplete;

    /// @brief Initialize an empty scoreboard; pre-allocate 10 frame slots.
    expose func init() {
        rolls = [];
        rollCount = 0;
        frameTotals = [];
        frameRoll1 = [];
        frameRoll2 = [];
        frameRoll3 = [];
        currentFrame = 1;
        currentRollInFrame = 1;
        pinsStanding = 10;
        consecutiveStrikes = 0;
        gameComplete = false;

        for (var i: Integer = 0; i < config.FRAMES_PER_GAME; i = i + 1) {
            frameTotals.add(-1);
            frameRoll1.add("");
            frameRoll2.add("");
            frameRoll3.add("");
        }
    }

    /// @brief Record a roll result. @return true when the frame closes.
    /// @details Branches on whether we're in frames 1-9 (≤ 2 rolls) vs
    ///          frame 10 (≤ 3 rolls with bonus rules). See module
    ///          header for the bonus formulas.
    expose func recordRoll(pinsDown: Integer) -> Boolean {
        if (gameComplete) { return true; }
        var clampedPinsDown = pinsDown;
        if (clampedPinsDown < 0) { clampedPinsDown = 0; }
        if (clampedPinsDown > pinsStanding) { clampedPinsDown = pinsStanding; }

        rolls.add(clampedPinsDown);
        rollCount = rollCount + 1;
        var frameIdx: Integer = currentFrame - 1;
        var frameComplete: Boolean = false;

        if (currentFrame < 10) {
            // ─── Frames 1-9 ───
            if (currentRollInFrame == 1) {
                if (clampedPinsDown == 10) {
                    // Strike
                    frameRoll1.set(frameIdx, "X");
                    frameRoll2.set(frameIdx, "");
                    consecutiveStrikes = consecutiveStrikes + 1;
                    frameComplete = true;
                } else {
                    if (clampedPinsDown == 0) {
                        frameRoll1.set(frameIdx, "-");
                    } else {
                        frameRoll1.set(frameIdx, toString(clampedPinsDown));
                    }
                    pinsStanding = 10 - clampedPinsDown;
                    currentRollInFrame = 2;
                    consecutiveStrikes = 0;
                }
            } else {
                // Second roll
                var total: Integer = rolls.get(rollCount - 2) + clampedPinsDown;
                if (total == 10) {
                    // Spare
                    frameRoll2.set(frameIdx, "/");
                } else if (clampedPinsDown == 0) {
                    frameRoll2.set(frameIdx, "-");
                } else {
                    frameRoll2.set(frameIdx, toString(clampedPinsDown));
                }
                consecutiveStrikes = 0;
                frameComplete = true;
            }

            if (frameComplete) {
                currentFrame = currentFrame + 1;
                currentRollInFrame = 1;
                pinsStanding = 10;
                if (currentFrame > config.FRAMES_PER_GAME) {
                    gameComplete = true;
                }
            }
        } else {
            // ─── 10th Frame (special rules) ───
            if (currentRollInFrame == 1) {
                if (clampedPinsDown == 10) {
                    frameRoll1.set(frameIdx, "X");
                    consecutiveStrikes = consecutiveStrikes + 1;
                    pinsStanding = 10; // Reset for bonus roll
                } else {
                    if (clampedPinsDown == 0) {
                        frameRoll1.set(frameIdx, "-");
                    } else {
                        frameRoll1.set(frameIdx, toString(clampedPinsDown));
                    }
                    pinsStanding = 10 - clampedPinsDown;
                    consecutiveStrikes = 0;
                }
                currentRollInFrame = 2;

            } else if (currentRollInFrame == 2) {
                var firstRollPins: Integer = rolls.get(rollCount - 2);
                var firstWasStrike: Boolean = (firstRollPins == 10);

                if (firstWasStrike) {
                    // After a strike, full rack reset
                    if (clampedPinsDown == 10) {
                        frameRoll2.set(frameIdx, "X");
                        consecutiveStrikes = consecutiveStrikes + 1;
                        pinsStanding = 10; // Reset again for 3rd roll
                    } else {
                        if (clampedPinsDown == 0) {
                            frameRoll2.set(frameIdx, "-");
                        } else {
                            frameRoll2.set(frameIdx, toString(clampedPinsDown));
                        }
                        pinsStanding = 10 - clampedPinsDown;
                        consecutiveStrikes = 0;
                    }
                    currentRollInFrame = 3;
                } else {
                    // After non-strike first roll
                    var total: Integer = firstRollPins + clampedPinsDown;
                    if (total == 10) {
                        // Spare
                        frameRoll2.set(frameIdx, "/");
                        pinsStanding = 10; // Reset for bonus roll
                        currentRollInFrame = 3;
                    } else {
                        // Open frame in 10th — no bonus roll
                        if (clampedPinsDown == 0) {
                            frameRoll2.set(frameIdx, "-");
                        } else {
                            frameRoll2.set(frameIdx, toString(clampedPinsDown));
                        }
                        consecutiveStrikes = 0;
                        frameComplete = true;
                        gameComplete = true;
                    }
                }

            } else {
                // 3rd roll (bonus)
                // Check if we're on a fresh rack or remaining pins
                if (clampedPinsDown == pinsStanding && clampedPinsDown == 10) {
                    frameRoll3.set(frameIdx, "X");
                    consecutiveStrikes = consecutiveStrikes + 1;
                } else if (clampedPinsDown == pinsStanding) {
                    frameRoll3.set(frameIdx, "/");
                } else if (clampedPinsDown == 0) {
                    frameRoll3.set(frameIdx, "-");
                } else {
                    frameRoll3.set(frameIdx, toString(clampedPinsDown));
                }
                frameComplete = true;
                gameComplete = true;
            }
        }

        // Recalculate all frame totals
        recalcTotals();
        return frameComplete;
    }

    /// @brief Recompute every frame's running total.
    /// @details Strike scores 10 + next 2 rolls; spare scores 10 + next
    ///          1 roll; open frame scores roll1 + roll2. A frame whose
    ///          bonus rolls haven't landed yet stays at -1 ("pending").
    hide func recalcTotals() {
        var runningTotal: Integer = 0;
        var rollIdx: Integer = 0;

        for (var f: Integer = 0; f < config.FRAMES_PER_GAME; f = f + 1) {
            if (rollIdx >= rollCount) {
                frameTotals.set(f, -1); // Not enough data yet
                continue;
            }

            if (f < 9) {
                // Frames 1-9
                var first: Integer = rolls.get(rollIdx);
                if (first == 10) {
                    // Strike: need next 2 rolls
                    if (rollIdx + 2 < rollCount) {
                        var bonus: Integer = rolls.get(rollIdx + 1) + rolls.get(rollIdx + 2);
                        runningTotal = runningTotal + 10 + bonus;
                        frameTotals.set(f, runningTotal);
                    } else {
                        frameTotals.set(f, -1); // Pending
                    }
                    rollIdx = rollIdx + 1;
                } else {
                    // Non-strike
                    if (rollIdx + 1 >= rollCount) {
                        frameTotals.set(f, -1); // Mid-frame
                        continue;
                    }
                    var second: Integer = rolls.get(rollIdx + 1);
                    var total: Integer = first + second;

                    if (total == 10) {
                        // Spare: need next 1 roll
                        if (rollIdx + 2 < rollCount) {
                            var bonus2: Integer = rolls.get(rollIdx + 2);
                            runningTotal = runningTotal + 10 + bonus2;
                            frameTotals.set(f, runningTotal);
                        } else {
                            frameTotals.set(f, -1); // Pending
                        }
                    } else {
                        // Open frame
                        runningTotal = runningTotal + total;
                        frameTotals.set(f, runningTotal);
                    }
                    rollIdx = rollIdx + 2;
                }
            } else {
                // 10th frame: just sum all remaining rolls (no look-ahead)
                var tenthTotal: Integer = 0;
                var tenthRolls: Integer = rollCount - rollIdx;
                for (var tr: Integer = 0; tr < tenthRolls; tr = tr + 1) {
                    tenthTotal = tenthTotal + rolls.get(rollIdx + tr);
                }

                if (gameComplete) {
                    runningTotal = runningTotal + tenthTotal;
                    frameTotals.set(f, runningTotal);
                } else {
                    frameTotals.set(f, -1); // Still rolling
                }
            }
        }
    }

    // ─── Query Methods ───

    /// @brief Current frame number (1-based).
    expose func getFrame() -> Integer {
        return currentFrame;
    }

    /// @brief Which roll within the current frame (1, 2, or 3 in 10th).
    expose func getRollInFrame() -> Integer {
        return currentRollInFrame;
    }

    /// @brief Pins still standing on the deck.
    expose func getPinsStanding() -> Integer {
        return pinsStanding;
    }

    /// @brief True after the 10th frame's last roll lands.
    expose func isGameOver() -> Boolean {
        return gameComplete;
    }

    /// @brief Latest computed total score (last non-pending frame total).
    expose func getTotalScore() -> Integer {
        // Return last valid frame total
        for (var i: Integer = config.FRAMES_PER_GAME - 1; i >= 0; i = i - 1) {
            if (frameTotals.get(i) >= 0) {
                return frameTotals.get(i);
            }
        }
        return 0;
    }

    /// @brief Running total at end of frame (-1 if not yet known).
    expose func getFrameTotal(frame: Integer) -> Integer {
        if (frame < 0 || frame >= config.FRAMES_PER_GAME) { return -1; }
        return frameTotals.get(frame);
    }

    /// @brief Display string for roll 1 of the given frame ("X", digit, etc.).
    expose func getFrameRoll1(frame: Integer) -> String {
        if (frame < 0 || frame >= config.FRAMES_PER_GAME) { return ""; }
        return frameRoll1.get(frame);
    }

    /// @brief Display string for roll 2 ("/" for spare, etc.).
    expose func getFrameRoll2(frame: Integer) -> String {
        if (frame < 0 || frame >= config.FRAMES_PER_GAME) { return ""; }
        return frameRoll2.get(frame);
    }

    /// @brief Display string for roll 3 (10th-frame bonus only).
    expose func getFrameRoll3(frame: Integer) -> String {
        if (frame < 0 || frame >= config.FRAMES_PER_GAME) { return ""; }
        return frameRoll3.get(frame);
    }

    /// @brief Streak length for "turkey" / "four-bagger" celebrations.
    expose func getConsecutiveStrikes() -> Integer {
        return consecutiveStrikes;
    }

    /// @brief True when the next roll begins on a fresh rack (10th-frame
    ///        strike/spare bonus).
    expose func needsFullReset() -> Boolean {
        return pinsStanding == 10;
    }

    /// @brief True if the most recently recorded roll was a strike (10 down).
    expose func wasStrike() -> Boolean {
        if (rollCount == 0) { return false; }
        var lastRoll: Integer = rolls.get(rollCount - 1);
        // Strike if 10 pins on first roll, or in 10th frame on fresh rack
        return lastRoll == 10;
    }

    /// @brief True if the last roll closed a spare (frame total = 10
    ///        without being a strike).
    expose func wasSpare() -> Boolean {
        if (rollCount < 2) { return false; }
        // Check if we just completed a spare (not a strike)
        var lastRoll: Integer = rolls.get(rollCount - 1);
        var prevRoll: Integer = rolls.get(rollCount - 2);
        if (prevRoll == 10) { return false; } // That was a strike, not spare
        return prevRoll + lastRoll == 10;
    }

    /// @brief True if the last roll was a gutter ball (0 pins down).
    expose func wasGutter() -> Boolean {
        if (rollCount == 0) { return false; }
        return rolls.get(rollCount - 1) == 0;
    }

    /// @brief Reset all per-game state for a new round.
    expose func reset() {
        rolls = [];
        rollCount = 0;
        currentFrame = 1;
        currentRollInFrame = 1;
        pinsStanding = 10;
        consecutiveStrikes = 0;
        gameComplete = false;

        for (var i: Integer = 0; i < config.FRAMES_PER_GAME; i = i + 1) {
            frameTotals.set(i, -1);
            frameRoll1.set(i, "");
            frameRoll2.set(i, "");
            frameRoll3.set(i, "");
        }
    }
}
