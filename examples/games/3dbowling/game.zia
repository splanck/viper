// game.zia — Main game loop, menus, input, fixed-step simulation, and match flow
module game;

bind Viper.Graphics3D;
bind Viper.Input;
bind Viper.Sound;
bind Viper.Terminal;
bind "./config";
bind "./menu";
bind "./engine/renderer";
bind "./engine/camera";
bind "./engine/hud";
bind "./lane/lane";
bind "./lane/pins";
bind "./lane/ball";
bind "./effects/particles";
bind "./effects/celebrations";
bind "./scoring/scoring";

class BowlingGame {
    hide Renderer render;
    hide CameraController camCtrl;
    hide HUD hudObj;
    hide BowlingMenu menuObj;

    hide LaneBuilder laneObj;
    hide PinManager pinMgr;
    hide Ball ballObj;
    hide ParticleManager particleMgr;
    hide CelebrationManager celebMgr;

    hide Physics3DWorld physWorld;

    hide ScoreKeeper scoreKeeperOne;
    hide ScoreKeeper scoreKeeperTwo;

    hide Integer screenState;
    hide Integer gameState;
    hide Float accumulator;
    hide Float settleTimer;
    hide Float scoreTimer;
    hide Float impactCooldown;
    hide Float skidMarkTimer;
    hide Float lightFlashTimer;

    hide Float aimX;
    hide Float power;
    hide Float spin;
    hide Boolean charging;
    hide Boolean gutterLatched;
    hide Boolean cinematicStarted;

    hide Integer oilPattern;
    hide Integer qualityMode;
    hide Integer currentMode;
    hide Integer playerCount;
    hide Integer activePlayer;

    hide Boolean pendingFrameAdvance;
    hide Boolean pendingPlayerSwitch;
    hide Boolean pendingResults;

    hide SoundBank soundBank;
    hide Boolean soundReady;
    hide Boolean quitRequested;

    hide Integer resultsPlayerOne;
    hide Integer resultsPlayerTwo;
    hide Integer resultsWinner;
    hide Boolean resultsNewHigh;

    expose func init() {
        screenState = config.SCREEN_TITLE;
        gameState = config.STATE_AIMING;
        accumulator = 0.0;
        settleTimer = 0.0;
        scoreTimer = 0.0;
        impactCooldown = 0.0;
        skidMarkTimer = 0.0;
        lightFlashTimer = 0.0;
        aimX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        gutterLatched = false;
        cinematicStarted = false;
        oilPattern = config.OIL_HOUSE;
        qualityMode = config.QUALITY_CINEMATIC;
        currentMode = config.MODE_SINGLE;
        playerCount = 1;
        activePlayer = 0;
        pendingFrameAdvance = false;
        pendingPlayerSwitch = false;
        pendingResults = false;
        soundReady = false;
        quitRequested = false;
        resultsPlayerOne = 0;
        resultsPlayerTwo = 0;
        resultsWinner = -1;
        resultsNewHigh = false;
    }

    expose func run() {
        printBanner();
        initSubsystems();
        gameLoop();
        Say("Thanks for playing 3D Bowling!");
    }

    hide func printBanner() {
        Say("╔══════════════════════════════════════╗");
        Say("║         3D BOWLING                   ║");
        Say("║  Native Viper 3D Runtime Showcase    ║");
        Say("╚══════════════════════════════════════╝");
        Say("");
    }

    hide func initSubsystems() {
        menuObj = new BowlingMenu();
        menuObj.init();
        oilPattern = menuObj.getOilPattern();
        qualityMode = menuObj.getQualityMode();
        currentMode = menuObj.getPreferredMode();

        render = new Renderer();
        render.initRenderer(qualityMode);

        camCtrl = new CameraController();
        camCtrl.initCamera(render.getCamera());

        hudObj = new HUD();
        hudObj.initHUD();

        initSound();
        setupActions();
        showTitleScreen();
    }

    hide func setupActions() {
        Action.Clear();
        Action.LoadPreset("menu_navigation");
        Action.BindKey(config.ACT_MENU_UP, Keyboard.get_KEY_W());
        Action.BindKey(config.ACT_MENU_UP, Keyboard.get_KEY_UP());
        Action.BindKey(config.ACT_MENU_DOWN, Keyboard.get_KEY_S());
        Action.BindKey(config.ACT_MENU_DOWN, Keyboard.get_KEY_DOWN());
        Action.BindKey(config.ACT_CONFIRM, Keyboard.get_KEY_ENTER());
        Action.BindKey(config.ACT_CONFIRM, Keyboard.get_KEY_SPACE());
        Action.BindKey(config.ACT_BACK, Keyboard.get_KEY_ESCAPE());
        Action.BindPadButton(config.ACT_MENU_UP, -1, Pad.get_PAD_UP());
        Action.BindPadButton(config.ACT_MENU_DOWN, -1, Pad.get_PAD_DOWN());
        Action.BindPadButton(config.ACT_CONFIRM, -1, Pad.get_PAD_A());
        Action.BindPadButton(config.ACT_BACK, -1, Pad.get_PAD_B());
        Action.BindPadButton(config.ACT_BACK, -1, Pad.get_PAD_START());

        Action.DefineAxis(config.ACT_AIM_X);
        Action.BindKeyAxis(config.ACT_AIM_X, Keyboard.get_KEY_A(), -1.0);
        Action.BindKeyAxis(config.ACT_AIM_X, Keyboard.get_KEY_LEFT(), -1.0);
        Action.BindKeyAxis(config.ACT_AIM_X, Keyboard.get_KEY_D(), 1.0);
        Action.BindKeyAxis(config.ACT_AIM_X, Keyboard.get_KEY_RIGHT(), 1.0);
        Action.BindPadButtonAxis(config.ACT_AIM_X, -1, Pad.get_PAD_LEFT(), -1.0);
        Action.BindPadButtonAxis(config.ACT_AIM_X, -1, Pad.get_PAD_RIGHT(), 1.0);

        Action.DefineAxis(config.ACT_SPIN_X);
        Action.BindKeyAxis(config.ACT_SPIN_X, Keyboard.get_KEY_Q(), -1.0);
        Action.BindKeyAxis(config.ACT_SPIN_X, Keyboard.get_KEY_E(), 1.0);
        Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_PAD_LB(), -1.0);
        Action.BindPadButtonAxis(config.ACT_SPIN_X, -1, Pad.get_PAD_RB(), 1.0);

        Action.Define(config.ACT_THROW);
        Action.BindKey(config.ACT_THROW, Keyboard.get_KEY_SPACE());
        Action.BindPadButton(config.ACT_THROW, -1, Pad.get_PAD_A());

        Action.Define(config.ACT_BALL_PREV);
        Action.BindKey(config.ACT_BALL_PREV, Keyboard.get_KEY_1());
        Action.BindPadButton(config.ACT_BALL_PREV, -1, Pad.get_PAD_LB());

        Action.Define(config.ACT_BALL_NEXT);
        Action.BindKey(config.ACT_BALL_NEXT, Keyboard.get_KEY_3());
        Action.BindPadButton(config.ACT_BALL_NEXT, -1, Pad.get_PAD_RB());

        Action.Define(config.ACT_RESET);
        Action.BindKey(config.ACT_RESET, Keyboard.get_KEY_R());
        Action.BindPadButton(config.ACT_RESET, -1, Pad.get_PAD_X());

        Action.Define(config.ACT_PAUSE);
        Action.BindKey(config.ACT_PAUSE, Keyboard.get_KEY_P());
        Action.BindPadButton(config.ACT_PAUSE, -1, Pad.get_PAD_START());

        Action.Define(config.ACT_CAMERA);
        Action.BindKey(config.ACT_CAMERA, Keyboard.get_KEY_C());
        Action.BindPadButton(config.ACT_CAMERA, -1, Pad.get_PAD_Y());
    }

    hide func initSound() {
        var ok = Audio.Init();
        if (ok == 0) {
            Say("Audio unavailable — continuing without sound");
            return;
        }

        Audio.SetMasterVolume(80);
        soundBank = SoundBank.New();
        soundBank.RegisterSound("roll", Synth.Sfx(config.SFX_LASER));
        soundBank.RegisterSound("crash", Synth.Sfx(config.SFX_EXPLODE));
        soundBank.RegisterSound("strike", Synth.Sfx(config.SFX_POWERUP));
        soundBank.RegisterSound("spare", Synth.Sfx(config.SFX_COIN));
        soundBank.RegisterSound("gutter", Synth.Sfx(config.SFX_HIT));
        soundBank.RegisterSound("ui", Synth.Sfx(config.SFX_COIN));
        soundReady = true;
    }

    hide func playSound(name: String) {
        if (soundReady) {
            soundBank.Play(name);
        }
    }

    hide func playSpatialSound(name: String, pos: Vec3, maxDistance: Float, volume: Integer) {
        if (soundReady == false) { return; }
        Audio3D.PlayAt(soundBank.Get(name), pos, maxDistance, volume);
    }

    hide func updateAudioListener() {
        if (soundReady == false) { return; }
        Audio3D.SetListener(Camera3D.get_Position(render.getCamera()),
            Camera3D.get_Forward(render.getCamera()));
    }

    hide func createGameplayWorld() {
        physWorld = Physics3DWorld.New(0.0, config.GRAVITY_Y, 0.0);

        laneObj = new LaneBuilder();
        laneObj.initLane(physWorld, oilPattern);

        pinMgr = new PinManager();
        pinMgr.initPins(physWorld);

        ballObj = new Ball();
        ballObj.initBall(physWorld);

        particleMgr = new ParticleManager();
        particleMgr.initParticles();

        celebMgr = new CelebrationManager();
        celebMgr.initCelebrations();

        var env = render.getSkybox();
        laneObj.applyEnvironment(env);
        pinMgr.applyEnvironment(env);
        ballObj.applyEnvironment(env);
    }

    hide func initScoreKeepers() {
        scoreKeeperOne = new ScoreKeeper();
        scoreKeeperOne.init();
        scoreKeeperTwo = new ScoreKeeper();
        scoreKeeperTwo.init();
    }

    hide func applyMenuSettings() {
        oilPattern = menuObj.getOilPattern();
        qualityMode = menuObj.getQualityMode();
        render.applyQuality(qualityMode);
    }

    hide func showTitleScreen() {
        applyMenuSettings();
        createGameplayWorld();
        screenState = config.SCREEN_TITLE;
        gameState = config.STATE_AIMING;
        aimX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        gutterLatched = false;
        accumulator = 0.0;
        camCtrl.setTitleMode();
        hudObj.showMessage("Select a mode and bowl.", config.HUD_COLOR_WHITE, config.MSG_DURATION_LONG);
    }

    hide func startNewMatch(mode: Integer) {
        applyMenuSettings();
        createGameplayWorld();
        initScoreKeepers();

        currentMode = mode;
        playerCount = 1;
        if (mode == config.MODE_VERSUS) { playerCount = 2; }
        activePlayer = 0;

        aimX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        accumulator = 0.0;
        settleTimer = 0.0;
        scoreTimer = 0.0;
        impactCooldown = 0.0;
        skidMarkTimer = 0.0;
        lightFlashTimer = 0.0;
        gutterLatched = false;
        cinematicStarted = false;
        pendingFrameAdvance = false;
        pendingPlayerSwitch = false;
        pendingResults = false;

        screenState = config.SCREEN_PLAYING;
        gameState = config.STATE_AIMING;
        camCtrl.setAimMode(0.0);

        if (playerCount == 2) {
            hudObj.showMessage("Versus match start. Player 1 up.", config.HUD_COLOR_GOLD, config.MSG_DURATION_LONG);
        } else {
            hudObj.showMessage("Aim and throw!", config.HUD_COLOR_WHITE, config.MSG_DURATION_LONG);
        }
    }

    hide func restartCurrentMatch() {
        startNewMatch(currentMode);
    }

    hide func gameLoop() {
        while (render.shouldClose() == false && quitRequested == false) {
            render.poll();
            if (render.shouldClose()) {
                break;
            }
            var dt = render.getDeltaTime();

            if (lightFlashTimer > 0.0) {
                lightFlashTimer = lightFlashTimer - dt;
                if (lightFlashTimer <= 0.0) {
                    render.resetPinLight();
                }
            }

            if (screenState == config.SCREEN_TITLE) {
                camCtrl.updateTitle(dt);
                handleTitleInput();
            } else if (screenState == config.SCREEN_OPTIONS) {
                camCtrl.updateTitle(dt);
                handleOptionsInput();
            } else if (screenState == config.SCREEN_PLAYING) {
                handlePlayingInput(dt);
            } else if (screenState == config.SCREEN_PAUSED) {
                handlePauseInput();
            } else if (screenState == config.SCREEN_RESULTS) {
                camCtrl.updateTitle(dt);
                handleResultsInput();
            }

            particleMgr.update(dt);
            celebMgr.update(dt);
            hudObj.update(dt);
            updateAudioListener();

            render.beginFrame();
            drawScene();
            render.endFrame();
            drawOverlays();
            render.flip();
        }
    }

    hide func handleTitleInput() {
        var cmd = menuObj.updateTitle();
        if (cmd == menu.CMD_START_SINGLE) {
            startNewMatch(config.MODE_SINGLE);
        } else if (cmd == menu.CMD_START_VERSUS) {
            startNewMatch(config.MODE_VERSUS);
        } else if (cmd == menu.CMD_OPEN_OPTIONS) {
            screenState = config.SCREEN_OPTIONS;
        } else if (cmd == menu.CMD_QUIT) {
            quitRequested = true;
        }
    }

    hide func handleOptionsInput() {
        var cmd = menuObj.updateOptions();
        applyMenuSettings();
        if (cmd == menu.CMD_BACK) {
            showTitleScreen();
        }
    }

    hide func handlePauseInput() {
        var cmd = menuObj.updatePause();
        if (cmd == menu.CMD_RESUME) {
            screenState = config.SCREEN_PLAYING;
        } else if (cmd == menu.CMD_RESTART) {
            restartCurrentMatch();
        } else if (cmd == menu.CMD_MAIN_MENU) {
            showTitleScreen();
        }
    }

    hide func handleResultsInput() {
        var cmd = menuObj.updateResults();
        if (cmd == menu.CMD_PLAY_AGAIN) {
            startNewMatch(currentMode);
        } else if (cmd == menu.CMD_MAIN_MENU) {
            showTitleScreen();
        }
    }

    hide func handlePlayingInput(dt: Float) {
        if (Action.Pressed(config.ACT_PAUSE) || Action.Pressed(config.ACT_BACK)) {
            screenState = config.SCREEN_PAUSED;
            return;
        }
        if (Action.Pressed(config.ACT_RESET)) {
            restartCurrentMatch();
            return;
        }
        if (Action.Pressed(config.ACT_CAMERA)) {
            cycleCameraMode();
        }

        if (gameState == config.STATE_AIMING) {
            updateAiming(dt);
        } else if (gameState == config.STATE_ROLLING) {
            runFixedStep(dt, true);
        } else if (gameState == config.STATE_SETTLING) {
            runFixedStep(dt, false);
        } else if (gameState == config.STATE_SCORING) {
            updateScoring();
        } else if (gameState == config.STATE_SWEEPING) {
            updateSweeping(dt);
        } else if (gameState == config.STATE_RESETTING) {
            updateResetting(dt);
        } else if (gameState == config.STATE_CELEBRATING) {
            updateCelebrating(dt);
        }
    }

    hide func runFixedStep(dt: Float, rolling: Boolean) {
        accumulator = accumulator + dt;
        var steps = 0;
        while (accumulator >= config.PHYSICS_DT && steps < config.MAX_FIXED_STEPS) {
            if (rolling) {
                updateRollingStep(config.PHYSICS_DT);
            } else {
                updateSettlingStep(config.PHYSICS_DT);
            }
            accumulator = accumulator - config.PHYSICS_DT;
            steps = steps + 1;
        }
    }

    hide func updateAiming(dt: Float) {
        aimX = aimX + Action.Axis(config.ACT_AIM_X) * config.AIM_SPEED * dt;
        if (aimX < -config.AIM_MAX) { aimX = -config.AIM_MAX; }
        if (aimX > config.AIM_MAX) { aimX = config.AIM_MAX; }

        spin = spin + Action.Axis(config.ACT_SPIN_X) * config.SPIN_RATE * dt;
        if (spin < -config.SPIN_MAX) { spin = -config.SPIN_MAX; }
        if (spin > config.SPIN_MAX) { spin = config.SPIN_MAX; }

        if (Action.Pressed(config.ACT_BALL_PREV)) {
            ballObj.cycleBall(-1);
            playSound("ui");
        }
        if (Action.Pressed(config.ACT_BALL_NEXT)) {
            ballObj.cycleBall(1);
            playSound("ui");
        }

        if (Action.Held(config.ACT_THROW)) {
            if (charging == false) {
                charging = true;
                power = 0.0;
            }
            power = power + dt * config.THROW_POWER_RATE;
            if (power > 1.0) { power = 1.0; }
        } else if (charging) {
            charging = false;
            ballObj.setSpin(spin);
            ballObj.doThrow(aimX, power);
            particleMgr.startLaneDust(aimX, config.BALL_THROW_Z);
            playSpatialSound("roll", ballObj.getPosition(), 12.0, 80);
            gutterLatched = false;
            impactCooldown = 0.0;
            skidMarkTimer = 0.0;
            accumulator = 0.0;
            gameState = config.STATE_ROLLING;
            camCtrl.setFollowMode();
        }

        ballObj.setAimPosition(aimX);
        camCtrl.updateAim(aimX, dt);
    }

    hide func updateRollingStep(dt: Float) {
        impactCooldown = impactCooldown - dt;
        skidMarkTimer = skidMarkTimer - dt;

        var friction = laneObj.getFrictionAt(ballObj.getPosX(), ballObj.getPosZ());
        ballObj.updateMotion(dt, friction, laneObj.getOilEndZ());
        Physics3DWorld.Step(physWorld, dt);
        updateTriggerZones();
        pinMgr.updateKnockdowns(dt);
        handlePinImpacts();

        if (friction > config.OIL_FRICTION_BLEND && Abs(ballObj.getSpin()) > 0.16 && skidMarkTimer <= 0.0) {
            particleMgr.spawnSkidMark(ballObj.getPosX(), ballObj.getPosZ());
            skidMarkTimer = 0.16;
        }

        particleMgr.updateLaneDust(ballObj.getPosX(), ballObj.getPosZ());
        camCtrl.updateFollow(ballObj.getPosX(), ballObj.getPosZ(), dt);

        if (ballObj.hasPastPins() || ballObj.isSlow() || ballObj.getPosZ() > config.GUTTER_EXIT_Z) {
            particleMgr.stopLaneDust();
            accumulator = 0.0;
            settleTimer = config.SETTLE_TIME;
            gameState = config.STATE_SETTLING;
            camCtrl.setOverheadMode();
        }
    }

    hide func updateSettlingStep(dt: Float) {
        impactCooldown = impactCooldown - dt;
        Physics3DWorld.Step(physWorld, dt);
        pinMgr.updateKnockdowns(dt);
        handlePinImpacts();

        settleTimer = settleTimer - dt;
        if (pinMgr.allSettled() && settleTimer < config.SETTLE_TIME - 0.4) {
            settleTimer = 0.0;
        }

        if (settleTimer <= 0.0) {
            accumulator = 0.0;
            gameState = config.STATE_SCORING;
        }
    }

    hide func updateTriggerZones() {
        if (ballObj.thrown() == false) { return; }

        var pos = ballObj.getPosition();
        var px = Vec3.get_X(pos);
        var py = Vec3.get_Y(pos);
        var pz = Vec3.get_Z(pos);
        var laneHalf = config.LANE_WIDTH / 2.0;
        var overhangEdge = laneHalf + config.GUTTER_DETECT_OVERHANG;
        var inLeftGutter = false;
        var inRightGutter = false;
        if (pz > config.GUTTER_DETECT_Z) {
            if (px < -overhangEdge) { inLeftGutter = true; }
            if (px > overhangEdge) { inRightGutter = true; }
            if (py < config.BALL_RADIUS * 0.58) {
                if (px < -(laneHalf - config.BALL_RADIUS * 0.08)) { inLeftGutter = true; }
                if (px > laneHalf - config.BALL_RADIUS * 0.08) { inRightGutter = true; }
            }
        }
        var inGutter = inLeftGutter || inRightGutter || py < config.GUTTER_Y;
        if (inGutter && gutterLatched == false) {
            gutterLatched = true;
            var gutterSide = 1;
            if (inLeftGutter || px < 0.0) {
                gutterSide = -1;
            }
            ballObj.markGutter(gutterSide);
            particleMgr.stopLaneDust();
            particleMgr.spawnGutterSplash(ballObj.getPosX(), ballObj.getPosZ());
            playSpatialSound("gutter", pos, 14.0, 90);
            hudObj.showMessage("Gutter ball", config.HUD_COLOR_GRAY, config.MSG_DURATION_SHORT);
        }

        if (Abs(px) < 1.25 && pz > config.PIN_Z_OFFSET - 0.8 && pz < config.PIN_Z_OFFSET + 1.8) {
            render.flashPinLight(1.8);
            lightFlashTimer = 0.15;
        }
    }

    hide func handlePinImpacts() {
        if (impactCooldown > 0.0) { return; }

        var collisionCount = Physics3DWorld.get_CollisionCount(physWorld);
        var bestDepth = 0.0;
        var bestPos = new Vec3(0.0, 0.0, 0.0);
        var ballPinImpact = false;

        for (var ci: Integer = 0; ci < collisionCount; ci = ci + 1) {
            var depth = Physics3DWorld.GetCollisionDepth(physWorld, ci);
            if (depth <= bestDepth) { continue; }

            var bodyA = Physics3DWorld.GetCollisionBodyA(physWorld, ci);
            var bodyB = Physics3DWorld.GetCollisionBodyB(physWorld, ci);
            var layerA = Physics3DBody.get_CollisionLayer(bodyA);
            var layerB = Physics3DBody.get_CollisionLayer(bodyB);
            var posA = Physics3DBody.get_Position(bodyA);
            var posB = Physics3DBody.get_Position(bodyB);

            if ((layerA == config.LAYER_BALL || layerA == config.LAYER_PINS) && isImpactBodyInPinDeck(posA)) {
                bestDepth = depth;
                bestPos = posA;
                ballPinImpact =
                    (layerA == config.LAYER_BALL && layerB == config.LAYER_PINS) ||
                    (layerA == config.LAYER_PINS && layerB == config.LAYER_BALL);
            }
            if ((layerB == config.LAYER_BALL || layerB == config.LAYER_PINS) &&
                isImpactBodyInPinDeck(posB) && depth > bestDepth) {
                bestDepth = depth;
                bestPos = posB;
                ballPinImpact =
                    (layerA == config.LAYER_BALL && layerB == config.LAYER_PINS) ||
                    (layerA == config.LAYER_PINS && layerB == config.LAYER_BALL);
            }
        }

        if (bestDepth > 0.007) {
            impactCooldown = config.IMPACT_COOLDOWN;
            if (ballPinImpact) {
                ballObj.dampForPinDeckImpact(bestDepth);
            }
            particleMgr.spawnCrashSparks(Vec3.get_X(bestPos), Vec3.get_Y(bestPos), Vec3.get_Z(bestPos));
            playSpatialSound("crash", bestPos, 16.0, 90);
            camCtrl.shake(config.SHAKE_PIN_INTENSITY, config.SHAKE_PIN_DURATION);
            render.flashPinLight(1.35 + bestDepth * 20.0);
            lightFlashTimer = 0.08;
        }
    }

    hide func updateScoring() {
        var current = getActiveScoreKeeper();
        var newlyKnocked = pinMgr.countNewlyKnocked();
        var scoredKnocked = newlyKnocked;
        if (ballObj.gutterBall()) {
            scoredKnocked = 0;
            if (newlyKnocked > 0) {
                pinMgr.restoreSavedPinState();
            }
        }
        var frameComplete = current.recordRoll(scoredKnocked);

        if (ballObj.gutterBall()) {
            celebMgr.onGutter();
        } else if (current.wasStrike()) {
            celebMgr.onStrike();
            particleMgr.spawnFireworks();
            camCtrl.shake(config.SHAKE_STRIKE_INTENSITY, config.SHAKE_STRIKE_DURATION);
            render.flashPinLight(3.0);
            lightFlashTimer = 0.40;
            playSound("strike");
            if (current.isGameOver() && current.getTotalScore() == config.MAX_SCORE) {
                celebMgr.onPerfectGame();
            }
        } else if (current.wasSpare()) {
            celebMgr.onSpare();
            playSound("spare");
        } else {
            celebMgr.onOpenFrame();
        }

        pinMgr.savePinState();
        pendingFrameAdvance = frameComplete;
        pendingPlayerSwitch = frameComplete && playerCount > 1;
        pendingResults = frameComplete && allPlayersFinished();
        scoreTimer = 0.75;
        cinematicStarted = false;

        Say(getPlayerLabel(activePlayer) + "  Frame " + toString(current.getFrame())
            + "  Total " + toString(current.getTotalScore()));

        pinMgr.startSweep();
        gameState = config.STATE_SWEEPING;
    }

    hide func updateSweeping(dt: Float) {
        if (pinMgr.updateSweep(dt)) {
            if (pendingFrameAdvance) {
                pinMgr.startFullReset();
                gameState = config.STATE_RESETTING;
            } else {
                pinMgr.prepareSecondRoll();
                gameState = config.STATE_CELEBRATING;
            }
        }
    }

    hide func updateResetting(dt: Float) {
        if (pinMgr.updateReset(dt)) {
            gameState = config.STATE_CELEBRATING;
        }
    }

    hide func updateCelebrating(dt: Float) {
        if (celebMgr.isActive()) {
            var ctype = celebMgr.getType();
            if (cinematicStarted == false &&
                (ctype == celebrations.STRIKE || ctype == celebrations.TURKEY || ctype == celebrations.PERFECT)) {
                camCtrl.startCinematic(0.0, config.PIN_Z_OFFSET);
                cinematicStarted = true;
            }
            if (cinematicStarted) {
                camCtrl.updateCinematic(dt);
            }
        }

        scoreTimer = scoreTimer - dt;
        if (scoreTimer <= 0.0 && celebMgr.isActive() == false) {
            render.resetPinLight();
            if (pendingResults && allPlayersFinished()) {
                openResultsScreen();
                return;
            }

            if (pendingPlayerSwitch) {
                advanceToNextPlayer();
            }
            prepareNextTurn();
        }
    }

    hide func prepareNextTurn() {
        ballObj.resetBall();
        aimX = 0.0;
        power = 0.0;
        spin = 0.0;
        charging = false;
        accumulator = 0.0;
        gutterLatched = false;
        cinematicStarted = false;
        pendingFrameAdvance = false;
        pendingPlayerSwitch = false;
        pendingResults = false;
        gameState = config.STATE_AIMING;
        camCtrl.setAimMode(0.0);

        var current = getActiveScoreKeeper();
        hudObj.showMessage(getPlayerLabel(activePlayer) + "  Frame " + toString(current.getFrame())
            + "  Roll " + toString(current.getRollInFrame()), config.HUD_COLOR_WHITE, config.MSG_DURATION_SHORT);
    }

    hide func advanceToNextPlayer() {
        if (playerCount <= 1) {
            activePlayer = 0;
            return;
        }

        if (activePlayer == 0) {
            if (scoreKeeperTwo.isGameOver() == false) {
                activePlayer = 1;
            }
        } else {
            if (scoreKeeperOne.isGameOver() == false) {
                activePlayer = 0;
            }
        }
    }

    hide func allPlayersFinished() -> Boolean {
        if (playerCount <= 1) {
            return scoreKeeperOne.isGameOver();
        }
        return scoreKeeperOne.isGameOver() && scoreKeeperTwo.isGameOver();
    }

    hide func openResultsScreen() {
        var p1 = scoreKeeperOne.getTotalScore();
        var p2 = scoreKeeperTwo.getTotalScore();
        var previousBest = menuObj.getBestScore();
        var resultsToast = "Final score: " + toString(p1);

        menuObj.recordFinishedMatch(p1, currentMode);
        resultsPlayerOne = p1;
        resultsPlayerTwo = p2;
        resultsWinner = -1;
        resultsNewHigh = p1 > previousBest;
        if (currentMode == config.MODE_VERSUS) {
            if (p1 > p2) { resultsWinner = 0; }
            if (p2 > p1) { resultsWinner = 1; }
            if (resultsWinner == 0) { resultsToast = "Player 1 wins"; }
            else if (resultsWinner == 1) { resultsToast = "Player 2 wins"; }
            else { resultsToast = "Tie game"; }
        } else if (resultsNewHigh) {
            resultsToast = "New high score";
        }

        screenState = config.SCREEN_RESULTS;
        camCtrl.setTitleMode();
        hudObj.showMessage(resultsToast, config.HUD_COLOR_GOLD, config.MSG_DURATION_RESULTS);
    }

    hide func cycleCameraMode() {
        if (gameState == config.STATE_AIMING) {
            if (camCtrl.getMode() == camera.MODE_OVERHEAD) {
                camCtrl.setAimMode(aimX);
                hudObj.showMessage("Approach camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            } else {
                camCtrl.setOverheadMode();
                hudObj.showMessage("Overhead preview", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            }
            return;
        }

        if (gameState == config.STATE_ROLLING || gameState == config.STATE_SETTLING || gameState == config.STATE_CELEBRATING) {
            if (camCtrl.getMode() == camera.MODE_OVERHEAD) {
                camCtrl.setFollowMode();
                hudObj.showMessage("Follow camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            } else {
                camCtrl.setOverheadMode();
                hudObj.showMessage("Overhead camera", config.HUD_COLOR_CYAN, config.MSG_DURATION_SHORT);
            }
        }
    }

    hide func isImpactBodyInPinDeck(pos: Vec3) -> Boolean {
        var z = Vec3.get_Z(pos);
        return z > config.PIN_Z_OFFSET - 1.0 && z < config.PIN_Z_OFFSET + 3.0;
    }

    hide func drawScene() {
        laneObj.draw(render.getCanvas());
        if (pinMgr.isSweeping()) {
            laneObj.drawSweepBar(render.getCanvas(), pinMgr.getSweepY());
        }
        pinMgr.draw(render.getCanvas());
        ballObj.draw(render.getCanvas());
        particleMgr.draw(render.getCanvas(), render.getCamera());
    }

    hide func drawOverlays() {
        var canvas = render.getCanvas();
        var cw = render.getWidth();
        var ch = render.getHeight();

        if (screenState == config.SCREEN_PLAYING) {
            celebMgr.draw(canvas, cw, ch);
            hudObj.draw(canvas, getActiveScoreKeeper(), power, charging, spin, aimX,
                ballObj.getBallType(), gameState, render.getFps(), playerCount, activePlayer,
                scoreKeeperOne.getTotalScore(), scoreKeeperTwo.getTotalScore(), laneObj.getOilPatternName());
        } else if (screenState == config.SCREEN_PAUSED) {
            hudObj.draw(canvas, getActiveScoreKeeper(), power, charging, spin, aimX,
                ballObj.getBallType(), gameState, render.getFps(), playerCount, activePlayer,
                scoreKeeperOne.getTotalScore(), scoreKeeperTwo.getTotalScore(), laneObj.getOilPatternName());
            menuObj.drawPause(canvas, cw, ch);
        } else if (screenState == config.SCREEN_OPTIONS) {
            menuObj.drawOptions(canvas, cw, ch);
        } else if (screenState == config.SCREEN_RESULTS) {
            var headline = "Game Complete";
            var subtitle = "Final Score: " + toString(resultsPlayerOne);
            var detail = "Best score: " + toString(menuObj.getBestScore());

            if (currentMode == config.MODE_VERSUS) {
                headline = "Match Complete";
                if (resultsWinner == 0) {
                    subtitle = "Player 1 wins";
                } else if (resultsWinner == 1) {
                    subtitle = "Player 2 wins";
                } else {
                    subtitle = "Tie game";
                }
                detail = "P1 " + toString(resultsPlayerOne) + "  |  P2 " + toString(resultsPlayerTwo);
            } else if (resultsNewHigh) {
                detail = "New high score";
            }

            menuObj.drawResults(canvas, cw, ch, headline, subtitle, detail);
        } else {
            menuObj.drawTitle(canvas, cw, ch);
        }
    }

    hide func getActiveScoreKeeper() -> ScoreKeeper {
        if (activePlayer == 1) { return scoreKeeperTwo; }
        return scoreKeeperOne;
    }

    hide func getPlayerLabel(index: Integer) -> String {
        if (playerCount <= 1) { return "Player"; }
        if (index == 1) { return "Player 2"; }
        return "Player 1";
    }
}
