// forest.zia - Imported maple forest placement and materials.
module forest;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Graphics3D.AssetDiagnostics3D as AssetDiagnostics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./terrain";
bind "./mathutil";

class ShowcaseForest {
    hide List[Material3D] treeMats;
    hide Material3D barkMat;
    hide List[Float] beaconXs;
    hide List[Float] beaconZs;
    hide List[Float] treeXs;
    hide List[Float] treeZs;
    hide Mesh3D unitCylinder;
    hide Mesh3D unitSphere;
    hide InstanceBatch3D trunkBatch;
    hide List[InstanceBatch3D] lobeBatches;

    expose func spawn(world: World3D, land: Terrain3D, bx: List[Float], bz: List[Float]) {
        beaconXs = bx;
        beaconZs = bz;
        treeXs = [];
        treeZs = [];
        var model = loadTreeModel();
        buildFoliageMaterials();
        buildInstanceBatches();

        if (treeBad(model)) {
            var fallbackPlanted = plantHomeGrove(world, land, null);
            fallbackPlanted = fallbackPlanted + plantHillForest(world, land, null);
            Terminal.Say("Forest: planted " + toString(fallbackPlanted) + " procedural maples.");
            return;
        }

        var planted = plantHomeGrove(world, land, model);
        planted = planted + plantHillForest(world, land, model);
        Terminal.Say("Forest: planted " + toString(planted) + " maples.");
    }

    hide func treeBad(m: SceneAsset) -> Boolean {
        if (m == null) { return true; }
        return SceneAsset.get_MeshCount(m) <= 0;
    }

    hide func loadTreeModel() -> SceneAsset {
        var model = SceneAsset.LoadAsset(config.TREE_MODEL_PATH);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("asset", config.TREE_MODEL_PATH, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH);

        model = SceneAsset.Load(config.TREE_MODEL_PATH);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH);

        model = SceneAsset.Load(config.TREE_MODEL_PATH_ALT);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH_ALT, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH_ALT);

        model = SceneAsset.Load(config.TREE_MODEL_PATH_FROM_BIN);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH_FROM_BIN, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH_FROM_BIN);
        return null;
    }

    hide func reportTreeLoadSuccess(kind: String, path: String, model: SceneAsset) {
        Terminal.Say("Forest: loaded tree " + kind + " '" + path + "'"
            + " meshes=" + toString(SceneAsset.get_MeshCount(model))
            + " materials=" + toString(SceneAsset.get_MaterialCount(model))
            + " nodes=" + toString(SceneAsset.get_NodeCount(model))
            + " scenes=" + toString(SceneAsset.get_SceneCount(model)) + ".");
    }

    hide func reportTreeLoadFailure(path: String) {
        var msg = AssetDiagnostics3D.get_LastLoadError();
        if (msg == "") {
            Terminal.Say("Forest: tree model path unavailable: " + path);
        } else {
            Terminal.Say("Forest: tree model path unavailable: " + path + " (" + msg + ")");
        }
    }

    hide func plantHomeGrove(world: World3D, land: Terrain3D, model: SceneAsset) -> Integer {
        var cx = terrain.terrainWorldMaxX() * 0.5;
        var cz = terrain.terrainWorldMaxZ() * 0.5;
        var planted = 0;

        var i = 0;
        while (i < config.GROVE_COUNT) {
            var ang = (i + 0.0) / (config.GROVE_COUNT + 0.0) * 6.2831853 + mathutil.hash01(i, 23);
            var radius = config.GROVE_RADIUS_MIN
                + mathutil.hash01(i, 31) * (config.GROVE_RADIUS_MAX - config.GROVE_RADIUS_MIN);
            var wx = cx + Sin(ang) * radius;
            var wz = cz + Cos(ang) * radius;
            if (wx > config.FOREST_MARGIN && wx < terrain.terrainWorldMaxX() - config.FOREST_MARGIN
                    && wz > config.FOREST_MARGIN && wz < terrain.terrainWorldMaxZ() - config.FOREST_MARGIN) {
                var gy = terrain.sampleGround(land, wx, wz);
                if (gy > config.WATER_HEIGHT + 0.4) {
                    var s = config.FOREST_SCALE_MIN
                        + mathutil.hash01(i, 7) * (config.FOREST_SCALE_MAX - config.FOREST_SCALE_MIN);
                    plantTreeOrFallback(world, model, wx, wz, gy, s, mathutil.hash01(i, 13) * 360.0);
                    planted = planted + 1;
                }
            }
            i = i + 1;
        }

        return planted;
    }

    hide func plantHillForest(world: World3D, land: Terrain3D, model: SceneAsset) -> Integer {
        var maxX = terrain.terrainWorldMaxX();
        var maxZ = terrain.terrainWorldMaxZ();
        var cell = config.FOREST_CELL;
        var planted = 0;
        var seed = 0;

        var gz = config.FOREST_MARGIN;
        while (gz < maxZ - config.FOREST_MARGIN && planted < config.FOREST_MAX) {
            var gx = config.FOREST_MARGIN;
            while (gx < maxX - config.FOREST_MARGIN && planted < config.FOREST_MAX) {
                seed = seed + 1;
                if (mathutil.hash01(seed, 17) < config.FOREST_DENSITY) {
                    var wx = gx + (mathutil.hash01(seed, 3) - 0.5) * cell * 1.4;
                    var wz = gz + (mathutil.hash01(seed, 9) - 0.5) * cell * 1.4;
                    if (canPlantTree(land, wx, wz, maxX, maxZ)) {
                        var s = config.FOREST_SCALE_MIN
                            + mathutil.hash01(seed, 5) * (config.FOREST_SCALE_MAX - config.FOREST_SCALE_MIN);
                        plantTreeOrFallback(world, model, wx, wz, terrain.sampleGround(land, wx, wz), s, mathutil.hash01(seed, 11) * 360.0);
                        planted = planted + 1;
                    }
                }
                gx = gx + cell;
            }
            gz = gz + cell;
        }

        return planted;
    }

    hide func canPlantTree(land: Terrain3D, wx: Float, wz: Float, maxX: Float, maxZ: Float) -> Boolean {
        if (wx < config.FOREST_MARGIN || wx > maxX - config.FOREST_MARGIN) { return false; }
        if (wz < config.FOREST_MARGIN || wz > maxZ - config.FOREST_MARGIN) { return false; }
        if (terrain.sampleGround(land, wx, wz) < config.FOREST_MIN_GROUND) { return false; }
        var normal = Terrain3D.GetNormalAt(land, wx, wz);
        if (Vec3.get_Y(normal) < config.FOREST_MIN_NORMALY) { return false; }
        if (notNearBeacon(wx, wz) == false) { return false; }
        if (notNearPlayerStart(wx, wz) == false) { return false; }
        return true;
    }

    // Material accessors so probes/tests can validate procedural-tree material
    // quality now that trunks/lobes render from instance batches, not entities.
    expose func getBarkMat() -> Material3D { return barkMat; }
    expose func getCanopyMat() -> Material3D { return treeMats.get(0); }
    expose func getTreeCount() -> Integer { return treeXs.count(); }

    hide func plantTreeOrFallback(world: World3D, model: SceneAsset, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        treeXs.add(x);
        treeZs.add(z);
        spawnTrunkCollider(world, x, y, z);
        if (treeBad(model)) {
            plantProceduralTree(world, x, z, y, scale, yawDeg);
        } else {
            plantTree(world, model, x, z, y, scale, yawDeg);
        }
    }

    // Invisible static capsule around the trunk so the character controller
    // slides around trees (replaces the old manual resolveTreeCollision push-out).
    // Centered above the ground so it covers the lower trunk the player can reach.
    hide func spawnTrunkCollider(world: World3D, x: Float, y: Float, z: Float) {
        var col: Entity3D = Entity3D.New();
        col.Name = "tree_trunk_collider";
        col.Layer = Layers.get_World();
        col.SetPosition(x, y + 3.0, z);
        col.AttachBody(BodyDef.Capsule(config.TREE_COLLIDE_RADIUS, 6.0, 0.0));
        world.Spawn(col);
    }

    hide func plantTree(world: World3D, model: SceneAsset, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        var node = SceneAsset.Instantiate(model);
        var ent = Entity3D.FromNode(node);
        ent.Name = "maple";
        ent.Layer = Layers.get_World();
        applyTreeMaterials(ent, treeMats.get(pickFoliage(x, z)));
        ent.SetScaleXYZ(scale, scale, scale);
        ent.SetRotationEuler(yawDeg, 0.0, 0.0);
        ent.SetPosition(x, y, z);
        // Screen-size-driven LOD: distant maples simplify automatically.
        ent.Node.SetAutoLOD(true, config.FOREST_LOD_ERROR_PX);
        world.Spawn(ent);
    }

    hide func plantProceduralTree(world: World3D, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        var height = scale * 620.0;
        var trunkHeight = height * 0.56;
        var trunkRadius = height * 0.038;
        var canopyRadius = height * 0.22;
        var foliageIdx = pickFoliage(x, z);
        var canopyMat = treeMats.get(foliageIdx);

        // Trunk: instanced. A cylinder is symmetric about its Y axis, so the old
        // SetRotationEuler(0, yaw, 0) was a visual no-op and is dropped here.
        trunkBatch.Add(Mat4.Mul(
            Mat4.Translate(x, y + trunkHeight * 0.5, z),
            Mat4.Scale(trunkRadius, trunkHeight, trunkRadius)));

        plantBranch(world, x, z, y + trunkHeight * 0.58, yawDeg + 18.0, trunkRadius * 0.44, trunkHeight * 0.48, 28.0);
        plantBranch(world, x, z, y + trunkHeight * 0.66, yawDeg + 142.0, trunkRadius * 0.36, trunkHeight * 0.40, -32.0);
        plantBranch(world, x, z, y + trunkHeight * 0.78, yawDeg + 258.0, trunkRadius * 0.30, trunkHeight * 0.34, 24.0);
        plantBranch(world, x, z, y + trunkHeight * 0.88, yawDeg + 314.0, trunkRadius * 0.22, trunkHeight * 0.26, 36.0);

        plantCanopyLobe(foliageIdx, x, z, y, yawDeg, canopyRadius, 0.0, 0.0, 1.28, 0.86, 1.18, 0.52);
        plantCanopyLobe(foliageIdx, x, z, y, yawDeg + 28.0, canopyRadius * 0.78, -0.34, 0.18, 1.08, 0.72, 0.94, 0.38);
        plantCanopyLobe(foliageIdx, x, z, y, yawDeg + 146.0, canopyRadius * 0.72, 0.36, -0.22, 0.96, 0.76, 1.06, 0.34);
        plantCanopyLobe(foliageIdx, x, z, y, yawDeg + 244.0, canopyRadius * 0.66, 0.10, 0.42, 1.02, 0.64, 0.88, 0.62);
        plantCanopyLobe(foliageIdx, x, z, y, yawDeg + 8.0, canopyRadius * 0.56, 0.0, 0.02, 0.78, 0.86, 0.72, 0.92);
        plantLeafPlate(world, x, z, y, yawDeg + 18.0, canopyRadius, canopyMat, 0.0, 0.0, 1.08);
        plantLeafPlate(world, x, z, y, yawDeg + 72.0, canopyRadius * 0.86, canopyMat, -0.26, 0.22, 0.94);
        plantLeafPlate(world, x, z, y, yawDeg + 136.0, canopyRadius * 0.78, canopyMat, 0.24, -0.28, 0.88);
        plantLeafPlate(world, x, z, y, yawDeg + 248.0, canopyRadius * 0.72, canopyMat, 0.12, 0.30, 0.82);
    }

    hide func plantBranch(world: World3D, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, length: Float, pitchDeg: Float) {
        var branch: Entity3D = Prefab.Cylinder(radius, length, 12, barkMat);
        branch.Name = "procedural_maple_branch";
        branch.Layer = Layers.get_World();
        branch.SetRotationEuler(pitchDeg, yawDeg, 38.0);
        branch.SetPosition(x + Sin(yawDeg * 0.0174533) * length * 0.18, y + length * 0.18, z + Cos(yawDeg * 0.0174533) * length * 0.18);
        world.Spawn(branch);
    }

    // Canopy lobe: instanced ellipsoid. The world position already bakes in the
    // yaw (via the sin/cos offset), so RotateY only orients the squash axes,
    // matching the old SetRotationEuler(0, yaw, 0) on the scaled sphere.
    hide func plantCanopyLobe(foliageIdx: Integer, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, ox: Float, oz: Float, sx: Float, sy: Float, sz: Float, lift: Float) {
        var wx = x + Sin(yawDeg * 0.0174533) * ox * radius + Cos(yawDeg * 0.0174533) * oz * radius;
        var wz = z + Cos(yawDeg * 0.0174533) * ox * radius - Sin(yawDeg * 0.0174533) * oz * radius;
        var xform = Mat4.Mul(
            Mat4.Mul(
                Mat4.Translate(wx, y + scaleCanopyBase(radius) + lift * radius, wz),
                Mat4.RotateY(yawDeg * 0.0174533)),
            Mat4.Scale(radius * sx, radius * sy, radius * sz));
        lobeBatches.get(foliageIdx).Add(xform);
    }

    hide func plantLeafPlate(world: World3D, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, mat: Material3D, ox: Float, oz: Float, lift: Float) {
        var plate: Entity3D = Prefab.BoxXYZ(radius * 1.72, radius * 0.08, radius * 1.18, mat);
        var wx = x + Sin(yawDeg * 0.0174533) * ox * radius + Cos(yawDeg * 0.0174533) * oz * radius;
        var wz = z + Cos(yawDeg * 0.0174533) * ox * radius - Sin(yawDeg * 0.0174533) * oz * radius;
        plate.Name = "procedural_maple_leaf_plate";
        plate.Layer = Layers.get_World();
        plate.SetRotationEuler(6.0, yawDeg, 11.0);
        plate.SetPosition(wx, y + scaleCanopyBase(radius) + lift * radius, wz);
        world.Spawn(plate);
    }

    hide func scaleCanopyBase(radius: Float) -> Float {
        return radius * 2.45;
    }

    // Shared unit meshes + one batch per foliage material. The procedural-tree
    // trunks and canopy lobes are drawn from these batches (hardware instancing)
    // instead of spawning a scene entity per part.
    hide func buildInstanceBatches() {
        unitCylinder = Mesh3D.NewCylinder(1.0, 1.0, 18);
        unitSphere = Mesh3D.NewSphere(1.0, 22);
        trunkBatch = InstanceBatch3D.New(unitCylinder, barkMat);
        lobeBatches = [];
        for i in 0..treeMats.count() {
            lobeBatches.add(InstanceBatch3D.New(unitSphere, treeMats.get(i)));
        }
    }

    // Draw the instanced procedural-tree parts (trunks + canopy lobes): a few
    // DrawInstanced calls in place of hundreds of per-part scene draws. A no-op
    // when the FBX maples loaded and the procedural path went unused.
    expose func drawInstanced(canvas: Canvas3D) {
        if (trunkBatch == null) { return; }
        Canvas3D.DrawInstanced(canvas, trunkBatch);
        for i in 0..lobeBatches.count() {
            Canvas3D.DrawInstanced(canvas, lobeBatches.get(i));
        }
    }

    hide func buildFoliageMaterials() {
        treeMats = [];
        treeMats.add(makeFoliage(0.28, 0.58, 0.20));
        treeMats.add(makeFoliage(0.74, 0.56, 0.18));
        treeMats.add(makeFoliage(0.68, 0.32, 0.14));
        barkMat = Material3D.NewPBR(0.38, 0.23, 0.12);
        Material3D.SetAlbedoMap(barkMat, createBarkAlbedo(64));
        Material3D.SetNormalMap(barkMat, createBarkNormal(64));
        barkMat.Roughness = 0.88;
        barkMat.Metallic = 0.0;
        barkMat.NormalScale = 0.48;
        Material3D.SetEmissiveColor(barkMat, 0.026, 0.014, 0.006);
    }

    hide func applyTreeMaterials(ent: Entity3D, canopyMat: Material3D) {
        var node = ent.Node;
        var meshCount = countMeshNodes(node);
        var assigned = applyTreeMaterialsRecursive(node, canopyMat, meshCount);
        if (assigned == 0) {
            ent.SetMaterialRecursive(canopyMat);
        }
    }

    hide func applyTreeMaterialsRecursive(node: SceneNode, canopyMat: Material3D, meshCount: Integer) -> Integer {
        if (node == null) { return 0; }
        var assigned = 0;
        if (node.Mesh != null) {
            if (isBarkNode(node, meshCount)) {
                node.Material = barkMat;
                assigned = assigned + 1;
            } else {
                node.Material = canopyMat;
                assigned = assigned + 1;
            }
        }
        var count = node.ChildCount;
        for i in 0..count {
            assigned = assigned + applyTreeMaterialsRecursive(SceneNode.GetChild(node, i), canopyMat, meshCount);
        }
        return assigned;
    }

    hide func countMeshNodes(node: SceneNode) -> Integer {
        if (node == null) { return 0; }
        var total = 0;
        if (node.Mesh != null) {
            total = 1;
        }
        var count = node.ChildCount;
        for i in 0..count {
            total = total + countMeshNodes(SceneNode.GetChild(node, i));
        }
        return total;
    }

    hide func isBarkNode(node: SceneNode, meshCount: Integer) -> Boolean {
        var name = node.Name;
        if (name == "mesh_0_material_0") { return true; }
        if (name == "mesh_1_material_1") { return false; }
        if (meshCount <= 1) { return false; }
        return isBarkMesh(node);
    }

    hide func isBarkMesh(node: SceneNode) -> Boolean {
        var amin = node.BoundsMin;
        var amax = node.BoundsMax;
        var dx = Vec3.get_X(amax) - Vec3.get_X(amin);
        var dy = Vec3.get_Y(amax) - Vec3.get_Y(amin);
        var dz = Vec3.get_Z(amax) - Vec3.get_Z(amin);
        var minXZ = minf(dx, dz);
        var maxXZ = mathutil.maxf(dx, dz);

        if (maxXZ <= 0.0001) { return false; }
        if (dy > maxXZ * 1.40) { return true; }
        if (minXZ > 0.0001 && dy > minXZ * 1.18 && dy < maxXZ * 1.75) { return true; }
        return false;
    }

    hide func minf(a: Float, b: Float) -> Float {
        if (a < b) { return a; }
        return b;
    }

    hide func absInt(value: Integer) -> Integer {
        if (value < 0) { return 0 - value; }
        return value;
    }

    hide func makeFoliage(r: Float, g: Float, b: Float) -> Material3D {
        var m = Material3D.NewPBR(r, g, b);
        Material3D.SetAlbedoMap(m, createLeafAlbedo(64, r, g, b));
        Material3D.SetNormalMap(m, createLeafNormal(64));
        m.Roughness = 0.94;
        m.Metallic = 0.0;
        m.NormalScale = 0.36;
        Material3D.SetEmissiveColor(m, r * 0.075, g * 0.105, b * 0.045);
        m.DoubleSided = true;
        return m;
    }

    hide func createLeafAlbedo(size: Integer, r: Float, g: Float, b: Float) -> Pixels {
        var tex = Pixels.New(size, size);
        var baseR = Convert.NumToInt(r * 255.0);
        var baseG = Convert.NumToInt(g * 255.0);
        var baseB = Convert.NumToInt(b * 255.0);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 17 + py * 29 + px * py * 3) % 44) - 22;
                var vein = 0;
                var major = absInt(((px + py * 2) % 19) - 9);
                var minor = absInt(((px * 2 - py + size * 2) % 23) - 11);
                if (major <= 1) { vein = 26; }
                if (minor == 0) { vein = vein + 14; }
                var shadow = ((px / 8 + py / 8) % 2) * 5;
                tex.Set(px, py, mathutil.packPixel(
                    mathutil.clampByte(baseR + 18 + noise / 4 + vein / 4 - shadow),
                    mathutil.clampByte(baseG + 20 + noise / 2 + vein - shadow),
                    mathutil.clampByte(baseB + 10 + noise / 5 + vein / 5 - shadow / 2),
                    255));
            }
        }

        return tex;
    }

    hide func createLeafNormal(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var major = ((px + py * 2) % 19) - 9;
                var minor = ((px * 2 - py + size * 2) % 23) - 11;
                var nx = mathutil.clampByte(128 + major * 3);
                var nz = mathutil.clampByte(128 + minor * 2);
                var ny = 244;
                if (absInt(major) <= 1 || absInt(minor) == 0) { ny = 252; }
                tex.Set(px, py, mathutil.packPixel(nx, nz, ny, 255));
            }
        }

        return tex;
    }

    hide func createBarkAlbedo(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var groove = absInt(((px + py / 3) % 14) - 7);
                var noise = ((px * 11 + py * 23 + px * py) % 34) - 17;
                var dark = 0;
                if (groove <= 1) { dark = 26; }
                tex.Set(px, py, mathutil.packPixel(
                    mathutil.clampByte(116 + noise - dark),
                    mathutil.clampByte(72 + noise / 2 - dark / 2),
                    mathutil.clampByte(38 + noise / 4 - dark / 3),
                    255));
            }
        }

        return tex;
    }

    hide func createBarkNormal(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var groove = ((px + py / 3) % 14) - 7;
                var nx = mathutil.clampByte(128 + groove * 8);
                var nz = mathutil.clampByte(128 + (((px * 3 + py) % 9) - 4) * 2);
                var ny = 232;
                if (absInt(groove) <= 1) { ny = 214; }
                tex.Set(px, py, mathutil.packPixel(nx, nz, ny, 255));
            }
        }

        return tex;
    }

    hide func pickFoliage(x: Float, z: Float) -> Integer {
        var h = mathutil.hash01(Convert.NumToInt(x * 7.0), Convert.NumToInt(z * 7.0));
        if (h < 0.55) { return 0; }
        if (h < 0.82) { return 1; }
        return 2;
    }

    hide func notNearBeacon(x: Float, z: Float) -> Boolean {
        for i in 0..beaconXs.count() {
            var dx = x - beaconXs.get(i);
            var dz = z - beaconZs.get(i);
            if (dx * dx + dz * dz < config.FOREST_BEACON_CLEAR) { return false; }
        }
        return true;
    }

    hide func notNearPlayerStart(x: Float, z: Float) -> Boolean {
        var dx = x - terrain.terrainWorldMaxX() * 0.5;
        var dz = z - terrain.terrainWorldMaxZ() * 0.5;
        return dx * dx + dz * dz > config.FOREST_PLAYER_CLEAR;
    }
}
