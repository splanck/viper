// forest.zia - Imported maple forest placement and materials.
module forest;

bind Viper.Game3D;
bind Viper.Graphics3D;
bind Viper.Graphics3D.Assets3D as Assets3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind "./config";
bind "./terrain";

class ShowcaseForest {
    hide List[Material3D] treeMats;
    hide Material3D barkMat;
    hide List[Float] beaconXs;
    hide List[Float] beaconZs;

    expose func spawn(world: World3D, land: Terrain3D, bx: List[Float], bz: List[Float]) {
        beaconXs = bx;
        beaconZs = bz;
        var model = loadTreeModel();
        buildFoliageMaterials();

        if (treeBad(model)) {
            var fallbackPlanted = plantHomeGrove(world, land, null);
            fallbackPlanted = fallbackPlanted + plantHillForest(world, land, null);
            Terminal.Say("Forest: planted " + toString(fallbackPlanted) + " procedural maples.");
            return;
        }

        var planted = plantHomeGrove(world, land, model);
        planted = planted + plantHillForest(world, land, model);
        Terminal.Say("Forest: planted " + toString(planted) + " maples.");
    }

    hide func treeBad(m: Model3D) -> Boolean {
        if (m == null) { return true; }
        return Model3D.get_MeshCount(m) <= 0;
    }

    hide func loadTreeModel() -> Model3D {
        var model = Model3D.LoadAsset(config.TREE_MODEL_PATH);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("asset", config.TREE_MODEL_PATH, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH);

        model = Model3D.Load(config.TREE_MODEL_PATH);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH);

        model = Model3D.Load(config.TREE_MODEL_PATH_ALT);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH_ALT, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH_ALT);

        model = Model3D.Load(config.TREE_MODEL_PATH_FROM_BIN);
        if (not treeBad(model)) {
            reportTreeLoadSuccess("model", config.TREE_MODEL_PATH_FROM_BIN, model);
            return model;
        }
        reportTreeLoadFailure(config.TREE_MODEL_PATH_FROM_BIN);
        return null;
    }

    hide func reportTreeLoadSuccess(kind: String, path: String, model: Model3D) {
        Terminal.Say("Forest: loaded tree " + kind + " '" + path + "'"
            + " meshes=" + toString(Model3D.get_MeshCount(model))
            + " materials=" + toString(Model3D.get_MaterialCount(model))
            + " nodes=" + toString(Model3D.get_NodeCount(model))
            + " scenes=" + toString(Model3D.get_SceneCount(model)) + ".");
    }

    hide func reportTreeLoadFailure(path: String) {
        var msg = Assets3D.get_LastLoadError();
        if (msg == "") {
            Terminal.Say("Forest: tree model path unavailable: " + path);
        } else {
            Terminal.Say("Forest: tree model path unavailable: " + path + " (" + msg + ")");
        }
    }

    hide func plantHomeGrove(world: World3D, land: Terrain3D, model: Model3D) -> Integer {
        var cx = terrain.terrainWorldMaxX() * 0.5;
        var cz = terrain.terrainWorldMaxZ() * 0.5;
        var planted = 0;

        var i = 0;
        while (i < config.GROVE_COUNT) {
            var ang = (i + 0.0) / (config.GROVE_COUNT + 0.0) * 6.2831853 + terrain.hash01(i, 23);
            var radius = config.GROVE_RADIUS_MIN
                + terrain.hash01(i, 31) * (config.GROVE_RADIUS_MAX - config.GROVE_RADIUS_MIN);
            var wx = cx + Sin(ang) * radius;
            var wz = cz + Cos(ang) * radius;
            if (wx > config.FOREST_MARGIN && wx < terrain.terrainWorldMaxX() - config.FOREST_MARGIN
                    && wz > config.FOREST_MARGIN && wz < terrain.terrainWorldMaxZ() - config.FOREST_MARGIN) {
                var gy = terrain.sampleGround(land, wx, wz);
                if (gy > config.WATER_HEIGHT + 0.4) {
                    var s = config.FOREST_SCALE_MIN
                        + terrain.hash01(i, 7) * (config.FOREST_SCALE_MAX - config.FOREST_SCALE_MIN);
                    plantTreeOrFallback(world, model, wx, wz, gy, s, terrain.hash01(i, 13) * 360.0);
                    planted = planted + 1;
                }
            }
            i = i + 1;
        }

        return planted;
    }

    hide func plantHillForest(world: World3D, land: Terrain3D, model: Model3D) -> Integer {
        var maxX = terrain.terrainWorldMaxX();
        var maxZ = terrain.terrainWorldMaxZ();
        var cell = config.FOREST_CELL;
        var planted = 0;
        var seed = 0;

        var gz = config.FOREST_MARGIN;
        while (gz < maxZ - config.FOREST_MARGIN && planted < config.FOREST_MAX) {
            var gx = config.FOREST_MARGIN;
            while (gx < maxX - config.FOREST_MARGIN && planted < config.FOREST_MAX) {
                seed = seed + 1;
                if (terrain.hash01(seed, 17) < config.FOREST_DENSITY) {
                    var wx = gx + (terrain.hash01(seed, 3) - 0.5) * cell * 1.4;
                    var wz = gz + (terrain.hash01(seed, 9) - 0.5) * cell * 1.4;
                    if (canPlantTree(land, wx, wz, maxX, maxZ)) {
                        var s = config.FOREST_SCALE_MIN
                            + terrain.hash01(seed, 5) * (config.FOREST_SCALE_MAX - config.FOREST_SCALE_MIN);
                        plantTreeOrFallback(world, model, wx, wz, terrain.sampleGround(land, wx, wz), s, terrain.hash01(seed, 11) * 360.0);
                        planted = planted + 1;
                    }
                }
                gx = gx + cell;
            }
            gz = gz + cell;
        }

        return planted;
    }

    hide func canPlantTree(land: Terrain3D, wx: Float, wz: Float, maxX: Float, maxZ: Float) -> Boolean {
        if (wx < config.FOREST_MARGIN || wx > maxX - config.FOREST_MARGIN) { return false; }
        if (wz < config.FOREST_MARGIN || wz > maxZ - config.FOREST_MARGIN) { return false; }
        if (terrain.sampleGround(land, wx, wz) < config.FOREST_MIN_GROUND) { return false; }
        var normal = Terrain3D.GetNormalAt(land, wx, wz);
        if (Vec3.get_Y(normal) < config.FOREST_MIN_NORMALY) { return false; }
        if (notNearBeacon(wx, wz) == false) { return false; }
        if (notNearPlayerStart(wx, wz) == false) { return false; }
        return true;
    }

    hide func plantTreeOrFallback(world: World3D, model: Model3D, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        if (treeBad(model)) {
            plantProceduralTree(world, x, z, y, scale, yawDeg);
        } else {
            plantTree(world, model, x, z, y, scale, yawDeg);
        }
    }

    hide func plantTree(world: World3D, model: Model3D, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        var node = Model3D.Instantiate(model);
        var ent = Entity3D.FromNode(node);
        Entity3D.setName(ent, "maple");
        Entity3D.setLayer(ent, Layers.get_World());
        applyTreeMaterials(ent, treeMats.get(pickFoliage(x, z)));
        Entity3D.setScaleXYZ(ent, scale, scale, scale);
        Entity3D.setRotationEuler(ent, yawDeg, 0.0, 0.0);
        Entity3D.setPosition(ent, x, y, z);
        World3D.spawn(world, ent);
    }

    hide func plantProceduralTree(world: World3D, x: Float, z: Float, y: Float, scale: Float, yawDeg: Float) {
        var height = scale * 620.0;
        var trunkHeight = height * 0.56;
        var trunkRadius = height * 0.038;
        var canopyRadius = height * 0.22;
        var canopyMat = treeMats.get(pickFoliage(x, z));

        var trunk = Prefab.Cylinder(trunkRadius, trunkHeight, 18, barkMat);
        Entity3D.setName(trunk, "procedural_maple_trunk");
        Entity3D.setLayer(trunk, Layers.get_World());
        Entity3D.setRotationEuler(trunk, 0.0, yawDeg, 0.0);
        Entity3D.setPosition(trunk, x, y + trunkHeight * 0.5, z);
        World3D.spawn(world, trunk);

        plantBranch(world, x, z, y + trunkHeight * 0.58, yawDeg + 18.0, trunkRadius * 0.44, trunkHeight * 0.48, 28.0);
        plantBranch(world, x, z, y + trunkHeight * 0.66, yawDeg + 142.0, trunkRadius * 0.36, trunkHeight * 0.40, -32.0);
        plantBranch(world, x, z, y + trunkHeight * 0.78, yawDeg + 258.0, trunkRadius * 0.30, trunkHeight * 0.34, 24.0);
        plantBranch(world, x, z, y + trunkHeight * 0.88, yawDeg + 314.0, trunkRadius * 0.22, trunkHeight * 0.26, 36.0);

        plantCanopyLobe(world, x, z, y, yawDeg, canopyRadius, canopyMat, 0.0, 0.0, 1.28, 0.86, 1.18, 0.52);
        plantCanopyLobe(world, x, z, y, yawDeg + 28.0, canopyRadius * 0.78, canopyMat, -0.34, 0.18, 1.08, 0.72, 0.94, 0.38);
        plantCanopyLobe(world, x, z, y, yawDeg + 146.0, canopyRadius * 0.72, canopyMat, 0.36, -0.22, 0.96, 0.76, 1.06, 0.34);
        plantCanopyLobe(world, x, z, y, yawDeg + 244.0, canopyRadius * 0.66, canopyMat, 0.10, 0.42, 1.02, 0.64, 0.88, 0.62);
        plantCanopyLobe(world, x, z, y, yawDeg + 8.0, canopyRadius * 0.56, canopyMat, 0.0, 0.02, 0.78, 0.86, 0.72, 0.92);
        plantLeafPlate(world, x, z, y, yawDeg + 18.0, canopyRadius, canopyMat, 0.0, 0.0, 1.08);
        plantLeafPlate(world, x, z, y, yawDeg + 72.0, canopyRadius * 0.86, canopyMat, -0.26, 0.22, 0.94);
        plantLeafPlate(world, x, z, y, yawDeg + 136.0, canopyRadius * 0.78, canopyMat, 0.24, -0.28, 0.88);
        plantLeafPlate(world, x, z, y, yawDeg + 248.0, canopyRadius * 0.72, canopyMat, 0.12, 0.30, 0.82);
    }

    hide func plantBranch(world: World3D, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, length: Float, pitchDeg: Float) {
        var branch = Prefab.Cylinder(radius, length, 12, barkMat);
        Entity3D.setName(branch, "procedural_maple_branch");
        Entity3D.setLayer(branch, Layers.get_World());
        Entity3D.setRotationEuler(branch, pitchDeg, yawDeg, 38.0);
        Entity3D.setPosition(branch, x + Sin(yawDeg * 0.0174533) * length * 0.18, y + length * 0.18, z + Cos(yawDeg * 0.0174533) * length * 0.18);
        World3D.spawn(world, branch);
    }

    hide func plantCanopyLobe(world: World3D, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, mat: Material3D, ox: Float, oz: Float, sx: Float, sy: Float, sz: Float, lift: Float) {
        var crown = Prefab.Sphere(radius, 22, mat);
        var wx = x + Sin(yawDeg * 0.0174533) * ox * radius + Cos(yawDeg * 0.0174533) * oz * radius;
        var wz = z + Cos(yawDeg * 0.0174533) * ox * radius - Sin(yawDeg * 0.0174533) * oz * radius;
        Entity3D.setName(crown, "procedural_maple_crown");
        Entity3D.setLayer(crown, Layers.get_World());
        Entity3D.setScaleXYZ(crown, sx, sy, sz);
        Entity3D.setRotationEuler(crown, 0.0, yawDeg, 0.0);
        Entity3D.setPosition(crown, wx, y + scaleCanopyBase(radius) + lift * radius, wz);
        World3D.spawn(world, crown);
    }

    hide func plantLeafPlate(world: World3D, x: Float, z: Float, y: Float, yawDeg: Float, radius: Float, mat: Material3D, ox: Float, oz: Float, lift: Float) {
        var plate = Prefab.BoxXYZ(radius * 1.72, radius * 0.08, radius * 1.18, mat);
        var wx = x + Sin(yawDeg * 0.0174533) * ox * radius + Cos(yawDeg * 0.0174533) * oz * radius;
        var wz = z + Cos(yawDeg * 0.0174533) * ox * radius - Sin(yawDeg * 0.0174533) * oz * radius;
        Entity3D.setName(plate, "procedural_maple_leaf_plate");
        Entity3D.setLayer(plate, Layers.get_World());
        Entity3D.setRotationEuler(plate, 6.0, yawDeg, 11.0);
        Entity3D.setPosition(plate, wx, y + scaleCanopyBase(radius) + lift * radius, wz);
        World3D.spawn(world, plate);
    }

    hide func scaleCanopyBase(radius: Float) -> Float {
        return radius * 2.45;
    }

    hide func buildFoliageMaterials() {
        treeMats = [];
        treeMats.add(makeFoliage(0.20, 0.44, 0.18));
        treeMats.add(makeFoliage(0.74, 0.52, 0.16));
        treeMats.add(makeFoliage(0.66, 0.26, 0.12));
        barkMat = Materials.Rubber(0.30, 0.21, 0.13);
        Material3D.SetEmissiveColor(barkMat, 0.010, 0.007, 0.004);
    }

    hide func applyTreeMaterials(ent: Entity3D, canopyMat: Material3D) {
        var node = Entity3D.get_node(ent);
        var assigned = applyTreeMaterialsRecursive(node, canopyMat);
        if (assigned == 0) {
            Entity3D.setMaterialRecursive(ent, canopyMat);
        }
    }

    hide func applyTreeMaterialsRecursive(node: SceneNode3D, canopyMat: Material3D) -> Integer {
        if (node == null) { return 0; }
        var assigned = 0;
        if (SceneNode3D.get_Mesh(node) != null) {
            var amin = SceneNode3D.get_AABBMin(node);
            var amax = SceneNode3D.get_AABBMax(node);
            var dy = Vec3.get_Y(amax) - Vec3.get_Y(amin);
            var dxz = terrain.maxf(Vec3.get_X(amax) - Vec3.get_X(amin),
                                   Vec3.get_Z(amax) - Vec3.get_Z(amin));
            if (dy > dxz * 1.4) {
                SceneNode3D.set_Material(node, barkMat);
            } else {
                SceneNode3D.set_Material(node, canopyMat);
            }
            assigned = assigned + 1;
        }
        var count = SceneNode3D.get_ChildCount(node);
        for i in 0..count {
            assigned = assigned + applyTreeMaterialsRecursive(SceneNode3D.GetChild(node, i), canopyMat);
        }
        return assigned;
    }

    hide func makeFoliage(r: Float, g: Float, b: Float) -> Material3D {
        var m = Materials.Rubber(r, g, b);
        return m;
    }

    hide func pickFoliage(x: Float, z: Float) -> Integer {
        var h = terrain.hash01(Convert.NumToInt(x * 7.0), Convert.NumToInt(z * 7.0));
        if (h < 0.55) { return 0; }
        if (h < 0.82) { return 1; }
        return 2;
    }

    hide func notNearBeacon(x: Float, z: Float) -> Boolean {
        for i in 0..beaconXs.count() {
            var dx = x - beaconXs.get(i);
            var dz = z - beaconZs.get(i);
            if (dx * dx + dz * dz < config.FOREST_BEACON_CLEAR) { return false; }
        }
        return true;
    }

    hide func notNearPlayerStart(x: Float, z: Float) -> Boolean {
        var dx = x - terrain.terrainWorldMaxX() * 0.5;
        var dz = z - terrain.terrainWorldMaxZ() * 0.5;
        return dx * dx + dz * dz > config.FOREST_PLAYER_CLEAR;
    }
}
