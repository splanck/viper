// smoke_probe.zia - One-frame validation for the Game3D open-world showcase.
module smoke_probe;

bind Viper.Game3D;
bind Viper.Terminal as Terminal;
bind "./game";

func main() {
    var game = new Game3DShowcase();
    game.setup("Game3D Showcase Smoke", 960, 540);
    game.step(0.016);
    game.renderFrame();
    World3D.present(game.getWorld());
    game.destroy();
    Terminal.Say("RESULT: ok");
}
