// terrain.zia - Terrain, procedural textures, and shared math helpers.
module terrain;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";

func packPixel(r: Integer, g: Integer, b: Integer, a: Integer) -> Integer {
    return (((r * 256) + g) * 256 + b) * 256 + a;
}

func clampByte(value: Integer) -> Integer {
    if (value < 0) { return 0; }
    if (value > 255) { return 255; }
    return value;
}

func clampFloat(value: Float, lo: Float, hi: Float) -> Float {
    if (value < lo) { return lo; }
    if (value > hi) { return hi; }
    return value;
}

func absFloat(value: Float) -> Float {
    if (value < 0.0) { return 0.0 - value; }
    return value;
}

func lerpFloat(a: Float, b: Float, t: Float) -> Float {
    return a + (b - a) * t;
}

func maxf(a: Float, b: Float) -> Float {
    if (a > b) { return a; }
    return b;
}

func terrainWorldMaxX() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_X;
}

func terrainWorldMaxZ() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_Z;
}

func sampleGround(land: Terrain3D, x: Float, z: Float) -> Float {
    var sx = x;
    var sz = z;

    if (sx < 0.0) { sx = 0.0; }
    if (sz < 0.0) { sz = 0.0; }
    if (sx > terrainWorldMaxX()) { sx = terrainWorldMaxX(); }
    if (sz > terrainWorldMaxZ()) { sz = terrainWorldMaxZ(); }

    return Terrain3D.GetHeightAt(land, sx, sz);
}

func hash01(a: Integer, b: Integer) -> Float {
    var h = (a * 374761393 + b * 668265263) % 2147483647;
    if (h < 0) { h = 0 - h; }
    h = (h * 1103515245 + 12345) % 2147483647;
    if (h < 0) { h = 0 - h; }
    return (h % 100000 + 0.0) / 100000.0;
}

func createStoneAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 13 + py * 7 + px * py * 3) % 40) - 20;
            var base = clampByte(120 + n);
            var cool = clampByte(126 + n / 2);
            tex.Set(px, py, packPixel(base, base, cool, 255));
        }
    }

    return tex;
}

func createMetalAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 9 + py * 11) % 24) - 12;
            var brush = ((py * 5) % 14) - 7;
            var r = clampByte(150 + n + brush);
            var g = clampByte(140 + n + brush);
            var b = clampByte(118 + n);
            tex.Set(px, py, packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func createNormalMap(size: Integer, strength: Float) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var hl = bumpHeight(px - 1, py, size);
            var hr = bumpHeight(px + 1, py, size);
            var hd = bumpHeight(px, py - 1, size);
            var hu = bumpHeight(px, py + 1, size);
            var nx = (hl - hr) * strength;
            var nz = (hd - hu) * strength;
            var ny = 1.0;
            var len = Sqrt(nx * nx + ny * ny + nz * nz);
            if (len <= 0.0001) { len = 1.0; }
            nx = nx / len;
            ny = ny / len;
            nz = nz / len;
            var r = clampByte(Convert.NumToInt((nx * 0.5 + 0.5) * 255.0));
            var g = clampByte(Convert.NumToInt((nz * 0.5 + 0.5) * 255.0));
            var b = clampByte(Convert.NumToInt((ny * 0.5 + 0.5) * 255.0));
            tex.Set(px, py, packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func bumpHeight(x: Integer, y: Integer, size: Integer) -> Float {
    var xx = x % size;
    if (xx < 0) { xx = xx + size; }
    var yy = y % size;
    if (yy < 0) { yy = yy + size; }
    var n = (xx * 13 + yy * 7 + xx * yy * 3) % 23;
    return (n + 0.0) / 23.0;
}

class ShowcaseTerrain {
    hide Terrain3D land;
    hide Pixels splatMap;
    hide Vegetation3D grass;

    expose func build(terrainMat: Material3D) -> Terrain3D {
        land = Terrain3D.New(config.TERRAIN_SIZE, config.TERRAIN_SIZE);
        var noise = PerlinNoise.New(42);

        Terrain3D.GeneratePerlin(
            land,
            noise,
            config.TERRAIN_NOISE_SCALE,
            config.TERRAIN_NOISE_OCTAVES,
            config.TERRAIN_NOISE_PERSIST);
        Terrain3D.SetScale(
            land, config.TERRAIN_SCALE_X, config.TERRAIN_SCALE_Y, config.TERRAIN_SCALE_Z);
        Terrain3D.SetMaterial(land, terrainMat);

        Terrain3D.SetLayerTexture(land, 0, createGrassTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 1, createRockTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 2, createDirtTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerScale(land, 0, 11.0);
        Terrain3D.SetLayerScale(land, 1, 7.0);
        Terrain3D.SetLayerScale(land, 2, 8.0);
        splatMap = createTerrainSplatMap(land, config.SPLAT_SIZE, config.SPLAT_SIZE);
        Terrain3D.SetSplatMap(land, splatMap);
        Terrain3D.SetLODDistances(land, config.TERRAIN_LOD_NEAR, config.TERRAIN_LOD_FAR);
        Terrain3D.SetSkirtDepth(land, config.TERRAIN_SKIRT_DEPTH);

        return land;
    }

    expose func buildVegetation() {
        grass = Vegetation3D.New(createGrassBladeTexture());
        Vegetation3D.SetBladeSize(grass, config.GRASS_BLADE_W, config.GRASS_BLADE_H, config.GRASS_BLADE_VAR);
        Vegetation3D.SetWindParams(grass, config.GRASS_WIND_STRENGTH, config.GRASS_WIND_FREQ, config.GRASS_WIND_DIR);
        Vegetation3D.SetLODDistances(grass, config.GRASS_LOD_NEAR, config.GRASS_LOD_FAR);
        Vegetation3D.SetDensityMap(grass, createVegetationDensity(config.SPLAT_SIZE, config.SPLAT_SIZE));
        Vegetation3D.Populate(grass, land, config.GRASS_BLADE_COUNT);
    }

    expose func updateVegetation(dt: Float, camera: Camera3D) {
        if (grass == null) { return; }
        var camPos = Camera3D.get_Position(camera);
        Vegetation3D.Update(grass, dt, Vec3.get_X(camPos), Vec3.get_Y(camPos), Vec3.get_Z(camPos));
    }

    expose func drawVegetation(canvas: Canvas3D) {
        if (grass != null) {
            Canvas3D.DrawVegetation(canvas, grass);
        }
    }

    expose func getTerrain() -> Terrain3D {
        return land;
    }

    hide func createGrassTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 7 + py * 11 + px * py) % 28) - 14;
                var r = clampByte(70 + noise / 2);
                var g = clampByte(112 + noise);
                var b = clampByte(48 + noise / 3);
                tex.Set(px, py, packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createRockTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 13 + py * 9 + px * py * 3) % 26) - 13;
                var gray = clampByte(142 + noise);
                var blue = clampByte(150 + noise / 2);
                tex.Set(px, py, packPixel(gray, gray, blue, 255));
            }
        }

        return tex;
    }

    hide func createDirtTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 9 + py * 5 + px * py) % 22) - 11;
                var r = clampByte(142 + noise);
                var g = clampByte(108 + noise / 2);
                var b = clampByte(66 + noise / 3);
                tex.Set(px, py, packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createTerrainSplatMap(srcTerrain: Terrain3D, width: Integer, depth: Integer) -> Pixels {
        var splat = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var normal = Terrain3D.GetNormalAt(srcTerrain, wx, wz);
                var ny = Vec3.get_Y(normal);
                var grassLayer = 0;
                var rockLayer = 0;
                var dirtLayer = 0;

                if (ny > 0.88) {
                    grassLayer = 255;
                } else {
                    if (ny > 0.70) {
                        if (((px / 7) + (py / 5)) % 4 <= 1) {
                            dirtLayer = 255;
                        } else {
                            grassLayer = 255;
                        }
                    } else {
                        rockLayer = 255;
                    }
                }

                splat.Set(px, py, packPixel(grassLayer, rockLayer, dirtLayer, 0));
            }
        }

        return splat;
    }

    hide func createVegetationDensity(width: Integer, depth: Integer) -> Pixels {
        var density = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var ny = Vec3.get_Y(Terrain3D.GetNormalAt(land, wx, wz));
                var h = Terrain3D.GetHeightAt(land, wx, wz);
                var v = 0;
                if (ny > 0.84 && h > config.WATER_HEIGHT + 0.6) {
                    v = clampByte(Convert.NumToInt((ny - 0.84) / 0.16 * 255.0));
                }
                density.Set(px, py, packPixel(v, v, v, v));
            }
        }

        return density;
    }

    hide func createGrassBladeTexture() -> Pixels {
        var w = 16;
        var h = 32;
        var tex = Pixels.New(w, h);

        for (var py: Integer = 0; py < h; py = py + 1) {
            for (var px: Integer = 0; px < w; px = px + 1) {
                var halfW = 8 - py / 4;
                if (halfW < 1) { halfW = 1; }
                var dx = px - 8;
                if (dx < 0) { dx = 0 - dx; }
                if (dx <= halfW) {
                    var noise = ((px * 7 + py * 13) % 20) - 10;
                    var r = clampByte(46 + noise);
                    var g = clampByte(150 + noise - py);
                    var b = clampByte(34 + noise);
                    var alpha = 255;
                    if (py > 26) { alpha = clampByte(255 - (py - 26) * 40); }
                    tex.Set(px, py, packPixel(r, g, b, alpha));
                } else {
                    tex.Set(px, py, packPixel(0, 0, 0, 0));
                }
            }
        }

        return tex;
    }
}
