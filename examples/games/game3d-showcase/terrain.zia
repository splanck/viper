// terrain.zia - Terrain generation, procedural textures, and ground queries.
module terrain;

bind Viper.Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Core.Convert as Convert;
bind Viper.Math;
bind "./config";
bind "./mathutil";

// Shared numeric, pixel, and hash helpers moved to mathutil.zia (bound above).

func noise01(noise: PerlinNoise, x: Float, z: Float, octaves: Integer, persistence: Float) -> Float {
    return mathutil.clampFloat((PerlinNoise.Octave2D(noise, x, z, octaves, persistence) + 1.0) * 0.5, 0.0, 1.0);
}

func heightPixel(value: Float) -> Integer {
    var h = mathutil.clampFloat(value, 0.0, 1.0);
    var h16 = Convert.NumToInt(h * 65535.0);
    if (h16 < 0) { h16 = 0; }
    if (h16 > 65535) { h16 = 65535; }
    return mathutil.packPixel(h16 / 256, h16 % 256, 0, 255);
}

func terrainWorldMaxX() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_X;
}

func terrainWorldMaxZ() -> Float {
    return (config.TERRAIN_SIZE - 1 + 0.0) * config.TERRAIN_SCALE_Z;
}

func sampleGround(land: Terrain3D, x: Float, z: Float) -> Float {
    var sx = x;
    var sz = z;

    if (sx < 0.0) { sx = 0.0; }
    if (sz < 0.0) { sz = 0.0; }
    if (sx > terrainWorldMaxX()) { sx = terrainWorldMaxX(); }
    if (sz > terrainWorldMaxZ()) { sz = terrainWorldMaxZ(); }

    return Terrain3D.GetHeightAt(land, sx, sz);
}

func createStoneAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 13 + py * 7 + px * py * 3) % 40) - 20;
            var base = mathutil.clampByte(120 + n);
            var cool = mathutil.clampByte(126 + n / 2);
            tex.Set(px, py, mathutil.packPixel(base, base, cool, 255));
        }
    }

    return tex;
}

func createMetalAlbedo(size: Integer) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var n = ((px * 9 + py * 11) % 24) - 12;
            var brush = ((py * 5) % 14) - 7;
            var r = mathutil.clampByte(150 + n + brush);
            var g = mathutil.clampByte(140 + n + brush);
            var b = mathutil.clampByte(118 + n);
            tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func createNormalMap(size: Integer, strength: Float) -> Pixels {
    var tex = Pixels.New(size, size);

    for (var py: Integer = 0; py < size; py = py + 1) {
        for (var px: Integer = 0; px < size; px = px + 1) {
            var hl = bumpHeight(px - 1, py, size);
            var hr = bumpHeight(px + 1, py, size);
            var hd = bumpHeight(px, py - 1, size);
            var hu = bumpHeight(px, py + 1, size);
            var nx = (hl - hr) * strength;
            var nz = (hd - hu) * strength;
            var ny = 1.0;
            var len = Sqrt(nx * nx + ny * ny + nz * nz);
            if (len <= 0.0001) { len = 1.0; }
            nx = nx / len;
            ny = ny / len;
            nz = nz / len;
            var r = mathutil.clampByte(Convert.NumToInt((nx * 0.5 + 0.5) * 255.0));
            var g = mathutil.clampByte(Convert.NumToInt((nz * 0.5 + 0.5) * 255.0));
            var b = mathutil.clampByte(Convert.NumToInt((ny * 0.5 + 0.5) * 255.0));
            tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
        }
    }

    return tex;
}

func bumpHeight(x: Integer, y: Integer, size: Integer) -> Float {
    var xx = x % size;
    if (xx < 0) { xx = xx + size; }
    var yy = y % size;
    if (yy < 0) { yy = yy + size; }
    var n = (xx * 13 + yy * 7 + xx * yy * 3) % 23;
    return (n + 0.0) / 23.0;
}

class ShowcaseTerrain {
    hide Terrain3D land;
    hide Pixels splatMap;
    hide Vegetation3D grass;

    expose func build(terrainMat: Material3D) -> Terrain3D {
        land = Terrain3D.New(config.TERRAIN_SIZE, config.TERRAIN_SIZE);
        Terrain3D.SetHeightmap(land, createShowcaseHeightmap(config.TERRAIN_SIZE, config.TERRAIN_SIZE));
        Terrain3D.SetScale(
            land, config.TERRAIN_SCALE_X, config.TERRAIN_SCALE_Y, config.TERRAIN_SCALE_Z);
        Terrain3D.SetMaterial(land, terrainMat);

        Terrain3D.SetLayerTexture(land, 0, createGrassTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 1, createRockTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerTexture(land, 2, createDirtTexture(config.TERRAIN_TEXTURE_SIZE));
        Terrain3D.SetLayerScale(land, 0, 11.0);
        Terrain3D.SetLayerScale(land, 1, 7.0);
        Terrain3D.SetLayerScale(land, 2, 8.0);
        splatMap = createTerrainSplatMap(land, config.SPLAT_SIZE, config.SPLAT_SIZE);
        Terrain3D.SetSplatMap(land, splatMap);
        Terrain3D.SetLODDistances(land, config.TERRAIN_LOD_NEAR, config.TERRAIN_LOD_FAR);
        Terrain3D.SetSkirtDepth(land, config.TERRAIN_SKIRT_DEPTH);

        return land;
    }

    expose func buildVegetation() {
        grass = Vegetation3D.New(createGrassBladeTexture());
        Vegetation3D.SetBladeSize(grass, config.GRASS_BLADE_W, config.GRASS_BLADE_H, config.GRASS_BLADE_VAR);
        Vegetation3D.SetWindParams(grass, config.GRASS_WIND_SPEED, config.GRASS_WIND_STRENGTH, config.GRASS_WIND_TURBULENCE);
        Vegetation3D.SetLODDistances(grass, config.GRASS_LOD_NEAR, config.GRASS_LOD_FAR);
        Vegetation3D.SetDensityMap(grass, createVegetationDensity(config.SPLAT_SIZE, config.SPLAT_SIZE));
        Vegetation3D.Populate(grass, land, config.GRASS_BLADE_COUNT);
    }

    expose func updateVegetation(dt: Float, camera: Camera3D) {
        if (grass == null) { return; }
        var camPos = camera.Position;
        Vegetation3D.Update(grass, dt, Vec3.get_X(camPos), Vec3.get_Y(camPos), Vec3.get_Z(camPos));
    }

    expose func drawVegetation(canvas: Canvas3D) {
        if (grass != null) {
            Canvas3D.DrawVegetation(canvas, grass);
        }
    }

    expose func getTerrain() -> Terrain3D {
        return land;
    }

    hide func createGrassTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 7 + py * 11 + px * py) % 28) - 14;
                var r = mathutil.clampByte(70 + noise / 2);
                var g = mathutil.clampByte(112 + noise);
                var b = mathutil.clampByte(48 + noise / 3);
                tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createRockTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 13 + py * 9 + px * py * 3) % 26) - 13;
                var gray = mathutil.clampByte(142 + noise);
                var blue = mathutil.clampByte(150 + noise / 2);
                tex.Set(px, py, mathutil.packPixel(gray, gray, blue, 255));
            }
        }

        return tex;
    }

    hide func createDirtTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var noise = ((px * 9 + py * 5 + px * py) % 22) - 11;
                var r = mathutil.clampByte(142 + noise);
                var g = mathutil.clampByte(108 + noise / 2);
                var b = mathutil.clampByte(66 + noise / 3);
                tex.Set(px, py, mathutil.packPixel(r, g, b, 255));
            }
        }

        return tex;
    }

    hide func createShowcaseHeightmap(width: Integer, depth: Integer) -> Pixels {
        var heights = Pixels.New(width, depth);
        var noise = PerlinNoise.New(42);
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var pz: Integer = 0; pz < depth; pz = pz + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var nx = (px + 0.0) / (lastX + 0.0);
                var nz = (pz + 0.0) / (lastZ + 0.0);
                heights.Set(px, pz, heightPixel(sampleShowcaseHeight(noise, nx, nz)));
            }
        }

        return heights;
    }

    hide func sampleShowcaseHeight(noise: PerlinNoise, nx: Float, nz: Float) -> Float {
        var rolling = noise01(
            noise,
            nx * config.TERRAIN_NOISE_SCALE,
            nz * config.TERRAIN_NOISE_SCALE,
            config.TERRAIN_NOISE_OCTAVES,
            config.TERRAIN_NOISE_PERSIST);
        var broad = noise01(noise, nx * 1.65 + 13.0, nz * 1.65 - 4.0, 3, 0.56);
        var detail = noise01(noise, nx * 15.0 + 2.0, nz * 15.0 + 9.0, 3, 0.48);
        var h = 0.135 + rolling * 0.18 + broad * 0.055 + detail * 0.025;

        var lakeDx = (nx - config.LAKE_CENTER_X) / config.LAKE_RADIUS_X;
        var lakeDz = (nz - config.LAKE_CENTER_Z) / config.LAKE_RADIUS_Z;
        var lakeDist = Sqrt(lakeDx * lakeDx + lakeDz * lakeDz);
        var basin = 1.0 - mathutil.smoothStep(0.62, 1.10, lakeDist);
        var lakeFloor = 0.035 + detail * 0.018;
        h = mathutil.lerpFloat(h, lakeFloor, basin);

        var shore = 1.0 - mathutil.smoothStep(0.94, 1.17, lakeDist);
        if (lakeDist > 0.96) {
            h = mathutil.lerpFloat(h, 0.135 + rolling * 0.035, shore * 0.48);
        }

        var homeDx = (nx - 0.50) / 0.085;
        var homeDz = (nz - 0.50) / 0.075;
        var homeDist = Sqrt(homeDx * homeDx + homeDz * homeDz);
        var homeIsland = 1.0 - mathutil.smoothStep(0.62, 1.05, homeDist);
        var homeHeight = 0.185 + rolling * 0.040 + broad * 0.015;
        h = mathutil.lerpFloat(h, mathutil.maxf(h, homeHeight), homeIsland);

        var edge = mathutil.minf(mathutil.minf(nx, 1.0 - nx), mathutil.minf(nz, 1.0 - nz));
        var mountainBand = 1.0 - mathutil.smoothStep(0.055, config.MOUNTAIN_RING_FADE, edge);
        var crestBand = 1.0 - mathutil.smoothStep(0.0, config.MOUNTAIN_CREST_FADE, edge);
        var ridgeNoise = noise01(noise, nx * 7.7 + 5.0, nz * 7.7 - 3.0, 5, 0.54);
        var cragNoise = noise01(noise, nx * 27.0 - 11.0, nz * 27.0 + 4.0, 4, 0.50);
        var striation = mathutil.absFloat(Sin((nx * 39.0 + nz * 27.0) * 3.14159));
        var mountain = 0.24
            + mountainBand * (0.22 + ridgeNoise * 0.26)
            + crestBand * (0.16 + cragNoise * 0.20 + striation * 0.065);
        if (mountain > h) { h = mountain; }

        var guardEdge = mathutil.minf(
            config.PLAYER_BOUNDS_MARGIN / terrainWorldMaxX(),
            config.PLAYER_BOUNDS_MARGIN / terrainWorldMaxZ());
        var blocker = 1.0 - mathutil.smoothStep(0.0, guardEdge, edge);
        var blockerHeight = 0.76 + blocker * (0.20 + cragNoise * 0.04);
        if (blocker > 0.0 && blockerHeight > h) { h = blockerHeight; }

        return mathutil.clampFloat(h, 0.0, 1.0);
    }

    hide func createTerrainSplatMap(srcTerrain: Terrain3D, width: Integer, depth: Integer) -> Pixels {
        var splat = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var normal = Terrain3D.GetNormalAt(srcTerrain, wx, wz);
                var ny = Vec3.get_Y(normal);
                var h = Terrain3D.GetHeightAt(srcTerrain, wx, wz);
                var grassLayer = 0;
                var rockLayer = 0;
                var dirtLayer = 0;

                if (h < config.WATER_HEIGHT + 0.9) {
                    dirtLayer = 255;
                } else {
                    if (h > config.WATER_HEIGHT + 13.5) {
                        rockLayer = 255;
                    } else {
                        if (ny > 0.88) {
                            grassLayer = 255;
                        } else {
                            if (ny > 0.70) {
                                if (((px / 7) + (py / 5)) % 4 <= 1) {
                                    dirtLayer = 255;
                                } else {
                                    grassLayer = 255;
                                }
                            } else {
                                rockLayer = 255;
                            }
                        }
                    }
                }

                splat.Set(px, py, mathutil.packPixel(grassLayer, rockLayer, dirtLayer, 0));
            }
        }

        return splat;
    }

    hide func createVegetationDensity(width: Integer, depth: Integer) -> Pixels {
        var density = Pixels.New(width, depth);
        var maxX = terrainWorldMaxX();
        var maxZ = terrainWorldMaxZ();
        var lastX = width - 1;
        var lastZ = depth - 1;

        for (var py: Integer = 0; py < depth; py = py + 1) {
            for (var px: Integer = 0; px < width; px = px + 1) {
                var wx = (px + 0.0) * maxX / (lastX + 0.0);
                var wz = (py + 0.0) * maxZ / (lastZ + 0.0);
                var ny = Vec3.get_Y(Terrain3D.GetNormalAt(land, wx, wz));
                var h = Terrain3D.GetHeightAt(land, wx, wz);
                var v = 0;
                if (ny > 0.84 && h > config.WATER_HEIGHT + 0.6) {
                    v = mathutil.clampByte(Convert.NumToInt((ny - 0.84) / 0.16 * 255.0));
                }
                density.Set(px, py, mathutil.packPixel(v, v, v, v));
            }
        }

        return density;
    }

    hide func createGrassBladeTexture() -> Pixels {
        var w = 16;
        var h = 32;
        var tex = Pixels.New(w, h);

        for (var py: Integer = 0; py < h; py = py + 1) {
            for (var px: Integer = 0; px < w; px = px + 1) {
                var halfW = 1 + py / 6;
                if (halfW < 1) { halfW = 1; }
                var dx = px - 8;
                if (dx < 0) { dx = 0 - dx; }
                if (dx <= halfW) {
                    var noise = ((px * 7 + py * 13) % 20) - 10;
                    var r = mathutil.clampByte(40 + noise / 2);
                    var g = mathutil.clampByte(118 + noise + (h - py) / 3);
                    var b = mathutil.clampByte(30 + noise / 3);
                    var alpha = 255;
                    if (py < 4) { alpha = mathutil.clampByte(110 + py * 36); }
                    tex.Set(px, py, mathutil.packPixel(r, g, b, alpha));
                } else {
                    tex.Set(px, py, mathutil.packPixel(0, 0, 0, 0));
                }
            }
        }

        return tex;
    }
}
