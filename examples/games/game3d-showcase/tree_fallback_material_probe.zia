// tree_fallback_material_probe.zia - Validate procedural fallback tree material detail.
module tree_fallback_material_probe;

bind Viper.Game3D;
bind Viper.Graphics3D.Material3D as Material3D;
bind Viper.Graphics3D.SceneNode as SceneNode;
bind Viper.Math;
bind Viper.Terminal as Terminal;
bind "./game";
bind "./forest";

func fail(game: Game3DShowcase, msg: String) {
    Terminal.Say("FAIL: " + msg);
    game.destroy();
}

func matHasSurfaceDetail(mat: Material3D) -> Boolean {
    if (mat == null) { return false; }
    if (mat.HasTexture) { return true; }
    if (mat.HasNormalMap) { return true; }
    return false;
}

func absFloat(value: Float) -> Float {
    if (value < 0.0) { return 0.0 - value; }
    return value;
}

func colorDistance(a: Material3D, b: Material3D) -> Float {
    var ac = a.Color;
    var bc = b.Color;
    return absFloat(Vec3.get_X(ac) - Vec3.get_X(bc))
        + absFloat(Vec3.get_Y(ac) - Vec3.get_Y(bc))
        + absFloat(Vec3.get_Z(ac) - Vec3.get_Z(bc));
}

func main() {
    Diagnostics3D.Reset();

    var game = new Game3DShowcase();
    game.setup("Game3D Showcase Fallback Tree Material Probe", 320, 180);

    var forest = game.getForest();
    if (forest.getTreeCount() <= 0) {
        fail(game, "procedural fallback planted no trees");
        return;
    }

    // Trunks and canopy lobes now render from instance batches rather than scene
    // nodes, so validate the shared materials those batches draw with directly.
    var trunkMat = forest.getBarkMat();
    var canopyMat = forest.getCanopyMat();
    if (trunkMat == null) {
        fail(game, "procedural fallback trunk material missing");
        return;
    }
    if (canopyMat == null) {
        fail(game, "procedural fallback canopy material missing");
        return;
    }
    if (matHasSurfaceDetail(trunkMat) == false) {
        fail(game, "fallback trunk material has no albedo/normal texture detail");
        return;
    }
    if (matHasSurfaceDetail(canopyMat) == false) {
        fail(game, "fallback canopy material has no albedo/normal texture detail");
        return;
    }
    if (colorDistance(trunkMat, canopyMat) < 0.12) {
        fail(game, "fallback trunk and canopy materials collapsed to the same color");
        return;
    }

    var trunkColor = trunkMat.Color;
    if (Vec3.get_X(trunkColor) <= Vec3.get_Y(trunkColor) ||
            Vec3.get_Y(trunkColor) <= Vec3.get_Z(trunkColor)) {
        fail(game, "fallback trunk material is not brown-toned");
        return;
    }

    var diagSummary = Diagnostics3D.Summary();
    if (diagSummary != "") {
        fail(game, "diagnostics recorded degradation: " + diagSummary);
        return;
    }

    game.destroy();
    Terminal.Say("RESULT: ok");
}
