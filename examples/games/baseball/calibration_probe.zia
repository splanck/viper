// ============================================================================
// File: calibration_probe.zia
// Purpose: Run a 120-game calibration sample and check that the per-game
//          rate aggregates land inside the configured bands. Plan 06 §
//          Calibration workflow is the design — the goal is to detect
//          meaningful drift in the engine's outcome rates from one change
//          to the next, NOT to claim the engine is calibrated to MLB
//          targets (Phase 5 will narrow the bands further).
//
//          Tracked rates: runs, hits, walks, strikeouts, home runs, HBP,
//          errors, plate appearances per game. Each is checked against a
//          (min, max) band scaled by 100 (so a band of (700, 950) means
//          7.00 to 9.50 per game).
// Run via: viper run examples/games/baseball/calibration_probe.zia
// ============================================================================
module calibration_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/demo/default_game";
bind "./src/sim/game_engine";
bind "./src/model/game_state";

// Per-run aggregate counters. Bumped per-team via accumulateTeam, then
// divided by `games` (NOT 2*games) to get the per-game-both-teams rate.
class AggregateStats {
    expose Integer games;
    expose Integer runs;
    expose Integer hits;
    expose Integer walks;
    expose Integer strikeouts;
    expose Integer homeRuns;
    expose Integer hitByPitch;
    expose Integer errors;
    expose Integer plateAppearances;

    expose func init() {
        games = 0;
        runs = 0;
        hits = 0;
        walks = 0;
        strikeouts = 0;
        homeRuns = 0;
        hitByPitch = 0;
        errors = 0;
        plateAppearances = 0;
    }
}

// Add one team's per-game totals into the running aggregate.
func accumulateTeam(stats: AggregateStats, teamState: game_state.TeamGameState) {
    stats.runs = stats.runs + teamState.score;
    stats.hits = stats.hits + teamState.hits;
    stats.errors = stats.errors + teamState.errors;

    for i in 0..teamState.battingLines.length() {
        var line = teamState.battingLines.get(i);
        stats.walks = stats.walks + line.BB;
        stats.strikeouts = stats.strikeouts + line.SO;
        stats.homeRuns = stats.homeRuns + line.homeRuns;
        stats.hitByPitch = stats.hitByPitch + line.HBP;
        stats.plateAppearances = stats.plateAppearances + line.PA;
    }
}

// Format a (total, games) pair as a per-game decimal string with two
// decimal places. e.g., (1015, 120) -> "8.45". Uses integer math so the
// result is byte-for-byte deterministic.
func perGameText(total: Integer, games: Integer) -> String {
    if games <= 0 {
        return "0.00";
    }
    var scaled = (total * 100) / games;
    var whole = scaled / 100;
    var frac = scaled % 100;
    return Fmt.Int(whole) + "." + Fmt.IntPad(frac, 2, "0");
}

// Check whether (total / games * 100) is within [minScaled, maxScaled].
// minScaled and maxScaled are pre-multiplied by 100 so they can be integer
// constants in the call site (e.g., 700 == 7.00 per game).
func inBand(total: Integer, games: Integer, minScaled: Integer, maxScaled: Integer) -> Boolean {
    if games <= 0 {
        return false;
    }
    var scaled = (total * 100) / games;
    return scaled >= minScaled && scaled <= maxScaled;
}

// Run the calibration sample: simulate 120 games with 120 distinct seeds,
// accumulate per-game stats, print rates, check against the configured
// bands, and emit RESULT: ok or RESULT: out_of_band.
func start() {
    var sampleGames = 120;
    var stats = new AggregateStats();

    for i in 0..sampleGames {
        var state = default_game.buildDefaultGame(4000 + i);
        var engine = new game_engine.GameEngine(state);
        var finalState = engine.simulate();
        stats.games = stats.games + 1;
        accumulateTeam(stats, finalState.away);
        accumulateTeam(stats, finalState.home);
    }

    Terminal.Say("games=" + Fmt.Int(stats.games));
    Terminal.Say("runs_per_game=" + perGameText(stats.runs, stats.games));
    Terminal.Say("hits_per_game=" + perGameText(stats.hits, stats.games));
    Terminal.Say("walks_per_game=" + perGameText(stats.walks, stats.games));
    Terminal.Say("strikeouts_per_game=" + perGameText(stats.strikeouts, stats.games));
    Terminal.Say("home_runs_per_game=" + perGameText(stats.homeRuns, stats.games));
    Terminal.Say("hbp_per_game=" + perGameText(stats.hitByPitch, stats.games));
    Terminal.Say("errors_per_game=" + perGameText(stats.errors, stats.games));
    Terminal.Say("pa_per_game=" + perGameText(stats.plateAppearances, stats.games));

    // Calibration bands. The numbers are scaled by 100 (so 700 == 7.00 per game).
    // These bands are intentionally tight enough to detect meaningful drift in
    // the engine's outcome rates from one change to the next, but loose enough
    // to absorb normal RNG variance over a 120-game sample. They are NOT
    // calibrated to modern MLB norms yet — that's Phase 5 work. The Phase 5
    // realism pass should narrow these further toward real targets and add
    // splits-aware bands (LHP vs LHB, hitter counts vs pitcher counts, etc.).
    //
    // Approximate modern MLB per-game (both teams combined) for reference:
    //   runs ~9.2, hits ~17, walks ~6.8, K ~17, HR ~2.4, HBP ~0.7, errors ~0.6
    var okay = true;
    if !inBand(stats.runs,             stats.games,  700,  950) { okay = false; }
    if !inBand(stats.hits,             stats.games, 1750, 2050) { okay = false; }
    if !inBand(stats.walks,            stats.games,  450,  650) { okay = false; }
    if !inBand(stats.strikeouts,       stats.games, 1200, 1550) { okay = false; }
    if !inBand(stats.homeRuns,         stats.games,  200,  350) { okay = false; }
    if !inBand(stats.hitByPitch,       stats.games,   20,   80) { okay = false; }
    if !inBand(stats.errors,           stats.games,   70,  150) { okay = false; }
    if !inBand(stats.plateAppearances, stats.games, 7700, 8300) { okay = false; }

    if okay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: out_of_band");
    }
}
