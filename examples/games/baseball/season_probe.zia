// ============================================================================
// File: season_probe.zia
// Purpose: Season-level smoke test. Builds the canonical 4-team default
//          franchise with seed 5151, simulates a full regular season, and
//          asserts that:
//            - completed games equals scheduled games (no loss / no
//              double-count)
//            - total wins == total losses == scheduled games (every game
//              produced exactly one winner and one loser)
//            - 4 standings rows
//            - decision log has more entries than games (every game logs
//              at least one decision)
//          Then runs the off-season tick and checks that the year advanced
//          to 2027 and the career ledger has 40+ entries (4 teams × 34
//          players minus duplicates).
// Run via: viper run examples/games/baseball/season_probe.zia
// ============================================================================
module season_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/season_model";

// Sum the number of scheduled games across every GameDay in the calendar.
func scheduledGameCount(state: season_model.FranchiseState) -> Integer {
    var total = 0;
    for i in 0..state.calendar.days.length() {
        total = total + state.calendar.days.get(i).scheduledGames.length();
    }
    return total;
}

// Run the season smoke test: simulate one season, dump aggregate counters,
// run the off-season tick, assert against the bands, exit.
func start() {
    var franchise = default_franchise.buildDefaultFranchise(5151);
    var expectedGames = scheduledGameCount(franchise);
    var engine = new season_engine.SeasonEngine(franchise);
    var seasonState = engine.simulateRegularSeason();
    var standings = engine.buildStandings();

    var totalWins = 0;
    var totalLosses = 0;
    for i in 0..standings.length() {
        totalWins = totalWins + standings.get(i).wins;
        totalLosses = totalLosses + standings.get(i).losses;
    }

    Terminal.Say("scheduled_games=" + Fmt.Int(expectedGames));
    Terminal.Say("completed_games=" + Fmt.Int(seasonState.completedGames.length()));
    Terminal.Say("standings_rows=" + Fmt.Int(standings.length()));
    Terminal.Say("wins=" + Fmt.Int(totalWins));
    Terminal.Say("losses=" + Fmt.Int(totalLosses));
    Terminal.Say("decision_log_entries=" + Fmt.Int(seasonState.managerDecisionLog.length()));
    Terminal.Say("transactions=" + Fmt.Int(seasonState.transactionLog.length()));

    var okay = true;
    if seasonState.completedGames.length() != expectedGames { okay = false; }
    if totalWins != expectedGames { okay = false; }
    if totalLosses != expectedGames { okay = false; }
    if standings.length() != seasonState.teams.length() { okay = false; }
    if seasonState.managerDecisionLog.length() <= expectedGames { okay = false; }

    engine.runOffseason();
    Terminal.Say("next_year=" + Fmt.Int(seasonState.seasonYear));
    Terminal.Say("career_entries=" + Fmt.Int(seasonState.careerLines.length()));
    if seasonState.seasonYear != 2027 { okay = false; }
    if seasonState.careerLines.length() < 40 { okay = false; }

    if okay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
