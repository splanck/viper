module smoke_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/demo/default_game";
bind "./src/sim/game_engine";
bind "./src/model/game_state";

func totalPlateAppearances(teamState: game_state.TeamGameState) -> Integer {
    var total = 0;
    for i in 0..teamState.battingLines.length() {
        total = total + teamState.battingLines.get(i).PA;
    }
    return total;
}

func totalWalks(teamState: game_state.TeamGameState) -> Integer {
    var total = 0;
    for i in 0..teamState.battingLines.length() {
        total = total + teamState.battingLines.get(i).BB;
    }
    return total;
}

func start() {
    var state = default_game.buildDefaultGame(4242);
    var engine = new game_engine.GameEngine(state);
    var finalState = engine.simulate();

    var combinedRuns = finalState.away.score + finalState.home.score;
    var combinedHits = finalState.away.hits + finalState.home.hits;
    var combinedWalks = totalWalks(finalState.away) + totalWalks(finalState.home);
    var combinedPA = totalPlateAppearances(finalState.away) + totalPlateAppearances(finalState.home);

    Terminal.Say("final=" + finalState.away.teamRef.nickname + " " + Fmt.Int(finalState.away.score) +
                 ", " + finalState.home.teamRef.nickname + " " + Fmt.Int(finalState.home.score));
    Terminal.Say("innings=" + Fmt.Int(finalState.inning));
    Terminal.Say("combined_runs=" + Fmt.Int(combinedRuns));
    Terminal.Say("combined_hits=" + Fmt.Int(combinedHits));
    Terminal.Say("combined_walks=" + Fmt.Int(combinedWalks));
    Terminal.Say("combined_pa=" + Fmt.Int(combinedPA));
    Terminal.Say("event_log_lines=" + Fmt.Int(finalState.eventLog.length()));

    var okay = true;
    if finalState.inning < 9 { okay = false; }
    if combinedRuns < 3 || combinedRuns > 20 { okay = false; }
    if combinedHits < 10 || combinedHits > 30 { okay = false; }
    if combinedWalks < 1 || combinedWalks > 14 { okay = false; }
    if combinedPA < 65 || combinedPA > 95 { okay = false; }
    if finalState.eventLog.length() < 150 { okay = false; }

    if okay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
