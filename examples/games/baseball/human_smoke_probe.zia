// ============================================================================
// File: human_smoke_probe.zia
// Purpose: Smoke test for the human-manager mode scaffolding. Constructs a
//          franchise directly (bypassing the shell's interactive boot),
//          installs a HumanSeasonTeamManager on one team with the observe-
//          only pacing profile (which surfaces zero prompts), sims a full
//          game via simulateCurrentDay, and asserts the game completed
//          cleanly. This is deliberately a non-interactive probe — the
//          observe-only profile means no prompts fire even though the human
//          manager classes are installed, so the probe can run inside CI
//          without a scripted stdin stream.
//
//          What it verifies:
//            - HumanSeasonTeamManager integrates with SeasonEngine.setManager
//            - HumanManagerPolicy is reachable from GameEngine.setPolicies
//              via SeasonTeamManager.inGamePolicy
//            - observe-only profile is behavior-preserving (no prompts,
//              engine completes the game normally)
//            - decision log captures both AI and human-manager entries
//
// Run via: viper run examples/games/baseball/human_smoke_probe.zia
// ============================================================================
module human_smoke_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/manager_layer";
bind "./src/human/pacing_profile";

func start() {
    var franchise = default_franchise.buildDefaultFranchise(4242);
    var engine = new season_engine.SeasonEngine(franchise);

    // Install a HumanSeasonTeamManager on "port_city" with the observe-only
    // profile. With prompt_on_lineup=false the HumanSeasonTeamManager falls
    // through to super.submitPregameLineup, and the HumanManagerPolicy gates
    // all in-game checkpoints off as well — so the sim runs exactly like an
    // AI-only sim, but every code path exercised is the human-mode path.
    var humanMgr = new manager_layer.HumanSeasonTeamManager("Test Skipper");
    humanMgr.setProfile(pacing_profile.makeObserveOnly());
    engine.setManager("port_city", humanMgr);

    // Run simulateCurrentDay repeatedly until we find a day with a scheduled
    // port_city game. Once that day completes, we've exercised the full
    // path through HumanManagerPolicy (decideSubstitutionAction +
    // decidePitchingChangeAction + decideIntentionalWalkAction) under the
    // observe-only profile.
    var daysSimmed = 0;
    var userGamesSimmed = 0;
    var cal = franchise.calendar;
    while daysSimmed < 10 && cal.currentDayIndex < cal.days.length() {
        var day = cal.currentDay();
        var userPlaysToday = false;
        for i in 0..day.scheduledGames.length() {
            var g = day.scheduledGames.get(i);
            if g.homeTeamId == "port_city" || g.awayTeamId == "port_city" {
                userPlaysToday = true;
            }
        }
        engine.simulateCurrentDay();
        daysSimmed = daysSimmed + 1;
        if userPlaysToday {
            userGamesSimmed = userGamesSimmed + 1;
        }
        if userGamesSimmed >= 2 {
            break;
        }
    }

    var ok = true;
    if daysSimmed == 0 {
        ok = false;
    }
    if userGamesSimmed == 0 {
        ok = false;
    }
    if franchise.managerDecisionLog.length() == 0 {
        ok = false;
    }
    if franchise.completedGames.length() == 0 {
        ok = false;
    }

    Terminal.Say("days_simmed=" + Fmt.Int(daysSimmed));
    Terminal.Say("user_games_simmed=" + Fmt.Int(userGamesSimmed));
    Terminal.Say("decision_log_entries=" + Fmt.Int(franchise.managerDecisionLog.length()));
    Terminal.Say("completed_games=" + Fmt.Int(franchise.completedGames.length()));
    if ok {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
