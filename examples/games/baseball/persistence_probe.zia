// ============================================================================
// File: persistence_probe.zia
// Purpose: Verify the season-level save/load round-trip. Builds a default
//          franchise with seed 9090, simulates 12 days, saves the franchise
//          to a temp directory, loads it back, and asserts that every
//          observable field on the loaded franchise matches the saved
//          franchise. Crucially, also verifies the three between-game RNG
//          stream cursors (injuryRngState, developmentRngState,
//          transactionRngState) round-trip identically — that's the
//          plan-15 § RNG handling determinism guarantee in action.
// Run via: viper run examples/games/baseball/persistence_probe.zia
// ============================================================================
module persistence_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind Viper.IO.TempFile as TempFile;
bind Viper.IO.Path as Path;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/persistence";

// Run the persistence round-trip: simulate 12 days, save, load, compare
// every field including the RNG stream cursors, exit.
func start() {
    var franchise = default_franchise.buildDefaultFranchise(9090);
    var engine = new season_engine.SeasonEngine(franchise);

    var days = 0;
    while days < 12 {
        engine.simulateCurrentDay();
        days = days + 1;
    }

    var root = Path.Join(TempFile.Dir(), "baseball_persistence_probe");
    persistence.saveFranchise(root, franchise);

    var load = persistence.loadFranchise(Path.Join(root, franchise.franchiseId));
    Terminal.Say("load_ok=" + Fmt.Int(load.ok ? 1 : 0));
    if !load.ok || load.state == null {
        Terminal.Say("error=" + load.error);
        Terminal.Say("RESULT: fail");
        return;
    }

    var loaded = load.state!;
    Terminal.Say("saved_year=" + Fmt.Int(franchise.seasonYear));
    Terminal.Say("loaded_year=" + Fmt.Int(loaded.seasonYear));
    Terminal.Say("saved_completed=" + Fmt.Int(franchise.completedGames.length()));
    Terminal.Say("loaded_completed=" + Fmt.Int(loaded.completedGames.length()));
    Terminal.Say("saved_day_index=" + Fmt.Int(franchise.calendar.currentDayIndex));
    Terminal.Say("loaded_day_index=" + Fmt.Int(loaded.calendar.currentDayIndex));
    Terminal.Say("saved_teams=" + Fmt.Int(franchise.teams.length()));
    Terminal.Say("loaded_teams=" + Fmt.Int(loaded.teams.length()));
    Terminal.Say("saved_decisions=" + Fmt.Int(franchise.managerDecisionLog.length()));
    Terminal.Say("loaded_decisions=" + Fmt.Int(loaded.managerDecisionLog.length()));
    Terminal.Say("saved_injury_rng=" + Fmt.Int(franchise.injuryRngState));
    Terminal.Say("loaded_injury_rng=" + Fmt.Int(loaded.injuryRngState));
    Terminal.Say("saved_dev_rng=" + Fmt.Int(franchise.developmentRngState));
    Terminal.Say("loaded_dev_rng=" + Fmt.Int(loaded.developmentRngState));
    Terminal.Say("saved_tx_rng=" + Fmt.Int(franchise.transactionRngState));
    Terminal.Say("loaded_tx_rng=" + Fmt.Int(loaded.transactionRngState));
    Terminal.Say("saved_next_game=" + Fmt.Int(franchise.nextGameNumber));
    Terminal.Say("loaded_next_game=" + Fmt.Int(loaded.nextGameNumber));

    var detailOkay = true;
    if franchise.completedGames.length() > 0 && loaded.completedGames.length() > 0 {
        var savedLast = franchise.completedGames.get(franchise.completedGames.length() - 1);
        var loadedLast = loaded.completedGames.get(loaded.completedGames.length() - 1);
        Terminal.Say("saved_last_digest=" + Fmt.Int(savedLast.eventDigest.length()));
        Terminal.Say("loaded_last_digest=" + Fmt.Int(loadedLast.eventDigest.length()));
        Terminal.Say("saved_last_away_batting=" + Fmt.Int(savedLast.awayBatting.length()));
        Terminal.Say("loaded_last_away_batting=" + Fmt.Int(loadedLast.awayBatting.length()));
        if loadedLast.eventDigest.length() != savedLast.eventDigest.length() { detailOkay = false; }
        if loadedLast.awayBatting.length() != savedLast.awayBatting.length() { detailOkay = false; }
        if loadedLast.homePitching.length() != savedLast.homePitching.length() { detailOkay = false; }
    }

    var okay = true;
    if loaded.seasonYear != franchise.seasonYear { okay = false; }
    if loaded.completedGames.length() != franchise.completedGames.length() { okay = false; }
    if loaded.calendar.currentDayIndex != franchise.calendar.currentDayIndex { okay = false; }
    if loaded.teams.length() != franchise.teams.length() { okay = false; }
    if loaded.managerDecisionLog.length() != franchise.managerDecisionLog.length() { okay = false; }
    if loaded.injuryRngState != franchise.injuryRngState { okay = false; }
    if loaded.developmentRngState != franchise.developmentRngState { okay = false; }
    if loaded.transactionRngState != franchise.transactionRngState { okay = false; }
    if loaded.nextGameNumber != franchise.nextGameNumber { okay = false; }
    if !detailOkay { okay = false; }
    // Plan 15 § Verification: the live RNG state must be non-zero after at
    // least one day's simulation, otherwise sync isn't running at all.
    if franchise.injuryRngState == 0 { okay = false; }

    if okay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
