// ============================================================================
// File: src/main.zia
// Purpose: Top-level entry point for the baseball manager simulation demo.
//          Builds a default 4-team franchise, runs a full regular season via
//          the SeasonEngine, prints the final standings, recent games, and a
//          short readiness summary, then advances the calendar one off-season
//          to demonstrate that multi-season state is wired correctly.
// Owns:    Nothing — this file is purely orchestration. All real logic lives
//          in the model/, sim/, season/, and output/ subdirectories.
// Entry:   `func start()` is the canonical Zia entry function (matches the
//          frogger / centipede / 3dworld convention used elsewhere in the
//          repo).
// ============================================================================
module Main;

bind Viper.Terminal;
bind Viper.Fmt as Fmt;
bind "./season/demo/default_franchise";
bind "./season/season_engine";
bind "./season/output/season_writer";
bind "./season/date_utils";

// Print every entry of a List[String] as a separate terminal line. Used to
// dump the multi-line output blocks returned by the season writers without
// forcing every caller to write its own loop.
func writeLines(lines: List[String]) {
    for i in 0..lines.length() {
        Say(lines.get(i));
    }
}

// Demo entry point. Constructs a deterministic franchise from a fixed seed,
// simulates one regular season, prints the snapshot + recent results, runs
// the off-season tick to advance to the next season, and exits cleanly.
func start() {
    var franchise = default_franchise.buildDefaultFranchise(4242);
    var engine = new season_engine.SeasonEngine(franchise);
    var finalState = engine.simulateRegularSeason();
    var standings = engine.buildStandings();

    writeLines(season_writer.renderFranchiseSnapshot(finalState, standings));
    Say("");
    writeLines(season_writer.renderCompletedGameSummaries(finalState.completedGames, 8));
    Say("");
    engine.runOffseason();
    Say("Next season prepared: " + Fmt.Int(finalState.seasonYear));
    Say("Opening day: " + date_utils.fromDaysText(finalState.calendar.startDateDays));
    Say("Career ledger entries: " + Fmt.Int(finalState.careerLines.length()));
    Say("");
    Say("Ready for continued simulation.");
}
