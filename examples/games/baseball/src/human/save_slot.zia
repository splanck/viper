// ============================================================================
// File: src/human/save_slot.zia
// Purpose: Thin wrapper around persistence.saveFranchise / loadFranchise that
//          adds the "save slot" concept the franchise shell needs: listing
//          saves, creating a new career, deleting a career, and carrying the
//          per-user metadata (manager name, favorite team, pacing profile)
//          alongside the persisted franchise state.
//
//          The root layout is:
//              <saveRoot>/
//                  <franchiseId>/
//                      franchise.save        — written by persistence
//                      user.save             — written by user_profile (NEW)
//                      careers.txt           — written by persistence
//                      seasons/<year>/...    — written by persistence
//                  <franchiseId2>/
//                      ...
//
//          A "save slot" is a directory directly under <saveRoot>. Listing
//          slots = scanning <saveRoot> for subdirs that contain a
//          franchise.save file. Each slot's SaveSlot record reads the
//          user.save line (if present) to surface the user team + profile
//          in the shell's "load game" menu.
//
// Cross-refs:
//          - persistence.saveFranchise / loadFranchise — the actual franchise
//            I/O. We delegate to them after writing/reading user.save.
//          - default_franchise.buildDefaultFranchise — builds the initial
//            FranchiseState for a new career.
//          - franchise_shell.zia — the only caller in normal operation.
// ============================================================================
module save_slot;

bind Viper.IO.Dir as Dir;
bind Viper.IO.File as File;
bind Viper.IO.Path as Path;
bind Viper.Collections.Seq as Seq;
bind Viper.Fmt as Fmt;
bind "../season/season_model";
bind "../season/persistence";
bind "../season/demo/default_franchise";
bind "./user_profile";
bind "./pacing_profile";

// Summary record for one save slot. Combines the franchise metadata that
// the shell's "load game" menu needs to display the slot with the user
// metadata from user.save. `hasUserProfile` distinguishes slots created by
// the human-manager mode from legacy AI-only probe saves.
class SaveSlot {
    expose String franchiseId;
    expose String leagueName;
    expose Integer seasonYear;
    expose String userTeamId;
    expose String managerName;
    expose String pacingProfileId;
    expose Boolean hasUserProfile;

    // Construct an empty slot with neutral defaults. listSlots overwrites
    // fields from the loaded franchise + user.save; the shell only reads.
    expose func init() {
        franchiseId = "";
        leagueName = "";
        seasonYear = 0;
        userTeamId = "";
        managerName = "";
        pacingProfileId = pacing_profile.PROFILE_STANDARD_MANAGER;
        hasUserProfile = false;
    }
}

// Enumerate every save slot under `saveRoot`. A slot is recognized by the
// presence of `franchise.save` directly inside its directory. Slots with
// missing or unreadable franchise.save files are silently skipped so one
// corrupt save cannot block the shell from listing the others. Returns
// an empty list if `saveRoot` doesn't exist yet (first-run case).
func listSlots(saveRoot: String) -> List[SaveSlot] {
    var slots: List[SaveSlot] = [];
    if !Dir.Exists(saveRoot) {
        return slots;
    }
    for name in Dir.DirsSeq(saveRoot) {
        var franchiseDir = Path.Join(saveRoot, name);
        if !File.Exists(Path.Join(franchiseDir, "franchise.save")) {
            continue;
        }
        var loadRes = persistence.loadFranchise(franchiseDir);
        if !loadRes.ok || loadRes.state == null {
            continue;
        }
        var franchise = loadRes.state!;
        var profile = user_profile.load(franchiseDir);
        var slot = new SaveSlot();
        slot.franchiseId = franchise.franchiseId;
        slot.leagueName = franchise.leagueName;
        slot.seasonYear = franchise.seasonYear;
        slot.userTeamId = profile.userTeamId;
        slot.managerName = profile.managerName;
        slot.pacingProfileId = profile.pacingProfileId;
        slot.hasUserProfile = profile.hasProfile;
        slots.add(slot);
    }
    return slots;
}

// Create a brand-new save slot under `saveRoot`. Builds the default
// franchise with the supplied RNG seed, writes the user.save metadata,
// and persists the franchise through persistence.saveFranchise. Returns
// the FranchiseState that was written so the shell can start managing
// immediately without a separate load round-trip.
func createSlot(saveRoot: String, franchiseId: String, userTeamId: String,
                managerName: String, pacingProfileId: String,
                seed: Integer) -> season_model.FranchiseState {
    var franchise = default_franchise.buildDefaultFranchise(seed);
    franchise.franchiseId = franchiseId;

    Dir.MakeAll(Path.Join(saveRoot, franchiseId));

    var profile = new user_profile.UserProfile();
    profile.userTeamId = userTeamId;
    profile.managerName = managerName;
    profile.pacingProfileId = pacingProfileId;
    profile.hasProfile = true;
    user_profile.save(Path.Join(saveRoot, franchiseId), profile);

    persistence.saveFranchise(saveRoot, franchise);
    return franchise;
}

// Save an existing franchise + user profile back to disk. This is the
// "Save" / "Save and quit" shell action. Writes user.save first (so a
// mid-save crash leaves the metadata consistent with the last complete
// franchise write), then delegates to persistence.saveFranchise which
// writes the rest atomically.
func saveSlot(saveRoot: String, franchise: season_model.FranchiseState,
              profile: user_profile.UserProfile) {
    var franchiseDir = Path.Join(saveRoot, franchise.franchiseId);
    Dir.MakeAll(franchiseDir);
    user_profile.save(franchiseDir, profile);
    persistence.saveFranchise(saveRoot, franchise);
}

// Typed load result for a save slot. Bundles the FranchiseState and the
// UserProfile so the shell can route both to the SeasonEngine + the
// HumanSeasonTeamManager on the chosen team in one call.
class LoadSlotResult {
    expose Boolean ok;
    expose String error;
    expose season_model.FranchiseState? franchise;
    expose user_profile.UserProfile profile;

    // Default to a failed load. loadSlot overwrites all three fields on
    // success.
    expose func init() {
        ok = false;
        error = "";
        franchise = null;
        profile = new user_profile.UserProfile();
    }
}

// Load one save slot by franchise id. Returns a LoadSlotResult with
// ok=false and an error message on any failure (missing directory,
// missing franchise.save, parse error) — the shell surfaces the error
// string to the user verbatim.
func loadSlot(saveRoot: String, franchiseId: String) -> LoadSlotResult {
    var result = new LoadSlotResult();
    var franchiseDir = Path.Join(saveRoot, franchiseId);
    if !Dir.Exists(franchiseDir) {
        result.error = "save slot not found: " + franchiseId;
        return result;
    }
    var loadRes = persistence.loadFranchise(franchiseDir);
    if !loadRes.ok || loadRes.state == null {
        result.error = loadRes.error;
        return result;
    }
    result.ok = true;
    result.franchise = loadRes.state;
    result.profile = user_profile.load(franchiseDir);
    return result;
}

// Delete a save slot. Removes <saveRoot>/<franchiseId>/ and everything
// inside it. Fails silently if the slot doesn't exist. The shell should
// confirm with the user before calling this — deletion is irreversible.
func deleteSlot(saveRoot: String, franchiseId: String) {
    var franchiseDir = Path.Join(saveRoot, franchiseId);
    if Dir.Exists(franchiseDir) {
        Dir.RemoveAll(franchiseDir);
    }
}
