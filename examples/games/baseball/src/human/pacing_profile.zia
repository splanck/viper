// ============================================================================
// File: src/human/pacing_profile.zia
// Purpose: The four human-manager pacing profiles from plans/17 § Prompt
//          pacing profiles. A PacingProfile is the knob that controls how
//          many prompts the human sees per game. The human_manager_policy
//          and human_season_manager modules consult a PacingProfile at
//          every checkpoint to decide: prompt the user, or delegate to the
//          default AI policy.
//
//          Profile spec (from plan 17):
//            - observe_only       : human sets only the pregame lineup.
//                                   AI handles everything else.
//            - standard_manager   : human gets pregame + pitching change +
//                                   IBB + material substitution prompts.
//                                   This is the DEFAULT product experience.
//            - high_touch_manager : adds optional pre-pitch bunt / steal
//                                   prompts on top of standard_manager.
//            - commissioner_debug : every checkpoint fires, including the
//                                   per-pitch pitch-intent prompt. For
//                                   engine debugging, not the product
//                                   experience.
//
//          The class exposes boolean gates rather than comparing identifier
//          strings at every call site — simpler, faster, easier to grep for
//          "which profile enables X".
//
// Key invariants:
//          - Every checkpoint the human policy can surface is represented by
//            exactly one boolean gate on this class. Adding a new checkpoint
//            means adding a new gate here first, then turning it on in the
//            profiles that enable it.
//          - The four identifier strings are the only legal values of
//            PacingProfile.identifier. They appear in save files as the
//            HUMAN| header field, so changing them is a save-format
//            migration.
// Cross-refs:
//          - human_manager_policy.HumanManagerPolicy reads the gates.
//          - human_season_manager.HumanSeasonTeamManager reads
//            prompt_on_lineup.
//          - save_slot persists the identifier string in the franchise
//            header's HUMAN| line.
// ============================================================================
module pacing_profile;

// --- Profile identifiers. The franchise save file's HUMAN| header field
//     stores exactly one of these strings so the profile round-trips
//     across save/load. ---------------------------------------------------
final PROFILE_OBSERVE_ONLY = "observe_only";
final PROFILE_STANDARD_MANAGER = "standard_manager";
final PROFILE_HIGH_TOUCH_MANAGER = "high_touch_manager";
final PROFILE_COMMISSIONER_DEBUG = "commissioner_debug";

// One pacing profile. Carries the identifier string plus one boolean gate
// per checkpoint. The gates are expose-read-only by convention; callers
// never mutate them after construction. Use the `make*()` factories below
// to get a profile with the correct gates set for a given identifier.
class PacingProfile {
    expose String identifier;

    // The user sets the daily lineup card interactively. True for every
    // non-observe_only profile.
    expose Boolean prompt_on_lineup;
    // The engine asked "should we pull the pitcher here?" and the default
    // AI says yes. The human sees a pitching-change menu.
    expose Boolean prompt_on_pitching_change;
    // A pinch-hit / pinch-run / defensive-sub opportunity is material.
    // The engine calls decideSubstitutionAction before every between-PA
    // pitching check; the human sees a substitution menu only if this
    // gate is true AND the leverage filter passes.
    expose Boolean prompt_on_substitution;
    // An intentional-walk opportunity is worth surfacing. True for every
    // non-observe_only profile, but gated further by a leverage filter
    // so routine PAs never trigger.
    expose Boolean prompt_on_intentional_walk;
    // Pre-pitch bunt / steal prompts. Only high_touch_manager enables these.
    // Inert in v1 until plate_appearance_engine gains a pre-pitch checkpoint.
    expose Boolean prompt_on_bunt_steal;
    // Per-pitch pitch-intent prompt. Only commissioner_debug enables this —
    // every other profile delegates to the default AI's pitch-intent logic.
    expose Boolean prompt_per_pitch_intent;

    // Private constructor. Callers should use the make*() factories below
    // rather than setting gates by hand — that way "what does standard
    // enable?" has one authoritative answer.
    expose func init(id: String,
                     lineup: Boolean,
                     pitchingChange: Boolean,
                     substitution: Boolean,
                     intentionalWalk: Boolean,
                     buntSteal: Boolean,
                     pitchIntent: Boolean) {
        identifier = id;
        prompt_on_lineup = lineup;
        prompt_on_pitching_change = pitchingChange;
        prompt_on_substitution = substitution;
        prompt_on_intentional_walk = intentionalWalk;
        prompt_on_bunt_steal = buntSteal;
        prompt_per_pitch_intent = pitchIntent;
    }

    // True iff this profile surfaces any in-game checkpoint. observe_only
    // returns false (human only manages pregame); the other three return true.
    expose func hasInGamePrompts() -> Boolean {
        return prompt_on_pitching_change || prompt_on_substitution ||
               prompt_on_intentional_walk || prompt_on_bunt_steal ||
               prompt_per_pitch_intent;
    }
}

// observe_only — human sets only the pregame lineup. Plan 17: "human sets
// pregame lineup, AI handles the game". The absolute minimum interaction
// mode; useful for players who just want to pick the batting order each
// day and watch their team play.
func makeObserveOnly() -> PacingProfile {
    return new PacingProfile(PROFILE_OBSERVE_ONLY, true, false, false, false, false, false);
}

// standard_manager — plan 17's default product experience. Human gets the
// high-value prompts only: pregame lineup, pitching changes, intentional
// walks in tight late-inning situations, and material pinch-hit/run
// opportunities. Target: fewer than 10 prompts per full game so a game can
// be managed in a few minutes.
func makeStandardManager() -> PacingProfile {
    return new PacingProfile(PROFILE_STANDARD_MANAGER, true, true, true, true, false, false);
}

// high_touch_manager — adds optional pre-pitch bunt / steal prompts on top
// of standard_manager. Plan 17 flags these as opt-in because they fire
// frequently and can destroy pacing if enabled unintentionally. v1 exposes
// the gate but the engine does not yet have the pre-pitch call-site, so
// the bunt/steal prompt is inert until the plate-appearance engine gains
// that checkpoint.
func makeHighTouchManager() -> PacingProfile {
    return new PacingProfile(PROFILE_HIGH_TOUCH_MANAGER, true, true, true, true, true, false);
}

// commissioner_debug — every checkpoint including per-pitch pitch intent.
// Not a product mode. Used during engine development to step through a
// plate appearance pitch by pitch while inspecting the manager-visible
// context at each point. Pacing is deliberately slow; turning this on for
// normal play will produce thousands of prompts per game.
func makeCommissionerDebug() -> PacingProfile {
    return new PacingProfile(PROFILE_COMMISSIONER_DEBUG, true, true, true, true, true, true);
}

// Resolve an identifier string to a fresh PacingProfile instance. Unknown
// identifiers fall back to standard_manager so a corrupt save or an older
// save from before a new profile was added still loads cleanly.
func fromIdentifier(id: String) -> PacingProfile {
    if id == PROFILE_OBSERVE_ONLY {
        return makeObserveOnly();
    }
    if id == PROFILE_HIGH_TOUCH_MANAGER {
        return makeHighTouchManager();
    }
    if id == PROFILE_COMMISSIONER_DEBUG {
        return makeCommissionerDebug();
    }
    return makeStandardManager();
}
