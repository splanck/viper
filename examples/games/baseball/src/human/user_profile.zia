// ============================================================================
// File: src/human/user_profile.zia
// Purpose: The per-save "who is the user" record. Persisted alongside the
//          franchise files so that loading a save restores the user's chosen
//          team, pacing profile, and display name.
//
//          The profile is a single line of text in a file named `user.save`
//          under the franchise root. The format is tag-prefixed (matching
//          persistence.zia's style) so a human can read it with `cat`:
//
//              HUMAN|<userTeamId>|<pacingProfileId>|<managerName>
//
//          Saves created by the existing AI-only persistence layer don't
//          have this file; loadUserProfile returns a default UserProfile
//          (with empty fields) in that case. That preserves backwards
//          compatibility with probe-recorded saves.
//
// Cross-refs:
//          - save_slot.zia writes / reads this file.
//          - franchise_shell.zia reads it at boot to decide which team the
//            user is managing and which pacing profile to install on that
//            team's HumanSeasonTeamManager.
// ============================================================================
module user_profile;

bind Viper.IO.File as File;
bind Viper.IO.Path as Path;
bind Viper.String as String;
bind Viper.Collections.Seq as Seq;
bind "./pacing_profile";

// Sentinel used when no user profile was found on disk (legacy AI-only save).
// The shell treats this as "pick the defaults on next interactive prompt".
final PROFILE_TAG = "HUMAN";

// The user's identity for one save slot. Stored per-franchise (each save
// slot picks its own team + profile). managerName is purely cosmetic —
// shown in the decision log and the status bar — and has no engine effect.
class UserProfile {
    expose String managerName;
    expose String userTeamId;
    expose String pacingProfileId;
    expose Boolean hasProfile;

    // Construct a blank profile. The shell populates the fields at save
    // creation time; legacy loads leave them empty and hasProfile=false.
    expose func init() {
        managerName = "";
        userTeamId = "";
        pacingProfileId = pacing_profile.PROFILE_STANDARD_MANAGER;
        hasProfile = false;
    }
}

// Render one UserProfile as a single tagged line. Trailing newline is NOT
// included — callers typically append '\n' before writing.
func render(profile: UserProfile) -> String {
    return PROFILE_TAG + "|" + profile.userTeamId + "|" +
           profile.pacingProfileId + "|" + profile.managerName;
}

// Parse a single HUMAN|... line into a UserProfile. Returns a default
// profile (hasProfile=false) if the line is malformed or tag-mismatched.
func parse(line: String) -> UserProfile {
    var profile = new UserProfile();
    var parts = String.Split(line, "|");
    var count = Seq.get_Length(parts);
    if count < 4 {
        return profile;
    }
    if Seq.GetStr(parts, 0) != PROFILE_TAG {
        return profile;
    }
    profile.userTeamId = Seq.GetStr(parts, 1);
    profile.pacingProfileId = Seq.GetStr(parts, 2);
    profile.managerName = Seq.GetStr(parts, 3);
    profile.hasProfile = true;
    return profile;
}

// Persist a UserProfile to <franchiseDir>/user.save. Uses the same write-
// to-temp-then-rename atomic pattern as persistence.writeAtomic so a
// crashed save cannot leave a half-written user.save behind.
func save(franchiseDir: String, profile: UserProfile) {
    var path = Path.Join(franchiseDir, "user.save");
    var tmp = path + ".tmp";
    File.WriteAllText(tmp, render(profile) + "\n");
    if File.Exists(path) {
        File.Delete(path);
    }
    File.Move(tmp, path);
}

// Load the UserProfile from <franchiseDir>/user.save. Returns a default
// profile (hasProfile=false) if the file is missing — that's the legacy
// AI-only save case and callers should prompt for team + profile in that
// case.
func load(franchiseDir: String) -> UserProfile {
    var path = Path.Join(franchiseDir, "user.save");
    if !File.Exists(path) {
        return new UserProfile();
    }
    var text = File.ReadAllText(path);
    var lines = String.Split(text, "\n");
    if Seq.get_Length(lines) == 0 {
        return new UserProfile();
    }
    return parse(Seq.GetStr(lines, 0));
}
