// ============================================================================
// File: src/human/prompts.zia
// Purpose: All user-facing render + prompt logic for the human-manager mode.
//          Every `Viper.Terminal.Ask` / `ReadLine` in the project funnels
//          through this module so the rest of the codebase (policies,
//          season-level manager, shell) stays free of direct I/O.
//
//          Two classes of function live here:
//            - render*  : pure, return List[String]. No I/O. Testable without
//                         stubbing stdin. Used both by prompts.* (to build
//                         the menu display) and by the shell's status views.
//            - prompt*  : do I/O, return typed results (ManagerAction or a
//                         small PromptResult wrapper). Consume render*
//                         output, then call into Terminal.Ask / ReadLine.
//
// Information boundary (plan 17 § Information boundary):
//          Every player render routes through ManagerVisiblePlayerCard.
//          Reading `player.contact`, `rawPower`, `stuff`, `stamina`, etc. in
//          this file is forbidden — those are hidden talent ratings that
//          the manager is not supposed to see. The verification probe
//          greps this file for those field names and fails if any appear.
//
// Delegation verbs (plan 17 § Delegation and autopilot):
//          A small number of typed-string verbs let the user delegate a
//          single checkpoint ("auto"), the rest of the game ("auto game"),
//          or the rest of the day ("auto day") to the AI. They surface as
//          a typed PromptResult rather than mixing into the numeric menu
//          choice so callers can route them cleanly.
// ============================================================================
module prompts;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind Viper.Core.Parse as Parse;
bind "../model/game_state";
bind "../model/lineup_card";
bind "../model/player";
bind "../model/constants";
bind "../sim/manager_action";
bind "../season/manager_context";
bind "../season/season_model";

// --- Delegation verbs. User can type any of these in any numeric prompt
//     to skip interactive control. ------------------------------------------
final VERB_AUTO = "auto";
final VERB_AUTO_GAME = "auto game";
final VERB_AUTO_DAY = "auto day";
final VERB_QUIT = "quit";

// --- PromptResult kinds. Every prompt helper returns one of these so the
//     caller can route the outcome without parsing strings. ------------------
final RESULT_ACTION = "action";         // Normal typed ManagerAction chosen.
final RESULT_AUTO = "auto";             // User delegated this checkpoint.
final RESULT_AUTO_GAME = "auto_game";   // User delegated the rest of the game.
final RESULT_AUTO_DAY = "auto_day";     // User delegated the rest of the day.
final RESULT_QUIT = "quit";             // User aborted; caller should unwind.
final RESULT_NOOP = "noop";             // User chose "no change" — valid but
                                        // distinct from delegation.

// One typed prompt outcome. Either carries a ManagerAction (RESULT_ACTION /
// RESULT_NOOP — the latter with kind == ACTION_NOOP) or is a delegation /
// quit signal with action == null.
class PromptResult {
    expose String kind;
    expose manager_action.ManagerAction? action;

    expose func init(k: String, a: manager_action.ManagerAction?) {
        kind = k;
        action = a;
    }
}

// =========================================================================
// Low-level input parsing
// =========================================================================

// Read a line from stdin, trimmed. Returns empty string on EOF so callers
// don't have to unwrap null everywhere. Delegation verbs flow through here
// untouched so prompts can scan for them.
func readLineTrimmed() -> String {
    var raw = Terminal.ReadLine();
    if raw == null {
        return "";
    }
    return raw!.Trim();
}

// Parse a line as a non-negative integer. Returns -1 if the line is empty
// or not parseable — caller uses -1 as the "invalid" sentinel.
func parseInteger(s: String) -> Integer {
    if s.length() == 0 {
        return -1;
    }
    return Parse.IntOr(s, -1);
}

// Classify an input line as a delegation verb or regular choice. Returns
// one of RESULT_AUTO / RESULT_AUTO_GAME / RESULT_AUTO_DAY / RESULT_QUIT /
// RESULT_ACTION (the last means "not a verb — caller should parse the line
// as a normal choice").
func classifyVerb(line: String) -> String {
    var lower = line.ToLower();
    if lower == VERB_QUIT {
        return RESULT_QUIT;
    }
    if lower == VERB_AUTO_GAME {
        return RESULT_AUTO_GAME;
    }
    if lower == VERB_AUTO_DAY {
        return RESULT_AUTO_DAY;
    }
    if lower == VERB_AUTO {
        return RESULT_AUTO;
    }
    return RESULT_ACTION;
}

// =========================================================================
// Rendering — pure, no I/O
// =========================================================================

// One-line situation summary: inning / score / outs / count / base state.
// Used at the top of every in-game prompt so the user always sees the
// state they're deciding on.
func renderGameSituation(state: game_state.GameState) -> List[String] {
    var lines: List[String] = [];
    var half = "Top";
    if !state.topHalf {
        half = "Bot";
    }
    lines.add(half + " " + Fmt.Int(state.inning) + "  " +
              state.away.teamRef.fullName + " " + Fmt.Int(state.away.score) + " - " +
              state.home.teamRef.fullName + " " + Fmt.Int(state.home.score));
    var bases = "---";
    if state.firstBase != null {
        bases = "1--";
    }
    if state.secondBase != null {
        if state.firstBase != null {
            bases = "12-";
        } else {
            bases = "-2-";
        }
    }
    if state.thirdBase != null {
        // Simple composition: rebuild with third present.
        var b1 = "-";
        var b2 = "-";
        if state.firstBase != null {
            b1 = "1";
        }
        if state.secondBase != null {
            b2 = "2";
        }
        bases = b1 + b2 + "3";
    }
    lines.add("outs=" + Fmt.Int(state.outs) + "  count=" +
              Fmt.Int(state.balls) + "-" + Fmt.Int(state.strikes) +
              "  bases=" + bases);
    return lines;
}

// Render the active pitcher's current-stint line. Used in the
// pitching-change prompt so the user sees how tired the starter is before
// deciding to pull them. Shows only manager-visible information — name,
// stint pitches, runs allowed, and derived fatigue bucket. True stamina
// value is never shown.
func renderPitcherLine(defense: game_state.TeamGameState) -> List[String] {
    var lines: List[String] = [];
    var p = defense.lineup.activePitcher;
    if p == null {
        lines.add("Current pitcher: (none)");
        return lines;
    }
    var line = defense.currentPitchingLine();
    lines.add("Current pitcher: " + p!.name +
              "  pitches=" + Fmt.Int(line.pitches) +
              "  R=" + Fmt.Int(line.R) +
              "  K=" + Fmt.Int(line.SO) +
              "  BB=" + Fmt.Int(line.BB));
    return lines;
}

// Render each eligible bullpen arm as a numbered option. Consumed by the
// pitching-change menu. Only shows manager-visible information: name,
// handedness, role-hint-derived tag. Appearance/rest state comes from the
// season layer when available; in-game only we render a short placeholder.
func renderBullpenOptions(defense: game_state.TeamGameState) -> List[String] {
    var lines: List[String] = [];
    lines.add("Bullpen:");
    var bp = defense.lineup.bullpen;
    if bp.length() == 0 {
        lines.add("  (none available)");
        return lines;
    }
    for i in 0..bp.length() {
        var p = bp.get(i);
        lines.add("  " + Fmt.Int(i + 1) + ". " + p.name +
                  " (" + p.throwsHand + "HP)");
    }
    return lines;
}

// Render each bench player as a numbered option. Used by the
// substitution menu. Same information-boundary rule — name, handedness,
// primary position only.
func renderBenchOptions(offense: game_state.TeamGameState) -> List[String] {
    var lines: List[String] = [];
    lines.add("Bench:");
    var bench = offense.lineup.bench;
    if bench.length() == 0 {
        lines.add("  (empty)");
        return lines;
    }
    for i in 0..bench.length() {
        var p = bench.get(i);
        lines.add("  " + Fmt.Int(i + 1) + ". " + p.name +
                  " (" + p.bats + "B/" + p.throwsHand + "T, " +
                  p.primaryPosition + ")");
    }
    return lines;
}

// Render the pregame lineup that's been built (AI default or edit in
// progress). Pure function — returns List[String] so the shell can dump
// it into its output stream.
func renderLineupCard(card: lineup_card.LineupCard) -> List[String] {
    var lines: List[String] = [];
    lines.add(card.teamRef.fullName);
    var pitcher = card.activePitcher;
    if pitcher != null {
        lines.add("  P: " + pitcher!.name);
    }
    for i in 0..card.battingOrder.length() {
        var p = card.battingOrder.get(i);
        var pos = "";
        if i < card.battingPositions.length() {
            pos = card.battingPositions.get(i);
        }
        lines.add("  " + Fmt.Int(i + 1) + ". " + p.name + " (" + pos + ")");
    }
    if card.bench.length() > 0 {
        lines.add("  Bench: " + Fmt.Int(card.bench.length()));
    }
    if card.bullpen.length() > 0 {
        lines.add("  Bullpen: " + Fmt.Int(card.bullpen.length()));
    }
    return lines;
}

// Render a manager-visible player card (used by the shell roster view +
// the pregame context view). Routes every read through the scouting-grade
// accessors, never through the raw Player object.
func renderVisibleCard(card: manager_context.ManagerVisiblePlayerCard) -> String {
    return card.playerName + " (" + card.bats + "B/" + card.throwsHand + "T, " +
           card.primaryPosition + ")  OFF=" + Fmt.Int(card.offenseGrade) +
           " DEF=" + Fmt.Int(card.defenseGrade) +
           " PIT=" + Fmt.Int(card.pitchingGrade) +
           "  [" + card.readinessTier + "]";
}

// =========================================================================
// Output helpers — write a List[String] block to the terminal
// =========================================================================

func sayLines(lines: List[String]) {
    for i in 0..lines.length() {
        Terminal.Say(lines.get(i));
    }
}

func sayBlank() {
    Terminal.Say("");
}

// =========================================================================
// Numbered menu — the generic prompt primitive
// =========================================================================

// Present a numbered menu, return the 1-based choice the user picked (or
// a delegation verb / quit). The caller supplies the menu options as a
// pre-built list; the helper adds the numbering and the prompt string.
// Invalid input re-prompts. On EOF the helper returns RESULT_QUIT so the
// shell can unwind gracefully.
func promptMenuChoice(header: String, options: List[String]) -> PromptResult {
    if options.length() == 0 {
        return new PromptResult(RESULT_NOOP, null);
    }
    while true {
        Terminal.Say(header);
        for i in 0..options.length() {
            Terminal.Say("  " + Fmt.Int(i + 1) + ") " + options.get(i));
        }
        Terminal.Print("Choose 1-" + Fmt.Int(options.length()) +
                       " (or auto / auto game / auto day / quit): ");
        var line = readLineTrimmed();
        if line.length() == 0 {
            return new PromptResult(RESULT_QUIT, null);
        }
        var verb = classifyVerb(line);
        if verb != RESULT_ACTION {
            return new PromptResult(verb, null);
        }
        var n = parseInteger(line);
        if n < 1 || n > options.length() {
            Terminal.Say("  (invalid choice, try again)");
            continue;
        }
        var ok = new manager_action.ManagerAction(manager_action.ACTION_NOOP, "menu_choice");
        ok.intentValue = Fmt.Int(n);
        ok.subSlot = n;
        return new PromptResult(RESULT_ACTION, ok);
    }
    return new PromptResult(RESULT_QUIT, null);
}

// =========================================================================
// Checkpoint prompts — called from HumanManagerPolicy
// =========================================================================

// Prompt the manager whether to issue an intentional walk against the
// current batter. Two numbered options: pitch to him (NOOP) or walk.
func promptIntentionalWalk(state: game_state.GameState,
                           batter: player.Player) -> PromptResult {
    sayBlank();
    Terminal.Say("-- Intentional walk decision --");
    sayLines(renderGameSituation(state));
    Terminal.Say("Batter: " + batter.name);
    var options: List[String] = [];
    options.add("Pitch to him");
    options.add("Issue intentional walk");
    var res = promptMenuChoice("Manager decision:", options);
    if res.kind != RESULT_ACTION {
        return res;
    }
    var slot = res.action!.subSlot;
    if slot == 2 {
        var act = new manager_action.ManagerAction(
            manager_action.ACTION_ISSUE_INTENTIONAL_WALK, "human_ibb");
        return new PromptResult(RESULT_ACTION, act);
    }
    return new PromptResult(RESULT_NOOP,
        new manager_action.ManagerAction(manager_action.ACTION_NOOP, "human_pitch_to_him"));
}

// Prompt the manager for a pitching-change decision. Shows the current
// pitcher line, then each eligible reliever as a numbered option. Option 0
// is always "keep current pitcher".
func promptPitchingChange(state: game_state.GameState,
                          defense: game_state.TeamGameState) -> PromptResult {
    sayBlank();
    Terminal.Say("-- Pitching change decision --");
    sayLines(renderGameSituation(state));
    sayLines(renderPitcherLine(defense));
    sayLines(renderBullpenOptions(defense));
    var options: List[String] = [];
    options.add("Keep current pitcher");
    var bp = defense.lineup.bullpen;
    for i in 0..bp.length() {
        options.add("Bring in " + bp.get(i).name);
    }
    var res = promptMenuChoice("Manager decision:", options);
    if res.kind != RESULT_ACTION {
        return res;
    }
    var slot = res.action!.subSlot;
    if slot == 1 {
        return new PromptResult(RESULT_NOOP,
            new manager_action.ManagerAction(manager_action.ACTION_NOOP, "human_stick_with_pitcher"));
    }
    var act = new manager_action.ManagerAction(manager_action.ACTION_CHANGE_PITCHER, "human_change");
    act.pitcherChoice = bp.get(slot - 2);
    return new PromptResult(RESULT_ACTION, act);
}

// Prompt the manager for a between-PA substitution (pinch hit / pinch run
// / defensive switch). Offers: keep lineup, or swap slot N with bench
// player M. The two-step flow (pick slot, pick bench player) stays inside
// this single prompt so the caller doesn't have to model it.
func promptSubstitution(state: game_state.GameState,
                        offense: game_state.TeamGameState) -> PromptResult {
    sayBlank();
    Terminal.Say("-- Substitution opportunity --");
    sayLines(renderGameSituation(state));
    var bench = offense.lineup.bench;
    if bench.length() == 0 {
        Terminal.Say("(bench is empty — no substitution possible)");
        return new PromptResult(RESULT_NOOP,
            new manager_action.ManagerAction(manager_action.ACTION_NOOP, "bench_empty"));
    }

    // Step 1: slot to replace (or keep lineup).
    var slotOptions: List[String] = [];
    slotOptions.add("Keep lineup as-is");
    var order = offense.lineup.battingOrder;
    for i in 0..order.length() {
        var pos = "";
        if i < offense.lineup.battingPositions.length() {
            pos = offense.lineup.battingPositions.get(i);
        }
        slotOptions.add("Replace slot " + Fmt.Int(i + 1) + ": " +
                        order.get(i).name + " (" + pos + ")");
    }
    var slotRes = promptMenuChoice("Which slot?", slotOptions);
    if slotRes.kind != RESULT_ACTION {
        return slotRes;
    }
    var slotChoice = slotRes.action!.subSlot;
    if slotChoice == 1 {
        return new PromptResult(RESULT_NOOP,
            new manager_action.ManagerAction(manager_action.ACTION_NOOP, "human_keep_lineup"));
    }
    var targetSlot = slotChoice - 1;

    // Step 2: bench player to insert.
    sayLines(renderBenchOptions(offense));
    var benchOptions: List[String] = [];
    for i in 0..bench.length() {
        benchOptions.add(bench.get(i).name);
    }
    var benchRes = promptMenuChoice("Bring in whom?", benchOptions);
    if benchRes.kind != RESULT_ACTION {
        return benchRes;
    }
    var benchChoice = benchRes.action!.subSlot;
    var act = new manager_action.ManagerAction(
        manager_action.ACTION_MAKE_SUBSTITUTION, "human_substitution");
    act.subSlot = targetSlot;
    act.subOut = order.get(targetSlot - 1);
    act.subIn = bench.get(benchChoice - 1);
    return new PromptResult(RESULT_ACTION, act);
}

// =========================================================================
// Pregame lineup builder
// =========================================================================

// Prompt the manager to accept or edit the AI-generated daily lineup card.
// The AI has already built a legal card; the human can accept, change the
// starter, or reorder the batting slots. Returns the final LineupCard
// (guaranteed legal at the caller's legality check).
//
// The AI-built card is passed in rather than re-built here so the
// HumanSeasonTeamManager can reuse the base class's logic verbatim.
func promptLineupCard(ctx: manager_context.PregameLineupContext,
                      aiCard: lineup_card.LineupCard) -> PromptResult {
    sayBlank();
    Terminal.Say("======================================================");
    Terminal.Say("PREGAME LINEUP — " + ctx.teamName + " vs " + ctx.opponentTeamName);
    Terminal.Say("  Ballpark: " + ctx.ballparkName +
                 "  DH: " + (ctx.useDh ? "on" : "off"));
    Terminal.Say("======================================================");
    var card = aiCard;
    while true {
        sayBlank();
        sayLines(renderLineupCard(card));
        var options: List[String] = [];
        options.add("Accept this lineup");
        options.add("Change starting pitcher");
        options.add("Swap two batting slots");
        options.add("View my roster");
        var res = promptMenuChoice("Lineup menu:", options);
        if res.kind == RESULT_QUIT {
            return res;
        }
        if res.kind == RESULT_AUTO || res.kind == RESULT_AUTO_GAME ||
           res.kind == RESULT_AUTO_DAY {
            // Delegation from the lineup menu == accept AI default.
            return new PromptResult(RESULT_ACTION, lineupAction(card));
        }
        var slot = res.action!.subSlot;
        if slot == 1 {
            return new PromptResult(RESULT_ACTION, lineupAction(card));
        }
        if slot == 2 {
            self_changeStarter(card, ctx);
            continue;
        }
        if slot == 3 {
            self_swapBattingSlots(card);
            continue;
        }
        if slot == 4 {
            self_showRoster(ctx);
            continue;
        }
    }
    return new PromptResult(RESULT_QUIT, null);
}

// Helper: change the starting pitcher. Asks the user which pitcher to
// start today from the bullpen options. If the user picks the current
// starter, nothing happens. The swap removes the new starter from the
// bullpen and adds the previous starter back into it (so they remain
// available for relief later in the week). This is a simplification of
// real rotation mechanics but keeps the daily lineup self-contained.
func self_changeStarter(card: lineup_card.LineupCard,
                        ctx: manager_context.PregameLineupContext) {
    if card.activePitcher == null {
        Terminal.Say("(no current starter — cannot change)");
        return;
    }
    var bp = card.bullpen;
    if bp.length() == 0 {
        Terminal.Say("(bullpen is empty — no other starter available)");
        return;
    }
    var options: List[String] = [];
    options.add("Keep " + card.activePitcher!.name);
    for i in 0..bp.length() {
        options.add(bp.get(i).name + " (" + bp.get(i).throwsHand + "HP)");
    }
    var res = promptMenuChoice("Starting pitcher:", options);
    if res.kind != RESULT_ACTION {
        return;
    }
    var slot = res.action!.subSlot;
    if slot == 1 {
        return;
    }
    var newStarter = bp.get(slot - 2);
    var old = card.activePitcher!;
    // Remove newStarter from bullpen, add old starter as reliever.
    bp.removeAt(slot - 2);
    bp.add(old);
    card.setPitcher(newStarter);
    // If this is a DH-off game, also swap the pitcher into the batting
    // order at whatever slot the old pitcher occupied. DH-on: nothing to do,
    // since the pitcher isn't in the batting order.
    if !ctx.useDh {
        for i in 0..card.battingOrder.length() {
            if card.battingOrder.get(i).id == old.id {
                card.battingOrder.set(i, newStarter);
                break;
            }
        }
    }
    Terminal.Say("Starting pitcher changed to " + newStarter.name + ".");
}

// Helper: swap two slots in the batting order. User picks two 1-9
// numbers; the helper exchanges them. The fielding position at each slot
// follows the player.
func self_swapBattingSlots(card: lineup_card.LineupCard) {
    Terminal.Print("First slot (1-" + Fmt.Int(card.battingOrder.length()) + "): ");
    var a = parseInteger(readLineTrimmed());
    Terminal.Print("Second slot (1-" + Fmt.Int(card.battingOrder.length()) + "): ");
    var b = parseInteger(readLineTrimmed());
    if a < 1 || a > card.battingOrder.length() ||
       b < 1 || b > card.battingOrder.length() ||
       a == b {
        Terminal.Say("(invalid slots)");
        return;
    }
    var pa = card.battingOrder.get(a - 1);
    var pb = card.battingOrder.get(b - 1);
    var posa = card.battingPositions.get(a - 1);
    var posb = card.battingPositions.get(b - 1);
    card.battingOrder.set(a - 1, pb);
    card.battingOrder.set(b - 1, pa);
    card.battingPositions.set(a - 1, posb);
    card.battingPositions.set(b - 1, posa);
    Terminal.Say("Slots " + Fmt.Int(a) + " and " + Fmt.Int(b) + " swapped.");
}

// Helper: dump the full active-roster scouting view (grade summary for
// every player in the pregame context). No I/O side effect beyond output.
func self_showRoster(ctx: manager_context.PregameLineupContext) {
    sayBlank();
    Terminal.Say("Active roster — " + ctx.teamName);
    for i in 0..ctx.players.length() {
        Terminal.Say("  " + renderVisibleCard(ctx.players.get(i)));
    }
}

// Build a SUBMIT_LINEUP ManagerAction from a completed card. Used by the
// lineup-builder return path.
func lineupAction(card: lineup_card.LineupCard) -> manager_action.ManagerAction {
    var act = new manager_action.ManagerAction(
        manager_action.ACTION_SUBMIT_LINEUP, "human_lineup");
    act.lineupChoice = card;
    act.pitcherChoice = card.activePitcher;
    return act;
}

// =========================================================================
// Leverage filter (used by HumanManagerPolicy before surfacing a prompt)
// =========================================================================

// Plan 17: "do not prompt the human at every micro-event by default".
// This helper returns true iff the current between-PA state is a material
// substitution opportunity — runners in scoring position in the 7th+ OR
// a tight late-inning lead. Everything else is routine and the policy
// will return NOOP without prompting.
func isMaterialSubstitutionMoment(state: game_state.GameState) -> Boolean {
    if state.inning < 7 {
        return false;
    }
    // Runners in scoring position — pinch-hit opportunity.
    if state.secondBase != null || state.thirdBase != null {
        return true;
    }
    // Tight game in the 9th or later — defensive-sub opportunity.
    var diff = state.home.score - state.away.score;
    if diff < 0 { diff = -diff; }
    if state.inning >= 9 && diff <= 2 {
        return true;
    }
    return false;
}

// Same logic for intentional-walk prompts — only surface in the 7th+ with
// a runner in scoring position AND first base open. Prevents
// "prompt on every late-game PA" fatigue.
func isMaterialIntentionalWalkMoment(state: game_state.GameState) -> Boolean {
    if state.inning < 7 {
        return false;
    }
    if state.firstBase != null {
        return false;
    }
    return state.secondBase != null || state.thirdBase != null;
}
