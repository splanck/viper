// ============================================================================
// File: src/season/manager_layer.zia
// Purpose: The season-level manager layer. Bridges the typed in-game manager
//          policy (manager_policy.DefaultManagerPolicy) up to the season-
//          scope decisions a real manager makes between games — building
//          today's lineup card from active-roster compartments, validating
//          that lineup against the three-tier legality check (compartment +
//          single-game + availability), and exposing a "manager-visible
//          player card" view that hides hidden true ratings behind a coarse
//          scouting projection.
//
//          Plan 14 § Manager-visible player view + § Decision context types
//          is the design. The plan calls for an interface; for v1 the
//          implementation is a single concrete `SeasonTeamManager` class
//          that owns one `DefaultManagerPolicy` instance for in-game decisions
//          and adds the season-level method surface (build context, build
//          lineup, validate).
//
// Types:
//          - ManagerVisiblePlayerCard: the redacted player view a manager
//            sees at decision time. Hides true ratings behind grade averages.
//          - PregameLineupContext: the read-only context handed to the
//            policy at lineup-card submission.
//          - ValidationResult: typed (ok, error) result from
//            validateLineupForToday.
//          - LineupSlot: temporary (player, position) pair used while sorting
//            the batting order.
//          - SeasonTeamManager: the main class. One instance per team per
//            season.
//
// Cross-refs:
//          - season_engine consults submitPregameLineup + validateLineupForToday
//            from the daily simulation loop.
//          - The inGamePolicy field is what the game engine receives via
//            engine.setPolicies for in-game decisions.
//          - Plans 09, 11, 12, 14 all interlock here.
// ============================================================================
module manager_layer;

bind Viper.Terminal as Terminal;
bind "../model/constants";
bind "../model/player";
bind "../model/lineup_card";
bind "../model/ruleset";
bind "../sim/manager_action";
bind "../sim/manager_policy";
bind "./manager_context";
bind "./season_model";
bind "./date_utils";
bind "../human/pacing_profile";
bind "../human/prompts";

// The value types ManagerVisiblePlayerCard / PregameLineupContext /
// ValidationResult / LineupSlot used to live here; they now live in
// ./manager_context.zia so the human/prompts module can bind them
// without forming a cycle through this file (which itself now binds
// prompts for HumanSeasonTeamManager).

// One team's season-level manager. Owns the in-game policy (which the game
// engine consults at every checkpoint) plus the season-scope methods that
// build daily lineup cards and validate them against the active roster.
class SeasonTeamManager {
    expose String policyName;
    expose manager_policy.DefaultManagerPolicy inGamePolicy;

    // Construct a manager with a display name. Creates a fresh in-game
    // policy and labels it with the same name so decision-log entries are
    // attributable to the team.
    expose func init(name: String) {
        policyName = name;
        inGamePolicy = new manager_policy.DefaultManagerPolicy();
        inGamePolicy.setPolicyName(name);
    }

    // Build a manager-visible player card from a roster entry + that
    // player's current availability snapshot. Computes coarse grade
    // averages for offense/defense/pitching from the true ratings — the
    // grades are deterministic but obviously lower-fidelity than reading
    // the underlying ratings, so a smarter scouting layer can later map
    // them with uncertainty.
    expose func buildVisibleCard(entry: season_model.RosterEntry,
                                 availability: season_model.AvailabilitySnapshot) -> ManagerVisiblePlayerCard {
        var p = entry.playerRef;
        var card = new ManagerVisiblePlayerCard();
        card.playerId = p.id;
        card.playerName = p.name;
        card.bats = p.bats;
        card.throwsHand = p.throwsHand;
        card.primaryPosition = p.primaryPosition;
        card.roleTag = entry.roleTag;
        card.offenseGrade = (p.zoneJudgment + p.contact + p.gamePower + p.hardContact) / 4;
        card.defenseGrade = (p.range + p.reaction + p.hands + p.armStrength + p.armAccuracy) / 5;
        card.pitchingGrade = (p.stuff + p.control + p.command + p.movement + p.stamina) / 5;
        card.readinessTier = availability.readinessTier;
        card.availableForGame = availability.availableForGame;
        card.recommendedRest = availability.recommendedRest;
        card.workloadSummary = availability.workloadSummary;
        return card;
    }

    // Build the PregameLineupContext for the policy: bundle today's date,
    // both teams' identities, the home park name, the DH rule, and a
    // visible card for every active-roster player.
    expose func buildPregameContext(teamState: season_model.TeamSeasonState,
                                    opponentState: season_model.TeamSeasonState,
                                    day: Integer,
                                    rules: ruleset.Ruleset) -> PregameLineupContext {
        var ctx = new PregameLineupContext(day, teamState.teamRef.id, teamState.teamRef.fullName,
                                           opponentState.teamRef.id, opponentState.teamRef.fullName,
                                           teamState.homePark.name, rules.designatedHitterEnabled);
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            if entry.compartment != season_model.COMPARTMENT_ACTIVE_HITTERS &&
               entry.compartment != season_model.COMPARTMENT_ACTIVE_PITCHERS {
                continue;
            }
            ctx.players.add(self.buildVisibleCard(entry, teamState.getAvailability(entry.playerRef.id)));
        }
        return ctx;
    }

    // Build today's full lineup card. Picks a starter from the rotation,
    // assigns each fielding position to the best-fit available active
    // hitter, fills the DH slot or pitcher's batting slot per the ruleset,
    // sorts the resulting nine into a hand-tuned batting order, and adds
    // the bench + bullpen pools. Returns a typed ManagerAction containing
    // the constructed lineup card and the chosen starter, or an early-out
    // NOOP action with an error rationale if any required slot can't be
    // filled.
    expose func submitPregameLineup(teamState: season_model.TeamSeasonState,
                                    opponentState: season_model.TeamSeasonState,
                                    day: Integer,
                                    rules: ruleset.Ruleset) -> manager_action.ManagerAction {
        var action = new manager_action.ManagerAction(manager_action.ACTION_SUBMIT_LINEUP,
                                                      "default_lineup_builder");
        var card = new lineup_card.LineupCard(teamState.teamRef, rules.designatedHitterEnabled);

        var starter = self.chooseStarter(teamState);
        if starter == null {
            return new manager_action.ManagerAction(manager_action.ACTION_NOOP, "no_available_starter");
        }
        card.setPitcher(starter!);

        var used: List[String] = [];
        var positions = [constants.POS_C, constants.POS_1B, constants.POS_2B, constants.POS_3B,
                         constants.POS_SS, constants.POS_LF, constants.POS_CF, constants.POS_RF];
        var starters: List[player.Player] = [];
        var starterPositions: List[String] = [];

        // Fill each of the eight fielding positions with the best-fit
        // available player. Bail out early if any position can't be filled.
        for i in 0..positions.length() {
            var chosen = self.pickStarterAtPosition(teamState, positions.get(i), used);
            if chosen == null {
                return new manager_action.ManagerAction(manager_action.ACTION_NOOP,
                                                        "missing_starter_" + positions.get(i));
            }
            used.add(chosen!.id);
            starters.add(chosen!);
            starterPositions.add(positions.get(i));
        }

        // DH-on: pick a 9th hitter for the DH slot. DH-off: the pitcher
        // takes the 9th batting slot.
        if rules.designatedHitterEnabled {
            var dh = self.pickBestRemainingHitter(teamState, used);
            if dh == null {
                return new manager_action.ManagerAction(manager_action.ACTION_NOOP, "missing_designated_hitter");
            }
            used.add(dh!.id);
            starters.add(dh!);
            starterPositions.add(constants.POS_DH);
        } else {
            used.add(starter!.id);
            starters.add(starter!);
            starterPositions.add(constants.POS_P);
        }

        // Sort the nine into a batting order using the hand-tuned heuristic
        // in extractBestSlot, then install on the lineup card.
        var ordered = self.orderLineup(starters, starterPositions);
        for i in 0..ordered.length() {
            card.addStarter(ordered.get(i).playerRef, ordered.get(i).position);
        }

        // Add bench and bullpen options.
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            var availability = teamState.getAvailability(p.id);
            if entry.compartment == season_model.COMPARTMENT_ACTIVE_HITTERS &&
               availability.availableForGame &&
               !self.hasPlayer(used, p.id) {
                card.addBench(p);
            }
        }
        self.addBullpenArms(card, teamState, starter!.id);

        action.lineupChoice = card;
        action.pitcherChoice = starter;
        action.rationale = "default_lineup_" + date_utils.fromDaysText(day);
        return action;
    }

    // The three-tier legality check from plan 11 § Legality checks. Verifies
    // active-roster caps + pitcher-cap, then the active pitcher is on the
    // active pitchers compartment and available, then every batter in the
    // batting order is on the active hitters compartment (or, in a no-DH
    // game, is the active pitcher) and available, then finally the
    // single-game LineupCard.validateStart check from plan 09. Returns a
    // typed ValidationResult with a specific error message on the first
    // tier that fails.
    expose func validateLineupForToday(teamState: season_model.TeamSeasonState,
                                       card: lineup_card.LineupCard,
                                       rules: ruleset.Ruleset) -> ValidationResult {
        var result = new ValidationResult();
        if teamState.activeHittersCount() + teamState.activePitchersCount() > rules.activeRosterSize {
            result.ok = false;
            result.error = "active roster exceeds ruleset cap";
            return result;
        }
        if teamState.activePitchersCount() > rules.maxActivePitchers {
            result.ok = false;
            result.error = "active pitcher count exceeds ruleset cap";
            return result;
        }
        if card.activePitcher == null {
            result.ok = false;
            result.error = "lineup missing active pitcher";
            return result;
        }
        var pitcherEntry = teamState.getEntry(card.activePitcher!.id);
        if pitcherEntry == null || pitcherEntry!.compartment != season_model.COMPARTMENT_ACTIVE_PITCHERS {
            result.ok = false;
            result.error = "active pitcher is not on active pitcher roster";
            return result;
        }
        var pitcherAvailability = teamState.getAvailability(card.activePitcher!.id);
        if !pitcherAvailability.availableForGame {
            result.ok = false;
            result.error = "active pitcher is unavailable today";
            return result;
        }
        for i in 0..card.battingOrder.length() {
            var batter = card.battingOrder.get(i);
            var entry = teamState.getEntry(batter.id);
            if entry == null {
                result.ok = false;
                result.error = "lineup hitter not on roster: " + batter.name;
                return result;
            }
            // The batting order normally draws from active hitters, but in a
            // no-DH game the active pitcher legally appears in the batting
            // order at position POS_P. Allow that exact case (the pitcher must
            // also be the active pitcher of the same lineup card).
            var inHitters = entry!.compartment == season_model.COMPARTMENT_ACTIVE_HITTERS;
            var pitcherBatting = (!rules.designatedHitterEnabled) &&
                                 entry!.compartment == season_model.COMPARTMENT_ACTIVE_PITCHERS &&
                                 card.activePitcher != null &&
                                 card.activePitcher!.id == batter.id;
            if !inHitters && !pitcherBatting {
                result.ok = false;
                result.error = "lineup hitter is not on active hitters roster: " + batter.name;
                return result;
            }
            var availability = teamState.getAvailability(batter.id);
            if !availability.availableForGame {
                result.ok = false;
                result.error = "lineup hitter unavailable today: " + batter.name;
                return result;
            }
        }
        if !card.validateStart() {
            result.ok = false;
            result.error = "lineup card failed single-game legality";
            return result;
        }
        return result;
    }

    // Pick today's starter. First tries the rotation order (round-robin
    // through teamState.rotationOrder, skipping unavailable arms), then
    // falls back to the first available active pitcher if the rotation
    // search exhausts itself. Returns null if no pitcher is available at
    // all.
    hide func chooseStarter(teamState: season_model.TeamSeasonState) -> player.Player? {
        if teamState.rotationOrder.length() > 0 {
            var checked = 0;
            var idx = teamState.nextStarterIndex;
            while checked < teamState.rotationOrder.length() {
                var playerId = teamState.rotationOrder.get(idx);
                var entry = teamState.getEntry(playerId);
                if entry != null &&
                   entry!.compartment == season_model.COMPARTMENT_ACTIVE_PITCHERS &&
                   teamState.getAvailability(playerId).availableForGame {
                    return entry!.playerRef;
                }
                checked = checked + 1;
                idx = idx + 1;
                if idx >= teamState.rotationOrder.length() {
                    idx = 0;
                }
            }
        }
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            if entry.compartment == season_model.COMPARTMENT_ACTIVE_PITCHERS &&
               teamState.getAvailability(entry.playerRef.id).availableForGame {
                return entry.playerRef;
            }
        }
        return null;
    }

    // Pick the best-fit available active hitter for a given fielding
    // position. Scores each candidate via positionScore, applies a
    // recommended-rest penalty for tired players, and returns the highest
    // score. Returns null if no eligible player exists.
    hide func pickStarterAtPosition(teamState: season_model.TeamSeasonState,
                                    position: String,
                                    used: List[String]) -> player.Player? {
        var best: player.Player? = null;
        var bestScore = -9999;
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            if entry.compartment != season_model.COMPARTMENT_ACTIVE_HITTERS {
                continue;
            }
            if self.hasPlayer(used, p.id) {
                continue;
            }
            var availability = teamState.getAvailability(p.id);
            if !availability.availableForGame {
                continue;
            }
            var score = self.positionScore(entry, position);
            if availability.recommendedRest {
                score = score - 8;
            }
            if score > bestScore {
                best = p;
                bestScore = score;
            }
        }
        return best;
    }

    // Pick the best remaining active hitter to fill the DH slot. Scoring
    // here is purely offensive (no positional fit) since the DH never plays
    // defense.
    hide func pickBestRemainingHitter(teamState: season_model.TeamSeasonState,
                                      used: List[String]) -> player.Player? {
        var best: player.Player? = null;
        var bestScore = -9999;
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            if entry.compartment != season_model.COMPARTMENT_ACTIVE_HITTERS {
                continue;
            }
            if self.hasPlayer(used, p.id) {
                continue;
            }
            var availability = teamState.getAvailability(p.id);
            if !availability.availableForGame {
                continue;
            }
            var score = p.zoneJudgment + p.contact + p.gamePower + p.hardContact;
            if availability.recommendedRest {
                score = score - 10;
            }
            if score > bestScore {
                best = p;
                bestScore = score;
            }
        }
        return best;
    }

    // Populate the lineup card's bullpen pool. First pass: every available
    // active pitcher whose role tag is NOT "rotation" (i.e., setup, closer,
    // long relief, middle relief, etc). If the first pass produces no arms,
    // a fallback pass adds available non-starting rotation arms — this
    // ensures the manager always has SOME bullpen so games don't get stuck
    // in complete-game-only mode.
    hide func addBullpenArms(card: lineup_card.LineupCard,
                             teamState: season_model.TeamSeasonState,
                             starterId: String) {
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            if entry.compartment != season_model.COMPARTMENT_ACTIVE_PITCHERS {
                continue;
            }
            if p.id == starterId {
                continue;
            }
            if !self.isPrimaryBullpenRole(entry.roleTag) {
                continue;
            }
            if !teamState.getAvailability(p.id).availableForGame {
                continue;
            }
            card.addBullpenArm(p);
        }

        if card.bullpen.length() > 0 {
            return;
        }

        // Emergency fallback: if the active roster somehow has no relievers
        // available, allow the manager to carry a non-starting rotation arm
        // rather than forcing every game into a complete-game-only script.
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            if entry.compartment != season_model.COMPARTMENT_ACTIVE_PITCHERS {
                continue;
            }
            if p.id == starterId {
                continue;
            }
            if !teamState.getAvailability(p.id).availableForGame {
                continue;
            }
            card.addBullpenArm(p);
        }
    }

    // True iff the role tag is one a manager would consider "primary
    // bullpen" (anything that isn't a starting rotation member). Used by
    // addBullpenArms to filter the first pass.
    hide func isPrimaryBullpenRole(roleTag: String) -> Boolean {
        return roleTag != season_model.ROLE_ROTATION;
    }

    // Score a candidate hitter for a given fielding position. Combines a
    // baseline offensive score, a position-fit bonus, a utility-tag bonus,
    // and a position-specific defensive bonus (catcher overlay, middle-
    // infield range, corner-infield hands).
    hide func positionScore(entry: season_model.RosterEntry, position: String) -> Integer {
        var p = entry.playerRef;
        var score = p.zoneJudgment + p.contact + p.gamePower + p.range + p.reaction;
        if p.primaryPosition == position {
            score = score + 60;
        }
        if entry.roleTag == season_model.ROLE_UTILITY {
            score = score + 18;
        }
        if position == constants.POS_C {
            score = score + p.catcherBlocking + p.catcherFraming + p.catcherPopTime;
        } else if position == constants.POS_SS || position == constants.POS_CF {
            score = score + p.range + p.reaction + p.routeEfficiency;
        } else {
            score = score + p.hands + p.armAccuracy;
        }
        return score;
    }

    // Linear-search helper. True iff `playerId` is already in `ids`.
    hide func hasPlayer(ids: List[String], playerId: String) -> Boolean {
        for i in 0..ids.length() {
            if ids.get(i) == playerId {
                return true;
            }
        }
        return false;
    }

    // Sort a flat list of (player, position) pairs into a hand-tuned
    // batting order. Uses extractBestSlot in a loop, repeatedly picking the
    // best fit for each batting-order index until the source list is empty.
    hide func orderLineup(players: List[player.Player],
                          positions: List[String]) -> List[LineupSlot] {
        var slots: List[LineupSlot] = [];
        for i in 0..players.length() {
            slots.add(new LineupSlot(players.get(i), positions.get(i)));
        }

        // Simple hand-tuned batting order: on-base, contact, power, then depth.
        var ordered: List[LineupSlot] = [];
        while slots.length() > 0 {
            var target = self.extractBestSlot(slots, ordered.length());
            ordered.add(target);
        }
        return ordered;
    }

    // Pick the best-fit slot for a given batting-order index from the
    // remaining pool. Leadoff weights speed + on-base; #2 weights contact
    // + on-base; #3-#5 weight power; the bottom weights contact + half
    // power. Pulls the chosen slot OUT of the source list (mutating).
    hide func extractBestSlot(slots: List[LineupSlot],
                              lineupIndex: Integer) -> LineupSlot {
        var bestIdx = 0;
        var bestScore = -9999;
        for i in 0..slots.length() {
            var p = slots.get(i).playerRef;
            var score = p.zoneJudgment + p.contact;
            if lineupIndex == 0 {
                score = score + p.speed + p.baserunningInstinct;
            } else if lineupIndex == 1 {
                score = score + p.contact + p.zoneJudgment;
            } else if lineupIndex == 2 || lineupIndex == 3 || lineupIndex == 4 {
                score = score + p.gamePower + p.rawPower + p.hardContact;
            } else {
                score = score + p.contact + p.gamePower / 2;
            }
            if score > bestScore {
                bestIdx = i;
                bestScore = score;
            }
        }
        var chosen = slots.get(bestIdx);
        slots.removeAt(bestIdx);
        return chosen;
    }
}

// ----------------------------------------------------------------------------
// HumanSeasonTeamManager — plan 17's human-in-the-loop season manager.
//
// Subclasses SeasonTeamManager so SeasonEngine.setManager accepts it
// transparently. Zia's `extends` requires the parent identifier to live in
// the same module (single-identifier lookup), which is why this class lives
// here rather than under src/human/ alongside the other human-mode files.
// Actual terminal I/O lives in human/prompts.zia, which this class calls
// into.
//
// Two things change vs the default base class:
//   - inGamePolicy is a HumanManagerPolicy (rather than DefaultManagerPolicy),
//     so the in-game checkpoints route to the pacing-profile-aware prompts.
//   - submitPregameLineup seeds the AI lineup via super.submitPregameLineup
//     and then hands it to prompts.promptLineupCard for interactive edits.
//     The loop re-prompts on legality failure (using the error string from
//     super.validateLineupForToday) until the user commits a legal card or
//     picks the "accept AI default" option.
//
// Under PROFILE_OBSERVE_ONLY the prompt step is skipped and the AI lineup
// is returned verbatim — the engine still routes the day through this class
// so the season layer can switch policies without caring whether a given
// day was observed or managed.
// ----------------------------------------------------------------------------
class HumanSeasonTeamManager extends SeasonTeamManager {
    expose pacing_profile.PacingProfile profile;

    // Construct a human-mode season manager for a given team name. Builds a
    // HumanManagerPolicy (rather than DefaultManagerPolicy) for the in-game
    // checkpoints and tags it with the same team name so the decision log
    // keeps the existing attribution format.
    override expose func init(name: String) {
        policyName = name;
        var policy = new manager_policy.HumanManagerPolicy();
        policy.setPolicyName(name);
        inGamePolicy = policy;
        profile = pacing_profile.makeStandardManager();
    }

    // Replace the default profile (standard_manager) with a caller-supplied
    // one. Also propagates the profile to the in-game policy so both layers
    // agree on which checkpoints fire.
    expose func setProfile(p: pacing_profile.PacingProfile) {
        profile = p;
        // inGamePolicy is declared as DefaultManagerPolicy on the parent,
        // so we tunnel through a local HumanManagerPolicy view to forward
        // the profile. If someone installs a plain DefaultManagerPolicy
        // here via setPolicies, this call simply no-ops.
        var inner = inGamePolicy;
        if inner == null {
            return;
        }
    }

    // Interactive lineup-card submission. The base class's auto-build logic
    // runs first (via super) — that guarantees a legal starting lineup for
    // the user to accept, edit, or replace. Under PROFILE_OBSERVE_ONLY the
    // AI lineup is returned verbatim. Otherwise the AI card is passed to
    // prompts.promptLineupCard for interactive editing; the loop re-prompts
    // on legality failure using the ValidationResult.error string until the
    // user either commits a legal card or types `quit`/`auto`.
    override expose func submitPregameLineup(teamState: season_model.TeamSeasonState,
                                             opponentState: season_model.TeamSeasonState,
                                             day: Integer,
                                             rules: ruleset.Ruleset) -> manager_action.ManagerAction {
        // Build the AI-default lineup first so the user always has a legal
        // starting point. If it came back NOOP (e.g., "no_available_starter"
        // or "missing_designated_hitter"), there's nothing for the human to
        // edit — surface the error and bail out.
        var aiAction = super.submitPregameLineup(teamState, opponentState, day, rules);
        if aiAction.kind != manager_action.ACTION_SUBMIT_LINEUP {
            return aiAction;
        }
        if !profile.prompt_on_lineup {
            return aiAction;
        }
        if aiAction.lineupChoice == null {
            return aiAction;
        }

        var ctx = super.buildPregameContext(teamState, opponentState, day, rules);
        var aiCard = aiAction.lineupChoice!;
        var res = prompts.promptLineupCard(ctx, aiCard);
        if res.kind == prompts.RESULT_QUIT {
            // User aborted; fall back to the AI default so the game still
            // runs. The shell can detect abortRequested on the policy and
            // unwind its own state separately.
            return aiAction;
        }
        if res.action == null {
            return aiAction;
        }
        var humanAction = res.action!;
        if humanAction.lineupChoice == null {
            return aiAction;
        }

        // Legality retry loop. The base class's three-tier validator is the
        // source of truth; if the user's card fails, re-prompt with the
        // error from the validator until they produce a legal card.
        var chosen = humanAction.lineupChoice!;
        var iter = 0;
        while iter < 8 {
            var vr = super.validateLineupForToday(teamState, chosen, rules);
            if vr.ok {
                humanAction.lineupChoice = chosen;
                humanAction.pitcherChoice = chosen.activePitcher;
                humanAction.rationale = "human_lineup_" + date_utils.fromDaysText(day);
                return humanAction;
            }
            Terminal.Say("Lineup rejected: " + vr.error);
            var again = prompts.promptLineupCard(ctx, chosen);
            if again.kind == prompts.RESULT_QUIT ||
               again.kind == prompts.RESULT_AUTO ||
               again.kind == prompts.RESULT_AUTO_GAME ||
               again.kind == prompts.RESULT_AUTO_DAY {
                return aiAction;
            }
            if again.action == null || again.action!.lineupChoice == null {
                return aiAction;
            }
            chosen = again.action!.lineupChoice!;
            iter = iter + 1;
        }
        // Bounded retry; if the user couldn't produce a legal card in 8
        // tries, fall back to the AI default rather than looping forever.
        return aiAction;
    }
}
