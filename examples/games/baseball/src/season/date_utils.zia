// ============================================================================
// File: src/season/date_utils.zia
// Purpose: Tiny calendar helpers built on top of `Viper.Time.DateOnly`. The
//          season layer represents dates as integer "days since epoch" so
//          two GameDay objects can be compared with `<` and game-day deltas
//          are simple subtraction. These helpers convert between the
//          integer representation and human-readable y/m/d, plus a couple
//          of date-arithmetic conveniences and a date-of-birth-aware age
//          calculator.
// Cross-refs:
//          - season_engine.makeRoundRobinCalendar uses toDays for the
//            opening-day origin.
//          - season_writer.renderFranchiseSnapshot uses fromDaysText to
//            print human-readable dates.
//          - Plan 13 § Off-season events § Season-reference age refresh
//            uses ageOnDate against the next opening-day reference date.
// ============================================================================
module date_utils;

bind Viper.Time.DateOnly as DO;
bind "../model/player";

// Convert (year, month, day) to integer days-since-epoch via DateOnly.
func toDays(year: Integer, month: Integer, day: Integer) -> Integer {
    return DO.Create(year, month, day).ToDays();
}

// Add a delta to a days-since-epoch value and return the result. Used by
// IL date arithmetic and other date-shift cases.
func addDays(days: Integer, delta: Integer) -> Integer {
    return DO.FromDays(days).AddDays(delta).ToDays();
}

// Format a days-since-epoch value as a human-readable date string for
// play-by-play and standings output. Format follows DateOnly.ToString
// (typically YYYY-MM-DD).
func fromDaysText(days: Integer) -> String {
    return DO.FromDays(days).ToString();
}

// Extract the month component (1..12) from a days-since-epoch value.
func monthFromDays(days: Integer) -> Integer {
    return DO.FromDays(days).get_Month();
}

// Extract the year component from a days-since-epoch value.
func yearFromDays(days: Integer) -> Integer {
    return DO.FromDays(days).get_Year();
}

// Compute a player's age on a given calendar date (passed as days-since-
// epoch). Implements the standard "age decreases by 1 if we haven't
// reached the player's birthday yet this year" rule. Plan 13 § Core
// principle: age is DERIVED from date_of_birth, never stored as mutable
// state.
func ageOnDate(p: player.Player, dateDays: Integer) -> Integer {
    var d = DO.FromDays(dateDays);
    var age = d.get_Year() - p.birthYear;
    if d.get_Month() < p.birthMonth {
        age = age - 1;
    } else if d.get_Month() == p.birthMonth && d.get_Day() < p.birthDay {
        age = age - 1;
    }
    return age;
}

// Day-of-week index (0..6) for a days-since-epoch value. Reserved for the
// future "day game after night game" fatigue marker; not consumed yet.
func weekday(days: Integer) -> Integer {
    return DO.FromDays(days).get_DayOfWeek();
}
