// ============================================================================
// File: src/season/season_rng.zia
// Purpose: A tiny per-instance RNG used by the season layer for the long-
//          lived between-game streams (injury rolls, development draws,
//          transaction RNG). Distinct from `src/sim/rng.zia` because the
//          season layer needs MULTIPLE independent streams whose state must
//          survive save/load (plan 15 § RNG handling).
//
//          The single-game engine uses the runtime's static `Viper.Math.
//          Random` (one global stream); the season layer uses one
//          `SeasonRng` instance per long-lived stream and persists their
//          `state` field via `persistence.zia`.
//
// Algorithm:
//          A small linear-congruential generator with classic ANSI
//          parameters (multiplier 1103515245, increment 12345, modulus
//          2^31 - 1). It is NOT a high-quality PRNG — it's a deterministic
//          replay-friendly stream with explicit state. The season-scale
//          calibration probes will pick up any quality issues.
// ============================================================================
module season_rng;

// One independent random stream. State is exposed so SeasonEngine can
// snapshot it into FranchiseState fields for save/load.
class SeasonRng {
    expose Integer state;

    // Construct a stream from a seed. Negative seeds are folded into the
    // positive range; zero seeds are bumped to 1 so the first nextRaw call
    // doesn't get stuck.
    expose func init(seed: Integer) {
        state = seed;
        if state <= 0 {
            state = 1 - state;
            if state <= 0 {
                state = 1;
            }
        }
    }

    // Advance the LCG by one step and return the new state. Always
    // non-negative.
    expose func nextRaw() -> Integer {
        // Small deterministic LCG for season-layer replay.
        state = (state * 1103515245 + 12345) % 2147483647;
        if state < 0 {
            state = -state;
        }
        return state;
    }

    // Return a uniformly-random integer in [0, max). Returns 0 for non-
    // positive max.
    expose func nextInt(max: Integer) -> Integer {
        if max <= 0 {
            return 0;
        }
        return self.nextRaw() % max;
    }

    // Return a uniformly-random integer in [minValue, maxValue], inclusive.
    // Degenerate ranges collapse to minValue.
    expose func range(minValue: Integer, maxValue: Integer) -> Integer {
        if maxValue <= minValue {
            return minValue;
        }
        return minValue + self.nextInt(maxValue - minValue + 1);
    }

    // Return true with `percent`% probability. percent is clamped to
    // [0, 100].
    expose func chance(percent: Integer) -> Boolean {
        if percent <= 0 {
            return false;
        }
        if percent >= 100 {
            return true;
        }
        return self.nextInt(100) < percent;
    }
}

// Derive a fresh seed from a base seed plus two namespace integers. Used
// by SeasonEngine to derive distinct streams for injury / development /
// transaction RNG without re-using the same sequence. The constants are
// arbitrary primes that mix the inputs reasonably; they are NOT
// cryptographic — replay determinism is the only requirement.
func deriveSeed(baseSeed: Integer, a: Integer, b: Integer) -> Integer {
    var seed = baseSeed * 97 + a * 131 + b * 193 + 17;
    if seed < 0 {
        seed = -seed;
    }
    if seed == 0 {
        seed = 1;
    }
    return seed;
}
