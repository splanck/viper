// ============================================================================
// File: src/season/season_engine.zia
// Purpose: The SeasonEngine — the daily simulation loop, the standings
//          builder, the off-season tick, and the helpers that turn one
//          completed game into season-level state updates (stat absorption,
//          fatigue carryover, injury rolls, IL transitions, auto-fill
//          roster moves). The season-scope analog to GameEngine in
//          src/sim/game_engine.zia.
//
//          Plan 10 § Daily simulation loop is the design. The loop
//          processes one GameDay at a time:
//          1. Refresh availability snapshots for both teams.
//          2. For each scheduled game on the day:
//             - Build per-team game state from current rosters.
//             - Have each team's manager submit a daily lineup card.
//             - Validate the card (compartment + single-game + availability).
//             - Construct a fresh single-game GameState and run it.
//             - Normalize the result into a CompletedGameRecord.
//             - Absorb stats into season totals.
//             - Capture per-game decision log into the franchise log.
//             - Roll injuries on every player who appeared.
//             - Auto-fill roster slots if anyone went on the IL.
//          3. Close the day for both teams (advance rest counters, decay
//             rolling windows, advance day-to-day injury counters,
//             activate IL players whose return day has arrived).
//          4. Sync the per-stream RNG cursors back into the franchise so
//             save/load preserves them (plan 15 § RNG handling).
//
//          The off-season tick (runOffseason) advances the calendar to
//          the next year, runs plan-13 development + aging + durability
//          drift, resets per-season counters, builds the next season's
//          calendar, and re-derives the RNG streams from the new year +
//          season seed.
//
//          The daily loop is broken into many small private helpers
//          (buildTeamDayUsages, processOffDay, simulateScheduledDay,
//          simulateScheduledGame, lineupsReadyForGame, logSubmittedLineups,
//          buildGameState, absorbCompletedGame, finishDay) so each step
//          is independently readable. Stat absorption is split into
//          absorbGame (per team) and absorbCompletedGame (the wrapper
//          that does both teams plus injury rolls and roster auto-fill).
//          Off-season is split into applyOffseasonDevelopment +
//          moveTowardCeiling + applyAgingDecline + resetPlayerStateForNewSeason.
//
//          The makeRoundRobinCalendar function (and its helpers
//          canSchedulePair, allTeamsScheduled, scheduledGamesFor,
//          incrementScheduledGames, rotateTeamIds, findTeam) builds the
//          season schedule.
//
// Cross-refs:
//          - manager_layer.SeasonTeamManager builds the lineup cards.
//          - sim/game_engine.GameEngine runs the actual single games.
//          - persistence.zia round-trips everything this engine produces.
// ============================================================================
module season_engine;

bind Viper.Fmt as Fmt;
bind "../model/constants";
bind "../model/game_state";
bind "../sim/game_engine";
bind "../sim/manager_action";
bind "../sim/manager_policy";
bind "./season_model";
bind "./manager_layer";
bind "./date_utils";
bind "./season_rng";

class TeamDayUsage {
    expose String teamId;
    expose List[String] appearedPlayers;
    expose List[String] startedPlayers;
    expose List[String] startingPitchers;
    expose List[String] catchersStarted;

    expose func init(tid: String) {
        teamId = tid;
        appearedPlayers = [];
        startedPlayers = [];
        startingPitchers = [];
        catchersStarted = [];
    }
}

class SeasonEngine {
    expose season_model.FranchiseState franchise;

    hide List[ManagerBinding] managers_;
    hide season_rng.SeasonRng injuryRng_;
    hide season_rng.SeasonRng developmentRng_;
    hide season_rng.SeasonRng transactionRng_;

    expose func init(state: season_model.FranchiseState) {
        franchise = state;
        managers_ = [];
        injuryRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(state.seasonSeed, state.seasonYear, 7));
        developmentRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(state.seasonSeed, state.seasonYear, 11));
        transactionRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(state.seasonSeed, state.seasonYear, 13));
        // If the franchise was loaded from a save with live RNG state, restore
        // it on top of the freshly-derived seeds. Zero means "no saved state
        // yet, keep the derived seed". Plan 15 § RNG handling requires this
        // for replay determinism across save/load.
        if state.injuryRngState != 0 {
            injuryRng_.state = state.injuryRngState;
        }
        if state.developmentRngState != 0 {
            developmentRng_.state = state.developmentRngState;
        }
        if state.transactionRngState != 0 {
            transactionRng_.state = state.transactionRngState;
        }
        self.syncRngStateToFranchise();
        for i in 0..state.teams.length() {
            var teamState = state.teams.get(i);
            managers_.add(new ManagerBinding(teamState.teamRef.id,
                                             new manager_layer.SeasonTeamManager(teamState.teamRef.fullName + " Manager")));
        }
    }

    hide func syncRngStateToFranchise() {
        franchise.injuryRngState = injuryRng_.state;
        franchise.developmentRngState = developmentRng_.state;
        franchise.transactionRngState = transactionRng_.state;
    }

    expose func setManager(teamId: String, manager: manager_layer.SeasonTeamManager) {
        for i in 0..managers_.length() {
            if managers_.get(i).teamId == teamId {
                managers_.get(i).manager = manager;
                return;
            }
        }
        managers_.add(new ManagerBinding(teamId, manager));
    }

    expose func simulateRegularSeason() -> season_model.FranchiseState {
        while franchise.calendar.currentDayIndex < franchise.calendar.days.length() {
            self.simulateCurrentDay();
        }
        return franchise;
    }

    expose func simulateCurrentDay() {
        if franchise.calendar.currentDayIndex >= franchise.calendar.days.length() {
            return;
        }
        var day = franchise.calendar.currentDay();
        var usages = self.buildTeamDayUsages();

        if day.isOffDay || day.scheduledGames.length() == 0 {
            self.processOffDay(usages);
            return;
        }

        self.simulateScheduledDay(day, usages);
        self.finishDay(usages, false);
    }

    hide func buildTeamDayUsages() -> List[TeamDayUsage] {
        var usages: List[TeamDayUsage] = [];
        for i in 0..franchise.teams.length() {
            usages.add(new TeamDayUsage(franchise.teams.get(i).teamRef.id));
        }
        return usages;
    }

    hide func processOffDay(usages: List[TeamDayUsage]) {
        for i in 0..franchise.teams.length() {
            self.refreshAvailability(franchise.teams.get(i));
        }
        self.finishDay(usages, true);
    }

    hide func simulateScheduledDay(day: season_model.GameDay,
                                   usages: List[TeamDayUsage]) {
        for i in 0..day.scheduledGames.length() {
            self.simulateScheduledGame(day.scheduledGames.get(i), day.dateDays, usages);
        }
    }

    hide func simulateScheduledGame(scheduled: season_model.ScheduledGame,
                                    dayDate: Integer,
                                    usages: List[TeamDayUsage]) {
        var away = franchise.getTeam(scheduled.awayTeamId);
        var home = franchise.getTeam(scheduled.homeTeamId);
        if away == null || home == null {
            return;
        }

        self.refreshAvailability(away!);
        self.refreshAvailability(home!);

        var awayManager = self.getManager(away!.teamRef.id);
        var homeManager = self.getManager(home!.teamRef.id);
        var awayLineupAction = awayManager.submitPregameLineup(away!, home!, dayDate, franchise.rules);
        var homeLineupAction = homeManager.submitPregameLineup(home!, away!, dayDate, franchise.rules);
        if !self.lineupsReadyForGame(scheduled, away!, home!, awayManager, homeManager,
                                     awayLineupAction, homeLineupAction) {
            return;
        }

        self.logSubmittedLineups(away!, home!, awayLineupAction, homeLineupAction);

        var awayStarterId = awayLineupAction.pitcherChoice!.id;
        var homeStarterId = homeLineupAction.pitcherChoice!.id;
        var state = self.buildGameState(scheduled, away!, home!, awayLineupAction, homeLineupAction);
        var engine = new game_engine.GameEngine(state);
        engine.setPolicies(awayManager.inGamePolicy, homeManager.inGamePolicy);
        var finalState = engine.simulate();

        var record = self.buildCompletedGameRecord(scheduled, dayDate, finalState);
        franchise.completedGames.add(record);
        franchise.nextGameNumber = franchise.nextGameNumber + 1;
        self.absorbCompletedGame(away!, home!, finalState, awayStarterId, homeStarterId, usages, record.gameId);
    }

    hide func lineupsReadyForGame(scheduled: season_model.ScheduledGame,
                                  away: season_model.TeamSeasonState,
                                  home: season_model.TeamSeasonState,
                                  awayManager: manager_layer.SeasonTeamManager,
                                  homeManager: manager_layer.SeasonTeamManager,
                                  awayLineupAction: manager_action.ManagerAction,
                                  homeLineupAction: manager_action.ManagerAction) -> Boolean {
        if awayLineupAction.lineupChoice == null || homeLineupAction.lineupChoice == null {
            franchise.managerDecisionLog.add("day=" + Fmt.Int(franchise.calendar.currentDayIndex + 1) +
                                             "|lineup_failure|" + scheduled.awayTeamId + "|" + scheduled.homeTeamId);
            return false;
        }

        var awayOk = awayManager.validateLineupForToday(away, awayLineupAction.lineupChoice!, franchise.rules);
        var homeOk = homeManager.validateLineupForToday(home, homeLineupAction.lineupChoice!, franchise.rules);
        if !awayOk.ok || !homeOk.ok {
            franchise.managerDecisionLog.add("day=" + Fmt.Int(franchise.calendar.currentDayIndex + 1) +
                                             "|lineup_invalid|" +
                                             awayOk.error + "|" + homeOk.error);
            return false;
        }
        return true;
    }

    hide func logSubmittedLineups(away: season_model.TeamSeasonState,
                                  home: season_model.TeamSeasonState,
                                  awayLineupAction: manager_action.ManagerAction,
                                  homeLineupAction: manager_action.ManagerAction) {
        franchise.managerDecisionLog.add("day=" + Fmt.Int(franchise.calendar.currentDayIndex + 1) +
                                         "|submit_lineup|" + away.teamRef.id + "|" + awayLineupAction.rationale);
        franchise.managerDecisionLog.add("day=" + Fmt.Int(franchise.calendar.currentDayIndex + 1) +
                                         "|submit_lineup|" + home.teamRef.id + "|" + homeLineupAction.rationale);
    }

    hide func buildGameState(scheduled: season_model.ScheduledGame,
                             away: season_model.TeamSeasonState,
                             home: season_model.TeamSeasonState,
                             awayLineupAction: manager_action.ManagerAction,
                             homeLineupAction: manager_action.ManagerAction) -> game_state.GameState {
        return new game_state.GameState(franchise.rules, home.homePark,
                                        new game_state.TeamGameState(away.teamRef, awayLineupAction.lineupChoice!),
                                        new game_state.TeamGameState(home.teamRef, homeLineupAction.lineupChoice!),
                                        season_rng.deriveSeed(franchise.seasonSeed,
                                                              franchise.seasonYear,
                                                              scheduled.plannedGameNumber));
    }

    hide func absorbCompletedGame(away: season_model.TeamSeasonState,
                                  home: season_model.TeamSeasonState,
                                  finalState: game_state.GameState,
                                  awayStarterId: String,
                                  homeStarterId: String,
                                  usages: List[TeamDayUsage],
                                  gameId: String) {
        self.absorbGame(away, finalState.away, awayStarterId, self.usageFor(usages, away.teamRef.id));
        self.absorbGame(home, finalState.home, homeStarterId, self.usageFor(usages, home.teamRef.id));
        self.advanceRotationAfterStart(away, awayStarterId);
        self.advanceRotationAfterStart(home, homeStarterId);
        self.captureDecisionLog(gameId, finalState.managerDecisionLog);
        self.rollInjuries(away, self.usageFor(usages, away.teamRef.id));
        self.rollInjuries(home, self.usageFor(usages, home.teamRef.id));
        self.autoFillActiveRoster(away, franchise.calendar.currentDayIndex + 1);
        self.autoFillActiveRoster(home, franchise.calendar.currentDayIndex + 1);
    }

    hide func finishDay(usages: List[TeamDayUsage], offDay: Boolean) {
        for i in 0..franchise.teams.length() {
            self.closeTeamDay(franchise.teams.get(i), usages.get(i), offDay);
        }
        franchise.calendar.currentDayIndex = franchise.calendar.currentDayIndex + 1;
        self.syncRngStateToFranchise();
    }

    expose func buildStandings() -> List[season_model.StandingsRow] {
        var rows: List[season_model.StandingsRow] = [];
        for i in 0..franchise.teams.length() {
            var teamState = franchise.teams.get(i);
            rows.add(new season_model.StandingsRow(teamState.teamRef.id, teamState.teamRef.fullName));
        }
        for i in 0..franchise.completedGames.length() {
            var record = franchise.completedGames.get(i);
            var away = self.rowFor(rows, record.awayTeamId);
            var home = self.rowFor(rows, record.homeTeamId);
            away.runsScored = away.runsScored + record.awayScore;
            away.runsAllowed = away.runsAllowed + record.homeScore;
            home.runsScored = home.runsScored + record.homeScore;
            home.runsAllowed = home.runsAllowed + record.awayScore;
            if record.awayScore > record.homeScore {
                away.wins = away.wins + 1;
                home.losses = home.losses + 1;
            } else {
                home.wins = home.wins + 1;
                away.losses = away.losses + 1;
            }
        }
        for i in 0..rows.length() {
            rows.get(i).runDifferential = rows.get(i).runsScored - rows.get(i).runsAllowed;
        }
        self.sortStandings(rows);
        if rows.length() > 0 {
            var leaderWins = rows.get(0).wins;
            var leaderLosses = rows.get(0).losses;
            for i in 0..rows.length() {
                rows.get(i).gamesBackTimes2 = ((leaderWins - rows.get(i).wins) +
                                               (rows.get(i).losses - leaderLosses));
            }
        }
        return rows;
    }

    expose func runOffseason() {
        var nextOpeningDay = date_utils.toDays(franchise.seasonYear + 1, 4, 1);
        for i in 0..franchise.teams.length() {
            var teamState = franchise.teams.get(i);
            self.updateCareerLedger(teamState);
            for j in 0..teamState.rosterEntries.length() {
                var entry = teamState.rosterEntries.get(j);
                self.applyOffseasonDevelopment(entry.playerRef, nextOpeningDay);
                self.resetPlayerStateForNewSeason(teamState, entry.playerRef.id);
                if entry.compartment == season_model.COMPARTMENT_IL10 ||
                   entry.compartment == season_model.COMPARTMENT_IL60 {
                    if entry.playerRef.isPitcher() {
                        entry.compartment = season_model.COMPARTMENT_ACTIVE_PITCHERS;
                    } else {
                        entry.compartment = season_model.COMPARTMENT_ACTIVE_HITTERS;
                    }
                }
            }
            teamState.nextStarterIndex = 0;
        }
        franchise.completedOffseasons = franchise.completedOffseasons + 1;
        franchise.offseasonHistory.add("season_" + Fmt.Int(franchise.seasonYear) + "_completed");
        franchise.seasonYear = franchise.seasonYear + 1;
        franchise.calendar = makeRoundRobinCalendar(franchise.leagueName, franchise.seasonYear,
                                                    franchise.seasonSeed, franchise.teams,
                                                    franchise.rules.seasonGamesPerTeam,
                                                    franchise.rules.offDaysPerWeek);
        franchise.completedGames = [];
        franchise.transactionLog = [];
        franchise.managerDecisionLog = [];
        injuryRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(franchise.seasonSeed, franchise.seasonYear, 7));
        developmentRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(franchise.seasonSeed, franchise.seasonYear, 11));
        transactionRng_ = new season_rng.SeasonRng(season_rng.deriveSeed(franchise.seasonSeed, franchise.seasonYear, 13));
        // After re-deriving the streams for the new season, also reset the
        // franchise mirror so a load picks up the fresh seeds rather than
        // last season's final cursor positions.
        self.syncRngStateToFranchise();
    }

    hide func buildCompletedGameRecord(scheduled: season_model.ScheduledGame,
                                       day: Integer,
                                       state: game_state.GameState) -> season_model.CompletedGameRecord {
        var record = new season_model.CompletedGameRecord();
        record.gameId = "g" + Fmt.IntPad(scheduled.plannedGameNumber, 4, "0");
        record.dayNumber = franchise.calendar.currentDayIndex + 1;
        record.dateDays = day;
        record.awayTeamId = state.away.teamRef.id;
        record.awayTeamName = state.away.teamRef.fullName;
        record.homeTeamId = state.home.teamRef.id;
        record.homeTeamName = state.home.teamRef.fullName;
        record.ballparkName = state.park.name;
        record.seed = state.rngSeed;
        record.inningsPlayed = state.inning;
        record.awayScore = state.away.score;
        record.homeScore = state.home.score;
        record.awayHits = state.away.hits;
        record.homeHits = state.home.hits;
        record.awayErrors = state.away.errors;
        record.homeErrors = state.home.errors;
        if state.away.score > state.home.score {
            record.winningTeamId = state.away.teamRef.id;
        } else {
            record.winningTeamId = state.home.teamRef.id;
        }
        record.summary = date_utils.fromDaysText(day) + " " + state.away.teamRef.nickname + " " +
                         Fmt.Int(state.away.score) + ", " + state.home.teamRef.nickname + " " +
                         Fmt.Int(state.home.score);

        self.captureTeamLines(state.away.battingLines, record.awayBatting);
        self.captureTeamLines(state.home.battingLines, record.homeBatting);
        self.capturePitchLines(state.away.pitchingLines, record.awayPitching);
        self.capturePitchLines(state.home.pitchingLines, record.homePitching);

        var digestMax = 24;
        var digestCount = state.eventLog.length();
        if digestCount > digestMax {
            digestCount = digestMax;
        }
        for i in 0..digestCount {
            record.eventDigest.add(state.eventLog.get(i));
        }
        return record;
    }

    hide func captureTeamLines(lines: List[game_state.BattingLine],
                               target: List[season_model.CompletedBattingLine]) {
        for i in 0..lines.length() {
            var src = lines.get(i);
            var dest = new season_model.CompletedBattingLine(src.playerRef.id, src.playerRef.name);
            dest.PA = src.PA;
            dest.AB = src.AB;
            dest.R = src.R;
            dest.H = src.H;
            dest.RBI = src.RBI;
            dest.BB = src.BB;
            dest.IBB = src.IBB;
            dest.SO = src.SO;
            dest.HBP = src.HBP;
            dest.SF = src.SF;
            dest.SH = src.SH;
            dest.GIDP = src.GIDP;
            dest.doubles = src.doubles;
            dest.triples = src.triples;
            dest.homeRuns = src.homeRuns;
            target.add(dest);
        }
    }

    hide func capturePitchLines(lines: List[game_state.PitchingLine],
                                target: List[season_model.CompletedPitchingLine]) {
        for i in 0..lines.length() {
            var src = lines.get(i);
            var dest = new season_model.CompletedPitchingLine(src.playerRef.id, src.playerRef.name);
            dest.BF = src.BF;
            dest.outsRecorded = src.outsRecorded;
            dest.H = src.H;
            dest.R = src.R;
            dest.ER = src.ER;
            dest.BB = src.BB;
            dest.IBB = src.IBB;
            dest.SO = src.SO;
            dest.HBP = src.HBP;
            dest.HR = src.HR;
            dest.pitches = src.pitches;
            dest.strikes = src.strikes;
            dest.inheritedRunners = src.inheritedRunners;
            dest.inheritedRunnersScored = src.inheritedRunnersScored;
            target.add(dest);
        }
    }

    hide func absorbGame(teamState: season_model.TeamSeasonState,
                         gameTeamState: game_state.TeamGameState,
                         starterId: String,
                         usage: TeamDayUsage) {
        for i in 0..gameTeamState.battingLines.length() {
            var line = gameTeamState.battingLines.get(i);
            var season = teamState.getSeasonBatting(line.playerRef.id);
            season.games = season.games + 1;
            season.starts = season.starts + 1;
            season.PA = season.PA + line.PA;
            season.AB = season.AB + line.AB;
            season.R = season.R + line.R;
            season.H = season.H + line.H;
            season.RBI = season.RBI + line.RBI;
            season.BB = season.BB + line.BB;
            season.IBB = season.IBB + line.IBB;
            season.SO = season.SO + line.SO;
            season.HBP = season.HBP + line.HBP;
            season.SF = season.SF + line.SF;
            season.SH = season.SH + line.SH;
            season.GIDP = season.GIDP + line.GIDP;
            season.doubles = season.doubles + line.doubles;
            season.triples = season.triples + line.triples;
            season.homeRuns = season.homeRuns + line.homeRuns;
            self.addUnique(usage.appearedPlayers, line.playerRef.id);
            self.addUnique(usage.startedPlayers, line.playerRef.id);
            if line.position == constants.POS_C {
                self.addUnique(usage.catchersStarted, line.playerRef.id);
            }
        }
        for i in 0..gameTeamState.pitchingLines.length() {
            var line = gameTeamState.pitchingLines.get(i);
            var season = teamState.getSeasonPitching(line.playerRef.id);
            season.games = season.games + 1;
            if line.playerRef.id == starterId {
                season.gamesStarted = season.gamesStarted + 1;
                self.addUnique(usage.startingPitchers, line.playerRef.id);
            }
            season.BF = season.BF + line.BF;
            season.outsRecorded = season.outsRecorded + line.outsRecorded;
            season.H = season.H + line.H;
            season.R = season.R + line.R;
            season.ER = season.ER + line.ER;
            season.BB = season.BB + line.BB;
            season.IBB = season.IBB + line.IBB;
            season.SO = season.SO + line.SO;
            season.HBP = season.HBP + line.HBP;
            season.HR = season.HR + line.HR;
            season.pitches = season.pitches + line.pitches;
            season.strikes = season.strikes + line.strikes;
            season.inheritedRunners = season.inheritedRunners + line.inheritedRunners;
            season.inheritedRunnersScored = season.inheritedRunnersScored + line.inheritedRunnersScored;
            self.addUnique(usage.appearedPlayers, line.playerRef.id);

            var rest = teamState.getPitcherRest(line.playerRef.id);
            rest.daysSinceLastAppearance = 0;
            rest.lastAppearancePitchCount = line.pitches;
            rest.pitchesLast7Days = rest.pitchesLast7Days + line.pitches;
            rest.appearancesLast7Days = rest.appearancesLast7Days + 1;
            rest.currentStintPitchCount = line.pitches;
            rest.cumulativeSeasonPitches = rest.cumulativeSeasonPitches + line.pitches;
            rest.appearancesThisSeason = rest.appearancesThisSeason + 1;
            if line.playerRef.id == starterId {
                rest.daysSinceLastStart = 0;
                rest.startsThisSeason = rest.startsThisSeason + 1;
            }
        }
    }

    hide func advanceRotationAfterStart(teamState: season_model.TeamSeasonState,
                                        starterId: String) {
        for i in 0..teamState.rotationOrder.length() {
            if teamState.rotationOrder.get(i) != starterId {
                continue;
            }
            teamState.nextStarterIndex = i + 1;
            if teamState.nextStarterIndex >= teamState.rotationOrder.length() {
                teamState.nextStarterIndex = 0;
            }
            return;
        }
    }

    hide func captureDecisionLog(gameId: String, lines: List[String]) {
        for i in 0..lines.length() {
            franchise.managerDecisionLog.add(gameId + "|" + lines.get(i));
        }
    }

    hide func rollInjuries(teamState: season_model.TeamSeasonState,
                           usage: TeamDayUsage) {
        for i in 0..usage.appearedPlayers.length() {
            var playerId = usage.appearedPlayers.get(i);
            var entry = teamState.getEntry(playerId);
            if entry == null {
                continue;
            }
            var p = entry!.playerRef;
            var chance = 0;
            if p.isPitcher() {
                var rest = teamState.getPitcherRest(playerId);
                chance = 1 + rest.lastAppearancePitchCount / 30 + (100 - p.fatigueResistance) / 45;
                if rest.daysSinceLastAppearance == 0 && rest.lastAppearancePitchCount >= 25 {
                    chance = chance + 1;
                }
            } else {
                var fatigue = teamState.getFatigue(playerId);
                chance = 1 + fatigue.gamesStartedConsecutive / 6 + (100 - p.injuryProneness) / 60;
            }
            if !injuryRng_.chance(chance) {
                continue;
            }
            var injury = teamState.getInjury(playerId);
            var severity = injuryRng_.nextInt(100);
            if severity < 70 {
                injury.dayToDayDaysRemaining = injuryRng_.range(1, 3);
                franchise.transactionLog.add(new season_model.TransactionRecord(franchise.calendar.currentDayIndex + 1,
                                                                                teamState.teamRef.id,
                                                                                "day_to_day",
                                                                                playerId,
                                                                                entry!.compartment,
                                                                                entry!.compartment,
                                                                                "rolled_day_to_day"));
            } else if severity < 90 {
                self.placeOnIl(teamState, entry!, season_model.COMPARTMENT_IL10, 10, "rolled_il10");
            } else {
                self.placeOnIl(teamState, entry!, season_model.COMPARTMENT_IL60, 60, "rolled_il60");
            }
        }
    }

    hide func placeOnIl(teamState: season_model.TeamSeasonState,
                        entry: season_model.RosterEntry,
                        ilType: String,
                        days: Integer,
                        note: String) {
        var injury = teamState.getInjury(entry.playerRef.id);
        injury.dayToDayDaysRemaining = 0;
        injury.ilType = ilType;
        injury.ilEligibleDay = franchise.calendar.currentDayIndex + 1 + days;
        injury.ilReturnDay = injury.ilEligibleDay;
        if ilType == season_model.COMPARTMENT_IL60 {
            injury.priorLongIlCount = injury.priorLongIlCount + 1;
        }
        var from = entry.compartment;
        entry.compartment = ilType;
        franchise.transactionLog.add(new season_model.TransactionRecord(franchise.calendar.currentDayIndex + 1,
                                                                        teamState.teamRef.id,
                                                                        "place_on_il",
                                                                        entry.playerRef.id,
                                                                        from,
                                                                        ilType,
                                                                        note));
    }

    hide func autoFillActiveRoster(teamState: season_model.TeamSeasonState,
                                   dayNumber: Integer) {
        while teamState.activePitchersCount() < franchise.rules.maxActivePitchers {
            var promoted = self.promoteFirstMinor(teamState, true, dayNumber);
            if !promoted {
                break;
            }
        }
        // Fill remaining roster slots, preferring hitters when the hitter count
        // is below its share of the cap. The first call promotes the preferred
        // role; if no minors player of that role exists, the fallback promotes
        // the OPPOSITE role so we don't strand open slots when only one type is
        // available in the callup pool.
        while teamState.activeHittersCount() + teamState.activePitchersCount() < franchise.rules.activeRosterSize {
            var hitterFirst = teamState.activeHittersCount() < (franchise.rules.activeRosterSize - franchise.rules.maxActivePitchers);
            var promoted = self.promoteFirstMinor(teamState, !hitterFirst, dayNumber);
            if !promoted {
                promoted = self.promoteFirstMinor(teamState, hitterFirst, dayNumber);
            }
            if !promoted {
                break;
            }
        }
    }

    hide func promoteFirstMinor(teamState: season_model.TeamSeasonState,
                                wantPitcher: Boolean,
                                dayNumber: Integer) -> Boolean {
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            if entry.compartment != season_model.COMPARTMENT_MINORS {
                continue;
            }
            if entry.playerRef.isPitcher() != wantPitcher {
                continue;
            }
            if wantPitcher {
                entry.compartment = season_model.COMPARTMENT_ACTIVE_PITCHERS;
            } else {
                entry.compartment = season_model.COMPARTMENT_ACTIVE_HITTERS;
            }
            franchise.transactionLog.add(new season_model.TransactionRecord(dayNumber,
                                                                            teamState.teamRef.id,
                                                                            "promote",
                                                                            entry.playerRef.id,
                                                                            season_model.COMPARTMENT_MINORS,
                                                                            entry.compartment,
                                                                            "auto_fill_roster"));
            return true;
        }
        return false;
    }

    hide func refreshAvailability(teamState: season_model.TeamSeasonState) {
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            var availability = teamState.getAvailability(p.id);
            availability.availableForGame = true;
            availability.readinessTier = season_model.READY_AVAILABLE;
            availability.recommendedRest = false;
            availability.reasonCode = "healthy";
            availability.workloadSummary = "";

            var injury = teamState.getInjury(p.id);
            if entry.compartment == season_model.COMPARTMENT_MINORS {
                availability.availableForGame = false;
                availability.readinessTier = season_model.READY_UNAVAILABLE;
                availability.reasonCode = "minors";
            } else if entry.compartment == season_model.COMPARTMENT_IL10 ||
                      entry.compartment == season_model.COMPARTMENT_IL60 {
                availability.availableForGame = false;
                availability.readinessTier = season_model.READY_UNAVAILABLE;
                availability.reasonCode = entry.compartment;
            } else if injury.dayToDayDaysRemaining > 0 {
                availability.availableForGame = false;
                availability.readinessTier = season_model.READY_UNAVAILABLE;
                availability.reasonCode = "day_to_day";
            } else if p.isPitcher() {
                var rest = teamState.getPitcherRest(p.id);
                availability.workloadSummary = "last_pitches=" + Fmt.Int(rest.lastAppearancePitchCount) +
                                               ",days_rest=" + Fmt.Int(rest.daysSinceLastAppearance);
                if entry.roleTag == season_model.ROLE_ROTATION &&
                   rest.daysSinceLastStart < franchise.rules.rotationGap {
                    availability.availableForGame = false;
                    availability.readinessTier = season_model.READY_UNAVAILABLE;
                    availability.reasonCode = "rotation_gap";
                } else if rest.lastAppearancePitchCount >= 30 && rest.daysSinceLastAppearance == 0 {
                    availability.availableForGame = false;
                    availability.readinessTier = season_model.READY_UNAVAILABLE;
                    availability.reasonCode = "heavy_previous_use";
                } else if rest.lastAppearancePitchCount >= 20 && rest.daysSinceLastAppearance == 0 {
                    availability.readinessTier = season_model.READY_EMERGENCY;
                    availability.recommendedRest = true;
                    availability.reasonCode = "back_to_back";
                } else if rest.appearancesLast7Days >= 4 {
                    availability.readinessTier = season_model.READY_TIRED;
                    availability.recommendedRest = true;
                    availability.reasonCode = "usage_cluster";
                }
            } else {
                var fatigue = teamState.getFatigue(p.id);
                availability.workloadSummary = "starts_straight=" + Fmt.Int(fatigue.gamesStartedConsecutive);
                if fatigue.gamesStartedConsecutive >= 8 {
                    availability.readinessTier = season_model.READY_TIRED;
                    availability.recommendedRest = true;
                    availability.reasonCode = "consecutive_starts";
                }
                if p.primaryPosition == constants.POS_C && fatigue.catcherStartsLast5Days >= 4 {
                    availability.readinessTier = season_model.READY_TIRED;
                    availability.recommendedRest = true;
                    availability.reasonCode = "catcher_load";
                }
            }
        }
    }

    hide func closeTeamDay(teamState: season_model.TeamSeasonState,
                           usage: TeamDayUsage,
                           offDay: Boolean) {
        for i in 0..teamState.rosterEntries.length() {
            var entry = teamState.rosterEntries.get(i);
            var p = entry.playerRef;
            var injury = teamState.getInjury(p.id);
            if injury.dayToDayDaysRemaining > 0 {
                injury.dayToDayDaysRemaining = injury.dayToDayDaysRemaining - 1;
            }
            if injury.ilType != "" && injury.ilReturnDay <= franchise.calendar.currentDayIndex + 1 {
                var fromCompartment = entry.compartment;
                if p.isPitcher() && teamState.activePitchersCount() < franchise.rules.maxActivePitchers {
                    entry.compartment = season_model.COMPARTMENT_ACTIVE_PITCHERS;
                    injury.ilEligibleDay = -1;
                    injury.ilReturnDay = -1;
                    injury.ilType = "";
                    franchise.transactionLog.add(new season_model.TransactionRecord(franchise.calendar.currentDayIndex + 1,
                                                                                    teamState.teamRef.id,
                                                                                    "activate_from_il",
                                                                                    p.id,
                                                                                    fromCompartment,
                                                                                    entry.compartment,
                                                                                    "eligible_activation"));
                } else if !p.isPitcher() &&
                          teamState.activeHittersCount() + teamState.activePitchersCount() < franchise.rules.activeRosterSize {
                    entry.compartment = season_model.COMPARTMENT_ACTIVE_HITTERS;
                    injury.ilEligibleDay = -1;
                    injury.ilReturnDay = -1;
                    injury.ilType = "";
                    franchise.transactionLog.add(new season_model.TransactionRecord(franchise.calendar.currentDayIndex + 1,
                                                                                    teamState.teamRef.id,
                                                                                    "activate_from_il",
                                                                                    p.id,
                                                                                    fromCompartment,
                                                                                    entry.compartment,
                                                                                    "eligible_activation"));
                }
            }

            if p.isPitcher() {
                var rest = teamState.getPitcherRest(p.id);
                if !self.hasString(usage.appearedPlayers, p.id) {
                    rest.daysSinceLastAppearance = rest.daysSinceLastAppearance + 1;
                }
                if !self.hasString(usage.startingPitchers, p.id) {
                    rest.daysSinceLastStart = rest.daysSinceLastStart + 1;
                }
                rest.pitchesLast7Days = self.decayCounter(rest.pitchesLast7Days, offDay ? 18 : 12);
                rest.appearancesLast7Days = self.decayCounter(rest.appearancesLast7Days, offDay ? 1 : 0);
            } else {
                var fatigue = teamState.getFatigue(p.id);
                if self.hasString(usage.startedPlayers, p.id) {
                    fatigue.gamesStartedConsecutive = fatigue.gamesStartedConsecutive + 1;
                    fatigue.startsThisSeason = fatigue.startsThisSeason + 1;
                    fatigue.gamesPlayedThisSeason = fatigue.gamesPlayedThisSeason + 1;
                } else {
                    fatigue.gamesStartedConsecutive = 0;
                }
                fatigue.defensiveInningsLast7Days = self.decayCounter(fatigue.defensiveInningsLast7Days, offDay ? 18 : 9);
                if self.hasString(usage.startedPlayers, p.id) {
                    fatigue.defensiveInningsLast7Days = fatigue.defensiveInningsLast7Days + 9;
                }
                fatigue.catcherStartsLast5Days = self.decayCounter(fatigue.catcherStartsLast5Days, 1);
                if self.hasString(usage.catchersStarted, p.id) {
                    fatigue.catcherStartsLast5Days = fatigue.catcherStartsLast5Days + 1;
                }
                fatigue.startedPreviousDay = self.hasString(usage.startedPlayers, p.id);
            }
        }
    }

    hide func updateCareerLedger(teamState: season_model.TeamSeasonState) {
        for i in 0..teamState.seasonBatting.length() {
            var line = teamState.seasonBatting.get(i);
            var career = franchise.getCareerLine(line.playerId, line.playerName);
            career.PA = career.PA + line.PA;
            career.AB = career.AB + line.AB;
            career.H = career.H + line.H;
            career.HR = career.HR + line.homeRuns;
            career.BB = career.BB + line.BB;
            career.SO = career.SO + line.SO;
        }
        for i in 0..teamState.seasonPitching.length() {
            var line = teamState.seasonPitching.get(i);
            var career = franchise.getCareerLine(line.playerId, line.playerName);
            career.outsRecorded = career.outsRecorded + line.outsRecorded;
            career.ER = career.ER + line.ER;
        }
        for i in 0..teamState.rosterEntries.length() {
            var p = teamState.rosterEntries.get(i).playerRef;
            franchise.getCareerLine(p.id, p.name).seasonsCompleted = franchise.completedOffseasons + 1;
        }
    }

    hide func applyOffseasonDevelopment(p: player.Player, nextOpeningDay: Integer) {
        var age = date_utils.ageOnDate(p, nextOpeningDay);
        if age < 27 {
            self.moveTowardCeiling(p, "contact");
            self.moveTowardCeiling(p, "power");
            self.moveTowardCeiling(p, "discipline");
            self.moveTowardCeiling(p, "speed");
            self.moveTowardCeiling(p, "defense");
            self.moveTowardCeiling(p, "pitching");
        } else if age >= 32 {
            self.applyAgingDecline(p, age);
        }
        if age >= 30 {
            p.fatigueResistance = self.clampRating(p.fatigueResistance - 1);
        }
        if age >= 32 {
            p.injuryProneness = self.clampRating(p.injuryProneness + 1);
        }
    }

    hide func moveTowardCeiling(p: player.Player, family: String) {
        var variance = developmentRng_.range(-2, 2) + (p.developmentVarianceTrait - 50) / 20;
        if family == "contact" {
            p.contact = self.growValue(p.contact, p.ceilingContact, variance);
            p.whiffAvoidance = self.growValue(p.whiffAvoidance, p.ceilingContact, variance);
        } else if family == "power" {
            p.rawPower = self.growValue(p.rawPower, p.ceilingPower, variance);
            p.gamePower = self.growValue(p.gamePower, p.ceilingPower, variance);
            p.hardContact = self.growValue(p.hardContact, p.ceilingPower, variance);
        } else if family == "discipline" {
            p.zoneJudgment = self.growValue(p.zoneJudgment, p.ceilingDiscipline, variance);
            p.chaseResistance = self.growValue(p.chaseResistance, p.ceilingDiscipline, variance);
        } else if family == "speed" {
            p.speed = self.growValue(p.speed, p.ceilingSpeed, variance);
            p.firstStep = self.growValue(p.firstStep, p.ceilingSpeed, variance);
        } else if family == "defense" {
            p.range = self.growValue(p.range, p.ceilingDefense, variance);
            p.reaction = self.growValue(p.reaction, p.ceilingDefense, variance);
            p.hands = self.growValue(p.hands, p.ceilingDefense, variance);
        } else if family == "pitching" {
            p.stuff = self.growValue(p.stuff, p.ceilingStuff, variance);
            p.control = self.growValue(p.control, p.ceilingControl, variance);
            p.command = self.growValue(p.command, p.ceilingControl, variance);
            p.movement = self.growValue(p.movement, p.ceilingMovement, variance);
        }
    }

    hide func applyAgingDecline(p: player.Player, age: Integer) {
        var decline = 1 + (age - 32) / 3 + (p.agingCurveProfile - 50) / 40;
        p.speed = self.clampRating(p.speed - decline);
        p.firstStep = self.clampRating(p.firstStep - decline);
        p.range = self.clampRating(p.range - decline);
        p.reaction = self.clampRating(p.reaction - decline);
        p.rawPower = self.clampRating(p.rawPower - decline / 2);
        p.gamePower = self.clampRating(p.gamePower - decline / 2);
        p.stuff = self.clampRating(p.stuff - decline / 2);
        if age >= 35 {
            p.stamina = self.clampRating(p.stamina - 1);
        }
    }

    hide func resetPlayerStateForNewSeason(teamState: season_model.TeamSeasonState,
                                           playerId: String) {
        var rest = teamState.getPitcherRest(playerId);
        rest.daysSinceLastAppearance = 99;
        rest.lastAppearancePitchCount = 0;
        rest.pitchesLast7Days = 0;
        rest.appearancesLast7Days = 0;
        rest.daysSinceLastStart = 99;
        rest.currentStintPitchCount = 0;
        rest.cumulativeSeasonPitches = 0;
        rest.startsThisSeason = 0;
        rest.appearancesThisSeason = 0;

        var fatigue = teamState.getFatigue(playerId);
        fatigue.gamesStartedConsecutive = 0;
        fatigue.defensiveInningsLast7Days = 0;
        fatigue.catcherStartsLast5Days = 0;
        fatigue.startedPreviousDay = false;
        fatigue.startsThisSeason = 0;
        fatigue.gamesPlayedThisSeason = 0;

        var injury = teamState.getInjury(playerId);
        injury.dayToDayDaysRemaining = 0;
        injury.ilType = "";
        injury.ilEligibleDay = -1;
        injury.ilReturnDay = -1;

        var batting = teamState.getSeasonBatting(playerId);
        batting.games = 0;
        batting.starts = 0;
        batting.PA = 0;
        batting.AB = 0;
        batting.R = 0;
        batting.H = 0;
        batting.RBI = 0;
        batting.BB = 0;
        batting.IBB = 0;
        batting.SO = 0;
        batting.HBP = 0;
        batting.SF = 0;
        batting.SH = 0;
        batting.GIDP = 0;
        batting.doubles = 0;
        batting.triples = 0;
        batting.homeRuns = 0;

        var pitching = teamState.getSeasonPitching(playerId);
        pitching.games = 0;
        pitching.gamesStarted = 0;
        pitching.BF = 0;
        pitching.outsRecorded = 0;
        pitching.H = 0;
        pitching.R = 0;
        pitching.ER = 0;
        pitching.BB = 0;
        pitching.IBB = 0;
        pitching.SO = 0;
        pitching.HBP = 0;
        pitching.HR = 0;
        pitching.pitches = 0;
        pitching.strikes = 0;
        pitching.inheritedRunners = 0;
        pitching.inheritedRunnersScored = 0;
    }

    hide func growValue(current: Integer, ceiling: Integer, variance: Integer) -> Integer {
        if current >= ceiling {
            return self.clampRating(current + variance / 3);
        }
        var gap = ceiling - current;
        var move = 1 + gap / 5 + variance;
        if move < 0 {
            move = 0;
        }
        return self.clampRating(current + move);
    }

    hide func usageFor(usages: List[TeamDayUsage], teamId: String) -> TeamDayUsage {
        for i in 0..usages.length() {
            if usages.get(i).teamId == teamId {
                return usages.get(i);
            }
        }
        var fallback = new TeamDayUsage(teamId);
        usages.add(fallback);
        return fallback;
    }

    hide func getManager(teamId: String) -> manager_layer.SeasonTeamManager {
        for i in 0..managers_.length() {
            if managers_.get(i).teamId == teamId {
                return managers_.get(i).manager;
            }
        }
        var fallback = new manager_layer.SeasonTeamManager(teamId + " Manager");
        managers_.add(new ManagerBinding(teamId, fallback));
        return fallback;
    }

    hide func rowFor(rows: List[season_model.StandingsRow],
                     teamId: String) -> season_model.StandingsRow {
        for i in 0..rows.length() {
            if rows.get(i).teamId == teamId {
                return rows.get(i);
            }
        }
        var fresh = new season_model.StandingsRow(teamId, teamId);
        rows.add(fresh);
        return fresh;
    }

    hide func sortStandings(rows: List[season_model.StandingsRow]) {
        var i = 0;
        while i < rows.length() {
            var j = i + 1;
            while j < rows.length() {
                var left = rows.get(i);
                var right = rows.get(j);
                var swap = false;
                if right.wins > left.wins {
                    swap = true;
                } else if right.wins == left.wins && right.runDifferential > left.runDifferential {
                    swap = true;
                }
                if swap {
                    rows.set(i, right);
                    rows.set(j, left);
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }

    hide func addUnique(items: List[String], value: String) {
        if !self.hasString(items, value) {
            items.add(value);
        }
    }

    hide func hasString(items: List[String], value: String) -> Boolean {
        for i in 0..items.length() {
            if items.get(i) == value {
                return true;
            }
        }
        return false;
    }

    hide func decayCounter(value: Integer, amount: Integer) -> Integer {
        if amount <= 0 {
            return value;
        }
        if value <= amount {
            return 0;
        }
        return value - amount;
    }

    hide func clampRating(value: Integer) -> Integer {
        if value < 20 {
            return 20;
        }
        if value > 99 {
            return 99;
        }
        return value;
    }
}

class ManagerBinding {
    expose String teamId;
    expose manager_layer.SeasonTeamManager manager;

    expose func init(tid: String, m: manager_layer.SeasonTeamManager) {
        teamId = tid;
        manager = m;
    }
}

class TeamScheduleCounter {
    expose String teamId;
    expose Integer gamesScheduled;

    expose func init(tid: String) {
        teamId = tid;
        gamesScheduled = 0;
    }
}

func makeRoundRobinCalendar(leagueName: String, seasonYear: Integer, seed: Integer,
                            teams: List[season_model.TeamSeasonState],
                            gamesPerTeam: Integer,
                            offDaysPerWeek: Integer) -> season_model.SeasonCalendar {
    var startDays = date_utils.toDays(seasonYear, 4, 1);
    var calendar = new season_model.SeasonCalendar(leagueName, seasonYear, seed, startDays);
    var teamIds: List[String] = [];
    for i in 0..teams.length() {
        teamIds.add(teams.get(i).teamRef.id);
    }
    if teamIds.length() % 2 == 1 {
        teamIds.add("__bye__");
    }
    var counters: List[TeamScheduleCounter] = [];
    for i in 0..teamIds.length() {
        if teamIds.get(i) != "__bye__" {
            counters.add(new TeamScheduleCounter(teamIds.get(i)));
        }
    }
    var targetGames = normalizeGamesPerTeam(counters.length(), gamesPerTeam);

    var rotating: List[String] = [];
    for i in 0..teamIds.length() {
        rotating.add(teamIds.get(i));
    }

    var baseRounds = teamIds.length() - 1;
    var dateDays = startDays;
    var gameNumber = 1;
    var playedRounds = 0;
    while !allTeamsScheduled(counters, targetGames) {
        for round in 0..baseRounds {
            if allTeamsScheduled(counters, targetGames) {
                break;
            }
            if offDaysPerWeek > 0 && playedRounds > 0 && playedRounds % (7 - offDaysPerWeek) == 0 {
                var offDay = new season_model.GameDay(dateDays);
                offDay.isOffDay = true;
                offDay.label = "scheduled_off_day";
                calendar.days.add(offDay);
                dateDays = dateDays + 1;
            }
            var day = new season_model.GameDay(dateDays);
            day.label = "regular_season";
            for pair in 0..(rotating.length() / 2) {
                var a = rotating.get(pair);
                var b = rotating.get(rotating.length() - 1 - pair);
                if !canSchedulePair(counters, a, b, targetGames) {
                    continue;
                }
                var homeId = a;
                var awayId = b;
                if (playedRounds + pair) % 2 == 1 {
                    homeId = b;
                    awayId = a;
                }
                var homeTeam = findTeam(teams, homeId);
                day.scheduledGames.add(new season_model.ScheduledGame(gameNumber, dateDays,
                                                                      homeId, awayId,
                                                                      homeTeam.homePark.name));
                incrementScheduledGames(counters, awayId);
                incrementScheduledGames(counters, homeId);
                gameNumber = gameNumber + 1;
            }
            if day.scheduledGames.length() == 0 {
                day.isOffDay = true;
                day.label = "bye_day";
            }
            calendar.days.add(day);
            dateDays = dateDays + 1;
            playedRounds = playedRounds + 1;
            rotating = rotateTeamIds(rotating);
        }
    }
    calendar.endDateDays = dateDays - 1;
    return calendar;
}

func normalizeGamesPerTeam(teamCount: Integer, requestedGames: Integer) -> Integer {
    if requestedGames <= 0 {
        return 0;
    }
    if teamCount % 2 == 1 && requestedGames % 2 == 1 {
        return requestedGames - 1;
    }
    return requestedGames;
}

func canSchedulePair(counters: List[TeamScheduleCounter], a: String, b: String,
                     gamesPerTeam: Integer) -> Boolean {
    if a == "__bye__" || b == "__bye__" {
        return false;
    }
    return scheduledGamesFor(counters, a) < gamesPerTeam &&
           scheduledGamesFor(counters, b) < gamesPerTeam;
}

func allTeamsScheduled(counters: List[TeamScheduleCounter], gamesPerTeam: Integer) -> Boolean {
    for i in 0..counters.length() {
        if counters.get(i).gamesScheduled < gamesPerTeam {
            return false;
        }
    }
    return true;
}

func scheduledGamesFor(counters: List[TeamScheduleCounter], teamId: String) -> Integer {
    for i in 0..counters.length() {
        if counters.get(i).teamId == teamId {
            return counters.get(i).gamesScheduled;
        }
    }
    return 0;
}

func incrementScheduledGames(counters: List[TeamScheduleCounter], teamId: String) {
    for i in 0..counters.length() {
        if counters.get(i).teamId == teamId {
            counters.get(i).gamesScheduled = counters.get(i).gamesScheduled + 1;
            return;
        }
    }
}

func rotateTeamIds(ids: List[String]) -> List[String] {
    var rotated: List[String] = [];
    if ids.length() <= 2 {
        for i in 0..ids.length() {
            rotated.add(ids.get(i));
        }
        return rotated;
    }
    rotated.add(ids.get(0));
    rotated.add(ids.get(ids.length() - 1));
    for i in 1..(ids.length() - 1) {
        rotated.add(ids.get(i));
    }
    return rotated;
}

func findTeam(teams: List[season_model.TeamSeasonState],
              teamId: String) -> season_model.TeamSeasonState {
    for i in 0..teams.length() {
        if teams.get(i).teamRef.id == teamId {
            return teams.get(i);
        }
    }
    return teams.get(0);
}
