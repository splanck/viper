// ============================================================================
// File: src/season/output/season_writer.zia
// Purpose: Text writers that turn season-level state into human-readable
//          List[String] blocks for the terminal. Three top-level views:
//
//          - renderStandings(rows): a fixed-width standings table (W, L,
//            GB, RS, RA, RD).
//          - renderFranchiseSnapshot(franchise, standings): the league
//            header + day pointer + completed-game count + decision and
//            transaction totals + the standings table.
//          - renderCompletedGameSummaries(games, maxCount): the most recent
//            N completed-game one-line summaries.
//          - renderCompletedGameBox(record): a persisted post-game box
//            score, rebuilt only from CompletedGameRecord.
//          - renderLeagueLeaders(franchise, maxCount): league leaderboards
//            for core batting and pitching categories.
//          - renderTeamStats / renderRosterReport / renderHealthReport:
//            management views used by the franchise shell.
//
//          These are pure-formatting helpers — they read from FranchiseState
//          + StandingsRow + CompletedGameRecord and never mutate.
// ============================================================================
module season_writer;

bind Viper.Text.Fmt as Fmt;
bind "../season_model";
bind "../date_utils";

// One sortable leaderboard row. `sortValue` is an integer scale specific
// to the metric (thousandths for AVG/OBP/SLG, hundredths for ERA/WHIP,
// raw counts for counting stats).
class LeaderRow {
    expose String playerName;
    expose String teamName;
    expose Integer sortValue;
    expose String valueText;
    expose String detailText;

    expose func init(name: String, team: String, sort: Integer,
                     value: String, detail: String) {
        playerName = name;
        teamName = team;
        sortValue = sort;
        valueText = value;
        detailText = detail;
    }
}

// Render the standings table as a List[String] of fixed-width rows. The
// header line is "Team W L GB RS RA RD" with right-aligned numeric
// columns. GB displays as "-" for the leader, "X" or "X.5" otherwise.
func renderStandings(rows: List[season_model.StandingsRow]) -> List[String] {
    var lines: List[String] = [];
    lines.add("Standings");
    lines.add("Team                    W   L   GB   RS   RA   RD");
    for i in 0..rows.length() {
        var row = rows.get(i);
        var name = row.teamName;
        while name.length() < 22 {
            name = name + " ";
        }
        // Convert the doubled-GB integer back to "X" or "X.5" for display.
        var gbWhole = row.gamesBackTimes2 / 2;
        var gbHalf = row.gamesBackTimes2 % 2;
        var gbText = Fmt.Int(gbWhole);
        if gbHalf != 0 {
            gbText = gbText + ".5";
        }
        if row.gamesBackTimes2 == 0 {
            gbText = "-";
        }
        while gbText.length() < 4 {
            gbText = " " + gbText;
        }
        lines.add(name + Fmt.IntPad(row.wins, 4, " ") +
                  Fmt.IntPad(row.losses, 4, " ") +
                  gbText +
                  Fmt.IntPad(row.runsScored, 5, " ") +
                  Fmt.IntPad(row.runsAllowed, 5, " ") +
                  Fmt.IntPad(row.runDifferential, 5, " "));
    }
    return lines;
}

// Render the league + season-snapshot header (league name, season year,
// current calendar date or "season complete" marker, completed-game count,
// decision-log entry count, transaction count) followed by the full
// standings table.
func renderFranchiseSnapshot(franchise: season_model.FranchiseState,
                             standings: List[season_model.StandingsRow]) -> List[String] {
    var lines: List[String] = [];
    lines.add(franchise.leagueName + " " + Fmt.Int(franchise.seasonYear));
    if franchise.calendar.currentDayIndex < franchise.calendar.days.length() {
        lines.add("Current day: " +
                  date_utils.fromDaysText(franchise.calendar.days.get(franchise.calendar.currentDayIndex).dateDays));
    } else {
        lines.add("Season complete through " + date_utils.fromDaysText(franchise.calendar.endDateDays));
    }
    lines.add("Completed games: " + Fmt.Int(franchise.completedGames.length()));
    lines.add("Decision log entries: " + Fmt.Int(franchise.managerDecisionLog.length()));
    lines.add("Transactions: " + Fmt.Int(franchise.transactionLog.length()));
    lines.add("");
    var standingsLines = renderStandings(standings);
    for i in 0..standingsLines.length() {
        lines.add(standingsLines.get(i));
    }
    return lines;
}

// Render the most recent maxCount completed games as one-line summaries.
// If the franchise has fewer than maxCount games, all of them are shown.
func renderCompletedGameSummaries(games: List[season_model.CompletedGameRecord],
                                  maxCount: Integer) -> List[String] {
    var lines: List[String] = [];
    lines.add("Recent Games");
    var start = 0;
    if games.length() > maxCount {
        start = games.length() - maxCount;
    }
    for i in start..games.length() {
        lines.add(games.get(i).summary);
    }
    return lines;
}

// Render a completed game as a box score from persisted CompletedGameRecord
// data. This intentionally does not depend on live GameState, so every game
// loaded from disk can still be reviewed later.
func renderCompletedGameBox(record: season_model.CompletedGameRecord) -> List[String] {
    var lines: List[String] = [];
    lines.add("Box Score: " + record.gameId + "  " + date_utils.fromDaysText(record.dateDays));
    lines.add(record.awayTeamName + " at " + record.homeTeamName);
    lines.add("Ballpark: " + record.ballparkName +
              "   Innings: " + Fmt.Int(record.inningsPlayed) +
              "   Seed: " + Fmt.Int(record.seed));
    lines.add("");
    lines.add("Final                         R   H   E");
    lines.add(padRight(record.awayTeamName, 28) +
              Fmt.IntPad(record.awayScore, 3, " ") +
              Fmt.IntPad(record.awayHits, 4, " ") +
              Fmt.IntPad(record.awayErrors, 4, " "));
    lines.add(padRight(record.homeTeamName, 28) +
              Fmt.IntPad(record.homeScore, 3, " ") +
              Fmt.IntPad(record.homeHits, 4, " ") +
              Fmt.IntPad(record.homeErrors, 4, " "));
    lines.add("");
    appendCompletedBatting(lines, record.awayTeamName, record.awayBatting);
    lines.add("");
    appendCompletedBatting(lines, record.homeTeamName, record.homeBatting);
    lines.add("");
    appendCompletedPitching(lines, record.awayTeamName, record.awayPitching);
    lines.add("");
    appendCompletedPitching(lines, record.homeTeamName, record.homePitching);
    if record.eventDigest.length() > 0 {
        lines.add("");
        lines.add("Game Log Digest");
        for i in 0..record.eventDigest.length() {
            lines.add("  " + record.eventDigest.get(i));
        }
    }
    return lines;
}

// Render league leaderboards for core production categories. Rate stats use
// dynamic minimums so an early April career still shows useful leaders while
// a longer run avoids one-plate-appearance noise.
func renderLeagueLeaders(franchise: season_model.FranchiseState,
                         maxCount: Integer) -> List[String] {
    var lines: List[String] = [];
    lines.add("League Leaders");
    lines.add(franchise.leagueName + " " + Fmt.Int(franchise.seasonYear));
    lines.add("");
    appendBattingLeader(lines, franchise, "Batting Average", "AVG", maxCount);
    appendBattingLeader(lines, franchise, "On-Base Percentage", "OBP", maxCount);
    appendBattingLeader(lines, franchise, "Slugging", "SLG", maxCount);
    appendBattingLeader(lines, franchise, "Home Runs", "HR", maxCount);
    appendBattingLeader(lines, franchise, "Runs Batted In", "RBI", maxCount);
    appendBattingLeader(lines, franchise, "Hits", "H", maxCount);
    appendPitchingLeader(lines, franchise, "Earned Run Average", "ERA", maxCount);
    appendPitchingLeader(lines, franchise, "WHIP", "WHIP", maxCount);
    appendPitchingLeader(lines, franchise, "Strikeouts", "SO", maxCount);
    appendPitchingLeader(lines, franchise, "Innings Pitched", "IP", maxCount);
    return lines;
}

// Render one team's accumulated batting and pitching lines.
func renderTeamStats(teamState: season_model.TeamSeasonState) -> List[String] {
    var lines: List[String] = [];
    lines.add("Team Statistics - " + teamState.teamRef.fullName);
    lines.add("");
    lines.add("Batting");
    lines.add("Player                  PA  AB   R   H  2B  3B  HR RBI  BB  SO   AVG   OBP   SLG");
    for i in 0..teamState.seasonBatting.length() {
        var b = teamState.seasonBatting.get(i);
        if b.PA == 0 {
            continue;
        }
        lines.add(padRight(b.playerName, 22) +
                  Fmt.IntPad(b.PA, 4, " ") +
                  Fmt.IntPad(b.AB, 4, " ") +
                  Fmt.IntPad(b.R, 4, " ") +
                  Fmt.IntPad(b.H, 4, " ") +
                  Fmt.IntPad(b.doubles, 4, " ") +
                  Fmt.IntPad(b.triples, 4, " ") +
                  Fmt.IntPad(b.homeRuns, 4, " ") +
                  Fmt.IntPad(b.RBI, 4, " ") +
                  Fmt.IntPad(b.BB, 4, " ") +
                  Fmt.IntPad(b.SO, 4, " ") + " " +
                  pct3(rateThousand(b.H, b.AB)) + " " +
                  pct3(rateThousand(b.H + b.BB + b.HBP, b.AB + b.BB + b.HBP + b.SF)) + " " +
                  pct3(rateThousand(totalBases(b), b.AB)));
    }
    lines.add("");
    lines.add("Pitching");
    lines.add("Pitcher                  G  GS     IP   H   R  ER  HR  BB  SO    ERA   WHIP    P-S");
    for i in 0..teamState.seasonPitching.length() {
        var p = teamState.seasonPitching.get(i);
        if p.games == 0 {
            continue;
        }
        lines.add(padRight(p.playerName, 22) +
                  Fmt.IntPad(p.games, 4, " ") +
                  Fmt.IntPad(p.gamesStarted, 4, " ") + " " +
                  padLeft(ipText(p.outsRecorded), 6) +
                  Fmt.IntPad(p.H, 4, " ") +
                  Fmt.IntPad(p.R, 4, " ") +
                  Fmt.IntPad(p.ER, 4, " ") +
                  Fmt.IntPad(p.HR, 4, " ") +
                  Fmt.IntPad(p.BB, 4, " ") +
                  Fmt.IntPad(p.SO, 4, " ") + " " +
                  fixed2(rateHundred(p.ER * 27, p.outsRecorded)) + " " +
                  fixed2(rateHundred((p.H + p.BB) * 3, p.outsRecorded)) + " " +
                  padLeft(Fmt.Int(p.pitches) + "-" + Fmt.Int(p.strikes), 8));
    }
    return lines;
}

// Render roster compartments plus readiness flags for the user-facing roster
// screen. This is about management availability, not raw hidden ratings.
func renderRosterReport(teamState: season_model.TeamSeasonState) -> List[String] {
    var lines: List[String] = [];
    lines.add("Roster - " + teamState.teamRef.fullName);
    appendRosterCompartment(lines, teamState, "Active Hitters",
                            season_model.COMPARTMENT_ACTIVE_HITTERS);
    appendRosterCompartment(lines, teamState, "Active Pitchers",
                            season_model.COMPARTMENT_ACTIVE_PITCHERS);
    appendRosterCompartment(lines, teamState, "Minors",
                            season_model.COMPARTMENT_MINORS);
    appendRosterCompartment(lines, teamState, "Injured List - 10 day",
                            season_model.COMPARTMENT_IL10);
    appendRosterCompartment(lines, teamState, "Injured List - 60 day",
                            season_model.COMPARTMENT_IL60);
    return lines;
}

// Render every unavailable or tired player, plus a compact pitching workload
// section. The shell uses this before simming so the manager can make rest
// and starter decisions with the same information the AI sees.
func renderHealthReport(teamState: season_model.TeamSeasonState) -> List[String] {
    var lines: List[String] = [];
    lines.add("Health and Workload - " + teamState.teamRef.fullName);
    var flagged = 0;
    for i in 0..teamState.rosterEntries.length() {
        var entry = teamState.rosterEntries.get(i);
        var p = entry.playerRef;
        var a = teamState.getAvailability(p.id);
        if a.availableForGame && !a.recommendedRest {
            continue;
        }
        flagged = flagged + 1;
        lines.add("  " + padRight(p.name, 22) +
                  padRight(p.primaryPosition, 4) +
                  padRight(entry.compartment, 16) +
                  padRight(a.readinessTier, 13) +
                  a.reasonCode + " " + a.workloadSummary);
    }
    if flagged == 0 {
        lines.add("  No active health flags.");
    }
    lines.add("");
    lines.add("Pitcher Workload");
    lines.add("Pitcher                 Role           Last  7-day  Rest  Starts  Apps");
    for i in 0..teamState.rosterEntries.length() {
        var entry = teamState.rosterEntries.get(i);
        if !entry.playerRef.isPitcher() {
            continue;
        }
        var rest = teamState.getPitcherRest(entry.playerRef.id);
        lines.add(padRight(entry.playerRef.name, 22) +
                  padRight(entry.roleTag, 15) +
                  Fmt.IntPad(rest.lastAppearancePitchCount, 5, " ") +
                  Fmt.IntPad(rest.pitchesLast7Days, 7, " ") +
                  Fmt.IntPad(rest.daysSinceLastAppearance, 6, " ") +
                  Fmt.IntPad(rest.startsThisSeason, 8, " ") +
                  Fmt.IntPad(rest.appearancesThisSeason, 6, " "));
    }
    return lines;
}

func renderTransactionLog(franchise: season_model.FranchiseState,
                          maxCount: Integer) -> List[String] {
    var lines: List[String] = [];
    lines.add("Transactions");
    var start = 0;
    if franchise.transactionLog.length() > maxCount {
        start = franchise.transactionLog.length() - maxCount;
    }
    for i in start..franchise.transactionLog.length() {
        var tx = franchise.transactionLog.get(i);
        lines.add("  day " + Fmt.Int(tx.dayNumber) + "  " + tx.teamId + "  " +
                  tx.actionType + "  " + tx.playerId + "  " +
                  tx.fromCompartment + " -> " + tx.toCompartment +
                  "  " + tx.note);
    }
    if franchise.transactionLog.length() == 0 {
        lines.add("  (none)");
    }
    return lines;
}

func renderDecisionLog(franchise: season_model.FranchiseState,
                       maxCount: Integer) -> List[String] {
    var lines: List[String] = [];
    lines.add("Manager Decision Log");
    var start = 0;
    if franchise.managerDecisionLog.length() > maxCount {
        start = franchise.managerDecisionLog.length() - maxCount;
    }
    for i in start..franchise.managerDecisionLog.length() {
        lines.add("  " + franchise.managerDecisionLog.get(i));
    }
    if franchise.managerDecisionLog.length() == 0 {
        lines.add("  (none)");
    }
    return lines;
}

func appendCompletedBatting(lines: List[String], teamName: String,
                            batting: List[season_model.CompletedBattingLine]) {
    lines.add("Batting - " + teamName);
    lines.add("Player                  AB   R   H RBI  BB  SO  2B  3B  HR");
    for i in 0..batting.length() {
        var b = batting.get(i);
        lines.add(padRight(b.playerName, 22) +
                  Fmt.IntPad(b.AB, 4, " ") +
                  Fmt.IntPad(b.R, 4, " ") +
                  Fmt.IntPad(b.H, 4, " ") +
                  Fmt.IntPad(b.RBI, 4, " ") +
                  Fmt.IntPad(b.BB, 4, " ") +
                  Fmt.IntPad(b.SO, 4, " ") +
                  Fmt.IntPad(b.doubles, 4, " ") +
                  Fmt.IntPad(b.triples, 4, " ") +
                  Fmt.IntPad(b.homeRuns, 4, " "));
    }
}

func appendCompletedPitching(lines: List[String], teamName: String,
                             pitching: List[season_model.CompletedPitchingLine]) {
    lines.add("Pitching - " + teamName);
    lines.add("Pitcher                    IP   H   R  ER  BB  SO  HR    P-S");
    for i in 0..pitching.length() {
        var p = pitching.get(i);
        lines.add(padRight(p.playerName, 22) +
                  padLeft(ipText(p.outsRecorded), 6) +
                  Fmt.IntPad(p.H, 4, " ") +
                  Fmt.IntPad(p.R, 4, " ") +
                  Fmt.IntPad(p.ER, 4, " ") +
                  Fmt.IntPad(p.BB, 4, " ") +
                  Fmt.IntPad(p.SO, 4, " ") +
                  Fmt.IntPad(p.HR, 4, " ") +
                  padLeft(Fmt.Int(p.pitches) + "-" + Fmt.Int(p.strikes), 8));
    }
}

func appendBattingLeader(lines: List[String],
                         franchise: season_model.FranchiseState,
                         title: String,
                         metric: String,
                         maxCount: Integer) {
    var rows: List[LeaderRow] = [];
    var minPa = franchise.completedGames.length() / 2;
    if minPa < 1 {
        minPa = 1;
    }
    for i in 0..franchise.teams.length() {
        var teamState = franchise.teams.get(i);
        for j in 0..teamState.seasonBatting.length() {
            var b = teamState.seasonBatting.get(j);
            var score = battingMetricValue(b, metric);
            if score < 0 {
                continue;
            }
            if isBattingRate(metric) && b.PA < minPa {
                continue;
            }
            rows.add(new LeaderRow(b.playerName, teamState.teamRef.nickname, score,
                                   battingMetricText(b, metric),
                                   battingMetricDetail(b, metric)));
        }
    }
    sortLeaderRows(rows, false);
    appendLeaderRows(lines, title, rows, maxCount);
}

func appendPitchingLeader(lines: List[String],
                          franchise: season_model.FranchiseState,
                          title: String,
                          metric: String,
                          maxCount: Integer) {
    var rows: List[LeaderRow] = [];
    var minOuts = franchise.completedGames.length();
    if minOuts < 3 {
        minOuts = 3;
    }
    for i in 0..franchise.teams.length() {
        var teamState = franchise.teams.get(i);
        for j in 0..teamState.seasonPitching.length() {
            var p = teamState.seasonPitching.get(j);
            var score = pitchingMetricValue(p, metric);
            if score < 0 {
                continue;
            }
            if isPitchingRate(metric) && p.outsRecorded < minOuts {
                continue;
            }
            rows.add(new LeaderRow(p.playerName, teamState.teamRef.nickname, score,
                                   pitchingMetricText(p, metric),
                                   pitchingMetricDetail(p, metric)));
        }
    }
    sortLeaderRows(rows, metric == "ERA" || metric == "WHIP");
    appendLeaderRows(lines, title, rows, maxCount);
}

func appendLeaderRows(lines: List[String], title: String,
                      rows: List[LeaderRow], maxCount: Integer) {
    lines.add(title);
    if rows.length() == 0 {
        lines.add("  (not enough qualified players yet)");
        lines.add("");
        return;
    }
    var count = maxCount;
    if count > rows.length() {
        count = rows.length();
    }
    for i in 0..count {
        var row = rows.get(i);
        lines.add("  " + Fmt.Int(i + 1) + ". " +
                  padRight(row.playerName, 22) +
                  padRight(row.teamName, 12) +
                  padLeft(row.valueText, 7) + "  " +
                  row.detailText);
    }
    lines.add("");
}

func appendRosterCompartment(lines: List[String],
                             teamState: season_model.TeamSeasonState,
                             title: String,
                             compartment: String) {
    lines.add("");
    lines.add(title);
    var count = 0;
    for i in 0..teamState.rosterEntries.length() {
        var entry = teamState.rosterEntries.get(i);
        if entry.compartment != compartment {
            continue;
        }
        var p = entry.playerRef;
        var a = teamState.getAvailability(p.id);
        count = count + 1;
        lines.add("  " + padRight(p.name, 22) +
                  padRight(p.primaryPosition, 4) +
                  padRight(entry.roleTag, 15) +
                  padRight(a.readinessTier, 13) +
                  a.reasonCode + " " + a.workloadSummary);
    }
    if count == 0 {
        lines.add("  (none)");
    }
}

func battingMetricValue(line: season_model.SeasonBattingLine,
                        metric: String) -> Integer {
    if metric == "AVG" {
        return rateThousand(line.H, line.AB);
    }
    if metric == "OBP" {
        return rateThousand(line.H + line.BB + line.HBP,
                            line.AB + line.BB + line.HBP + line.SF);
    }
    if metric == "SLG" {
        return rateThousand(totalBases(line), line.AB);
    }
    if metric == "HR" { return line.homeRuns; }
    if metric == "RBI" { return line.RBI; }
    if metric == "H" { return line.H; }
    return -1;
}

func battingMetricText(line: season_model.SeasonBattingLine,
                       metric: String) -> String {
    if metric == "AVG" || metric == "OBP" || metric == "SLG" {
        return pct3(battingMetricValue(line, metric));
    }
    return Fmt.Int(battingMetricValue(line, metric));
}

func battingMetricDetail(line: season_model.SeasonBattingLine,
                         _metric: String) -> String {
    return "PA=" + Fmt.Int(line.PA) +
           " AB=" + Fmt.Int(line.AB) +
           " H=" + Fmt.Int(line.H) +
           " HR=" + Fmt.Int(line.homeRuns) +
           " RBI=" + Fmt.Int(line.RBI);
}

func pitchingMetricValue(line: season_model.SeasonPitchingLine,
                         metric: String) -> Integer {
    if metric == "ERA" {
        return rateHundred(line.ER * 27, line.outsRecorded);
    }
    if metric == "WHIP" {
        return rateHundred((line.H + line.BB) * 3, line.outsRecorded);
    }
    if metric == "SO" { return line.SO; }
    if metric == "IP" { return line.outsRecorded; }
    return -1;
}

func pitchingMetricText(line: season_model.SeasonPitchingLine,
                        metric: String) -> String {
    if metric == "ERA" || metric == "WHIP" {
        return fixed2(pitchingMetricValue(line, metric));
    }
    if metric == "IP" {
        return ipText(line.outsRecorded);
    }
    return Fmt.Int(pitchingMetricValue(line, metric));
}

func pitchingMetricDetail(line: season_model.SeasonPitchingLine,
                          _metric: String) -> String {
    return "G=" + Fmt.Int(line.games) +
           " GS=" + Fmt.Int(line.gamesStarted) +
           " IP=" + ipText(line.outsRecorded) +
           " H=" + Fmt.Int(line.H) +
           " BB=" + Fmt.Int(line.BB) +
           " SO=" + Fmt.Int(line.SO);
}

func isBattingRate(metric: String) -> Boolean {
    return metric == "AVG" || metric == "OBP" || metric == "SLG";
}

func isPitchingRate(metric: String) -> Boolean {
    return metric == "ERA" || metric == "WHIP";
}

func sortLeaderRows(rows: List[LeaderRow], lowerBetter: Boolean) {
    var i = 0;
    while i < rows.length() {
        var j = i + 1;
        while j < rows.length() {
            var left = rows.get(i);
            var right = rows.get(j);
            var swap = false;
            if lowerBetter {
                if right.sortValue < left.sortValue {
                    swap = true;
                }
            } else if right.sortValue > left.sortValue {
                swap = true;
            }
            if swap {
                rows.set(i, right);
                rows.set(j, left);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

func totalBases(line: season_model.SeasonBattingLine) -> Integer {
    return line.H + line.doubles + line.triples * 2 + line.homeRuns * 3;
}

func rateThousand(numerator: Integer, denominator: Integer) -> Integer {
    if denominator <= 0 {
        return -1;
    }
    return (numerator * 1000 + denominator / 2) / denominator;
}

func rateHundred(numerator: Integer, denominator: Integer) -> Integer {
    if denominator <= 0 {
        return -1;
    }
    return (numerator * 100 + denominator / 2) / denominator;
}

func pct3(value: Integer) -> String {
    if value < 0 {
        return "---";
    }
    if value < 1000 {
        return "." + Fmt.IntPad(value, 3, "0");
    }
    return Fmt.Int(value / 1000) + "." + Fmt.IntPad(value % 1000, 3, "0");
}

func fixed2(value: Integer) -> String {
    if value < 0 {
        return "--";
    }
    return Fmt.Int(value / 100) + "." + Fmt.IntPad(value % 100, 2, "0");
}

func ipText(outsRecorded: Integer) -> String {
    return Fmt.Int(outsRecorded / 3) + "." + Fmt.Int(outsRecorded % 3);
}

func padRight(s: String, width: Integer) -> String {
    var out = s;
    while out.length() < width {
        out = out + " ";
    }
    return out;
}

func padLeft(s: String, width: Integer) -> String {
    var out = s;
    while out.length() < width {
        out = " " + out;
    }
    return out;
}
