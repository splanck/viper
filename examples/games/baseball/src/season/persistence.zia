// ============================================================================
// File: src/season/persistence.zia
// Purpose: Save / load the FranchiseState to / from a directory tree on
//          disk. Plan 15 § Save format and § Versioning is the design.
//
//          The save format is plain-text, line-oriented, and tag-prefixed:
//          every line is "TAG|field1|field2|...". Tags include FRANCHISE,
//          SEASON, DAY, GAME, TEAM, PLAYER, REST, FATIGUE, INJURY, SBAT,
//          SPIT, CGAME, OFFSEASON, CAREER, TX. The format is debuggable
//          (you can `cat` a save file and read it) and the parser is a
//          single-pass tag-dispatch loop.
//
//          File layout (per franchise):
//              <root>/<franchiseId>/franchise.save        — header + RNG state
//              <root>/<franchiseId>/careers.txt           — all-time stats
//              <root>/<franchiseId>/seasons/<year>/season.save
//              <root>/<franchiseId>/seasons/<year>/decision_log.txt
//              <root>/<franchiseId>/seasons/<year>/transaction_log.txt
//              <root>/<franchiseId>/seasons/<year>/completed_games/g0001.txt
//              ...
//
//          Round-trip determinism: every field SeasonEngine reads from
//          FranchiseState is persisted here, including the three between-
//          game RNG stream cursors (plan 15 § RNG handling). The
//          persistence_probe at the project root verifies the round-trip.
// ============================================================================
module persistence;

bind Viper.IO.Dir as Dir;
bind Viper.IO.File as File;
bind Viper.IO.Path as Path;
bind Viper.String as String;
bind Viper.Collections.Seq as Seq;
bind Viper.Fmt as Fmt;
bind "./season_model";
bind "./date_utils";
bind "../model/player";
bind "../model/team";
bind "../model/ruleset";
bind "../model/ballpark";

// Typed result from loadFranchise. ok=false means the load failed; state
// is null in that case and error contains a short reason.
class LoadResult {
    expose Boolean ok;
    expose String error;
    expose season_model.FranchiseState? state;

    // Initialize to a failed result with no state and an empty error
    // string. loadFranchise sets ok and state on success.
    expose func init() {
        ok = false;
        error = "";
        state = null;
    }
}

// Codec for the detailed completed-game files under seasons/<year>/
// completed_games/. season.save stores the index/summary line; this codec
// persists the richer digest + batting/pitching detail so loadFranchise can
// reconstruct the same completed-game detail that existed before the save.
class CompletedGameCodec {
    expose func init() { }

    expose func render(record: season_model.CompletedGameRecord) -> String {
        var lines: List[String] = [];
        lines.add("HEADER|" + record.gameId + "|" + Fmt.Int(record.dayNumber) + "|" +
                  Fmt.Int(record.dateDays) + "|" + record.awayTeamId + "|" +
                  record.awayTeamName + "|" + record.homeTeamId + "|" +
                  record.homeTeamName + "|" + record.ballparkName + "|" +
                  Fmt.Int(record.seed) + "|" + Fmt.Int(record.inningsPlayed) + "|" +
                  Fmt.Int(record.awayScore) + "|" + Fmt.Int(record.homeScore) + "|" +
                  Fmt.Int(record.awayHits) + "|" + Fmt.Int(record.homeHits) + "|" +
                  Fmt.Int(record.awayErrors) + "|" + Fmt.Int(record.homeErrors) + "|" +
                  record.winningTeamId + "|" + record.summary);
        for i in 0..record.eventDigest.length() {
            lines.add("DIGEST|" + record.eventDigest.get(i));
        }
        self.appendBatting(lines, "ABAT", record.awayBatting);
        self.appendBatting(lines, "HBAT", record.homeBatting);
        self.appendPitching(lines, "APIT", record.awayPitching);
        self.appendPitching(lines, "HPIT", record.homePitching);
        return renderStringList(lines);
    }

    expose func apply(record: season_model.CompletedGameRecord, text: String) {
        record.eventDigest = [];
        record.awayBatting = [];
        record.homeBatting = [];
        record.awayPitching = [];
        record.homePitching = [];

        var lines = readStringLines(text);
        for i in 0..lines.length() {
            self.applyLine(record, lines.get(i));
        }
    }

    hide func applyLine(record: season_model.CompletedGameRecord, line: String) {
        var parts = String.Split(line, "|");
        var tag = toStr(Seq.Get(parts, 0));
        if tag == "HEADER" {
            record.gameId = toStr(Seq.Get(parts, 1));
            record.dayNumber = toInt(Seq.Get(parts, 2));
            record.dateDays = toInt(Seq.Get(parts, 3));
            record.awayTeamId = toStr(Seq.Get(parts, 4));
            record.awayTeamName = toStr(Seq.Get(parts, 5));
            record.homeTeamId = toStr(Seq.Get(parts, 6));
            record.homeTeamName = toStr(Seq.Get(parts, 7));
            record.ballparkName = toStr(Seq.Get(parts, 8));
            record.seed = toInt(Seq.Get(parts, 9));
            record.inningsPlayed = toInt(Seq.Get(parts, 10));
            record.awayScore = toInt(Seq.Get(parts, 11));
            record.homeScore = toInt(Seq.Get(parts, 12));
            record.awayHits = toInt(Seq.Get(parts, 13));
            record.homeHits = toInt(Seq.Get(parts, 14));
            record.awayErrors = toInt(Seq.Get(parts, 15));
            record.homeErrors = toInt(Seq.Get(parts, 16));
            record.winningTeamId = toStr(Seq.Get(parts, 17));
            record.summary = toStr(Seq.Get(parts, 18));
            return;
        }
        if tag == "DIGEST" {
            record.eventDigest.add(toStr(Seq.Get(parts, 1)));
            return;
        }
        if tag == "ABAT" {
            record.awayBatting.add(parseCompletedBatting(parts));
            return;
        }
        if tag == "HBAT" {
            record.homeBatting.add(parseCompletedBatting(parts));
            return;
        }
        if tag == "APIT" {
            record.awayPitching.add(parseCompletedPitching(parts));
            return;
        }
        if tag == "HPIT" {
            record.homePitching.add(parseCompletedPitching(parts));
        }
    }

    hide func appendBatting(lines: List[String], tag: String,
                            batting: List[season_model.CompletedBattingLine]) {
        for i in 0..batting.length() {
            var line = batting.get(i);
            lines.add(tag + "|" + line.playerId + "|" + line.playerName + "|" +
                      Fmt.Int(line.PA) + "|" + Fmt.Int(line.AB) + "|" +
                      Fmt.Int(line.R) + "|" + Fmt.Int(line.H) + "|" +
                      Fmt.Int(line.RBI) + "|" + Fmt.Int(line.BB) + "|" +
                      Fmt.Int(line.IBB) + "|" + Fmt.Int(line.SO) + "|" +
                      Fmt.Int(line.HBP) + "|" + Fmt.Int(line.SF) + "|" +
                      Fmt.Int(line.SH) + "|" + Fmt.Int(line.GIDP) + "|" +
                      Fmt.Int(line.doubles) + "|" + Fmt.Int(line.triples) + "|" +
                      Fmt.Int(line.homeRuns));
        }
    }

    hide func appendPitching(lines: List[String], tag: String,
                             pitching: List[season_model.CompletedPitchingLine]) {
        for i in 0..pitching.length() {
            var line = pitching.get(i);
            lines.add(tag + "|" + line.playerId + "|" + line.playerName + "|" +
                      Fmt.Int(line.BF) + "|" + Fmt.Int(line.outsRecorded) + "|" +
                      Fmt.Int(line.H) + "|" + Fmt.Int(line.R) + "|" +
                      Fmt.Int(line.ER) + "|" + Fmt.Int(line.BB) + "|" +
                      Fmt.Int(line.IBB) + "|" + Fmt.Int(line.SO) + "|" +
                      Fmt.Int(line.HBP) + "|" + Fmt.Int(line.HR) + "|" +
                      Fmt.Int(line.pitches) + "|" + Fmt.Int(line.strikes) + "|" +
                      Fmt.Int(line.inheritedRunners) + "|" +
                      Fmt.Int(line.inheritedRunnersScored));
        }
    }
}

// Save the franchise to disk under <rootPath>/<franchiseId>/. Creates the
// directory tree if needed, writes franchise.save (header + RNG cursors),
// careers.txt, season.save, decision_log.txt, transaction_log.txt, and
// one completed_games/gNNNN.txt per game. Each file is written via
// writeAtomic to avoid partial-write corruption on crash.
func saveFranchise(rootPath: String, franchise: season_model.FranchiseState) {
    var franchiseDir = Path.Join(rootPath, franchise.franchiseId);
    var seasonsDir = Path.Join(franchiseDir, "seasons");
    var seasonDir = Path.Join(seasonsDir, Fmt.Int(franchise.seasonYear));
    var completedDir = Path.Join(seasonDir, "completed_games");
    var codec = new CompletedGameCodec();

    Dir.MakeAll(completedDir);
    writeAtomic(Path.Join(franchiseDir, "franchise.save"), renderFranchiseHeader(franchise));
    writeAtomic(Path.Join(franchiseDir, "careers.txt"), renderCareers(franchise));
    writeAtomic(Path.Join(seasonDir, "season.save"), renderSeason(franchise));
    writeAtomic(Path.Join(seasonDir, "decision_log.txt"), renderStringList(franchise.managerDecisionLog));
    writeAtomic(Path.Join(seasonDir, "transaction_log.txt"), renderTransactions(franchise.transactionLog));

    if Dir.Exists(completedDir) {
        Dir.RemoveAll(completedDir);
    }
    Dir.MakeAll(completedDir);
    for i in 0..franchise.completedGames.length() {
        var record = franchise.completedGames.get(i);
        writeAtomic(Path.Join(completedDir, record.gameId + ".txt"), codec.render(record));
    }
}

// Load a franchise from disk. rootPath should point AT the franchise dir
// (the one containing franchise.save), not the parent saves directory.
// Parses the header, then the season.save, then the careers + decision +
// transaction logs. Returns a LoadResult; on failure ok is false and
// error explains why.
func loadFranchise(rootPath: String) -> LoadResult {
    var result = new LoadResult();
    if !Dir.Exists(rootPath) {
        result.error = "root path does not exist";
        return result;
    }
    var franchiseHeaderPath = Path.Join(rootPath, "franchise.save");
    if !File.Exists(franchiseHeaderPath) {
        result.error = "missing franchise.save";
        return result;
    }

    var header = File.ReadAllText(franchiseHeaderPath);
    var headerLines = String.Split(header, "\n");
    var franchiseId = "";
    var leagueName = "";
    var seasonYear = 0;
    var seasonSeed = 0;
    var completedOffseasons = 0;
    var injuryRngState = 0;
    var developmentRngState = 0;
    var transactionRngState = 0;
    var nextGameNumber = 1;
    for i in 0..Seq.get_Length(headerLines) {
        var line = String.Trim(toStr(Seq.Get(headerLines, i)));
        if line == "" {
            continue;
        }
        var parts = String.Split(line, "|");
        var tag = toStr(Seq.Get(parts, 0));
        if tag == "FRANCHISE" {
            franchiseId = toStr(Seq.Get(parts, 1));
            leagueName = toStr(Seq.Get(parts, 2));
            seasonYear = toInt(Seq.Get(parts, 3));
            seasonSeed = toInt(Seq.Get(parts, 4));
            completedOffseasons = toInt(Seq.Get(parts, 5));
            // Backwards-compat: older saves only had 6 fields. The RNG state
            // fields are appended at positions 6-8 in the new format. If the
            // save predates plan-15 RNG persistence, leave them at 0 and
            // SeasonEngine.init will fall back to deriving from seed.
            if Seq.get_Length(parts) >= 7 {
                injuryRngState = toInt(Seq.Get(parts, 6));
            }
            if Seq.get_Length(parts) >= 8 {
                developmentRngState = toInt(Seq.Get(parts, 7));
            }
            if Seq.get_Length(parts) >= 9 {
                transactionRngState = toInt(Seq.Get(parts, 8));
            }
            if Seq.get_Length(parts) >= 10 {
                nextGameNumber = toInt(Seq.Get(parts, 9));
            }
        }
    }

    var seasonPath = Path.Join(Path.Join(Path.Join(rootPath, "seasons"), Fmt.Int(seasonYear)), "season.save");
    if !File.Exists(seasonPath) {
        result.error = "missing season.save";
        return result;
    }

    var seasonText = File.ReadAllText(seasonPath);
    var seasonLines = String.Split(seasonText, "\n");
    var rules = new ruleset.Ruleset();
    var calendar: season_model.SeasonCalendar? = null;
    var franchise: season_model.FranchiseState? = null;
    var currentDay: season_model.GameDay? = null;
    var currentTeam: season_model.TeamSeasonState? = null;
    var currentTeamId = "";

    for i in 0..Seq.get_Length(seasonLines) {
        var raw = String.Trim(toStr(Seq.Get(seasonLines, i)));
        if raw == "" {
            continue;
        }
        var parts = String.Split(raw, "|");
        var tag = toStr(Seq.Get(parts, 0));
        if tag == "SEASON" {
            rules.inningsPerGame = toInt(Seq.Get(parts, 1));
            rules.designatedHitterEnabled = toBool(Seq.Get(parts, 2));
            rules.extraInningsAutomaticRunnerEnabled = toBool(Seq.Get(parts, 3));
            rules.threeBatterMinimumEnabled = toBool(Seq.Get(parts, 4));
            rules.activeRosterSize = toInt(Seq.Get(parts, 5));
            rules.maxActivePitchers = toInt(Seq.Get(parts, 6));
            rules.minRotationSize = toInt(Seq.Get(parts, 7));
            rules.rotationGap = toInt(Seq.Get(parts, 8));
            rules.seasonGamesPerTeam = toInt(Seq.Get(parts, 9));
            rules.offDaysPerWeek = toInt(Seq.Get(parts, 10));
            var startDays = toInt(Seq.Get(parts, 11));
            var endDays = toInt(Seq.Get(parts, 12));
            var currentIndex = toInt(Seq.Get(parts, 13));
            calendar = new season_model.SeasonCalendar(leagueName, seasonYear, seasonSeed, startDays);
            calendar!.endDateDays = endDays;
            calendar!.currentDayIndex = currentIndex;
            franchise = new season_model.FranchiseState(franchiseId, leagueName, rules, seasonYear, seasonSeed, calendar!);
            franchise!.completedOffseasons = completedOffseasons;
            franchise!.injuryRngState = injuryRngState;
            franchise!.developmentRngState = developmentRngState;
            franchise!.transactionRngState = transactionRngState;
            franchise!.nextGameNumber = nextGameNumber;
        } else if tag == "DAY" {
            currentDay = new season_model.GameDay(toInt(Seq.Get(parts, 1)));
            currentDay!.isOffDay = toBool(Seq.Get(parts, 2));
            currentDay!.label = toStr(Seq.Get(parts, 3));
            calendar!.days.add(currentDay!);
        } else if tag == "GAME" {
            currentDay!.scheduledGames.add(new season_model.ScheduledGame(toInt(Seq.Get(parts, 1)),
                                                                          toInt(Seq.Get(parts, 2)),
                                                                          toStr(Seq.Get(parts, 3)),
                                                                          toStr(Seq.Get(parts, 4)),
                                                                          toStr(Seq.Get(parts, 5))));
        } else if tag == "TEAM" {
            var t = new team.Team(toStr(Seq.Get(parts, 1)), toStr(Seq.Get(parts, 2)), toStr(Seq.Get(parts, 3)));
            var park = new ballpark.Ballpark(toStr(Seq.Get(parts, 4)), toInt(Seq.Get(parts, 5)),
                                             toInt(Seq.Get(parts, 6)), toInt(Seq.Get(parts, 7)),
                                             toInt(Seq.Get(parts, 8)), toInt(Seq.Get(parts, 9)));
            park.foulTerritoryClass = toInt(Seq.Get(parts, 10));
            park.infieldSpeed = toInt(Seq.Get(parts, 11));
            park.outfieldSpeed = toInt(Seq.Get(parts, 12));
            currentTeam = new season_model.TeamSeasonState(t, park);
            currentTeam!.nextStarterIndex = toInt(Seq.Get(parts, 13));
            currentTeamId = t.id;
            franchise!.teams.add(currentTeam!);
        } else if tag == "PLAYER" {
            var p = new player.Player(toStr(Seq.Get(parts, 1)), toStr(Seq.Get(parts, 2)), toStr(Seq.Get(parts, 3)),
                                      toStr(Seq.Get(parts, 4)), toStr(Seq.Get(parts, 5)));
            p.setBirthDate(toInt(Seq.Get(parts, 6)), toInt(Seq.Get(parts, 7)), toInt(Seq.Get(parts, 8)));
            p.setHitting(toInt(Seq.Get(parts, 9)), toInt(Seq.Get(parts, 10)), toInt(Seq.Get(parts, 11)),
                         toInt(Seq.Get(parts, 12)), toInt(Seq.Get(parts, 13)), toInt(Seq.Get(parts, 14)),
                         toInt(Seq.Get(parts, 15)), toInt(Seq.Get(parts, 16)), toInt(Seq.Get(parts, 17)),
                         toInt(Seq.Get(parts, 18)), toInt(Seq.Get(parts, 19)), toInt(Seq.Get(parts, 20)),
                         toInt(Seq.Get(parts, 21)), toInt(Seq.Get(parts, 22)));
            p.setRunning(toInt(Seq.Get(parts, 23)), toInt(Seq.Get(parts, 24)), toInt(Seq.Get(parts, 25)),
                         toInt(Seq.Get(parts, 26)), toInt(Seq.Get(parts, 27)));
            p.setPitching(toInt(Seq.Get(parts, 28)), toInt(Seq.Get(parts, 29)), toInt(Seq.Get(parts, 30)),
                          toInt(Seq.Get(parts, 31)), toInt(Seq.Get(parts, 32)), toInt(Seq.Get(parts, 33)),
                          toInt(Seq.Get(parts, 34)), toInt(Seq.Get(parts, 35)), toInt(Seq.Get(parts, 36)));
            p.setDefense(toInt(Seq.Get(parts, 37)), toInt(Seq.Get(parts, 38)), toInt(Seq.Get(parts, 39)),
                         toInt(Seq.Get(parts, 40)), toInt(Seq.Get(parts, 41)), toInt(Seq.Get(parts, 42)),
                         toInt(Seq.Get(parts, 43)), toInt(Seq.Get(parts, 44)), toInt(Seq.Get(parts, 45)),
                         toInt(Seq.Get(parts, 46)));
            p.setDurability(toInt(Seq.Get(parts, 47)), toInt(Seq.Get(parts, 48)));
            p.setLongTermProfile(toInt(Seq.Get(parts, 49)), toInt(Seq.Get(parts, 50)), toInt(Seq.Get(parts, 51)),
                                 toInt(Seq.Get(parts, 52)), toInt(Seq.Get(parts, 53)), toInt(Seq.Get(parts, 54)),
                                 toInt(Seq.Get(parts, 55)), toInt(Seq.Get(parts, 56)), toInt(Seq.Get(parts, 57)),
                                 toInt(Seq.Get(parts, 58)));
            currentTeam!.addRosterEntry(p, toStr(Seq.Get(parts, 59)), toStr(Seq.Get(parts, 60)));
        } else if tag == "REST" {
            var rest = currentTeam!.getPitcherRest(toStr(Seq.Get(parts, 1)));
            rest.daysSinceLastAppearance = toInt(Seq.Get(parts, 2));
            rest.lastAppearancePitchCount = toInt(Seq.Get(parts, 3));
            rest.pitchesLast7Days = toInt(Seq.Get(parts, 4));
            rest.appearancesLast7Days = toInt(Seq.Get(parts, 5));
            rest.daysSinceLastStart = toInt(Seq.Get(parts, 6));
            rest.currentStintPitchCount = toInt(Seq.Get(parts, 7));
            rest.cumulativeSeasonPitches = toInt(Seq.Get(parts, 8));
            rest.startsThisSeason = toInt(Seq.Get(parts, 9));
            rest.appearancesThisSeason = toInt(Seq.Get(parts, 10));
        } else if tag == "FATIGUE" {
            var fatigue = currentTeam!.getFatigue(toStr(Seq.Get(parts, 1)));
            fatigue.gamesStartedConsecutive = toInt(Seq.Get(parts, 2));
            fatigue.defensiveInningsLast7Days = toInt(Seq.Get(parts, 3));
            fatigue.catcherStartsLast5Days = toInt(Seq.Get(parts, 4));
            fatigue.startedPreviousDay = toBool(Seq.Get(parts, 5));
            fatigue.startsThisSeason = toInt(Seq.Get(parts, 6));
            fatigue.gamesPlayedThisSeason = toInt(Seq.Get(parts, 7));
        } else if tag == "INJURY" {
            var injury = currentTeam!.getInjury(toStr(Seq.Get(parts, 1)));
            injury.dayToDayDaysRemaining = toInt(Seq.Get(parts, 2));
            injury.ilType = toStr(Seq.Get(parts, 3));
            injury.ilEligibleDay = toInt(Seq.Get(parts, 4));
            injury.ilReturnDay = toInt(Seq.Get(parts, 5));
            injury.priorLongIlCount = toInt(Seq.Get(parts, 6));
        } else if tag == "SBAT" {
            var bat = currentTeam!.getSeasonBatting(toStr(Seq.Get(parts, 1)));
            bat.games = toInt(Seq.Get(parts, 2));
            bat.starts = toInt(Seq.Get(parts, 3));
            bat.PA = toInt(Seq.Get(parts, 4));
            bat.AB = toInt(Seq.Get(parts, 5));
            bat.R = toInt(Seq.Get(parts, 6));
            bat.H = toInt(Seq.Get(parts, 7));
            bat.RBI = toInt(Seq.Get(parts, 8));
            bat.BB = toInt(Seq.Get(parts, 9));
            bat.IBB = toInt(Seq.Get(parts, 10));
            bat.SO = toInt(Seq.Get(parts, 11));
            bat.HBP = toInt(Seq.Get(parts, 12));
            bat.SF = toInt(Seq.Get(parts, 13));
            bat.SH = toInt(Seq.Get(parts, 14));
            bat.GIDP = toInt(Seq.Get(parts, 15));
            bat.doubles = toInt(Seq.Get(parts, 16));
            bat.triples = toInt(Seq.Get(parts, 17));
            bat.homeRuns = toInt(Seq.Get(parts, 18));
        } else if tag == "SPIT" {
            var pitch = currentTeam!.getSeasonPitching(toStr(Seq.Get(parts, 1)));
            pitch.games = toInt(Seq.Get(parts, 2));
            pitch.gamesStarted = toInt(Seq.Get(parts, 3));
            pitch.BF = toInt(Seq.Get(parts, 4));
            pitch.outsRecorded = toInt(Seq.Get(parts, 5));
            pitch.H = toInt(Seq.Get(parts, 6));
            pitch.R = toInt(Seq.Get(parts, 7));
            pitch.ER = toInt(Seq.Get(parts, 8));
            pitch.BB = toInt(Seq.Get(parts, 9));
            pitch.IBB = toInt(Seq.Get(parts, 10));
            pitch.SO = toInt(Seq.Get(parts, 11));
            pitch.HBP = toInt(Seq.Get(parts, 12));
            pitch.HR = toInt(Seq.Get(parts, 13));
            pitch.pitches = toInt(Seq.Get(parts, 14));
            pitch.strikes = toInt(Seq.Get(parts, 15));
            pitch.inheritedRunners = toInt(Seq.Get(parts, 16));
            pitch.inheritedRunnersScored = toInt(Seq.Get(parts, 17));
        } else if tag == "CGAME" {
            var record = new season_model.CompletedGameRecord();
            record.gameId = toStr(Seq.Get(parts, 1));
            record.dayNumber = toInt(Seq.Get(parts, 2));
            record.dateDays = toInt(Seq.Get(parts, 3));
            record.awayTeamId = toStr(Seq.Get(parts, 4));
            record.homeTeamId = toStr(Seq.Get(parts, 5));
            record.awayScore = toInt(Seq.Get(parts, 6));
            record.homeScore = toInt(Seq.Get(parts, 7));
            record.awayHits = toInt(Seq.Get(parts, 8));
            record.homeHits = toInt(Seq.Get(parts, 9));
            record.awayErrors = toInt(Seq.Get(parts, 10));
            record.homeErrors = toInt(Seq.Get(parts, 11));
            record.winningTeamId = toStr(Seq.Get(parts, 12));
            record.seed = toInt(Seq.Get(parts, 13));
            record.inningsPlayed = toInt(Seq.Get(parts, 14));
            record.summary = toStr(Seq.Get(parts, 15));
            var awayTeam = franchise!.getTeam(record.awayTeamId);
            var homeTeam = franchise!.getTeam(record.homeTeamId);
            record.awayTeamName = awayTeam!.teamRef.fullName;
            record.homeTeamName = homeTeam!.teamRef.fullName;
            record.ballparkName = homeTeam!.homePark.name;
            franchise!.completedGames.add(record);
        } else if tag == "OFFSEASON" {
            franchise!.offseasonHistory.add(toStr(Seq.Get(parts, 1)));
        }
    }

    loadCareerLines(rootPath, franchise!);
    loadDecisionLog(rootPath, seasonYear, franchise!);
    loadTransactionLog(rootPath, seasonYear, franchise!);
    loadCompletedGameDetails(rootPath, seasonYear, franchise!);

    result.ok = true;
    result.state = franchise;
    return result;
}

// Render the franchise.save header line. Format:
//   FRANCHISE|<id>|<league>|<year>|<seed>|<offseasons>|<injuryRng>|<devRng>|<txRng>|<nextGameNumber>
// The three RNG cursor fields are appended for plan-15 deterministic
// replay across saves; older save files without them load with zeros and
// SeasonEngine falls back to deriving from seed.
func renderFranchiseHeader(franchise: season_model.FranchiseState) -> String {
    return "FRANCHISE|" + franchise.franchiseId + "|" + franchise.leagueName + "|" +
           Fmt.Int(franchise.seasonYear) + "|" + Fmt.Int(franchise.seasonSeed) + "|" +
           Fmt.Int(franchise.completedOffseasons) + "|" +
           Fmt.Int(franchise.injuryRngState) + "|" +
           Fmt.Int(franchise.developmentRngState) + "|" +
           Fmt.Int(franchise.transactionRngState) + "|" +
           Fmt.Int(franchise.nextGameNumber) + "\n";
}

// Render the careers.txt content: one CAREER line per CareerLine in the
// franchise's career ledger.
func renderCareers(franchise: season_model.FranchiseState) -> String {
    var lines: List[String] = [];
    for i in 0..franchise.careerLines.length() {
        var line = franchise.careerLines.get(i);
        lines.add("CAREER|" + line.playerId + "|" + line.playerName + "|" +
                  Fmt.Int(line.seasonsCompleted) + "|" + Fmt.Int(line.PA) + "|" +
                  Fmt.Int(line.AB) + "|" + Fmt.Int(line.H) + "|" + Fmt.Int(line.HR) + "|" +
                  Fmt.Int(line.BB) + "|" + Fmt.Int(line.SO) + "|" +
                  Fmt.Int(line.outsRecorded) + "|" + Fmt.Int(line.ER) + "|" +
                  Fmt.Int(line.wins) + "|" + Fmt.Int(line.losses));
    }
    return renderStringList(lines);
}

// Render the season.save content: SEASON line (rules + calendar bounds),
// then DAY + GAME lines for the calendar, then per-team blocks (each team
// has TEAM + many PLAYER + REST + FATIGUE + INJURY + SBAT + SPIT lines),
// then CGAME lines for completed games, then OFFSEASON lines for the
// off-season history.
func renderSeason(franchise: season_model.FranchiseState) -> String {
    var lines: List[String] = [];
    lines.add("SEASON|" + Fmt.Int(franchise.rules.inningsPerGame) + "|" +
              boolText(franchise.rules.designatedHitterEnabled) + "|" +
              boolText(franchise.rules.extraInningsAutomaticRunnerEnabled) + "|" +
              boolText(franchise.rules.threeBatterMinimumEnabled) + "|" +
              Fmt.Int(franchise.rules.activeRosterSize) + "|" +
              Fmt.Int(franchise.rules.maxActivePitchers) + "|" +
              Fmt.Int(franchise.rules.minRotationSize) + "|" +
              Fmt.Int(franchise.rules.rotationGap) + "|" +
              Fmt.Int(franchise.rules.seasonGamesPerTeam) + "|" +
              Fmt.Int(franchise.rules.offDaysPerWeek) + "|" +
              Fmt.Int(franchise.calendar.startDateDays) + "|" +
              Fmt.Int(franchise.calendar.endDateDays) + "|" +
              Fmt.Int(franchise.calendar.currentDayIndex));
    for i in 0..franchise.calendar.days.length() {
        var day = franchise.calendar.days.get(i);
        lines.add("DAY|" + Fmt.Int(day.dateDays) + "|" + boolText(day.isOffDay) + "|" + day.label);
        for j in 0..day.scheduledGames.length() {
            var game = day.scheduledGames.get(j);
            lines.add("GAME|" + Fmt.Int(game.plannedGameNumber) + "|" + Fmt.Int(game.dateDays) + "|" +
                      game.homeTeamId + "|" + game.awayTeamId + "|" + game.ballparkName);
        }
    }
    for i in 0..franchise.teams.length() {
        appendTeam(lines, franchise.teams.get(i));
    }
    for i in 0..franchise.completedGames.length() {
        var game = franchise.completedGames.get(i);
        lines.add("CGAME|" + game.gameId + "|" + Fmt.Int(game.dayNumber) + "|" +
                  Fmt.Int(game.dateDays) + "|" + game.awayTeamId + "|" + game.homeTeamId + "|" +
                  Fmt.Int(game.awayScore) + "|" + Fmt.Int(game.homeScore) + "|" +
                  Fmt.Int(game.awayHits) + "|" + Fmt.Int(game.homeHits) + "|" +
                  Fmt.Int(game.awayErrors) + "|" + Fmt.Int(game.homeErrors) + "|" +
                  game.winningTeamId + "|" + Fmt.Int(game.seed) + "|" +
                  Fmt.Int(game.inningsPlayed) + "|" + game.summary);
    }
    for i in 0..franchise.offseasonHistory.length() {
        lines.add("OFFSEASON|" + franchise.offseasonHistory.get(i));
    }
    return renderStringList(lines);
}

// Append one team's full state to the season.save line buffer: a TEAM
// header line followed by PLAYER + REST + FATIGUE + INJURY + SBAT + SPIT
// lines for every player on the roster (active, IL, or minors).
func appendTeam(lines: List[String], teamState: season_model.TeamSeasonState) {
    lines.add("TEAM|" + teamState.teamRef.id + "|" + teamState.teamRef.city + "|" +
              teamState.teamRef.nickname + "|" + teamState.homePark.name + "|" +
              Fmt.Int(teamState.homePark.leftFieldDistance) + "|" +
              Fmt.Int(teamState.homePark.leftCenterDistance) + "|" +
              Fmt.Int(teamState.homePark.centerFieldDistance) + "|" +
              Fmt.Int(teamState.homePark.rightCenterDistance) + "|" +
              Fmt.Int(teamState.homePark.rightFieldDistance) + "|" +
              Fmt.Int(teamState.homePark.foulTerritoryClass) + "|" +
              Fmt.Int(teamState.homePark.infieldSpeed) + "|" +
              Fmt.Int(teamState.homePark.outfieldSpeed) + "|" +
              Fmt.Int(teamState.nextStarterIndex));

    for i in 0..teamState.rosterEntries.length() {
        var entry = teamState.rosterEntries.get(i);
        var p = entry.playerRef;
        lines.add("PLAYER|" + p.id + "|" + p.name + "|" + p.bats + "|" + p.throwsHand + "|" + p.primaryPosition +
                  "|" + Fmt.Int(p.birthYear) + "|" + Fmt.Int(p.birthMonth) + "|" + Fmt.Int(p.birthDay) +
                  "|" + Fmt.Int(p.zoneJudgment) + "|" + Fmt.Int(p.chaseResistance) + "|" + Fmt.Int(p.attackAggression) +
                  "|" + Fmt.Int(p.contact) + "|" + Fmt.Int(p.whiffAvoidance) + "|" + Fmt.Int(p.rawPower) +
                  "|" + Fmt.Int(p.gamePower) + "|" + Fmt.Int(p.hardContact) + "|" + Fmt.Int(p.groundBallTendency) +
                  "|" + Fmt.Int(p.lineDriveTendency) + "|" + Fmt.Int(p.flyBallTendency) + "|" +
                  Fmt.Int(p.pullTendency) + "|" + Fmt.Int(p.centerTendency) + "|" + Fmt.Int(p.oppositeFieldTendency) +
                  "|" + Fmt.Int(p.speed) + "|" + Fmt.Int(p.firstStep) + "|" + Fmt.Int(p.baserunningInstinct) +
                  "|" + Fmt.Int(p.stealJump) + "|" + Fmt.Int(p.stealSkill) + "|" +
                  Fmt.Int(p.starterRelieverProfile) + "|" + Fmt.Int(p.stamina) + "|" + Fmt.Int(p.stuff) +
                  "|" + Fmt.Int(p.control) + "|" + Fmt.Int(p.command) + "|" + Fmt.Int(p.movement) +
                  "|" + Fmt.Int(p.pitchMix) + "|" + Fmt.Int(p.holdRunners) + "|" + Fmt.Int(p.popUpInduction) +
                  "|" + Fmt.Int(p.range) + "|" + Fmt.Int(p.reaction) + "|" + Fmt.Int(p.hands) +
                  "|" + Fmt.Int(p.armStrength) + "|" + Fmt.Int(p.armAccuracy) + "|" + Fmt.Int(p.catcherFraming) +
                  "|" + Fmt.Int(p.catcherBlocking) + "|" + Fmt.Int(p.catcherPopTime) + "|" +
                  Fmt.Int(p.doublePlaySkill) + "|" + Fmt.Int(p.routeEfficiency) + "|" +
                  Fmt.Int(p.fatigueResistance) + "|" + Fmt.Int(p.injuryProneness) + "|" +
                  Fmt.Int(p.ceilingContact) + "|" + Fmt.Int(p.ceilingPower) + "|" +
                  Fmt.Int(p.ceilingDiscipline) + "|" + Fmt.Int(p.ceilingSpeed) + "|" +
                  Fmt.Int(p.ceilingDefense) + "|" + Fmt.Int(p.ceilingStuff) + "|" +
                  Fmt.Int(p.ceilingControl) + "|" + Fmt.Int(p.ceilingMovement) + "|" +
                  Fmt.Int(p.developmentVarianceTrait) + "|" + Fmt.Int(p.agingCurveProfile) + "|" +
                  entry.compartment + "|" + entry.roleTag);

        var rest = teamState.getPitcherRest(p.id);
        lines.add("REST|" + p.id + "|" + Fmt.Int(rest.daysSinceLastAppearance) + "|" +
                  Fmt.Int(rest.lastAppearancePitchCount) + "|" + Fmt.Int(rest.pitchesLast7Days) + "|" +
                  Fmt.Int(rest.appearancesLast7Days) + "|" + Fmt.Int(rest.daysSinceLastStart) + "|" +
                  Fmt.Int(rest.currentStintPitchCount) + "|" + Fmt.Int(rest.cumulativeSeasonPitches) + "|" +
                  Fmt.Int(rest.startsThisSeason) + "|" + Fmt.Int(rest.appearancesThisSeason));

        var fatigue = teamState.getFatigue(p.id);
        lines.add("FATIGUE|" + p.id + "|" + Fmt.Int(fatigue.gamesStartedConsecutive) + "|" +
                  Fmt.Int(fatigue.defensiveInningsLast7Days) + "|" +
                  Fmt.Int(fatigue.catcherStartsLast5Days) + "|" +
                  boolText(fatigue.startedPreviousDay) + "|" +
                  Fmt.Int(fatigue.startsThisSeason) + "|" + Fmt.Int(fatigue.gamesPlayedThisSeason));

        var injury = teamState.getInjury(p.id);
        lines.add("INJURY|" + p.id + "|" + Fmt.Int(injury.dayToDayDaysRemaining) + "|" +
                  injury.ilType + "|" + Fmt.Int(injury.ilEligibleDay) + "|" +
                  Fmt.Int(injury.ilReturnDay) + "|" + Fmt.Int(injury.priorLongIlCount));

        var batting = teamState.getSeasonBatting(p.id);
        lines.add("SBAT|" + p.id + "|" + Fmt.Int(batting.games) + "|" + Fmt.Int(batting.starts) + "|" +
                  Fmt.Int(batting.PA) + "|" + Fmt.Int(batting.AB) + "|" + Fmt.Int(batting.R) + "|" +
                  Fmt.Int(batting.H) + "|" + Fmt.Int(batting.RBI) + "|" + Fmt.Int(batting.BB) + "|" +
                  Fmt.Int(batting.IBB) + "|" + Fmt.Int(batting.SO) + "|" + Fmt.Int(batting.HBP) + "|" +
                  Fmt.Int(batting.SF) + "|" + Fmt.Int(batting.SH) + "|" + Fmt.Int(batting.GIDP) + "|" +
                  Fmt.Int(batting.doubles) + "|" + Fmt.Int(batting.triples) + "|" + Fmt.Int(batting.homeRuns));

        var pitching = teamState.getSeasonPitching(p.id);
        lines.add("SPIT|" + p.id + "|" + Fmt.Int(pitching.games) + "|" + Fmt.Int(pitching.gamesStarted) + "|" +
                  Fmt.Int(pitching.BF) + "|" + Fmt.Int(pitching.outsRecorded) + "|" + Fmt.Int(pitching.H) + "|" +
                  Fmt.Int(pitching.R) + "|" + Fmt.Int(pitching.ER) + "|" + Fmt.Int(pitching.BB) + "|" +
                  Fmt.Int(pitching.IBB) + "|" + Fmt.Int(pitching.SO) + "|" + Fmt.Int(pitching.HBP) + "|" +
                  Fmt.Int(pitching.HR) + "|" + Fmt.Int(pitching.pitches) + "|" + Fmt.Int(pitching.strikes) + "|" +
                  Fmt.Int(pitching.inheritedRunners) + "|" + Fmt.Int(pitching.inheritedRunnersScored));
    }
}

// Render the transaction_log.txt content: one TX line per
// TransactionRecord in the franchise's transaction log.
func renderTransactions(linesIn: List[season_model.TransactionRecord]) -> String {
    var lines: List[String] = [];
    for i in 0..linesIn.length() {
        var tx = linesIn.get(i);
        lines.add("TX|" + Fmt.Int(tx.dayNumber) + "|" + tx.teamId + "|" + tx.actionType + "|" +
                  tx.playerId + "|" + tx.fromCompartment + "|" + tx.toCompartment + "|" + tx.note);
    }
    return renderStringList(lines);
}

// Render one completed-game file (completed_games/gNNNN.txt) via the
// CompletedGameCodec. The per-game files intentionally carry more detail
// than the season.save CGAME summary line so loadFranchise can restore
// the digest and box lines as well.
func renderCompletedGame(record: season_model.CompletedGameRecord) -> String {
    var codec = new CompletedGameCodec();
    return codec.render(record);
}

// Parse the all-time careers.txt file (one CAREER line per player) and
// append every entry to franchise.careerLines. Skips silently if the file
// doesn't exist (a brand-new franchise saved before any season completed).
func loadCareerLines(rootPath: String, franchise: season_model.FranchiseState) {
    var careersPath = Path.Join(rootPath, "careers.txt");
    if !File.Exists(careersPath) {
        return;
    }
    var careersText = File.ReadAllText(careersPath);
    var careerLines = String.Split(careersText, "\n");
    for i in 0..Seq.get_Length(careerLines) {
        var line = String.Trim(toStr(Seq.Get(careerLines, i)));
        if line == "" {
            continue;
        }
        var parts = String.Split(line, "|");
        if toStr(Seq.Get(parts, 0)) != "CAREER" {
            continue;
        }
        var career = new season_model.CareerLine(toStr(Seq.Get(parts, 1)), toStr(Seq.Get(parts, 2)));
        career.seasonsCompleted = toInt(Seq.Get(parts, 3));
        career.PA = toInt(Seq.Get(parts, 4));
        career.AB = toInt(Seq.Get(parts, 5));
        career.H = toInt(Seq.Get(parts, 6));
        career.HR = toInt(Seq.Get(parts, 7));
        career.BB = toInt(Seq.Get(parts, 8));
        career.SO = toInt(Seq.Get(parts, 9));
        career.outsRecorded = toInt(Seq.Get(parts, 10));
        career.ER = toInt(Seq.Get(parts, 11));
        career.wins = toInt(Seq.Get(parts, 12));
        career.losses = toInt(Seq.Get(parts, 13));
        franchise.careerLines.add(career);
    }
}

// Restore the per-season manager decision log from the season's
// decision_log.txt file. Each line is opaque text — we don't parse the
// pipe-separated fields back, just round-trip the line strings.
func loadDecisionLog(rootPath: String, seasonYear: Integer,
                     franchise: season_model.FranchiseState) {
    var decisionPath = Path.Join(Path.Join(Path.Join(rootPath, "seasons"), Fmt.Int(seasonYear)), "decision_log.txt");
    if File.Exists(decisionPath) {
        franchise.managerDecisionLog = readStringLines(File.ReadAllText(decisionPath));
    }
}

// Restore the per-season transaction log. Each TX line is parsed into a
// fresh TransactionRecord and appended to franchise.transactionLog.
func loadTransactionLog(rootPath: String, seasonYear: Integer,
                        franchise: season_model.FranchiseState) {
    var transactionPath = Path.Join(Path.Join(Path.Join(rootPath, "seasons"), Fmt.Int(seasonYear)), "transaction_log.txt");
    if !File.Exists(transactionPath) {
        return;
    }
    var txLines = readStringLines(File.ReadAllText(transactionPath));
    for i in 0..txLines.length() {
        var txParts = String.Split(txLines.get(i), "|");
        if toStr(Seq.Get(txParts, 0)) != "TX" {
            continue;
        }
        franchise.transactionLog.add(new season_model.TransactionRecord(toInt(Seq.Get(txParts, 1)),
                                                                        toStr(Seq.Get(txParts, 2)),
                                                                        toStr(Seq.Get(txParts, 3)),
                                                                        toStr(Seq.Get(txParts, 4)),
                                                                        toStr(Seq.Get(txParts, 5)),
                                                                        toStr(Seq.Get(txParts, 6)),
                                                                        toStr(Seq.Get(txParts, 7))));
    }
}

// Walk every CompletedGameRecord that the season.save loader already put
// into franchise.completedGames and patch in the richer per-game detail
// (event digest, batting/pitching lines) by reading the matching
// completed_games/<gameId>.txt file via the CompletedGameCodec.
func loadCompletedGameDetails(rootPath: String, seasonYear: Integer,
                              franchise: season_model.FranchiseState) {
    var codec = new CompletedGameCodec();
    var completedDir = Path.Join(Path.Join(Path.Join(rootPath, "seasons"), Fmt.Int(seasonYear)), "completed_games");
    if !Dir.Exists(completedDir) {
        return;
    }
    for i in 0..franchise.completedGames.length() {
        var record = franchise.completedGames.get(i);
        var recordPath = Path.Join(completedDir, record.gameId + ".txt");
        if !File.Exists(recordPath) {
            continue;
        }
        codec.apply(record, File.ReadAllText(recordPath));
    }
}

// Parse one ABAT/HBAT line from a completed-game file into a
// CompletedBattingLine. The field order matches CompletedGameCodec.appendBatting.
func parseCompletedBatting(parts: Seq[String]) -> season_model.CompletedBattingLine {
    var line = new season_model.CompletedBattingLine(toStr(Seq.Get(parts, 1)), toStr(Seq.Get(parts, 2)));
    line.PA = toInt(Seq.Get(parts, 3));
    line.AB = toInt(Seq.Get(parts, 4));
    line.R = toInt(Seq.Get(parts, 5));
    line.H = toInt(Seq.Get(parts, 6));
    line.RBI = toInt(Seq.Get(parts, 7));
    line.BB = toInt(Seq.Get(parts, 8));
    line.IBB = toInt(Seq.Get(parts, 9));
    line.SO = toInt(Seq.Get(parts, 10));
    line.HBP = toInt(Seq.Get(parts, 11));
    line.SF = toInt(Seq.Get(parts, 12));
    line.SH = toInt(Seq.Get(parts, 13));
    line.GIDP = toInt(Seq.Get(parts, 14));
    line.doubles = toInt(Seq.Get(parts, 15));
    line.triples = toInt(Seq.Get(parts, 16));
    line.homeRuns = toInt(Seq.Get(parts, 17));
    return line;
}

// Parse one APIT/HPIT line from a completed-game file into a
// CompletedPitchingLine. The field order matches CompletedGameCodec.appendPitching.
func parseCompletedPitching(parts: Seq[String]) -> season_model.CompletedPitchingLine {
    var line = new season_model.CompletedPitchingLine(toStr(Seq.Get(parts, 1)), toStr(Seq.Get(parts, 2)));
    line.BF = toInt(Seq.Get(parts, 3));
    line.outsRecorded = toInt(Seq.Get(parts, 4));
    line.H = toInt(Seq.Get(parts, 5));
    line.R = toInt(Seq.Get(parts, 6));
    line.ER = toInt(Seq.Get(parts, 7));
    line.BB = toInt(Seq.Get(parts, 8));
    line.IBB = toInt(Seq.Get(parts, 9));
    line.SO = toInt(Seq.Get(parts, 10));
    line.HBP = toInt(Seq.Get(parts, 11));
    line.HR = toInt(Seq.Get(parts, 12));
    line.pitches = toInt(Seq.Get(parts, 13));
    line.strikes = toInt(Seq.Get(parts, 14));
    line.inheritedRunners = toInt(Seq.Get(parts, 15));
    line.inheritedRunnersScored = toInt(Seq.Get(parts, 16));
    return line;
}

// Helper: join a list of strings with newlines and append a trailing
// newline. Used by every render* function.
func renderStringList(lines: List[String]) -> String {
    var text = "";
    for i in 0..lines.length() {
        text = text + lines.get(i) + "\n";
    }
    return text;
}

// Helper: split a text blob into trimmed non-empty lines. Used to parse
// the decision and transaction logs back from disk.
func readStringLines(text: String) -> List[String] {
    var lines: List[String] = [];
    var parts = String.Split(text, "\n");
    for i in 0..Seq.get_Length(parts) {
        var line = String.Trim(toStr(Seq.Get(parts, i)));
        if line != "" {
            lines.add(line);
        }
    }
    return lines;
}

// Write a file atomically by writing to <path>.tmp, then replacing the
// final file via delete + move. Mitigates partial-write corruption from
// a mid-save crash. Plan 15 § Failure mode 5.
func writeAtomic(path: String, text: String) {
    Dir.MakeAll(Path.Dir(path));
    var tmp = path + ".tmp";
    File.WriteAllText(tmp, text);
    if File.Exists(path) {
        File.Delete(path);
    }
    File.Move(tmp, path);
}

// Helper: serialize a Boolean as the literal "true" or "false".
func boolText(value: Boolean) -> String {
    if value {
        return "true";
    }
    return "false";
}

// Helper: parse a Boolean from the literal "true" or "false". Anything
// else parses as false.
func toBool(text: String) -> Boolean {
    return toStr(text) == "true";
}

// Helper: identity function used as a documentation hook for Seq.Get
// returns. Kept as a no-op for clarity at call sites.
func toStr(value: String) -> String {
    return value;
}

// Helper: parse a (possibly negative) decimal integer from a trimmed
// string. Empty strings parse as 0; non-digit characters cause
// undefined behaviour but are not expected from our own writers.
func toInt(text: String) -> Integer {
    var trimmed = String.Trim(toStr(text));
    if trimmed == "" {
        return 0;
    }
    var negative = false;
    if String.StartsWith(trimmed, "-") {
        negative = true;
        trimmed = String.Substring(trimmed, 1, String.Length(trimmed) - 1);
    }
    var value = 0;
    for i in 0..String.Length(trimmed) {
        var ch = String.Substring(trimmed, i, 1);
        value = value * 10 + (String.Asc(ch) - 48);
    }
    if negative {
        return -value;
    }
    return value;
}
