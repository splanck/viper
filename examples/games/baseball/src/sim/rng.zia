// ============================================================================
// File: src/sim/rng.zia
// Purpose: Thin wrapper around the runtime's static `Viper.Math.Random` API
//          to give the single-game engine one obvious choke-point for all
//          random draws. Wrapping it (instead of inlining `Random.NextInt`
//          everywhere) means three things:
//
//          1. The whole single-game engine seeds from one place (`rng.seed`),
//             so a `viper run` of the demo is byte-for-byte deterministic
//             across runs.
//          2. Defensive guards on edge cases (NextInt(0), Range(min == max),
//             out-of-band percent values) live in one place rather than
//             scattered through callers.
//          3. The season layer's `season_rng.SeasonRng` class — which owns
//             persistent per-stream state for between-game RNG — is a
//             distinct object so the two RNG layers don't interfere.
//
//          The implementation is a thin static-state wrapper. Plan 02 §
//          Determinism and debugging is the design rationale.
// ============================================================================
module rng;

bind Viper.Math.Random as Random;

// Seed the global RNG. Called exactly once per game by game_engine.simulate
// from state.rngSeed.
func seed(value: Integer) {
    Random.Seed(value);
}

// Return a uniformly-random integer in [0, max). Returns 0 for non-positive
// max — a soft fallback so the engine never crashes on bad inputs.
func nextInt(max: Integer) -> Integer {
    if max <= 0 {
        return 0;
    }
    return Random.NextInt(max);
}

// Return a uniformly-random integer in [minValue, maxValue], inclusive on
// both ends. Degenerate ranges (max <= min) collapse to minValue.
func range(minValue: Integer, maxValue: Integer) -> Integer {
    if maxValue <= minValue {
        return minValue;
    }
    return minValue + Random.NextInt(maxValue - minValue + 1);
}

// Return true with `percent`% probability. percent is clamped to [0, 100];
// 0 always returns false, 100 always returns true.
func chance(percent: Integer) -> Boolean {
    if percent <= 0 {
        return false;
    }
    if percent >= 100 {
        return true;
    }
    return Random.NextInt(100) < percent;
}
