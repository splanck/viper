// ============================================================================
// File: src/sim/timing_model.zia
// Purpose: Pure-function timing helpers used by the batted-ball engine to
//          decide whether a fielder beats a runner to a base, whether an
//          outfielder reaches a fly ball before it lands, etc. Every value
//          is in milliseconds; the comparison happens in the caller.
//
//          The numbers are placeholders for v1 — calibrated against MLB
//          norms in plan 06's calibration pass. The shape (clamped linear
//          combinations of player ratings + ballpark factors) is what
//          matters: it's continuous, monotonic, and tunable without a
//          rewrite.
//
// Pure functions:
//          - clampInt: tiny helper, used to bound the various ms estimates.
//          - batterToFirstMs: time for a batter to run to first base.
//          - runnerBaseMs / runnerAdvanceMs: time for a runner to cover one
//            (or N) bases on a tag-up or read-and-go play.
//          - airInterceptMs: time for an outfielder/infielder to reach a
//            given air-ball intercept point with a given difficulty modifier.
//          - groundFieldMs: time to glove a grounder, accounting for the
//            ballpark's infield speed.
//          - throwMs: time for a fielder's throw to cover N feet.
//
// All functions accept a nullable Player (`Player?`) for the fielder so the
// caller can pass through the result of LineupCard.getFieldPlayer (which may
// be null in degenerate states); they return a sentinel large value (99999)
// when the fielder is missing so the comparison naturally fails.
// ============================================================================
module timing_model;

bind "../model/player";

// Clamp an integer to [minValue, maxValue]. Used internally for bounding the
// various ms estimates so they stay within sane ranges even when ratings are
// at the extremes.
func clampInt(value: Integer, minValue: Integer, maxValue: Integer) -> Integer {
    var v = value;
    if v < minValue { v = minValue; }
    if v > maxValue { v = maxValue; }
    return v;
}

// Estimated time for a batter to reach first base on a routine groundout, in
// milliseconds. Faster runners (high speed + first-step) get there sooner;
// the result is clamped to [3000, 4500] ms.
func batterToFirstMs(p: player.Player) -> Integer {
    return clampInt(4350 - p.speed * 10 - p.firstStep * 5, 3000, 4500);
}

// Estimated time for a runner already on base to advance one base, in
// milliseconds. Used internally by runnerAdvanceMs and (eventually) by the
// runner-advancement engine for race comparisons.
func runnerBaseMs(p: player.Player) -> Integer {
    return clampInt(3650 - p.speed * 8 - p.firstStep * 4, 2500, 3900);
}

// Estimated time to advance `bases` bases. Linear in the per-base time;
// realism passes can add a slight diminishing return for multi-base runs.
func runnerAdvanceMs(p: player.Player, bases: Integer) -> Integer {
    return runnerBaseMs(p) * bases;
}

// Estimated time for a fielder to reach an air-ball intercept point. Combines
// a reaction-time component (better reaction = faster start) with a movement
// component (range + route efficiency = faster cover) and a difficulty
// modifier from the ball type. Returns 99999 (unreachable) for null fielder.
func airInterceptMs(fielder: player.Player?, distanceFeet: Integer, difficulty: Integer) -> Integer {
    if fielder == null {
        return 99999;
    }
    var reaction = clampInt(850 - fielder!.reaction * 5, 260, 850);
    var speedScore = clampInt(70 + fielder!.range + fielder!.routeEfficiency, 70, 220);
    var moveMs = (distanceFeet * 1000) / speedScore;
    return reaction + moveMs + difficulty * 8;
}

// Estimated time for an infielder to glove a grounder cleanly. Combines
// reaction, hands, the exit velocity (faster grounder = bigger hop), the
// ballpark's infield speed (faster surface = bigger hop), and the play
// difficulty. Clamped to [450, 3600] ms. Returns 99999 for null fielder.
func groundFieldMs(fielder: player.Player?, exitVelocity: Integer, infieldSpeed: Integer, difficulty: Integer) -> Integer {
    if fielder == null {
        return 99999;
    }
    var reaction = clampInt(760 - fielder!.reaction * 4, 250, 760);
    var hands = clampInt(640 - fielder!.hands * 3, 220, 640);
    var hop = exitVelocity * 5 - infieldSpeed * 4;
    return clampInt(reaction + hands + hop + difficulty * 6, 450, 3600);
}

// Estimated time for a fielder's throw to cover a given distance, in
// milliseconds. Higher arm strength + accuracy = faster throw. The 250 ms
// constant is the transfer/setup time before the throw leaves the hand.
// Returns 99999 for null fielder.
func throwMs(fielder: player.Player?, distanceFeet: Integer) -> Integer {
    if fielder == null {
        return 99999;
    }
    var arm = clampInt(80 + fielder!.armStrength + fielder!.armAccuracy, 90, 240);
    return 250 + (distanceFeet * 900) / arm;
}
