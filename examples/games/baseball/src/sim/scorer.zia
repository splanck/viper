// ============================================================================
// File: src/sim/scorer.zia
// Purpose: The Scorer applies a finished PlayResult to game state. It is the
//          ONLY thing that mutates BattingLine, PitchingLine, score totals,
//          and the base state in response to a play. Every other engine
//          layer is allowed to read game state and produce PlayResults but
//          must route mutation through here.
//
//          This is the practical realization of plan 02 § Official Result
//          Builder + plan 02 § Scoring And Stats Engine. The runner_engine
//          builds the PlayResult; the Scorer applies it.
//
// Key invariants:
//          - Plate appearances always increment PA + BF.
//          - AB is incremented for outs, hits, errors, fielder's choices,
//            and strikeouts; it is NOT incremented for walks, HBP, sac
//            flies, or sac bunts.
//          - Earned-run accounting: a run is earned only if the half-inning
//            has not yet seen an error at the moment the run scores. The
//            currentHalfHadError flag (set inside this function on any
//            error) is the v1 coarse rule.
//          - Inherited-runner-scored is credited when a run scores whose
//            responsiblePitcher is NOT the current active pitcher.
//          - Bases are overwritten from result.postFirst/Second/Third —
//            the runner_engine has already done all the legwork; the Scorer
//            just installs the new state.
// Cross-refs:
//          - PlayResult is built by runner_engine.zia.
//          - GameState.currentHalfHadError is reset by game_engine.advanceHalfInning.
// ============================================================================
module scorer;

bind "../model/constants";
bind "../model/game_state";
bind "../model/play_result";

// The Scorer is a stateless service. It exists as a class purely so the
// game engine can hold one instance without re-allocating per call.
class Scorer {
    // Construct an empty scorer. No state to initialise.
    expose func init() { }

    // Apply a finished PlayResult to game state. Updates the batter's and
    // pitcher's stat lines, the team's score/hits/errors totals, the base
    // occupancy, the inning's earned-run flag, the out count, and finally
    // advances the batting order. Every PA in the engine routes through
    // here exactly once.
    expose func apply(state: game_state.GameState, result: play_result.PlayResult) {
        var offense = state.offense();
        var defense = state.defense();
        var batter = result.batter!;
        var pitcher = result.pitcher!;

        var batLine = offense.getBattingLine(batter);
        var pitchLine = defense.currentPitchingLine();

        // Plate appearance + batters faced + pitch counters always tick.
        batLine.PA = batLine.PA + 1;
        pitchLine.BF = pitchLine.BF + 1;
        pitchLine.pitches = pitchLine.pitches + result.pitchCount;
        pitchLine.strikes = pitchLine.strikes + result.strikePitchCount;
        pitchLine.outsRecorded = pitchLine.outsRecorded + result.outsAdded;
        defense.lineup.noteBatterFaced();

        // Walks and HBPs are NOT at-bats. Everything else is.
        if result.batterResultCode == constants.RESULT_WALK {
            batLine.BB = batLine.BB + 1;
            pitchLine.BB = pitchLine.BB + 1;
            if result.walkType == constants.WALK_INTENTIONAL {
                batLine.IBB = batLine.IBB + 1;
                pitchLine.IBB = pitchLine.IBB + 1;
            }
        } else if result.batterResultCode == constants.RESULT_HBP {
            batLine.HBP = batLine.HBP + 1;
            pitchLine.HBP = pitchLine.HBP + 1;
        } else {
            batLine.AB = batLine.AB + 1;
        }

        // Strikeouts are credited to both the batter and the pitcher even
        // when the batter reaches on an uncaught third strike — that's why
        // creditedStrikeouts is a separate field.
        if result.creditedStrikeouts > 0 {
            batLine.SO = batLine.SO + result.creditedStrikeouts;
            pitchLine.SO = pitchLine.SO + result.creditedStrikeouts;
        }

        // Hit accounting: team total + per-player + extra-base-type breakdown
        // + home runs charged to the pitcher.
        if result.isHit {
            offense.hits = offense.hits + 1;
            batLine.H = batLine.H + 1;
            pitchLine.H = pitchLine.H + 1;
            if result.hitBases == 2 { batLine.doubles = batLine.doubles + 1; }
            if result.hitBases == 3 { batLine.triples = batLine.triples + 1; }
            if result.hitBases == 4 {
                batLine.homeRuns = batLine.homeRuns + 1;
                pitchLine.HR = pitchLine.HR + 1;
            }
        }

        if result.isError {
            defense.errors = defense.errors + result.errorsCharged;
            // Mark the half-inning so any run that scores after this point
            // (including runs on this same play) is credited as unearned.
            // This is the coarse v1 ER rule; see GameState.currentHalfHadError.
            state.currentHalfHadError = true;
        }

        // Sacrifice flies and bunts swap an AB for an SF/SH credit (the
        // runner_engine already counted them as AB above; back it out here).
        if result.sacrificeType == constants.SAC_FLY {
            batLine.AB = batLine.AB - 1;
            batLine.SF = batLine.SF + 1;
        }
        if result.sacrificeType == constants.SAC_BUNT {
            batLine.AB = batLine.AB - 1;
            batLine.SH = batLine.SH + 1;
        }
        if result.isDoublePlay {
            batLine.GIDP = batLine.GIDP + 1;
        }

        batLine.RBI = batLine.RBI + result.RBIAwarded;

        // Apply each runner advance. Score scoring runs in the LINE SCORE
        // (not just the team total), credit R to the runner's batting line,
        // charge R + ER to the responsible pitcher, and bump
        // inheritedRunnersScored when a runner put on by a prior pitcher
        // crosses home.
        for i in 0..result.runnerAdvances.length() {
            var adv = result.runnerAdvances.get(i);
            if adv.scored {
                offense.addRun(state.inning);
                var runnerLine = offense.getBattingLine(adv.runner);
                runnerLine.R = runnerLine.R + 1;

                var charged = defense.getPitchingLine(adv.responsiblePitcher);
                charged.R = charged.R + 1;
                // Only credit an earned run if no error has occurred yet in
                // this half-inning. Once an error happens, all subsequent runs
                // are unearned under the v1 coarse rule.
                if !state.currentHalfHadError {
                    charged.ER = charged.ER + 1;
                }
                if adv.responsiblePitcher.id != pitcher.id {
                    pitchLine.inheritedRunnersScored = pitchLine.inheritedRunnersScored + 1;
                }
            }
        }

        // Install the post-PA base state and bump the out count + count
        // reset + batting order pointer.
        state.firstBase = result.postFirst;
        state.secondBase = result.postSecond;
        state.thirdBase = result.postThird;
        state.outs = state.outs + result.outsAdded;
        state.clearCount();
        offense.advanceBatter();
    }
}
