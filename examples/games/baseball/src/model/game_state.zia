// ============================================================================
// File: src/model/game_state.zia
// Purpose: Single-game state types — everything that lives during one game
//          and is reset between games. Owns:
//
//          - BaseOccupant: who is on a base + who put them there. The
//            responsiblePitcher field is the load-bearing piece for inherited-
//            runner accounting (plan 01 § BaseOccupant). A pitching change
//            updates the active pitcher but does NOT rewrite the
//            responsiblePitcher on existing occupants.
//          - BattingLine: per-player counting stats during one game. Reset
//            for each new game.
//          - PitchingLine: per-pitcher counting stats during one game,
//            including inherited runners and inherited runners scored.
//          - TeamGameState: one team's game-time state — lineup, batting and
//            pitching lines per player, the team's run total, hit total,
//            error total, and the per-inning line score.
//          - GameState: the top-level mutable state for one game. Owns the
//            count, outs, base occupancy, current batter/pitcher, both team
//            states, the event log, the per-inning ER tracking flag, and
//            the manager decision log.
//
// Key invariants:
//          - Stats live ONLY on BattingLine / PitchingLine, never on Player.
//          - GameState.currentHalfHadError is true for the rest of a half-
//            inning once any error happens. The scorer uses it to mark
//            subsequent runs as unearned. Reset by the game engine on
//            half-inning advance.
//          - GameState.managerDecisionLog accumulates per-game manager
//            decisions (pitching changes, intentional walks, non-default
//            pitch intents). The season layer captures these into the
//            franchise log via SeasonEngine.captureDecisionLog.
//          - At any moment exactly one of (firstBase, secondBase, thirdBase)
//            holds each runner — duplicates are an invariant violation.
// Cross-refs:
//          - scorer.apply mutates this state from PlayResult.
//          - game_engine.simulate owns the loop and validates start state.
//          - season_engine.absorbGame copies these stats into season totals.
// ============================================================================
module game_state;

bind "./player";
bind "./team";
bind "./lineup_card";
bind "./ruleset";
bind "./ballpark";

// Who is on a given base, plus who put them there. The responsiblePitcher
// field is what makes inherited-runner accounting tractable: when a runner
// scores, the scorer charges the run to this pitcher (not the current
// active pitcher) so a relief pitcher who came in mid-inning isn't charged
// for runs that the prior starter put on base.
class BaseOccupant {
    expose player.Player runner;
    expose player.Player responsiblePitcher;
    expose String reachedOnResult;

    // Construct a BaseOccupant. `how` is one of the RESULT_* / WALK_* /
    // END_UNCAUGHT_THIRD constants describing how the runner reached.
    expose func init(p: player.Player, rp: player.Player, how: String) {
        runner = p;
        responsiblePitcher = rp;
        reachedOnResult = how;
    }
}

// One player's per-game counting stats. Position is the slot they were
// assigned to in the starting lineup card; if substitutions are added later,
// the season layer will need to track per-stint position separately.
class BattingLine {
    expose player.Player playerRef;
    expose String position;
    expose Integer PA;
    expose Integer AB;
    expose Integer R;
    expose Integer H;
    expose Integer RBI;
    expose Integer BB;
    expose Integer IBB;
    expose Integer SO;
    expose Integer HBP;
    expose Integer SF;
    expose Integer SH;
    expose Integer GIDP;
    expose Integer doubles;
    expose Integer triples;
    expose Integer homeRuns;

    // Initialize a fresh batting line for one player at one position. All
    // counters start at 0.
    expose func init(p: player.Player, pos: String) {
        playerRef = p;
        position = pos;
        PA = 0;
        AB = 0;
        R = 0;
        H = 0;
        RBI = 0;
        BB = 0;
        IBB = 0;
        SO = 0;
        HBP = 0;
        SF = 0;
        SH = 0;
        GIDP = 0;
        doubles = 0;
        triples = 0;
        homeRuns = 0;
    }
}

// One pitcher's per-game counting stats. inheritedRunners and
// inheritedRunnersScored track the relief-pitcher accounting for runs put on
// base by a prior pitcher in the same inning.
class PitchingLine {
    expose player.Player playerRef;
    expose Integer BF;
    expose Integer outsRecorded;
    expose Integer H;
    expose Integer R;
    expose Integer ER;
    expose Integer BB;
    expose Integer IBB;
    expose Integer SO;
    expose Integer HBP;
    expose Integer HR;
    expose Integer pitches;
    expose Integer strikes;
    expose Integer inheritedRunners;
    expose Integer inheritedRunnersScored;

    // Initialize a fresh pitching line for one pitcher. All counters start
    // at 0.
    expose func init(p: player.Player) {
        playerRef = p;
        BF = 0;
        outsRecorded = 0;
        H = 0;
        R = 0;
        ER = 0;
        BB = 0;
        IBB = 0;
        SO = 0;
        HBP = 0;
        HR = 0;
        pitches = 0;
        strikes = 0;
        inheritedRunners = 0;
        inheritedRunnersScored = 0;
    }
}

// One team's per-game state: lineup, batting/pitching stat lines per player,
// per-inning line score, and team-level totals (score, hits, errors).
class TeamGameState {
    expose team.Team teamRef;
    expose lineup_card.LineupCard lineup;
    expose List[BattingLine] battingLines;
    expose List[PitchingLine] pitchingLines;
    expose List[Integer] lineScore;
    expose Integer score;
    expose Integer hits;
    expose Integer errors;

    // Initialize a fresh team game state. Pre-populates a BattingLine for
    // every player in the starting batting order and a PitchingLine for the
    // starting pitcher. Additional lines are created lazily on demand by
    // getBattingLine / getPitchingLine.
    expose func init(t: team.Team, lc: lineup_card.LineupCard) {
        teamRef = t;
        lineup = lc;
        battingLines = [];
        pitchingLines = [];
        lineScore = [];
        score = 0;
        hits = 0;
        errors = 0;

        for i in 0..lineup.battingOrder.length() {
            battingLines.add(new BattingLine(lineup.battingOrder.get(i), lineup.battingPositions.get(i)));
        }
        if lineup.activePitcher != null {
            pitchingLines.add(new PitchingLine(lineup.activePitcher!));
        }
    }

    // Return the player currently due to bat (delegates to the lineup card).
    expose func currentBatter() -> player.Player {
        return lineup.currentBatter();
    }

    // Advance the batting-order pointer one slot.
    expose func advanceBatter() {
        lineup.advanceBatter();
    }

    // Make sure the line score has at least `inning` entries, padding with
    // zeros if needed. Called before any add to a specific inning.
    expose func ensureInning(inning: Integer) {
        while lineScore.length() < inning {
            lineScore.add(0);
        }
    }

    // Credit one run to this team in the given inning. Updates both the
    // line score and the running team total.
    expose func addRun(inning: Integer) {
        self.ensureInning(inning);
        lineScore.set(inning - 1, lineScore.get(inning - 1) + 1);
        score = score + 1;
    }

    // Find or create the BattingLine for a player. Lazy creation handles the
    // case where a substitute enters the game (substitutions are not yet
    // implemented but the lookup is ready).
    expose func getBattingLine(p: player.Player) -> BattingLine {
        for i in 0..battingLines.length() {
            if battingLines.get(i).playerRef.id == p.id {
                return battingLines.get(i);
            }
        }
        var line = new BattingLine(p, p.primaryPosition);
        battingLines.add(line);
        return line;
    }

    // Find or create the PitchingLine for a pitcher. Lazy creation handles
    // pitching changes — when a relief pitcher enters, their line is created
    // here on first lookup.
    expose func getPitchingLine(p: player.Player) -> PitchingLine {
        for i in 0..pitchingLines.length() {
            if pitchingLines.get(i).playerRef.id == p.id {
                return pitchingLines.get(i);
            }
        }
        var line = new PitchingLine(p);
        pitchingLines.add(line);
        return line;
    }

    // Get the PitchingLine for the currently active pitcher.
    expose func currentPitchingLine() -> PitchingLine {
        return self.getPitchingLine(lineup.activePitcher!);
    }

    // Replace the active pitcher and credit any inherited runners. The
    // `inherited` count is the number of runners on base at the moment of
    // the change — those runners' responsiblePitcher fields are NOT touched
    // (that's what makes inherited-runner accounting work).
    expose func enterPitcher(p: player.Player, inherited: Integer) {
        lineup.setPitcher(p);
        var line = self.getPitchingLine(p);
        line.inheritedRunners = line.inheritedRunners + inherited;
    }
}

// Top-level mutable state for one game. Holds the rules, the park, both
// team states, the count, the base state, the active batter and pitcher,
// the event log, the per-half error tracker, the manager decision log,
// and the seed for deterministic replay.
class GameState {
    expose ruleset.Ruleset rules;
    expose ballpark.Ballpark park;
    expose TeamGameState away;
    expose TeamGameState home;

    expose Integer inning;
    expose Boolean topHalf;
    expose Integer outs;
    expose Integer balls;
    expose Integer strikes;

    expose BaseOccupant? firstBase;
    expose BaseOccupant? secondBase;
    expose BaseOccupant? thirdBase;

    expose player.Player? currentBatter;
    expose player.Player? currentPitcher;
    expose List[String] eventLog;
    expose List[String] managerDecisionLog;
    expose Integer rngSeed;

    // True for the rest of the current half-inning once any error occurs.
    // The scorer uses this to mark subsequent runs as unearned. This is the
    // coarse v1 approximation of MLB's earned-run rule (the precise rule
    // tracks "would have been the third out without errors", which requires
    // more bookkeeping than Phase 4 needs).
    expose Boolean currentHalfHadError;

    // Initialize a game state. The two team states are constructed by the
    // caller (the season engine or a single-game demo) before being passed
    // in. The seed is what makes single-game replay deterministic.
    expose func init(r: ruleset.Ruleset, p: ballpark.Ballpark,
                     awayState: TeamGameState, homeState: TeamGameState,
                     seed: Integer) {
        rules = r;
        park = p;
        away = awayState;
        home = homeState;
        inning = 1;
        topHalf = true;
        outs = 0;
        balls = 0;
        strikes = 0;
        firstBase = null;
        secondBase = null;
        thirdBase = null;
        currentBatter = null;
        currentPitcher = null;
        eventLog = [];
        managerDecisionLog = [];
        rngSeed = seed;
        currentHalfHadError = false;
    }

    // Return the team currently batting (away in the top half, home in the
    // bottom half).
    expose func offense() -> TeamGameState {
        if topHalf {
            return away;
        }
        return home;
    }

    // Return the team currently in the field (home in the top half, away
    // in the bottom half).
    expose func defense() -> TeamGameState {
        if topHalf {
            return home;
        }
        return away;
    }

    // Count of currently occupied bases. Used to compute "inherited runners"
    // when a pitching change happens.
    expose func baseCount() -> Integer {
        var total = 0;
        if firstBase != null { total = total + 1; }
        if secondBase != null { total = total + 1; }
        if thirdBase != null { total = total + 1; }
        return total;
    }

    // Reset the count to 0-0. Called between every plate appearance and at
    // the start of every half-inning.
    expose func clearCount() {
        balls = 0;
        strikes = 0;
    }

    // Clear all bases. Called between half-innings.
    expose func clearBases() {
        firstBase = null;
        secondBase = null;
        thirdBase = null;
    }
}
