// ============================================================================
// File: src/model/lineup_card.zia
// Purpose: The single-game LineupCard. Holds today's batting order, position
//          assignments, the active pitcher, and the bench/bullpen options the
//          manager may use during the game. Also owns the legality validator
//          that the engine calls before the first pitch (Phase 0 exit
//          criterion: "lineup cards validate for a legal starting game").
//
//          The LineupCard is the *daily* expression of personnel decisions.
//          It is constructed by the season-level manager layer from the
//          team's active roster compartments. The pool the card is drawn
//          from lives on TeamSeasonState in src/season/season_model.zia.
//
// Key invariants:
//          - battingOrder.length() == 9 for a legal lineup.
//          - activePitcher is non-null for a legal lineup.
//          - With DH on: a DH slot exists in battingPositions and the
//            pitcher is NOT in the batting order.
//          - With DH off: a DH slot does NOT exist and the pitcher IS in
//            the batting order at position POS_P.
//          - currentPitcherStintBatters tracks the modern three-batter
//            minimum rule from plans/01 § Ruleset.
// Cross-refs:
//          - manager_layer.SeasonTeamManager.submitPregameLineup builds
//            these. Plan 01 § LineupCard owns the design.
// ============================================================================
module lineup_card;

bind "./constants";
bind "./player";
bind "./team";
bind "./ruleset";

// One team's daily lineup. Built by the manager layer at the start of each
// game and validated before the first pitch.
class LineupCard {
    expose team.Team teamRef;
    expose List[player.Player] battingOrder;
    expose List[String] battingPositions;
    expose player.Player? activePitcher;
    expose List[player.Player] bench;
    expose List[player.Player] bullpen;
    expose Boolean dhEnabled;
    expose Integer battingIndex;
    expose Integer bullpenIndex;
    expose Integer currentPitcherStintBatters;

    // Construct an empty lineup card bound to a team and a DH setting. The
    // batting order, bench, bullpen, and pitcher choice are filled in by the
    // manager layer before the card is handed to the game engine.
    expose func init(t: team.Team, useDh: Boolean) {
        teamRef = t;
        battingOrder = [];
        battingPositions = [];
        activePitcher = null;
        bench = [];
        bullpen = [];
        dhEnabled = useDh;
        battingIndex = 0;
        bullpenIndex = 0;
        currentPitcherStintBatters = 0;
    }

    // Append a starter to the batting order at the given position. Caller is
    // responsible for adding all 9 starters in batting-order sequence.
    expose func addStarter(p: player.Player, position: String) {
        battingOrder.add(p);
        battingPositions.add(position);
    }

    // Add a player to the available bench pool. Bench players can enter as
    // pinch hitters, pinch runners, or defensive substitutes (substitution
    // mechanics themselves are deferred to a later phase).
    expose func addBench(p: player.Player) {
        bench.add(p);
    }

    // Add a relief pitcher to the bullpen queue. The bullpen is consumed in
    // FIFO order via pullNextReliever.
    expose func addBullpenArm(p: player.Player) {
        bullpen.add(p);
    }

    // Set the active pitcher and reset the three-batter-minimum counter to 0.
    // Called by both initial setup and pitching changes.
    expose func setPitcher(p: player.Player) {
        activePitcher = p;
        currentPitcherStintBatters = 0;
    }

    // Return the player currently due to bat. Wraps around when batting
    // through the order multiple times.
    expose func currentBatter() -> player.Player {
        return battingOrder.get(battingIndex);
    }

    // Advance the batting-order pointer. Wraps from slot 9 back to slot 1.
    // Called by the scorer at the end of every plate appearance.
    expose func advanceBatter() {
        battingIndex = battingIndex + 1;
        if battingIndex >= battingOrder.length() {
            battingIndex = 0;
        }
    }

    // Look up the player currently assigned to a fielding position. Returns
    // null if no one in the batting order is at that position. Used by the
    // batted-ball engine to find the fielder for routing.
    expose func getFieldPlayer(position: String) -> player.Player? {
        if position == constants.POS_P {
            return activePitcher;
        }
        for i in 0..battingOrder.length() {
            if battingPositions.get(i) == position {
                return battingOrder.get(i);
            }
        }
        return null;
    }

    // Increment the stint batter counter. Called by the scorer for every
    // completed plate appearance to enforce the three-batter minimum.
    expose func noteBatterFaced() {
        currentPitcherStintBatters = currentPitcherStintBatters + 1;
    }

    // Return true iff the active pitcher can be removed under the active
    // ruleset. The three-batter minimum says a relief pitcher must face at
    // least three batters (or end the half-inning) before they can be pulled.
    expose func canRemovePitcher(rules: ruleset.Ruleset) -> Boolean {
        if activePitcher == null {
            return false;
        }
        if !rules.threeBatterMinimumEnabled {
            return true;
        }
        return currentPitcherStintBatters >= 3;
    }

    // True iff there's at least one un-used relief pitcher remaining in the
    // bullpen queue. The bullpen is consumed in order; once exhausted, the
    // current pitcher must finish the game.
    expose func hasUnusedReliever() -> Boolean {
        return bullpenIndex < bullpen.length();
    }

    // Pop the next relief pitcher from the bullpen FIFO. Returns null if the
    // bullpen is empty. The caller is responsible for actually installing the
    // returned player as the active pitcher via setPitcher.
    expose func pullNextReliever() -> player.Player? {
        if bullpenIndex >= bullpen.length() {
            return null;
        }
        var p = bullpen.get(bullpenIndex);
        bullpenIndex = bullpenIndex + 1;
        return p;
    }

    // Phase 0 lineup-card legality. Returns true iff the card is structurally
    // valid for the start of a game:
    //   - exactly 9 batting slots AND 9 batting positions (parallel arrays)
    //   - active pitcher set
    //   - no duplicate players in the batting order
    //   - no duplicate positions in the batting order
    //   - all 8 fielding positions filled (C, 1B, 2B, 3B, SS, LF, CF, RF)
    //   - DH-on: a DH slot exists AND the pitcher is NOT in the batting order
    //   - DH-off: no DH slot AND the pitcher IS in the batting order
    // Wired into game_engine.simulate() so an invalid card aborts the game
    // before any play resolution runs.
    expose func validateStart() -> Boolean {
        if battingOrder.length() != 9 {
            return false;
        }
        if battingPositions.length() != 9 {
            return false;
        }
        if activePitcher == null {
            return false;
        }

        var hasC = false;
        var has1B = false;
        var has2B = false;
        var has3B = false;
        var hasSS = false;
        var hasLF = false;
        var hasCF = false;
        var hasRF = false;
        var hasDH = false;
        var pitcherInOrder = false;
        var seenPlayers: List[String] = [];
        var seenPositions: List[String] = [];

        for i in 0..battingPositions.length() {
            var pos = battingPositions.get(i);
            var pid = battingOrder.get(i).id;
            if self.hasString(seenPlayers, pid) {
                return false;
            }
            if self.hasString(seenPositions, pos) {
                return false;
            }
            seenPlayers.add(pid);
            seenPositions.add(pos);
            if pos == constants.POS_C { hasC = true; }
            if pos == constants.POS_1B { has1B = true; }
            if pos == constants.POS_2B { has2B = true; }
            if pos == constants.POS_3B { has3B = true; }
            if pos == constants.POS_SS { hasSS = true; }
            if pos == constants.POS_LF { hasLF = true; }
            if pos == constants.POS_CF { hasCF = true; }
            if pos == constants.POS_RF { hasRF = true; }
            if pos == constants.POS_DH { hasDH = true; }
            if battingOrder.get(i).id == activePitcher!.id { pitcherInOrder = true; }
        }

        if !(hasC && has1B && has2B && has3B && hasSS && hasLF && hasCF && hasRF) {
            return false;
        }
        // DH-on: a DH slot must exist, and the pitcher must NOT be in the batting order.
        if dhEnabled {
            if !hasDH {
                return false;
            }
            if pitcherInOrder {
                return false;
            }
        } else {
            // DH-off (NL-style): no DH slot allowed, and the pitcher must bat.
            if hasDH {
                return false;
            }
            if !pitcherInOrder {
                return false;
            }
        }
        return true;
    }

    // Linear-search helper for the validateStart duplicate checks. Returns
    // true iff `value` is already in `values`. Kept private since the only
    // caller is validateStart.
    hide func hasString(values: List[String], value: String) -> Boolean {
        for i in 0..values.length() {
            if values.get(i) == value {
                return true;
            }
        }
        return false;
    }
}
