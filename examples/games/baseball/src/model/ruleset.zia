// ============================================================================
// File: src/model/ruleset.zia
// Purpose: League-level rule configuration. Holds the knobs that control how
//          the engine should treat the game (DH on/off, innings per game,
//          three-batter minimum, roster cap, rotation gap, season length).
//          The defaults match modern MLB. Era-aware or fictional leagues can
//          construct a Ruleset and override fields without code changes.
// Key invariants:
//          - Defaults must reflect the modern MLB rule set so out-of-the-box
//            simulations look like real baseball.
//          - The Ruleset is read-only during a game; the engine never mutates
//            it once a game starts. The season layer may swap rulesets at
//            year boundaries.
// Cross-refs:
//          - LineupCard.validateStart consults dhEnabled.
//          - Game engine consults inningsPerGame for end-of-game logic.
//          - Season engine consults seasonGamesPerTeam, offDaysPerWeek,
//            rotationGap, activeRosterSize, and maxActivePitchers.
//          - Plan 11 § Active roster size and pitcher cap defines the roster
//            knobs; plan 10 § Calendar model defines the season knobs.
// ============================================================================
module ruleset;

// All league-level rule knobs that any phase of the engine consults. The
// defaults match modern MLB — change them on a fresh instance to model an
// alternate era or a fictional league.
class Ruleset {
    expose Integer inningsPerGame;
    expose Boolean designatedHitterEnabled;
    expose Boolean extraInningsAutomaticRunnerEnabled;
    expose Boolean threeBatterMinimumEnabled;
    expose Integer activeRosterSize;
    expose Integer maxActivePitchers;
    expose Integer minRotationSize;
    expose Integer rotationGap;
    expose Integer seasonGamesPerTeam;
    expose Integer offDaysPerWeek;

    // Initialise to modern MLB defaults: 9 innings, DH on, no extra-innings
    // automatic runner, three-batter minimum on, 26-man / 13-pitcher cap,
    // 5-man rotation, 4 days rest between starts, 54 games per team (to keep
    // the demo season short), 1 off-day per week.
    expose func init() {
        inningsPerGame = 9;
        designatedHitterEnabled = true;
        extraInningsAutomaticRunnerEnabled = false;
        threeBatterMinimumEnabled = true;
        activeRosterSize = 26;
        maxActivePitchers = 13;
        minRotationSize = 5;
        rotationGap = 4;
        seasonGamesPerTeam = 54;
        offDaysPerWeek = 1;
    }
}
