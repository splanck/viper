// ============================================================================
// File: src/output/play_by_play_writer.zia
// Purpose: Pure-formatting helpers that turn single-game state and PlayResult
//          objects into the human-readable text lines that the game engine
//          appends to GameState.eventLog. The writers are stateless functions
//          (not a class) — they read from passed-in state and never mutate.
//
//          Plan 02 § Output Adapters: this is the first of the canonical
//          three text adapters (play-by-play, line score, box score). The
//          play-by-play writer is the one the game engine consults during
//          play resolution; the other two are consulted by main.zia at the
//          end of the game.
// Functions:
//          - gameIntro: a 7-line banner emitted before the first inning.
//          - halfHeader: one-line "Top/Bottom N - <Team> batting" header.
//          - pitchingChange: one-line bullpen-change announcement.
//          - recordPA: the per-PA block: matchup line, indented pitch log,
//            play-text line, indented score + base/out summary.
//          - inningEnd / finalLine: half-inning and game-end markers.
//          - scoreSummary / outSummary / baseSummary: small helpers.
// ============================================================================
module play_by_play_writer;

bind Viper.Fmt as Fmt;
bind "../model/constants";
bind "../model/game_state";
bind "../model/player";
bind "../model/play_result";

// Build the seven-line game-intro banner: a separator, the demo title,
// another separator, the away-at-home matchup line, the ballpark name,
// the seed, and a blank line. Called once per game by GameEngine.simulate.
func gameIntro(state: game_state.GameState) -> List[String] {
    var lines: List[String] = [];
    lines.add("========================================");
    lines.add("  Viper Baseball Demo");
    lines.add("========================================");
    lines.add(state.away.teamRef.fullName + " at " + state.home.teamRef.fullName);
    lines.add("Ballpark: " + state.park.name);
    lines.add("Seed: " + Fmt.Int(state.rngSeed));
    lines.add("");
    return lines;
}

// Build the one-line "Top N - <Team> batting" header at the start of each
// half-inning. Called by GameEngine at the top of every half-inning loop.
func halfHeader(state: game_state.GameState) -> String {
    var half = "Top";
    var club = state.away.teamRef.fullName;
    if !state.topHalf {
        half = "Bottom";
        club = state.home.teamRef.fullName;
    }
    return half + " " + Fmt.Int(state.inning) + " - " + club + " batting";
}

// Build the bullpen-change announcement line: "<Team> goes to the bullpen:
// <old> out, <new> in (N inherited runners)". The inherited-runner suffix
// is omitted when N == 0 and pluralised correctly otherwise.
func pitchingChange(teamName: String, oldPitcher: player.Player,
                    newPitcher: player.Player, inherited: Integer) -> String {
    var line = teamName + " goes to the bullpen: " + oldPitcher.name + " out, " + newPitcher.name + " in";
    if inherited > 0 {
        line = line + " (" + Fmt.Int(inherited) + " inherited runner";
        if inherited != 1 {
            line = line + "s";
        }
        line = line + ")";
    }
    return line;
}

// Build the per-PA narration block. First line is "Batter vs Pitcher".
// Subsequent indented lines are the per-pitch log accumulated during the
// PA. Then a play-text line (e.g. "  Smith singles to center."). Then a
// score summary and a base/out summary. Returns the block as a List[String]
// so the engine can append it whole to the event log.
func recordPA(state: game_state.GameState, result: play_result.PlayResult) -> List[String] {
    var lines: List[String] = [];
    lines.add(result.batter!.name + " vs " + result.pitcher!.name);
    for i in 0..result.pitchLog.length() {
        lines.add("  " + result.pitchLog.get(i));
    }
    lines.add("  " + result.playText + ".");
    lines.add("  Score: " + scoreSummary(state));
    lines.add("  " + baseSummary(state) + ", " + outSummary(state.outs));
    return lines;
}

// Build the "End Top/Bottom N: Captains 4, Stags 7" line at the end of
// every half-inning.
func inningEnd(state: game_state.GameState) -> String {
    var half = "Top";
    if !state.topHalf {
        half = "Bottom";
    }
    return "End " + half + " " + Fmt.Int(state.inning) + ": " + scoreSummary(state);
}

// Build the "Final: Captains 4, Stags 7" line at the end of the game.
func finalLine(state: game_state.GameState) -> String {
    return "Final: " + scoreSummary(state);
}

// Compose the running score string in nickname form, e.g.
// "Captains 4, Stags 7".
func scoreSummary(state: game_state.GameState) -> String {
    return state.away.teamRef.nickname + " " + Fmt.Int(state.away.score) +
           ", " + state.home.teamRef.nickname + " " + Fmt.Int(state.home.score);
}

// Format the out count as "1 out" or "N outs" (handling the singular).
func outSummary(outs: Integer) -> String {
    if outs == 1 { return "1 out"; }
    return Fmt.Int(outs) + " outs";
}

// Compose the current base-state string for the post-PA summary line.
// Combinations like "Runner on first, runner on third" or "Bases empty"
// are built by concatenation; nothing fancier is needed yet.
func baseSummary(state: game_state.GameState) -> String {
    if state.firstBase == null && state.secondBase == null && state.thirdBase == null {
        return "Bases empty";
    }

    var text = "";
    if state.firstBase != null {
        text = "Runner on first";
    }
    if state.secondBase != null {
        if text != "" { text = text + ", "; }
        text = text + "runner on second";
    }
    if state.thirdBase != null {
        if text != "" { text = text + ", "; }
        text = text + "runner on third";
    }
    return text;
}
