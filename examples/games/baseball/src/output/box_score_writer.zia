// ============================================================================
// File: src/output/box_score_writer.zia
// Purpose: Render the post-game box score as text. Two top-level views,
//          one per team:
//
//          - renderTeamBatting: a row per batter with AB R H RBI BB SO.
//          - renderTeamPitching: a row per pitcher with IP H R ER BB SO P-S.
//
//          IP is rendered as "X.Y" where Y is the partial-inning third
//          (1/3 or 2/3). P-S is the pitches/strikes split.
// ============================================================================
module box_score_writer;

bind Viper.Fmt as Fmt;
bind "../model/game_state";

// Build the team's batting box as a List[String]. Header line plus one
// row per BattingLine. Player names are padded to a fixed 18 characters
// for column alignment.
func renderTeamBatting(teamState: game_state.TeamGameState) -> List[String] {
    var lines: List[String] = [];
    lines.add(teamState.teamRef.fullName + " Batting");
    lines.add("Player              AB  R  H RBI BB SO");
    for i in 0..teamState.battingLines.length() {
        var line = teamState.battingLines.get(i);
        var name = line.playerRef.name;
        while name.length() < 18 {
            name = name + " ";
        }
        var row = name;
        row = row + Fmt.IntPad(line.AB, 4, " ");
        row = row + Fmt.IntPad(line.R, 3, " ");
        row = row + Fmt.IntPad(line.H, 3, " ");
        row = row + Fmt.IntPad(line.RBI, 4, " ");
        row = row + Fmt.IntPad(line.BB, 3, " ");
        row = row + Fmt.IntPad(line.SO, 3, " ");
        lines.add(row);
    }
    return lines;
}

// Build the team's pitching box as a List[String]. Header line plus one
// row per PitchingLine. The IP column converts outsRecorded into the
// traditional "X.Y" innings notation; the P-S column shows total pitches
// and strikes thrown.
func renderTeamPitching(teamState: game_state.TeamGameState) -> List[String] {
    var lines: List[String] = [];
    lines.add(teamState.teamRef.fullName + " Pitching");
    lines.add("Pitcher             IP   H  R ER BB SO P-S");
    for i in 0..teamState.pitchingLines.length() {
        var line = teamState.pitchingLines.get(i);
        var name = line.playerRef.name;
        while name.length() < 18 {
            name = name + " ";
        }
        var row = name;
        row = row + ipText(line.outsRecorded);
        row = row + Fmt.IntPad(line.H, 4, " ");
        row = row + Fmt.IntPad(line.R, 3, " ");
        row = row + Fmt.IntPad(line.ER, 3, " ");
        row = row + Fmt.IntPad(line.BB, 3, " ");
        row = row + Fmt.IntPad(line.SO, 3, " ");
        row = row + " " + Fmt.Int(line.pitches) + "-" + Fmt.Int(line.strikes);
        lines.add(row);
    }
    return lines;
}

// Convert an integer "outs recorded" total into a baseball-style innings-
// pitched string. 7 outs becomes "2.1" (2 full innings + 1 out); 22 outs
// becomes "7.1". Right-padded to 5 characters for column alignment.
func ipText(outsRecorded: Integer) -> String {
    var whole = outsRecorded / 3;
    var rem = outsRecorded % 3;
    var text = Fmt.Int(whole) + "." + Fmt.Int(rem);
    while text.length() < 5 {
        text = " " + text;
    }
    return text;
}
