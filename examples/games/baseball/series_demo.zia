// ============================================================================
// File: examples/games/baseball/series_demo.zia
// Purpose: Demo program that builds two 25-player teams with proper positional
//          structure (2 catchers, 8 position-player starters + 1 DH, 3 bench,
//          5 starting pitchers, 7 relievers — 25 each), plays a 3-game series
//          between them, and prints the full line score plus a detailed
//          batting box and pitching box for each team after every game. A
//          short series summary line follows the last box score.
//
//          Both teams share a single 9-inning ruleset with the DH on. All
//          three games are played at Stonecreek Yards (the home team's park).
//          Each team rotates through its top three starting pitchers across
//          the series so the rotation shows up in the box scores.
//
// Run via: viper run examples/games/baseball/series_demo.zia
// ============================================================================
module series_demo;

bind Viper.Terminal as Terminal;
bind Viper.Text.Fmt as Fmt;
bind "./src/model/constants";
bind "./src/model/player";
bind "./src/model/team";
bind "./src/model/lineup_card";
bind "./src/model/ruleset";
bind "./src/model/ballpark";
bind "./src/model/game_state";
bind "./src/sim/game_engine";
bind "./src/output/box_score_writer";
bind "./src/output/line_score_writer";

// --- Player builders --------------------------------------------------------
// Compact constructors that wrap player.setHitting/setRunning/setPitching/
// setDefense/setDurability with the most-needed-for-tuning parameters in
// front. Tendency triplets and the latent profile fields fall through to
// defaults (sufficient — the off-season development tick never runs in
// single-game probes).

// Position player. Param order is the most-tuned fields: contact, power,
// patience, speed, defense, arm. The hitting tendency triplets default to
// balanced (34/33/33) and durability is mid-range.
func mkBatter(id: String, name: String, bats: String, throwsHand: String,
              position: String, contact: Integer, power: Integer,
              patience: Integer, speed: Integer, defense: Integer,
              arm: Integer) -> player.Player {
    var p = new player.Player(id, name, bats, throwsHand, position);
    p.setHitting(patience, patience, 48, contact, contact, power, power, power,
                 34, 33, 33, 34, 33, 33);
    p.setRunning(speed, speed, speed, 45, 45);
    p.setPitching(20, 20, 20, 20, 20, 20, 20, 20, 20);
    p.setDefense(defense, defense, defense, arm, arm, 50, 50, 50, defense, defense);
    p.setDurability(55, 45);
    return p;
}

// Catcher. Same shape as mkBatter but overwrites the defense block with
// catcher-specific values (framing, blocking, pop time) after construction.
// Speed is fixed-low to match a typical catcher profile.
func mkCatcher(id: String, name: String, bats: String, throwsHand: String,
               contact: Integer, power: Integer, patience: Integer) -> player.Player {
    var p = mkBatter(id, name, bats, throwsHand, constants.POS_C,
                     contact, power, patience, 35, 60, 65);
    p.setDefense(52, 56, 62, 68, 65, 60, 62, 66, 55, 40);
    return p;
}

// Pitcher. Hitting / running / defense are pegged low; the pitching family
// is fully parameterised. roleProfile is the starter/reliever indicator
// (high values are starter-shaped, low values are reliever-shaped).
func mkPitcher(id: String, name: String, bats: String, throwsHand: String,
               roleProfile: Integer, stamina: Integer, stuff: Integer,
               control: Integer, command: Integer, movement: Integer) -> player.Player {
    var p = new player.Player(id, name, bats, throwsHand, constants.POS_P);
    p.setHitting(18, 18, 30, 18, 18, 20, 20, 20, 40, 25, 35, 34, 33, 33);
    p.setRunning(25, 25, 35, 20, 20);
    p.setPitching(roleProfile, stamina, stuff, control, command, movement, 60, 55, 55);
    p.setDefense(50, 54, 55, 52, 55, 0, 0, 0, 45, 40);
    p.setDurability(70, 40);
    return p;
}

// --- Roster container -------------------------------------------------------
// Holds a team's static 25-player roster: 9 lineup starters (with parallel
// position list), 4 bench players, 5 starting pitchers, 7 relievers. The
// Team object inside is reused for all 3 games; only the per-game LineupCard
// and TeamGameState wrappers get rebuilt between games.
class TeamRoster {
    expose team.Team teamRef;
    expose List[player.Player] starters;
    expose List[String] starterPositions;
    expose List[player.Player] bench;
    expose List[player.Player] rotation;
    expose List[player.Player] bullpen;

    expose func init(t: team.Team) {
        teamRef = t;
        starters = [];
        starterPositions = [];
        bench = [];
        rotation = [];
        bullpen = [];
    }
}

// Add every player on a roster to the underlying Team's static player pool.
// This is the canonical "Player belongs to organization" registration; the
// per-game LineupCard then re-references these same Player objects.
func registerAllPlayers(r: TeamRoster) {
    for i in 0..r.starters.length() { r.teamRef.addPlayer(r.starters.get(i)); }
    for i in 0..r.bench.length()    { r.teamRef.addPlayer(r.bench.get(i)); }
    for i in 0..r.rotation.length() { r.teamRef.addPlayer(r.rotation.get(i)); }
    for i in 0..r.bullpen.length()  { r.teamRef.addPlayer(r.bullpen.get(i)); }
}

// --- Team factories ---------------------------------------------------------

// Bayport Mariners: pitching-and-defense identity. Strong rotation, athletic
// up-the-middle defense, average power, above-average speed. 25 players:
// 2 catchers, 8 position-player starters + 1 DH, 3 bench, 5 SP, 7 RP.
func buildMariners() -> TeamRoster {
    var t = new team.Team("bayport", "Bayport", "Mariners");
    var r = new TeamRoster(t);

    // Starting nine (ordered by lineup spot 1..9 below in addStarter calls).
    var c   = mkCatcher("bay_c1",  "Leo Morales",   "R", "R", 58, 50, 60);
    var b1  = mkBatter ("bay_1b",  "Ryan Holt",     "L", "R", constants.POS_1B, 60, 64, 58, 38, 52, 50);
    var b2  = mkBatter ("bay_2b",  "Mason Webb",    "R", "R", constants.POS_2B, 66, 42, 60, 74, 70, 56);
    var b3  = mkBatter ("bay_3b",  "Cal Brewer",    "R", "R", constants.POS_3B, 58, 60, 53, 50, 58, 65);
    var ss  = mkBatter ("bay_ss",  "Nico Cruz",     "S", "R", constants.POS_SS, 68, 44, 62, 70, 74, 62);
    var lf  = mkBatter ("bay_lf",  "Jace Mercer",   "L", "L", constants.POS_LF, 60, 58, 54, 60, 58, 60);
    var cf  = mkBatter ("bay_cf",  "Dante Fields",  "R", "R", constants.POS_CF, 64, 48, 58, 82, 78, 64);
    var rf  = mkBatter ("bay_rf",  "Eli Santos",    "L", "L", constants.POS_RF, 62, 62, 56, 62, 62, 68);
    var dh  = mkBatter ("bay_dh",  "Ty Brooks",     "R", "R", constants.POS_DH, 64, 66, 60, 35, 30, 40);

    r.starters.add(cf); r.starterPositions.add(constants.POS_CF);
    r.starters.add(ss); r.starterPositions.add(constants.POS_SS);
    r.starters.add(rf); r.starterPositions.add(constants.POS_RF);
    r.starters.add(b1); r.starterPositions.add(constants.POS_1B);
    r.starters.add(dh); r.starterPositions.add(constants.POS_DH);
    r.starters.add(lf); r.starterPositions.add(constants.POS_LF);
    r.starters.add(b3); r.starterPositions.add(constants.POS_3B);
    r.starters.add(c);  r.starterPositions.add(constants.POS_C);
    r.starters.add(b2); r.starterPositions.add(constants.POS_2B);

    // Bench: backup catcher, utility infielder, fourth outfielder, bench bat.
    r.bench.add(mkCatcher("bay_c2",   "Avery Quinn",    "R", "R", 45, 38, 48));
    r.bench.add(mkBatter ("bay_util", "Drew Lansing",   "S", "R", constants.POS_SS, 52, 40, 54, 62, 62, 56));
    r.bench.add(mkBatter ("bay_of4",  "Cody Hahn",      "L", "L", constants.POS_CF, 50, 44, 50, 74, 64, 58));
    r.bench.add(mkBatter ("bay_bb",   "Hugo Iverson",   "R", "R", constants.POS_1B, 48, 60, 46, 30, 40, 42));

    // Rotation (5): top-end stuff and control, strong stamina.
    r.rotation.add(mkPitcher("bay_sp1", "Adrian Pike",     "R", "R", 82, 76, 70, 64, 66, 65));
    r.rotation.add(mkPitcher("bay_sp2", "Jorge Vidal",     "L", "L", 80, 74, 66, 62, 64, 62));
    r.rotation.add(mkPitcher("bay_sp3", "Noah Briggs",     "R", "R", 78, 72, 64, 60, 62, 61));
    r.rotation.add(mkPitcher("bay_sp4", "Tomas Errazuriz", "R", "R", 76, 70, 62, 59, 60, 60));
    r.rotation.add(mkPitcher("bay_sp5", "Wyatt Lin",       "L", "L", 72, 66, 60, 56, 58, 58));

    // Bullpen (7): 1 long, 2 middle, 2 setup, 1 closer, 1 swingman.
    r.bullpen.add(mkPitcher("bay_lr",  "Joel Vance",     "R", "R", 42, 50, 60, 56, 58, 58));
    r.bullpen.add(mkPitcher("bay_mr1", "Marco King",     "L", "L", 32, 36, 70, 56, 58, 60));
    r.bullpen.add(mkPitcher("bay_mr2", "Otis Frey",      "R", "R", 30, 34, 71, 55, 56, 59));
    r.bullpen.add(mkPitcher("bay_su1", "Owen Slate",     "R", "R", 24, 30, 74, 58, 60, 64));
    r.bullpen.add(mkPitcher("bay_su2", "Pete Iglesias",  "L", "L", 24, 30, 75, 56, 58, 63));
    r.bullpen.add(mkPitcher("bay_cl",  "Rex Maddox",     "R", "R", 20, 26, 80, 58, 60, 66));
    r.bullpen.add(mkPitcher("bay_sw",  "Sven Yates",     "R", "R", 48, 52, 62, 55, 56, 58));

    registerAllPlayers(r);
    return r;
}

// Stonecreek Rangers: power-hitting identity. Big bats top to bottom, league-
// average pitching, less athletic in the field. 25 players, same shape.
func buildRangers() -> TeamRoster {
    var t = new team.Team("stonecreek", "Stonecreek", "Rangers");
    var r = new TeamRoster(t);

    var c   = mkCatcher("stn_c1",  "Hank Robles",    "R", "R", 56, 60, 54);
    var b1  = mkBatter ("stn_1b",  "Grant Morrow",   "R", "L", constants.POS_1B, 58, 76, 56, 32, 48, 50);
    var b2  = mkBatter ("stn_2b",  "Parker West",    "L", "R", constants.POS_2B, 62, 50, 58, 68, 64, 54);
    var b3  = mkBatter ("stn_3b",  "Cole Bennett",   "R", "R", constants.POS_3B, 60, 70, 54, 44, 54, 62);
    var ss  = mkBatter ("stn_ss",  "Ilan Reyes",     "S", "R", constants.POS_SS, 64, 54, 58, 62, 66, 56);
    var lf  = mkBatter ("stn_lf",  "Noah Vale",      "L", "L", constants.POS_LF, 60, 68, 52, 50, 52, 54);
    var cf  = mkBatter ("stn_cf",  "Trent Holloway", "R", "R", constants.POS_CF, 60, 56, 54, 74, 68, 58);
    var rf  = mkBatter ("stn_rf",  "Miles Rowan",    "L", "L", constants.POS_RF, 62, 74, 56, 52, 58, 64);
    var dh  = mkBatter ("stn_dh",  "Hudson Price",   "R", "R", constants.POS_DH, 62, 78, 58, 28, 28, 38);

    r.starters.add(cf); r.starterPositions.add(constants.POS_CF);
    r.starters.add(b2); r.starterPositions.add(constants.POS_2B);
    r.starters.add(rf); r.starterPositions.add(constants.POS_RF);
    r.starters.add(b1); r.starterPositions.add(constants.POS_1B);
    r.starters.add(b3); r.starterPositions.add(constants.POS_3B);
    r.starters.add(dh); r.starterPositions.add(constants.POS_DH);
    r.starters.add(lf); r.starterPositions.add(constants.POS_LF);
    r.starters.add(c);  r.starterPositions.add(constants.POS_C);
    r.starters.add(ss); r.starterPositions.add(constants.POS_SS);

    r.bench.add(mkCatcher("stn_c2",   "Pablo Inza",   "L", "R", 48, 40, 50));
    r.bench.add(mkBatter ("stn_util", "Sammy Hart",   "R", "R", constants.POS_SS, 50, 46, 52, 60, 60, 56));
    r.bench.add(mkBatter ("stn_of4",  "Ezra Park",    "L", "L", constants.POS_CF, 48, 50, 48, 72, 60, 58));
    r.bench.add(mkBatter ("stn_bb",   "Theo Vaughn",  "R", "R", constants.POS_1B, 50, 64, 48, 28, 38, 42));

    r.rotation.add(mkPitcher("stn_sp1", "Ben Harrow",      "L", "L", 80, 74, 64, 60, 62, 62));
    r.rotation.add(mkPitcher("stn_sp2", "Chase Donovan",   "R", "R", 78, 70, 62, 58, 60, 60));
    r.rotation.add(mkPitcher("stn_sp3", "Diego Pinheiro",  "R", "R", 76, 68, 60, 56, 58, 58));
    r.rotation.add(mkPitcher("stn_sp4", "Emmet Riggs",     "L", "L", 74, 66, 58, 55, 56, 56));
    r.rotation.add(mkPitcher("stn_sp5", "Fox Lambert",     "R", "R", 70, 62, 56, 54, 55, 55));

    r.bullpen.add(mkPitcher("stn_lr",  "Chris Vale",    "R", "R", 40, 48, 58, 55, 56, 57));
    r.bullpen.add(mkPitcher("stn_mr1", "Luca Drake",    "R", "R", 30, 34, 70, 53, 55, 60));
    r.bullpen.add(mkPitcher("stn_mr2", "Marv Bennett",  "L", "L", 28, 32, 69, 52, 54, 58));
    r.bullpen.add(mkPitcher("stn_su1", "Sam Keene",     "L", "L", 24, 28, 76, 58, 60, 65));
    r.bullpen.add(mkPitcher("stn_su2", "Toby Park",     "R", "R", 22, 28, 78, 57, 59, 64));
    r.bullpen.add(mkPitcher("stn_cl",  "Uri Mossberg",  "R", "R", 18, 24, 82, 60, 62, 68));
    r.bullpen.add(mkPitcher("stn_sw",  "Yannik Reese",  "R", "R", 46, 50, 60, 54, 55, 56));

    registerAllPlayers(r);
    return r;
}

// --- Per-game wiring --------------------------------------------------------

// Build a fresh LineupCard for one game. Uses `rotation[startIdx]` as the
// starting pitcher and queues the remaining rotation arms behind the bullpen
// as emergency long relief. Every bench player is registered so the engine
// has them available for substitutions.
func buildLineupCard(r: TeamRoster, useDh: Boolean, startIdx: Integer) -> lineup_card.LineupCard {
    var lc = new lineup_card.LineupCard(r.teamRef, useDh);
    for i in 0..r.starters.length() {
        lc.addStarter(r.starters.get(i), r.starterPositions.get(i));
    }
    for i in 0..r.bench.length() {
        lc.addBench(r.bench.get(i));
    }
    lc.setPitcher(r.rotation.get(startIdx));
    for i in 0..r.bullpen.length() {
        lc.addBullpenArm(r.bullpen.get(i));
    }
    // Remaining rotation arms sit behind the bullpen as emergency long relief.
    for i in 0..r.rotation.length() {
        if i != startIdx {
            lc.addBullpenArm(r.rotation.get(i));
        }
    }
    return lc;
}

// Wire one game end-to-end: build the ruleset, the park, both lineup cards,
// both team game-state wrappers, and the top-level GameState. The same Team
// (and the same Player objects) are reused across all 3 games — only the
// LineupCard and TeamGameState wrappers are fresh per game so per-game stats
// reset cleanly.
func buildGameState(away: TeamRoster, home: TeamRoster,
                    startIdxA: Integer, startIdxH: Integer,
                    seed: Integer) -> game_state.GameState {
    var rules = new ruleset.Ruleset();
    var park = new ballpark.Ballpark("Stonecreek Yards", 330, 374, 402, 380, 329);
    park.foulTerritoryClass = 48;
    park.infieldSpeed = 52;
    park.outfieldSpeed = 51;
    var awayCard = buildLineupCard(away, rules.designatedHitterEnabled, startIdxA);
    var homeCard = buildLineupCard(home, rules.designatedHitterEnabled, startIdxH);
    var awayTGS = new game_state.TeamGameState(away.teamRef, awayCard);
    var homeTGS = new game_state.TeamGameState(home.teamRef, homeCard);
    return new game_state.GameState(rules, park, awayTGS, homeTGS, seed);
}

// --- Output -----------------------------------------------------------------

// Print every line of a List[String] on its own terminal line. Used so the
// box / line score writers can return self-contained blocks without each one
// reimplementing a loop.
func sayAll(lines: List[String]) {
    for i in 0..lines.length() {
        Terminal.Say(lines.get(i));
    }
}

// Print one game's complete report block: header banner, line score, both
// batting boxes, both pitching boxes.
func printGame(state: game_state.GameState, gameNum: Integer, seed: Integer) {
    Terminal.Say("");
    Terminal.Say("================================================================");
    Terminal.Say("Game " + Fmt.Int(gameNum) + " — " +
                 state.away.teamRef.fullName + " at " + state.home.teamRef.fullName);
    Terminal.Say("Ballpark: " + state.park.name + "   Seed: " + Fmt.Int(seed));
    Terminal.Say("================================================================");
    Terminal.Say("");
    sayAll(line_score_writer.render(state));
    Terminal.Say("");
    sayAll(box_score_writer.renderTeamBatting(state.away));
    Terminal.Say("");
    sayAll(box_score_writer.renderTeamBatting(state.home));
    Terminal.Say("");
    sayAll(box_score_writer.renderTeamPitching(state.away));
    Terminal.Say("");
    sayAll(box_score_writer.renderTeamPitching(state.home));
}

// --- Entry point ------------------------------------------------------------

func start() {
    var mariners = buildMariners();
    var rangers = buildRangers();

    Terminal.Say("");
    Terminal.Say("================================================================");
    Terminal.Say("3-Game Series: " + mariners.teamRef.fullName + " at " +
                 rangers.teamRef.fullName);
    Terminal.Say(mariners.teamRef.nickname + " roster: " +
                 Fmt.Int(mariners.teamRef.roster.length()) + " players");
    Terminal.Say(rangers.teamRef.nickname + " roster: " +
                 Fmt.Int(rangers.teamRef.roster.length()) + " players");
    Terminal.Say("================================================================");

    var seeds: List[Integer] = [1001, 2002, 3003];
    var marinersWins = 0;
    var rangersWins = 0;
    var seriesLines: List[String] = [];

    for g in 0..3 {
        // Each team rotates one slot through its rotation per game so the
        // series shows different starting pitchers on both sides.
        var state = buildGameState(mariners, rangers, g, g, seeds.get(g));
        var engine = new game_engine.GameEngine(state);
        var finalState = engine.simulate();
        printGame(finalState, g + 1, seeds.get(g));

        var line = "Game " + Fmt.Int(g + 1) + ": " +
                   finalState.away.teamRef.nickname + " " + Fmt.Int(finalState.away.score) +
                   ", " +
                   finalState.home.teamRef.nickname + " " + Fmt.Int(finalState.home.score);
        seriesLines.add(line);

        if finalState.away.score > finalState.home.score {
            marinersWins = marinersWins + 1;
        } else if finalState.home.score > finalState.away.score {
            rangersWins = rangersWins + 1;
        }
    }

    Terminal.Say("");
    Terminal.Say("================================================================");
    Terminal.Say("Series Summary");
    Terminal.Say("================================================================");
    for i in 0..seriesLines.length() {
        Terminal.Say(seriesLines.get(i));
    }
    Terminal.Say("");
    Terminal.Say("Final: " + mariners.teamRef.nickname + " " +
                 Fmt.Int(marinersWins) + ", " + rangers.teamRef.nickname + " " +
                 Fmt.Int(rangersWins));
    Terminal.Say("================================================================");
}
