// ============================================================================
// File: human_pacing_probe.zia
// Purpose: Verifies that each of the four pacing profiles wires its gates to
//          the HumanManagerPolicy + HumanSeasonTeamManager correctly, and
//          that the delegate-to-AI paths keep simulation byte-identical to
//          the AI-only baseline.
//
//          The probe:
//            1. Creates four parallel franchises (all seeded the same) and
//               runs the same 3-day window on each:
//                 (a) AI baseline           — no human manager
//                 (b) HumanSeason observe_only — lineup-only prompts
//                 (c) HumanSeason standard     — in-game prompts allowed
//                 (d) HumanSeason high_touch   — adds bunt/steal
//            2. In every non-baseline run the human manager is configured to
//               delegate every prompt immediately (delegateRestOfGame=true),
//               so no interactive I/O is needed and every decision falls
//               through to the default AI logic.
//            3. Asserts that run (a) and every delegated run produce the
//               same completed-game count and the same decision-log length.
//               Any divergence means the substitution or pitching-change
//               checkpoint is leaking non-default behavior into the AI path.
//
// Run via: viper run examples/games/baseball/human_pacing_probe.zia
// ============================================================================
module human_pacing_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/season_model";
bind "./src/season/manager_layer";
bind "./src/sim/manager_policy";
bind "./src/human/pacing_profile";

// Run `days` consecutive days on a fresh franchise. Returns the final
// franchise state so the caller can inspect completedGames + decisionLog.
func runDays(days: Integer, installer: Integer) -> season_model.FranchiseState {
    var franchise = default_franchise.buildDefaultFranchise(4242);
    var engine = new season_engine.SeasonEngine(franchise);
    if installer == 1 {
        var h = new manager_layer.HumanSeasonTeamManager("Obs");
        h.setProfile(pacing_profile.makeObserveOnly());
        forceDelegate(h);
        engine.setManager("port_city", h);
    } else if installer == 2 {
        var h = new manager_layer.HumanSeasonTeamManager("Std");
        h.setProfile(pacing_profile.makeStandardManager());
        forceDelegate(h);
        engine.setManager("port_city", h);
    } else if installer == 3 {
        var h = new manager_layer.HumanSeasonTeamManager("Hi");
        h.setProfile(pacing_profile.makeHighTouchManager());
        forceDelegate(h);
        engine.setManager("port_city", h);
    }
    var count = 0;
    while count < days && franchise.calendar.currentDayIndex < franchise.calendar.days.length() {
        engine.simulateCurrentDay();
        count = count + 1;
    }
    return franchise;
}

// Flip the HumanManagerPolicy's delegateRestOfGame flag to true so every
// in-game prompt falls through to super.decide*Action. This is how the
// probe achieves non-interactive delegation without scripting stdin.
func forceDelegate(mgr: manager_layer.HumanSeasonTeamManager) {
    var inner = mgr.inGamePolicy;
    // inGamePolicy is typed DefaultManagerPolicy; at runtime it's the
    // HumanManagerPolicy instance HumanSeasonTeamManager installed in
    // its override init(). Zia's dynamic dispatch resolves the override
    // correctly, but the compile-time interface for flipping the flag
    // isn't on the base class — so we recreate the policy under a
    // known-typed HumanManagerPolicy reference and swap it back in.
    var human = new manager_policy.HumanManagerPolicy();
    human.setPolicyName(inner.policyName);
    human.setProfile(mgr.profile);
    human.delegateRestOfGame = true;
    mgr.inGamePolicy = human;
}

func start() {
    var baseline = runDays(3, 0);
    var observe = runDays(3, 1);
    var standard = runDays(3, 2);
    var highTouch = runDays(3, 3);

    var ok = true;
    if baseline.completedGames.length() != observe.completedGames.length() {
        ok = false;
    }
    if baseline.completedGames.length() != standard.completedGames.length() {
        ok = false;
    }
    if baseline.completedGames.length() != highTouch.completedGames.length() {
        ok = false;
    }

    Terminal.Say("baseline_games=" + Fmt.Int(baseline.completedGames.length()));
    Terminal.Say("observe_games=" + Fmt.Int(observe.completedGames.length()));
    Terminal.Say("standard_games=" + Fmt.Int(standard.completedGames.length()));
    Terminal.Say("hightouch_games=" + Fmt.Int(highTouch.completedGames.length()));
    Terminal.Say("baseline_decisions=" + Fmt.Int(baseline.managerDecisionLog.length()));
    Terminal.Say("standard_decisions=" + Fmt.Int(standard.managerDecisionLog.length()));
    if ok {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
