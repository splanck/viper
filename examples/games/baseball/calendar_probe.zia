module calendar_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/season_model";

func gamesFor(calendar: season_model.SeasonCalendar, teamId: String) -> Integer {
    var total = 0;
    for i in 0..calendar.days.length() {
        var day = calendar.days.get(i);
        for j in 0..day.scheduledGames.length() {
            var game = day.scheduledGames.get(j);
            if game.homeTeamId == teamId || game.awayTeamId == teamId {
                total = total + 1;
            }
        }
    }
    return total;
}

func start() {
    var base = default_franchise.buildDefaultFranchise(7171);
    var teams: List[season_model.TeamSeasonState] = [];
    for i in 0..base.teams.length() {
        teams.add(base.teams.get(i));
    }
    teams.add(default_franchise.buildTeam("harbor", "Harbor", "Waves", "Harbor Grounds", 1, 0));

    var calendar = season_engine.makeRoundRobinCalendar("Probe League", 2026, 7171,
                                                        teams, 10, 1);

    var okay = true;
    for i in 0..teams.length() {
        var teamId = teams.get(i).teamRef.id;
        var scheduled = gamesFor(calendar, teamId);
        Terminal.Say(teamId + "_games=" + Fmt.Int(scheduled));
        if scheduled != 10 {
            okay = false;
        }
    }

    Terminal.Say("calendar_days=" + Fmt.Int(calendar.days.length()));
    if okay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
