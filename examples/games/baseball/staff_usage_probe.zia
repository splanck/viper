module staff_usage_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/season_engine";
bind "./src/season/manager_layer";
bind "./src/season/season_model";

func hasTeam(ids: List[String], teamId: String) -> Boolean {
    for i in 0..ids.length() {
        if ids.get(i) == teamId {
            return true;
        }
    }
    return false;
}

func start() {
    var franchise = default_franchise.buildDefaultFranchise(6161);
    var openingDay = franchise.calendar.currentDay();
    var playedTeams: List[String] = [];
    for i in 0..openingDay.scheduledGames.length() {
        var game = openingDay.scheduledGames.get(i);
        playedTeams.add(game.awayTeamId);
        playedTeams.add(game.homeTeamId);
    }

    var teamState = franchise.teams.get(0);
    var opponentState = franchise.teams.get(1);
    var manager = new manager_layer.SeasonTeamManager(teamState.teamRef.fullName + " Manager");
    var lineupAction = manager.submitPregameLineup(teamState, opponentState,
                                                   openingDay.dateDays,
                                                   franchise.rules);

    var bullpenRotationArms = 0;
    var lineupBuilt = lineupAction.lineupChoice != null;
    if lineupAction.lineupChoice != null {
        for i in 0..lineupAction.lineupChoice!.bullpen.length() {
            var arm = lineupAction.lineupChoice!.bullpen.get(i);
            var entry = teamState.getEntry(arm.id);
            if entry != null && entry!.roleTag == season_model.ROLE_ROTATION {
                bullpenRotationArms = bullpenRotationArms + 1;
            }
        }
    }

    var engine = new season_engine.SeasonEngine(franchise);
    engine.simulateCurrentDay();

    var rotationCursorOkay = true;
    for i in 0..franchise.teams.length() {
        var club = franchise.teams.get(i);
        Terminal.Say(club.teamRef.id + "_next_starter_index=" + Fmt.Int(club.nextStarterIndex));
        if hasTeam(playedTeams, club.teamRef.id) {
            if club.nextStarterIndex != 1 {
                rotationCursorOkay = false;
            }
        } else if club.nextStarterIndex != 0 {
            rotationCursorOkay = false;
        }
    }

    Terminal.Say("lineup_built=" + Fmt.Int(lineupBuilt ? 1 : 0));
    Terminal.Say("bullpen_rotation_arms=" + Fmt.Int(bullpenRotationArms));

    if lineupBuilt && bullpenRotationArms == 0 && rotationCursorOkay {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
