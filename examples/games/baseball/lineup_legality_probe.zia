module lineup_legality_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/demo/default_game";
bind "./src/sim/game_engine";
bind "./src/model/game_state";
bind "./src/model/ruleset";

// This probe verifies that the engine actually invokes LineupCard.validateStart()
// during simulate() by feeding it a deliberately broken setup. The default game
// builds rosters assuming DH is on, which leaves the pitcher OUT of the batting
// order. If we flip the ruleset to no-DH after construction, validation should
// reject both lineups (no DH slot expected, and pitcher is not in the order).
//
// Expected behavior:
//   - simulate() bails out without playing any innings
//   - eventLog contains "Lineup invalid" lines for both teams
//   - inning is still 1 and outs is still 0 (game never advanced past setup)

func start() {
    var state = default_game.buildDefaultGame(4242);
    // Force the ruleset into no-DH mode after the rosters were built with the
    // DH lineup template. This makes both lineup cards illegal.
    state.rules.designatedHitterEnabled = false;
    state.away.lineup.dhEnabled = false;
    state.home.lineup.dhEnabled = false;

    var engine = new game_engine.GameEngine(state);
    var finalState = engine.simulate();

    Terminal.Say("inning_after_simulate=" + Fmt.Int(finalState.inning));
    Terminal.Say("outs_after_simulate=" + Fmt.Int(finalState.outs));
    Terminal.Say("event_log_lines=" + Fmt.Int(finalState.eventLog.length()));

    var sawAwayInvalid = false;
    var sawHomeInvalid = false;
    for i in 0..finalState.eventLog.length() {
        var line = finalState.eventLog.get(i);
        Terminal.Say("  " + line);
        if line == "Lineup invalid: Port City Captains" { sawAwayInvalid = true; }
        if line == "Lineup invalid: Lakeview Stags" { sawHomeInvalid = true; }
    }

    if sawAwayInvalid && finalState.inning == 1 && finalState.outs == 0 {
        Terminal.Say("RESULT: ok (validateStart rejects bad lineup, engine aborts cleanly)");
    } else {
        Terminal.Say("RESULT: fail");
    }
}
