// ============================================================================
// File: human_legality_probe.zia
// Purpose: Asserts that the legality-retry loop in the HumanSeasonTeamManager
//          rejects illegal lineup cards using the same validator the AI path
//          uses (SeasonTeamManager.validateLineupForToday). Builds three
//          illegal lineups and verifies each rejection surfaces the expected
//          error string category.
//
//          Exercises:
//            - no DH under DH-on rules
//            - pitcher batting under DH-on rules
//            - no pitcher set
//
// Run via: viper run examples/games/baseball/human_legality_probe.zia
// ============================================================================
module human_legality_probe;

bind Viper.Terminal as Terminal;
bind Viper.Fmt as Fmt;
bind "./src/season/demo/default_franchise";
bind "./src/season/manager_layer";
bind "./src/model/lineup_card";

func start() {
    var franchise = default_franchise.buildDefaultFranchise(4242);
    var portCity = franchise.getTeam("port_city");
    if portCity == null {
        Terminal.Say("missing port_city team");
        Terminal.Say("RESULT: fail");
        return;
    }
    var teamState = portCity!;
    var mgr = new manager_layer.SeasonTeamManager("Validator");

    // Build a legal AI card first so we can mutate it into each illegal
    // shape. This is also the baseline the human path uses, so a bug in
    // the AI path would surface here too.
    var aiAction = mgr.submitPregameLineup(teamState, teamState, 20260401, franchise.rules);
    if aiAction.lineupChoice == null {
        Terminal.Say("AI failed to build lineup");
        Terminal.Say("RESULT: fail");
        return;
    }
    var baseline = aiAction.lineupChoice!;

    // Case 1: clear the activePitcher — validator must reject.
    var noPitcher = aiAction.lineupChoice!;
    noPitcher.activePitcher = null;
    var noPitcherResult = mgr.validateLineupForToday(teamState, noPitcher, franchise.rules);

    // Case 2: good card should pass. Rebuild from AI to reset the pitcher
    // we cleared above.
    var fresh = mgr.submitPregameLineup(teamState, teamState, 20260401, franchise.rules);
    var good = fresh.lineupChoice!;
    var goodResult = mgr.validateLineupForToday(teamState, good, franchise.rules);

    // Case 3: mangle the batting order by clearing it — validator must
    // reject (batting order length != 9).
    var freshB = mgr.submitPregameLineup(teamState, teamState, 20260401, franchise.rules);
    var shortOrder = freshB.lineupChoice!;
    while shortOrder.battingOrder.length() > 5 {
        shortOrder.battingOrder.removeAt(shortOrder.battingOrder.length() - 1);
    }
    var shortOrderResult = mgr.validateLineupForToday(teamState, shortOrder, franchise.rules);

    var ok = true;
    if goodResult.ok == false {
        Terminal.Say("good card unexpectedly rejected: " + goodResult.error);
        ok = false;
    }
    if noPitcherResult.ok == true {
        Terminal.Say("card with no pitcher unexpectedly passed");
        ok = false;
    }
    if shortOrderResult.ok == true {
        Terminal.Say("short batting order unexpectedly passed");
        ok = false;
    }

    Terminal.Say("good_ok=" + boolStr(goodResult.ok));
    Terminal.Say("no_pitcher_ok=" + boolStr(noPitcherResult.ok));
    Terminal.Say("no_pitcher_error=" + noPitcherResult.error);
    Terminal.Say("short_order_ok=" + boolStr(shortOrderResult.ok));
    Terminal.Say("short_order_error=" + shortOrderResult.error);
    if ok {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: fail");
    }
}

func boolStr(b: Boolean) -> String {
    if b {
        return "true";
    }
    return "false";
}
