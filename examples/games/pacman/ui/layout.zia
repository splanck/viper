module layout;

bind "../config";

class Rect {
    expose Integer x;
    expose Integer y;
    expose Integer w;
    expose Integer h;

    expose func init() {
        x = 0;
        y = 0;
        w = 0;
        h = 0;
    }

    expose func setup(px: Integer, py: Integer, pw: Integer, ph: Integer) {
        x = px;
        y = py;
        w = pw;
        h = ph;
    }
}

final OUTER_PAD = 24;
final CARD_GAP = 16;
final PLAYFIELD_PAD = 16;
final MENU_CARD_W = 520;
final MENU_CARD_H = 536;
final OPTIONS_CARD_W = 580;
final OPTIONS_CARD_H = 454;
final PROFILE_CARD_W = 680;
final PROFILE_CARD_H = 662;
final SUMMARY_CARD_W = 620;
final SUMMARY_CARD_H = 540;

func rect(px: Integer, py: Integer, pw: Integer, ph: Integer) -> Rect {
    var r = new Rect();
    r.setup(px, py, pw, ph);
    return r;
}

func contains(r: Rect, mx: Integer, my: Integer) -> Boolean {
    return mx >= r.x and mx < r.x + r.w and my >= r.y and my < r.y + r.h;
}

func marqueeRect() -> Rect {
    return rect(0, 0, config.SCREEN_WIDTH, 96);
}

func hudRowRect() -> Rect {
    return rect(0, marqueeRect().h, config.SCREEN_WIDTH, config.HUD_HEIGHT);
}

func playfieldRect() -> Rect {
    return rect(config.PLAYFIELD_X, config.PLAYFIELD_Y, config.PLAYFIELD_WIDTH, config.PLAYFIELD_HEIGHT);
}

func playfieldFrameRect() -> Rect {
    var pf = playfieldRect();
    return rect(pf.x - PLAYFIELD_PAD, pf.y - PLAYFIELD_PAD, pf.w + PLAYFIELD_PAD * 2, pf.h + PLAYFIELD_PAD * 2);
}

func footerRect() -> Rect {
    return rect(0, config.SCREEN_HEIGHT - config.FOOTER_HEIGHT, config.SCREEN_WIDTH, config.FOOTER_HEIGHT);
}

func scoreCardRect() -> Rect {
    var hud = hudRowRect();
    return rect(OUTER_PAD, hud.y + 10, 220, hud.h - 20);
}

func highScoreCardRect() -> Rect {
    var hud = hudRowRect();
    return rect((config.SCREEN_WIDTH - 220) / 2, hud.y + 10, 220, hud.h - 20);
}

func livesCardRect() -> Rect {
    var hud = hudRowRect();
    return rect(config.SCREEN_WIDTH - OUTER_PAD - 220, hud.y + 10, 220, hud.h - 20);
}

func menuCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - MENU_CARD_W) / 2, 150, MENU_CARD_W, MENU_CARD_H);
}

func menuButtonRect(idx: Integer) -> Rect {
    var card = menuCardRect();
    return rect(card.x + 52, card.y + 188 + idx * 52, card.w - 104, 40);
}

func menuInfoRect() -> Rect {
    var card = menuCardRect();
    return rect(card.x + 42, card.y + 456, card.w - 84, 48);
}

func attractLaneRect() -> Rect {
    var card = menuCardRect();
    return rect(card.x + 20, card.y + 124, card.w - 40, 52);
}

func menuShowcaseRect() -> Rect {
    var card = menuCardRect();
    return rect((config.SCREEN_WIDTH - 620) / 2, card.y + card.h + 14, 620, 198);
}

func menuGhostEntryRect(idx: Integer) -> Rect {
    var show = menuShowcaseRect();
    var col = idx % 2;
    var row = idx / 2;
    var cellW = (show.w - 52) / 2;
    var cellH = 58;
    return rect(show.x + 18 + col * (cellW + 16), show.y + 58 + row * 64, cellW, cellH);
}

func leaderboardCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - 420) / 2, 198, 420, 452);
}

func overlayCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - 360) / 2, (config.SCREEN_HEIGHT - 190) / 2, 360, 190);
}

func optionsCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - OPTIONS_CARD_W) / 2, 190, OPTIONS_CARD_W, OPTIONS_CARD_H);
}

func optionsRowRect(idx: Integer) -> Rect {
    var card = optionsCardRect();
    return rect(card.x + 32, card.y + 100 + idx * 54, card.w - 64, 42);
}

func optionsHintRect() -> Rect {
    var card = optionsCardRect();
    return rect(card.x + 36, card.y + card.h - 62, card.w - 72, 32);
}

func profileCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - PROFILE_CARD_W) / 2, 146, PROFILE_CARD_W, PROFILE_CARD_H);
}

func profileStatsRect() -> Rect {
    var card = profileCardRect();
    return rect(card.x + 26, card.y + 92, 236, card.h - 154);
}

func profileStatRowRect(idx: Integer) -> Rect {
    var box = profileStatsRect();
    return rect(box.x + 10, box.y + 18 + idx * 62, box.w - 20, 50);
}

func profileAchievementsRect() -> Rect {
    var card = profileCardRect();
    return rect(card.x + 280, card.y + 92, card.w - 306, card.h - 154);
}

func profileAchievementRowRect(idx: Integer, startIdx: Integer) -> Rect {
    var list = profileAchievementsRect();
    var row = idx - startIdx;
    return rect(list.x + 12, list.y + 16 + row * 48, list.w - 24, 42);
}

func profileFooterRect() -> Rect {
    var card = profileCardRect();
    return rect(card.x + 28, card.y + card.h - 48, card.w - 56, 26);
}

func summaryCardRect() -> Rect {
    return rect((config.SCREEN_WIDTH - SUMMARY_CARD_W) / 2, 190, SUMMARY_CARD_W, SUMMARY_CARD_H);
}

func summaryHeaderRect() -> Rect {
    var card = summaryCardRect();
    return rect(card.x + 26, card.y + 24, card.w - 52, 64);
}

func summaryStatRect(idx: Integer) -> Rect {
    var card = summaryCardRect();
    var col = idx % 2;
    var row = idx / 2;
    return rect(card.x + 34 + col * 276, card.y + 112 + row * 68, 242, 54);
}

func summaryUnlocksRect() -> Rect {
    var card = summaryCardRect();
    return rect(card.x + 34, card.y + 320, card.w - 68, 104);
}

func summaryButtonRect(idx: Integer) -> Rect {
    var card = summaryCardRect();
    return rect(card.x + 40 + idx * 182, card.y + card.h - 68, 160, 40);
}
