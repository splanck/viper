module music_tracks;

bind Viper.Sound;

hide func buildMenuSong() -> Sound {
    var song = MusicGen.New(98);
    var pad = song.AddChannel(0);
    var sparkle = song.AddChannel(3);
    var bass = song.AddChannel(2);
    var bell = song.AddChannel(1);

    song.SetSwing(10);

    song.SetEnvelope(pad, 220, 180, 62, 260);
    song.SetChannelVol(pad, 42);
    song.SetPan(pad, -24);
    song.SetDetune(pad, 6);

    song.SetEnvelope(sparkle, 8, 60, 40, 110);
    song.SetChannelVol(sparkle, 34);
    song.SetPan(sparkle, 18);

    song.SetEnvelope(bass, 6, 70, 68, 120);
    song.SetChannelVol(bass, 46);
    song.SetPan(bass, -10);

    song.SetEnvelope(bell, 6, 90, 24, 170);
    song.SetChannelVol(bell, 40);
    song.SetDuty(bell, 18);
    song.SetVibrato(bell, 7, 420);
    song.SetPan(bell, 28);

    song.AddNote(pad, 0, 60, 800);
    song.AddNote(pad, 800, 57, 800);
    song.AddNote(pad, 1600, 53, 800);
    song.AddNote(pad, 2400, 55, 800);

    var arpPos = 0;
    while arpPos < 800 {
        song.AddNote(sparkle, arpPos, 72, 100);
        song.AddNote(sparkle, arpPos + 100, 76, 100);
        song.AddNote(sparkle, arpPos + 200, 79, 100);
        song.AddNote(sparkle, arpPos + 300, 84, 100);
        arpPos = arpPos + 400;
    }
    while arpPos < 1600 {
        song.AddNote(sparkle, arpPos, 69, 100);
        song.AddNote(sparkle, arpPos + 100, 72, 100);
        song.AddNote(sparkle, arpPos + 200, 76, 100);
        song.AddNote(sparkle, arpPos + 300, 81, 100);
        arpPos = arpPos + 400;
    }
    while arpPos < 2400 {
        song.AddNote(sparkle, arpPos, 65, 100);
        song.AddNote(sparkle, arpPos + 100, 69, 100);
        song.AddNote(sparkle, arpPos + 200, 72, 100);
        song.AddNote(sparkle, arpPos + 300, 77, 100);
        arpPos = arpPos + 400;
    }
    while arpPos < 3200 {
        song.AddNote(sparkle, arpPos, 67, 100);
        song.AddNote(sparkle, arpPos + 100, 71, 100);
        song.AddNote(sparkle, arpPos + 200, 74, 100);
        song.AddNote(sparkle, arpPos + 300, 79, 100);
        arpPos = arpPos + 400;
    }

    song.AddNote(bell, 200, 79, 150);
    song.AddNote(bell, 450, 84, 100);
    song.AddNote(bell, 650, 83, 100);
    song.AddNote(bell, 1000, 81, 150);
    song.AddNote(bell, 1250, 79, 100);
    song.AddNote(bell, 1450, 76, 100);
    song.AddNote(bell, 1800, 77, 150);
    song.AddNote(bell, 2050, 79, 100);
    song.AddNote(bell, 2250, 81, 150);
    song.AddNote(bell, 2600, 79, 150);
    song.AddNote(bell, 2850, 77, 100);
    song.AddNote(bell, 3000, 74, 120);

    song.AddNote(bass, 0, 48, 200);
    song.AddNote(bass, 200, 55, 200);
    song.AddNote(bass, 400, 48, 200);
    song.AddNote(bass, 600, 55, 200);
    song.AddNote(bass, 800, 45, 200);
    song.AddNote(bass, 1000, 52, 200);
    song.AddNote(bass, 1200, 45, 200);
    song.AddNote(bass, 1400, 52, 200);
    song.AddNote(bass, 1600, 41, 200);
    song.AddNote(bass, 1800, 48, 200);
    song.AddNote(bass, 2000, 41, 200);
    song.AddNote(bass, 2200, 48, 200);
    song.AddNote(bass, 2400, 43, 200);
    song.AddNote(bass, 2600, 50, 200);
    song.AddNote(bass, 2800, 43, 200);
    song.AddNote(bass, 3000, 50, 200);

    song.SetLength(3200);
    song.SetLoopable(1);
    return song.Build();
}

hide func buildGameSong() -> Sound {
    var song = MusicGen.New(136);
    var lead = song.AddChannel(1);
    var counter = song.AddChannel(3);
    var bass = song.AddChannel(2);
    var pad = song.AddChannel(0);
    var drums = song.AddChannel(4);

    song.SetSwing(8);

    song.SetEnvelope(lead, 5, 45, 54, 70);
    song.SetChannelVol(lead, 54);
    song.SetDuty(lead, 28);
    song.SetVibrato(lead, 8, 620);
    song.SetPortamento(lead, 24);
    song.SetPan(lead, -10);

    song.SetEnvelope(counter, 6, 55, 42, 90);
    song.SetChannelVol(counter, 30);
    song.SetPan(counter, 18);

    song.SetEnvelope(bass, 4, 38, 86, 50);
    song.SetChannelVol(bass, 48);
    song.SetPan(bass, 8);

    song.SetEnvelope(pad, 80, 110, 30, 120);
    song.SetChannelVol(pad, 20);
    song.SetPan(pad, -20);

    song.SetEnvelope(drums, 1, 18, 0, 24);
    song.SetChannelVol(drums, 34);

    song.AddNote(pad, 0, 60, 400);
    song.AddNote(pad, 400, 57, 400);
    song.AddNote(pad, 800, 53, 400);
    song.AddNote(pad, 1200, 55, 400);

    song.AddNote(lead, 0, 76, 75);
    song.AddNote(lead, 100, 79, 50);
    song.AddNote(lead, 150, 83, 50);
    song.AddNote(lead, 200, 79, 100);
    song.AddNote(lead, 300, 76, 100);
    song.AddNote(lead, 400, 81, 75);
    song.AddNote(lead, 500, 79, 50);
    song.AddNote(lead, 550, 76, 50);
    song.AddNote(lead, 600, 72, 100);
    song.AddNote(lead, 700, 76, 100);
    song.AddNote(lead, 800, 77, 75);
    song.AddNote(lead, 900, 81, 50);
    song.AddNote(lead, 950, 84, 50);
    song.AddNote(lead, 1000, 81, 100);
    song.AddNote(lead, 1100, 77, 100);
    song.AddNote(lead, 1200, 79, 75);
    song.AddNote(lead, 1300, 83, 50);
    song.AddNote(lead, 1350, 81, 50);
    song.AddNote(lead, 1400, 74, 100);
    song.AddNote(lead, 1500, 71, 100);

    song.AddNote(counter, 50, 72, 50);
    song.AddNote(counter, 150, 76, 50);
    song.AddNote(counter, 250, 79, 50);
    song.AddNote(counter, 350, 84, 50);
    song.AddNote(counter, 450, 72, 50);
    song.AddNote(counter, 550, 76, 50);
    song.AddNote(counter, 650, 81, 50);
    song.AddNote(counter, 750, 76, 50);
    song.AddNote(counter, 850, 72, 50);
    song.AddNote(counter, 950, 77, 50);
    song.AddNote(counter, 1050, 81, 50);
    song.AddNote(counter, 1150, 84, 50);
    song.AddNote(counter, 1250, 74, 50);
    song.AddNote(counter, 1350, 79, 50);
    song.AddNote(counter, 1450, 83, 50);
    song.AddNote(counter, 1550, 79, 50);

    song.AddNote(bass, 0, 48, 100);
    song.AddNote(bass, 100, 55, 100);
    song.AddNote(bass, 200, 48, 100);
    song.AddNote(bass, 300, 55, 100);
    song.AddNote(bass, 400, 45, 100);
    song.AddNote(bass, 500, 52, 100);
    song.AddNote(bass, 600, 45, 100);
    song.AddNote(bass, 700, 52, 100);
    song.AddNote(bass, 800, 41, 100);
    song.AddNote(bass, 900, 48, 100);
    song.AddNote(bass, 1000, 41, 100);
    song.AddNote(bass, 1100, 48, 100);
    song.AddNote(bass, 1200, 43, 100);
    song.AddNote(bass, 1300, 50, 100);
    song.AddNote(bass, 1400, 43, 100);
    song.AddNote(bass, 1500, 50, 100);

    var beat = 0;
    while beat < 1600 {
        song.AddNote(drums, beat, 2, 18);
        song.AddNote(drums, beat + 50, 12, 12);
        song.AddNote(drums, beat + 100, 8, 24);
        song.AddNote(drums, beat + 150, 12, 12);
        beat = beat + 200;
    }

    song.SetLength(1600);
    song.SetLoopable(1);
    return song.Build();
}

expose func registerTracks(bank: SoundBank) {
    var menuSound = buildMenuSong();
    if menuSound != null {
        bank.RegisterSound("music_menu", menuSound);
    }

    var gameSound = buildGameSong();
    if gameSound != null {
        bank.RegisterSound("music_game", gameSound);
    }
}
