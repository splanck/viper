module test_minimal;

bind Zanna.Graphics;
bind Zanna.Graphics.Canvas;
bind Zanna.Graphics.Color;
bind Zanna.Time;

func main() {
    var canvas = Canvas.New("Test", 400, 300);

    var black = RGB(0, 0, 0);
    var white = RGB(255, 255, 255);

    var i = 0;
    while i < 60 {
        canvas.Poll();
        canvas.Clear(black);
        canvas.Text(10, 10, "Hello Zanna!", white);
        canvas.Flip();
        Zanna.Time.Clock.Sleep(16);
        i = i + 1;
    }
}
