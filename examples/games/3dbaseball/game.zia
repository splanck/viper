// game.zia — Imported FBX baseball field viewer with fly camera controls.
module game;

bind Viper.Graphics3D;
bind Viper.Graphics;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Math;
bind Viper.Input;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind "./config";

class BaseballFieldDemo {
    hide Canvas3D canvas;
    hide Camera3D camera;
    hide Scene3D scene;
    hide SceneNode3D fieldRoot;
    hide Model3D fieldModel;
    hide CubeMap3D skybox;

    hide Float modelSpanX;
    hide Float modelSpanY;
    hide Float modelSpanZ;
    hide Float modelScale;
    hide Float moveSpeed;
    hide String backendName;
    hide Boolean quitRequested;
    hide Boolean ignoreFirstLookSample;

    hide func packPixel(r: Integer, g: Integer, b: Integer, a: Integer) -> Integer {
        return (((r * 256) + g) * 256 + b) * 256 + a;
    }

    expose func initDemo(title: String, width: Integer, height: Integer) {
        canvas = Canvas3D.New(title, width, height);
        Canvas3D.SetDTMax(canvas, config.DT_MAX_MS);
        Canvas3D.ClearFog(canvas);
        Canvas3D.SetAmbient(canvas, 0.54, 0.56, 0.60);
        Canvas3D.EnableShadows(canvas, 0);
        Canvas3D.SetOcclusionCulling(canvas, false);

        backendName = Canvas3D.get_Backend(canvas);

        var aspect = (width + 0.0) / (height + 0.0);
        camera = Camera3D.New(config.CAMERA_FOV, aspect, config.CAMERA_NEAR, config.CAMERA_FAR);

        skybox = createSkybox();
        Canvas3D.SetSkybox(canvas, skybox);

        fieldModel = Model3D.Load("model.fbx");
        scene = Scene3D.New();
        fieldRoot = Model3D.Instantiate(fieldModel);
        normalizeFieldRoot();
        Scene3D.Add(scene, fieldRoot);
        applyEnvironmentToImportedMaterials();

        buildLights();
        placeInitialCamera();

        quitRequested = false;
        ignoreFirstLookSample = true;
        Mouse.Capture();
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func run() {
        while (Canvas3D.get_ShouldClose(canvas) == 0 && quitRequested == false) {
            Canvas3D.Poll(canvas);

            var dt = (Canvas3D.get_DeltaTime(canvas) + 0.0) / 1000.0;
            if (dt <= 0.0) { dt = 0.016; }
            if (dt > config.DT_MAX_SEC) { dt = config.DT_MAX_SEC; }

            step(dt);
            renderFrame();
            Canvas3D.Flip(canvas);
        }

        Mouse.Release();
    }

    expose func step(dt: Float) {
        if (Keyboard.WasPressed(Keyboard.get_KEY_ESCAPE())) {
            quitRequested = true;
            return;
        }

        var mdx = 1.0 * Mouse.DeltaX();
        var mdy = 1.0 * Mouse.DeltaY();
        if (ignoreFirstLookSample) {
            mdx = 0.0;
            mdy = 0.0;
            ignoreFirstLookSample = false;
        }

        var fwd = 0.0;
        var right = 0.0;
        var updown = 0.0;
        if (Keyboard.IsDown(Keyboard.get_KEY_UP())) { fwd = 1.0; }
        if (Keyboard.IsDown(Keyboard.get_KEY_DOWN())) { fwd = -1.0; }
        if (Keyboard.IsDown(Keyboard.get_KEY_LEFT())) { right = -1.0; }
        if (Keyboard.IsDown(Keyboard.get_KEY_RIGHT())) { right = 1.0; }
        if (Keyboard.IsDown(Keyboard.get_KEY_PAGEUP())) { updown = 1.0; }
        if (Keyboard.IsDown(Keyboard.get_KEY_PAGEDOWN())) { updown = -1.0; }

        var speed = moveSpeed;
        if (Keyboard.IsDown(Keyboard.get_KEY_LSHIFT())) { speed = moveSpeed * config.SPRINT_MULT; }
        var climb = updown * (config.UPDOWN_SPEED / config.BASE_MOVE_SPEED);

        Camera3D.FPSUpdate(
            camera,
            mdx * config.MOUSE_SENS,
            0.0 - mdy * config.MOUSE_SENS,
            fwd,
            right,
            climb,
            speed,
            dt);
    }

    expose func renderFrame() {
        Canvas3D.Clear(canvas, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);
        Canvas3D.Begin(canvas, camera);

        Scene3D.Draw(scene, canvas, camera);
        Canvas3D.End(canvas);

        drawHud();
    }

    hide func normalizeFieldRoot() {
        var minV = SceneNode3D.get_AABBMin(fieldRoot);
        var maxV = SceneNode3D.get_AABBMax(fieldRoot);

        var rawSpanX = Vec3.get_X(maxV) - Vec3.get_X(minV);
        var rawSpanY = Vec3.get_Y(maxV) - Vec3.get_Y(minV);
        var rawSpanZ = Vec3.get_Z(maxV) - Vec3.get_Z(minV);
        var longest = maxFloat(rawSpanX, maxFloat(rawSpanY, rawSpanZ));

        modelScale = 1.0;
        if (longest > 0.001) {
            modelScale = config.TARGET_MODEL_SPAN / longest;
        }

        var centerX = (Vec3.get_X(minV) + Vec3.get_X(maxV)) * 0.5;
        var centerZ = (Vec3.get_Z(minV) + Vec3.get_Z(maxV)) * 0.5;
        var groundY = Vec3.get_Y(minV);

        SceneNode3D.SetScale(fieldRoot, modelScale, modelScale, modelScale);
        SceneNode3D.SetPosition(fieldRoot, 0.0 - centerX * modelScale, 0.0 - groundY * modelScale,
                                0.0 - centerZ * modelScale);

        modelSpanX = rawSpanX * modelScale;
        modelSpanY = rawSpanY * modelScale;
        modelSpanZ = rawSpanZ * modelScale;
        moveSpeed = config.BASE_MOVE_SPEED * clampFloat(maxFloat(modelSpanX, modelSpanZ) / 180.0, 0.65, 1.55);
    }

    hide func applyEnvironmentToImportedMaterials() {
        return;
    }

    hide func buildLights() {
        var sun = Light3D.NewDirectional(new Vec3(-0.34, -1.0, -0.26), 1.0, 0.98, 0.94);
        Light3D.SetIntensity(sun, 0.82);
        Canvas3D.SetLight(canvas, 0, sun);

        var fill = Light3D.NewDirectional(new Vec3(0.54, -0.50, 0.62), 0.54, 0.64, 0.84);
        Light3D.SetIntensity(fill, 0.34);
        Canvas3D.SetLight(canvas, 1, fill);
    }

    hide func placeInitialCamera() {
        var startX = modelSpanX * 0.26 + 8.0;
        var startY = maxFloat(modelSpanY * 1.45, 92.0);
        var startZ = modelSpanZ * 0.54 + 18.0;
        var lookX = modelSpanX * 0.02;
        var lookY = maxFloat(modelSpanY * 0.05, 8.0);
        var lookZ = 0.0 - modelSpanZ * 0.08;

        Camera3D.LookAt(
            camera,
            new Vec3(startX, startY, startZ),
            new Vec3(lookX, lookY, lookZ),
            new Vec3(0.0, 1.0, 0.0));
    }

    hide func drawHud() {
        Canvas3D.DrawRect2D(canvas, 18, 18, 496, 112, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, 24, 24, 484, 22, config.HUD_CARD);
        Canvas3D.DrawText2D(canvas, 36, 28, "3D BASEBALL FIELD", config.HUD_GOLD);
        Canvas3D.DrawText2D(canvas, 36, 56, "Mouse look • Arrow keys move • Shift sprint", config.HUD_TEXT);
        Canvas3D.DrawText2D(canvas, 36, 78, "PageUp / PageDown climb • ESC quit", config.HUD_MUTED);
        Canvas3D.DrawText2D(
            canvas,
            36,
            100,
            "backend: " + backendName + " • span " + toString(Convert.NumToInt(maxFloat(modelSpanX, modelSpanZ))) + "u",
            config.HUD_ACCENT);
    }

    hide func createSkybox() -> CubeMap3D {
        return CubeMap3D.New(
            createSkyFace(0),
            createSkyFace(1),
            createSkyFace(2),
            createSkyFace(3),
            createSkyFace(4),
            createSkyFace(5));
    }

    hide func createSkyFace(faceId: Integer) -> Pixels {
        var size = config.SKYBOX_FACE_SIZE;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var u = (((px + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                var v = (((py + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                face.Set(px, py, sampleSkyPixelForFace(faceId, u, v));
            }
        }

        return face;
    }

    hide func sampleSkyPixelForFace(faceId: Integer, u: Float, v: Float) -> Integer {
        var dx = 0.0;
        var dy = 0.0;
        var dz = 0.0;

        if (faceId == 0) {
            dx = 1.0;
            dy = 0.0 - v;
            dz = 0.0 - u;
        } else {
            if (faceId == 1) {
                dx = -1.0;
                dy = 0.0 - v;
                dz = u;
            } else {
                if (faceId == 2) {
                    dx = u;
                    dy = 1.0;
                    dz = v;
                } else {
                    if (faceId == 3) {
                        dx = u;
                        dy = -1.0;
                        dz = 0.0 - v;
                    } else {
                        if (faceId == 4) {
                            dx = u;
                            dy = 0.0 - v;
                            dz = 1.0;
                        } else {
                            dx = 0.0 - u;
                            dy = 0.0 - v;
                            dz = -1.0;
                        }
                    }
                }
            }
        }

        var len = Sqrt(dx * dx + dy * dy + dz * dz);
        if (len <= 0.0001) {
            return packPixel(155, 203, 246, 255);
        }

        return sampleSkyPixel(dx / len, dy / len, dz / len);
    }

    hide func sampleSkyPixel(dx: Float, dy: Float, dz: Float) -> Integer {
        var up = clampFloat((dy + 0.16) / 1.16, 0.0, 1.0);
        var haze = clampFloat(1.0 - absFloat(dy) * 2.1, 0.0, 1.0);
        var cloud = sampleCloudMask(dx, dy, dz);

        var r = lerpFloat(170.0, 82.0, up) + haze * 16.0;
        var g = lerpFloat(212.0, 146.0, up) + haze * 10.0;
        var b = lerpFloat(246.0, 227.0, up) + haze * 8.0;

        if (dy < -0.10) {
            var ground = clampFloat((0.0 - dy - 0.10) / 0.90, 0.0, 1.0);
            r = lerpFloat(r, 118.0, ground);
            g = lerpFloat(g, 142.0, ground);
            b = lerpFloat(b, 156.0, ground);
            cloud = cloud * (1.0 - ground);
        }

        r = lerpFloat(r, 255.0, cloud * 0.92);
        g = lerpFloat(g, 255.0, cloud * 0.95);
        b = lerpFloat(b, 255.0, cloud);

        return packPixel(
            clampByte(Convert.NumToInt(r)),
            clampByte(Convert.NumToInt(g)),
            clampByte(Convert.NumToInt(b)),
            255);
    }

    hide func sampleCloudMask(dx: Float, dy: Float, dz: Float) -> Float {
        var band = clampFloat(1.0 - absFloat(dy - 0.18) * 2.4, 0.0, 1.0);
        var f =
            Sin(dx * 6.0 + Sin(dz * 2.2) * 0.8) * 0.46 +
            Cos(dz * 7.4 - dx * 4.8) * 0.28 +
            Sin((dx + dz) * 11.5 + dy * 4.2) * 0.14 +
            Cos((dx - dz) * 16.0 - dy * 2.4) * 0.08;
        var mask = clampFloat((f + band * 0.58 - 0.30) / 0.58, 0.0, 1.0);
        mask = mask * mask * (3.0 - 2.0 * mask);
        return mask * clampFloat((dy + 0.05) / 1.05, 0.0, 1.0);
    }

    hide func clampByte(value: Integer) -> Integer {
        if (value < 0) { return 0; }
        if (value > 255) { return 255; }
        return value;
    }

    hide func clampFloat(value: Float, lo: Float, hi: Float) -> Float {
        if (value < lo) { return lo; }
        if (value > hi) { return hi; }
        return value;
    }

    hide func absFloat(value: Float) -> Float {
        if (value < 0.0) { return 0.0 - value; }
        return value;
    }

    hide func lerpFloat(a: Float, b: Float, t: Float) -> Float {
        return a + (b - a) * t;
    }

    hide func maxFloat(a: Float, b: Float) -> Float {
        if (a > b) { return a; }
        return b;
    }
}
