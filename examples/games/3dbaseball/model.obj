# Minimal checked-in baseball field stand-in for smoke tests.
# The full example can be pointed at richer imported assets, but CI needs a
# deterministic asset that does not depend on external downloads.
v -0.50 0.0 -0.50
v 0.50 0.0 -0.50
v 0.50 0.0 0.50
v -0.50 0.0 0.50
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0
vn 0.0 1.0 0.0
f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1
