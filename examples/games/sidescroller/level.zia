    // =========================================================================
    // Level 4: "Overgrowth" — Ancient Alien Ruins
    // Uses existing tile types: RUIN_STONE, MOSS_STONE, VINE, JUNGLE tiles
    // Reuses ruins background theme
    // =========================================================================

    hide func buildOvergrowth() {
        levelWidth = 150;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_RUINS;

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

        // ==== BIOME 1: Overgrown Surface (cols 0-49) ====
        fillRowTile(GROUND_ROW, 0, 49, TILE_MOSS_STONE);
        fillRowTile(FLOOR_ROW, 0, 49, TILE_RUIN_STONE);

        // Vine-covered platforms
        buildPlatformRun(6, 12, 4, TILE_MOSS_STONE, 11);
        buildPlatformRun(12, 10, 3, TILE_JUNGLE_PLATFORM, 9);
        buildPlatformRun(17, 12, 5, TILE_MOSS_STONE, 11);
        buildPlatformRun(24, 8, 3, TILE_JUNGLE_PLATFORM, 7);
