        addEnemy(ENEMY_TURRET, 87, 9);
        addEnemy(ENEMY_SLIME, 91, 11);
        addPickup(PICKUP_COIN, 79, 11);
        addPickup(PICKUP_COIN, 85, 9);
        addPickup(PICKUP_COIN, 90, 11);
        addPickup(PICKUP_RAPIDFIRE, 83, 14);

        tilemap.SetTile(96, GROUND_ROW - 1, TILE_CHECKPOINT);

        // ==== BIOME 3: Frozen Core + Boss (cols 100-149) ====
        fillRowTile(0, 100, 149, TILE_CAVE_TOP);
        fillRowTile(1, 100, 149, TILE_CAVE_WALL);
        fillRowTile(GROUND_ROW, 100, 149, TILE_STONE);
        fillRowTile(FLOOR_ROW, 100, 149, TILE_STONE);

        buildPlatformRun(102, 12, 4, TILE_STONE, 11);
