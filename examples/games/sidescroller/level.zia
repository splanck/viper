    }

    // =========================================================================
    // Level 3: "Frozen Abyss" — Ice Caverns
    // Uses existing tile types: STONE, CRYSTAL, CAVE_WALL, SPIKE, BRIDGE
    // Reuses cave/crystal biome backgrounds with a frozen color twist
    // =========================================================================

    hide func buildFrozenAbyss() {
        levelWidth = 150;
