        tilemap.SetTile(8, 8, TILE_VINE);
        tilemap.SetTile(9, 9, TILE_VINE);
        tilemap.SetTile(14, 7, TILE_VINE);
        tilemap.SetTile(19, 9, TILE_VINE);
        addEnemy(ENEMY_SLIME, 10, 14);
        addEnemy(ENEMY_SLIME, 20, 14);
        addEnemy(ENEMY_BAT, 16, 6);
        addPickup(PICKUP_COIN, 7, 11);
        addPickup(PICKUP_COIN, 13, 9);
        addPickup(PICKUP_COIN, 18, 11);
        addPickup(PICKUP_COIN, 25, 7);
        addPickup(PICKUP_HEALTH, 22, 14);

        // Thorn gap
        buildGapWithHazard(29, 33, TILE_THORN);
        buildPlatformRun(29, 11, 2, TILE_JUNGLE_PLATFORM, 10);
        buildPlatformRun(32, 9, 2, TILE_JUNGLE_PLATFORM, 8);
        addEnemy(ENEMY_BAT, 31, 6);
        addPickup(PICKUP_COIN, 30, 10);
        addPickup(PICKUP_COIN, 33, 8);

        buildPlatformRun(36, 12, 5, TILE_MOSS_STONE, 11);
        buildPlatformRun(42, 10, 4, TILE_JUNGLE_PLATFORM, 9);
        addEnemy(ENEMY_TURRET, 39, 11);
        addEnemy(ENEMY_SLIME, 44, 9);
        addPickup(PICKUP_COIN, 37, 11);
        addPickup(PICKUP_COIN, 43, 9);
        addPickup(PICKUP_SPEED, 47, 14);

        tilemap.SetTile(48, GROUND_ROW - 1, TILE_CHECKPOINT);
        checkpointX = 48 * TILE_SIZE;
        checkpointY = (GROUND_ROW - 2) * TILE_SIZE;
        hasCheckpoint = true;

        // ==== BIOME 2: Deep Ruins (cols 50-99) ====
