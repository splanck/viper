        addPickup(PICKUP_COIN, 59, 9);
        addPickup(PICKUP_COIN, 64, 11);

        // Lava crossing
        buildGapWithHazard(68, 74, TILE_LAVA);
        buildPlatformRun(68, 11, 2, TILE_STONE, 10);
        buildPlatformRun(71, 9, 2, TILE_CAVE_CRYSTAL, 8);
        buildPlatformRun(74, 11, 2, TILE_STONE, 10);
