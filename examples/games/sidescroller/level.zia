        fillRowTile(FLOOR_ROW, 50, 99, TILE_RUIN_STONE);

        buildPlatformRun(52, 12, 4, TILE_RUIN_STONE, 11);
        buildPlatformRun(58, 10, 3, TILE_MOSS_STONE, 9);
        buildPlatformRun(63, 12, 4, TILE_RUIN_STONE, 11);
        tilemap.SetTile(55, 10, TILE_VINE);
        tilemap.SetTile(56, 11, TILE_VINE);
        tilemap.SetTile(61, 8, TILE_VINE);
        addEnemy(ENEMY_BAT, 56, 7);
        addEnemy(ENEMY_TURRET, 60, 9);
        addEnemy(ENEMY_SLIME, 65, 11);
        addPickup(PICKUP_COIN, 53, 11);
        addPickup(PICKUP_COIN, 59, 9);
        addPickup(PICKUP_COIN, 64, 11);

        // Lava ruin crossing
        buildGapWithHazard(69, 75, TILE_LAVA);
        buildPlatformRun(69, 11, 2, TILE_RUIN_STONE, 10);
        buildPlatformRun(72, 9, 2, TILE_MOSS_STONE, 8);
        buildPlatformRun(75, 11, 2, TILE_RUIN_STONE, 10);
        addEnemy(ENEMY_BAT, 71, 6);
        addEnemy(ENEMY_BAT, 74, 8);
        addPickup(PICKUP_COIN, 70, 10);
        addPickup(PICKUP_COIN, 73, 8);
        addPickup(PICKUP_SHIELD, 77, 14);

        buildPlatformRun(79, 12, 5, TILE_RUIN_STONE, 11);
        buildPlatformRun(85, 10, 4, TILE_MOSS_STONE, 9);
        buildPlatformRun(90, 12, 4, TILE_RUIN_STONE, 11);
        addEnemy(ENEMY_TURRET, 82, 11);
        addEnemy(ENEMY_TURRET, 88, 9);
        addEnemy(ENEMY_SLIME, 92, 11);
        addPickup(PICKUP_COIN, 80, 11);
        addPickup(PICKUP_COIN, 86, 9);
        addPickup(PICKUP_COIN, 91, 11);
        addPickup(PICKUP_RAPIDFIRE, 84, 14);

        tilemap.SetTile(97, GROUND_ROW - 1, TILE_CHECKPOINT);

        // ==== BIOME 3: Heart of Ruins + Boss (cols 100-149) ====
