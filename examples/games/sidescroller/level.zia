        addEnemy(ENEMY_BAT, 73, 8);
        addPickup(PICKUP_COIN, 69, 10);
        addPickup(PICKUP_COIN, 72, 8);
        addPickup(PICKUP_SHIELD, 76, 14);

        // Crystal gauntlet
        buildPlatformRun(78, 12, 5, TILE_STONE, 11);
