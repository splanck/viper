    // =========================================================================
    // Level builder helpers
    // =========================================================================

    hide func addPlatform(col: Integer, row: Integer, width: Integer) {
        var c = col;
        while c < col + width {
            tilemap.SetTile(c, row, TILE_PLATFORM);
            c = c + 1;
        }
    }

    hide func clearGround(startCol: Integer, endCol: Integer) {
        var c = startCol;
        while c <= endCol {
            tilemap.SetTile(c, GROUND_ROW, TILE_EMPTY);
            tilemap.SetTile(c, FLOOR_ROW, TILE_EMPTY);
            c = c + 1;
        }
    }

    // =========================================================================
    // =========================================================================
    // Post-build enemy enrichment — adds new enemy types to existing levels
    // =========================================================================
    expose func enrichEnemies(levelNum: Integer) {
        if levelNum == 1 {
            enemyTypes.add(ENEMY_PATROL_DRONE);
            enemyX.add(60 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_BOMB_CARRIER);
            enemyX.add(90 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
        }
        if levelNum == 2 {
            enemyTypes.add(ENEMY_SPOREWALKER);
            enemyX.add(30 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_SPOREWALKER);
            enemyX.add(55 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(40 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(70 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_FUNGAL_TURRET);
            enemyX.add(85 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_MYCELIUM);
            enemyX.add(95 * TILE_SIZE); enemyY.add(4 * TILE_SIZE);
            // Spore Mother boss is spawned via level.bossType — not here
        }
        if levelNum == 3 {
            enemyTypes.add(ENEMY_CRYSTAL_GOLEM);
            enemyX.add(35 * TILE_SIZE); enemyY.add(12 * TILE_SIZE);
            enemyTypes.add(ENEMY_SHARD_BAT);
            enemyX.add(50 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_SHARD_BAT);
            enemyX.add(75 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_RESONANCE_ORB);
            enemyX.add(60 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_MIRROR_SLIME);
            enemyX.add(90 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            // Crystal Wyrm boss is spawned via level.bossType — not here
        }
        if levelNum == 4 {
            enemyTypes.add(ENEMY_VINE_WHIP);
            enemyX.add(25 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_RUIN_GUARDIAN);
            enemyX.add(80 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_PATROL_DRONE);
            enemyX.add(100 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
        }
        if levelNum == 5 {
            enemyTypes.add(ENEMY_FROST_BEETLE);
            enemyX.add(40 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(60 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_BOMB_CARRIER);
            enemyX.add(100 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
        }
        if levelNum == 6 {
            enemyTypes.add(ENEMY_MAGMA_SLUG);
            enemyX.add(30 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_MAGMA_SLUG);
            enemyX.add(60 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_EMBER_WASP);
            enemyX.add(45 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_EMBER_WASP);
            enemyX.add(75 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_FORGE_SENTINEL);
            enemyX.add(105 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            // Magma Core boss is spawned via level.bossType — not here
        }
        if levelNum == 7 {
            enemyTypes.add(ENEMY_MOSS_GOLEM);
            enemyX.add(40 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_VINE_WHIP);
            enemyX.add(65 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_SPOREWALKER);
            enemyX.add(100 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_MOSS_GOLEM);
            enemyX.add(120 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
        }
        if levelNum == 8 {
            enemyTypes.add(ENEMY_ICE_WRAITH);
            enemyX.add(35 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_ICE_WRAITH);
            enemyX.add(70 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_FROST_BEETLE);
            enemyX.add(50 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_STALACTITE_BAT);
            enemyX.add(55 * TILE_SIZE); enemyY.add(2 * TILE_SIZE);
            enemyTypes.add(ENEMY_STALACTITE_BAT);
            enemyX.add(80 * TILE_SIZE); enemyY.add(2 * TILE_SIZE);
        }
        if levelNum == 9 {
            enemyTypes.add(ENEMY_SHADOW_CLONE);
            enemyX.add(30 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_SHADOW_CLONE);
            enemyX.add(60 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_CORRUPTION);
            enemyX.add(45 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_CORRUPTION);
            enemyX.add(75 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_PATROL_DRONE);
            enemyX.add(55 * TILE_SIZE); enemyY.add(4 * TILE_SIZE);
        }

        // Add gems and HP upgrades to all levels
        addGemsToLevel(levelNum);
    }

    // Scatter gem pickups and secrets throughout each level
    hide func addGemsToLevel(levelNum: Integer) {
        // Every level gets 5-7 gems at varied positions
        var gemCount = 5 + levelNum % 3;
        var g = 0;
        while g < gemCount {
            pickupTypes.add(PICKUP_GEM);
            // Distribute gems across the level width
            var gx = (15 + g * 20 + levelNum * 7) % (levelWidth - 20) + 10;
            var gy = 4 + (g * 3 + levelNum * 2) % 10;
            pickupX.add(gx * TILE_SIZE);
            pickupY.add(gy * TILE_SIZE);
            g = g + 1;
        }
        // HP upgrades in even-numbered levels (hidden, higher positions)
        if levelNum % 2 == 0 and levelNum <= 8 {
            pickupTypes.add(PICKUP_HP_UP);
            pickupX.add((levelWidth / 2 + levelNum * 5) * TILE_SIZE);
            pickupY.add(2 * TILE_SIZE); // Near ceiling — requires exploration
        }
        // Keys in levels 5 and 9
        if levelNum == 5 or levelNum == 9 {
            pickupTypes.add(PICKUP_KEY);
            pickupX.add((levelWidth * 3 / 4) * TILE_SIZE);
            pickupY.add(6 * TILE_SIZE);
        }
        // Extra health pickups before bosses
        if levelNum == 2 or levelNum == 3 or levelNum == 6 or levelNum == 10 {
            pickupTypes.add(PICKUP_HEALTH);
            pickupX.add((levelWidth - 25) * TILE_SIZE);
            pickupY.add(10 * TILE_SIZE);
            pickupTypes.add(PICKUP_HEALTH);
            pickupX.add((levelWidth - 20) * TILE_SIZE);
            pickupY.add(12 * TILE_SIZE);
        }
        // Speed boost before gauntlet sections
        if levelNum == 5 or levelNum == 9 {
            pickupTypes.add(PICKUP_SPEED);
            pickupX.add((levelWidth / 3) * TILE_SIZE);
            pickupY.add(8 * TILE_SIZE);
        }
        // Shield before boss fights
        if levelNum == 6 or levelNum == 10 {
            pickupTypes.add(PICKUP_SHIELD);
            pickupX.add((levelWidth - 30) * TILE_SIZE);
            pickupY.add(8 * TILE_SIZE);
        }
        // Rapid fire in combat-heavy levels
        if levelNum == 3 or levelNum == 7 {
            pickupTypes.add(PICKUP_RAPIDFIRE);
            pickupX.add((levelWidth / 2) * TILE_SIZE);
            pickupY.add(6 * TILE_SIZE);
        }
    }

    // =========================================================================
    // Level 10: The Core — Final level, all mechanics combined
    // =========================================================================
    // A gauntlet through the Architect's corrupted heart. Dark corridors,
    // corruption tendrils, shadow clones, and the final boss arena.
    // Tests every ability the player has acquired.
    //
    // Layout: 200 tiles wide × 22 tall
    //   Cols 0-40:   Entry corridor (corruption, tendrils, shadow clones)
    //   Cols 41-80:  Ability gauntlet (requires all abilities to traverse)
    //   Cols 81-120: Enemy arena (all enemy types mixed)
    //   Cols 121-160: Vertical shaft (platforming challenge)
    //   Cols 161-200: The Architect's arena (final boss)
    // =========================================================================
    hide func buildTheCore() {
        levelWidth = 200;
        levelHeight = 22;
        levelTheme = 10; // Corrupted core
        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        // Ground floor
        var c = 0;
        while c < levelWidth {
            tilemap.SetTile(c, levelHeight - 1, TILE_OBSIDIAN);
            tilemap.SetTile(c, levelHeight - 2, TILE_OBSIDIAN);
            c = c + 1;
        }

        // Ceiling
        c = 0;
        while c < levelWidth {
            tilemap.SetTile(c, 0, TILE_OBSIDIAN);
            tilemap.SetTile(c, 1, TILE_OBSIDIAN);
            c = c + 1;
        }

        // ─── Section 1: Entry Corridor (0-40) ────────────────────────
        // Narrow passages with corruption and tendrils
        c = 0;
        while c < 40 {
            // Corridor walls (leaving 8-tile-high passage)
            tilemap.SetTile(c, 2, TILE_OBSIDIAN);
            tilemap.SetTile(c, 3, TILE_OBSIDIAN);
            tilemap.SetTile(c, levelHeight - 3, TILE_OBSIDIAN);
            c = c + 1;
        }

        // Platforms within corridor
        buildPlatformRun(5, 14, 4, TILE_OBSIDIAN, 14 - 2);
        buildPlatformRun(15, 10, 3, TILE_OBSIDIAN, 10 - 2);
        buildPlatformRun(25, 14, 4, TILE_OBSIDIAN, 14 - 2);
        buildPlatformRun(35, 10, 3, TILE_OBSIDIAN, 10 - 2);

        // Corruption tendrils in entry
        enemyTypes.add(ENEMY_CORRUPTION);
        enemyX.add(10 * TILE_SIZE);
        enemyY.add(16 * TILE_SIZE);

        enemyTypes.add(ENEMY_CORRUPTION);
        enemyX.add(20 * TILE_SIZE);
        enemyY.add(16 * TILE_SIZE);

        enemyTypes.add(ENEMY_SHADOW_CLONE);
        enemyX.add(30 * TILE_SIZE);
        enemyY.add(12 * TILE_SIZE);

        // ─── Section 2: Ability Gauntlet (41-80) ─────────────────────
        // Tests dash (narrow gap), charge shot (destructible wall),
        // ground pound (breakable floor), double jump (high platforms)

        // Dash challenge: narrow passage with timed hazard
        c = 41;
        while c < 50 {
            tilemap.SetTile(c, 8, TILE_OBSIDIAN);
            c = c + 1;
        }
        // Gap requiring dash to cross
        clearGround(45, 49);

        // Charge shot wall
        tilemap.SetTile(55, 12, TILE_DESTRUCTIBLE);
        tilemap.SetTile(55, 13, TILE_DESTRUCTIBLE);
        tilemap.SetTile(55, 14, TILE_DESTRUCTIBLE);

        // High platforms requiring double jump
        buildPlatformRun(60, 8, 3, TILE_OBSIDIAN, 8 - 2);
        buildPlatformRun(65, 5, 3, TILE_OBSIDIAN, 5 - 2);
        buildPlatformRun(70, 8, 3, TILE_OBSIDIAN, 8 - 2);
        buildPlatformRun(75, 12, 4, TILE_OBSIDIAN, 12 - 2);

        // Enemies guarding gauntlet
        enemyTypes.add(ENEMY_PATROL_DRONE);
        enemyX.add(48 * TILE_SIZE);
        enemyY.add(6 * TILE_SIZE);

        enemyTypes.add(ENEMY_SHADOW_CLONE);
        enemyX.add(62 * TILE_SIZE);
        enemyY.add(6 * TILE_SIZE);

        enemyTypes.add(ENEMY_SHADOW_CLONE);
        enemyX.add(72 * TILE_SIZE);
        enemyY.add(6 * TILE_SIZE);

        // ─── Section 3: Enemy Arena (81-120) ─────────────────────────
        // Open arena with mixed enemy types from all biomes

        // Arena floor and walls
        c = 81;
        while c < 120 {
            tilemap.SetTile(c, levelHeight - 3, TILE_OBSIDIAN);
            c = c + 1;
        }

        // Platforms for verticality
        buildPlatformRun(85, 12, 5, TILE_OBSIDIAN, 12 - 2);
        buildPlatformRun(95, 8, 4, TILE_OBSIDIAN, 8 - 2);
        buildPlatformRun(105, 12, 5, TILE_OBSIDIAN, 12 - 2);
        buildPlatformRun(90, 15, 3, TILE_OBSIDIAN, 15 - 2);
        buildPlatformRun(100, 15, 3, TILE_OBSIDIAN, 15 - 2);
        buildPlatformRun(110, 8, 4, TILE_OBSIDIAN, 8 - 2);

        // Mixed enemies — one from each biome
        enemyTypes.add(ENEMY_SPOREWALKER);
        enemyX.add(86 * TILE_SIZE);
        enemyY.add(10 * TILE_SIZE);

        enemyTypes.add(ENEMY_CRYSTAL_GOLEM);
        enemyX.add(92 * TILE_SIZE);
        enemyY.add(14 * TILE_SIZE);

        enemyTypes.add(ENEMY_EMBER_WASP);
        enemyX.add(96 * TILE_SIZE);
        enemyY.add(6 * TILE_SIZE);

        enemyTypes.add(ENEMY_EMBER_WASP);
        enemyX.add(98 * TILE_SIZE);
        enemyY.add(8 * TILE_SIZE);

        enemyTypes.add(ENEMY_ICE_WRAITH);
        enemyX.add(102 * TILE_SIZE);
        enemyY.add(10 * TILE_SIZE);

        enemyTypes.add(ENEMY_FORGE_SENTINEL);
        enemyX.add(108 * TILE_SIZE);
        enemyY.add(14 * TILE_SIZE);

        enemyTypes.add(ENEMY_RUIN_GUARDIAN);
        enemyX.add(114 * TILE_SIZE);
        enemyY.add(14 * TILE_SIZE);

        // ─── Section 4: Vertical Shaft (121-160) ─────────────────────
        // Climbing section with platforms and hazards

        // Narrow vertical shaft walls
        c = 121;
        while c < 160 {
            if c < 130 or c > 150 {
                tilemap.SetTile(c, 4, TILE_OBSIDIAN);
                tilemap.SetTile(c, 5, TILE_OBSIDIAN);
            }
            c = c + 1;
        }

        // Staggered platforms for climbing
        buildPlatformRun(125, 16, 4, TILE_OBSIDIAN, 16 - 2);
        buildPlatformRun(132, 13, 3, TILE_OBSIDIAN, 13 - 2);
        buildPlatformRun(138, 10, 4, TILE_OBSIDIAN, 10 - 2);
        buildPlatformRun(144, 7, 3, TILE_OBSIDIAN, 7 - 2);
        buildPlatformRun(150, 10, 3, TILE_OBSIDIAN, 10 - 2);
        buildPlatformRun(155, 14, 4, TILE_OBSIDIAN, 14 - 2);

        // Steam vents for vertical traversal
        tilemap.SetTile(130, levelHeight - 3, TILE_STEAM_VENT);
        tilemap.SetTile(140, levelHeight - 3, TILE_STEAM_VENT);

        // Hazards
        tilemap.SetTile(135, 16, TILE_SPIKE);
        tilemap.SetTile(136, 16, TILE_SPIKE);
        tilemap.SetTile(145, 12, TILE_SPIKE);

        // Save station before boss
        tilemap.SetTile(158, levelHeight - 3, TILE_SAVE_STATION);
        hasCheckpoint = true;
        checkpointX = 158 * TILE_SIZE;
        checkpointY = (levelHeight - 4) * TILE_SIZE;

        // ─── Section 5: The Architect's Arena (161-200) ──────────────
        // Flat arena with pillars for cover

        // Arena walls
        c = 161;
        while c < 200 {
            tilemap.SetTile(c, 2, TILE_OBSIDIAN);
            c = c + 1;
        }

        // Pillars for cover
        var pillar = 0;
        while pillar < 4 {
            var px2 = 168 + pillar * 8;
            tilemap.SetTile(px2, levelHeight - 3, TILE_OBSIDIAN);
            tilemap.SetTile(px2, levelHeight - 4, TILE_OBSIDIAN);
            tilemap.SetTile(px2, levelHeight - 5, TILE_OBSIDIAN);
            pillar = pillar + 1;
        }

        // Platforms at different heights for boss dodging
        buildPlatformRun(170, 10, 3, TILE_OBSIDIAN, 10 - 2);
        buildPlatformRun(180, 8, 4, TILE_OBSIDIAN, 8 - 2);
        buildPlatformRun(190, 10, 3, TILE_OBSIDIAN, 10 - 2);
        buildPlatformRun(175, 14, 3, TILE_OBSIDIAN, 14 - 2);
        buildPlatformRun(185, 14, 3, TILE_OBSIDIAN, 14 - 2);

        // The Architect (final boss — 4-phase berserk)
        hasBoss = true;
        bossType = ENEMY_ARCHITECT;
        bossX = 185 * TILE_SIZE;
        bossY = 14 * TILE_SIZE;

        // Lore terminal near boss
        tilemap.SetTile(162, levelHeight - 3, TILE_LORE_TERMINAL);

        // Pickups in arena
        pickupTypes.add(PICKUP_HEALTH);
        pickupX.add(172 * TILE_SIZE);
        pickupY.add(8 * TILE_SIZE);

        pickupTypes.add(PICKUP_HEALTH);
        pickupX.add(192 * TILE_SIZE);
        pickupY.add(8 * TILE_SIZE);

        // Player spawn
        playerStartX = 3 * TILE_SIZE;
        playerStartY = (levelHeight - 4) * TILE_SIZE;

        // Gems scattered through level
        var g = 0;
        while g < 8 {
            pickupTypes.add(PICKUP_GEM);
            pickupX.add((20 + g * 20) * TILE_SIZE);
            pickupY.add((8 + g % 4 * 2) * TILE_SIZE);
            g = g + 1;
        }
    }
}
