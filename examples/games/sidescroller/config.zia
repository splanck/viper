// config.zia — All game constants, colors, tile IDs, entity IDs, physics params
module config;

// =============================================================================
// Screen & Window
// =============================================================================
final SCREEN_W = 1280;
final SCREEN_H = 720;
final TILE_SIZE = 64;         // 48→64: ~1.33x larger tiles for more visible detail
final FPS_MS = 16;
