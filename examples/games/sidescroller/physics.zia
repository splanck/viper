// =============================================================================
// Physics Helper — Tile collision resolution, gravity, AABB overlap
// =============================================================================
// Viper APIs demonstrated:
//   - Viper.Math (abs, min, max)
//   - Viper.Game.CollisionRect: AABB overlap detection via Overlaps()
//
// Zia best practices:
//   - Reusable CollisionRect instances (avoid per-check allocation)
//   - hide for internal helpers (toTileCoord), expose for public API
//   - x100 sub-pixel coordinate system for smooth movement
//   - MoveResult struct for clean multiple return values
//
// Coordinate system:
//   All positions/velocities are in x100 units (centipixels) unless noted.
//   Example: PLAYER_SPEED=525 means 5.25 pixels per frame at 60fps.
//   Collision resolves against TILE_SIZE-aligned grid boundaries.
// =============================================================================

module physics;

bind Viper.Math;
bind Viper.Game;
bind "./config";
bind "./level";

// Collision result — replaces the old out-parameter List[Integer] pattern.
struct MoveResult {
    expose Integer x;
    expose Integer y;
    expose Boolean hitFloor;
    expose Boolean hitCeiling;
    expose Boolean hitLeft;
    expose Boolean hitRight;
}

class PhysicsHelper {

    // CollisionRect instances reused each frame (avoid allocation per check).
    hide CollisionRect rectA;
    hide CollisionRect rectB;

    expose func init() {
        rectA = CollisionRect.New(0.0, 0.0, 1.0, 1.0);
        rectB = CollisionRect.New(0.0, 0.0, 1.0, 1.0);
    }

    // Move an entity by (vx, vy) and resolve collisions against the tile grid.
    // Returns a MoveResult with the resolved position and collision flags.
    expose func moveAndCollide(
        x: Integer, y: Integer, vx: Integer, vy: Integer,
        w: Integer, h: Integer, level: Level
    ) -> MoveResult {
        var newX = x + vx;
        var newY = y + vy;
        var floor = false;
        var ceiling = false;
        var left = false;
        var right = false;

        var w100 = w * 100;
        var h100 = h * 100;

        // =====================================================================
        // Resolve X axis first
        // =====================================================================
        if vx != 0 {
            var leadX = newX;
            if vx > 0 { leadX = newX + w100 - 1; }

            var tileX = toTileCoord(leadX);
            var topTile = toTileCoord(y);
            var botTile = toTileCoord(y + h100 - 1);

            for ty in topTile..=botTile {
                if level.isSolid(tileX, ty) {
                    if vx > 0 {
                        newX = tileX * TILE_SIZE * 100 - w100;
                        right = true;
                    } else {
                        newX = (tileX + 1) * TILE_SIZE * 100;
                        left = true;
                    }
                    break;
                }
            }
        }

        // =====================================================================
        // Resolve Y axis
        // =====================================================================
        if vy != 0 {
            var leadY = newY;
            if vy > 0 { leadY = newY + h100 - 1; }

            var tileY = toTileCoord(leadY);
            var leftTile = toTileCoord(newX);
            var rightTile = toTileCoord(newX + w100 - 1);

            for tx in leftTile..=rightTile {
                if level.isSolid(tx, tileY) {
                    if vy > 0 {
                        newY = tileY * TILE_SIZE * 100 - h100;
                        floor = true;
                    } else {
                        newY = (tileY + 1) * TILE_SIZE * 100;
                        ceiling = true;
                    }
                    break;
                }
            }
        }

        return new MoveResult(newX, newY, floor, ceiling, left, right);
    }

    // Check if a point (x100) is on solid ground (one pixel below feet)
    expose func isOnGround(x: Integer, y: Integer, w: Integer, h: Integer, level: Level) -> Boolean {
        var w100 = w * 100;
        var h100 = h * 100;
        var feetY = y + h100 + 50; // slightly below feet
        var tileY = toTileCoord(feetY);
        var leftTile = toTileCoord(x);
        var rightTile = toTileCoord(x + w100 - 1);

        for tx in leftTile..=rightTile {
            if level.isSolid(tx, tileY) {
                return true;
            }
        }
        return false;
    }

    // Check if touching a wall on the given side (-1 = left, 1 = right)
    expose func isTouchingWall(x: Integer, y: Integer, w: Integer, h: Integer,
                               dir: Integer, level: Level) -> Boolean {
        var w100 = w * 100;
        var h100 = h * 100;
        var checkX = x - 50;
        if dir > 0 {
            checkX = x + w100 + 50;
        }

        var tileX = toTileCoord(checkX);
        var topTile = toTileCoord(y);
        var botTile = toTileCoord(y + h100 - 1);

        for ty in topTile..=botTile {
            if level.isSolid(tileX, ty) {
                return true;
            }
        }
        return false;
    }

    // Check if standing on a hazard tile (spikes, lava)
    expose func isOnHazard(x: Integer, y: Integer, w: Integer, h: Integer, level: Level) -> Boolean {
        var w100 = w * 100;
        var h100 = h * 100;
        var feetY = y + h100 + 50;
        var tileY = toTileCoord(feetY);
        var leftTile = toTileCoord(x + 200);
        var rightTile = toTileCoord(x + w100 - 200);

        for tx in leftTile..=rightTile {
            if level.isHazard(tx, tileY) {
                return true;
            }
            // Also check one row up for lava surface
            if level.isHazard(tx, tileY - 1) {
                return true;
            }
        }
        return false;
    }

    // AABB overlap test with pixel coordinates using CollisionRect.Overlaps().
    // CollisionRect is reused per call to avoid per-frame allocation.
    expose func rectOverlapPx(ax: Integer, ay: Integer, aw: Integer, ah: Integer,
                              bx: Integer, by: Integer, bw: Integer, bh: Integer) -> Boolean {
        rectA.SetPosition(ax + 0.0, ay + 0.0);
        rectA.SetSize(aw + 0.0, ah + 0.0);
        rectB.SetPosition(bx + 0.0, by + 0.0);
        rectB.SetSize(bw + 0.0, bh + 0.0);
        return rectA.Overlaps(rectB);
    }

    // AABB overlap test (all in x100 coordinates) — delegates to pixel version.
    expose func rectOverlap(ax: Integer, ay: Integer, aw: Integer, ah: Integer,
                            bx: Integer, by: Integer, bw: Integer, bh: Integer) -> Boolean {
        return rectOverlapPx(ax / 100, ay / 100, aw / 100, ah / 100,
                            bx / 100, by / 100, bw / 100, bh / 100);
    }

    // Apply gravity with jump-apex hang time.
    // Near the peak of a jump (|vy| < threshold), gravity is reduced to 60%
    // for a floatier feel. This is a common platformer polish technique.
    expose func applyGravity(vy: Integer, dt: Integer) -> Integer {
        var g = GRAVITY * dt / DT_BASE;

        // Apex hang: reduce gravity when near the top of the arc.
        // The threshold 200 (x100 = 2px/frame) covers ~3 frames around the peak.
        var absVy = vy;
        if absVy < 0 { absVy = 0 - absVy; }
        if absVy < 200 {
            g = g * 3 / 5;  // 60% gravity at apex
        }

        var newVy = vy + g;
        if newVy > MAX_FALL { newVy = MAX_FALL; }
        return newVy;
    }

    // Convert x100 coordinate to tile coordinate
    hide func toTileCoord(pos100: Integer) -> Integer {
        var px = pos100 / 100;
        if pos100 < 0 {
            // Handle negative coordinates properly
            return (px - TILE_SIZE + 1) / TILE_SIZE;
        }
        return px / TILE_SIZE;
    }

    // =========================================================================
    // Environmental tile interactions
    // =========================================================================

    // Check what type of hazard tile the player is standing on/in.
    // Returns the tile ID of the hazard, or 0 if none.
    expose func checkHazardTile(x100: Integer, y100: Integer,
                                 w: Integer, h: Integer,
                                 level: Level) -> Integer {
        var px = x100 / 100;
        var py = y100 / 100;
        // Check feet position (center-bottom of player)
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            var t = level.getTile(tileX, tileY);
            if t == TILE_SPIKE { return t; }
            if t == TILE_LAVA { return t; }
            if t == TILE_THORN { return t; }
            if t == TILE_ELECTRIC { return t; }
            if t == TILE_COOLANT { return t; }
            if t == TILE_POISON_POOL { return t; }
        }
        // Also check row above feet
        var tileY2 = (py + h - TILE_SIZE / 2) / TILE_SIZE;
        if tileY2 >= 0 and tileY2 < level.levelHeight {
            var t2 = level.getTile(tileX, tileY2);
            if t2 == TILE_SPIKE { return t2; }
            if t2 == TILE_LAVA { return t2; }
            if t2 == TILE_THORN { return t2; }
            if t2 == TILE_ELECTRIC { return t2; }
        }
        return 0;
    }

    // Check if player is on ice (returns true for reduced friction).
    expose func isOnIce(x100: Integer, y100: Integer,
                         w: Integer, h: Integer, level: Level) -> Boolean {
        var px = x100 / 100;
        var py = y100 / 100;
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h + 2) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            return level.getTile(tileX, tileY) == TILE_ICE_FLOOR;
        }
        return false;
    }

    // Check if player is on conveyor belt. Returns -1 (left), 0 (none), 1 (right).
    expose func getConveyorDir(x100: Integer, y100: Integer,
                                w: Integer, h: Integer, level: Level) -> Integer {
        var px = x100 / 100;
        var py = y100 / 100;
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h + 2) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            var t = level.getTile(tileX, tileY);
            if t == TILE_CONVEYOR_L { return -1; }
            if t == TILE_CONVEYOR_R { return 1; }
        }
        return 0;
    }

    // Check if player is on a steam vent (launches upward).
    expose func isOnSteamVent(x100: Integer, y100: Integer,
                               w: Integer, h: Integer, level: Level) -> Boolean {
        var px = x100 / 100;
        var py = y100 / 100;
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h + 2) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            return level.getTile(tileX, tileY) == TILE_STEAM_VENT;
        }
        return false;
    }

    // Check if player is near a save station.
    expose func isNearSaveStation(x100: Integer, y100: Integer,
                                   w: Integer, h: Integer, level: Level) -> Boolean {
        var px = x100 / 100;
        var py = y100 / 100;
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h / 2) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            return level.getTile(tileX, tileY) == TILE_SAVE_STATION;
        }
        return false;
    }

    // Check if player is near a lore terminal.
    expose func isNearLoreTerminal(x100: Integer, y100: Integer,
                                    w: Integer, h: Integer, level: Level) -> Integer {
        var px = x100 / 100;
        var py = y100 / 100;
        var tileX = (px + w / 2) / TILE_SIZE;
        var tileY = (py + h / 2) / TILE_SIZE;
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            if level.getTile(tileX, tileY) == TILE_LORE_TERMINAL {
                // Return a lore index based on tile position (deterministic)
                return tileX + tileY * level.levelWidth;
            }
        }
        return -1;
    }

    // Check if a tile is a crumbling platform.
    expose func isCrumblingTile(tileX: Integer, tileY: Integer, level: Level) -> Boolean {
        if tileX >= 0 and tileX < level.levelWidth and tileY >= 0 and tileY < level.levelHeight {
            return level.getTile(tileX, tileY) == TILE_CRUMBLE;
        }
        return false;
    }
}
