// =============================================================================
// Sprite Factory — Procedural sprite generation for all game entities
// =============================================================================
// Viper APIs demonstrated:
//   - Viper.Graphics.Pixels: full procedural drawing API (DrawDisc, DrawEllipse,
//     DrawTriangle, DrawThickLine, DrawBezier, DrawLine, DrawBox, DrawEllipseFrame,
//     FlipH, Clone, SetRGB, Blur, Tint)
//
// Zia best practices:
//   - Entity with cached sprite lists (generated once, reused every frame)
//   - hide all sprite data, expose only accessor methods
//   - Each build function creates one sprite and returns it
//   - Multi-layer drawing technique: base fill → shadow → highlight → detail
//     creates a top-left-lit aesthetic for depth without real lighting
//
// Character sprite density targets:
//   - Player: ~120 draw calls per frame (36x48 px)
//   - Slime: ~45 calls per frame (36x30 px)
//   - Bat: ~55 calls per frame (42x30 px)
//   - Boss: ~90 calls per frame (84x84 px)
//   - Turret: ~40 calls (42x42 px)
//   - Tiles: ~15-25 calls each (48x48 px)
// =============================================================================

module sprites;

bind Viper.Graphics;
bind "./config";
bind "./palette";

// Original (pre-scale) sprite sizes. All draw calls use these coordinates,
// then Pixels.Scale() upsamples to the final display size. This avoids
// recalculating hundreds of hardcoded pixel coordinates when sizes change.
final ORIG_TILE = 48;
final ORIG_SLIME_W = 36;
final ORIG_SLIME_H = 30;
final ORIG_BAT_W = 42;
final ORIG_BAT_H = 30;
final ORIG_TURRET_W = 42;
final ORIG_TURRET_H = 42;
final ORIG_BOSS_W = 84;
final ORIG_BOSS_H = 84;
final ORIG_COIN_SIZE = 24;
final ORIG_POWERUP_SIZE = 30;

class SpriteFactory {
    // Cached sprites — created once, reused every frame
    // Player (2 idle, 4 run, jump, fall, djump, wallslide, hurt, dead = 12 frames)
    hide Palette pal;
    hide List[Pixels] playerRight;
    hide List[Pixels] playerLeft;

    // Enemies
    hide List[Pixels] slimeFrames;
    hide List[Pixels] batFrames;
    hide Pixels turretBase;
    hide Pixels turretBarrel;
    hide List[Pixels] bossFrames;

    // New enemy sprites (placeholder fields — built on demand)
    hide List[Pixels] sporewalkerFrames;
    hide List[Pixels] glowmothFrames;
    hide List[Pixels] fungalTurretFrames;
    hide List[Pixels] myceliumFrames;
    hide List[Pixels] crystalGolemFrames;
    hide List[Pixels] shardBatFrames;
    hide List[Pixels] resonanceOrbFrames;
    hide List[Pixels] mirrorSlimeFrames;
    hide List[Pixels] magmaSlugFrames;
    hide List[Pixels] emberWaspFrames;
    hide List[Pixels] forgeSentinelFrames;
    hide List[Pixels] frostBeetleFrames;
    hide List[Pixels] iceWraithFrames;
    hide List[Pixels] stalactiteBatFrames;
    hide Pixels vineWhipSprite;
    hide List[Pixels] mossGolemFrames;
    hide List[Pixels] ruinGuardianFrames;
    hide List[Pixels] shadowCloneFrames;
    hide List[Pixels] sporeMothFrames;
    hide List[Pixels] crystalWyrmFrames;
    hide List[Pixels] magmaCoreFrames;
    hide Pixels corruptionSprite;
    hide List[Pixels] architectFrames;
    hide List[Pixels] bombCarrierFrames;
    hide Boolean newSpritesBuilt;

    // Tiles
    hide Pixels tileGrassTop;
    hide Pixels tileDirt;
    hide Pixels tileMissing;
    hide Pixels tileStone;
    hide Pixels tileBrick;
    hide Pixels tilePlatform;
    hide Pixels tileLava1;
    hide Pixels tileLava2;
    hide Pixels tileCrystal;
    hide Pixels tileCaveTop;
    hide Pixels tileCaveWall;
    hide Pixels tileBridge;
    hide Pixels tileSpike;
    hide Pixels tileCheckpoint;
    // New level tiles
    hide Pixels tileMagma;
    hide Pixels tileObsidian;
    hide Pixels tileCloud;
    hide Pixels tileSkyBrick;
    hide Pixels tileRuinStone;
    hide Pixels tileVine;
    hide Pixels tileMossStone;
    // Xenoscape biome tiles
    hide Pixels tileJungleGround;
    hide Pixels tileJunglePlatform;
    hide Pixels tileThorn;
    hide Pixels tileMushroom;
    hide Pixels tileCaveCrystal;
    hide Pixels tileMetalGrate;
    hide Pixels tileMagmaRock;
    // Level 2: Station tiles
    hide Pixels tileHullPlate;
    hide Pixels tileGirder;
    hide Pixels tileElectric;
    hide Pixels tileAirlock;
    hide Pixels tilePipe;
    hide Pixels tileCatwalk;
    hide Pixels tileCoolant1;
    hide Pixels tileCoolant2;
    hide Pixels tileConduit;
    hide Pixels tileConsole;
    hide Pixels tileHoloBridge;
    hide Pixels tileViewport;
    // New environmental tiles
    hide Pixels tilePoisonPool1;
    hide Pixels tilePoisonPool2;
    hide Pixels tileIceFloor;
    hide Pixels tileSteamVent;
    hide Pixels tileDestructible;
    hide Pixels tileSaveStation;
    hide Pixels tileLoreTerminal;
    hide Pixels tileConveyorL;
    hide Pixels tileConveyorR;
    hide Pixels tileCrumble;
    hide Pixels tileOneWay;
    hide Pixels tileQuicksand;

    // Level 2: Drone enemy
    hide List[Pixels] droneFrames;

    // Tile lookup (replaces if-chain in getTile)
    hide List[Integer] tileIds;
    hide List[Pixels] tileSpriteList;

    // Pickups
    hide List[Pixels] coinFrames;
    hide Pixels healthOrb;
    hide Pixels speedPickup;
    hide Pixels shieldPickup;
    hide Pixels rapidPickup;

    // Bullet
    hide Pixels bulletRight;
    hide Pixels bulletLeft;
    hide Pixels enemyBullet;

    // Background elements
    hide Pixels cloud1;
    hide Pixels cloud2;
    hide Pixels treeBg;
    hide Pixels mountainBg;

    expose func init(p: Palette) {
        pal = p;
        playerRight = [];
        playerLeft = [];
        slimeFrames = [];
        batFrames = [];
        bossFrames = [];
        coinFrames = [];

        droneFrames = [];

        buildPlayerSprites();
        buildEnemySprites();
        buildTileSprites();
        buildStationTileSprites();
        buildTileLookup();
        buildPickupSprites();
        buildBulletSprites();
        buildBackgroundElements();
    }

    // =========================================================================
    // Player Sprites — drawn at 36x48, scaled to PLAYER_SPRITE_W x PLAYER_SPRITE_H
    // =========================================================================
    // Scale strategy: all draw calls use the original 36x48 coordinate space
    // for readability. After building each frame, Pixels.Scale() upsamples to
    // the final display size. This avoids recalculating 120+ coordinates.

    hide func buildPlayerSprites() {
        // Build right-facing frames at 36x48, then scale + flip for left
        // Frame 0-1: Idle (visor glow pulse)
        playerRight.add(scalePlayer(buildPlayerFrame(0, 0)));
        playerRight.add(scalePlayer(buildPlayerFrame(0, 1)));

        // Frame 2-5: Run (4-frame leg animation cycle)
        playerRight.add(scalePlayer(buildPlayerFrame(1, 0)));
        playerRight.add(scalePlayer(buildPlayerFrame(1, 1)));
        playerRight.add(scalePlayer(buildPlayerFrame(1, 2)));
        playerRight.add(scalePlayer(buildPlayerFrame(1, 3)));

        // Frame 6: Jump
        playerRight.add(scalePlayer(buildPlayerFrame(2, 0)));
        // Frame 7: Fall
        playerRight.add(scalePlayer(buildPlayerFrame(3, 0)));
        // Frame 8: Double jump
        playerRight.add(scalePlayer(buildPlayerFrame(4, 0)));
        // Frame 9: Wall slide
        playerRight.add(scalePlayer(buildPlayerFrame(5, 0)));
        // Frame 10: Hurt
        playerRight.add(scalePlayer(buildPlayerFrame(6, 0)));
        // Frame 11: Dead
        playerRight.add(scalePlayer(buildPlayerFrame(7, 0)));

        // Create left-facing versions by flipping the scaled sprites
        for i in 0..playerRight.length() {
            var flipped = playerRight.get(i).Clone();
            flipped.FlipH();
            playerLeft.add(flipped);
        }
    }

    // Scale a 36x48 sprite to the final player display size.
    hide func scalePlayer(src: Pixels) -> Pixels {
        return src.Scale(PLAYER_SPRITE_W, PLAYER_SPRITE_H);
    }

    hide func buildPlayerFrame(state: Integer, frame: Integer) -> Pixels {
        // REALISTIC ASTRONAUT: proper human proportions (head 1/5 of height),
        // articulated limbs, detailed suit panels, thin outlines, 3-tone shading.
        // Drawn at 36x48, scaled to 56x72 by caller.
        var px = Pixels.New(36, 48);
        var OL = pal.outline;

        var SUIT = 0xDDDDEE;
        var SUIT_LT = 0xEEEEFF;
        var SUIT_DK = 0xAAAABB;
        var SUIT_DD = 0x888899;
        var VISOR = 0x44CCEE;
        var VIS_LT = 0x88EEFF;
        var ACCENT = 0xFF6633;
        var BLUE = 0x3366FF;
        var METAL = 0x667788;

        // === Leg animation ===
        var bOff = 0;
        var lSp = 0;
        if state == 1 {
            if frame == 0 { bOff = 3; lSp = 2; }
            if frame == 1 { bOff = 1; lSp = 0; }
            if frame == 2 { bOff = -3; lSp = 2; }
            if frame == 3 { bOff = -1; lSp = 0; }
        }

        // === Jetpack (behind body, left side) ===
        px.DrawEllipse(5, 22, 4, 9, METAL);
        px.DrawEllipse(4, 21, 2, 6, 0x778899);              // highlight
        px.DrawEllipseFrame(5, 22, 4, 9, OL);
        px.DrawBox(8, 18, 2, 3, SUIT_DD);                   // mount bracket
        px.DrawBox(8, 26, 2, 3, SUIT_DD);
        // Nozzles
        px.DrawDisc(3, 33, 2, METAL);
        px.DrawDisc(7, 33, 2, METAL);
        px.DrawDisc(3, 33, 1, 0x333344);
        px.DrawDisc(7, 33, 1, 0x333344);
        // Fuel line
        px.DrawBezier(5, 14, 9, 14, 11, 17, SUIT_DD);
        // Status LED
        px.DrawDisc(5, 27, 1, 0x44FF66);

        // === Back arm (state-specific) ===
        if state == 2 {
            px.DrawThickLine(11, 18, 6, 10, 2, SUIT_DK);
            px.DrawDisc(6, 10, 2, SUIT);
        }
        if state == 3 {
            px.DrawThickLine(11, 20, 4, 24, 2, SUIT_DK);
            px.DrawDisc(4, 24, 2, SUIT);
        }

        // === Legs (thigh + knee + shin, proper proportions) ===
        var lkx = 13 - lSp;
        var lky = 36 + bOff / 2;
        var rkx = 22 + lSp;
        var rky = 36 - bOff / 2;
        // Left leg: thigh
        px.DrawThickLine(14, 32, lkx, lky, 3, SUIT_DK);
        px.DrawLine(14, 31, lkx, lky - 1, SUIT);            // highlight edge
        // Knee pad
        px.DrawDisc(lkx, lky, 2, SUIT_DD);
        px.DrawDisc(lkx, lky, 1, METAL);
        // Shin
        px.DrawThickLine(lkx, lky, lkx - 1, 40 + bOff, 3, SUIT_DK);
        px.DrawLine(lkx, lky, lkx - 1, 40 + bOff, SUIT);
        // Right leg
        px.DrawThickLine(21, 32, rkx, rky, 3, SUIT_DK);
        px.DrawLine(21, 31, rkx, rky - 1, SUIT);
        px.DrawDisc(rkx, rky, 2, SUIT_DD);
        px.DrawDisc(rkx, rky, 1, METAL);
        px.DrawThickLine(rkx, rky, rkx + 1, 40 - bOff, 3, SUIT_DK);
        px.DrawLine(rkx, rky, rkx + 1, 40 - bOff, SUIT);

        // === Boots (grey/white spacesuit boots, not orange) ===
        var lbx = lkx - 1;
        var lby = 43 + bOff;
        var rbx = rkx + 1;
        var rby = 43 - bOff;
        px.DrawEllipse(lbx, lby, 5, 4, SUIT_DK);
        px.DrawEllipse(lbx, lby - 1, 4, 2, SUIT);
        px.DrawLine(lbx - 4, lby + 3, lbx + 4, lby + 3, 0x555566);
        px.DrawEllipseFrame(lbx, lby, 5, 4, OL);
        px.DrawEllipse(rbx, rby, 5, 4, SUIT_DK);
        px.DrawEllipse(rbx, rby - 1, 4, 2, SUIT);
        px.DrawLine(rbx - 4, rby + 3, rbx + 4, rby + 3, 0x555566);
        px.DrawEllipseFrame(rbx, rby, 5, 4, OL);

        // === Torso (armor panels, proper proportions) ===
        px.DrawEllipse(17, 24, 9, 10, SUIT);
        px.DrawEllipse(17, 22, 6, 5, SUIT_LT);              // upper chest highlight
        px.DrawEllipse(17, 28, 7, 5, SUIT_DK);              // lower shadow
        // Panel seam lines
        px.DrawLine(10, 17, 10, 32, SUIT_DD);
        px.DrawLine(24, 17, 24, 32, SUIT_DD);
        // Chest blue mission patch
        px.DrawEllipse(17, 22, 3, 2, BLUE);
        px.DrawDisc(17, 22, 1, 0x5588FF);
        // Belt / waist
        px.DrawBox(9, 30, 16, 2, SUIT_DD);
        px.DrawLine(9, 30, 25, 30, METAL);
        px.DrawDisc(17, 31, 1, METAL);                       // buckle
        // Oxygen line (tube from jetpack to suit)
        px.DrawBezier(10, 18, 8, 20, 10, 22, SUIT_DD);
        // Body outline
        px.DrawEllipseFrame(17, 24, 9, 10, OL);

        // === Gun arm (articulated: shoulder → elbow → forearm → barrel) ===
        if state != 7 {
            px.DrawDisc(25, 19, 3, SUIT);                    // shoulder
            px.DrawThickLine(25, 19, 29, 18, 2, SUIT);       // upper arm
            px.DrawDisc(29, 18, 2, METAL);                   // elbow
            px.DrawThickLine(29, 18, 34, 18, 2, SUIT_DK);   // forearm
            px.DrawDisc(35, 18, 2, METAL);                   // gun muzzle
            px.DrawDisc(35, 18, 1, 0x333344);                // bore
            px.DrawLine(31, 16, 31, 20, SUIT_DD);            // cooling vent
        }

        // === Helmet (proper proportions — 1/5 of height) ===
        px.DrawDisc(18, 7, 8, SUIT);
        px.DrawDisc(16, 5, 3, SUIT_LT);                     // highlight
        px.DrawEllipse(18, 13, 8, 3, SUIT);                 // chin
        px.DrawLine(10, 13, 26, 13, SUIT_DD);               // rim
        px.DrawEllipseFrame(18, 7, 8, 8, OL);
        // Vent slits
        px.DrawLine(8, 6, 8, 9, SUIT_DD);
        px.DrawLine(9, 6, 9, 9, SUIT_DD);
        // Antenna
        px.DrawLine(22, 0, 22, 3, METAL);
        px.DrawDisc(22, 0, 1, 0xFF4444);

        // === Visor (reflective, detailed) ===
        px.DrawEllipse(21, 7, 6, 4, 0x112233);              // dark backing
        px.DrawEllipse(21, 7, 5, 3, VISOR);                 // visor glass
        px.DrawEllipse(22, 6, 3, 2, VIS_LT);                // inner glow
        px.DrawDisc(24, 5, 1, 0xDDFFFF);                    // specular
        px.DrawEllipseFrame(21, 7, 6, 4, OL);

        // === State overlays ===
        if state == 0 {
            if frame == 1 {
                px.DrawEllipse(21, 7, 4, 2, 0x33AACC);      // visor dim
            }
        }
        if state == 2 {
            // Jump flames
            px.DrawTriangle(1, 34, 5, 34, 3, 44, 0xFF6622);
            px.DrawTriangle(5, 34, 9, 34, 7, 44, 0xFF6622);
            px.DrawTriangle(2, 35, 4, 35, 3, 41, 0xFFDD44);
            px.DrawTriangle(6, 35, 8, 35, 7, 41, 0xFFDD44);
        }
        if state == 4 {
            px.DrawEllipse(18, 20, 13, 2, VISOR);
        }
        if state == 6 {
            px.DrawEllipse(21, 7, 5, 3, 0xFF4466);          // visor red flash
        }
        if state == 7 {
            px.DrawEllipse(21, 7, 5, 3, 0x334455);          // visor dark
            px.DrawLine(17, 5, 21, 9, 0xFF6666);
            px.DrawLine(21, 5, 17, 9, 0xFF6666);
        }

        return px;
    }

    // =========================================================================
    // Enemy Sprites
    // =========================================================================

    hide func buildEnemySprites() {
        // Slime: draw at 36x30, scale to SLIME_W x SLIME_H
        for i in 0..4 {
            slimeFrames.add(buildSlimeFrame(i).Scale(SLIME_W, SLIME_H));
        }

        // Bat: draw at 42x30, scale to BAT_W x BAT_H
        for i in 0..3 {
            batFrames.add(buildBatFrame(i).Scale(BAT_W, BAT_H));
        }

        // Maintenance drone: compact hovering robot with a blinking eye.
        for i in 0..2 {
            droneFrames.add(buildDroneFrame(i).Scale(DRONE_W, DRONE_H));
        }

        // Turret: draw at 42x42, scale to TURRET_W x TURRET_H
        turretBase = buildTurretBase().Scale(TURRET_W, TURRET_H);
        turretBarrel = buildTurretBarrel().Scale(30 * TURRET_W / ORIG_TURRET_W, 9 * TURRET_H / ORIG_TURRET_H);

        // Boss: draw at 84x84, scale to BOSS_W x BOSS_H
        for i in 0..4 {
            bossFrames.add(buildBossFrame(i).Scale(BOSS_W, BOSS_H));
        }
    }

    hide func buildSlimeFrame(frame: Integer) -> Pixels {
        // REALISTIC ALIEN BLOB: translucent body with visible inner structure,
        // menacing narrow eyes, dripping tendrils. Not cute — hostile.
        var px = Pixels.New(ORIG_SLIME_W, ORIG_SLIME_H);
        var OL = pal.outline;

        var sq = 0;
        if frame == 1 { sq = -3; }
        if frame == 2 { sq = 4; }
        if frame == 3 { sq = 1; }

        var cy = 16 + sq;
        var rx = 14 + sq;
        var ry = 8 - sq;

        // Ground shadow
        px.DrawEllipse(18, 28, rx - 3, 2, 0x113311);

        // Body — outer membrane
        px.DrawEllipse(18, cy, rx, ry, pal.slime);
        px.DrawDisc(18, cy - 3, rx - 2, pal.slime);
        // Inner structure (darker veins visible through translucent body)
        px.DrawEllipse(18, cy + 1, rx - 3, ry - 2, pal.slimeDark);
        px.DrawBezier(10, cy - 2, 18, cy + 3, 26, cy - 1, 0x33AA33);
        px.DrawBezier(12, cy + 2, 18, cy - 1, 24, cy + 3, 0x339933);
        // Nucleus (dark core)
        px.DrawDisc(18, cy, 3, 0x227722);
        px.DrawDisc(18, cy, 1, 0x115511);
        // Highlight (top-left reflective membrane)
        px.DrawDisc(14, cy - 5, 3, 0x88EE66);
        px.DrawDisc(13, cy - 6, 1, 0xBBFFAA);

        // Eyes — narrow, menacing slits
        var ey = cy - 2;
        px.DrawEllipse(12, ey, 3, 1, 0xFFFF44);
        px.DrawEllipse(24, ey, 3, 1, 0xFFFF44);
        px.DrawEllipse(12, ey, 2, 1, 0xFFFFAA);
        px.DrawEllipse(24, ey, 2, 1, 0xFFFFAA);

        // Dripping tendrils
        if frame == 0 || frame == 1 {
            px.DrawBezier(8, cy + ry, 7, cy + ry + 5, 9, cy + ry + 3, pal.slime);
            px.DrawBezier(14, cy + ry, 13, cy + ry + 4, 15, cy + ry + 2, pal.slimeDark);
            px.DrawBezier(26, cy + ry, 27, cy + ry + 4, 25, cy + ry + 2, pal.slime);
        }

        // Outline
        px.DrawEllipseFrame(18, cy, rx, ry, OL);

        return px;
    }

    hide func buildBatFrame(frame: Integer) -> Pixels {
        // REALISTIC ALIEN FLYER: angular wings with membrane veins,
        // compact armored body, compound red eyes, barbed tail. Hostile.
        var px = Pixels.New(ORIG_BAT_W, ORIG_BAT_H);
        var OL = pal.outline;

        // Wings — angular membrane with bone struts and veins
        if frame == 0 {
            // Wings UP
            px.DrawTriangle(14, 12, 0, 2, 8, 4, pal.batWing);
            px.DrawTriangle(14, 12, 8, 4, 8, 12, pal.batWing);
            px.DrawTriangle(28, 12, 42, 2, 34, 4, pal.batWing);
            px.DrawTriangle(28, 12, 34, 4, 34, 12, pal.batWing);
            px.DrawLine(14, 12, 1, 3, 0x553399);
            px.DrawLine(14, 12, 8, 6, 0x553399);
            px.DrawLine(28, 12, 41, 3, 0x553399);
            px.DrawLine(28, 12, 34, 6, 0x553399);
            // Membrane veins
            px.DrawLine(5, 5, 10, 9, 0x442277);
            px.DrawLine(37, 5, 32, 9, 0x442277);
        }
        if frame == 1 {
            px.DrawTriangle(14, 13, 0, 10, 10, 17, pal.batWing);
            px.DrawTriangle(28, 13, 42, 10, 32, 17, pal.batWing);
            px.DrawLine(14, 13, 1, 11, 0x553399);
            px.DrawLine(28, 13, 41, 11, 0x553399);
            px.DrawLine(6, 13, 10, 16, 0x442277);
            px.DrawLine(36, 13, 32, 16, 0x442277);
        }
        if frame == 2 {
            px.DrawTriangle(14, 14, 0, 20, 8, 25, pal.batWing);
            px.DrawTriangle(28, 14, 42, 20, 34, 25, pal.batWing);
            px.DrawLine(14, 14, 2, 21, 0x553399);
            px.DrawLine(28, 14, 40, 21, 0x553399);
        }

        // Body — compact armored oval
        px.DrawEllipse(21, 14, 7, 9, pal.batBody);
        px.DrawEllipse(21, 12, 5, 4, 0x9955BB);            // upper highlight
        px.DrawEllipse(21, 17, 5, 4, 0x6622AA);            // lower shadow
        // Armor plates
        px.DrawLine(16, 10, 16, 20, 0x553399);
        px.DrawLine(26, 10, 26, 20, 0x553399);
        px.DrawEllipseFrame(21, 14, 7, 9, OL);

        // Head — angular, insectoid
        px.DrawDisc(21, 7, 6, pal.batBody);
        px.DrawDisc(19, 5, 3, 0x9955BB);
        px.DrawEllipseFrame(21, 7, 6, 6, OL);

        // Compound eyes — multi-faceted red glow
        px.DrawDisc(17, 7, 3, 0x881111);
        px.DrawDisc(25, 7, 3, 0x881111);
        px.DrawDisc(17, 7, 2, pal.batEye);
        px.DrawDisc(25, 7, 2, pal.batEye);
        px.DrawDisc(17, 6, 1, 0xFF8844);
        px.DrawDisc(25, 6, 1, 0xFF8844);

        // Mandibles
        px.DrawLine(18, 12, 17, 15, 0x775599);
        px.DrawLine(24, 12, 25, 15, 0x775599);

        // Barbed tail
        px.DrawBezier(21, 23, 20, 27, 23, 29, 0x6622AA);
        px.DrawTriangle(22, 28, 24, 28, 23, 30, 0x553399);

        return px;
    }

    hide func buildDroneFrame(frame: Integer) -> Pixels {
        var px = Pixels.New(30, 24);
        var wingY = 11;
        if frame == 1 { wingY = 10; }
        if frame == 2 { wingY = 12; }

        // Side thruster pods
        px.DrawDisc(6, wingY, 4, pal.hullPlateLt);
        px.DrawDisc(24, wingY, 4, pal.hullPlateLt);
        px.DrawDisc(6, wingY, 2, pal.hullPlateDk);
        px.DrawDisc(24, wingY, 2, pal.hullPlateDk);

        // Main hull
        px.DrawBox(8, 7, 14, 10, pal.hullPlate);
        px.DrawBox(10, 5, 10, 4, pal.hullPlateLt);
        px.DrawFrame(8, 7, 14, 10, pal.outline);

        // Sensor eye
        var eye = pal.emergencyLight;
        if frame == 1 { eye = pal.white; }
        px.DrawDisc(15, 11, 2, eye);
        px.DrawDisc(15, 11, 1, pal.black);

        // Landing struts / antennae
        px.DrawLine(11, 16, 9, 21, pal.outline);
        px.DrawLine(19, 16, 21, 21, pal.outline);
        px.DrawLine(12, 7, 10, 3, pal.outline);
        px.DrawLine(18, 7, 20, 3, pal.outline);

        // Hover glow
        if frame != 2 {
            px.DrawLine(5, 18, 7, 22, pal.coolantBright);
            px.DrawLine(23, 18, 25, 22, pal.coolantBright);
        }

        return px;
    }

    hide func buildTurretBase() -> Pixels {
        // MILITARY SENTRY: armored angular housing, sensor dome,
        // warning light, panel detail. Industrial, not cute.
        var px = Pixels.New(ORIG_TURRET_W, ORIG_TURRET_H);
        var OL = pal.outline;

        // Base pedestal
        px.DrawEllipse(21, 37, 18, 5, 0x556677);
        px.DrawEllipse(21, 36, 17, 5, pal.turretBase);
        px.DrawEllipseFrame(21, 36, 17, 5, OL);

        // Housing body (angular)
        px.DrawBox(6, 18, 30, 18, pal.turretBase);
        px.DrawBox(9, 16, 24, 4, pal.turretBase);
        // Shading
        px.DrawLine(6, 18, 36, 18, 0x99AABB);               // top edge highlight
        px.DrawLine(6, 36, 36, 36, 0x556677);                // bottom edge shadow
        px.DrawLine(6, 18, 6, 36, 0x99AABB);                 // left highlight
        px.DrawLine(36, 18, 36, 36, 0x556677);               // right shadow
        // Panel seams
        px.DrawLine(6, 24, 36, 24, 0x667788);
        px.DrawLine(6, 30, 36, 30, 0x667788);
        px.DrawLine(21, 18, 21, 36, 0x667788);
        // Corner bolts
        px.DrawDisc(9, 20, 1, 0xAABBCC);
        px.DrawDisc(33, 20, 1, 0xAABBCC);
        px.DrawDisc(9, 33, 1, 0xAABBCC);
        px.DrawDisc(33, 33, 1, 0xAABBCC);

        // Sensor dome
        px.DrawDisc(21, 14, 9, 0x778899);
        px.DrawDisc(21, 14, 7, 0x889AAA);
        px.DrawDisc(18, 11, 3, 0xAABBCC);                   // specular
        px.DrawEllipseFrame(21, 14, 9, 9, OL);
        // Antenna
        px.DrawLine(21, 4, 21, 8, 0x778899);
        px.DrawDisc(21, 4, 1, 0xFF3333);

        // Warning light
        px.DrawDisc(21, 28, 3, pal.turretLight);
        px.DrawDisc(21, 28, 1, 0xFF6666);
        // Status LEDs
        px.DrawDisc(14, 32, 1, 0x44FF44);
        px.DrawDisc(21, 32, 1, 0xFFFF44);
        px.DrawDisc(28, 32, 1, 0xFF4444);

        return px;
    }

    hide func buildTurretBarrel() -> Pixels {
        // Military barrel with cooling vents and muzzle detail.
        var px = Pixels.New(30, 9);
        var OL = pal.outline;

        px.DrawThickLine(0, 5, 22, 5, 4, pal.turretBarrel);
        px.DrawLine(2, 2, 20, 2, 0x778899);                 // top highlight
        px.DrawLine(2, 7, 20, 7, 0x444455);                 // bottom shadow
        // Cooling vents
        px.DrawLine(8, 2, 8, 7, 0x556666);
        px.DrawLine(12, 2, 12, 7, 0x556666);
        px.DrawLine(16, 2, 16, 7, 0x556666);
        // Muzzle
        px.DrawDisc(26, 5, 4, 0x667788);
        px.DrawDisc(26, 5, 2, 0x445566);
        px.DrawDisc(26, 5, 1, 0x222233);

        return px;
    }

    hide func buildBossFrame(frame: Integer) -> Pixels {
        // CUTE CHUNKY boss: big round head, angry eye slit, oversized fists,
        // bold red armor with thick outlines. Chunky but intimidating.
        // Frame 0=phase 0, 1=phase 1, 2=phase 2, 3=attack wind-up.
        var px = Pixels.New(ORIG_BOSS_W, ORIG_BOSS_H);
        var OL = pal.outline;

        // === Shoulder pauldrons ===
        px.DrawDisc(14, 30, 10, pal.bossMetal);
        px.DrawDisc(13, 27, 4, 0x778899);
        px.DrawEllipseFrame(14, 30, 10, 10, OL);
        px.DrawDisc(70, 30, 10, pal.bossMetal);
        px.DrawDisc(69, 27, 4, 0x778899);
        px.DrawEllipseFrame(70, 30, 10, 10, OL);

        // === Body armor (layered plates) ===
        px.DrawEllipse(42, 44, 25, 20, pal.bossArmor);
        px.DrawEllipse(42, 42, 20, 14, 0xEE4444);
        px.DrawEllipse(42, 48, 22, 12, pal.bossDark);
        px.DrawBox(24, 24, 36, 8, pal.bossArmor);
        // Panel lines
        px.DrawLine(20, 30, 20, 56, pal.bossMetal);
        px.DrawLine(64, 30, 64, 56, pal.bossMetal);
        px.DrawLine(22, 24, 62, 24, 0xCC5555);
        px.DrawLine(22, 58, 62, 58, pal.bossDark);
        px.DrawEllipseFrame(42, 44, 25, 20, OL);

        // === Reactor core (phase-colored) ===
        var coreCol = 0x3388CC;
        var coreGlow = 0x55BBEE;
        if frame == 1 { coreCol = 0xCC8833; coreGlow = 0xFFBB44; }
        if frame == 2 { coreCol = 0xCC3333; coreGlow = 0xFF5555; }
        if frame == 3 { coreCol = 0xFF4444; coreGlow = 0xFFAAAA; }
        px.DrawDisc(42, 40, 7, 0x222233);
        px.DrawDisc(42, 40, 6, coreCol);
        px.DrawDisc(42, 40, 4, coreGlow);
        px.DrawDisc(42, 40, 2, 0xFFFFFF);
        px.DrawEllipseFrame(42, 40, 7, 7, OL);

        // === Head dome ===
        px.DrawDisc(42, 16, 13, pal.bossMetal);
        px.DrawDisc(42, 16, 11, 0x667788);
        px.DrawDisc(38, 11, 5, 0x778899);
        px.DrawEllipseFrame(42, 16, 13, 13, OL);
        // Crest
        px.DrawTriangle(42, 2, 36, 10, 48, 10, pal.bossArmor);
        px.DrawLine(42, 2, 36, 10, OL);
        px.DrawLine(42, 2, 48, 10, OL);
        // Eye slit
        var eyeW = 8;
        if frame == 1 { eyeW = 6; }
        if frame == 2 { eyeW = 10; }
        if frame == 3 { eyeW = 12; }
        px.DrawEllipse(42, 16, eyeW, 3, pal.bossEye);
        px.DrawEllipse(42, 16, eyeW - 2, 2, 0xFFAAAA);
        if frame == 3 { px.DrawDisc(42, 16, 5, 0xFFCCCC); }
        // Vent slits
        px.DrawLine(30, 14, 32, 14, 0x334455);
        px.DrawLine(30, 16, 32, 16, 0x334455);
        px.DrawLine(52, 14, 54, 14, 0x334455);
        px.DrawLine(52, 16, 54, 16, 0x334455);

        // === Arms with fists ===
        if frame == 2 {
            px.DrawThickLine(14, 30, 6, 42, 5, pal.bossMetal);
            px.DrawDisc(12, 36, 3, 0x667788);
            px.DrawDisc(4, 48, 6, pal.bossArmor);
            px.DrawDisc(4, 48, 3, pal.bossDark);
            px.DrawEllipseFrame(4, 48, 6, 6, OL);
            px.DrawThickLine(70, 30, 78, 42, 5, pal.bossMetal);
            px.DrawDisc(72, 36, 3, 0x667788);
            px.DrawDisc(80, 48, 6, pal.bossArmor);
            px.DrawDisc(80, 48, 3, pal.bossDark);
            px.DrawEllipseFrame(80, 48, 6, 6, OL);
        } else if frame == 3 {
            px.DrawThickLine(14, 30, 4, 22, 5, pal.bossMetal);
            px.DrawDisc(4, 20, 6, pal.bossArmor);
            px.DrawDisc(4, 20, 2, coreGlow);
            px.DrawThickLine(70, 30, 80, 22, 5, pal.bossMetal);
            px.DrawDisc(80, 20, 6, pal.bossArmor);
            px.DrawDisc(80, 20, 2, coreGlow);
        } else {
            px.DrawThickLine(14, 30, 10, 48, 5, pal.bossMetal);
            px.DrawLine(14, 29, 10, 47, 0x667788);
            px.DrawDisc(12, 38, 3, 0x667788);
            px.DrawDisc(10, 52, 6, pal.bossArmor);
            px.DrawDisc(10, 52, 3, pal.bossDark);
            px.DrawEllipseFrame(10, 52, 6, 6, OL);
            px.DrawThickLine(70, 30, 74, 48, 5, pal.bossMetal);
            px.DrawLine(70, 29, 74, 47, 0x667788);
            px.DrawDisc(72, 38, 3, 0x667788);
            px.DrawDisc(74, 52, 6, pal.bossArmor);
            px.DrawDisc(74, 52, 3, pal.bossDark);
            px.DrawEllipseFrame(74, 52, 6, 6, OL);
        }

        // === Legs (hydraulic) ===
        px.DrawThickLine(34, 58, 30, 68, 5, pal.bossMetal);
        px.DrawLine(34, 57, 30, 67, 0x667788);
        px.DrawDisc(30, 68, 3, 0x667788);
        px.DrawThickLine(30, 68, 28, 76, 4, pal.bossMetal);
        px.DrawLine(33, 60, 31, 74, 0x778899);
        px.DrawEllipse(28, 78, 7, 4, pal.bossMetal);
        px.DrawEllipseFrame(28, 78, 7, 4, OL);

        px.DrawThickLine(50, 58, 54, 68, 5, pal.bossMetal);
        px.DrawLine(50, 57, 54, 67, 0x667788);
        px.DrawDisc(54, 68, 3, 0x667788);
        px.DrawThickLine(54, 68, 56, 76, 4, pal.bossMetal);
        px.DrawLine(51, 60, 53, 74, 0x778899);
        px.DrawEllipse(56, 78, 7, 4, pal.bossMetal);
        px.DrawEllipseFrame(56, 78, 7, 4, OL);

        // === Phase damage ===
        if frame == 1 {
            px.DrawLine(30, 32, 38, 48, 0xFF8888);
            px.DrawLine(48, 34, 54, 50, 0xFF8888);
            px.DrawDisc(34, 40, 1, 0xFFDD44);
        }
        if frame == 2 {
            px.DrawLine(28, 30, 38, 50, 0xFF6666);
            px.DrawLine(46, 28, 56, 50, 0xFF6666);
            px.DrawLine(34, 46, 50, 46, 0xFF6666);
            px.DrawLine(30, 38, 34, 44, 0x4444FF);
            px.DrawLine(50, 36, 54, 44, 0x4444FF);
            px.DrawDisc(32, 42, 2, 0xFFFF44);
            px.DrawDisc(52, 40, 2, 0xFFFF44);
        }

        return px;
    }

    // =========================================================================
    // Tile Sprites (48x48 each)
    // =========================================================================

    // Scale helper: draw tile at ORIG_TILE (48), scale to TILE_SIZE (64)
    hide func scaleTile(src: Pixels) -> Pixels {
        return src.Scale(TILE_SIZE, TILE_SIZE);
    }

    hide func buildTileSprites() {
        tileGrassTop = scaleTile(buildGrassTile());
        tileDirt = scaleTile(buildDirtTile());
        tileMissing = scaleTile(buildMissingTile());
        tileStone = scaleTile(buildStoneTile());
        tileBrick = scaleTile(buildBrickTile());
        tilePlatform = scaleTile(buildPlatformTile());
        tileLava1 = scaleTile(buildLavaTile(0));
        tileLava2 = scaleTile(buildLavaTile(1));
        tileCrystal = scaleTile(buildCrystalTile());
        tileCaveTop = scaleTile(buildCaveTopTile());
        tileCaveWall = scaleTile(buildCaveWallTile());
        tileBridge = scaleTile(buildBridgeTile());
        tileSpike = scaleTile(buildSpikeTile());
        tileCheckpoint = scaleTile(buildCheckpointTile());
        tileMagma = scaleTile(buildMagmaTile());
        tileObsidian = scaleTile(buildObsidianTile());
        tileCloud = scaleTile(buildCloudTile());
        tileSkyBrick = scaleTile(buildSkyBrickTile());
        tileRuinStone = scaleTile(buildRuinStoneTile());
        tileVine = scaleTile(buildVineTile());
        tileMossStone = scaleTile(buildMossStoneTile());
        // Xenoscape biome tiles
        tileJungleGround = scaleTile(buildJungleGroundTile());
        tileJunglePlatform = scaleTile(buildJunglePlatformTile());
        tileThorn = scaleTile(buildThornTile());
        tileMushroom = scaleTile(buildMushroomTile());
        tileCaveCrystal = scaleTile(buildCaveCrystalTile());
        tileMetalGrate = scaleTile(buildMetalGrateTile());
        tileMagmaRock = scaleTile(buildMagmaRockTile());
        // New environmental tiles
        tilePoisonPool1 = scaleTile(buildPoisonPoolTile(0));
        tilePoisonPool2 = scaleTile(buildPoisonPoolTile(1));
        tileIceFloor = scaleTile(buildIceFloorTile());
        tileSteamVent = scaleTile(buildSteamVentTile());
        tileDestructible = scaleTile(buildDestructibleTile());
        tileSaveStation = scaleTile(buildSaveStationTile());
        tileLoreTerminal = scaleTile(buildLoreTerminalTile());
        tileConveyorL = scaleTile(buildConveyorTile(-1));
        tileConveyorR = scaleTile(buildConveyorTile(1));
        tileCrumble = scaleTile(buildCrumbleTile());
        tileOneWay = scaleTile(buildOneWayTile());
        tileQuicksand = scaleTile(buildQuicksandTile());
    }

    // ─── New Tile Builders ────────────────────────────────────────────

    hide func buildPoisonPoolTile(frame: Integer) -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Acid green pool
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(40, 80, 20));
        px.DrawBox(2, 2, ORIG_TILE - 4, ORIG_TILE - 4, Color.RGB(60, 120, 30));
        // Bubbles
        var bx = 10 + frame * 12;
        px.DrawDisc(bx, 15, 3, Color.RGB(100, 180, 50));
        px.DrawDisc(bx + 18, 20, 2, Color.RGB(90, 160, 40));
        px.Set(bx - 1, 13, Color.RGB(180, 255, 100));
        // Surface shimmer
        px.DrawLine(4, 6, 44, 6, Color.RGB(100, 200, 60));
        px.DrawLine(8, 4, 40, 4, Color.RGB(120, 220, 80));
        return px;
    }

    hide func buildIceFloorTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Ice blue base
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(160, 200, 240));
        px.DrawBox(2, 2, ORIG_TILE - 4, ORIG_TILE - 4, Color.RGB(180, 215, 245));
        // Frost cracks
        px.DrawLine(5, 10, 20, 30, Color.RGB(200, 230, 255));
        px.DrawLine(30, 5, 40, 25, Color.RGB(200, 230, 255));
        px.DrawLine(15, 40, 35, 42, Color.RGB(190, 220, 250));
        // Specular highlights
        px.Set(12, 8, Color.RGB(255, 255, 255));
        px.Set(13, 8, Color.RGB(255, 255, 255));
        px.Set(30, 15, Color.RGB(255, 255, 255));
        // Bevel
        px.DrawLine(0, 0, ORIG_TILE - 1, 0, Color.RGB(220, 240, 255));
        px.DrawLine(0, ORIG_TILE - 1, ORIG_TILE - 1, ORIG_TILE - 1, Color.RGB(120, 160, 200));
        return px;
    }

    hide func buildSteamVentTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Metal base
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(100, 100, 110));
        // Vent grate pattern
        var y = 4;
        while y < ORIG_TILE - 4 {
            px.DrawLine(8, y, 40, y, Color.RGB(70, 70, 80));
            y = y + 4;
        }
        // Center opening
        px.DrawBox(16, 12, 16, 24, Color.RGB(60, 60, 70));
        // Steam wisps (bright lines)
        px.DrawLine(20, 4, 18, 0, Color.RGB(200, 220, 240));
        px.DrawLine(28, 6, 30, 0, Color.RGB(180, 200, 220));
        px.DrawLine(24, 2, 24, 0, Color.RGB(220, 240, 255));
        // Rivets
        px.DrawDisc(6, 6, 2, Color.RGB(80, 80, 90));
        px.DrawDisc(42, 6, 2, Color.RGB(80, 80, 90));
        px.DrawDisc(6, 42, 2, Color.RGB(80, 80, 90));
        px.DrawDisc(42, 42, 2, Color.RGB(80, 80, 90));
        return px;
    }

    hide func buildDestructibleTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Cracked stone with visible fractures
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(120, 110, 90));
        px.DrawBox(2, 2, ORIG_TILE - 4, ORIG_TILE - 4, Color.RGB(135, 125, 105));
        // Major crack pattern
        px.DrawLine(10, 0, 24, 24, Color.RGB(80, 70, 55));
        px.DrawLine(24, 24, 40, 48, Color.RGB(80, 70, 55));
        px.DrawLine(0, 20, 20, 30, Color.RGB(85, 75, 60));
        px.DrawLine(30, 15, 48, 35, Color.RGB(85, 75, 60));
        // Bright crack edges (catch light)
        px.DrawLine(11, 0, 25, 24, Color.RGB(160, 150, 130));
        px.DrawLine(31, 15, 48, 34, Color.RGB(160, 150, 130));
        // Warning marks (X pattern)
        px.DrawLine(4, 4, 12, 12, Color.RGB(200, 150, 50));
        px.DrawLine(12, 4, 4, 12, Color.RGB(200, 150, 50));
        return px;
    }

    hide func buildSaveStationTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Platform base
        px.DrawBox(0, 32, ORIG_TILE, 16, Color.RGB(60, 70, 90));
        px.DrawBox(4, 34, ORIG_TILE - 8, 12, Color.RGB(70, 80, 100));
        // Crystal/beacon on top
        px.DrawTriangle(24, 4, 14, 32, 34, 32, Color.RGB(50, 200, 150));
        px.DrawTriangle(24, 8, 16, 30, 32, 30, Color.RGB(70, 230, 180));
        // Glow
        px.DrawDisc(24, 20, 8, Color.RGB(100, 255, 200));
        px.DrawDisc(24, 20, 4, Color.RGB(200, 255, 230));
        // Sparkles
        px.Set(18, 12, Color.RGB(255, 255, 255));
        px.Set(30, 16, Color.RGB(255, 255, 255));
        px.Set(24, 6, Color.RGB(255, 255, 255));
        return px;
    }

    hide func buildLoreTerminalTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Terminal body
        px.DrawBox(8, 8, 32, 36, Color.RGB(50, 50, 70));
        px.DrawBox(10, 10, 28, 32, Color.RGB(60, 60, 80));
        // Screen
        px.DrawBox(12, 12, 24, 18, Color.RGB(30, 80, 120));
        px.DrawBox(14, 14, 20, 14, Color.RGB(40, 100, 150));
        // Text lines on screen
        px.DrawLine(16, 17, 30, 17, Color.RGB(80, 180, 220));
        px.DrawLine(16, 21, 28, 21, Color.RGB(80, 180, 220));
        px.DrawLine(16, 25, 24, 25, Color.RGB(80, 180, 220));
        // Base
        px.DrawBox(6, 44, 36, 4, Color.RGB(40, 40, 55));
        // Indicator light
        px.DrawDisc(24, 35, 2, Color.RGB(50, 200, 100));
        px.Set(23, 34, Color.RGB(150, 255, 200));
        return px;
    }

    hide func buildConveyorTile(dir: Integer) -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Metal base
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(90, 90, 100));
        px.DrawBox(2, 4, ORIG_TILE - 4, ORIG_TILE - 8, Color.RGB(100, 100, 110));
        // Belt rollers
        var x = 6;
        while x < ORIG_TILE - 6 {
            px.DrawLine(x, 8, x, ORIG_TILE - 8, Color.RGB(70, 70, 80));
            x = x + 6;
        }
        // Direction arrows
        if dir > 0 {
            // Right arrows
            px.DrawTriangle(20, 24, 12, 18, 12, 30, Color.RGB(255, 200, 50));
            px.DrawTriangle(34, 24, 26, 18, 26, 30, Color.RGB(255, 200, 50));
        } else {
            // Left arrows
            px.DrawTriangle(14, 24, 22, 18, 22, 30, Color.RGB(255, 200, 50));
            px.DrawTriangle(28, 24, 36, 18, 36, 30, Color.RGB(255, 200, 50));
        }
        // Edge rails
        px.DrawLine(0, 0, ORIG_TILE, 0, Color.RGB(120, 120, 130));
        px.DrawLine(0, ORIG_TILE - 1, ORIG_TILE, ORIG_TILE - 1, Color.RGB(60, 60, 70));
        return px;
    }

    hide func buildCrumbleTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Cracked stone platform
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(140, 130, 110));
        px.DrawBox(2, 2, ORIG_TILE - 4, ORIG_TILE - 4, Color.RGB(155, 145, 125));
        // Heavy crack pattern
        px.DrawLine(0, 24, 48, 24, Color.RGB(100, 90, 75));
        px.DrawLine(24, 0, 24, 48, Color.RGB(100, 90, 75));
        px.DrawLine(8, 8, 40, 40, Color.RGB(105, 95, 80));
        // Crumbling edge particles
        px.DrawDisc(4, 44, 2, Color.RGB(120, 110, 95));
        px.DrawDisc(44, 42, 1, Color.RGB(115, 105, 90));
        px.DrawDisc(40, 46, 2, Color.RGB(125, 115, 100));
        // Warning: slight red tint
        px.DrawLine(0, 0, ORIG_TILE, 0, Color.RGB(180, 120, 80));
        return px;
    }

    hide func buildOneWayTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Thin platform with upward arrow pattern
        px.DrawBox(0, 0, ORIG_TILE, 8, Color.RGB(100, 120, 140));
        px.DrawBox(2, 2, ORIG_TILE - 4, 4, Color.RGB(120, 140, 160));
        // Upward arrows (indicating pass-through direction)
        var x = 8;
        while x < ORIG_TILE - 8 {
            px.DrawTriangle(x + 4, 10, x, 16, x + 8, 16, Color.RGB(80, 100, 120));
            x = x + 12;
        }
        // Dashed line below (indicating one-way)
        x = 0;
        while x < ORIG_TILE {
            px.DrawLine(x, 8, x + 4, 8, Color.RGB(60, 80, 100));
            x = x + 8;
        }
        return px;
    }

    hide func buildQuicksandTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Sandy base with darker patches
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(180, 160, 120));
        px.DrawBox(4, 4, 12, 12, Color.RGB(160, 140, 100));
        px.DrawBox(24, 20, 16, 16, Color.RGB(165, 145, 105));
        px.DrawBox(8, 30, 14, 14, Color.RGB(155, 135, 95));
        // Swirl pattern
        px.DrawLine(24, 24, 20, 28, Color.RGB(140, 120, 80));
        px.DrawLine(20, 28, 24, 32, Color.RGB(140, 120, 80));
        px.DrawLine(24, 32, 28, 28, Color.RGB(140, 120, 80));
        // Surface texture (ripples)
        px.DrawLine(4, 8, 44, 8, Color.RGB(170, 150, 110));
        px.DrawLine(8, 20, 40, 20, Color.RGB(170, 150, 110));
        px.DrawLine(4, 36, 44, 36, Color.RGB(170, 150, 110));
        return px;
    }

    hide func buildGrassTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Dirt base
        px.DrawBox(0, 16, 48, 32, pal.dirt);
        // Grass top area
        px.DrawBox(0, 0, 48, 20, pal.grass);
        px.DrawBox(0, 0, 48, 10, pal.grassDark);

        // Grass blades — triangles along the top edge for organic look
        var i = 0;
        while i < 46 {
            var h = 4 + (i * 7) % 6;
            var shade = pal.grass;
            if i % 10 < 5 {
                shade = pal.grassDark;
            }
            px.DrawTriangle(i, 18, i + 2, 18 - h, i + 4, 18, shade);
            i = i + 5;
        }

        // Shadow line below grass
        px.DrawLine(0, 20, 47, 20, pal.grassDark);

        // Dirt pebbles
        px.DrawDisc(10, 28, 2, pal.dirtDark);
        px.DrawDisc(30, 34, 2, pal.dirtDark);
        px.DrawDisc(22, 42, 1, pal.dirtDark);
        px.DrawDisc(40, 26, 1, pal.dirtDark);

        // Root details
        px.DrawLine(5, 22, 16, 24, pal.dirtDark);
        px.DrawLine(32, 21, 42, 23, pal.dirtDark);
        return px;
    }

    hide func buildDirtTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.dirt);
        // Pebble texture using discs
        var i = 0;
        while i < 8 {
            var tx = (i * 13 + 5) % 43 + 2;
            var ty = (i * 17 + 3) % 43 + 2;
            px.DrawDisc(tx, ty, 2, pal.dirtDark);
            i = i + 1;
        }
        // Root lines
        px.DrawLine(5, 14, 20, 16, pal.dirtDark);
        px.DrawLine(28, 32, 44, 30, pal.dirtDark);
        return px;
    }

    hide func buildStoneTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.stone);

        // Mortar lines (thin)
        px.DrawLine(0, 0, 47, 0, pal.stoneDark);
        px.DrawLine(0, 23, 47, 23, pal.stoneDark);
        px.DrawLine(0, 24, 47, 24, pal.stoneDark);
        px.DrawLine(0, 47, 47, 47, pal.stoneDark);
        // Vertical mortar
        px.DrawLine(23, 0, 23, 23, pal.stoneDark);
        px.DrawLine(0, 24, 0, 47, pal.stoneDark);

        // Bevel highlights (top/left of each brick face)
        px.DrawLine(1, 2, 22, 2, pal.stoneLight);
        px.DrawLine(1, 2, 1, 22, pal.stoneLight);
        px.DrawLine(24, 26, 47, 26, pal.stoneLight);
        px.DrawLine(24, 26, 24, 46, pal.stoneLight);

        // Bevel shadows (bottom/right of each brick)
        px.DrawLine(22, 3, 22, 22, pal.stoneDark);
        px.DrawLine(1, 22, 22, 22, pal.stoneDark);
        px.DrawLine(47, 26, 47, 46, pal.stoneDark);
        px.DrawLine(24, 46, 47, 46, pal.stoneDark);

        // Mineral flecks
        px.DrawDisc(10, 12, 1, 0x909090);
        px.DrawDisc(35, 36, 1, 0x707070);
        px.DrawDisc(38, 10, 1, 0x909090);
        return px;
    }

    hide func buildBrickTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.brick);

        // Mortar lines (using DrawLine for cleaner look)
        px.DrawLine(0, 11, 47, 11, pal.brickDark);
        px.DrawLine(0, 12, 47, 12, pal.brickDark);
        px.DrawLine(0, 23, 47, 23, pal.brickDark);
        px.DrawLine(0, 24, 47, 24, pal.brickDark);
        px.DrawLine(0, 35, 47, 35, pal.brickDark);
        px.DrawLine(0, 36, 47, 36, pal.brickDark);
        // Vertical mortar (offset per row)
        px.DrawLine(23, 0, 23, 11, pal.brickDark);
        px.DrawLine(11, 12, 11, 23, pal.brickDark);
        px.DrawLine(35, 12, 35, 23, pal.brickDark);
        px.DrawLine(23, 24, 23, 35, pal.brickDark);
        px.DrawLine(11, 36, 11, 47, pal.brickDark);
        px.DrawLine(35, 36, 35, 47, pal.brickDark);

        // Bevel highlights (top edge of each brick)
        px.DrawLine(1, 1, 22, 1, 0xC06040);
        px.DrawLine(1, 13, 10, 13, 0xC06040);
        px.DrawLine(13, 13, 34, 13, 0xC06040);
        px.DrawLine(1, 25, 22, 25, 0xC06040);
        px.DrawLine(1, 37, 10, 37, 0xC06040);
        px.DrawLine(13, 37, 34, 37, 0xC06040);
        return px;
    }

    hide func buildPlatformTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.platform);
        // Top edge (beveled)
        px.DrawBox(0, 0, 48, 5, 0x8B6830);
        px.DrawLine(0, 5, 47, 5, pal.platformDark);
        // Wood grain lines
        px.DrawLine(0, 14, 47, 14, pal.platformDark);
        px.DrawLine(0, 28, 47, 28, pal.platformDark);
        px.DrawLine(0, 42, 47, 42, pal.platformDark);
        // Wood grain curves (subtle)
        px.DrawBezier(0, 20, 24, 18, 47, 21, pal.platformDark);
        px.DrawBezier(0, 35, 24, 37, 47, 34, pal.platformDark);
        // Nail dots (round)
        px.DrawDisc(6, 9, 1, 0x555555);
        px.DrawDisc(42, 9, 1, 0x555555);
        px.DrawDisc(24, 22, 1, 0x555555);
        return px;
    }

    hide func buildLavaTile(frame: Integer) -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.lava);

        // Bubbles (animated disc positions)
        if frame == 0 {
            px.DrawDisc(12, 14, 6, pal.lavaBright);
            px.DrawDisc(36, 26, 5, pal.lavaBright);
            px.DrawDisc(22, 38, 7, pal.lavaBright);
            // Bright centers
            px.DrawDisc(12, 14, 3, 0xFFDD44);
            px.DrawDisc(22, 38, 3, 0xFFDD44);
        } else {
            px.DrawDisc(26, 10, 5, pal.lavaBright);
            px.DrawDisc(8, 30, 6, pal.lavaBright);
            px.DrawDisc(38, 40, 5, pal.lavaBright);
            // Bright centers
            px.DrawDisc(26, 10, 2, 0xFFDD44);
            px.DrawDisc(8, 30, 3, 0xFFDD44);
        }

        // Wavy veins
        px.DrawBezier(0, 20, 24, 14, 47, 22, 0xFFDD44);
        px.DrawBezier(0, 38, 24, 44, 47, 36, 0xFFAA22);
        // Surface glow (top edge)
        px.DrawEllipse(24, 3, 24, 3, 0xFFAA22);
        return px;
    }

    hide func buildCrystalTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.caveRock);

        // Blue crystal shard (tall triangle)
        px.DrawTriangle(6, 36, 12, 6, 18, 36, pal.crystalBlue);
        // Crystal facet (darker right face)
        px.DrawTriangle(12, 6, 18, 36, 15, 20, 0x40A0CC);
        // Facet line
        px.DrawLine(12, 6, 15, 20, 0x80E0FF);
        // Glow highlight
        px.DrawDisc(11, 18, 2, 0x80E0FF);

        // Pink crystal shard
        px.DrawTriangle(27, 38, 33, 12, 39, 38, pal.crystalPink);
        px.DrawTriangle(33, 12, 39, 38, 36, 24, 0xCC60A0);
        px.DrawLine(33, 12, 36, 24, 0xFFA0E0);
        px.DrawDisc(33, 22, 2, 0xFFA0E0);

        // Small crystal fragment
        px.DrawTriangle(40, 42, 43, 28, 46, 42, pal.crystalBlue);
        px.DrawDisc(43, 34, 1, 0x80E0FF);
        return px;
    }

    hide func buildCaveTopTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.caveRock);
        px.DrawBox(0, 30, 48, 18, pal.caveRockDark);

        // Stalactites as triangles (pointing down)
        px.DrawTriangle(6, 32, 15, 32, 10, 46, pal.caveRock);
        px.DrawTriangle(8, 34, 13, 34, 10, 44, 0x6A6A8E);
        px.DrawTriangle(28, 34, 38, 34, 33, 47, pal.caveRock);
        px.DrawTriangle(30, 36, 36, 36, 33, 45, 0x6A6A8E);

        // Drip dots at tips
        px.SetRGB(10, 47, 0x4488CC);
        px.SetRGB(33, 47, 0x4488CC);
        return px;
    }

    hide func buildCaveWallTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.caveRock);

        // Rock face variations using ellipses
        px.DrawEllipse(14, 14, 10, 8, pal.caveRockDark);
        px.DrawEllipse(36, 36, 8, 10, pal.caveRockDark);

        // Crack lines
        px.DrawLine(22, 5, 30, 18, 0x4A4A6A);
        px.DrawLine(8, 36, 16, 46, 0x4A4A6A);

        // Mineral spots
        px.DrawDisc(32, 10, 1, 0x7A7A9E);
        px.DrawDisc(10, 28, 1, 0x7A7A9E);
        return px;
    }

    hide func buildBridgeTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Planks (top section)
        px.DrawBox(0, 0, 48, 12, pal.bridge);
        px.DrawBox(0, 0, 48, 3, 0x5A4320);
        // Plank division lines
        px.DrawLine(15, 0, 15, 11, 0x5A4320);
        px.DrawLine(32, 0, 32, 11, 0x5A4320);
        // Wood grain curve
        px.DrawBezier(0, 7, 16, 6, 32, 8, 0x6A5330);
        // Rope supports (thick lines)
        px.DrawThickLine(1, 12, 1, 47, 2, 0x8B7355);
        px.DrawThickLine(46, 12, 46, 47, 2, 0x8B7355);
        // Rope cross-hatching
        px.DrawLine(0, 18, 3, 22, 0x7A6345);
        px.DrawLine(0, 30, 3, 34, 0x7A6345);
        px.DrawLine(44, 20, 47, 24, 0x7A6345);
        px.DrawLine(44, 32, 47, 36, 0x7A6345);
        return px;
    }

    hide func buildSpikeTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // 4 proper triangular spikes
        var i = 0;
        while i < 4 {
            var baseX = i * 12;
            var tipY = 4 + (i % 2) * 5;
            // Main spike body
            px.DrawTriangle(baseX + 1, 47, baseX + 6, tipY, baseX + 11, 47, 0xCCCCCC);
            // Shaded right face
            px.DrawTriangle(baseX + 6, tipY, baseX + 11, 47, baseX + 9, 30, 0x999999);
            // Metallic highlight on left edge
            px.DrawLine(baseX + 2, 45, baseX + 6, tipY + 1, 0xEEEEEE);
            i = i + 1;
        }
        return px;
    }

    hide func buildCheckpointTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Flag pole (thick line instead of fat rectangle)
        px.DrawThickLine(23, 2, 23, 47, 2, 0x888888);
        // Pole top knob
        px.DrawDisc(23, 3, 3, 0xAAAAAA);
        // Flag as triangle (not rectangle)
        px.DrawTriangle(25, 6, 42, 12, 25, 18, pal.checkpoint);
        // Flag highlight stripe
        px.DrawTriangle(25, 9, 36, 12, 25, 15, 0x22CC22);
        return px;
    }

    // --- New Level Tiles ---

    hide func buildMagmaTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.magma);
        // Embedded ember spots
        px.DrawDisc(10, 12, 3, pal.magmaGlow);
        px.DrawDisc(34, 28, 2, pal.magmaGlow);
        px.DrawDisc(22, 40, 3, pal.magmaGlow);
        // Crack lines
        px.DrawLine(5, 8, 20, 22, pal.magmaDark);
        px.DrawLine(28, 10, 42, 30, pal.magmaDark);
        px.DrawLine(12, 35, 36, 42, pal.magmaDark);
        // Glowing vein
        px.DrawBezier(0, 24, 24, 18, 47, 28, 0xFF6622);
        return px;
    }

    hide func buildObsidianTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.obsidian);
        // Angular fracture lines
        px.DrawLine(8, 0, 20, 24, pal.obsidianLight);
        px.DrawLine(20, 24, 40, 12, pal.obsidianLight);
        px.DrawLine(30, 30, 48, 44, pal.obsidianLight);
        // Reflection spots
