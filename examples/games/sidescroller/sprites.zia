    // ─── Frost Beetle: armored ice creature ───────────────────────────
    hide func buildFrostBeetleSprites() {
        frostBeetleFrames = [];
        var f = 0;
        while f < 4 {
            var pix = Pixels.New(36, 30);
            if f < 2 {
                // Walking frames
                Pixels.DrawEllipse(pix, 18, 16, 16, 12, Color.RGB(80, 140, 180));
                Pixels.DrawEllipse(pix, 18, 14, 14, 10, Color.RGB(100, 160, 200));
                // Shell plates
