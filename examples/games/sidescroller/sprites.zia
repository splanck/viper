            Pixels.DrawDisc(pix, 15, 6, 1, pal.white);
            Pixels.DrawDisc(pix, 9, 6, 0, pal.outline);
            Pixels.DrawDisc(pix, 15, 6, 0, pal.outline);
            Pixels.DrawLine(pix, 8, 10, 6 + tendril, 15, pal.jungleRoots);
            Pixels.DrawLine(pix, 12, 10, 12, 15, pal.jungleRoots);
            Pixels.DrawLine(pix, 16, 10, 18 - tendril, 15, pal.jungleRoots);
            Pixels.DrawLine(pix, 12, 2, 12, 0, pal.outline);
            myceliumFrames.add(Pixels.Scale(pix, MYCELIUM_W, MYCELIUM_H));
            f = f + 1;
        }
    }

