                // Eyes
                Pixels.DrawDisc(pix, 12, 12, 2, Color.RGB(200, 240, 255));
                Pixels.DrawDisc(pix, 24, 12, 2, Color.RGB(200, 240, 255));
                // Legs
                var off = f * 2;
                Pixels.DrawBox(pix, 6, 24 + off, 4, 6, Color.RGB(60, 100, 140));
                Pixels.DrawBox(pix, 26, 24 - off, 4, 6, Color.RGB(60, 100, 140));
            } else {
                // Roll frames (curled up)
                Pixels.DrawDisc(pix, 18, 15, 14, Color.RGB(80, 140, 180));
                Pixels.DrawDisc(pix, 18, 15, 12, Color.RGB(100, 160, 200));
                // Shell ridges
                if f == 2 {
                    Pixels.DrawLine(pix, 8, 8, 28, 22, Color.RGB(60, 120, 160));
                } else {
                    Pixels.DrawLine(pix, 28, 8, 8, 22, Color.RGB(60, 120, 160));
                }
            }
            // Frost crystals on shell
            Pixels.Set(pix, 10, 8, Color.RGB(220, 240, 255));
            Pixels.Set(pix, 26, 10, Color.RGB(220, 240, 255));
            frostBeetleFrames.add(Pixels.Scale(pix, FROST_BEETLE_W, FROST_BEETLE_H));
            f = f + 1;
        }
    }

