        px.DrawDisc(36, 34, 2, 0x444466);
        return px;
    }

    hide func buildCloudTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Cloud puff shape
        px.DrawEllipse(24, 24, 22, 18, pal.cloudWhite);
        px.DrawDisc(12, 20, 14, pal.cloudWhite);
        px.DrawDisc(36, 20, 14, pal.cloudWhite);
        px.DrawDisc(24, 14, 16, 0xFFFFFF);
        // Soft shading on bottom
        px.DrawEllipse(24, 32, 20, 8, 0xCCDDEE);
        return px;
    }

    hide func buildSkyBrickTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.skyStone);
        // Mortar lines
        px.DrawLine(0, 23, 47, 23, pal.skyStoneDark);
        px.DrawLine(23, 0, 23, 23, pal.skyStoneDark);
        px.DrawLine(0, 24, 0, 47, pal.skyStoneDark);
        // Bevel highlights
        px.DrawLine(1, 1, 22, 1, 0xAABBCC);
        px.DrawLine(24, 25, 47, 25, 0xAABBCC);
        // Crystal inlays
        px.DrawDisc(12, 12, 2, pal.crystalBlue);
        px.DrawDisc(36, 36, 2, pal.crystalBlue);
        return px;
    }

    hide func buildRuinStoneTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.ruin);
        // Cracks and fissures
        px.DrawLine(10, 5, 22, 20, pal.ruinDark);
        px.DrawLine(22, 20, 18, 36, pal.ruinDark);
        px.DrawLine(30, 12, 42, 30, pal.ruinDark);
        // Moss patches
        px.DrawDisc(8, 38, 4, pal.ruinMoss);
        px.DrawDisc(38, 8, 3, pal.ruinMoss);
        // Worn edge
        px.DrawLine(0, 0, 47, 0, pal.ruinDark);
        px.DrawLine(0, 47, 47, 47, pal.ruinDark);
        return px;
    }

    hide func buildVineTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Vine curves
        px.DrawBezier(10, 0, 6, 16, 14, 32, pal.vineGreen);
        px.DrawBezier(14, 32, 20, 40, 12, 47, pal.vineGreen);
        px.DrawBezier(30, 0, 36, 14, 28, 28, pal.vineDark);
        px.DrawBezier(28, 28, 22, 36, 32, 47, pal.vineDark);
        // Leaf clusters
        px.DrawDisc(8, 14, 4, pal.vineGreen);
        px.DrawDisc(18, 30, 3, pal.vineGreen);
        px.DrawDisc(34, 10, 3, pal.vineDark);
        px.DrawDisc(26, 40, 4, pal.vineGreen);
        // Leaf highlights
        px.DrawDisc(7, 12, 2, 0x44AA44);
        px.DrawDisc(25, 38, 2, 0x44AA44);
        return px;
    }

    hide func buildMossStoneTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.ruin);
        // Stone texture
        px.DrawEllipse(16, 16, 10, 8, pal.ruinDark);
        px.DrawEllipse(36, 36, 8, 6, pal.ruinDark);
        // Moss coverage (ellipses for organic shapes)
        px.DrawEllipse(12, 10, 8, 5, pal.ruinMoss);
        px.DrawEllipse(30, 22, 6, 4, pal.ruinMoss);
        px.DrawEllipse(20, 40, 10, 5, pal.ruinMoss);
        // Moss highlights
        px.DrawDisc(10, 8, 3, 0x558844);
        px.DrawDisc(22, 38, 3, 0x558844);
        return px;
    }

    // =========================================================================
    // Xenoscape Biome Tiles
    // =========================================================================

    hide func buildJungleGroundTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Rich alien soil
        px.DrawBox(0, 8, 48, 40, pal.jungleGround);
        // Moss top layer
        px.DrawBox(0, 0, 48, 12, pal.jungleGroundTop);
        px.DrawEllipse(12, 8, 8, 3, pal.jungleMoss);
        px.DrawEllipse(36, 9, 6, 3, pal.jungleMoss);
        // Glowing root veins
        px.DrawBezier(4, 20, 20, 24, 44, 18, pal.jungleRoots);
        px.DrawBezier(8, 36, 28, 40, 42, 34, pal.jungleRoots);
        // Soil texture
        px.DrawDisc(14, 30, 2, pal.dirtDark);
        px.DrawDisc(34, 26, 1, pal.dirtDark);
        // Outline
        px.DrawLine(0, 0, 47, 0, pal.outline);
        return px;
    }

    hide func buildJunglePlatformTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Moss-covered stone
        px.DrawBox(0, 4, 48, 40, pal.cavernStone);
        px.DrawBox(0, 0, 48, 8, pal.jungleMoss);
        // Glowing sap vein across platform
        px.DrawBezier(0, 24, 24, 20, 47, 26, pal.jungleSap);
        // Stone cracks
        px.DrawLine(16, 12, 24, 28, pal.cavernStoneDk);
        px.DrawLine(32, 16, 38, 32, pal.cavernStoneDk);
        // Moss drip
        px.DrawDisc(8, 44, 2, pal.jungleMoss);
        px.DrawDisc(40, 42, 1, pal.jungleMoss);
        // Outline
        px.DrawLine(0, 0, 47, 0, pal.outline);
        px.DrawLine(0, 44, 47, 44, pal.outline);
        return px;
    }

    hide func buildThornTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Organic thorn clusters — alien, not metallic
        var i = 0;
        while i < 4 {
            var bx = i * 12;
            var tipY = 3 + (i % 2) * 4;
            // Thorn body (organic green-brown)
            px.DrawTriangle(bx + 1, 47, bx + 6, tipY, bx + 11, 47, pal.jungleThorn);
            // Purple tip
            px.DrawTriangle(bx + 4, tipY + 6, bx + 6, tipY, bx + 8, tipY + 6, pal.jungleThornTip);
            // Highlight edge
            px.DrawLine(bx + 2, 44, bx + 6, tipY + 1, 0xAA7744);
            i = i + 1;
        }
        return px;
    }

    hide func buildMushroomTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Bouncy alien mushroom platform
        // Stem
        px.DrawBox(18, 24, 12, 24, pal.mushroomStem);
        px.DrawLine(18, 24, 18, 47, pal.outline);
        px.DrawLine(30, 24, 30, 47, pal.outline);
        // Cap (big dome)
        px.DrawEllipse(24, 18, 22, 14, Color.RGB(140, 80, 160));
        px.DrawEllipse(24, 14, 16, 8, pal.mushroomGlow);
        px.DrawDisc(18, 12, 4, 0xFFAADD);                   // highlight
        // Spots on cap
        px.DrawDisc(14, 16, 3, 0xEE55AA);
        px.DrawDisc(30, 14, 2, 0xEE55AA);
        px.DrawDisc(22, 20, 2, 0xEE55AA);
        // Outline
        px.DrawEllipseFrame(24, 18, 22, 14, pal.outline);
        return px;
    }

    hide func buildCaveCrystalTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Translucent crystal platform
        px.DrawBox(0, 8, 48, 36, pal.cavernStone);
        // Crystal surface (angular facets)
        px.DrawTriangle(0, 8, 24, 0, 48, 8, pal.crystalCyan);
        px.DrawTriangle(24, 0, 48, 8, 36, 4, 0x33BBDD);    // darker facet
        // Inner refraction lines
        px.DrawLine(12, 6, 20, 16, 0x88EEFF);
        px.DrawLine(28, 4, 36, 14, 0x88EEFF);
        // Glow underneath
        px.DrawEllipse(24, 20, 16, 4, pal.crystalGlow);
        // Stone base
        px.DrawLine(0, 44, 47, 44, pal.outline);
        return px;
    }

    hide func buildMetalGrateTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Industrial metal grating over lava
        px.DrawBox(0, 0, 48, 48, pal.thermalGrate);
        // Grid pattern
        var i = 0;
        while i < 48 {
            px.DrawLine(i, 0, i, 47, 0x556677);
            px.DrawLine(0, i, 47, i, 0x556677);
            i = i + 8;
        }
        // Rust stains
        px.DrawEllipse(12, 20, 4, 3, pal.thermalRust);
        px.DrawEllipse(36, 36, 3, 2, pal.thermalRust);
        // Highlight top edge
        px.DrawLine(0, 0, 47, 0, 0x8899AA);
        // Lava visible through grate (warm glow underneath)
        px.DrawEllipse(24, 36, 12, 6, 0x442211);
        return px;
    }

    hide func buildMagmaRockTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Dark rock with glowing magma vein cracks
        px.DrawBox(0, 0, 48, 48, pal.thermalRock);
        // Magma veins (glowing cracks)
        px.DrawBezier(4, 12, 20, 20, 44, 8, pal.thermalCrack);
        px.DrawBezier(8, 36, 28, 42, 40, 32, pal.thermalCrack);
        px.DrawLine(24, 0, 20, 24, pal.thermalCrack);
        // Vein glow (wider, dimmer)
        px.DrawBezier(4, 13, 20, 21, 44, 9, 0x882211);
        // Rock texture
        px.DrawEllipse(16, 24, 6, 4, 0x3A2A2A);
        px.DrawEllipse(38, 16, 4, 3, 0x3A2A2A);
        // Outline
        px.DrawLine(0, 0, 47, 0, pal.outline);
        return px;
    }

    // =========================================================================
    // Level 2: Station Tile Sprites
    // =========================================================================

    hide func buildStationTileSprites() {
        tileHullPlate = scaleTile(buildHullPlateTile());
        tileGirder = scaleTile(buildGirderTile());
        tileElectric = scaleTile(buildElectricTile());
        tileAirlock = scaleTile(buildAirlockTile());
        tilePipe = scaleTile(buildPipeTile());
        tileCatwalk = scaleTile(buildCatwalkTile());
        tileCoolant1 = scaleTile(buildCoolantTile(0));
        tileCoolant2 = scaleTile(buildCoolantTile(1));
        tileConduit = scaleTile(buildConduitTile());
        tileConsole = scaleTile(buildConsoleTile());
        tileHoloBridge = scaleTile(buildHoloBridgeTile());
        tileViewport = scaleTile(buildViewportTile());
    }

    hide func buildHullPlateTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.hullPlate);
        // Panel seam lines
        px.DrawLine(0, 23, 47, 23, pal.hullPlateDk);
        px.DrawLine(23, 0, 23, 47, pal.hullPlateDk);
        // Bevel highlights
        px.DrawLine(1, 1, 22, 1, pal.hullPlateLt);
        px.DrawLine(24, 25, 47, 25, pal.hullPlateLt);
        // Rivet dots
        px.DrawDisc(6, 6, 1, pal.hullPlateLt);
        px.DrawDisc(42, 6, 1, pal.hullPlateLt);
        px.DrawDisc(6, 42, 1, pal.hullPlateLt);
        px.DrawDisc(42, 42, 1, pal.hullPlateLt);
        // Scratches
        px.DrawLine(10, 14, 18, 16, pal.hullPlateDk);
        px.DrawLine(30, 32, 40, 30, pal.hullPlateDk);
        return px;
    }

    hide func buildGirderTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // I-beam cross section
        px.DrawBox(0, 0, 48, 6, pal.girder);             // top flange
        px.DrawBox(0, 42, 48, 6, pal.girder);             // bottom flange
        px.DrawBox(20, 6, 8, 36, pal.girder);             // web
        // Highlights
        px.DrawLine(0, 0, 47, 0, pal.girderLt);
        px.DrawLine(20, 6, 20, 42, pal.girderLt);
        // Cross bracing
        px.DrawLine(0, 6, 20, 24, pal.girderLt);
        px.DrawLine(28, 24, 47, 42, pal.girderLt);
        // Outline
        px.DrawLine(0, 0, 47, 0, pal.outline);
        px.DrawLine(0, 47, 47, 47, pal.outline);
        return px;
    }

    hide func buildElectricTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.electricBg);
        // Lightning bolt lines
        px.DrawLine(12, 8, 20, 20, pal.electricSpark);
        px.DrawLine(20, 20, 14, 28, pal.electricSpark);
        px.DrawLine(14, 28, 24, 42, pal.electricSpark);
        px.DrawLine(30, 6, 36, 16, pal.electricSpark);
        px.DrawLine(36, 16, 32, 24, pal.electricSpark);
        // Spark glow
        px.DrawDisc(20, 20, 3, pal.electricSpark);
        px.DrawDisc(14, 28, 2, pal.electricSpark);
        // Warning border
        px.DrawLine(0, 0, 47, 0, pal.airlockStripe);
        px.DrawLine(0, 47, 47, 47, pal.airlockStripe);
        return px;
    }

    hide func buildAirlockTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.airlock);
        // Hazard stripes (diagonal yellow/black)
        var i = 0;
        while i < 48 {
            px.DrawLine(i, 0, i + 8, 8, pal.airlockStripe);
            px.DrawLine(i, 40, i + 8, 48, pal.airlockStripe);
            i = i + 12;
        }
        // Heavy frame lines
        px.DrawBox(0, 0, 48, 3, pal.hullPlateDk);
        px.DrawBox(0, 45, 48, 3, pal.hullPlateDk);
        px.DrawBox(0, 0, 3, 48, pal.hullPlateDk);
        px.DrawBox(45, 0, 3, 48, pal.hullPlateDk);
        // Center lock mechanism
        px.DrawDisc(24, 24, 6, pal.hullPlateDk);
        px.DrawDisc(24, 24, 4, pal.hullPlate);
        px.DrawDisc(24, 24, 1, pal.outline);
        return px;
    }

    hide func buildPipeTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Cylindrical pipe — gradient effect via layered ellipses
        px.DrawBox(0, 12, 48, 24, pal.pipe);
        px.DrawBox(0, 14, 48, 8, pal.pipeLt);               // top highlight
        px.DrawBox(0, 28, 48, 6, pal.outline);               // bottom shadow
        // Pipe joints
        px.DrawBox(10, 10, 4, 28, pal.pipeLt);
        px.DrawBox(34, 10, 4, 28, pal.pipeLt);
        // Valve wheel
        px.DrawDisc(24, 24, 5, pal.pipeLt);
        px.DrawDisc(24, 24, 3, pal.pipe);
        px.DrawLine(20, 24, 28, 24, pal.outline);
        px.DrawLine(24, 20, 24, 28, pal.outline);
        return px;
    }

    hide func buildCatwalkTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.catwalk);
        // Grid pattern
        var i = 0;
        while i < 48 {
            px.DrawLine(i, 0, i, 47, pal.hullPlateDk);
            px.DrawLine(0, i, 47, i, pal.hullPlateDk);
            i = i + 8;
        }
        // Red emergency strip along top
        px.DrawBox(0, 0, 48, 3, pal.catwalkStripe);
        // Highlight
        px.DrawLine(0, 3, 47, 3, pal.hullPlateLt);
        return px;
    }

    hide func buildCoolantTile(frame: Integer) -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.coolant);
        // Bubbles (animated positions)
        if frame == 0 {
            px.DrawDisc(12, 14, 4, pal.coolantBright);
            px.DrawDisc(34, 28, 3, pal.coolantBright);
            px.DrawDisc(22, 38, 5, pal.coolantBright);
        } else {
            px.DrawDisc(26, 10, 3, pal.coolantBright);
            px.DrawDisc(8, 30, 4, pal.coolantBright);
            px.DrawDisc(38, 40, 3, pal.coolantBright);
        }
        // Surface glow
        px.DrawEllipse(24, 4, 20, 4, pal.coolantBright);
        // Toxic veins
        px.DrawBezier(0, 22, 24, 16, 47, 24, pal.coolantBright);
        return px;
    }

    hide func buildConduitTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.conduit);
        // Cable bundles (colored lines running through)
        px.DrawThickLine(4, 0, 4, 47, 3, pal.electricSpark);    // blue cable
        px.DrawThickLine(14, 0, 14, 47, 2, pal.catwalkStripe);  // red cable
        px.DrawThickLine(24, 0, 24, 47, 3, pal.coolant);        // green cable
        px.DrawThickLine(34, 0, 34, 47, 2, pal.airlockStripe);  // yellow cable
        px.DrawThickLine(44, 0, 44, 47, 2, pal.hullPlateLt);    // white cable
        // Cable clamps
        px.DrawBox(0, 10, 48, 3, pal.outline);
        px.DrawBox(0, 34, 48, 3, pal.outline);
        return px;
    }

    hide func buildConsoleTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, 48, 48, pal.console);
        // Screen (bright blue rectangle)
        px.DrawBox(4, 4, 40, 24, pal.consoleScreen);
        px.DrawBox(6, 6, 36, 20, pal.holo);
        // Screen scan line
        px.DrawLine(6, 14, 42, 14, pal.holoLt);
        // Button row
        px.DrawDisc(10, 36, 2, pal.catwalkStripe);     // red button
        px.DrawDisc(18, 36, 2, pal.coolant);            // green button
        px.DrawDisc(26, 36, 2, pal.electricSpark);      // blue button
        px.DrawDisc(34, 36, 2, pal.airlockStripe);      // yellow button
        // LED indicator
        px.DrawDisc(42, 36, 1, pal.coolantBright);
        // Frame
        px.DrawLine(0, 0, 47, 0, pal.outline);
        px.DrawLine(0, 47, 47, 47, pal.outline);
        return px;
    }

    hide func buildHoloBridgeTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Translucent blue platform
        px.DrawBox(0, 0, 48, 48, pal.holo);
        // Scan lines for holographic effect
        var i = 0;
        while i < 48 {
            px.DrawLine(0, i, 47, i, pal.holoLt);
            i = i + 4;
        }
        // Edge glow
        px.DrawBox(0, 0, 48, 2, pal.holoLt);
        px.DrawBox(0, 46, 48, 2, pal.holoLt);
        // Center data pattern
        px.DrawDisc(24, 24, 6, pal.holoLt);
        px.DrawDisc(24, 24, 3, pal.holo);
        return px;
    }

    hide func buildViewportTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        // Dark space background
        px.DrawBox(0, 0, 48, 48, pal.viewportBg);
        // Stars visible through viewport
        px.DrawDisc(8, 12, 1, pal.white);
        px.DrawDisc(20, 6, 1, pal.emergencyLight);
        px.DrawDisc(36, 18, 1, pal.white);
        px.DrawDisc(14, 32, 1, pal.white);
        px.DrawDisc(40, 38, 1, pal.emergencyLight);
        px.DrawDisc(28, 42, 1, pal.white);
        // Viewport frame
        px.DrawBox(0, 0, 48, 3, pal.hullPlateDk);
        px.DrawBox(0, 45, 48, 3, pal.hullPlateDk);
        px.DrawBox(0, 0, 3, 48, pal.hullPlateDk);
        px.DrawBox(45, 0, 3, 48, pal.hullPlateDk);
        return px;
    }

    hide func buildMissingTile() -> Pixels {
        var px = Pixels.New(ORIG_TILE, ORIG_TILE);
        px.DrawBox(0, 0, ORIG_TILE, ORIG_TILE, Color.RGB(255, 0, 255));
        px.DrawBox(4, 4, ORIG_TILE - 8, ORIG_TILE - 8, Color.RGB(30, 0, 30));
        px.DrawLine(0, 0, ORIG_TILE - 1, ORIG_TILE - 1, Color.RGB(255, 255, 255));
        px.DrawLine(ORIG_TILE - 1, 0, 0, ORIG_TILE - 1, Color.RGB(255, 255, 255));
        return px;
    }

    // =========================================================================
    // Tile Lookup (replaces if-chain in getTile)
    // =========================================================================

    hide func buildTileLookup() {
        tileIds = [];
        tileSpriteList = [];

        // Register all tiles: id → sprite mapping
        // Level 1 tiles
        registerTile(TILE_GRASS_TOP, tileGrassTop);
        registerTile(TILE_GROUND, tileDirt);
        registerTile(TILE_DIRT, tileDirt);
        registerTile(TILE_STONE, tileStone);
        registerTile(TILE_BRICK, tileBrick);
        registerTile(TILE_PLATFORM, tilePlatform);
        registerTile(TILE_CRYSTAL, tileCrystal);
        registerTile(TILE_CAVE_TOP, tileCaveTop);
        registerTile(TILE_CAVE_WALL, tileCaveWall);
        registerTile(TILE_BRIDGE, tileBridge);
        registerTile(TILE_SPIKE, tileSpike);
        registerTile(TILE_CHECKPOINT, tileCheckpoint);
        registerTile(TILE_MAGMA, tileMagma);
        registerTile(TILE_OBSIDIAN, tileObsidian);
        registerTile(TILE_CLOUD, tileCloud);
        registerTile(TILE_SKY_BRICK, tileSkyBrick);
        registerTile(TILE_RUIN_STONE, tileRuinStone);
        registerTile(TILE_VINE, tileVine);
        registerTile(TILE_MOSS_STONE, tileMossStone);
        // Xenoscape biome tiles
        registerTile(TILE_JUNGLE_GROUND, tileJungleGround);
        registerTile(TILE_JUNGLE_PLATFORM, tileJunglePlatform);
        registerTile(TILE_THORN, tileThorn);
        registerTile(TILE_MUSHROOM, tileMushroom);
        registerTile(TILE_CAVE_CRYSTAL, tileCaveCrystal);
        registerTile(TILE_METAL_GRATE, tileMetalGrate);
        registerTile(TILE_MAGMA_ROCK, tileMagmaRock);
        // Level 2: Station tiles
        registerTile(TILE_HULL_PLATE, tileHullPlate);
        registerTile(TILE_GIRDER, tileGirder);
        registerTile(TILE_ELECTRIC, tileElectric);
        registerTile(TILE_AIRLOCK, tileAirlock);
        registerTile(TILE_PIPE, tilePipe);
        registerTile(TILE_CATWALK, tileCatwalk);
        registerTile(TILE_COOLANT, tileCoolant1);
        registerTile(TILE_CONDUIT, tileConduit);
        registerTile(TILE_CONSOLE, tileConsole);
        registerTile(TILE_HOLO_BRIDGE, tileHoloBridge);
        registerTile(TILE_VIEWPORT, tileViewport);
        // Environmental and interaction tiles
        registerTile(TILE_POISON_POOL, tilePoisonPool1);
        registerTile(TILE_QUICKSAND, tileQuicksand);
        registerTile(TILE_CRUMBLE, tileCrumble);
        registerTile(TILE_ICE_FLOOR, tileIceFloor);
        registerTile(TILE_CONVEYOR_L, tileConveyorL);
        registerTile(TILE_CONVEYOR_R, tileConveyorR);
        registerTile(TILE_STEAM_VENT, tileSteamVent);
        registerTile(TILE_DESTRUCTIBLE, tileDestructible);
        registerTile(TILE_ONE_WAY, tileOneWay);
        registerTile(TILE_SAVE_STATION, tileSaveStation);
        registerTile(TILE_LORE_TERMINAL, tileLoreTerminal);
    }

    hide func registerTile(id: Integer, sprite: Pixels) {
        tileIds.add(id);
        tileSpriteList.add(sprite);
    }

    // =========================================================================
    // Pickup Sprites
    // =========================================================================

    hide func buildPickupSprites() {
        // Coins: draw at ORIG_COIN_SIZE (24), scale to COIN_SIZE (36)
        for i in 0..4 {
            coinFrames.add(buildCoinFrame(i).Scale(COIN_SIZE, COIN_SIZE));
        }

        // Power-ups: draw at ORIG_POWERUP_SIZE (30), scale to POWERUP_SIZE (42)
        healthOrb = buildHealthOrb().Scale(POWERUP_SIZE, POWERUP_SIZE);
        speedPickup = buildPowerupIcon(pal.speed).Scale(POWERUP_SIZE, POWERUP_SIZE);
        shieldPickup = buildPowerupIcon(pal.shield).Scale(POWERUP_SIZE, POWERUP_SIZE);
        rapidPickup = buildPowerupIcon(pal.rapidfire).Scale(POWERUP_SIZE, POWERUP_SIZE);
    }

    hide func buildCoinFrame(frame: Integer) -> Pixels {
        var px = Pixels.New(ORIG_COIN_SIZE, ORIG_COIN_SIZE);
        // Coin rotation using ellipse with varying x-radius
        var rx = 9;
        if frame == 1 {
            rx = 6;
        }
        if frame == 2 {
            rx = 3;
        }
        if frame == 3 {
            rx = 6;
        }
        // Outer coin body
        px.DrawEllipse(12, 12, rx, 9, pal.coinGold);
        // Dark edge ring
        if rx > 3 {
            px.DrawEllipseFrame(12, 12, rx, 9, pal.coinDark);
        }
        // Shine highlight
        if rx > 5 {
            px.DrawDisc(10, 9, 2, 0xFFEE88);
        }
        return px;
    }

    hide func buildHealthOrb() -> Pixels {
        var px = Pixels.New(ORIG_POWERUP_SIZE, ORIG_POWERUP_SIZE);
        // Outer glow
        px.DrawDisc(15, 15, 13, 0xCC2233);
        // Main orb
        px.DrawDisc(15, 15, 11, pal.health);
        px.DrawDisc(15, 15, 8, 0xFF6677);
        // Cross
        px.DrawBox(12, 8, 6, 14, pal.white);
        px.DrawBox(8, 12, 14, 6, pal.white);
        // Highlight
        px.DrawDisc(12, 11, 2, 0xFFAAAA);
        return px;
    }

    hide func buildPowerupIcon(col: Integer) -> Pixels {
        var px = Pixels.New(ORIG_POWERUP_SIZE, ORIG_POWERUP_SIZE);
        // Background disc
        px.DrawDisc(15, 15, 12, col);
        px.DrawDisc(15, 15, 9, 0xFFFFFF);
        // Arrow using triangle (pointing up)
        px.DrawTriangle(8, 18, 22, 18, 15, 6, col);
        // Arrow shaft
        px.DrawBox(12, 16, 6, 8, col);
        return px;
    }

    // =========================================================================
    // Bullet Sprites
    // =========================================================================

    hide func buildBulletSprites() {
        // Player bullet — draw at 12x6 (old size), scale to BULLET_W x BULLET_H
        var bSrc = Pixels.New(12, 6);
        bSrc.DrawEllipse(6, 3, 6, 3, pal.bullet);
        bSrc.DrawEllipse(7, 3, 4, 2, pal.bulletGlow);
        bSrc.DrawDisc(10, 3, 2, 0xAAEEFF);
        bulletRight = bSrc.Scale(BULLET_W, BULLET_H);
        bulletLeft = bulletRight.Clone();
        bulletLeft.FlipH();

        // Enemy bullet — draw at 9x9, scale to 14x14
        var eSrc = Pixels.New(9, 9);
        eSrc.DrawDisc(5, 5, 5, pal.enemyBullet);
        eSrc.DrawRing(5, 5, 4, 0xFF6666);
        eSrc.DrawDisc(5, 5, 2, 0xFF8888);
        enemyBullet = eSrc.Scale(14, 14);
    }

    // =========================================================================
    // Background Elements
    // =========================================================================

    hide func buildBackgroundElements() {
        cloud1 = buildCloud(90, 30);
        cloud2 = buildCloud(60, 24);
        treeBg = buildTreeBg();
        mountainBg = buildMountainBg();
    }

    hide func buildCloud(w: Integer, h: Integer) -> Pixels {
        var px = Pixels.New(w, h);
        var col = 0xFFFFFF;
        // Main body
        px.DrawBox(6, h / 2, w - 12, h / 2, col);
        // Puffs (overlapping discs)
        px.DrawDisc(w / 4, h / 2, h / 3, col);
        px.DrawDisc(w / 2, h / 3, h / 2, col);
        px.DrawDisc(w * 3 / 4, h / 2, h / 3, col);
        // Soft edges via blur
        var blurred = px.Blur(2);
        return blurred;
    }

    hide func buildTreeBg() -> Pixels {
        var px = Pixels.New(48, 72);
        // Trunk
        px.DrawBox(18, 42, 12, 30, 0x3A2808);
        px.DrawBox(21, 45, 6, 27, 0x2A1A06);
        // Canopy (dark silhouette greens — overlapping discs)
        px.DrawDisc(24, 21, 21, 0x143A16);
        px.DrawDisc(15, 27, 15, 0x1A4A1E);
        px.DrawDisc(33, 27, 15, 0x1A4A1E);
        px.DrawDisc(24, 15, 15, 0x205A24);
        // Canopy highlights
        px.DrawDisc(18, 14, 6, 0x2A6A2E);
        px.DrawDisc(30, 18, 5, 0x286828);
        return px;
    }

    hide func buildMountainBg() -> Pixels {
        var px = Pixels.New(180, 120);
        // Mountain shape using triangles
        px.DrawTriangle(0, 119, 90, 0, 180, 119, 0x2A3366);
        // Shaded right face
        px.DrawTriangle(90, 0, 180, 119, 135, 60, 0x1E2548);
        // Snow cap
        px.DrawTriangle(78, 18, 90, 0, 102, 18, 0xCCCCDD);
        px.DrawTriangle(82, 24, 90, 0, 98, 24, 0xDDDDEE);
        // Atmospheric haze via blur
        var blurred = px.Blur(1);
        return blurred;
    }

    // =========================================================================
    // Public accessors
    // =========================================================================

    expose func getPlayerFrame(facing: Integer, frameIdx: Integer) -> Pixels {
        if facing >= 0 {
            if frameIdx >= 0 {
                if frameIdx < playerRight.length() {
                    return playerRight.get(frameIdx);
                }
            }
            return playerRight.get(0);
        }
        if frameIdx >= 0 {
            if frameIdx < playerLeft.length() {
                return playerLeft.get(frameIdx);
            }
        }
        return playerLeft.get(0);
    }

    expose func getSlimeFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < slimeFrames.length() {
                return slimeFrames.get(frame);
            }
        }
        return slimeFrames.get(0);
    }

    expose func getBatFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < batFrames.length() {
                return batFrames.get(frame);
            }
        }
        return batFrames.get(0);
    }

    expose func getTurretBase() -> Pixels {
        return turretBase;
    }

    expose func getTurretBarrel() -> Pixels {
        return turretBarrel;
    }

    expose func getBossFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < bossFrames.length() {
                return bossFrames.get(frame);
            }
        }
        return bossFrames.get(0);
    }

    // List-based tile lookup: O(n) scan but zero code changes when adding tiles.
    // New tiles just need a registerTile() call in buildTileLookup().
    expose func getTile(id: Integer) -> Pixels {
        var i = 0;
        while i < tileIds.length() {
            if tileIds.get(i) == id {
                return tileSpriteList.get(i);
            }
            i = i + 1;
        }
        return tileMissing;  // fallback
    }

    expose func getLavaTile(frame: Integer) -> Pixels {
        if frame == 0 {
            return tileLava1;
        }
        return tileLava2;
    }

    expose func getCoinFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < coinFrames.length() {
                return coinFrames.get(frame);
            }
        }
        return coinFrames.get(0);
    }

    expose func getHealthOrb() -> Pixels { return healthOrb; }
    expose func getSpeedPickup() -> Pixels { return speedPickup; }
    expose func getShieldPickup() -> Pixels { return shieldPickup; }
    expose func getRapidPickup() -> Pixels { return rapidPickup; }

    expose func getBullet(facing: Integer) -> Pixels {
        if facing >= 0 { return bulletRight; }
        return bulletLeft;
    }

    expose func getEnemyBullet() -> Pixels { return enemyBullet; }

    expose func getCloud1() -> Pixels { return cloud1; }
    expose func getCloud2() -> Pixels { return cloud2; }
    expose func getTreeBg() -> Pixels { return treeBg; }
    expose func getMountainBg() -> Pixels { return mountainBg; }

    // =========================================================================
    // New Enemy Sprite Builders — Procedural generation for all new types
    // =========================================================================
    // Each enemy gets a distinct visual identity using the multi-layer technique:
    //   base fill → shadow/depth → surface detail → highlights → glow elements

    expose func buildNewEnemySprites() {
        if newSpritesBuilt { return; }
        newSpritesBuilt = true;

        buildSporewalkerSprites();
        buildGlowmothSprites();
        buildFungalTurretSprites();
        buildMyceliumSprites();
        buildCrystalGolemSprites();
        buildShardBatSprites();
        buildResonanceOrbSprites();
        buildMirrorSlimeSprites();
        buildMagmaSlugSprites();
        buildEmberWaspSprites();
        buildForgeSentinelSprites();
        buildFrostBeetleSprites();
        buildIceWraithSprites();
        buildStalactiteBatSprites();
        buildVineWhipSprite();
        buildMossGolemSprites();
        buildRuinGuardianSprites();
        buildShadowCloneSprites();
        buildCorruptionSprite();
        buildBossSprites2();
        buildBombCarrierSprites();
    }

    // ─── Sporewalker: mushroom-headed walker ──────────────────────────
    hide func buildSporewalkerSprites() {
        sporewalkerFrames = [];
        var f = 0;
        while f < 4 {
            var pix = Pixels.New(24, 30);
            // Body: dark brown mushroom stalk
            Pixels.DrawBox(pix, 8, 14, 8, 16, pal.jungleRoots);
            Pixels.DrawBox(pix, 6, 16, 12, 12, Color.Darken(pal.jungleRoots, 10));
            // Legs: alternating stance per frame
            var legOff = 0; if f % 2 == 1 { legOff = 2; }
            Pixels.DrawBox(pix, 6, 28 - legOff, 4, 4, pal.jungleRoots);
            Pixels.DrawBox(pix, 14, 26 + legOff, 4, 4, pal.jungleRoots);
            // Cap: bulbous mushroom top
            Pixels.DrawEllipse(pix, 12, 10, 12, 10, Color.RGB(140, 80, 160));
            Pixels.DrawEllipse(pix, 12, 8, 10, 8, Color.Brighten(Color.RGB(140, 80, 160), 15));
            // Spore dots on cap
            Pixels.DrawDisc(pix, 6, 7, 2, Color.Brighten(Color.RGB(140, 80, 160), 30));
            Pixels.DrawDisc(pix, 16, 9, 2, Color.Brighten(Color.RGB(140, 80, 160), 25));
            Pixels.DrawDisc(pix, 11, 4, 1, Color.Brighten(Color.RGB(140, 80, 160), 40));
            // Eyes: small yellow dots
            Pixels.DrawDisc(pix, 9, 12, 1, pal.slimeEye);
            Pixels.DrawDisc(pix, 15, 12, 1, pal.slimeEye);
            // Highlight on cap
            Pixels.Set(pix, 8, 3, Color.RGB(255, 220, 200));
            // Scale to display size
            sporewalkerFrames.add(Pixels.Scale(pix, SPOREWALKER_W, SPOREWALKER_H));
            f = f + 1;
        }
    }

    // ─── Glowmoth: luminous flying insect ─────────────────────────────
    hide func buildGlowmothSprites() {
        glowmothFrames = [];
        var f = 0;
        while f < 3 {
            var pix = Pixels.New(27, 21);
            // Wings: translucent with glow
            var wingSpread = 10 + f * 2; // Flap animation
            Pixels.DrawEllipse(pix, 7, 10, wingSpread, 8, Color.RGB(180, 255, 120));
            Pixels.DrawEllipse(pix, 20, 10, wingSpread, 8, Color.RGB(180, 255, 120));
            // Wing veins
            Pixels.DrawLine(pix, 7, 10, 2, 5, Color.RGB(100, 180, 60));
            Pixels.DrawLine(pix, 20, 10, 25, 5, Color.RGB(100, 180, 60));
            // Body: compact oval
            Pixels.DrawEllipse(pix, 13, 10, 5, 4, Color.RGB(100, 200, 50));
            // Head
            Pixels.DrawDisc(pix, 13, 6, 3, Color.RGB(120, 220, 70));
            // Eyes: bright
            Pixels.Set(pix, 11, 5, Color.RGB(255, 255, 200));
            Pixels.Set(pix, 15, 5, Color.RGB(255, 255, 200));
            // Glow aura (center)
            Pixels.DrawDisc(pix, 13, 10, 2, Color.RGB(220, 255, 150));
            glowmothFrames.add(Pixels.Scale(pix, GLOWMOTH_W, GLOWMOTH_H));
            f = f + 1;
        }
    }

    // ─── Fungal Turret: mushroom with spore cannon ────────────────────
    hide func buildFungalTurretSprites() {
        fungalTurretFrames = [];
        var f = 0;
        while f < 2 {
            var pix = Pixels.New(36, 42);
            // Base stalk
            Pixels.DrawBox(pix, 12, 24, 12, 18, Color.RGB(80, 60, 50));
            Pixels.DrawBox(pix, 10, 30, 16, 12, Color.RGB(70, 50, 40));
            // Cap: large mushroom
            Pixels.DrawEllipse(pix, 18, 16, 18, 12, Color.RGB(140, 80, 160));
            Pixels.DrawEllipse(pix, 18, 14, 16, 10, Color.RGB(160, 100, 180));
            // Cap spots
            Pixels.DrawDisc(pix, 10, 12, 3, Color.RGB(180, 130, 200));
            Pixels.DrawDisc(pix, 24, 14, 2, Color.RGB(180, 130, 200));
            // Cannon opening (visible when frame == 1)
            if f == 1 {
                Pixels.DrawDisc(pix, 18, 8, 4, Color.RGB(200, 255, 100));
                Pixels.DrawDisc(pix, 18, 8, 2, Color.RGB(255, 255, 200));
            }
            // Eyes
            Pixels.DrawDisc(pix, 13, 18, 2, Color.RGB(255, 200, 50));
            Pixels.DrawDisc(pix, 23, 18, 2, Color.RGB(255, 200, 50));
            fungalTurretFrames.add(Pixels.Scale(pix, FUNGAL_TURRET_W, FUNGAL_TURRET_H));
            f = f + 1;
        }
    }

    hide func buildMyceliumSprites() {
        myceliumFrames = [];
        var f = 0;
        while f < 3 {
            var pix = Pixels.New(24, 16);
