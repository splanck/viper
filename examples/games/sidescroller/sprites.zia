    // =========================================================================
    // Enhanced sprite rendering helpers — rim lighting, shadows, glow
    // =========================================================================
    // These helper functions add visual depth to sprites when drawn.
    // Called from the renderer for per-frame effects.

    // Draw a sprite with a colored rim light effect (highlight edge)
    expose func drawWithRimLight(canvas: Canvas, spr: Pixels, sx: Integer, sy: Integer,
                                  lightColor: Integer, lightSide: Integer) {
        // Draw the sprite normally
        canvas.BlitAlpha(sx, sy, spr);
        // Add a 1px bright edge on the light-facing side
        var w = spr.get_Width();
        var h = spr.get_Height();
        if lightSide > 0 {
            // Light from right: bright right edge
            canvas.BoxAlpha(sx + w - 1, sy + 2, 1, h - 4, lightColor, 60);
            canvas.BoxAlpha(sx + w - 2, sy + 1, 1, h - 2, lightColor, 30);
        } else {
            // Light from left: bright left edge
            canvas.BoxAlpha(sx, sy + 2, 1, h - 4, lightColor, 60);
            canvas.BoxAlpha(sx + 1, sy + 1, 1, h - 2, lightColor, 30);
        }
    }

    // Draw a sprite with a drop shadow beneath it
    expose func drawWithShadow(canvas: Canvas, spr: Pixels, sx: Integer, sy: Integer,
                                groundY: Integer) {
        // Shadow: dark ellipse on the ground
        var w = spr.get_Width();
        var shadowW = w * 3 / 4;
        var shadowH = 6;
        var shadowX = sx + w / 2 - shadowW / 2;
        canvas.EllipseAlpha(shadowX + shadowW / 2, groundY + 2, shadowW / 2, shadowH / 2,
                            Color.RGB(0, 0, 0), 40);
        // Draw sprite
        canvas.BlitAlpha(sx, sy, spr);
    }

    // Draw a sprite with a pulsing glow aura (for power-ups, bosses)
    expose func drawWithGlow(canvas: Canvas, spr: Pixels, sx: Integer, sy: Integer,
                              glowColor: Integer, timer: Integer) {
        var w = spr.get_Width();
        var h = spr.get_Height();
        var cx = sx + w / 2;
        var cy = sy + h / 2;
        // Pulsing glow
        var pulse = (timer % 30) * 2;
        var r = w / 2 + 4 + pulse / 10;
        canvas.DiscAlpha(cx, cy, r, glowColor, 30);
        canvas.DiscAlpha(cx, cy, r - 4, glowColor, 20);
        // Draw sprite on top
        canvas.BlitAlpha(sx, sy, spr);
    }

    // Draw a sprite with a damage crack overlay (based on HP percentage)
    expose func drawWithDamage(canvas: Canvas, spr: Pixels, sx: Integer, sy: Integer,
                                hpPercent: Integer) {
        canvas.BlitAlpha(sx, sy, spr);
        var w = spr.get_Width();
        var h = spr.get_Height();
        if hpPercent < 75 {
            // Light damage: subtle crack
            canvas.Line(sx + w / 4, sy + h / 4, sx + w * 3 / 4, sy + h / 2,
                       Color.RGB(60, 60, 60));
        }
        if hpPercent < 50 {
            // Medium damage: more cracks
            canvas.Line(sx + w / 2, sy + 2, sx + w / 3, sy + h - 2,
                       Color.RGB(50, 50, 50));
            canvas.Line(sx + w * 2 / 3, sy + h / 3, sx + w - 4, sy + h * 2 / 3,
                       Color.RGB(50, 50, 50));
        }
        if hpPercent < 25 {
            // Heavy damage: red tint overlay
            canvas.BoxAlpha(sx, sy, w, h, Color.RGB(200, 30, 30), 30);
        }
    }

    // Draw a sprite as a silhouette (for shadows, afterimages)
    expose func drawSilhouette(canvas: Canvas, spr: Pixels, sx: Integer, sy: Integer,
                                color: Integer, alpha: Integer) {
        // We approximate a silhouette by drawing the sprite then overlaying a color box
        // at the same position with matching alpha
        canvas.BlitAlpha(sx, sy, spr);
        var w = spr.get_Width();
        var h = spr.get_Height();
        canvas.BoxAlpha(sx, sy, w, h, color, alpha);
    }

    // =========================================================================
    // Procedural effect sprites — reusable visual elements
    // =========================================================================

    // Generate a poison cloud particle sprite
    expose func buildPoisonCloudSprite(size: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;
        // Layered circles for cloud effect
        Pixels.DrawDisc(pix, cx, cy, size / 2 - 2, Color.RGB(60, 140, 40));
        Pixels.DrawDisc(pix, cx - size / 6, cy - size / 6, size / 3, Color.RGB(80, 180, 50));
        Pixels.DrawDisc(pix, cx + size / 6, cy + size / 6, size / 4, Color.RGB(70, 160, 45));
        // Bright spore dots
        Pixels.Set(pix, cx - 2, cy - 2, Color.RGB(200, 255, 100));
        Pixels.Set(pix, cx + 3, cy, Color.RGB(180, 240, 80));
        Pixels.Set(pix, cx - 1, cy + 3, Color.RGB(190, 250, 90));
        return pix;
    }

    // Generate an ice crystal particle sprite
    expose func buildIceCrystalSprite(size: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;
        // Six-pointed star shape
        Pixels.DrawLine(pix, cx, 0, cx, size - 1, Color.RGB(180, 220, 255));
        Pixels.DrawLine(pix, 0, cy, size - 1, cy, Color.RGB(180, 220, 255));
        Pixels.DrawLine(pix, 2, 2, size - 3, size - 3, Color.RGB(160, 200, 240));
        Pixels.DrawLine(pix, size - 3, 2, 2, size - 3, Color.RGB(160, 200, 240));
        // Center bright
        Pixels.DrawDisc(pix, cx, cy, 2, Color.RGB(255, 255, 255));
        return pix;
    }

    // Generate a lava droplet sprite
    expose func buildLavaDropSprite(size: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        // Teardrop shape
        Pixels.DrawDisc(pix, cx, cx + 2, size / 2 - 1, Color.RGB(255, 120, 20));
        Pixels.DrawTriangle(pix, cx, 0, cx - size / 3, cx, cx + size / 3, cx,
                           Color.RGB(255, 150, 30));
        // Bright core
        Pixels.DrawDisc(pix, cx, cx + 1, size / 4, Color.RGB(255, 220, 80));
        return pix;
    }

    // Generate a corruption wisp sprite
    expose func buildCorruptionWispSprite(size: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;
        // Amorphous dark shape
        Pixels.DrawDisc(pix, cx, cy, size / 2 - 1, Color.RGB(60, 20, 80));
        Pixels.DrawDisc(pix, cx - 2, cy - 1, size / 3, Color.RGB(80, 30, 110));
        // Glowing eye
        Pixels.Set(pix, cx, cy - 1, Color.RGB(200, 50, 255));
        Pixels.Set(pix, cx + 1, cy - 1, Color.RGB(200, 50, 255));
        // Tendrils
        Pixels.DrawLine(pix, cx - size / 3, cy + 2, cx - size / 2 + 1, cy + size / 3,
                        Color.RGB(50, 15, 70));
        Pixels.DrawLine(pix, cx + size / 3, cy + 2, cx + size / 2 - 1, cy + size / 3,
                        Color.RGB(50, 15, 70));
        return pix;
    }

    // Generate a shield bubble sprite
    expose func buildShieldBubbleSprite(size: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;
        var r = size / 2 - 2;
        // Translucent ring
        Pixels.DrawRing(pix, cx, cy, r, Color.RGB(80, 200, 255));
        Pixels.DrawRing(pix, cx, cy, r - 1, Color.RGB(100, 220, 255));
        // Highlight arc
        Pixels.DrawLine(pix, cx - r / 2, cy - r * 3 / 4,
                        cx + r / 4, cy - r * 3 / 4 + 2,
                        Color.RGB(200, 255, 255));
        return pix;
    }

    // Generate an explosion ring sprite
    expose func buildExplosionRingSprite(size: Integer, frame: Integer) -> Pixels {
        var pix = Pixels.New(size, size);
        var cx = size / 2;
        var cy = size / 2;
        var r = (frame + 1) * size / 8;
        if r > size / 2 - 2 { r = size / 2 - 2; }
        // Expanding ring
        Pixels.DrawRing(pix, cx, cy, r, Color.RGB(255, 200, 50));
        if r > 3 {
            Pixels.DrawRing(pix, cx, cy, r - 2, Color.RGB(255, 150, 30));
        }
        // Bright center on early frames
        if frame < 3 {
            Pixels.DrawDisc(pix, cx, cy, r / 2, Color.RGB(255, 255, 200));
        }
        return pix;
    }

    // Generate a dash afterimage sprite (translucent copy of player)
    expose func buildDashAfterimageSprite(playerSpr: Pixels) -> Pixels {
        var w = playerSpr.get_Width();
        var h = playerSpr.get_Height();
        var pix = Pixels.Clone(playerSpr);
        // Tint blue and reduce opacity by blending a blue overlay
        Pixels.DrawBox(pix, 0, 0, w, h, Color.RGB(50, 100, 200));
        return pix;
    }

    // =========================================================================
    // Tile sprite getters for new tile types
    // =========================================================================
    expose func getPoisonPoolTile(frame: Integer) -> Pixels {
        if frame % 2 == 0 { return tilePoisonPool1; }
        return tilePoisonPool2;
    }
