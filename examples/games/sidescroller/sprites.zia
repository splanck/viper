    hide func buildVineTile() -> Pixels {
        var px = Pixels.New(TILE_SIZE, TILE_SIZE);
        // Vine curves
        px.DrawBezier(10, 0, 6, 16, 14, 32, COL_VINE_GREEN);
        px.DrawBezier(14, 32, 20, 40, 12, 47, COL_VINE_GREEN);
        px.DrawBezier(30, 0, 36, 14, 28, 28, COL_VINE_DARK);
        px.DrawBezier(28, 28, 22, 36, 32, 47, COL_VINE_DARK);
        // Leaf clusters
        px.DrawDisc(8, 14, 4, COL_VINE_GREEN);
        px.DrawDisc(18, 30, 3, COL_VINE_GREEN);
        px.DrawDisc(34, 10, 3, COL_VINE_DARK);
        px.DrawDisc(26, 40, 4, COL_VINE_GREEN);
        // Leaf highlights
        px.DrawDisc(7, 12, 2, 0x44AA44);
        px.DrawDisc(25, 38, 2, 0x44AA44);
        return px;
    }

    hide func buildMossStoneTile() -> Pixels {
        var px = Pixels.New(TILE_SIZE, TILE_SIZE);
        px.DrawBox(0, 0, 48, 48, COL_RUIN);
        // Stone texture
        px.DrawEllipse(16, 16, 10, 8, COL_RUIN_DARK);
        px.DrawEllipse(36, 36, 8, 6, COL_RUIN_DARK);
        // Moss coverage (ellipses for organic shapes)
        px.DrawEllipse(12, 10, 8, 5, COL_RUIN_MOSS);
        px.DrawEllipse(30, 22, 6, 4, COL_RUIN_MOSS);
        px.DrawEllipse(20, 40, 10, 5, COL_RUIN_MOSS);
        // Moss highlights
        px.DrawDisc(10, 8, 3, 0x558844);
        px.DrawDisc(22, 38, 3, 0x558844);
        return px;
    }

    // =========================================================================
    // Pickup Sprites
    // =========================================================================

    hide func buildPickupSprites() {
        // Coins (4 frames for rotation effect)
        coinFrames.add(buildCoinFrame(0));
        coinFrames.add(buildCoinFrame(1));
        coinFrames.add(buildCoinFrame(2));
        coinFrames.add(buildCoinFrame(3));

        healthOrb = buildHealthOrb();
        speedPickup = buildPowerupIcon(COL_SPEED);
        shieldPickup = buildPowerupIcon(COL_SHIELD);
        rapidPickup = buildPowerupIcon(COL_RAPIDFIRE);
    }

    hide func buildCoinFrame(frame: Integer) -> Pixels {
        var px = Pixels.New(COIN_SIZE, COIN_SIZE);
        // Coin rotation using ellipse with varying x-radius
        var rx = 9;
        if frame == 1 {
            rx = 6;
        }
        if frame == 2 {
            rx = 3;
        }
        if frame == 3 {
            rx = 6;
        }
        // Outer coin body
        px.DrawEllipse(12, 12, rx, 9, COL_COIN_GOLD);
        // Dark edge ring
        if rx > 3 {
            px.DrawEllipseFrame(12, 12, rx, 9, COL_COIN_DARK);
        }
        // Shine highlight
        if rx > 5 {
            px.DrawDisc(10, 9, 2, 0xFFEE88);
        }
        return px;
    }

    hide func buildHealthOrb() -> Pixels {
        var px = Pixels.New(POWERUP_SIZE, POWERUP_SIZE);
        // Outer glow
        px.DrawDisc(15, 15, 13, 0xCC2233);
        // Main orb
        px.DrawDisc(15, 15, 11, COL_HEALTH);
        px.DrawDisc(15, 15, 8, 0xFF6677);
        // Cross
        px.DrawBox(12, 8, 6, 14, COL_WHITE);
        px.DrawBox(8, 12, 14, 6, COL_WHITE);
        // Highlight
        px.DrawDisc(12, 11, 2, 0xFFAAAA);
        return px;
    }

    hide func buildPowerupIcon(col: Integer) -> Pixels {
        var px = Pixels.New(POWERUP_SIZE, POWERUP_SIZE);
        // Background disc
        px.DrawDisc(15, 15, 12, col);
        px.DrawDisc(15, 15, 9, 0xFFFFFF);
        // Arrow using triangle (pointing up)
        px.DrawTriangle(8, 18, 22, 18, 15, 6, col);
        // Arrow shaft
        px.DrawBox(12, 16, 6, 8, col);
        return px;
    }

    // =========================================================================
    // Bullet Sprites
    // =========================================================================

    hide func buildBulletSprites() {
        // Player bullet — elongated energy bolt
        bulletRight = Pixels.New(BULLET_W, BULLET_H);
        bulletRight.DrawEllipse(6, 3, 6, 3, COL_BULLET);
        bulletRight.DrawEllipse(7, 3, 4, 2, COL_BULLET_GLOW);
        bulletRight.DrawDisc(10, 3, 2, 0xAAEEFF);

        bulletLeft = bulletRight.Clone();
        bulletLeft.FlipH();

        // Enemy bullet — round with halo
        enemyBullet = Pixels.New(9, 9);
        enemyBullet.DrawDisc(5, 5, 5, COL_ENEMY_BULLET);
        enemyBullet.DrawRing(5, 5, 4, 0xFF6666);
        enemyBullet.DrawDisc(5, 5, 2, 0xFF8888);
    }

    // =========================================================================
    // Background Elements
    // =========================================================================

    hide func buildBackgroundElements() {
        cloud1 = buildCloud(90, 30);
        cloud2 = buildCloud(60, 24);
        treeBg = buildTreeBg();
        mountainBg = buildMountainBg();
    }

    hide func buildCloud(w: Integer, h: Integer) -> Pixels {
        var px = Pixels.New(w, h);
        var col = 0xFFFFFF;
        // Main body
        px.DrawBox(6, h / 2, w - 12, h / 2, col);
        // Puffs (overlapping discs)
        px.DrawDisc(w / 4, h / 2, h / 3, col);
        px.DrawDisc(w / 2, h / 3, h / 2, col);
        px.DrawDisc(w * 3 / 4, h / 2, h / 3, col);
        // Soft edges via blur
        var blurred = px.Blur(2);
        return blurred;
    }

    hide func buildTreeBg() -> Pixels {
        var px = Pixels.New(48, 72);
        // Trunk
        px.DrawBox(18, 42, 12, 30, 0x3A2808);
        px.DrawBox(21, 45, 6, 27, 0x2A1A06);
        // Canopy (dark silhouette greens — overlapping discs)
        px.DrawDisc(24, 21, 21, 0x143A16);
        px.DrawDisc(15, 27, 15, 0x1A4A1E);
        px.DrawDisc(33, 27, 15, 0x1A4A1E);
        px.DrawDisc(24, 15, 15, 0x205A24);
        // Canopy highlights
        px.DrawDisc(18, 14, 6, 0x2A6A2E);
        px.DrawDisc(30, 18, 5, 0x286828);
        return px;
    }

    hide func buildMountainBg() -> Pixels {
        var px = Pixels.New(180, 120);
        // Mountain shape using triangles
        px.DrawTriangle(0, 119, 90, 0, 180, 119, 0x2A3366);
        // Shaded right face
        px.DrawTriangle(90, 0, 180, 119, 135, 60, 0x1E2548);
        // Snow cap
        px.DrawTriangle(78, 18, 90, 0, 102, 18, 0xCCCCDD);
        px.DrawTriangle(82, 24, 90, 0, 98, 24, 0xDDDDEE);
        // Atmospheric haze via blur
        var blurred = px.Blur(1);
        return blurred;
    }

    // =========================================================================
    // Public accessors
    // =========================================================================

    expose func getPlayerFrame(facing: Integer, frameIdx: Integer) -> Pixels {
        if facing >= 0 {
            if frameIdx >= 0 {
                if frameIdx < playerRight.length() {
                    return playerRight.get(frameIdx);
                }
            }
            return playerRight.get(0);
        }
        if frameIdx >= 0 {
            if frameIdx < playerLeft.length() {
                return playerLeft.get(frameIdx);
            }
        }
        return playerLeft.get(0);
    }

    expose func getSlimeFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < slimeFrames.length() {
                return slimeFrames.get(frame);
            }
        }
        return slimeFrames.get(0);
    }

    expose func getBatFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < batFrames.length() {
                return batFrames.get(frame);
            }
        }
        return batFrames.get(0);
    }

    expose func getTurretBase() -> Pixels {
        return turretBase;
    }

    expose func getTurretBarrel() -> Pixels {
        return turretBarrel;
    }

    expose func getBossFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < bossFrames.length() {
                return bossFrames.get(frame);
            }
        }
        return bossFrames.get(0);
    }

    expose func getTile(id: Integer) -> Pixels {
        if id == TILE_GRASS_TOP { return tileGrassTop; }
        if id == TILE_GROUND { return tileDirt; }
        if id == TILE_DIRT { return tileDirt; }
        if id == TILE_STONE { return tileStone; }
        if id == TILE_BRICK { return tileBrick; }
        if id == TILE_PLATFORM { return tilePlatform; }
        if id == TILE_LAVA { return tileLava1; }
        if id == TILE_CRYSTAL { return tileCrystal; }
        if id == TILE_CAVE_TOP { return tileCaveTop; }
        if id == TILE_CAVE_WALL { return tileCaveWall; }
        if id == TILE_BRIDGE { return tileBridge; }
        if id == TILE_SPIKE { return tileSpike; }
        if id == TILE_CHECKPOINT { return tileCheckpoint; }
        if id == TILE_MAGMA { return tileMagma; }
        if id == TILE_OBSIDIAN { return tileObsidian; }
        if id == TILE_CLOUD { return tileCloud; }
        if id == TILE_SKY_BRICK { return tileSkyBrick; }
        if id == TILE_RUIN_STONE { return tileRuinStone; }
        if id == TILE_VINE { return tileVine; }
        if id == TILE_MOSS_STONE { return tileMossStone; }
        return tileDirt;
    }

    expose func getLavaTile(frame: Integer) -> Pixels {
        if frame == 0 {
            return tileLava1;
        }
        return tileLava2;
    }

    expose func getCoinFrame(frame: Integer) -> Pixels {
        if frame >= 0 {
            if frame < coinFrames.length() {
                return coinFrames.get(frame);
            }
        }
        return coinFrames.get(0);
    }

    expose func getHealthOrb() -> Pixels { return healthOrb; }
    expose func getSpeedPickup() -> Pixels { return speedPickup; }
    expose func getShieldPickup() -> Pixels { return shieldPickup; }
    expose func getRapidPickup() -> Pixels { return rapidPickup; }

    expose func getBullet(facing: Integer) -> Pixels {
        if facing >= 0 { return bulletRight; }
        return bulletLeft;
    }

    expose func getEnemyBullet() -> Pixels { return enemyBullet; }

    expose func getCloud1() -> Pixels { return cloud1; }
    expose func getCloud2() -> Pixels { return cloud2; }
    expose func getTreeBg() -> Pixels { return treeBg; }
    expose func getMountainBg() -> Pixels { return mountainBg; }
}
