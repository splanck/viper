        px.DrawEllipse(24, 24, 22, 18, COL_CLOUD_WHITE);
        px.DrawDisc(12, 20, 14, COL_CLOUD_WHITE);
        px.DrawDisc(36, 20, 14, COL_CLOUD_WHITE);
        px.DrawDisc(24, 14, 16, 0xFFFFFF);
        // Soft shading on bottom
        px.DrawEllipse(24, 32, 20, 8, 0xCCDDEE);
        return px;
    }

    hide func buildSkyBrickTile() -> Pixels {
        var px = Pixels.New(TILE_SIZE, TILE_SIZE);
        px.DrawBox(0, 0, 48, 48, COL_SKY_STONE);
        // Mortar lines
        px.DrawLine(0, 23, 47, 23, COL_SKY_STONE_DARK);
        px.DrawLine(23, 0, 23, 23, COL_SKY_STONE_DARK);
        px.DrawLine(0, 24, 0, 47, COL_SKY_STONE_DARK);
        // Bevel highlights
        px.DrawLine(1, 1, 22, 1, 0xAABBCC);
        px.DrawLine(24, 25, 47, 25, 0xAABBCC);
        // Crystal inlays
        px.DrawDisc(12, 12, 2, COL_CRYSTAL_BLUE);
        px.DrawDisc(36, 36, 2, COL_CRYSTAL_BLUE);
        return px;
    }

    hide func buildRuinStoneTile() -> Pixels {
        var px = Pixels.New(TILE_SIZE, TILE_SIZE);
        px.DrawBox(0, 0, 48, 48, COL_RUIN);
        // Cracks and fissures
        px.DrawLine(10, 5, 22, 20, COL_RUIN_DARK);
        px.DrawLine(22, 20, 18, 36, COL_RUIN_DARK);
        px.DrawLine(30, 12, 42, 30, COL_RUIN_DARK);
        // Moss patches
        px.DrawDisc(8, 38, 4, COL_RUIN_MOSS);
        px.DrawDisc(38, 8, 3, COL_RUIN_MOSS);
        // Worn edge
        px.DrawLine(0, 0, 47, 0, COL_RUIN_DARK);
        px.DrawLine(0, 47, 47, 47, COL_RUIN_DARK);
        return px;
