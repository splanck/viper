    // ─── Boss Sprites (new bosses) ────────────────────────────────────
    hide func buildBossSprites2() {
        // Spore Mother
        sporeMothFrames = [];
        var f = 0;
        while f < 3 {
            var pix = Pixels.New(72, 72);
            // Massive fungal body
            Pixels.DrawEllipse(pix, 36, 40, 34, 30, Color.RGB(50, 100, 40));
            Pixels.DrawEllipse(pix, 36, 38, 30, 26, Color.RGB(60, 120, 50));
            // Giant mushroom cap
            Pixels.DrawEllipse(pix, 36, 20, 36, 20, Color.RGB(120, 60, 140));
            Pixels.DrawEllipse(pix, 36, 18, 32, 18, Color.RGB(140, 80, 160));
            // Spore vents (glow based on phase)
            var glowCol = Color.RGB(200, 255, 100);
            if f == 1 { glowCol = Color.RGB(255, 200, 50); }
            if f == 2 { glowCol = Color.RGB(255, 100, 100); }
            Pixels.DrawDisc(pix, 20, 16, 5, glowCol);
            Pixels.DrawDisc(pix, 52, 16, 5, glowCol);
            Pixels.DrawDisc(pix, 36, 8, 4, glowCol);
            // Eyes: multiple
            Pixels.DrawDisc(pix, 28, 28, 3, Color.RGB(255, 200, 50));
            Pixels.DrawDisc(pix, 44, 28, 3, Color.RGB(255, 200, 50));
            Pixels.DrawDisc(pix, 36, 32, 2, Color.RGB(255, 200, 50));
            // Tendrils
            Pixels.DrawLine(pix, 10, 50, 2, 65, Color.RGB(40, 80, 30));
            Pixels.DrawLine(pix, 62, 50, 70, 65, Color.RGB(40, 80, 30));
            sporeMothFrames.add(Pixels.Scale(pix, SPORE_MOTHER_W, SPORE_MOTHER_H));
            f = f + 1;
        }

        // Crystal Wyrm
        crystalWyrmFrames = [];
        f = 0;
        while f < 3 {
            var pix2 = Pixels.New(60, 60);
            // Serpentine crystal body
            Pixels.DrawEllipse(pix2, 30, 30, 28, 20, Color.RGB(60, 80, 180));
            Pixels.DrawEllipse(pix2, 30, 28, 24, 16, Color.RGB(80, 110, 210));
            // Crystal segments
            var seg = 0;
            while seg < 5 {
                var sx2 = 10 + seg * 10;
                Pixels.DrawLine(pix2, sx2, 12, sx2, 48, Color.RGB(100, 140, 230));
                seg = seg + 1;
            }
            // Head
            Pixels.DrawTriangle(pix2, 50, 30, 40, 20, 40, 40, Color.RGB(90, 120, 220));
            // Eyes
            Pixels.DrawDisc(pix2, 46, 26, 3, Color.RGB(255, 100, 50));
            Pixels.DrawDisc(pix2, 46, 34, 3, Color.RGB(255, 100, 50));
            // Crystal spikes along back
            Pixels.DrawTriangle(pix2, 20, 10, 16, 18, 24, 18, Color.RGB(120, 160, 240));
            Pixels.DrawTriangle(pix2, 34, 8, 30, 16, 38, 16, Color.RGB(120, 160, 240));
            crystalWyrmFrames.add(Pixels.Scale(pix2, CRYSTAL_WYRM_W, CRYSTAL_WYRM_H));
            f = f + 1;
        }

        // Magma Core
        magmaCoreFrames = [];
        f = 0;
        while f < 3 {
            var pix3 = Pixels.New(84, 84);
            // Outer rocky shell
            Pixels.DrawEllipse(pix3, 42, 42, 40, 40, Color.RGB(60, 30, 20));
            Pixels.DrawEllipse(pix3, 42, 42, 36, 36, Color.RGB(80, 40, 25));
            // Magma veins
            Pixels.DrawLine(pix3, 10, 30, 42, 42, Color.RGB(255, 150, 30));
            Pixels.DrawLine(pix3, 42, 42, 74, 50, Color.RGB(255, 150, 30));
            Pixels.DrawLine(pix3, 20, 60, 42, 42, Color.RGB(255, 130, 20));
            Pixels.DrawLine(pix3, 42, 42, 60, 20, Color.RGB(255, 130, 20));
            // Eye (phase 2 only — open)
            if f == 2 {
                Pixels.DrawEllipse(pix3, 42, 38, 12, 8, Color.RGB(255, 200, 50));
                Pixels.DrawDisc(pix3, 42, 38, 5, Color.RGB(200, 50, 20));
                Pixels.DrawDisc(pix3, 42, 38, 2, Color.RGB(0, 0, 0));
            } else {
                // Closed slit
                Pixels.DrawLine(pix3, 30, 38, 54, 38, Color.RGB(255, 100, 30));
            }
            // Lava drips at bottom
            Pixels.DrawDisc(pix3, 30, 78, 4, Color.RGB(255, 160, 40));
            Pixels.DrawDisc(pix3, 54, 80, 3, Color.RGB(255, 140, 30));
            magmaCoreFrames.add(Pixels.Scale(pix3, MAGMA_CORE_W, MAGMA_CORE_H));
            f = f + 1;
        }

        // The Architect
        architectFrames = [];
        f = 0;
        while f < 4 {
            var pix4 = Pixels.New(72, 84);
            // Mechanical body
            Pixels.DrawBox(pix4, 16, 20, 40, 48, Color.RGB(50, 30, 60));
            Pixels.DrawBox(pix4, 18, 22, 36, 44, Color.RGB(60, 35, 75));
            // Armor plates
            Pixels.DrawLine(pix4, 18, 40, 54, 40, Color.RGB(80, 50, 100));
            // Head: angular with glowing visor
            Pixels.DrawBox(pix4, 20, 4, 32, 20, Color.RGB(55, 30, 70));
            Pixels.DrawTriangle(pix4, 36, 0, 20, 8, 52, 8, Color.RGB(65, 40, 80));
            // Visor: purple glow (intensifies with phase)
            var visorBright = 150 + f * 30;
            if visorBright > 255 { visorBright = 255; }
            Pixels.DrawBox(pix4, 24, 10, 24, 6, Color.RGB(visorBright, 50, 255));
            Pixels.DrawBox(pix4, 26, 11, 20, 4, Color.RGB(visorBright + 20, 80, 255));
            // Arms: mechanical
            Pixels.DrawBox(pix4, 4, 24, 12, 30, Color.RGB(45, 25, 55));
            Pixels.DrawBox(pix4, 56, 24, 12, 30, Color.RGB(45, 25, 55));
            // Weapon pods on arms
            Pixels.DrawDisc(pix4, 10, 50, 5, Color.RGB(200, 50, 255));
            Pixels.DrawDisc(pix4, 62, 50, 5, Color.RGB(200, 50, 255));
            // Legs
            Pixels.DrawBox(pix4, 20, 68, 12, 16, Color.RGB(40, 20, 50));
            Pixels.DrawBox(pix4, 40, 68, 12, 16, Color.RGB(40, 20, 50));
            // Phase indicators (energy lines)
            if f >= 1 { Pixels.DrawLine(pix4, 18, 25, 54, 25, Color.RGB(200, 80, 255)); }
            if f >= 2 { Pixels.DrawLine(pix4, 18, 35, 54, 35, Color.RGB(200, 80, 255)); }
            if f >= 3 {
                Pixels.DrawLine(pix4, 18, 45, 54, 45, Color.RGB(255, 100, 255));
                Pixels.DrawLine(pix4, 18, 55, 54, 55, Color.RGB(255, 100, 255));
            }
            architectFrames.add(Pixels.Scale(pix4, ARCHITECT_W, ARCHITECT_H));
            f = f + 1;
        }
    }

    hide func buildBombCarrierSprites() {
        bombCarrierFrames = [];
        var f = 0;
        while f < 2 {
            var pix = Pixels.New(24, 24);
            Pixels.DrawDisc(pix, 12, 10, 6, pal.hullPlateLt);
            Pixels.DrawDisc(pix, 12, 10, 4, pal.hullPlate);
            Pixels.DrawDisc(pix, 12, 10, 1, pal.emergencyLight);
            Pixels.DrawLine(pix, 6, 8, 2, 12 + f, pal.outline);
            Pixels.DrawLine(pix, 18, 8, 22, 12 + f, pal.outline);
            Pixels.DrawLine(pix, 12, 15, 12, 18, pal.outline);
            Pixels.DrawDisc(pix, 12, 21, 4, Color.RGB(180, 60, 60));
            Pixels.DrawLine(pix, 12, 17, 12, 24, Color.RGB(255, 230, 80));
            if f == 0 {
                Pixels.DrawDisc(pix, 12, 17, 1, pal.sparkYellow);
            }
            bombCarrierFrames.add(Pixels.Scale(pix, BOMB_CARRIER_W, BOMB_CARRIER_H));
            f = f + 1;
        }
    }

    // ─── Accessor methods for new sprites ─────────────────────────────
    // These return the cached sprite for the given animation frame.
    // If sprites haven't been built yet, build them on first access.

    expose func getSporewalkerFrame(f: Integer) -> Pixels {
        if not newSpritesBuilt { buildNewEnemySprites(); }
        return sporewalkerFrames.get(f % sporewalkerFrames.length());
    }
