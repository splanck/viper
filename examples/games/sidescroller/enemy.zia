    // =========================================================================
    // Drawing
    // =========================================================================

    expose func drawAll(canvas: Canvas, camX: Integer, camY: Integer, sprites: SpriteFactory) {
        var i = pool.FirstActive();
        while i >= 0 {
            var next = pool.NextActive(i);
            var sx = ex.get(i) / 100 - camX;
            var sy = ey.get(i) / 100 - camY;

            // Skip if off screen
            if sx > -96 {
                if sx < SCREEN_W + 96 {
                    if sy > -96 {
                        if sy < SCREEN_H + 96 {
                            var t = etype.get(i);
                            var f = eframe.get(i);

                            // Flash when hurt (skip draw every other 2-frame pair)
                            var skipDraw = false;
                            if estate.get(i) == 1 {
                                if etimer.get(i) % 4 < 2 {
                                    skipDraw = true;
                                }
                            }
                            if skipDraw == false {
                                drawEnemy(canvas, t, f, sx, sy, sprites);
                            }
                        }
                    }
                }
            }
            i = next;
        }

        // Draw enemy bullets
        drawEnemyBullets(canvas, camX, camY, sprites);
    }

    hide func drawEnemy(canvas: Canvas, t: Integer, f: Integer,
                        sx: Integer, sy: Integer, sprites: SpriteFactory) {
        if t == ENEMY_SLIME { canvas.BlitAlpha(sx, sy, sprites.getSlimeFrame(f)); return; }
        if t == ENEMY_BAT { canvas.BlitAlpha(sx, sy, sprites.getBatFrame(f)); return; }
        if t == ENEMY_TURRET { canvas.BlitAlpha(sx, sy, sprites.getTurretBase()); return; }
        if t == ENEMY_BOSS { canvas.BlitAlpha(sx, sy, sprites.getBossFrame(f)); return; }

        // New enemies — placeholder colored shapes (proper sprites will replace these)
        var w = getEnemyW(t); var h = getEnemyH(t);
        if t == ENEMY_SPOREWALKER { canvas.Box(sx, sy, w, h, Color.RGB(80, 180, 60)); canvas.Frame(sx, sy, w, h, Color.RGB(40, 100, 30)); }
        else if t == ENEMY_GLOWMOTH { canvas.Disc(sx + w / 2, sy + h / 2, w / 2, Color.RGB(200, 255, 100)); }
        else if t == ENEMY_FUNGAL_TURRET { canvas.Box(sx, sy, w, h, Color.RGB(140, 80, 160)); canvas.Frame(sx, sy, w, h, Color.RGB(80, 40, 100)); }
        else if t == ENEMY_MYCELIUM { canvas.Box(sx, sy, w, h, Color.RGB(100, 60, 40)); }
        else if t == ENEMY_SPORE_MOTHER { canvas.Box(sx, sy, w, h, Color.RGB(60, 140, 50)); canvas.Frame(sx + 4, sy + 4, w - 8, h - 8, Color.RGB(200, 255, 100)); }
        else if t == ENEMY_CRYSTAL_GOLEM { canvas.Box(sx, sy, w, h, Color.RGB(80, 120, 200)); canvas.Frame(sx, sy, w, h, Color.RGB(150, 200, 255)); }
        else if t == ENEMY_SHARD_BAT { canvas.Disc(sx + w / 2, sy + h / 2, w / 2, Color.RGB(130, 100, 220)); }
        else if t == ENEMY_RESONANCE_ORB { canvas.Disc(sx + w / 2, sy + h / 2, w / 2, Color.RGB(180, 160, 255)); if f == 1 { canvas.Ring(sx + w / 2, sy + h / 2, w, Color.RGB(200, 180, 255)); } }
        else if t == ENEMY_MIRROR_SLIME { canvas.Box(sx, sy, w, h, Color.RGB(200, 220, 230)); canvas.Frame(sx, sy, w, h, Color.RGB(255, 255, 255)); }
        else if t == ENEMY_CRYSTAL_WYRM { canvas.Box(sx, sy, w, h, Color.RGB(60, 80, 180)); canvas.Frame(sx + 4, sy + 4, w - 8, h - 8, Color.RGB(100, 140, 255)); }
        else if t == ENEMY_MAGMA_SLUG { canvas.Box(sx, sy, w, h, Color.RGB(200, 80, 20)); canvas.Frame(sx, sy, w, h, Color.RGB(255, 150, 30)); }
        else if t == ENEMY_EMBER_WASP { canvas.Disc(sx + w / 2, sy + h / 2, w / 2, Color.RGB(255, 180, 50)); }
        else if t == ENEMY_FORGE_SENTINEL { canvas.Box(sx, sy, w, h, Color.RGB(120, 120, 130)); canvas.Frame(sx, sy, w, h, Color.RGB(180, 80, 40)); }
        else if t == ENEMY_PISTON_TRAP { canvas.Box(sx, sy, w, h, Color.RGB(150, 150, 160)); canvas.Box(sx + 4, sy, w - 8, h / 3, Color.RGB(200, 50, 50)); }
        else if t == ENEMY_MAGMA_CORE { canvas.Box(sx, sy, w, h, Color.RGB(180, 40, 20)); canvas.Disc(sx + w / 2, sy + w / 2, 20, Color.RGB(255, 200, 50)); }
        else if t == ENEMY_ICE_WRAITH { canvas.BoxAlpha(sx, sy, w, h, Color.RGB(180, 220, 255), 150); }
        else if t == ENEMY_FROST_BEETLE { canvas.Box(sx, sy, w, h, Color.RGB(100, 160, 200)); canvas.Frame(sx, sy, w, h, Color.RGB(60, 100, 140)); }
        else if t == ENEMY_STALACTITE_BAT { canvas.Box(sx, sy, w, h, Color.RGB(160, 180, 200)); }
        else if t == ENEMY_VINE_WHIP { canvas.Box(sx, sy, w, h, Color.RGB(50, 130, 40)); }
        else if t == ENEMY_MOSS_GOLEM { canvas.Box(sx, sy, w, h, Color.RGB(80, 110, 60)); canvas.Frame(sx, sy, w, h, Color.RGB(60, 90, 40)); }
        else if t == ENEMY_RUIN_GUARDIAN { canvas.Box(sx, sy, w, h, Color.RGB(140, 130, 110)); canvas.Frame(sx, sy, w, h, Color.RGB(180, 170, 150)); }
        else if t == ENEMY_SHADOW_CLONE { canvas.BoxAlpha(sx, sy, w, h, Color.RGB(40, 0, 60), 180); }
        else if t == ENEMY_CORRUPTION { canvas.Box(sx, sy, w, h, Color.RGB(80, 0, 100)); }
        else if t == ENEMY_ARCHITECT { canvas.Box(sx, sy, w, h, Color.RGB(60, 20, 80)); canvas.Frame(sx + 8, sy + 8, w - 16, h - 16, Color.RGB(200, 50, 255)); }
        else if t == ENEMY_PATROL_DRONE { canvas.Box(sx, sy, w, h, Color.RGB(100, 120, 140)); canvas.Disc(sx + w / 2, sy + h / 2, 4, Color.RGB(255, 50, 50)); }
        else if t == ENEMY_BOMB_CARRIER { canvas.Box(sx, sy, w, h, Color.RGB(180, 60, 60)); if f % 2 == 0 { canvas.Disc(sx + w / 2, sy + 4, 4, Color.RGB(255, 255, 50)); } }
        else { canvas.Box(sx, sy, w, h, Color.RGB(255, 0, 255)); } // Fallback: magenta
    }

    hide func drawEnemyBullets(canvas: Canvas, camX: Integer, camY: Integer,
                                sprites: SpriteFactory) {
        var i = 0;
        while i < ebCount {
            if ebactive.get(i) == 1 {
                var sx = ebx.get(i) - camX;
                var sy = eby.get(i) - camY;
                if sx > -15 {
                    if sx < SCREEN_W + 15 {
                        canvas.BlitAlpha(sx, sy, sprites.getEnemyBullet());
                    }
                }
            }
            i = i + 1;
        }
    }

    // Accessors
    expose func getEnemyType(i: Integer) -> Integer { return etype.get(i); }
    expose func isActive(i: Integer) -> Integer { if pool.IsActive(i) { return 1; } return 0; }
    expose func getEnemyHp(i: Integer) -> Integer { return ehp.get(i); }
    expose func isBossAlive() -> Boolean {
        if bossIndex < 0 { return false; }
        return pool.IsActive(bossIndex);
    }
    expose func getBossHp() -> Integer {
        if bossIndex < 0 { return 0; }
        return ehp.get(bossIndex);
    }
}
