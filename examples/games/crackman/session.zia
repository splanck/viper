// ============================================================================
// MODULE: session (Session)
// PURPOSE: One play-through of the game. Owns the maze, player, ghosts,
//          fruit, particles, sound, scoring, collision resolution,
//          level progression, ready/dying/game-over transitions,
//          ScreenFX overlays.
//
// WHERE-THIS-FITS: Constructed by Game when a run starts; torn down
//          when the player returns to the frontend. The per-frame
//          update() returns an EVENT_* enum code to Game so the
//          top-level state machine can react (pause, game-over,
//          victory, etc.).
//
// KEY-DESIGN-CHOICES:
//   * EVENT ENUM RETURN. update() returns an EVENT_* code indicating
//     what happened this frame. Game.zia switches on it to drive
//     screen transitions. Cleaner than nested callbacks.
//   * SCREENFX OVERLAYS. FX module provides flashes, fades, and
//     freeze effects layered on top of the rendered scene.
//   * ONE CLASS OWNS EVERYTHING GAMEPLAY-RELATED. The Session is a
//     "big bag of state" deliberately; small games benefit more from
//     readability than from fine-grained decoupling.
// ============================================================================

module session;

bind Viper.Graphics;
bind Viper.Input;
bind Viper.Game;
bind Viper.Game.ScreenFX as FX;

bind "./config";
bind "./utils";
bind "./maze";
bind "./player";
bind "./ghost";
bind "./fruit";
bind "./particles";
bind "./popups";
bind "./sound";
bind "./progression";
bind "./ui/renderer";

final EVENT_NONE = 0;
final EVENT_PAUSE = 1;
final EVENT_DYING = 2;
final EVENT_GAME_OVER = 3;
final EVENT_WIN = 4;
final EVENT_READY_COMPLETE = 5;
final EVENT_DYING_COMPLETE = 6;

/// @brief One play-through — owns everything gameplay-related.
class Session {
    hide maze.Maze theMaze;
    hide player.PacMan pacman;
    hide List[ghost.Ghost] ghosts;
    hide fruit.Fruit theFruit;
    hide particles.ParticleSystem particleSys;
    hide popups.ScorePopups scorePops;
    hide progression.Progression profile;

    hide Integer score;
    hide Integer lives;
    hide Integer level;
    hide Integer highScore;
    hide Integer dotsEaten;
    hide Integer ghostsEaten;
    hide Boolean extraLifeAwarded;

    hide Timer readyTimer;
    hide Timer deathTimer;
    hide Timer modeTimer;
    hide Boolean chaseMode;

    hide Tween readyTween;
    hide SmoothValue displayScore;
    hide Timer comboTimer;
    hide Tween comboTween;
    hide Integer comboScore;
    hide Integer comboCount;
    hide Boolean frightenedActive;
    hide FX fx;

    hide Lighting2D lights;
    hide Boolean deluxeLighting;

    expose func init() {
        theMaze = new maze.Maze();
        theMaze.init();

        pacman = new player.PacMan(14, 23);

        ghosts = [];
        ghosts.add(new ghost.Ghost(0, 14, 11, config.COLOR_RED));
        ghosts.add(new ghost.Ghost(1, 13, 14, config.COLOR_PINK));
        ghosts.add(new ghost.Ghost(2, 14, 14, config.COLOR_CYAN));
        ghosts.add(new ghost.Ghost(3, 15, 14, config.COLOR_ORANGE));

        theFruit = new fruit.Fruit();
        theFruit.init();

        particleSys = new particles.ParticleSystem();
        scorePops = new popups.ScorePopups();
        fx = FX.New();

        lights = Lighting2D.New(16);
        lights.set_Darkness(212);
        lights.set_TintColor(0x0A0A24);
        lights.SetPlayerLight(118, 0xFFE24A);
        deluxeLighting = false;

        readyTimer = Timer.New();
        deathTimer = Timer.New();
        modeTimer = Timer.New();

        readyTween = Tween.New();
        displayScore = SmoothValue.New(0.0, 900.0);
        comboTimer = Timer.New();
        comboTween = Tween.New();
        comboTimer.Stop();
        comboScore = 0;
        comboCount = 0;

        score = 0;
        lives = 3;
        level = 1;
        highScore = 10000;
        dotsEaten = 0;
        ghostsEaten = 0;
        extraLifeAwarded = false;
        chaseMode = false;
        frightenedActive = false;
    }

    expose func attachProgression(theProfile: progression.Progression) {
        profile = theProfile;
    }

    expose func updateFrame(dt: Integer) {
        fx.Update(dt);
        particleSys.update();
        scorePops.update();
        displayScore.Target = score * 1.0;
        displayScore.Update();
        comboTimer.Update();
        comboTween.Update();
    }

    expose func startReady(sfx: sound.SoundManager) {
        readyTimer.Start(config.READY_DURATION);
        readyTween.StartI64(0, 100, 30, config.EASE_OUT_BOUNCE);
        sfx.playGameMusic();
        sfx.playReady();
    }

    expose func updateReady() -> Integer {
        readyTimer.Update();
        readyTween.Update();

        if readyTimer.IsExpired {
            modeTimer.Start(config.MODE_SWITCH_TIME);
            chaseMode = false;
            return EVENT_READY_COMPLETE;
        }
        return EVENT_NONE;
    }

    expose func updatePlaying(sfx: sound.SoundManager) -> Integer {
        if Action.Pressed(config.ACTION_PAUSE) {
            self.killSiren(sfx);
            sfx.playPause();
            return EVENT_PAUSE;
        }

        if Action.Pressed(config.ACTION_LIGHTS) {
            deluxeLighting = !deluxeLighting;
        }

        self.handleMovementInput();
        self.updateGhostModeTimer();

        pacman.update(theMaze);
        theFruit.update();

        self.handleDotEating(sfx);
        self.handleFruitCollect(sfx);
        self.handleExtraLife(sfx);
        self.updateHighScore();
        self.updateGhosts();
        self.updateSiren(sfx);

        var collisionEvent = self.handleGhostCollisions(sfx);
        if collisionEvent != EVENT_NONE {
            return collisionEvent;
        }

        if theMaze.allDotsEaten() {
            self.killSiren(sfx);
            var winX = config.PLAYFIELD_X + config.PLAYFIELD_WIDTH / 2;
            var winY = config.PLAYFIELD_Y + config.PLAYFIELD_HEIGHT / 2;
            particleSys.burstCelebrate(winX, winY);
            fx.Flash(config.COLOR_WHITE * 256 + 0x55, 240);
            Pad.Vibrate(config.PAD_IDX, 0.3, 0.6);
            if profile != null {
                profile.noteBoardClear(level);
            }
            sfx.playLevelClear();
            return EVENT_WIN;
        }

        return EVENT_NONE;
    }

    /// @brief Keep the looping power-pellet siren in sync with frightened state.
    hide func updateSiren(sfx: sound.SoundManager) {
        if self.getMaxFrightenedRemaining() > 0 {
            if !frightenedActive {
                sfx.playSiren();
                frightenedActive = true;
            }
        } else {
            self.killSiren(sfx);
        }
    }

    hide func killSiren(sfx: sound.SoundManager) {
        if frightenedActive {
            sfx.stopSiren();
            frightenedActive = false;
        }
    }

    expose func updateDying() -> Integer {
        deathTimer.Update();
        pacman.setDeathProgress(deathTimer.Progress);
        if deathTimer.IsExpired {
            self.resetActors();
            return EVENT_DYING_COMPLETE;
        }
        return EVENT_NONE;
    }

    expose func resetGame() {
        score = 0;
        lives = 3;
        level = 1;
        dotsEaten = 0;
        extraLifeAwarded = false;
        chaseMode = false;
        frightenedActive = false;

        theMaze.reset();
        self.resetActors();
        theFruit.reset();
        particleSys.reset();
        scorePops.reset();
        displayScore.SetImmediate(0.0);
        comboTimer.Stop();
        comboScore = 0;
        comboCount = 0;
    }

    expose func nextLevel() {
        level = level + 1;
        dotsEaten = 0;
        chaseMode = false;
        frightenedActive = false;

        theMaze.reset();
        self.resetActors();
        theFruit.reset();
        scorePops.reset();
        comboTimer.Stop();
        comboScore = 0;
        comboCount = 0;
    }

    expose func render(canvas: Canvas, overlayState: Integer, uiTick: Integer) {
        renderer.drawPlayfieldShell(canvas, uiTick);

        theMaze.draw(canvas, uiTick);
        self.drawFrightenedVignette(canvas, uiTick);
        theFruit.draw(canvas);
        pacman.draw(canvas);

        for i in 0..ghosts.length() {
            ghosts.get(i).draw(canvas);
        }

        particleSys.draw(canvas);
        scorePops.draw(canvas);
        self.drawDeluxeLighting(canvas);
        if overlayState == config.STATE_WIN {
            self.drawWinFlash(canvas, uiTick);
        }
        renderer.drawHud(canvas, displayScore.ValueI64, highScore, level, lives,
                         theMaze.getDotsRemaining(), theMaze.getTotalDots(),
                         self.getMaxFrightenedRemaining(), config.FRIGHTENED_DURATION, uiTick);

        if !comboTimer.IsExpired && comboCount > 0 {
            renderer.drawComboToast(canvas, comboScore, comboCount, comboTween.ValueI64, uiTick);
        }

        var overlayCol = fx.get_OverlayColor();
        if overlayCol != 0 {
            var r = (overlayCol / 0x1000000) % 256;
            var g = (overlayCol / 0x10000) % 256;
            var b = (overlayCol / 0x100) % 256;
            var a = overlayCol % 256;
            var rgb = r * 0x10000 + g * 0x100 + b;
            canvas.BoxAlpha(0, 0, config.SCREEN_WIDTH, config.SCREEN_HEIGHT, rgb, a);
        }

        renderer.drawStateOverlay(canvas, overlayState, readyTween.Progress, uiTick);
    }

    /// @brief R11 — optional "deluxe" lighting mode (toggle with L). Darkens the
    ///        maze and makes Crackman and the power pellets glow as light
    ///        sources. Drawn before the HUD so the HUD stays readable.
    hide func drawDeluxeLighting(canvas: Canvas) {
        if !deluxeLighting {
            return;
        }
        for gy in 0..config.GRID_HEIGHT {
            for gx in 0..config.GRID_WIDTH {
                if theMaze.getTile(gx, gy) == config.TILE_PELLET {
                    lights.AddTileLight(utils.gridToCenterX(gx), utils.gridToCenterY(gy), 64, 0xFFE8B8);
                }
            }
        }
        lights.Update();
        var pacX = pacman.getScreenX() + config.TILE_SIZE / 2;
        var pacY = pacman.getScreenY() + config.TILE_SIZE / 2;
        lights.Draw(canvas, 0, 0, pacX, pacY);
    }

    /// @brief R14 — gentle white maze pulse on board clear (soft, not a strobe).
    hide func drawWinFlash(canvas: Canvas, uiTick: Integer) {
        var pulse = (uiTick / 5) % 100;
        if pulse > 50 { pulse = 100 - pulse; }
        canvas.BoxAlpha(config.PLAYFIELD_X, config.PLAYFIELD_Y,
                        config.PLAYFIELD_WIDTH, config.PLAYFIELD_HEIGHT,
                        0xFFFFFF, 8 + pulse / 3);
    }

    /// @brief R8 — pulsing blue edge glow while any ghost is frightened, so the
    ///        power-pellet window reads at a glance (not just by ghost recolor).
    hide func drawFrightenedVignette(canvas: Canvas, uiTick: Integer) {
        if self.getMaxFrightenedRemaining() <= 0 {
            return;
        }
        var px = config.PLAYFIELD_X;
        var py = config.PLAYFIELD_Y;
        var pw = config.PLAYFIELD_WIDTH;
        var ph = config.PLAYFIELD_HEIGHT;
        var pulse = (uiTick / 6) % 100;
        if pulse > 50 { pulse = 100 - pulse; }
        var band = 16 + pulse / 3;
        var blue = 0x2A7BFF;

        canvas.BoxAlpha(px, py, pw, ph, 0x1030C0, 8 + pulse / 8);
        canvas.BoxAlpha(px, py, pw, 24, blue, band);
        canvas.BoxAlpha(px, py + ph - 24, pw, 24, blue, band);
        canvas.BoxAlpha(px, py, 24, ph, blue, band);
        canvas.BoxAlpha(px + pw - 24, py, 24, ph, blue, band);
    }

    expose func getScore() -> Integer {
        return score;
    }

    expose func getHighScore() -> Integer {
        return highScore;
    }

    expose func getLevel() -> Integer {
        return level;
    }

    expose func setHighScore(value: Integer) {
        highScore = value;
    }

    hide func handleMovementInput() {
        if Action.Held(config.ACTION_UP) {
            pacman.setNextDirection(config.DIR_UP);
        } else if Action.Held(config.ACTION_DOWN) {
            pacman.setNextDirection(config.DIR_DOWN);
        } else if Action.Held(config.ACTION_LEFT) {
            pacman.setNextDirection(config.DIR_LEFT);
        } else if Action.Held(config.ACTION_RIGHT) {
            pacman.setNextDirection(config.DIR_RIGHT);
        }
    }

    hide func updateGhostModeTimer() {
        if modeTimer.Update() {
            chaseMode = !chaseMode;
            modeTimer.Start(config.MODE_SWITCH_TIME);

            for i in 0..ghosts.length() {
                var g = ghosts.get(i);
                if g.getMode() != config.MODE_FRIGHTENED {
                    if chaseMode {
                        g.setMode(config.MODE_CHASE);
                    } else {
                        g.setMode(config.MODE_SCATTER);
                    }
                }
            }
        }
    }

    hide func handleDotEating(sfx: sound.SoundManager) {
        var points = theMaze.eatDot(pacman.getGridX(), pacman.getGridY());
        if points <= 0 {
            return;
        }

        score = score + points;
        dotsEaten = dotsEaten + 1;
        if profile != null {
            profile.noteDot(points, score);
        }

        var dotPx = utils.gridToCenterX(pacman.getGridX());
        var dotPy = utils.gridToCenterY(pacman.getGridY());
        if points == config.PELLET_POINTS {
            particleSys.burstPellet(dotPx, dotPy);
            fx.Flash(config.COLOR_BLUE * 256 + 0x44, 80);
            sfx.playPellet();
        } else {
            particleSys.burstDotEat(dotPx, dotPy);
            if (dotsEaten % 2) == 0 {
                sfx.playDot();
            }
        }

        if dotsEaten == 70 || dotsEaten == 170 {
            theFruit.spawn(level);
        }

        if points == config.PELLET_POINTS {
            ghostsEaten = 0;
            for i in 0..ghosts.length() {
                ghosts.get(i).setMode(config.MODE_FRIGHTENED);
            }
        }
    }

    hide func handleFruitCollect(sfx: sound.SoundManager) {
        if !theFruit.collidesWithPacman(pacman.getGridX(), pacman.getGridY()) {
            return;
        }

        var fruitPx = utils.gridToCenterX(pacman.getGridX());
        var fruitPy = utils.gridToCenterY(pacman.getGridY());
        particleSys.burstFruitCollect(fruitPx, fruitPy, config.COLOR_GREEN);
        score = score + theFruit.collect();
        if profile != null {
            profile.noteFruitCollect(score);
        }
        sfx.playFruit();
    }

    hide func handleExtraLife(sfx: sound.SoundManager) {
        if score >= config.EXTRA_LIFE_SCORE && !extraLifeAwarded {
            lives = lives + 1;
            extraLifeAwarded = true;
            sfx.playExtraLife();
        }
    }

    hide func updateHighScore() {
        if score > highScore {
            highScore = score;
        }
    }

    hide func updateGhosts() {
        var blinkyX = 0;
        var blinkyY = 0;
        if ghosts.length() > 0 {
            var blinky = ghosts.get(0);
            blinkyX = blinky.getGridX();
            blinkyY = blinky.getGridY();
        }

        for i in 0..ghosts.length() {
            ghosts.get(i).update(theMaze, pacman.getGridX(), pacman.getGridY(), blinkyX, blinkyY);
        }
    }

    hide func getMaxFrightenedRemaining() -> Integer {
        var best = 0;
        for i in 0..ghosts.length() {
            var remaining = ghosts.get(i).getFrightenedRemaining();
            if remaining > best {
                best = remaining;
            }
        }
        return best;
    }

    hide func handleGhostCollisions(sfx: sound.SoundManager) -> Integer {
        for i in 0..ghosts.length() {
            var g = ghosts.get(i);
            if !g.collidesWithPacman(pacman.getGridX(), pacman.getGridY()) {
                continue;
            }

            var gPx = utils.gridToCenterX(g.getGridX());
            var gPy = utils.gridToCenterY(g.getGridY());
            if g.getMode() == config.MODE_FRIGHTENED {
                ghostsEaten = ghostsEaten + 1;
                var ghostPoints = config.GHOST_BASE_POINTS;
                var mult = 1;
                var n = 1;
                while n < ghostsEaten {
                    mult = mult * 2;
                    n = n + 1;
                }
                score = score + ghostPoints * mult;
                comboScore = ghostPoints * mult;
                comboCount = ghostsEaten;
                comboTimer.Start(90);
                comboTween.StartI64(0, 26, 90, config.EASE_OUT_QUAD);
                particleSys.burstGhostEat(gPx, gPy, g.getColor());

                var popCol = config.COLOR_CYAN;
                if ghostsEaten >= 4 {
                    popCol = config.COLOR_YELLOW;
                } else if ghostsEaten >= 3 {
                    popCol = config.COLOR_PINK;
                }
                scorePops.spawn(gPx, gPy - 6, ghostPoints * mult, popCol);

                fx.Shake(4000, 120, 500);
                Pad.Vibrate(config.PAD_IDX, 0.45, 0.55);
                sfx.playGhostEat();
                if profile != null {
                    profile.noteGhostEaten(ghostsEaten, score);
                }
                g.setMode(config.MODE_EATEN);
            } else if g.getMode() != config.MODE_EATEN {
                self.crackmanDeath(sfx);
                if lives <= 0 {
                    return EVENT_GAME_OVER;
                }
                return EVENT_DYING;
            }
        }

        return EVENT_NONE;
    }

    hide func crackmanDeath(sfx: sound.SoundManager) {
        var deathPx = utils.gridToCenterX(pacman.getGridX());
        var deathPy = utils.gridToCenterY(pacman.getGridY());
        self.killSiren(sfx);
        pacman.beginDeath();
        particleSys.burstDeath(deathPx, deathPy);
        fx.Shake(8000, 200, 500);
        fx.Flash(config.COLOR_RED * 256 + 0xAA, 160);
        Pad.Vibrate(config.PAD_IDX, 0.9, 0.9);
        sfx.playDeath();
        lives = lives - 1;
        if profile != null {
            profile.noteDeath();
        }
        if lives > 0 {
            deathTimer.Start(config.DEATH_DURATION);
        }
    }

    hide func resetActors() {
        pacman.reset(14, 23);
        for i in 0..ghosts.length() {
            ghosts.get(i).reset();
        }
    }
}
