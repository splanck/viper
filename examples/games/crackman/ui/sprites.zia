// ============================================================================
// MODULE: ui/sprites
// PURPOSE: Central sprite cache. Delegates actual rendering to four sub-
//          modules (sprite_maze / sprite_items / sprite_entities /
//          sprite_support) and caches the generated Pixels buffers so
//          the renderer blits them repeatedly without re-rasterizing.
//
// WHERE-THIS-FITS: UI sub-tree. The renderer calls getPacman /
//          getGhost / getFruit / getDot / etc.; builds happen lazily
//          on first request via ensureStorage().
//
// KEY-DESIGN-CHOICES:
//   * PRE-RENDER THEN BLIT. Sprites are procedurally generated into
//     Pixels buffers once. Each frame the renderer calls
//     Canvas.BlitAlpha — dramatically faster than re-running the draw
//     calls per frame.
//   * FOUR-WAY SPRITE SETS. Players and ghosts have 4 direction
//     variants stored as an indexed list keyed by DIR_RIGHT / LEFT /
//     UP / DOWN. Ghost sets further split by mode (chase /
//     frightened / frightened-flash / eaten).
//   * LAZY STORAGE. storageReady_ guard + ensureStorage() lets the
//     module be imported cheaply; actual sprite generation only
//     fires on first use.
// ============================================================================

module sprites;

bind Viper.Graphics;

bind "../config";
bind "./theme";
bind "./sprite_support";
bind "./sprite_entities";
bind "./sprite_items";
bind "./sprite_maze";

var storageReady_: Boolean = false;
var wallTiles_: List[Pixels];
var pacmanSprites_: List[Pixels];
var ghostSprites_: List[Pixels];
var eatenSprites_: List[Pixels];
var frightenedSprites_: List[Pixels];
var frightenedFlashSprites_: List[Pixels];
var fruitSprites_: List[Pixels];
var lifeIcon_: Pixels;
var dotSprite_: Pixels;
var pelletSprite_: Pixels;
var gateSprite_: Pixels;
var logoPacOpen_: Pixels;
var logoPacClosed_: Pixels;
var logoGhostRed_: Pixels;
var logoGhostPink_: Pixels;
var logoGhostCyan_: Pixels;
var logoGhostOrange_: Pixels;

hide func ensureStorage() {
    if storageReady_ { return; }
    storageReady_ = true;

    wallTiles_ = [];
    for i in 0..16 {
        wallTiles_.add(null);
    }

    pacmanSprites_ = [];
    for i in 0..8 {
        pacmanSprites_.add(null);
    }

    ghostSprites_ = [];
    for i in 0..16 {
        ghostSprites_.add(null);
    }

    eatenSprites_ = [];
    for i in 0..4 {
        eatenSprites_.add(null);
    }

    frightenedSprites_ = [];
    frightenedFlashSprites_ = [];
    for i in 0..4 {
        frightenedSprites_.add(null);
        frightenedFlashSprites_.add(null);
    }

    fruitSprites_ = [];
    for i in 0..9 {
        fruitSprites_.add(null);
    }
}

expose func prewarmGameplayAssets() {
    ensureStorage();

    for i in 0..16 {
        if wallTiles_.get(i) == null {
            wallTiles_.set(i, sprite_maze.buildWallTile(i));
        }
    }

    var dirs = [config.DIR_RIGHT, config.DIR_LEFT, config.DIR_UP, config.DIR_DOWN];
    for i in 0..4 {
        var dir = dirs.get(i);
        var base = sprite_support.dirIndex(dir) * 2;
        if pacmanSprites_.get(base) == null {
            pacmanSprites_.set(base, sprite_entities.buildPacmanSprite(32, dir, true));
        }
        if pacmanSprites_.get(base + 1) == null {
            pacmanSprites_.set(base + 1, sprite_entities.buildPacmanSprite(32, dir, false));
        }
    }

    var colors = [config.COLOR_RED, config.COLOR_PINK, config.COLOR_CYAN, config.COLOR_ORANGE];
    for ci in 0..4 {
        var color = colors.get(ci);
        for di in 0..4 {
            var dir2 = dirs.get(di);
            var idx = ci * 4 + di;
            if ghostSprites_.get(idx) == null {
                ghostSprites_.set(idx, sprite_entities.buildGhostSprite(32, color, dir2, false, false));
            }
        }
    }

    for di in 0..4 {
        var dir3 = dirs.get(di);
        if eatenSprites_.get(di) == null {
            eatenSprites_.set(di, sprite_entities.buildEatenGhostSprite(32, dir3));
        }
        if frightenedSprites_.get(di) == null {
            frightenedSprites_.set(di, sprite_entities.buildGhostSprite(32, theme.ACCENT_BLUE, dir3, true, false));
        }
        if frightenedFlashSprites_.get(di) == null {
            frightenedFlashSprites_.set(di, sprite_entities.buildGhostSprite(32, theme.TEXT_PRIMARY, dir3, true, true));
        }
    }

    if dotSprite_ == null {
        dotSprite_ = sprite_items.buildDotSprite();
    }
    if pelletSprite_ == null {
        pelletSprite_ = sprite_items.buildPelletSprite();
    }
    if gateSprite_ == null {
        gateSprite_ = sprite_items.buildGateSprite();
    }
    if lifeIcon_ == null {
        lifeIcon_ = sprite_entities.buildPacmanSprite(20, config.DIR_RIGHT, true);
    }
}

expose func getWallTile(mask: Integer) -> Pixels {
    ensureStorage();
    var idx = mask;
    if idx < 0 || idx >= wallTiles_.length() {
        idx = 0;
    }
    var px = wallTiles_.get(idx);
    if px == null {
        px = sprite_maze.buildWallTile(idx);
        wallTiles_.set(idx, px);
    }
    return px;
}

expose func getPacman(direction: Integer, mouthOpen: Boolean) -> Pixels {
    ensureStorage();
    var idx = sprite_support.dirIndex(direction) * 2;
    if !mouthOpen { idx = idx + 1; }
    var px = pacmanSprites_.get(idx);
    if px == null {
        px = sprite_entities.buildPacmanSprite(32, direction, mouthOpen);
        pacmanSprites_.set(idx, px);
    }
    return px;
}

expose func getPacmanLogo(mouthOpen: Boolean) -> Pixels {
    ensureStorage();
    if mouthOpen {
        if logoPacOpen_ == null {
            logoPacOpen_ = sprite_entities.buildPacmanSprite(56, config.DIR_RIGHT, true);
        }
        return logoPacOpen_;
    }
    if logoPacClosed_ == null {
        logoPacClosed_ = sprite_entities.buildPacmanSprite(56, config.DIR_RIGHT, false);
    }
    return logoPacClosed_;
}

expose func getLifeIcon() -> Pixels {
    ensureStorage();
    if lifeIcon_ == null {
        lifeIcon_ = sprite_entities.buildPacmanSprite(20, config.DIR_RIGHT, true);
    }
    return lifeIcon_;
}

expose func getGhost(color: Integer, direction: Integer, mode: Integer, flash: Boolean) -> Pixels {
    ensureStorage();
    var d = sprite_support.dirIndex(direction);
    if mode == config.MODE_EATEN {
        var eatenPx = eatenSprites_.get(d);
        if eatenPx == null {
            eatenPx = sprite_entities.buildEatenGhostSprite(32, direction);
            eatenSprites_.set(d, eatenPx);
        }
        return eatenPx;
    }
    if mode == config.MODE_FRIGHTENED {
        if flash {
            var flashPx = frightenedFlashSprites_.get(d);
            if flashPx == null {
                flashPx = sprite_entities.buildGhostSprite(32, theme.TEXT_PRIMARY, direction, true, true);
                frightenedFlashSprites_.set(d, flashPx);
            }
            return flashPx;
        }
        var frightPx = frightenedSprites_.get(d);
        if frightPx == null {
            frightPx = sprite_entities.buildGhostSprite(32, theme.ACCENT_BLUE, direction, true, false);
            frightenedSprites_.set(d, frightPx);
        }
        return frightPx;
    }
    var idx = sprite_support.colorIndex(color) * 4 + d;
    var px = ghostSprites_.get(idx);
    if px == null {
        px = sprite_entities.buildGhostSprite(32, color, direction, false, false);
        ghostSprites_.set(idx, px);
    }
    return px;
}

expose func getGhostLogo(color: Integer) -> Pixels {
    ensureStorage();
    if color == config.COLOR_PINK {
        if logoGhostPink_ == null {
            logoGhostPink_ = sprite_entities.buildGhostSprite(44, config.COLOR_PINK, config.DIR_LEFT, false, false);
        }
        return logoGhostPink_;
    }
    if color == config.COLOR_CYAN {
        if logoGhostCyan_ == null {
            logoGhostCyan_ = sprite_entities.buildGhostSprite(44, config.COLOR_CYAN, config.DIR_LEFT, false, false);
        }
        return logoGhostCyan_;
    }
    if color == config.COLOR_ORANGE {
        if logoGhostOrange_ == null {
            logoGhostOrange_ = sprite_entities.buildGhostSprite(44, config.COLOR_ORANGE, config.DIR_LEFT, false, false);
        }
        return logoGhostOrange_;
    }
    if logoGhostRed_ == null {
        logoGhostRed_ = sprite_entities.buildGhostSprite(44, config.COLOR_RED, config.DIR_LEFT, false, false);
    }
    return logoGhostRed_;
}

expose func getFruit(kind: Integer) -> Pixels {
    ensureStorage();
    if kind <= 0 || kind >= fruitSprites_.length() {
        return null;
    }
    var px = fruitSprites_.get(kind);
    if px == null {
        px = sprite_items.buildFruitSprite(kind);
        fruitSprites_.set(kind, px);
    }
    return px;
}

expose func getDot() -> Pixels {
    ensureStorage();
    if dotSprite_ == null {
        dotSprite_ = sprite_items.buildDotSprite();
    }
    return dotSprite_;
}

expose func getPellet() -> Pixels {
    ensureStorage();
    if pelletSprite_ == null {
        pelletSprite_ = sprite_items.buildPelletSprite();
    }
    return pelletSprite_;
}

expose func getGate() -> Pixels {
    ensureStorage();
    if gateSprite_ == null {
        gateSprite_ = sprite_items.buildGateSprite();
    }
    return gateSprite_;
}
