// game.zia — Procedural 3D scene showcase with a cloud skybox.
module game;

bind Viper.Graphics3D;
bind Viper.Graphics;
bind Viper.Math;
bind Viper.Input;
bind Viper.Terminal;
bind Viper.Core.Convert as Convert;
bind "./config";

class SceneGame {
    hide Canvas3D canvas;
    hide Camera3D camera;
    hide CubeMap3D skybox;
    hide PostFX3D postfx;
    hide Particles3D energyPlume;

    hide Mesh3D planeMesh;
    hide Mesh3D boxMesh;
    hide Mesh3D sphereMesh;
    hide Mesh3D cylinderMesh;

    hide Material3D floorMat;
    hide Material3D chromeMat;
    hide Material3D goldMat;
    hide Material3D cyanMat;
    hide Material3D glowMat;
    hide Material3D glassMat;
    hide Material3D darkMat;

    hide Light3D sunLight;
    hide Light3D rimLight;
    hide Light3D coreLight;
    hide Light3D warmLight;

    hide Float sceneTime;
    hide Boolean quitRequested;
    hide String backendName;

    hide func packPixel(r: Integer, g: Integer, b: Integer, a: Integer) -> Integer {
        return (((r * 256) + g) * 256 + b) * 256 + a;
    }

    expose func initDemo(title: String, width: Integer, height: Integer) {
        canvas = Canvas3D.New(title, width, height);
        Canvas3D.SetDTMax(canvas, config.DT_MAX_MS);
        Canvas3D.SetFog(
            canvas, config.FOG_NEAR, config.FOG_FAR, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);
        Canvas3D.EnableShadows(canvas, 1);
        Canvas3D.SetShadowBias(canvas, 0.0016);
        Canvas3D.SetAmbient(canvas, 0.16, 0.19, 0.24);

        backendName = Canvas3D.get_Backend(canvas);

        var aspect = (width + 0.0) / (height + 0.0);
        camera = Camera3D.New(config.CAMERA_FOV, aspect, config.CAMERA_NEAR, config.CAMERA_FAR);

        planeMesh = Mesh3D.NewPlane(1.0, 1.0);
        boxMesh = Mesh3D.NewBox(1.0, 1.0, 1.0);
        sphereMesh = Mesh3D.NewSphere(1.0, 22);
        cylinderMesh = Mesh3D.NewCylinder(0.5, 1.0, 20);

        skybox = createSkybox();
        Canvas3D.SetSkybox(canvas, skybox);

        buildMaterials();
        buildLights();
        buildPostFx();
        buildParticles();

        sceneTime = 0.0;
        quitRequested = false;
        updateCamera();
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func run() {
        while (Canvas3D.get_ShouldClose(canvas) == 0 && quitRequested == false) {
            Canvas3D.Poll(canvas);

            var dt = (Canvas3D.get_DeltaTime(canvas) + 0.0) / 1000.0;
            if (dt <= 0.0) { dt = 0.016; }
            if (dt > config.DT_MAX_SEC) { dt = config.DT_MAX_SEC; }

            step(dt);
            renderFrame();
            Canvas3D.Flip(canvas);
        }
    }

    expose func step(dt: Float) {
        if (Keyboard.WasPressed(Keyboard.get_KEY_ESCAPE())) {
            quitRequested = true;
            return;
        }

        sceneTime = sceneTime + dt;
        Particles3D.SetPosition(energyPlume, 0.0, 1.45 + Sin(sceneTime * 1.4) * 0.12, 0.0);
        Particles3D.Update(energyPlume, dt);
        updateCamera();
    }

    expose func renderFrame() {
        Canvas3D.Clear(canvas, config.CLEAR_R, config.CLEAR_G, config.CLEAR_B);
        Canvas3D.Begin(canvas, camera);
        drawFloor();
        drawArchitecture();
        drawCenterpiece();
        drawOrbitEffects();
        Particles3D.Draw(energyPlume, canvas, camera);
        Canvas3D.End(canvas);
        drawHud();
    }

    hide func buildMaterials() {
        floorMat = Material3D.NewPBR(0.18, 0.24, 0.31);
        Material3D.SetAlbedoMap(floorMat, createFloorTexture(config.FLOOR_TEXTURE_SIZE));
        Material3D.set_Metallic(floorMat, 0.16);
        Material3D.set_Roughness(floorMat, 0.28);
        Material3D.set_Reflectivity(floorMat, 0.20);
        Material3D.SetEnvMap(floorMat, skybox);
        Material3D.SetEmissiveColor(floorMat, 0.02, 0.05, 0.08);

        chromeMat = Material3D.NewPBR(0.92, 0.96, 1.0);
        Material3D.set_Metallic(chromeMat, 1.0);
        Material3D.set_Roughness(chromeMat, 0.06);
        Material3D.set_Reflectivity(chromeMat, 0.95);
        Material3D.SetEnvMap(chromeMat, skybox);

        goldMat = Material3D.NewPBR(0.96, 0.78, 0.32);
        Material3D.set_Metallic(goldMat, 0.90);
        Material3D.set_Roughness(goldMat, 0.18);
        Material3D.set_Reflectivity(goldMat, 0.60);
        Material3D.SetEnvMap(goldMat, skybox);
        Material3D.SetEmissiveColor(goldMat, 0.10, 0.05, 0.01);

        cyanMat = Material3D.NewPBR(0.34, 0.72, 1.0);
        Material3D.set_Metallic(cyanMat, 0.34);
        Material3D.set_Roughness(cyanMat, 0.16);
        Material3D.set_Reflectivity(cyanMat, 0.36);
        Material3D.SetEnvMap(cyanMat, skybox);
        Material3D.SetEmissiveColor(cyanMat, 0.08, 0.18, 0.30);
        Material3D.set_EmissiveIntensity(cyanMat, 1.5);

        glowMat = Material3D.NewPBR(0.62, 0.88, 1.0);
        Material3D.set_Metallic(glowMat, 0.08);
        Material3D.set_Roughness(glowMat, 0.06);
        Material3D.SetEmissiveColor(glowMat, 0.34, 0.68, 1.0);
        Material3D.set_EmissiveIntensity(glowMat, 2.8);
        Material3D.set_Reflectivity(glowMat, 0.10);

        glassMat = Material3D.NewPBR(0.78, 0.90, 1.0);
        Material3D.set_Metallic(glassMat, 0.02);
        Material3D.set_Roughness(glassMat, 0.04);
        Material3D.set_AlphaMode(glassMat, 2);
        Material3D.set_Alpha(glassMat, 0.34);
        Material3D.set_DoubleSided(glassMat, true);
        Material3D.SetEnvMap(glassMat, skybox);
        Material3D.set_Reflectivity(glassMat, 0.58);
        Material3D.SetEmissiveColor(glassMat, 0.04, 0.10, 0.18);
        Material3D.set_EmissiveIntensity(glassMat, 0.9);

        darkMat = Material3D.NewPBR(0.12, 0.15, 0.18);
        Material3D.set_Metallic(darkMat, 0.14);
        Material3D.set_Roughness(darkMat, 0.62);
        Material3D.set_Reflectivity(darkMat, 0.05);
        Material3D.SetEnvMap(darkMat, skybox);
    }

    hide func buildLights() {
        sunLight = Light3D.NewDirectional(new Vec3(-0.28, -1.0, -0.16), 1.0, 0.98, 0.92);
        Light3D.SetIntensity(sunLight, 1.08);
        Canvas3D.SetLight(canvas, 0, sunLight);

        rimLight = Light3D.NewDirectional(new Vec3(0.62, -0.55, 0.50), 0.48, 0.64, 0.98);
        Light3D.SetIntensity(rimLight, 0.54);
        Canvas3D.SetLight(canvas, 1, rimLight);

        coreLight = Light3D.NewPoint(new Vec3(0.0, 4.2, 0.0), 0.46, 0.76, 1.0, 0.04);
        Light3D.SetIntensity(coreLight, 1.35);
        Canvas3D.SetLight(canvas, 2, coreLight);

        warmLight = Light3D.NewPoint(new Vec3(0.0, 1.8, 0.0), 1.0, 0.78, 0.42, 0.05);
        Light3D.SetIntensity(warmLight, 0.92);
        Canvas3D.SetLight(canvas, 3, warmLight);
    }

    hide func buildPostFx() {
        postfx = PostFX3D.New();
        PostFX3D.AddTonemap(postfx, 1, 1.16);
        PostFX3D.AddBloom(postfx, 0.78, 0.18, 3);
        PostFX3D.AddFXAA(postfx);
        PostFX3D.AddColorGrade(postfx, 0.02, 1.08, 1.10);
        PostFX3D.AddVignette(postfx, 0.84, 0.10);
        Canvas3D.SetPostFX(canvas, postfx);
    }

    hide func buildParticles() {
        energyPlume = Particles3D.New(320);
        Particles3D.SetPosition(energyPlume, 0.0, 1.45, 0.0);
        Particles3D.SetDirection(energyPlume, 0.0, 1.0, 0.0, 0.42);
        Particles3D.SetSpeed(energyPlume, 0.8, 2.4);
        Particles3D.SetLifetime(energyPlume, 0.8, 1.7);
        Particles3D.SetSize(energyPlume, 0.30, 0.05);
        Particles3D.SetGravity(energyPlume, 0.0, 0.28, 0.0);
        Particles3D.SetColor(energyPlume, 0x95E3FF, 0xFFFFFF);
        Particles3D.SetAlpha(energyPlume, 0.72, 0.0);
        Particles3D.SetRate(energyPlume, 80.0);
        Particles3D.SetTexture(energyPlume, createParticleTexture(32));
        Particles3D.SetEmitterShape(energyPlume, 1);
        Particles3D.SetEmitterSize(energyPlume, 0.25, 0.25, 0.25);
        Particles3D.set_Additive(energyPlume, true);
        Particles3D.Start(energyPlume);
    }

    hide func updateCamera() {
        var orbit = sceneTime * config.CAMERA_ORBIT_SPEED;
        var radius = config.CAMERA_RADIUS + Sin(sceneTime * 0.31) * 1.2;
        var eyeX = Cos(orbit) * radius;
        var eyeY = config.CAMERA_HEIGHT + Sin(sceneTime * 0.57) * 1.1;
        var eyeZ = Sin(orbit) * radius;
        var targetY = 2.8 + Sin(sceneTime * 0.81) * 0.25;

        Camera3D.LookAt(
            camera,
            new Vec3(eyeX, eyeY, eyeZ),
            new Vec3(0.0, targetY, 0.0),
            new Vec3(0.0, 1.0, 0.0));
    }

    hide func drawFloor() {
        Canvas3D.DrawMesh(
            canvas,
            planeMesh,
            Mat4.Mul(Mat4.Translate(0.0, 0.0, 0.0), Mat4.Scale(config.FLOOR_SIZE, 1.0, config.FLOOR_SIZE)),
            floorMat);

        for (var i: Integer = 0; i < config.PAD_COUNT; i = i + 1) {
            var angle = ((i + 0.0) / (config.PAD_COUNT + 0.0)) * 6.283185307179586;
            var px = Cos(angle) * 6.8;
            var pz = Sin(angle) * 6.8;
            var pulse = 0.90 + Sin(sceneTime * 1.6 + angle * 2.0) * 0.12;
            Canvas3D.DrawMesh(
                canvas,
                cylinderMesh,
                Mat4.Mul(
                    Mat4.Translate(px, 0.05, pz),
                    Mat4.Scale(0.80, 0.10, 0.80)),
                cyanMat);
            Canvas3D.DrawMesh(
                canvas,
                sphereMesh,
                Mat4.Mul(
                    Mat4.Translate(px, 0.22 + pulse * 0.05, pz),
                    Mat4.Scale(0.10 + pulse * 0.02, 0.10 + pulse * 0.02, 0.10 + pulse * 0.02)),
                glowMat);
        }
    }

    hide func drawArchitecture() {
        for (var i: Integer = 0; i < config.COLUMN_COUNT; i = i + 1) {
            var angle = ((i + 0.0) / (config.COLUMN_COUNT + 0.0)) * 6.283185307179586;
            var px = Cos(angle) * 10.8;
            var pz = Sin(angle) * 10.8;
            var height = 2.9 + Sin(angle * 3.0) * 0.8;
            var pulse = 0.70 + Sin(sceneTime * 1.4 + angle * 4.0) * 0.20;

            Canvas3D.DrawMesh(
                canvas,
                cylinderMesh,
                Mat4.Mul(
                    Mat4.Translate(px, height / 2.0, pz),
                    Mat4.Scale(0.72, height, 0.72)),
                darkMat);
            Canvas3D.DrawMesh(
                canvas,
                sphereMesh,
                Mat4.Mul(
                    Mat4.Translate(px, height + 0.38 + pulse * 0.05, pz),
                    Mat4.Scale(0.16 + pulse * 0.03, 0.16 + pulse * 0.03, 0.16 + pulse * 0.03)),
                glowMat);
        }

        drawGateFrame(0.0, -8.3, 0.0);
        drawGateFrame(0.0, 8.3, 0.0);
        drawGateFrame(-8.3, 0.0, 1.5707963267948966);
        drawGateFrame(8.3, 0.0, 1.5707963267948966);
    }

    hide func drawGateFrame(x: Float, z: Float, yaw: Float) {
        var leftPost =
            Mat4.Mul(
                Mat4.Mul(
                    Mat4.Translate(x + Cos(yaw) * -2.2, 2.4, z + Sin(yaw) * -2.2),
                    Mat4.RotateY(yaw)),
                Mat4.Scale(0.48, 4.8, 0.48));
        var rightPost =
            Mat4.Mul(
                Mat4.Mul(
                    Mat4.Translate(x + Cos(yaw) * 2.2, 2.4, z + Sin(yaw) * 2.2),
                    Mat4.RotateY(yaw)),
                Mat4.Scale(0.48, 4.8, 0.48));
        var bridge =
            Mat4.Mul(
                Mat4.Mul(
                    Mat4.Translate(x, 4.9, z),
                    Mat4.RotateY(yaw)),
                Mat4.Scale(4.9, 0.30, 0.40));
        var glowBridge =
            Mat4.Mul(
                Mat4.Mul(
                    Mat4.Translate(x, 4.52, z),
                    Mat4.RotateY(yaw)),
                Mat4.Scale(3.6, 0.06, 0.18));

        Canvas3D.DrawMesh(canvas, boxMesh, leftPost, darkMat);
        Canvas3D.DrawMesh(canvas, boxMesh, rightPost, darkMat);
        Canvas3D.DrawMesh(canvas, boxMesh, bridge, goldMat);
        Canvas3D.DrawMesh(canvas, boxMesh, glowBridge, glowMat);
    }

    hide func drawCenterpiece() {
        var bob = Sin(sceneTime * 1.2) * 0.18;
        var shellScale = 1.45 + Sin(sceneTime * 0.8) * 0.04;

        Canvas3D.DrawMesh(
            canvas,
            cylinderMesh,
            Mat4.Mul(Mat4.Translate(0.0, 0.48, 0.0), Mat4.Scale(2.45, 0.96, 2.45)),
            darkMat);
        Canvas3D.DrawMesh(
            canvas,
            cylinderMesh,
            Mat4.Mul(Mat4.Translate(0.0, 1.05, 0.0), Mat4.Scale(1.36, 0.18, 1.36)),
            cyanMat);
        Canvas3D.DrawMesh(
            canvas,
            cylinderMesh,
            Mat4.Mul(Mat4.Translate(0.0, 2.8, 0.0), Mat4.Scale(0.42, 3.6, 0.42)),
            chromeMat);
        Canvas3D.DrawMesh(
            canvas,
            sphereMesh,
            Mat4.Mul(Mat4.Translate(0.0, 3.95 + bob, 0.0), Mat4.Scale(0.92, 0.92, 0.92)),
            chromeMat);
        Canvas3D.DrawMesh(
            canvas,
            sphereMesh,
            Mat4.Mul(
                Mat4.Translate(0.0, 3.95 + bob, 0.0),
                Mat4.Scale(shellScale, shellScale, shellScale)),
            glassMat);
        Canvas3D.DrawMesh(
            canvas,
            sphereMesh,
            Mat4.Mul(
                Mat4.Translate(0.0, 5.82 + bob * 0.6, 0.0),
                Mat4.Scale(0.20, 0.20, 0.20)),
            glowMat);
    }

    hide func drawOrbitEffects() {
        for (var i: Integer = 0; i < config.SHARD_COUNT; i = i + 1) {
            var angle = ((i + 0.0) / (config.SHARD_COUNT + 0.0)) * 6.283185307179586 + sceneTime * 0.72;
            var radius = 3.30 + Sin(sceneTime * 0.9 + angle * 3.0) * 0.14;
            var px = Cos(angle) * radius;
            var py = 3.02 + Sin(sceneTime * 1.7 + angle * 4.0) * 0.24;
            var pz = Sin(angle) * radius;
            var twist = Sin(sceneTime * 1.1 + angle * 2.0) * 0.28;
            var rot = Mat4.Mul(Mat4.RotateY(0.0 - angle), Mat4.RotateZ(twist));
            var xform =
                Mat4.Mul(
                    Mat4.Mul(Mat4.Translate(px, py, pz), rot),
                    Mat4.Scale(0.22, 0.10, 1.30));

            if ((i % 2) == 0) {
                Canvas3D.DrawMesh(canvas, boxMesh, xform, goldMat);
            } else {
                Canvas3D.DrawMesh(canvas, boxMesh, xform, cyanMat);
            }
        }

        for (var j: Integer = 0; j < config.ORB_COUNT; j = j + 1) {
            var angleB = ((j + 0.0) / (config.ORB_COUNT + 0.0)) * 6.283185307179586 - sceneTime * 0.55;
            var orbX = Cos(angleB) * 1.9;
            var orbY = 3.1 + Sin(angleB) * 1.95;
            var orbZ = Sin(sceneTime * 0.9 + angleB * 1.4) * 2.55;
            var scale = 0.12 + (0.5 + 0.5 * Sin(sceneTime * 2.0 + angleB * 3.0)) * 0.05;
            Canvas3D.DrawMesh(
                canvas,
                sphereMesh,
                Mat4.Mul(Mat4.Translate(orbX, orbY, orbZ), Mat4.Scale(scale, scale, scale)),
                glowMat);
        }

        for (var k: Integer = 0; k < 10; k = k + 1) {
            var angleC = ((k + 0.0) / 10.0) * 6.283185307179586 + sceneTime * 0.95;
            var sparkX = Cos(angleC) * 5.2;
            var sparkY = 1.6 + Sin(sceneTime * 1.3 + angleC * 2.2) * 0.46;
            var sparkZ = Sin(angleC) * 5.2;
            Canvas3D.DrawMesh(
                canvas,
                sphereMesh,
                Mat4.Mul(Mat4.Translate(sparkX, sparkY, sparkZ), Mat4.Scale(0.08, 0.08, 0.08)),
                cyanMat);
        }
    }

    hide func drawHud() {
        Canvas3D.DrawRect2D(canvas, 18, 18, 424, 88, config.HUD_PANEL);
        Canvas3D.DrawRect2D(canvas, 24, 24, 412, 20, config.HUD_CARD);
        Canvas3D.DrawText2D(canvas, 34, 28, "3D SCENE", config.HUD_GOLD);
        Canvas3D.DrawText2D(
            canvas, 34, 54, "Autopilot camera • procedural sky • reflective sculpture", config.HUD_TEXT);
        Canvas3D.DrawText2D(canvas, 34, 74, "ESC quit • backend: " + backendName, config.HUD_MUTED);
        Canvas3D.DrawText2D(canvas, 34, 92, "Blue skybox with cloud layers and animated energy plume", config.HUD_ACCENT);
    }

    hide func createSkybox() -> CubeMap3D {
        return CubeMap3D.New(
            createSkyFace(0),
            createSkyFace(1),
            createSkyFace(2),
            createSkyFace(3),
            createSkyFace(4),
            createSkyFace(5));
    }

    hide func createSkyFace(faceId: Integer) -> Pixels {
        var size = config.SKYBOX_FACE_SIZE;
        var face = Pixels.New(size, size);

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var u = (((px + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                var v = (((py + 0.5) / (size + 0.0)) * 2.0) - 1.0;
                face.Set(px, py, sampleSkyPixelForFace(faceId, u, v));
            }
        }

        return face;
    }

    hide func sampleSkyPixelForFace(faceId: Integer, u: Float, v: Float) -> Integer {
        var dx = 0.0;
        var dy = 0.0;
        var dz = 0.0;

        if (faceId == 0) {
            dx = 1.0;
            dy = 0.0 - v;
            dz = 0.0 - u;
        } else {
            if (faceId == 1) {
                dx = -1.0;
                dy = 0.0 - v;
                dz = u;
            } else {
                if (faceId == 2) {
                    dx = u;
                    dy = 1.0;
                    dz = v;
                } else {
                    if (faceId == 3) {
                        dx = u;
                        dy = -1.0;
                        dz = 0.0 - v;
                    } else {
                        if (faceId == 4) {
                            dx = u;
                            dy = 0.0 - v;
                            dz = 1.0;
                        } else {
                            dx = 0.0 - u;
                            dy = 0.0 - v;
                            dz = -1.0;
                        }
                    }
                }
            }
        }

        var len = Sqrt(dx * dx + dy * dy + dz * dz);
        if (len <= 0.0001) {
            return packPixel(152, 198, 245, 255);
        }

        return sampleSkyPixel(dx / len, dy / len, dz / len);
    }

    hide func sampleSkyPixel(dx: Float, dy: Float, dz: Float) -> Integer {
        var up = clampFloat((dy + 0.22) / 1.22, 0.0, 1.0);
        var horizon = clampFloat(1.0 - absFloat(dy) * 2.3, 0.0, 1.0);
        var cloud = sampleCloudMask(dx, dy, dz);

        var r = lerpFloat(178.0, 78.0, up) + horizon * 14.0;
        var g = lerpFloat(216.0, 144.0, up) + horizon * 11.0;
        var b = lerpFloat(248.0, 223.0, up) + horizon * 7.0;

        if (dy < -0.12) {
            var under = clampFloat((0.0 - dy - 0.12) / 0.88, 0.0, 1.0);
            r = lerpFloat(r, 116.0, under);
            g = lerpFloat(g, 138.0, under);
            b = lerpFloat(b, 156.0, under);
            cloud = cloud * (1.0 - under);
        }

        r = lerpFloat(r, 255.0, cloud * 0.92);
        g = lerpFloat(g, 255.0, cloud * 0.95);
        b = lerpFloat(b, 255.0, cloud);

        return packPixel(
            clampByte(Convert.NumToInt(r)),
            clampByte(Convert.NumToInt(g)),
            clampByte(Convert.NumToInt(b)),
            255);
    }

    hide func sampleCloudMask(dx: Float, dy: Float, dz: Float) -> Float {
        var band = clampFloat(1.0 - absFloat(dy - 0.18) * 2.0, 0.0, 1.0);
        var field =
            Sin(dx * 6.4 + Sin(dz * 3.1) * 0.8) * 0.48 +
            Cos(dz * 7.6 - dx * 5.2 + Cos(dx * 4.0) * 0.5) * 0.30 +
            Sin((dx + dz) * 12.2 + dy * 4.8) * 0.16 +
            Cos((dx - dz) * 17.0 - dy * 2.7) * 0.06;
        var wisps = (0.5 + 0.5 * Sin(dx * 18.0 - dz * 11.0 + dy * 9.0)) * 0.18;
        var mask = clampFloat((field + band * 0.56 + wisps - 0.34) / 0.54, 0.0, 1.0);
        mask = mask * mask * (3.0 - 2.0 * mask);
        return mask * clampFloat((dy + 0.04) / 1.04, 0.0, 1.0);
    }

    hide func createFloorTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);
        var half = size / 2;

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var dx = ((px - half) + 0.0) / (size + 0.0);
                var dz = ((py - half) + 0.0) / (size + 0.0);
                var dist = Sqrt(dx * dx + dz * dz);
                var core = clampFloat(1.0 - dist * 2.6, 0.0, 1.0);
                var ringGlow = clampFloat(0.12 - absFloat(Sin(dist * 82.0)), 0.0, 0.12) * 5.6;
                var diag = (0.5 + 0.5 * Sin(dx * 42.0) * Cos(dz * 42.0)) * 0.18;

                var grid = 0.0;
                if ((px % 32) < 2 || (py % 32) < 2) {
                    grid = 1.0;
                }

                var r = 24.0 + core * 16.0 + ringGlow * 36.0 + grid * 20.0 + diag * 24.0;
                var g = 32.0 + core * 22.0 + ringGlow * 44.0 + grid * 30.0 + diag * 32.0;
                var b = 42.0 + core * 34.0 + ringGlow * 56.0 + grid * 40.0 + diag * 40.0;

                tex.Set(
                    px,
                    py,
                    packPixel(
                        clampByte(Convert.NumToInt(r)),
                        clampByte(Convert.NumToInt(g)),
                        clampByte(Convert.NumToInt(b)),
                        255));
            }
        }

        return tex;
    }

    hide func createParticleTexture(size: Integer) -> Pixels {
        var tex = Pixels.New(size, size);
        var half = size / 2;

        for (var py: Integer = 0; py < size; py = py + 1) {
            for (var px: Integer = 0; px < size; px = px + 1) {
                var dx = ((px - half) + 0.0) / (half + 0.0);
                var dy = ((py - half) + 0.0) / (half + 0.0);
                var dist = Sqrt(dx * dx + dy * dy);
                var alpha = clampFloat(1.0 - dist, 0.0, 1.0);
                alpha = alpha * alpha;

                var r = lerpFloat(110.0, 255.0, alpha);
                var g = lerpFloat(190.0, 255.0, alpha);
                var b = 255.0;
                tex.Set(
                    px,
                    py,
                    packPixel(
                        clampByte(Convert.NumToInt(r)),
                        clampByte(Convert.NumToInt(g)),
                        clampByte(Convert.NumToInt(b)),
                        clampByte(Convert.NumToInt(alpha * 255.0))));
            }
        }

        return tex;
    }

    hide func clampByte(value: Integer) -> Integer {
        if (value < 0) { return 0; }
        if (value > 255) { return 255; }
        return value;
    }

    hide func clampFloat(value: Float, lo: Float, hi: Float) -> Float {
        if (value < lo) { return lo; }
        if (value > hi) { return hi; }
        return value;
    }

    hide func absFloat(value: Float) -> Float {
        if (value < 0.0) { return 0.0 - value; }
        return value;
    }

    hide func lerpFloat(a: Float, b: Float, t: Float) -> Float {
        return a + (b - a) * t;
    }
}
