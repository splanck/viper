module smoke_probe;

bind Viper.Graphics3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.IO.Path as Path;
bind Viper.IO.TempFile as TempFile;
bind Viper.Math as Math;
bind Viper.Terminal as Terminal;
bind "./game";

func red(px: Integer) -> Integer {
    return Math.Bits.And(px >> 24, 0xFF);
}

func green(px: Integer) -> Integer {
    return Math.Bits.And(px >> 16, 0xFF);
}

func blue(px: Integer) -> Integer {
    return Math.Bits.And(px >> 8, 0xFF);
}

func luminance(px: Integer) -> Integer {
    return (red(px) * 30 + green(px) * 59 + blue(px) * 11) / 100;
}

func avgLuma(img: Pixels, x0: Integer, y0: Integer, x1: Integer, y1: Integer, step: Integer) -> Integer {
    var sum = 0;
    var count = 0;
    var y = y0;
    while (y <= y1) {
        var x = x0;
        while (x <= x1) {
            sum = sum + luminance(Pixels.Get(img, x, y));
            count = count + 1;
            x = x + step;
        }
        y = y + step;
    }
    if (count <= 0) { return 0; }
    return sum / count;
}

func assertNoHardCornerVignette(img: Pixels) -> Boolean {
    if (img == null) {
        Terminal.Say("RESULT: fail screenshot null");
        return false;
    }
    var w = Pixels.get_Width(img);
    var h = Pixels.get_Height(img);
    if (w < 64 || h < 64) {
        Terminal.Say("RESULT: fail screenshot size");
        return false;
    }

    var center = avgLuma(img, w / 2 - 24, h / 2 - 16, w / 2 + 24, h / 2 + 16, 8);
    var left = avgLuma(img, 4, h - 40, 44, h - 4, 8);
    var right = avgLuma(img, w - 44, h - 40, w - 4, h - 4, 8);
    var corners = (left + right) / 2;
    if (center > 32 && corners < 10) {
        Terminal.Say("RESULT: fail hard corner vignette");
        return false;
    }
    return true;
}

func main() {
    var demo = new SceneGame();
    demo.configureSmokeProbe();
    demo.initDemo("3D Scene Smoke", 320, 180);
    demo.step(0.016);
    demo.renderFrame();

    var snap = demo.getCanvas().ScreenshotFinal();
    if (assertNoHardCornerVignette(snap) == false) {
        return;
    }
    if Pixels.SavePng(snap, Path.Join(TempFile.Dir(), "3dscene_smoke.png")) != 1 {
        Terminal.Say("RESULT: fail screenshot");
        return;
    }

    Canvas3D.Flip(demo.getCanvas());
    Terminal.Say("RESULT: ok");
}
