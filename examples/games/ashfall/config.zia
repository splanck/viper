var A_CROUCH: Integer = 5;
var A_SPRINT: Integer = 6;
var A_FIRE: Integer = 7;
var A_ADS: Integer = 8;
var A_RELOAD: Integer = 9;
var A_INTERACT: Integer = 10;
var A_GRENADE: Integer = 11;
var A_CYCLE_GRENADE: Integer = 12;
var A_MELEE: Integer = 13;
