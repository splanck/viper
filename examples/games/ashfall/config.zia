// --- Levels ------------------------------------------------------------------
var LV_ARENA: Integer = 0;
var LV_L1: Integer = 1;
var LV_L2: Integer = 2;
var LV_L3: Integer = 3;
var LV_L4: Integer = 4;
var LV_L5: Integer = 5;
var LV_L6: Integer = 6;
var LV_L7: Integer = 7;
