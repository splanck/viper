    lb.addProp(props.PROP_PYLON, 10.0, 0.0, 24.0, 0.0, 1.0);
    lb.addProp(props.PROP_PYLON, -3.0, 0.0, -18.0, 0.0, 1.0);
    lb.addProp(props.PROP_PYLON, 3.0, 0.0, -18.0, 0.0, 1.0);
    // Server racks + storage + the radar dish under the skylight.
    lb.addProp(props.PROP_RACK, -10.0, 0.0, -22.5, 0.2, 1.0);
    lb.addProp(props.PROP_RACK, 10.0, 0.0, -22.5, -0.15, 1.0);
