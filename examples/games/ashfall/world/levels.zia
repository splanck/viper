// =============================================================================
// world/levels.zia — nine combat arenas + the Redoubt hub
// =============================================================================
//
// One builder per level fills a LevelBuilder (geometry/lights/spawns/pickups) +
// Objectives. Each mission is a combat-first space with a distinct silhouette,
// landmark, route, vertical option, encounter rhythm, and authored material
// palette. The level manager picks the builder by level id.
// =============================================================================
module levels;

bind Zanna.Math as Math;
bind "../config" as config;
bind "./level_base" as level_base;
bind "./objectives" as objectives;
bind "./props" as props;
bind "../assets/textures" as textures;

// Dispatch: fill lb + obj for the given level id.
func build(levelId: Integer, lb: level_base.LevelBuilder, obj: objectives.Objectives) {
    lb.reset();
    obj.clear();
    if levelId == config.LV_L1 { buildL1(lb, obj); }
    else if levelId == config.LV_L2 { buildL2(lb, obj); }
    else if levelId == config.LV_L3 { buildL3(lb, obj); }
    else if levelId == config.LV_L4 { buildL4(lb, obj); }
    else if levelId == config.LV_L5 { buildL5(lb, obj); }
    else if levelId == config.LV_L6 { buildL6(lb, obj); }
    else if levelId == config.LV_L7 { buildL7(lb, obj); }
    else if levelId == config.LV_L8 { buildL8(lb, obj); }
    else if levelId == config.LV_L9 { buildL9(lb, obj); }
    else if levelId == config.LV_HUB { buildHub(lb, obj); }
    else { buildL1(lb, obj); }
    finishLevelMeta(levelId, lb);
}

// Scatter cover in a ring: the colliding block keeps its frozen footprint, and
// each position gains non-colliding dressing (offset caps/slabs) so cover reads
// as belonging to the level instead of floating primitives.
hide func scatterCover(lb: level_base.LevelBuilder, count: Integer, radius: Float, r: Float, g: Float, b: Float) {
    scatterCoverMat(lb, count, radius, textures.SURF_DEFAULT, r, g, b);
}

hide func scatterCoverMat(lb: level_base.LevelBuilder, count: Integer, radius: Float,
                          surf: Integer, r: Float, g: Float, b: Float) {
    var i = 0;
    while i < count {
        var ang = (i + 0.0) / (count + 0.0) * 6.2831853;
        var cx = Math.Cos(ang) * radius;
        var cz = Math.Sin(ang) * radius;
        lb.addBoxMat(cx, 0.8, cz, 0.8, 0.8, 0.8, surf, r, g, b, true);
        lb.addCover(cx, cz, 0.0 - Math.Cos(ang), 0.0 - Math.Sin(ang));
        // Dressing: a smaller offset cap + a ground skirt (visual only).
        var ox = Math.Cos(ang + 0.9) * 0.55;
        var oz = Math.Sin(ang + 0.9) * 0.55;
        lb.addBoxMat(cx + ox, 1.75, cz + oz, 0.45, 0.22, 0.4, surf,
                     r * 0.92, g * 0.92, b * 0.92, false);
        lb.addBoxMat(cx - ox, 0.22, cz - oz, 1.15, 0.22, 1.05, surf,
                     r * 0.85, g * 0.85, b * 0.85, false);
        i = i + 1;
    }
}

/// Add a low emissive-style guide strip to make the intended route readable.
///
/// Strips are visual-only floor decals built from thin boxes so the graybox
/// level language can communicate path direction without adding a decal system.
hide func addGuide(lb: level_base.LevelBuilder, x: Float, z: Float, hx: Float, hz: Float) {
    lb.addBoxMat(x, 0.035, z, hx, 0.035, hz, textures.SURF_ACCENT,
                 0.92, 0.62, 0.18, false);
    lb.addRouteMarker(x, z, 0);
    // Low route posts make the intended path visible in first-person without
    // relying only on a flat floor strip.
    lb.addBoxMat(x, 0.45, z, 0.08, 0.45, 0.08, textures.SURF_ACCENT,
                 1.0, 0.72, 0.24, false);
    lb.addBoxMat(x, 0.96, z, 0.18, 0.05, 0.18, textures.SURF_ACCENT,
                 1.0, 0.78, 0.30, false);
}

/// Mark a visible prop or collider as useful AI cover.
///
/// The authored geometry stays responsible for sightline blocking; this helper
/// only adds the metadata ranged enemies use to choose believable firing pockets.
hide func markCover(lb: level_base.LevelBuilder, x: Float, z: Float, faceX: Float, faceZ: Float) {
    lb.addCover(x, z, faceX, faceZ);
}

hide func markFlank(lb: level_base.LevelBuilder, x: Float, z: Float) {
    lb.addFlank(x, z);
    lb.addBoxMat(x, 0.05, z, 0.22, 0.05, 0.22, textures.SURF_ACCENT,
                 0.45, 0.72, 1.0, false);
}

hide func markLandmark(lb: level_base.LevelBuilder, x: Float, z: Float, kind: Integer) {
    lb.addLandmark(x, z, kind);
    lb.addRouteMarker(x, z, kind + 1);
}

hide func markBeat(lb: level_base.LevelBuilder, x: Float, z: Float, kind: Integer, wave: Integer) {
    lb.addEncounterBeat(x, z, kind, wave);
}

hide func addFloorArrow(lb: level_base.LevelBuilder, x: Float, z: Float, axis: Integer) {
    if axis == 0 {
        lb.addBoxMat(x, 0.055, z, 0.18, 0.035, 0.72, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
        lb.addBoxMat(x - 0.32, 0.06, z - 0.48, 0.35, 0.035, 0.10, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
        lb.addBoxMat(x + 0.32, 0.06, z - 0.48, 0.35, 0.035, 0.10, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
    } else {
        lb.addBoxMat(x, 0.055, z, 0.72, 0.035, 0.18, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
        lb.addBoxMat(x + 0.48, 0.06, z - 0.32, 0.10, 0.035, 0.35, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
        lb.addBoxMat(x + 0.48, 0.06, z + 0.32, 0.10, 0.035, 0.35, textures.SURF_ACCENT,
                     0.95, 0.68, 0.22, false);
    }
    lb.addRouteMarker(x, z, 0);
}

hide func addObjectivePad(lb: level_base.LevelBuilder, x: Float, z: Float,
                          hx: Float, hz: Float, kind: Integer) {
    lb.addBoxMat(x, 0.045, z, hx, 0.035, hz, textures.SURF_ACCENT,
                 0.30, 0.86, 1.0, false);
    lb.addBoxMat(x, 0.075, z - hz, hx, 0.035, 0.08, textures.SURF_ACCENT,
                 0.95, 0.70, 0.22, false);
    lb.addBoxMat(x, 0.075, z + hz, hx, 0.035, 0.08, textures.SURF_ACCENT,
                 0.95, 0.70, 0.22, false);
    lb.addBoxMat(x - hx, 0.075, z, 0.08, 0.035, hz, textures.SURF_ACCENT,
                 0.95, 0.70, 0.22, false);
    lb.addBoxMat(x + hx, 0.075, z, 0.08, 0.035, hz, textures.SURF_ACCENT,
                 0.95, 0.70, 0.22, false);
    lb.addRouteMarker(x, z, kind);
}

hide func addBulkheadRib(lb: level_base.LevelBuilder, x: Float, z: Float,
                         hx: Float, hz: Float, wallSurf: Integer) {
    lb.addBoxMat(x, 2.8, z, hx, 2.8, hz, wallSurf, 0.32, 0.33, 0.36, false);
    lb.addBoxMat(x, 5.65, z, hx + 0.1, 0.08, hz + 0.1, textures.SURF_ACCENT,
                 0.55, 0.72, 0.95, false);
}

hide func addHazardLip(lb: level_base.LevelBuilder, x: Float, z: Float, hx: Float, hz: Float) {
    lb.addBoxMat(x, 0.055, z, hx, 0.035, hz, textures.SURF_HAZARD,
                 0.95, 0.68, 0.12, false);
}

/// Build collision-backed stairs whose individual rises stay within the player
/// controller's step limit. `axis` 0 climbs X and 1 climbs Z; `dir` is -1 or 1.
/// Accent nosings make the climb readable during a fight and keep raised routes
/// from looking like unreachable background dressing.
hide func addCombatStairs(lb: level_base.LevelBuilder, startX: Float, startZ: Float,
                          axis: Integer, dir: Float, count: Integer,
                          tread: Float, rise: Float, halfWidth: Float,
                          surf: Integer) {
    var i = 0;
    while i < count {
        var cx = startX;
        var cz = startZ;
        var hx = halfWidth;
        var hz = halfWidth;
        if axis == 0 {
            cx = startX + dir * (i + 0.0) * tread;
            hx = tread * 0.5 + 0.02;
        } else {
            cz = startZ + dir * (i + 0.0) * tread;
            hz = tread * 0.5 + 0.02;
        }
        var top = (i + 1.0) * rise;
        lb.addBoxMat(cx, top * 0.5, cz, hx, top * 0.5, hz, surf,
                     0.44, 0.47, 0.52, true);
        var noseX = cx;
        var noseZ = cz;
        var nhx = hx;
        var nhz = 0.035;
        if axis == 0 {
            noseX = cx + dir * tread * 0.42;
            nhx = 0.035;
            nhz = hz;
        } else {
            noseZ = cz + dir * tread * 0.42;
        }
        lb.addBoxMat(noseX, top + 0.012, noseZ, nhx, 0.012, nhz,
                     textures.SURF_ACCENT, 0.66, 0.82, 1.0, false);
        i = i + 1;
    }
}

hide func finishLevelMeta(levelId: Integer, lb: level_base.LevelBuilder) {
    if levelId == config.LV_L1 {
        markLandmark(lb, 0.0, -20.0, 0);
        markLandmark(lb, 0.0, -34.0, 1);
        markFlank(lb, -12.0, -8.0); markFlank(lb, 12.0, -12.0);
        markBeat(lb, 0.0, 24.0, 0, 0); markBeat(lb, -5.0, 8.0, 1, 1);
        markBeat(lb, 4.0, -10.0, 1, 2); markBeat(lb, 0.0, -25.0, 1, 3);
    } else if levelId == config.LV_L2 {
        markLandmark(lb, 0.0, -18.0, 2);
        markLandmark(lb, 18.0, -20.0, 0);
        markFlank(lb, -13.0, -4.0); markFlank(lb, 13.0, -4.0);
        markBeat(lb, 0.0, 12.0, 2, 0); markBeat(lb, 0.0, 4.0, 2, 1);
        markBeat(lb, 0.0, -6.0, 2, 2); markBeat(lb, 0.0, -16.0, 2, 3);
    } else if levelId == config.LV_L3 {
        markLandmark(lb, 0.0, -47.5, 1);
        markLandmark(lb, 0.0, 0.0, 0);
        markFlank(lb, -4.0, 20.0); markFlank(lb, 4.0, -20.0);
        markBeat(lb, 0.0, 30.0, 0, 0); markBeat(lb, 0.0, 10.0, 1, 1);
        markBeat(lb, 0.0, -10.0, 1, 2); markBeat(lb, 0.0, -30.0, 1, 3);
    } else if levelId == config.LV_L4 {
        markLandmark(lb, 0.0, -33.4, 0);
        markLandmark(lb, 0.0, -24.0, 2);
        markFlank(lb, -18.0, 10.0); markFlank(lb, 18.0, 10.0);
        markBeat(lb, 0.0, 22.0, 0, 0); markBeat(lb, -16.0, 6.0, 1, 1);
        markBeat(lb, 16.0, -8.0, 1, 2); markBeat(lb, 0.0, -24.0, 2, 3);
    } else if levelId == config.LV_L5 {
        markLandmark(lb, -12.0, -14.0, 3);
        markLandmark(lb, 0.0, -24.0, 2);
        markFlank(lb, -18.0, 12.0); markFlank(lb, 18.0, -12.0);
        markBeat(lb, 0.0, 20.0, 0, 0); markBeat(lb, -18.0, 6.0, 1, 1);
        markBeat(lb, 16.0, -8.0, 1, 2); markBeat(lb, 0.0, -22.0, 1, 3);
    } else if levelId == config.LV_L6 {
        markLandmark(lb, 0.0, 0.0, 3);
        markLandmark(lb, 0.0, -14.0, 1);
        markFlank(lb, -16.0, 0.0); markFlank(lb, 16.0, 0.0);
        markBeat(lb, 0.0, 0.0, 2, 0); markBeat(lb, 0.0, 0.0, 2, 1);
        markBeat(lb, 0.0, 0.0, 2, 2); markBeat(lb, 0.0, 0.0, 2, 3);
        markBeat(lb, 0.0, 0.0, 2, 4);
    } else if levelId == config.LV_L7 {
        markLandmark(lb, 14.0, 4.0, 3);
        markLandmark(lb, 0.0, -22.0, 0);
        markFlank(lb, -16.0, 10.0); markFlank(lb, 16.0, 10.0);
        markBeat(lb, 0.0, -22.0, 3, 0); markBeat(lb, -12.0, 0.0, 2, 1);
        markBeat(lb, 12.0, 0.0, 2, 2);
    } else if levelId == config.LV_L8 {
        markLandmark(lb, 0.0, -44.0, 0);
        markLandmark(lb, 0.0, 0.0, 3);
        markFlank(lb, -20.0, 0.0); markFlank(lb, 20.0, 0.0);
        markBeat(lb, 0.0, -28.0, 3, 0); markBeat(lb, -18.0, 8.0, 2, 1);
        markBeat(lb, 18.0, -8.0, 2, 2);
    } else if levelId == config.LV_L9 {
        markLandmark(lb, 0.0, 0.0, 0);
        markLandmark(lb, 0.0, 26.0, 1);
        markFlank(lb, -14.0, 8.0); markFlank(lb, 14.0, 8.0);
        markBeat(lb, 0.0, -26.0, 3, 0); markBeat(lb, -13.0, 8.0, 2, 1);
        markBeat(lb, 13.0, -8.0, 2, 2); markBeat(lb, 0.0, 16.0, 2, 3);
    } else if levelId == config.LV_HUB {
        markLandmark(lb, 0.0, -8.0, 2);
        markLandmark(lb, 0.0, -13.0, 0);
        lb.addRouteMarker(0.0, -8.0, 3);
    }
}

// L1 — Crashsite Canyon: dawn canyon under the wreck arch (terrain rim hero).
hide func buildL1(lb: level_base.LevelBuilder, obj: objectives.Objectives) {
    lb.setName("Crashsite Canyon");
    lb.setAmbient(0.26, 0.22, 0.20);
    lb.setStart(0.0, 0.2, 34.0, 0.0);
    lb.setTerrain(1);                      // canyon rim rises outside the walls
    // Shell: ash-rock floor, canyon-wall berms.
    lb.addArenaShellMat(40.0, 8.0, textures.SURF_ROCK, textures.SURF_ROCK,
                        0.42, 0.36, 0.31, 0.40, 0.34, 0.30);
    // Directed canyon route: broken berms form a readable S-curve from the
    // drop-in to the wreck, then toward the lit relay exit.
    lb.addBoxMat(-18.0, 1.0, 22.0, 1.0, 1.0, 10.0, textures.SURF_ROCK, 0.38, 0.32, 0.28, true);
    lb.addBoxMat(18.0, 1.0, 14.0, 1.0, 1.0, 9.0, textures.SURF_ROCK, 0.38, 0.32, 0.28, true);
    lb.addBoxMat(-14.0, 0.8, 2.0, 1.0, 0.8, 8.0, textures.SURF_ROCK, 0.40, 0.34, 0.30, true);
    lb.addBoxMat(15.0, 0.8, -8.0, 1.0, 0.8, 8.0, textures.SURF_ROCK, 0.40, 0.34, 0.30, true);
    scatterCoverMat(lb, 5, 12.0, textures.SURF_ROCK, 0.42, 0.36, 0.30);
    // Wreckage cluster under the arch (collider kept at its frozen footprint).
    lb.addBoxMat(0.0, 1.2, -20.0, 4.0, 1.2, 2.0, textures.SURF_HULL, 0.44, 0.38, 0.32, true);
    lb.addBoxMat(-3.2, 0.5, -17.5, 1.4, 0.5, 1.0, textures.SURF_HULL, 0.40, 0.34, 0.30, false);
    lb.addBoxMat(3.6, 0.4, -22.4, 1.2, 0.4, 1.4, textures.SURF_HULL, 0.38, 0.33, 0.29, false);
    // Hero: the 26 m hull arch spanning the canyon over the wreck site.
    lb.addProp(props.PROP_WRECKHULL, 0.0, 0.0, -20.0, 0.0, 1.0);
    // Debris field + supply dressing near the drop-in.
    lb.addProp(props.PROP_DEBRIS, -10.0, 0.0, -26.0, 0.7, 1.1);
    lb.addProp(props.PROP_DEBRIS, 12.0, 0.0, -24.0, 2.4, 0.9);
    lb.addProp(props.PROP_DEBRIS, -14.0, 0.0, 6.0, 4.1, 1.0);
    lb.addProp(props.PROP_DEBRIS, 18.0, 0.0, -6.0, 1.2, 1.2);
    lb.addProp(props.PROP_CRATE, 5.6, 0.0, 22.0, 0.4, 1.0);
    lb.addProp(props.PROP_CRATE, 6.9, 0.0, 22.6, 1.1, 0.8);
    lb.addProp(props.PROP_BARREL, -5.5, 0.0, 21.4, 0.0, 1.0);
    lb.addProp(props.PROP_BARREL, -6.4, 0.0, 22.3, 0.0, 1.0);
    lb.addProp(props.PROP_LAMPPOST, -3.6, 0.0, 18.0, 0.2, 1.0);
    lb.addProp(props.PROP_LAMPPOST, 3.8, 0.0, 6.0, -0.4, 1.0);
    lb.addProp(props.PROP_DOORFRAME, 0.0, 0.0, -34.0, 0.0, 1.2);
    lb.addGate(0.0, 1.35, -31.8, 4.8, 1.35, 0.22, 0);
    lb.addProp(props.PROP_PYLON, -4.0, 0.0, -33.0, 0.0, 1.0);
    lb.addProp(props.PROP_PYLON, 4.0, 0.0, -33.0, 0.0, 1.0);
    lb.addProp(props.PROP_STALAGMITE, -24.0, 0.0, -30.0, 0.8, 1.6);
    lb.addProp(props.PROP_STALAGMITE, 27.0, 0.0, -14.0, 2.2, 1.3);
    lb.addProp(props.PROP_STALAGMITE, -30.0, 0.0, 12.0, 3.9, 1.8);
    lb.addProp(props.PROP_STALAGMITE, 25.0, 0.0, 24.0, 5.0, 1.2);
    // Practicals: warm nav pools at the wreck + cool rim accent.
    lb.addPoint(0.0, 6.0, -20.0, 0.9, 0.55, 0.3, 18.0);
    lb.addPoint(-8.0, 2.5, -16.0, 0.8, 0.5, 0.25, 10.0);
    lb.addPoint(6.0, 2.0, 24.0, 0.5, 0.55, 0.7, 9.0);
    lb.addPoint(0.0, 2.8, -34.0, 1.0, 0.78, 0.25, 12.0);
    addGuide(lb, 0.0, 25.0, 0.5, 1.8);
    addGuide(lb, -5.0, 12.0, 1.8, 0.5);
    addGuide(lb, 0.0, -2.0, 0.5, 2.2);
    addGuide(lb, 4.5, -17.0, 1.8, 0.5);
    addGuide(lb, 0.0, -29.0, 0.7, 2.2);
    addFloorArrow(lb, 0.0, 28.0, 0);
    addFloorArrow(lb, -5.0, 12.0, 1);
    addFloorArrow(lb, 4.5, -17.0, 1);
    addObjectivePad(lb, 0.0, -34.0, 1.9, 1.1, 2);
    lb.addBoxMat(-8.0, 0.18, -31.0, 2.6, 0.18, 0.22, textures.SURF_HULL, 0.35, 0.30, 0.27, false);
    lb.addBoxMat(8.0, 0.18, -31.0, 2.6, 0.18, 0.22, textures.SURF_HULL, 0.35, 0.30, 0.27, false);
    // Four combat beats: hot start, wreck ambush, ranged crossfire, relay push.
    lb.addSpawnRoute(config.EN_HUSK, -12.0, 22.0, 0, -6.0, 20.0);
    lb.addSpawnRoute(config.EN_HUSK, 12.0, 20.0, 0, 6.0, 18.0);
    lb.addSpawnRoute(config.EN_HUSK, 0.0, 14.0, 0, 0.0, 9.0);
    lb.addSpawnRoute(config.EN_SAPPER, -18.0, 12.0, 0, -8.0, 10.0);
    lb.addSpawnRoute(config.EN_SAPPER, 18.0, 10.0, 0, 8.0, 8.0);
    lb.addSpawnRoute(config.EN_HUSK, -20.0, 4.0, 1, -8.0, 2.0);
    lb.addSpawnRoute(config.EN_HUSK, 20.0, 2.0, 1, 8.0, 0.0);
    lb.addSpawnRoute(config.EN_SAPPER, 0.0, -2.0, 1, 0.0, -8.0);
    lb.addSpawnRoute(config.EN_RANGER, -18.0, -6.0, 1, -8.0, -8.0);
    lb.addSpawnRoute(config.EN_RANGER, 18.0, -8.0, 1, 8.0, -10.0);
    lb.addSpawnRoute(config.EN_HUSK, -22.0, -12.0, 2, -8.0, -14.0);
    lb.addSpawnRoute(config.EN_HUSK, 22.0, -14.0, 2, 8.0, -16.0);
    lb.addSpawnRoute(config.EN_RANGER, -14.0, -20.0, 2, -6.0, -18.0);
    lb.addSpawnRoute(config.EN_DRONE, 0.0, -18.0, 2, 0.0, -14.0);
    lb.addSpawnRoute(config.EN_SAPPER, 14.0, -22.0, 2, 6.0, -20.0);
    lb.addSpawnRoute(config.EN_HUSK, -18.0, -28.0, 3, -7.0, -24.0);
    lb.addSpawnRoute(config.EN_HUSK, 18.0, -28.0, 3, 7.0, -24.0);
    lb.addSpawnRoute(config.EN_RANGER, -10.0, -32.0, 3, -5.0, -26.0);
    lb.addSpawnRoute(config.EN_DRONE, 0.0, -34.0, 3, 0.0, -25.0);
    lb.addSpawnRoute(config.EN_SAPPER, 10.0, -32.0, 3, 5.0, -26.0);
    lb.addPickup(config.PK_AMMO, 4.0, 0.0, 20.0, 40.0);
    lb.addPickup(config.PK_HEALTH, -4.0, 0.0, 20.0, 30.0);
    obj.add(objectives.OBJ_CLEAR, 0.0, 0.0, 0.0, 0, "Break the crashsite counterattack", false);
    obj.setPrompt(0, "PUSH THROUGH FOUR ENEMY WAVES");
    obj.addAfter(objectives.OBJ_REACH, 0.0, -34.0, 5.0, 0, "Breach the relay path", false, 0);
    obj.setPrompt(1, "MOVE THROUGH THE OPEN RELAY GATE");
}

// L2 — Relay Outpost: night interior — real rooms, cyan coves, console glow.
hide func buildL2(lb: level_base.LevelBuilder, obj: objectives.Objectives) {
    lb.setName("Relay Outpost");
    lb.setAmbient(0.10, 0.11, 0.14);
    lb.setStart(0.0, 0.2, 22.0, 0.0);
    lb.addArenaShellMat(26.0, 6.0, textures.SURF_CONCRETE, textures.SURF_METAL,
                        0.30, 0.31, 0.34, 0.34, 0.35, 0.39);
    // Ceiling slab with a skylight gap over the radar dish (visual only).
    lb.addBoxMat(-4.0, 6.15, 0.0, 22.0, 0.2, 26.0, textures.SURF_METAL, 0.22, 0.23, 0.26, false);
    lb.addBoxMat(22.0, 6.15, -13.0, 4.0, 0.2, 13.0, textures.SURF_METAL, 0.22, 0.23, 0.26, false);
    lb.addBoxMat(22.0, 6.15, 17.0, 4.0, 0.2, 9.0, textures.SURF_METAL, 0.22, 0.23, 0.26, false);
    // Interior partitions (frozen colliders, re-dressed).
    lb.addBoxMat(-8.0, 3.0, 4.0, 0.4, 3.0, 10.0, textures.SURF_METAL, 0.34, 0.35, 0.39, true);
