    lb.addSpawnRoute(config.EN_RANGER, -28.0, 18.0, 1, -12.0, 10.0);
    lb.addSpawnRoute(config.EN_RANGER, 28.0, 18.0, 1, 12.0, 10.0);
    lb.addSpawnRoute(config.EN_SHRIKE, -30.0, 10.0, 2, -16.0, 4.0);
