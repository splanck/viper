    addGuide(lb, 0.0, 17.0, 0.5, 1.8);
    addFloorArrow(lb, 17.0, 0.0, 1);
    addFloorArrow(lb, -17.0, 0.0, 1);
    addFloorArrow(lb, 0.0, 17.0, 0);
    lb.addSpawnRoute(config.BOSS_SHRIKE, 0.0, -28.0, 0, 0.0, -20.0);
    lb.addSpawnRoute(config.EN_DRONE, -24.0, 12.0, 0, -10.0, 6.0);
    lb.addSpawnRoute(config.EN_DRONE, 24.0, 12.0, 0, 10.0, 6.0);
    lb.addSpawnRoute(config.EN_SHRIKE, -30.0, 0.0, 0, -16.0, 0.0);
    lb.addSpawnRoute(config.EN_SHRIKE, 30.0, 0.0, 0, 16.0, 0.0);
    lb.addSpawnRoute(config.EN_DRONE, -28.0, -16.0, 1, -14.0, -8.0);
