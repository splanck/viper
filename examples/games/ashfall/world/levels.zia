    markCover(lb, -3.0, 22.0, 0.0, -1.0);
    markCover(lb, 3.2, 22.4, 0.0, -1.0);
    // Beacon practicals.
    lb.addPoint(24.0, 3.2, 0.0, 0.55, 0.75, 1.0, 10.0);
