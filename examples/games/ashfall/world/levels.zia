    // Hero: the spire antenna piercing the cloud band beyond the south wall.
    lb.addProp(props.PROP_SPIRE, 0.0, 0.0, -44.0, 0.0, 1.3);
    // Ring beacons around the platform.
    lb.addProp(props.PROP_PYLON, 24.0, 0.0, 0.0, 0.0, 1.2);
