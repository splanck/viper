    lb.addProp(props.PROP_PYLON, 12.0, 0.0, -20.8, 0.0, 1.2);
    lb.addProp(props.PROP_RADAR, 26.0, 0.0, 26.0, 0.0, 1.2);
    lb.addProp(props.PROP_CRATE, -3.0, 0.0, 22.0, 0.4, 1.0);
