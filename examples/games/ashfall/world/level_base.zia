// =============================================================================
// world/level_base.zia — LevelBuilder: accumulate a level spec, build/unload it
// =============================================================================
//
// Each level function fills a LevelBuilder with geometry boxes, lights, an
// ambient/sun setup, enemy spawn points, pickups, and objectives, then the level
// manager calls build() to instantiate everything into the world (tracking the
// nodes + physics bodies it creates) and unload() to tear it down on transition.
// The same builder API is what the JSON manifest loader targets, so authored and
// coded levels share one path.
// =============================================================================
module level_base;

bind Viper.Game3D as Game3D;
bind Viper.Graphics3D as G3D;
bind Viper.Math as Math;
bind "../config" as config;
bind "../assets/textures" as textures;
bind Viper.Graphics as Gfx;
bind "../core/mathutil" as M;

class LevelBuilder {
    // Geometry.
    hide List[Float] bx; hide List[Float] by; hide List[Float] bz;
    hide List[Float] bhx; hide List[Float] bhy; hide List[Float] bhz;
    hide List[Float] br; hide List[Float] bg; hide List[Float] bb;
    hide List[Integer] bcollide;
    hide List[Integer] bsurf;      // textures.SURF_* class per box
    // Props (instantiated by the LevelManager's PropSet after build()).
    hide List[Integer] pKind;
    hide List[Float] pX; hide List[Float] pY; hide List[Float] pZ;
    hide List[Float] pYaw; hide List[Float] pScale;
    // Exterior terrain (visual-only; playfield stays flat, slab colliders
    // authoritative). 0=none 1=canyon 2=ash sea 3=terrace mountainside.
    hide Integer terrainKind;
    hide G3D.Terrain3D terra;
    hide Boolean hasTerra;
    hide Float terraOffX; hide Float terraOffY; hide Float terraOffZ;
    // Water pool (visual; L5 basin).
    hide Boolean wantWater;
    hide Float watX; hide Float watY; hide Float watZ; hide Float watW; hide Float watD;
    hide G3D.Water3D water;
    hide Boolean hasWat;
    // Lights (kind 0=directional, 1=point).
    hide List[Integer] lkind;
    hide List[Float] lx; hide List[Float] ly; hide List[Float] lz;
    hide List[Float] lr; hide List[Float] lg; hide List[Float] lb;
    hide List[Float] lrange;
    hide Float ambR; hide Float ambG; hide Float ambB;
    // Enemy spawns.
    hide List[Integer] spArch; hide List[Float] spX; hide List[Float] spZ; hide List[Integer] spWave;
    hide List[Float] spRouteX; hide List[Float] spRouteZ;
    // AI cover hints: world position plus a preferred facing vector.
    hide List[Float] covX; hide List[Float] covZ; hide List[Float] covFaceX; hide List[Float] covFaceZ;
    // Tactical flank hints: authored side pockets for enemies that should
    // reposition instead of orbiting or walking straight at the player.
    hide List[Float] flX; hide List[Float] flZ;
    // Readability metadata used by probes and in-game guidance.
    hide List[Float] routeX; hide List[Float] routeZ; hide List[Integer] routeKind;
    hide List[Float] markX; hide List[Float] markZ; hide List[Integer] markKind;
    hide List[Float] beatX; hide List[Float] beatZ; hide List[Integer] beatKind; hide List[Integer] beatWave;
    // Objective gates: physical blockers that open after an objective completes.
    hide List[Float] gtX; hide List[Float] gtY; hide List[Float] gtZ;
    hide List[Float] gtHX; hide List[Float] gtHY; hide List[Float] gtHZ;
    hide List[Integer] gtUnlockObj; hide List[Integer] gtOpen;
    hide List[Game3D.Entity3D] gtNode; hide List[G3D.PhysicsBody3D] gtBody;
    // Pickups.
    hide List[Integer] pkKind; hide List[Float] pkX; hide List[Float] pkY; hide List[Float] pkZ; hide List[Float] pkAmt;
    // Player start.
    hide Float startX; hide Float startY; hide Float startZ; hide Float startYaw;
    hide String levelName;
    hide Integer waveCount;
    // Owned instances (for unload).
    hide List[Game3D.Entity3D] ownedNodes;
    hide List[G3D.PhysicsBody3D] ownedBodies;
    hide Boolean built;

    expose func init() { reset(); }

    expose func reset() {
        bx = []; by = []; bz = []; bhx = []; bhy = []; bhz = [];
        br = []; bg = []; bb = []; bcollide = []; bsurf = [];
        pKind = []; pX = []; pY = []; pZ = []; pYaw = []; pScale = [];
        terrainKind = 0;
        hasTerra = false;
        terraOffX = 0.0; terraOffY = 0.0; terraOffZ = 0.0;
        wantWater = false;
        hasWat = false;
        watX = 0.0; watY = 0.0; watZ = 0.0; watW = 4.0; watD = 4.0;
        lkind = []; lx = []; ly = []; lz = []; lr = []; lg = []; lb = []; lrange = [];
        ambR = 0.15; ambG = 0.15; ambB = 0.18;
        spArch = []; spX = []; spZ = []; spWave = []; spRouteX = []; spRouteZ = [];
        covX = []; covZ = []; covFaceX = []; covFaceZ = [];
        flX = []; flZ = [];
        routeX = []; routeZ = []; routeKind = [];
        markX = []; markZ = []; markKind = [];
        beatX = []; beatZ = []; beatKind = []; beatWave = [];
        gtX = []; gtY = []; gtZ = []; gtHX = []; gtHY = []; gtHZ = [];
        gtUnlockObj = []; gtOpen = []; gtNode = []; gtBody = [];
        pkKind = []; pkX = []; pkY = []; pkZ = []; pkAmt = [];
        startX = 0.0; startY = 0.2; startZ = 0.0; startYaw = 0.0;
        levelName = "Level";
        waveCount = 0;
        ownedNodes = []; ownedBodies = [];
        built = false;
    }

    // --- Spec construction (called by level functions / the JSON loader) -----
    expose func setName(n: String) { levelName = n; }
    expose func getName() -> String { return levelName; }
    expose func setAmbient(r: Float, g: Float, b: Float) { ambR = r; ambG = g; ambB = b; }
    expose func setStart(x: Float, y: Float, z: Float, yaw: Float) {
        startX = x; startY = y; startZ = z; startYaw = yaw;
    }
    expose func startXv() -> Float { return startX; }
    expose func startYv() -> Float { return startY; }
    expose func startZv() -> Float { return startZ; }
    expose func startYawv() -> Float { return startYaw; }

    expose func addBox(cx: Float, cy: Float, cz: Float, hx: Float, hy: Float, hz: Float,
                       r: Float, g: Float, b: Float, collide: Boolean) {
        addBoxMat(cx, cy, cz, hx, hy, hz, textures.SURF_DEFAULT, r, g, b, collide);
    }

    // Surface-classed box: the build step resolves `surf` through the texture
    // library into a shared textured material (albedo+normal+emissive floor).
    expose func addBoxMat(cx: Float, cy: Float, cz: Float, hx: Float, hy: Float, hz: Float,
                          surf: Integer, r: Float, g: Float, b: Float, collide: Boolean) {
        bx.Add(cx); by.Add(cy); bz.Add(cz); bhx.Add(hx); bhy.Add(hy); bhz.Add(hz);
        br.Add(r); bg.Add(g); bb.Add(b); bsurf.Add(surf);
        if collide { bcollide.Add(1); } else { bcollide.Add(0); }
    }

    // Floor slab (top at y=0) + four perimeter walls of half-extent `half`.
    expose func addArenaShell(half: Float, wallH: Float, fr: Float, fg: Float, fb: Float,
                              wr: Float, wg: Float, wb: Float) {
        addArenaShellMat(half, wallH, textures.SURF_DEFAULT, textures.SURF_DEFAULT,
                         fr, fg, fb, wr, wg, wb);
    }

    // Surface-classed shell: separate classes for the floor and the walls.
    expose func addArenaShellMat(half: Float, wallH: Float, floorSurf: Integer, wallSurf: Integer,
                                 fr: Float, fg: Float, fb: Float,
                                 wr: Float, wg: Float, wb: Float) {
        addBoxMat(0.0, -0.25, 0.0, half, 0.25, half, floorSurf, fr, fg, fb, true);
        addBoxMat(0.0, wallH * 0.5, 0.0 - half, half, wallH * 0.5, 0.4, wallSurf, wr, wg, wb, true);
        addBoxMat(0.0, wallH * 0.5, half, half, wallH * 0.5, 0.4, wallSurf, wr, wg, wb, true);
        addBoxMat(0.0 - half, wallH * 0.5, 0.0, 0.4, wallH * 0.5, half, wallSurf, wr, wg, wb, true);
        addBoxMat(half, wallH * 0.5, 0.0, 0.4, wallH * 0.5, half, wallSurf, wr, wg, wb, true);
        // Visual trim breaks up graybox shells and gives every combat space a
        // readable perimeter line without adding collision complexity.
        addBoxMat(0.0, 0.08, 0.0 - half + 0.72, half - 1.0, 0.04, 0.07,
                  textures.SURF_ACCENT, 0.72, 0.48, 0.18, false);
        addBoxMat(0.0, 0.08, half - 0.72, half - 1.0, 0.04, 0.07,
                  textures.SURF_ACCENT, 0.72, 0.48, 0.18, false);
        addBoxMat(0.0 - half + 0.72, 0.08, 0.0, 0.07, 0.04, half - 1.0,
                  textures.SURF_ACCENT, 0.72, 0.48, 0.18, false);
        addBoxMat(half - 0.72, 0.08, 0.0, 0.07, 0.04, half - 1.0,
                  textures.SURF_ACCENT, 0.72, 0.48, 0.18, false);
    }

    expose func addProp(kind: Integer, x: Float, y: Float, z: Float, yaw: Float, scale: Float) {
        pKind.Add(kind); pX.Add(x); pY.Add(y); pZ.Add(z); pYaw.Add(yaw); pScale.Add(scale);
    }
    expose func propCount() -> Integer { return pKind.Count; }
    expose func propKindAt(i: Integer) -> Integer { return pKind[i]; }
    expose func propXat(i: Integer) -> Float { return pX[i]; }
    expose func propYat(i: Integer) -> Float { return pY[i]; }
    expose func propZat(i: Integer) -> Float { return pZ[i]; }
    expose func propYawAt(i: Integer) -> Float { return pYaw[i]; }
    expose func propScaleAt(i: Integer) -> Float { return pScale[i]; }

    expose func setWater(x: Float, y: Float, z: Float, halfW: Float, halfD: Float) {
        wantWater = true;
        watX = x; watY = y; watZ = z; watW = halfW; watD = halfD;
    }
    expose func hasWater() -> Boolean { return hasWat; }
    expose func waterObj() -> G3D.Water3D { return water; }

    expose func setTerrain(kind: Integer) { terrainKind = kind; }
    expose func terrainKindOf() -> Integer { return terrainKind; }
    expose func hasTerrain() -> Boolean { return hasTerra; }
    expose func terrainObj() -> G3D.Terrain3D { return terra; }
    expose func terrainOffXv() -> Float { return terraOffX; }
    expose func terrainOffYv() -> Float { return terraOffY; }
    expose func terrainOffZv() -> Float { return terraOffZ; }

    expose func addDirectional(dx: Float, dy: Float, dz: Float, r: Float, g: Float, b: Float) {
        lkind.Add(0); lx.Add(dx); ly.Add(dy); lz.Add(dz); lr.Add(r); lg.Add(g); lb.Add(b); lrange.Add(0.0);
    }
    expose func addPoint(px: Float, py: Float, pz: Float, r: Float, g: Float, b: Float, range: Float) {
        lkind.Add(1); lx.Add(px); ly.Add(py); lz.Add(pz); lr.Add(r); lg.Add(g); lb.Add(b); lrange.Add(range);
    }

    expose func addSpawn(archetype: Integer, x: Float, z: Float, wave: Integer) {
        spArch.Add(archetype); spX.Add(x); spZ.Add(z); spWave.Add(wave);
        spRouteX.Add(99999.0); spRouteZ.Add(99999.0);
        if wave + 1 > waveCount { waveCount = wave + 1; }
    }

    /// Add an enemy spawn with an authored first-move waypoint.
    ///
    /// The AI moves through this lane before resuming its archetype behavior,
    /// giving encounters readable ingress paths without adding a navmesh
    /// dependency.
    expose func addSpawnRoute(archetype: Integer, x: Float, z: Float, wave: Integer,
                              routeX: Float, routeZ: Float) {
        spArch.Add(archetype); spX.Add(x); spZ.Add(z); spWave.Add(wave);
        spRouteX.Add(routeX); spRouteZ.Add(routeZ);
        if wave + 1 > waveCount { waveCount = wave + 1; }
    }
    expose func spawnCount() -> Integer { return spArch.Count; }
    expose func spawnArchAt(i: Integer) -> Integer { return spArch[i]; }
    expose func spawnXat(i: Integer) -> Float { return spX[i]; }
    expose func spawnZat(i: Integer) -> Float { return spZ[i]; }
    expose func spawnWaveAt(i: Integer) -> Integer { return spWave[i]; }
    /// Return the authored first waypoint X coordinate for a spawn, or a sentinel.
    expose func spawnRouteXat(i: Integer) -> Float { return spRouteX[i]; }
    /// Return the authored first waypoint Z coordinate for a spawn, or a sentinel.
    expose func spawnRouteZat(i: Integer) -> Float { return spRouteZ[i]; }
    expose func waveTotal() -> Integer { return waveCount; }

    /// Add an AI cover hint at a readable piece of level geometry.
    ///
    /// Cover hints are non-physical metadata. The visible/solid cover remains
    /// authored with boxes and props; the enemy director reads these points so
    /// ranged units can strafe to believable firing pockets instead of orbiting
    /// in the open.
    expose func addCover(x: Float, z: Float, faceX: Float, faceZ: Float) {
        covX.Add(x); covZ.Add(z); covFaceX.Add(faceX); covFaceZ.Add(faceZ);
    }
    /// Return the number of authored AI cover hints in this level.
    expose func coverCount() -> Integer { return covX.Count; }
    /// Return the X coordinate for an authored AI cover hint.
    expose func coverXat(i: Integer) -> Float { return covX[i]; }
    /// Return the Z coordinate for an authored AI cover hint.
    expose func coverZat(i: Integer) -> Float { return covZ[i]; }
    /// Return the preferred X-facing component for an authored AI cover hint.
    expose func coverFaceXat(i: Integer) -> Float { return covFaceX[i]; }
    /// Return the preferred Z-facing component for an authored AI cover hint.
    expose func coverFaceZat(i: Integer) -> Float { return covFaceZ[i]; }

    /// Add an authored side pocket that enemies can use for flanking.
    expose func addFlank(x: Float, z: Float) {
        flX.Add(x); flZ.Add(z);
    }
    expose func flankCount() -> Integer { return flX.Count; }
    expose func flankXat(i: Integer) -> Float { return flX[i]; }
    expose func flankZat(i: Integer) -> Float { return flZ[i]; }

    /// Add a route marker for player guidance and level-readability gates.
    ///
    /// kind is game-local metadata: 0=route, 1=objective, 2=exit, 3=safe/hold.
    expose func addRouteMarker(x: Float, z: Float, kind: Integer) {
        routeX.Add(x); routeZ.Add(z); routeKind.Add(kind);
    }
    expose func routeMarkerCount() -> Integer { return routeX.Count; }
    expose func routeMarkerXat(i: Integer) -> Float { return routeX[i]; }
    expose func routeMarkerZat(i: Integer) -> Float { return routeZ[i]; }
    expose func routeMarkerKindAt(i: Integer) -> Integer { return routeKind[i]; }

    /// Add a strong visual landmark used to prove the level has a readable identity.
    ///
    /// kind is game-local metadata: 0=hero prop, 1=exit, 2=objective, 3=hazard.
    expose func addLandmark(x: Float, z: Float, kind: Integer) {
        markX.Add(x); markZ.Add(z); markKind.Add(kind);
    }
    expose func landmarkCount() -> Integer { return markX.Count; }
    expose func landmarkXat(i: Integer) -> Float { return markX[i]; }
    expose func landmarkZat(i: Integer) -> Float { return markZ[i]; }
    expose func landmarkKindAt(i: Integer) -> Integer { return markKind[i]; }

    /// Add an encounter beat so level flow is authored, not just enemy count.
    ///
    /// kind is game-local metadata: 0=reveal, 1=ambush, 2=holdout, 3=boss phase.
    expose func addEncounterBeat(x: Float, z: Float, kind: Integer, wave: Integer) {
        beatX.Add(x); beatZ.Add(z); beatKind.Add(kind); beatWave.Add(wave);
    }
    expose func encounterBeatCount() -> Integer { return beatX.Count; }
    expose func encounterBeatXat(i: Integer) -> Float { return beatX[i]; }
    expose func encounterBeatZat(i: Integer) -> Float { return beatZ[i]; }
    expose func encounterBeatKindAt(i: Integer) -> Integer { return beatKind[i]; }
    expose func encounterBeatWaveAt(i: Integer) -> Integer { return beatWave[i]; }

    /// Add a physical gate that opens after `unlockObjective` is completed.
    ///
    /// Gates are ordinary world boxes while closed. They stay under LevelBuilder
    /// ownership so unload removes them exactly like other level geometry.
    expose func addGate(x: Float, y: Float, z: Float, hx: Float, hy: Float, hz: Float,
                        unlockObjective: Integer) {
        gtX.Add(x); gtY.Add(y); gtZ.Add(z); gtHX.Add(hx); gtHY.Add(hy); gtHZ.Add(hz);
        gtUnlockObj.Add(unlockObjective); gtOpen.Add(0);
        gtNode.Add(null); gtBody.Add(null);
    }
    /// Return the number of authored objective gates in this level.
    expose func gateCount() -> Integer { return gtX.Count; }
    /// Return the X coordinate of an objective gate.
    expose func gateXat(i: Integer) -> Float { return gtX[i]; }
    /// Return the Y coordinate of an objective gate.
    expose func gateYat(i: Integer) -> Float { return gtY[i]; }
    /// Return the Z coordinate of an objective gate.
    expose func gateZat(i: Integer) -> Float { return gtZ[i]; }
    /// Return the X half-extent of an objective gate.
    expose func gateHXat(i: Integer) -> Float { return gtHX[i]; }
    /// Return the Y half-extent of an objective gate.
    expose func gateHYat(i: Integer) -> Float { return gtHY[i]; }
    /// Return the Z half-extent of an objective gate.
    expose func gateHZat(i: Integer) -> Float { return gtHZ[i]; }
    /// Return the objective index that opens the gate.
    expose func gateUnlockAt(i: Integer) -> Integer { return gtUnlockObj[i]; }
    /// Return true when the gate has already opened this load.
    expose func gateIsOpen(i: Integer) -> Boolean { return gtOpen[i] == 1; }

    /// Open a gate by moving its visual and collider below the playable space.
    ///
    /// The object remains owned by the level and is still unloaded normally, but
    /// it no longer blocks traversal or draws in the arena.
    expose func openGate(i: Integer) {
        if i < 0 || i >= gtOpen.Count { return; }
        if gtOpen[i] == 1 { return; }
        gtOpen[i] = 1;
        if gtNode[i] != null { gtNode[i].SetPosition(gtX[i], -100.0, gtZ[i]); }
        if gtBody[i] != null { G3D.PhysicsBody3D.SetPosition(gtBody[i], gtX[i], -100.0, gtZ[i]); }
    }

    expose func addPickup(kind: Integer, x: Float, y: Float, z: Float, amt: Float) {
        pkKind.Add(kind); pkX.Add(x); pkY.Add(y); pkZ.Add(z); pkAmt.Add(amt);
    }
    expose func pickupCount() -> Integer { return pkKind.Count; }
    expose func pickupKindAt(i: Integer) -> Integer { return pkKind[i]; }
    expose func pickupXat(i: Integer) -> Float { return pkX[i]; }
    expose func pickupYat(i: Integer) -> Float { return pkY[i]; }
    expose func pickupZat(i: Integer) -> Float { return pkZ[i]; }
    expose func pickupAmtAt(i: Integer) -> Float { return pkAmt[i]; }

    // --- Spec introspection (for the manifest serializer) --------------------
    expose func ambRv() -> Float { return ambR; }
    expose func ambGv() -> Float { return ambG; }
    expose func ambBv() -> Float { return ambB; }
    expose func boxCount() -> Integer { return bx.Count; }
    expose func boxCXat(i: Integer) -> Float { return bx[i]; }
    expose func boxCYat(i: Integer) -> Float { return by[i]; }
    expose func boxCZat(i: Integer) -> Float { return bz[i]; }
    expose func boxHXat(i: Integer) -> Float { return bhx[i]; }
    expose func boxHYat(i: Integer) -> Float { return bhy[i]; }
    expose func boxHZat(i: Integer) -> Float { return bhz[i]; }
    expose func boxRat(i: Integer) -> Float { return br[i]; }
    expose func boxGat(i: Integer) -> Float { return bg[i]; }
    expose func boxBat(i: Integer) -> Float { return bb[i]; }
    expose func boxCollideAt(i: Integer) -> Integer { return bcollide[i]; }
    expose func boxSurfAt(i: Integer) -> Integer { return bsurf[i]; }
    expose func lightCount() -> Integer { return lkind.Count; }
    expose func lightKindAt(i: Integer) -> Integer { return lkind[i]; }
    expose func lightXat(i: Integer) -> Float { return lx[i]; }
    expose func lightYat(i: Integer) -> Float { return ly[i]; }
    expose func lightZat(i: Integer) -> Float { return lz[i]; }
    expose func lightRat(i: Integer) -> Float { return lr[i]; }
    expose func lightGat(i: Integer) -> Float { return lg[i]; }
    expose func lightBat(i: Integer) -> Float { return lb[i]; }
    expose func lightRangeAt(i: Integer) -> Float { return lrange[i]; }

    // --- Build / unload ------------------------------------------------------
    expose func build(world: Game3D.World3D, phys: G3D.PhysicsWorld3D, canvas: G3D.Canvas3D,
                      texLib: textures.TextureLib) {
        // The environment rig (fx/lighting) owns ambient + key/fill at slots 0-7;
        // builder lights are practicals and live at slots 8+.
        G3D.Canvas3D.ClearLights(canvas);
        // Geometry.
        var i = 0;
        while i < bx.Count {
            var mesh = G3D.Mesh3D.Box(bhx[i] * 2.0, bhy[i] * 2.0, bhz[i] * 2.0);
            var mat = G3D.Material3D.PBR(br[i], bg[i], bb[i]);
            if texLib != null {
                mat = texLib.mat(bsurf[i], br[i], bg[i], bb[i]);
            }
            var e = Game3D.Entity3D.New();
            e.Mesh = mesh;
            e.Material = mat;
            e.SetPosition(bx[i], by[i], bz[i]);
            world.Spawn(e);
            ownedNodes.Add(e);
            if bcollide[i] == 1 {
                var body = G3D.PhysicsBody3D.NewAABB(bhx[i], bhy[i], bhz[i], 0.0);
                G3D.PhysicsBody3D.SetPosition(body, bx[i], by[i], bz[i]);
                G3D.PhysicsBody3D.set_CollisionLayer(body, config.LAYER_WORLD);
                G3D.PhysicsWorld3D.Add(phys, body);
                ownedBodies.Add(body);
            }
            i = i + 1;
        }
        // Lights (practicals; slots 8+ — see fx/lighting slot partition).
        i = 0;
        var slot = 8;
        while i < lkind.Count {
            if lkind[i] == 0 {
                var d = Math.Vec3.New(lx[i], ly[i], lz[i]);
                var lt = G3D.Light3D.Directional(d, lr[i], lg[i], lb[i]);
                G3D.Canvas3D.SetLight(canvas, slot, lt);
            } else {
                var p = Math.Vec3.New(lx[i], ly[i], lz[i]);
                var lt = G3D.Light3D.Point(p, lr[i], lg[i], lb[i], lrange[i]);
                G3D.Canvas3D.SetLight(canvas, slot, lt);
            }
            slot = slot + 1;
            i = i + 1;
        }
        // Gates are authored separately from regular boxes so the level manager
        // can open them when objective dependencies complete.
        i = 0;
        while i < gtX.Count {
            var meshG = G3D.Mesh3D.Box(gtHX[i] * 2.0, gtHY[i] * 2.0, gtHZ[i] * 2.0);
            var matG = G3D.Material3D.PBR(0.95, 0.58, 0.18);
            if texLib != null {
                matG = texLib.mat(textures.SURF_HAZARD, 0.95, 0.58, 0.18);
            }
            var eg = Game3D.Entity3D.New();
            eg.Mesh = meshG;
            eg.Material = matG;
            eg.SetPosition(gtX[i], gtY[i], gtZ[i]);
            world.Spawn(eg);
            ownedNodes.Add(eg);
            gtNode[i] = eg;
            var bgate = G3D.PhysicsBody3D.NewAABB(gtHX[i], gtHY[i], gtHZ[i], 0.0);
            G3D.PhysicsBody3D.SetPosition(bgate, gtX[i], gtY[i], gtZ[i]);
            G3D.PhysicsBody3D.set_CollisionLayer(bgate, config.LAYER_WORLD);
            G3D.PhysicsWorld3D.Add(phys, bgate);
            ownedBodies.Add(bgate);
            gtBody[i] = bgate;
            i = i + 1;
        }
        if terrainKind > 0 && texLib != null { buildTerrain(texLib); }
        if wantWater && texLib != null { buildWater(texLib); }
        built = true;
    }

    // Still pool: teal texture + gentle waves; env map picks up the sky.
    hide func buildWater(texLib: textures.TextureLib) {
        water = G3D.Water3D.New(watW * 2.0, watD * 2.0);
        G3D.Water3D.SetPosition(water, watX, watY, watZ);
        G3D.Water3D.SetTexture(water, texLib.waterTexture());
        G3D.Water3D.SetNormalMap(water, texLib.rawNormal(textures.SURF_CONCRETE));
        G3D.Water3D.AddWave(water, 1.0, 0.3, 0.05, 0.4, 1.2);
        G3D.Water3D.AddWave(water, -0.4, 0.8, 0.035, 0.7, 0.8);
        hasWat = true;
    }

    // --- Exterior terrain (visual-only) ---------------------------------------
    // 128x128 grid, 2 m spacing, centered on the origin via DrawTerrainAt offset.
    // The playfield stays flat (heights rise only outside the walls) and there
    // is NO heightfield collider — the floor slabs remain authoritative.
    hide func buildTerrain(texLib: textures.TextureLib) {
        var grid = 128;
        var sx = 2.0;
        var sy = 16.0;                      // canyon rim height
        var flatR = 46.0;
        var farR = 105.0;
        if terrainKind == 2 { sy = 3.5; flatR = 0.0; farR = 1.0; }     // ash sea dunes
        if terrainKind == 3 { sy = 24.0; flatR = 34.0; farR = 110.0; } // terrace range
        var hm = Gfx.Pixels.New(grid, grid);
        var sp = Gfx.Pixels.New(grid, grid);
        var noise = Math.PerlinNoise.New(4242);
        var gz = 0;
        while gz < grid {
            var gx = 0;
            while gx < grid {
                var wx = (gx - 64.0) * sx;
                var wz = (gz - 64.0) * sx;
                var d = Math.Sqrt(wx * wx + wz * wz);
                var ridge = (Math.PerlinNoise.Octave2D(noise, wx * 0.02, wz * 0.02, 3, 0.55) + 1.0) * 0.5;
                var h01 = 0.0;
                if terrainKind == 2 {
                    // Rolling ash dunes everywhere (sits 22 m under the deck).
                    h01 = 0.35 + 0.65 * ridge;
                } else {
                    var t = smooth01((d - flatR) / (farR - flatR));
                    h01 = t * (0.45 + 0.55 * ridge);
                }
                hm.Set(gx, gz, packH16(h01));
                // Splat weights: flats = ash sand, slopes = rock, peaks = dark
                // rock (or snow on the terrace range).
                var wRock = clamp01(h01 * 2.4);
                var wHigh = clamp01((h01 - 0.55) * 2.5);
                var wSand = clamp01(1.0 - wRock);
                var w2 = wHigh;
                var w3 = 0.0;
                if terrainKind == 3 { w3 = wHigh; w2 = 0.0; }
                sp.Set(gx, gz, packW(wSand + 0.0001, wRock - wHigh, w2, w3));
                gx = gx + 1;
            }
            gz = gz + 1;
        }
        terra = G3D.Terrain3D.New(grid, grid);
        G3D.Terrain3D.SetHeightmap(terra, hm);
        G3D.Terrain3D.SetScale(terra, sx, sy, sx);
        G3D.Terrain3D.SetMaterial(terra, texLib.terrainMat());
        G3D.Terrain3D.SetLayerTexture(terra, 0, texLib.terrainLayer(1));
        G3D.Terrain3D.SetLayerTexture(terra, 1, texLib.terrainLayer(0));
        G3D.Terrain3D.SetLayerTexture(terra, 2, texLib.terrainLayer(2));
        G3D.Terrain3D.SetLayerTexture(terra, 3, texLib.terrainLayer(3));
        G3D.Terrain3D.SetLayerScale(terra, 0, 56.0);
        G3D.Terrain3D.SetLayerScale(terra, 1, 44.0);
        G3D.Terrain3D.SetLayerScale(terra, 2, 40.0);
        G3D.Terrain3D.SetLayerScale(terra, 3, 48.0);
        G3D.Terrain3D.SetSplatMap(terra, sp);
        G3D.Terrain3D.SetLodDistances(terra, 45.0, 110.0);
        G3D.Terrain3D.SetSkirtDepth(terra, 3.0);
        terraOffX = 0.0 - 64.0 * sx;
        terraOffZ = 0.0 - 64.0 * sx;
        terraOffY = -0.35;                  // tuck the flat under the floor slab
        if terrainKind == 2 { terraOffY = -22.0; }
        hasTerra = true;
    }

    hide func smooth01(v: Float) -> Float {
        var t = v;
        if t < 0.0 { t = 0.0; }
        if t > 1.0 { t = 1.0; }
        return t * t * (3.0 - 2.0 * t);
    }
    hide func clamp01(v: Float) -> Float {
        if v < 0.0 { return 0.0; }
        if v > 1.0 { return 1.0; }
        return v;
    }
    // 16-bit height in R(hi)+G(lo) of 0xRRGGBBAA.
    hide func packH16(h01: Float) -> Integer {
        var t = h01;
        if t < 0.0 { t = 0.0; }
        if t > 1.0 { t = 1.0; }
        var v = M.roundi(t * 65535.0);
        var hi = v / 256;
        var lo = v % 256;
        return ((hi * 256 + lo) * 256) * 256 + 255;
    }
    // Splat weights into RGBA bytes (renderer normalizes).
    hide func packW(w0: Float, w1: Float, w2: Float, w3: Float) -> Integer {
        var a = wByte(w0); var b = wByte(w1); var c = wByte(w2); var d = wByte(w3);
        return ((a * 256 + b) * 256 + c) * 256 + d;
    }
    hide func wByte(w: Float) -> Integer {
        var t = w;
        if t < 0.0 { t = 0.0; }
        if t > 1.0 { t = 1.0; }
        return M.roundi(t * 255.0);
    }

    expose func unload(world: Game3D.World3D, phys: G3D.PhysicsWorld3D) {
        if built == false { return; }
        hasTerra = false;
        hasWat = false;
        var i = 0;
        while i < ownedNodes.Count {
            world.Despawn(ownedNodes[i]);
            i = i + 1;
        }
        i = 0;
        while i < ownedBodies.Count {
            G3D.PhysicsWorld3D.Remove(phys, ownedBodies[i]);
            i = i + 1;
        }
        ownedNodes = [];
        ownedBodies = [];
        built = false;
    }
}
