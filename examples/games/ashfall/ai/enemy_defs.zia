// =============================================================================
// ai/enemy_defs.zia — per-archetype stat tables (14: 11 enemies + 3 bosses)
// =============================================================================
//
// Parallel Lists indexed by archetype id (config.EN_* / BOSS_*). Behavior class
// selects the AI routine in ai_core; the numbers are the 16-enemies / 17-bosses
// design intent. Fallback-body colors/dims give each archetype a distinct
// silhouette before any GLB rig is downloaded (asset-optional rule).
// =============================================================================
module enemy_defs;

bind "../config" as config;

// Behavior classes.
var BC_MELEE: Integer = 0;      // chase + strike (Husk, Stalker, Wraith, Vanguard)
var BC_KAMIKAZE: Integer = 1;   // charge + self-detonate (Sapper)
var BC_RANGED: Integer = 2;     // approach to band + shoot (Ranger, Marauder)
var BC_FLYER: Integer = 3;      // orbit/strafe (Drone, Shrike)
var BC_TURRET: Integer = 4;     // stationary scan + stream
var BC_SWARM: Integer = 5;      // Mites
var BC_BOSS: Integer = 6;       // multi-phase (Warden/ShrikePrime/Helix)

class EnemyDefs {
    hide List[String] name;
    hide List[Float] hp;
    hide List[Integer] plates;
    hide List[Float] plateHp;
    hide List[Float] shield;
    hide List[Float] speed;
    hide List[Float] sightRange;
    hide List[Float] coneCos;       // cos(half-fov)
    hide List[Float] atkDamage;
    hide List[Float] atkRange;
    hide List[Float] atkCooldown;
    hide List[Float] telegraph;
    hide List[Integer] behavior;
    hide List[Integer] salvage;
    hide List[Float] colR; hide List[Float] colG; hide List[Float] colB;
    hide List[Float] silW; hide List[Float] silH;   // fallback body half-dims
    hide List[Float] blastR;        // self-detonate / rocket radius (0 = none)

    expose func init() {
        name = []; hp = []; plates = []; plateHp = []; shield = []; speed = [];
        sightRange = []; coneCos = []; atkDamage = []; atkRange = []; atkCooldown = [];
        telegraph = []; behavior = []; salvage = []; colR = []; colG = []; colB = [];
        silW = []; silH = []; blastR = [];
    }

    hide func add(nm: String, h: Float, pl: Integer, php: Float, sh: Float, sp: Float,
                  sr: Float, cc: Float, ad: Float, ar: Float, ac: Float, tg: Float,
                  bc: Integer, sv: Integer, r: Float, g: Float, b: Float,
                  w: Float, ht: Float, br: Float) {
        name.Add(nm); hp.Add(h); plates.Add(pl); plateHp.Add(php); shield.Add(sh); speed.Add(sp);
        sightRange.Add(sr); coneCos.Add(cc); atkDamage.Add(ad); atkRange.Add(ar); atkCooldown.Add(ac);
        telegraph.Add(tg); behavior.Add(bc); salvage.Add(sv); colR.Add(r); colG.Add(g); colB.Add(b);
        silW.Add(w); silH.Add(ht); blastR.Add(br);
    }

    expose func setup() {
        //  name        hp    pl php  sh    sp   sr    cc   ad   ar   ac   tg  behavior      sv  r    g    b    w    ht   br
        add("Husk",      70.0, 0, 0.0, 0.0, 4.2, 26.0, 0.5, 18.0, 2.0, 1.2, 0.4, BC_MELEE,    10, 0.55,0.20,0.18,0.4, 0.9, 0.0);
        add("Sapper",    40.0, 0, 0.0, 0.0, 5.6, 24.0, 0.4, 55.0, 2.0, 0.0, 0.3, BC_KAMIKAZE, 12, 0.85,0.45,0.10,0.4, 0.8, 5.0);
        add("Drone",     55.0, 0, 0.0, 0.0, 6.0, 30.0, 0.3, 12.0,20.0, 1.5, 0.5, BC_FLYER,    14, 0.30,0.55,0.75,0.4, 0.4, 0.0);
        add("Ranger",   110.0, 0, 0.0, 0.0, 4.8, 34.0, 0.4, 27.0,30.0, 1.5, 0.3, BC_RANGED,   18, 0.35,0.45,0.55,0.4, 0.95,0.0);
        add("Marauder", 320.0, 4, 60.0,0.0, 2.6, 28.0, 0.5, 24.0,25.0, 0.9, 2.0, BC_RANGED,   30, 0.50,0.50,0.55,0.7, 1.1, 0.0);
        add("Vanguard", 130.0, 0, 0.0,200.0,4.0, 26.0, 0.4, 24.0, 2.5, 1.3, 0.4, BC_MELEE,    24, 0.30,0.60,0.80,0.5, 1.0, 0.0);
        add("Stalker",   90.0, 0, 0.0, 0.0, 6.5, 30.0, 0.5, 26.0, 4.0, 1.5, 0.5, BC_MELEE,    22, 0.60,0.25,0.55,0.4, 0.85,0.0);
        add("Wraith",   140.0, 0, 0.0, 0.0, 5.0, 32.0, 0.5, 34.0, 2.5, 1.4, 0.5, BC_MELEE,    28, 0.45,0.55,0.60,0.4, 1.0, 0.0);
        add("Turret",   160.0, 0, 0.0, 0.0, 0.0, 40.0, 0.0,  8.0,40.0, 0.1, 1.0, BC_TURRET,   16, 0.55,0.55,0.60,0.5, 0.6, 0.0);
        add("Mite",       8.0, 0, 0.0, 0.0, 7.0, 18.0, 0.2,  3.0, 1.2, 0.4, 0.0, BC_SWARM,     1, 0.70,0.30,0.20,0.18,0.18,0.0);
        add("Shrike",   200.0, 0, 0.0, 0.0,12.0, 40.0, 0.3, 40.0,40.0, 2.5, 0.6, BC_FLYER,    40, 0.75,0.30,0.30,0.8, 0.5, 4.0);
        // Bosses.
        add("WARDEN Goliath", 1200.0, 6, 90.0, 0.0, 2.2, 40.0, 0.5, 30.0, 4.0, 1.0, 1.2, BC_BOSS, 300, 0.60,0.35,0.25,1.2,1.8,0.0);
        add("SHRIKE Prime",   1500.0, 0, 0.0,  0.0,14.0, 50.0, 0.3, 45.0,45.0, 1.8, 0.6, BC_BOSS, 400, 0.85,0.30,0.30,1.2,0.7,5.0);
        add("HELIX Avatar",   2000.0, 3,150.0, 0.0, 2.0, 60.0, 0.4, 35.0,50.0, 1.0, 1.0, BC_BOSS, 500, 0.40,0.75,0.85,1.4,2.4,6.0);
    }

    expose func nameOf(a: Integer) -> String { return name[a]; }
    expose func hpOf(a: Integer) -> Float { return hp[a]; }
    expose func platesOf(a: Integer) -> Integer { return plates[a]; }
    expose func plateHpOf(a: Integer) -> Float { return plateHp[a]; }
    expose func shieldOf(a: Integer) -> Float { return shield[a]; }
    expose func speedOf(a: Integer) -> Float { return speed[a]; }
    expose func sightRangeOf(a: Integer) -> Float { return sightRange[a]; }
    expose func coneCosOf(a: Integer) -> Float { return coneCos[a]; }
    expose func atkDamageOf(a: Integer) -> Float { return atkDamage[a]; }
    expose func atkRangeOf(a: Integer) -> Float { return atkRange[a]; }
    expose func atkCooldownOf(a: Integer) -> Float { return atkCooldown[a]; }
    expose func telegraphOf(a: Integer) -> Float { return telegraph[a]; }
    expose func behaviorOf(a: Integer) -> Integer { return behavior[a]; }
    expose func salvageOf(a: Integer) -> Integer { return salvage[a]; }
    expose func colRof(a: Integer) -> Float { return colR[a]; }
    expose func colGof(a: Integer) -> Float { return colG[a]; }
    expose func colBof(a: Integer) -> Float { return colB[a]; }
    expose func silWof(a: Integer) -> Float { return silW[a]; }
    expose func silHof(a: Integer) -> Float { return silH[a]; }
    expose func blastRof(a: Integer) -> Float { return blastR[a]; }
    expose func isFlyer(a: Integer) -> Boolean { return behavior[a] == BC_FLYER; }
    expose func isBoss(a: Integer) -> Boolean { return behavior[a] == BC_BOSS; }
}
