//===----------------------------------------------------------------------===//
//
// File: examples/games/ashfall/ai/ai_core.zia
// Purpose: Manage pooled enemy state, perception, behavior, combat, movement,
//          navigation, collision bodies, and encounter direction.
// Key invariants:
//   - Every enemy occupies one stable data-oriented pool slot.
//   - Moving nav agents steer every tick but rebuild paths at a staggered,
//     bounded cadence instead of synchronously rebuilding for every target tick.
// Ownership/Lifetime:
//   - EnemyManager owns its pooled bodies, models, projectiles, and nav agents.
//   - World, physics, definitions, registries, and event services are borrowed.
// Links: examples/games/ashfall/game.zia, docs/graphics3d-guide.md#navagent3d
//
//===----------------------------------------------------------------------===//
module ai_core;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D as G3D;
bind Zanna.Math as Math;
bind "../config" as config;
bind "../core/mathutil" as M;
bind "../core/events" as events;
bind "../core/rng" as rng;
bind "./enemy_defs" as enemy_defs;
bind "./enemy_projectiles" as enemy_projectiles;
bind "../weapons/ballistics" as ballistics;
bind "../weapons/targets" as targets;
bind "../assets/enemy_models" as enemy_models;

// FSM states.
var AI_IDLE: Integer = 0;
var AI_PATROL: Integer = 1;
var AI_SUSPICIOUS: Integer = 2;
var AI_SEARCHING: Integer = 3;
var AI_COMBAT: Integer = 4;
var AI_STAGGER: Integer = 5;
var AI_DISABLED: Integer = 6;
var AI_DEAD: Integer = 7;

// Path queries are synchronous and materially more expensive than steering.
// Keep moving targets fresh at the runtime's normal 4 Hz repath cadence, but
// distribute agents across that interval so a crowd never rebuilds in one tick.
var NAV_RETARGET_INTERVAL: Float = 0.25;
var NAV_RETARGET_JUMP_DISTANCE_SQ: Float = 16.0;
var NAV_RETARGET_JUMP_WINDOW: Float = 0.06;

class EnemyManager {
    hide Game3D.World3D world;
    hide G3D.PhysicsWorld3D phys;
    hide enemy_defs.EnemyDefs defs;
    hide targets.TargetRegistry reg;
    hide ballistics.Ballistics ball;
    hide events.EventBus bus;
    hide rng.RngStream rngAi;
    hide enemy_projectiles.EnemyProjectiles hostileShots;
    hide G3D.NavMesh3D navMesh;
    hide List[G3D.NavAgent3D] navAgent;
    hide List[Integer] navReady;
    hide List[Integer] navTargetSet;
    hide List[Float] navTargetX; hide List[Float] navTargetZ;
    hide List[Float] navRetargetT;
    hide Boolean navigationEnabled;
    hide Integer navRetargetCount;
    hide Integer lastShotLanded;

    hide List[Integer] arch;
    hide List[Float] x; hide List[Float] y; hide List[Float] z;
    hide List[Float] yaw;
    hide List[Float] health;
    hide List[Integer] platesLeft;
    hide List[Float] plateHp;
    hide List[Float] shield;
    hide List[Integer] state;
    hide List[Float] awareness;
    hide List[Float] stateTimer;
    hide List[Float] atkCd;
    hide List[Float] telegraphT;
    hide List[Integer] telegraphKind;     // 0 idle, 1 winding
    hide List[Float] aimX; hide List[Float] aimY; hide List[Float] aimZ;
    hide List[Float] disabledT;
    hide List[Float] staggerT;
    hide List[Float] dotDps;
    hide List[Float] dotTimer;
    hide List[Float] dotTickT;
    hide List[Integer] hasToken;
    hide List[Integer] alive;
    hide List[Integer] phase;
    hide List[Integer] routeOn;
    hide List[Float] routeX; hide List[Float] routeZ;
    hide List[Float] bossPulseT;
    hide List[Float] lastKnownX; hide List[Float] lastKnownZ;
    hide List[Float] orbitPhase;
    hide List[Float] repositionT;
    hide List[Integer] flankChoice;
    hide List[G3D.PhysicsBody3D] torso;
    hide List[G3D.PhysicsBody3D] head;
    hide List[G3D.PhysicsBody3D] weakBody;
    hide List[Float] coverX; hide List[Float] coverZ; hide List[Float] coverFaceX; hide List[Float] coverFaceZ;
    hide List[Float] flankX; hide List[Float] flankZ;
    hide enemy_models.EnemyModels models;
    hide Integer cap;
    hide Integer killCount;
    hide Integer attacksLanded;
    hide Integer alertLevel;
    hide Float healthScale;
    hide Float awarenessScale;
    hide Integer meleeTokenCap;
    hide Integer rangedTokenCap;

    expose func init() {
        healthScale = 1.0;
        awarenessScale = 1.0;
        meleeTokenCap = 2;
        rangedTokenCap = 4;
        hostileShots = new enemy_projectiles.EnemyProjectiles();
        navAgent = []; navReady = []; navTargetSet = [];
        navTargetX = []; navTargetZ = []; navRetargetT = [];
        navigationEnabled = false;
        navRetargetCount = 0;
        lastShotLanded = 0;
        arch = []; x = []; y = []; z = []; yaw = []; health = [];
        platesLeft = []; plateHp = []; shield = []; state = []; awareness = [];
        stateTimer = []; atkCd = []; telegraphT = []; telegraphKind = [];
        aimX = []; aimY = []; aimZ = [];
        disabledT = []; staggerT = []; hasToken = []; alive = []; phase = [];
        dotDps = []; dotTimer = []; dotTickT = [];
        routeOn = []; routeX = []; routeZ = []; bossPulseT = [];
        lastKnownX = []; lastKnownZ = []; orbitPhase = [];
        repositionT = []; flankChoice = [];
        torso = []; head = []; weakBody = [];
        coverX = []; coverZ = []; coverFaceX = []; coverFaceZ = [];
        flankX = []; flankZ = [];
        cap = config.POOL_AI;
        killCount = 0;
        attacksLanded = 0;
        alertLevel = 0;
    }

    expose func setup(w: Game3D.World3D, defs0: enemy_defs.EnemyDefs, reg0: targets.TargetRegistry,
                      ball0: ballistics.Ballistics, bus0: events.EventBus, rngAi0: rng.RngStream,
                      models0: enemy_models.EnemyModels) {
        world = w; phys = w.Physics; defs = defs0; reg = reg0; ball = ball0; bus = bus0; rngAi = rngAi0;
        models = models0;
        hostileShots.setup(phys, bus);
        var i = 0;
        while i < cap {
            arch.Add(-1); x.Add(0.0); y.Add(0.0); z.Add(0.0); yaw.Add(0.0); health.Add(0.0);
            platesLeft.Add(0); plateHp.Add(0.0); shield.Add(0.0); state.Add(AI_DEAD);
            awareness.Add(0.0); stateTimer.Add(0.0); atkCd.Add(0.0); telegraphT.Add(0.0);
            telegraphKind.Add(0); disabledT.Add(0.0); staggerT.Add(0.0); hasToken.Add(0);
            aimX.Add(0.0); aimY.Add(0.0); aimZ.Add(0.0);
            dotDps.Add(0.0); dotTimer.Add(0.0); dotTickT.Add(0.0);
            alive.Add(0); phase.Add(0); routeOn.Add(0); routeX.Add(0.0); routeZ.Add(0.0);
            bossPulseT.Add(0.0); lastKnownX.Add(0.0); lastKnownZ.Add(0.0); orbitPhase.Add(0.0);
            repositionT.Add(0.0); flankChoice.Add(-1);
            // Placeholder colliders sized for a generic humanoid. Each spawn
            // replaces the slot's three bodies with archetype-sized ones via
            // rebuildBodies (bounded per-spawn churn, not per-frame).
            var t = G3D.PhysicsBody3D.NewAABB(0.4, 0.9, 0.4, 0.0);
            G3D.PhysicsBody3D.set_CollisionLayer(t, config.LAYER_ENEMY);
            G3D.PhysicsBody3D.set_CollisionMask(t, 0);
            G3D.PhysicsBody3D.SetPosition(t, 0.0, -100.0, 0.0);
            G3D.PhysicsWorld3D.Add(phys, t);
            var hd = G3D.PhysicsBody3D.NewAABB(0.28, 0.28, 0.28, 0.0);
            G3D.PhysicsBody3D.set_CollisionLayer(hd, config.LAYER_ENEMY);
            G3D.PhysicsBody3D.set_CollisionMask(hd, 0);
            G3D.PhysicsBody3D.SetPosition(hd, 0.0, -100.0, 0.0);
            G3D.PhysicsWorld3D.Add(phys, hd);
            var wk = G3D.PhysicsBody3D.NewAABB(0.22, 0.22, 0.22, 0.0);
            G3D.PhysicsBody3D.set_CollisionLayer(wk, config.LAYER_ENEMY);
            G3D.PhysicsBody3D.set_CollisionMask(wk, 0);
            G3D.PhysicsBody3D.SetPosition(wk, 0.0, -100.0, 0.0);
            G3D.PhysicsWorld3D.Add(phys, wk);
            torso.Add(t); head.Add(hd); weakBody.Add(wk);
            navAgent.Add(null); navReady.Add(0); navTargetSet.Add(0);
            navTargetX.Add(0.0); navTargetZ.Add(0.0); navRetargetT.Add(0.0);
            i = i + 1;
        }
    }

    /// Attach ground enemies to a freshly baked level navigation mesh.
    expose func setNavigation(nav: G3D.NavMesh3D) {
        navMesh = nav;
        navigationEnabled = nav != null;
        var i = 0;
        while i < cap {
            navAgent[i] = null;
            navReady[i] = 0;
            navTargetSet[i] = 0;
            navRetargetT[i] = 0.0;
            if navigationEnabled && alive[i] == 1 && defs.isFlyer(arch[i]) == false {
                setupNavAgent(i);
            }
            i = i + 1;
        }
    }

    expose func disableNavigation() { setNavigation(null); }

    hide func setupNavAgent(s: Integer) {
        if navigationEnabled == false || navMesh == null || defs.isFlyer(arch[s]) { return; }
        var radius = defs.bodyHalfWidthOf(arch[s]);
        var height = defs.silHof(arch[s]) * 2.0;
        if height < 0.7 { height = 0.7; }
        var agent = G3D.NavAgent3D.New(navMesh, radius, height);
        G3D.NavAgent3D.set_DesiredSpeed(agent, defs.speedOf(arch[s]));
        G3D.NavAgent3D.set_StoppingDistance(agent, 0.18);
        // Ashfall supplies moving goals itself. AutoRepath would duplicate the
        // same synchronous query performed by the staggered SetTarget below.
        G3D.NavAgent3D.set_AutoRepath(agent, false);
        G3D.NavAgent3D.set_AvoidanceEnabled(agent, true);
        G3D.NavAgent3D.set_AvoidanceRadius(agent, radius * 1.35);
        G3D.NavAgent3D.Warp(agent, Math.Vec3.New(x[s], 0.0, z[s]));
        navAgent[s] = agent;
        navReady[s] = 1;
        navTargetSet[s] = 0;
        navTargetX[s] = x[s];
        navTargetZ[s] = z[s];
        // Seven is coprime with the 24-slot pool, so even the common initial
        // contiguous slots cover the whole interval instead of bunching early.
        var phaseSlot = (s * 7) % cap;
        navRetargetT[s] = (phaseSlot + 0.0) * NAV_RETARGET_INTERVAL / (cap + 0.0);
    }

    /// Remove authored cover hints before loading a new level.
    ///
    /// Cover points are per-level metadata injected by LevelManager after the
    /// LevelBuilder is built. Clearing them prevents ranged units from trying
    /// to move toward stale coordinates after a scene transition.
    expose func clearCovers() {
        coverX = []; coverZ = []; coverFaceX = []; coverFaceZ = [];
    }

    expose func clearFlanks() {
        flankX = []; flankZ = [];
    }

    /// Register a level-authored cover hint for ranged AI.
    ///
    /// The facing vector is stored for future animation/lean work; the current
    /// behavior uses the point itself to pick believable firing pockets.
    expose func addCover(x0: Float, z0: Float, faceX0: Float, faceZ0: Float) {
        coverX.Add(x0); coverZ.Add(z0); coverFaceX.Add(faceX0); coverFaceZ.Add(faceZ0);
    }

    expose func addFlank(x0: Float, z0: Float) {
        flankX.Add(x0); flankZ.Add(z0);
    }

    expose func flankCount() -> Integer { return flankX.Count; }
    expose func hostileProjectileCount() -> Integer { return hostileShots.activeCount(); }
    expose func hostileShotsFired() -> Integer { return hostileShots.firedCount(); }
    expose func hostileShotsLanded() -> Integer { return hostileShots.landedCount(); }
    expose func drawProjectiles(canvas: G3D.Canvas3D) { hostileShots.draw(canvas); }

    // --- Spawn / despawn -----------------------------------------------------
    hide func freeSlot() -> Integer {
        var i = 0;
        while i < cap {
            if alive[i] == 0 { return i; }
            i = i + 1;
        }
        return -1;
    }

    expose func spawn(archetype: Integer, sx: Float, sz: Float) -> Integer {
        var s = freeSlot();
        if s < 0 { return -1; }
        arch[s] = archetype;
        x[s] = sx; z[s] = sz;
        y[s] = defs.hoverHeightOf(archetype);
        yaw[s] = 0.0;
        health[s] = defs.hpOf(archetype) * healthScale;
        platesLeft[s] = defs.platesOf(archetype);
        plateHp[s] = defs.plateHpOf(archetype);
        shield[s] = defs.shieldOf(archetype);
        state[s] = AI_IDLE;
        awareness[s] = 0.0;
        stateTimer[s] = 0.0;
        atkCd[s] = 0.0;
        telegraphT[s] = 0.0;
        telegraphKind[s] = 0;
        aimX[s] = sx; aimY[s] = y[s] + 1.0; aimZ[s] = sz;
        disabledT[s] = 0.0;
        staggerT[s] = 0.0;
        dotDps[s] = 0.0;
        dotTimer[s] = 0.0;
        dotTickT[s] = 0.0;
        hasToken[s] = 0;
        phase[s] = 0;
        bossPulseT[s] = 2.5;
        routeOn[s] = 0;
        routeX[s] = sx;
        routeZ[s] = sz;
        repositionT[s] = 0.0;
        flankChoice[s] = -1;
        alive[s] = 1;
        orbitPhase[s] = rngAi.range(0.0, 6.28);
        // Hand the slot's visuals to the model layer (GLB rig or composite).
        models.onSpawn(s, archetype, defs.colRof(archetype), defs.colGof(archetype),
                       defs.colBof(archetype));
        rebuildBodies(s);
        placeBodies(s);
        reg.register(torso[s], config.TGT_ENEMY, s, config.REGION_BODY);
        reg.register(head[s], config.TGT_ENEMY, s, config.REGION_HEAD);
        reg.register(weakBody[s], config.TGT_ENEMY, s, config.REGION_WEAKPOINT);
        if navigationEnabled && defs.isFlyer(archetype) == false { setupNavAgent(s); }
        return s;
    }

    // Replace the slot's hit bodies with archetype-sized ones. Runs once per
    // spawn (never per frame); PhysicsWorld3D.Remove compacts the world's body
    // array and frees the old bodies, so the world body count stays flat.
    hide func rebuildBodies(s: Integer) {
        reg.unregisterEntity(config.TGT_ENEMY, s);
        G3D.PhysicsWorld3D.Remove(phys, torso[s]);
        G3D.PhysicsWorld3D.Remove(phys, head[s]);
        G3D.PhysicsWorld3D.Remove(phys, weakBody[s]);
        var hw = defs.bodyHalfWidthOf(arch[s]);
        var hh = defs.bodyHalfHeightOf(arch[s]);
        var hs = defs.headHalfSizeOf(arch[s]);
        var t = G3D.PhysicsBody3D.NewAABB(hw, hh, hw * 0.82, 0.0);
        var hd = G3D.PhysicsBody3D.NewAABB(hs, hs, hs, 0.0);
        var ws = M.maxf(0.10, hs * 0.72);
        var wk = G3D.PhysicsBody3D.NewAABB(ws, ws, ws, 0.0);
        configureQueryBody(t); configureQueryBody(hd); configureQueryBody(wk);
        G3D.PhysicsWorld3D.Add(phys, t);
        G3D.PhysicsWorld3D.Add(phys, hd);
        G3D.PhysicsWorld3D.Add(phys, wk);
        torso[s] = t; head[s] = hd; weakBody[s] = wk;
    }

    hide func configureQueryBody(body: G3D.PhysicsBody3D) {
        G3D.PhysicsBody3D.set_CollisionLayer(body, config.LAYER_ENEMY);
        G3D.PhysicsBody3D.set_CollisionMask(body, 0);
    }

    /// Assign an authored first-move waypoint to a live enemy slot.
    ///
    /// Level scripts use this for readable ingress lanes. The route is consumed
    /// once the enemy reaches the waypoint, after which normal archetype combat
    /// movement resumes.
    expose func assignRoute(slot: Integer, rx: Float, rz: Float) {
        if slot < 0 || slot >= cap { return; }
        if alive[slot] == 0 { return; }
        routeOn[slot] = 1;
        routeX[slot] = rx;
        routeZ[slot] = rz;
    }

    // Probe helper: point an enemy toward a world point (deterministic detection).
    expose func devFace(slot: Integer, tx: Float, tz: Float) {
        if slot < 0 || slot >= cap { return; }
        yaw[slot] = M.toDeg(Math.Atan2(tx - x[slot], 0.0 - (tz - z[slot])));
    }

    hide func placeBodies(s: Integer) {
        // The slot may have been freed mid-update (kamikaze detonation).
        if alive[s] == 0 { return; }
        var sh = defs.silHof(arch[s]);
        var by = y[s] + defs.bodyHalfHeightOf(arch[s]) + 0.05;
        var hy = y[s] + sh * 1.72;
        G3D.PhysicsBody3D.SetPosition(torso[s], x[s], by, z[s]);
        G3D.PhysicsBody3D.SetPosition(head[s], x[s], hy, z[s]);
        var weakBack = defs.bodyHalfWidthOf(arch[s]) * 1.05;
        var backX = 0.0 - Math.Sin(M.toRad(yaw[s])) * weakBack;
        var backZ = Math.Cos(M.toRad(yaw[s])) * weakBack;
        G3D.PhysicsBody3D.SetPosition(weakBody[s], x[s] + backX, y[s] + sh * 1.15, z[s] + backZ);
        var hpFrac = 1.0;
        var mx = defs.hpOf(arch[s]) * healthScale;
        if mx > 0.5 { hpFrac = health[s] / mx; }
        models.place(s, arch[s], x[s], y[s], z[s], yaw[s], state[s], telegraphKind[s],
                     hpFrac, phase[s]);
    }

    hide func despawn(s: Integer) {
        alive[s] = 0;
        arch[s] = -1;
        routeOn[s] = 0;
        reg.unregisterEntity(config.TGT_ENEMY, s);
        G3D.PhysicsBody3D.SetPosition(torso[s], 0.0, -100.0, 0.0);
        G3D.PhysicsBody3D.SetPosition(head[s], 0.0, -100.0, 0.0);
        G3D.PhysicsBody3D.SetPosition(weakBody[s], 0.0, -100.0, 0.0);
        models.onDespawn(s);
        if navReady[s] == 1 { G3D.NavAgent3D.ClearTarget(navAgent[s]); }
        navReady[s] = 0;
        navTargetSet[s] = 0;
    }

    expose func clearAll() {
        var i = 0;
        while i < cap {
            if alive[i] == 1 { despawn(i); }
            i = i + 1;
        }
        killCount = 0;
        attacksLanded = 0;
        alertLevel = 0;
        hostileShots.clear();
        lastShotLanded = 0;
    }

    // --- Accessors (probes) --------------------------------------------------
    expose func aliveCount() -> Integer {
        var n = 0; var i = 0;
        while i < cap { n = n + alive[i]; i = i + 1; }
        return n;
    }
    expose func nearestAliveTo(px: Float, pz: Float) -> Integer {
        var best = -1;
        var bestD = 1000000.0;
        var i = 0;
        while i < cap {
            if alive[i] == 1 {
                var d = M.distXZ(x[i], z[i], px, pz);
                if d < bestD { bestD = d; best = i; }
            }
            i = i + 1;
        }
        return best;
    }
    expose func bossAliveCount() -> Integer {
        var n = 0; var i = 0;
        while i < cap {
            if alive[i] == 1 && defs.isBoss(arch[i]) { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    /// Boss reinforcements retreat when their commander falls so victory never
    /// turns into a hunt for low-threat cleanup enemies.
    expose func retreatNonBosses() {
        var i = 0;
        while i < cap {
            if alive[i] == 1 && defs.isBoss(arch[i]) == false { despawn(i); }
            i = i + 1;
        }
    }

    /// Reinsert distant or stuck stragglers into a readable ring around combat.
    expose func recoverStragglers(px: Float, pz: Float, maxDistance: Float) {
        var i = 0;
        while i < cap {
            if alive[i] == 1 && M.distXZ(x[i], z[i], px, pz) > maxDistance {
                var ang = (i + 1.0) * 2.3999632;
                x[i] = px + Math.Cos(ang) * 18.0;
                z[i] = pz + Math.Sin(ang) * 18.0;
                routeOn[i] = 0;
                awareness[i] = 100.0;
                state[i] = AI_COMBAT;
                if navReady[i] == 1 {
                    G3D.NavAgent3D.Warp(navAgent[i], Math.Vec3.New(x[i], 0.0, z[i]));
                }
                placeBodies(i);
            }
            i = i + 1;
        }
    }
    expose func setHealthScale(sc: Float) {
        if sc <= 0.1 { return; }
        var ratio = sc / healthScale;
        var i = 0;
        while i < alive.Count {
            if alive[i] == 1 { health[i] = health[i] * ratio; }
            i = i + 1;
        }
        healthScale = sc;
    }
    expose func setCombatTuning(awareness: Float, meleeCap: Integer, rangedCap: Integer) {
        awarenessScale = awareness;
        meleeTokenCap = M.clampi(meleeCap, 1, 6);
        rangedTokenCap = M.clampi(rangedCap, 1, 8);
    }
    expose func killCountTotal() -> Integer { return killCount; }
    expose func attacksLandedTotal() -> Integer { return attacksLanded; }
    expose func navigationRetargetCount() -> Integer { return navRetargetCount; }
    expose func alertLevelNow() -> Integer { return alertLevel; }
    expose func stateOf(s: Integer) -> Integer { return state[s]; }
    expose func awarenessOf(s: Integer) -> Float { return awareness[s]; }
    expose func healthOf(s: Integer) -> Float { return health[s]; }
    expose func maxHealthOf(s: Integer) -> Float { return defs.hpOf(arch[s]) * healthScale; }
    expose func shieldOf(s: Integer) -> Float { return shield[s]; }
    expose func isAlive(s: Integer) -> Boolean { return alive[s] == 1; }
    expose func archOf(s: Integer) -> Integer { return arch[s]; }
    expose func posX(s: Integer) -> Float { return x[s]; }
    expose func posY(s: Integer) -> Float { return y[s]; }
    expose func posZ(s: Integer) -> Float { return z[s]; }
    expose func dotTimeOf(s: Integer) -> Float { return dotTimer[s]; }
    expose func maxAwareness() -> Float {
        var mx = 0.0; var i = 0;
        while i < cap {
            if alive[i] == 1 && awareness[i] > mx { mx = awareness[i]; }
            i = i + 1;
        }
        return mx;
    }
    expose func engagedCount() -> Integer {
        var n = 0; var i = 0;
        while i < cap {
            if alive[i] == 1 && state[i] == AI_COMBAT && hasToken[i] == 1 { n = n + 1; }
            i = i + 1;
        }
        return n;
    }

    // Probe helper: kill every live enemy through the normal death path
    // (counts kills, posts EV_KILL/drops), so CLEAR/KILL objectives resolve.
    expose func devKillAll() {
        var i = 0;
        while i < cap {
            if alive[i] == 1 { killSelf(i); }
            i = i + 1;
        }
    }

    // --- Main update ---------------------------------------------------------
    // px/py/pz = player chest position; playerNoise = current noise radius.
    expose func update(dt: Float, px: Float, py: Float, pz: Float, playerAlive: Boolean) {
        hostileShots.update(dt, px, py, pz, playerAlive);
        var shotLanded = hostileShots.landedCount();
        if shotLanded > lastShotLanded {
            attacksLanded = attacksLanded + shotLanded - lastShotLanded;
            lastShotLanded = shotLanded;
        }
        // Director: recompute token grants first.
        grantTokens(px, pz);
        // Hearing pass (reads this frame's events before they drain).
        hearing();
        var i = 0;
        while i < cap {
            if alive[i] == 1 {
                updateOne(i, dt, px, py, pz, playerAlive);
            }
            i = i + 1;
        }
        // Deferred body placement: updateOne only decides; all SetPosition calls
        // land here, contiguously AFTER every canSee raycast. Interleaving moves
        // with raycasts forced a physics query-broadphase rebuild per enemy per
        // tick. Placement timing is invisible to in-loop decisions: enemy bodies
        // are layer ENEMY / mask 0 and canSee raycasts only against LAYER_WORLD.
        i = 0;
        while i < cap {
            if alive[i] == 1 { placeBodies(i); }
            i = i + 1;
        }
        models.update(dt);
    }

    hide func updateOne(s: Integer, dt: Float, px: Float, py: Float, pz: Float, playerAlive: Boolean) {
        updateDot(s, dt);
        if alive[s] == 0 { return; }
        // Timers.
        if atkCd[s] > 0.0 { atkCd[s] = atkCd[s] - dt; }
        if repositionT[s] > 0.0 {
            repositionT[s] = repositionT[s] - dt;
            if repositionT[s] <= 0.0 { flankChoice[s] = -1; }
        }
        if staggerT[s] > 0.0 {
            staggerT[s] = staggerT[s] - dt;
            if staggerT[s] <= 0.0 && state[s] == AI_STAGGER { state[s] = AI_COMBAT; }
            return;
        }
        if disabledT[s] > 0.0 {
            disabledT[s] = disabledT[s] - dt;
            if disabledT[s] <= 0.0 && state[s] == AI_DISABLED { state[s] = AI_COMBAT; }
            return;
        }

        var dist = M.distXZ(x[s], z[s], px, pz);

        // Perception + awareness.
        var seen = false;
        if playerAlive { seen = canSee(s, px, py, pz, dist); }
        updateAwareness(s, dt, seen, px, pz);

        // FSM.
        stateTimer[s] = stateTimer[s] + dt;
        if state[s] == AI_IDLE || state[s] == AI_PATROL {
            // Idle scan: slowly sweep so a player wandering into the cone is spotted.
            yaw[s] = M.wrapDeg(yaw[s] + 45.0 * dt);
        } else if state[s] == AI_COMBAT || state[s] == AI_SEARCHING || state[s] == AI_SUSPICIOUS {
            behave(s, dt, px, py, pz, dist, seen, playerAlive);
        }
        // Body placement is deferred to update()'s trailing pass (see above).
    }

    hide func updateDot(s: Integer, dt: Float) {
        if dotTimer[s] <= 0.0 { return; }
        dotTimer[s] = dotTimer[s] - dt;
        dotTickT[s] = dotTickT[s] - dt;
        if dotTickT[s] <= 0.0 {
            damageEnemy(s, dotDps[s] * 0.25, config.REGION_BODY, config.DMG_DOT, 999.0);
            dotTickT[s] = 0.25;
        }
        if dotTimer[s] <= 0.0 {
            dotTimer[s] = 0.0;
            dotDps[s] = 0.0;
        }
    }

    // --- Perception ----------------------------------------------------------
    hide func canSee(s: Integer, px: Float, py: Float, pz: Float, dist: Float) -> Boolean {
        var a = arch[s];
        if dist > defs.sightRangeOf(a) { return false; }
        // View cone (turrets/searchers face where they look; others toward player once alert).
        var toX = px - x[s];
        var toZ = pz - z[s];
        var tl = Math.Sqrt(toX * toX + toZ * toZ);
        if tl < 0.01 { return true; }
        toX = toX / tl; toZ = toZ / tl;
        var fx = Math.Sin(M.toRad(yaw[s]));
        var fz = 0.0 - Math.Cos(M.toRad(yaw[s]));
        var d = fx * toX + fz * toZ;
        if d < defs.coneCosOf(a) { return false; }
        // LOS: ray from enemy eye to player chest; blocked only by world geometry.
        var ex = x[s]; var ey = y[s] + 1.5; var ez = z[s];
        var dx = px - ex; var dy = py - ey; var dz = pz - ez;
        var len = Math.Sqrt(dx * dx + dy * dy + dz * dz);
        if len < 0.01 { return true; }
        var origin = Math.Vec3.New(ex, ey, ez);
        var dir = Math.Vec3.New(dx / len, dy / len, dz / len);
        var hit = phys.Raycast(origin, dir, len - 0.3, config.LAYER_WORLD);
        return hit == null;
    }

    hide func updateAwareness(s: Integer, dt: Float, seen: Boolean, px: Float, pz: Float) {
        if seen {
            awareness[s] = M.clampf(awareness[s] + 140.0 * awarenessScale * dt, 0.0, 100.0);
            lastKnownX[s] = px; lastKnownZ[s] = pz;
            // Face the player when aware.
            yaw[s] = M.toDeg(Math.Atan2(px - x[s], 0.0 - (pz - z[s])));
        } else {
            awareness[s] = M.clampf(awareness[s] - 24.0 * dt, 0.0, 100.0);
        }
        // Threshold transitions.
        if awareness[s] >= 100.0 {
            if state[s] != AI_COMBAT && state[s] != AI_STAGGER && state[s] != AI_DISABLED {
                enterCombat(s);
            }
        } else if awareness[s] >= 70.0 {
            if state[s] == AI_IDLE || state[s] == AI_PATROL { state[s] = AI_SEARCHING; }
        } else if awareness[s] >= 35.0 {
            if state[s] == AI_IDLE || state[s] == AI_PATROL { state[s] = AI_SUSPICIOUS; }
        }
    }

    hide func enterCombat(s: Integer) {
        state[s] = AI_COMBAT;
        stateTimer[s] = 0.0;
        if alertLevel < 1 { alertLevel = 1; }
        bus.pushKind(config.EV_ALERT_RAISED, s, arch[s]);
        // Broadcast to squad: nearby idle enemies go SEARCHING toward the sighting.
        var i = 0;
        while i < cap {
            if alive[i] == 1 && i != s && state[i] == AI_IDLE {
                if M.distXZ(x[i], z[i], x[s], z[s]) < 30.0 {
                    state[i] = AI_SEARCHING;
                    lastKnownX[i] = lastKnownX[s]; lastKnownZ[i] = lastKnownZ[s];
                }
            }
            i = i + 1;
        }
    }

    // --- Hearing -------------------------------------------------------------
    hide func hearing() {
        var n = bus.getCount();
        var e = 0;
        while e < n {
            var k = bus.kindAt(e);
            if k == config.EV_GUNSHOT || k == config.EV_FOOTSTEP ||
               k == config.EV_EXPLOSION || k == config.EV_DECOY {
                var loud = bus.bAt(e) + 0.0;
                if k == config.EV_EXPLOSION { loud = 40.0; }
                var nx = bus.xAt(e); var nz = bus.zAt(e);
                var i = 0;
                while i < cap {
                    if alive[i] == 1 && state[i] != AI_COMBAT && state[i] != AI_DEAD {
                        var d = M.distXZ(x[i], z[i], nx, nz);
                        if d < loud {
                            awareness[i] = M.clampf(awareness[i] + 40.0, 0.0, 100.0);
                            lastKnownX[i] = nx; lastKnownZ[i] = nz;
                            if state[i] == AI_IDLE || state[i] == AI_PATROL { state[i] = AI_SEARCHING; }
                        }
                    }
                    i = i + 1;
                }
            }
            e = e + 1;
        }
    }

    // --- Behavior dispatch ---------------------------------------------------
    hide func behave(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                     dist: Float, seen: Boolean, playerAlive: Boolean) {
        var a = arch[s];
        var bc = defs.behaviorOf(a);
        if state[s] == AI_SEARCHING || state[s] == AI_SUSPICIOUS {
            // Move to the last known position; give up after a while.
            moveToward(s, dt, lastKnownX[s], lastKnownZ[s], defs.speedOf(a) * 0.6);
            if M.distXZ(x[s], z[s], lastKnownX[s], lastKnownZ[s]) < 1.5 && seen == false {
                if stateTimer[s] > 4.0 { state[s] = AI_IDLE; awareness[s] = 0.0; }
            }
            return;
        }
        // COMBAT behavior by class.
        if bc == enemy_defs.BC_MELEE {
            combatMelee(s, dt, px, py, pz, dist, playerAlive);
        } else if bc == enemy_defs.BC_KAMIKAZE {
            combatKamikaze(s, dt, px, pz, dist, playerAlive);
        } else if bc == enemy_defs.BC_RANGED {
            combatRanged(s, dt, px, py, pz, dist, seen, playerAlive);
        } else if bc == enemy_defs.BC_FLYER {
            combatFlyer(s, dt, px, py, pz, dist, seen, playerAlive);
        } else if bc == enemy_defs.BC_TURRET {
            combatTurret(s, dt, px, py, pz, dist, seen, playerAlive);
        } else if bc == enemy_defs.BC_SWARM {
            combatMelee(s, dt, px, py, pz, dist, playerAlive);
        } else if bc == enemy_defs.BC_BOSS {
            combatBoss(s, dt, px, py, pz, dist, seen, playerAlive);
        }
    }

    hide func moveToward(s: Integer, dt: Float, tx: Float, tz: Float, speed: Float) {
        var gx = tx;
        var gz = tz;
        if routeOn[s] == 1 {
            var rd = M.distXZ(x[s], z[s], routeX[s], routeZ[s]);
            if rd > 1.2 {
                gx = routeX[s];
                gz = routeZ[s];
            } else {
                routeOn[s] = 0;
            }
        }
        var dx = gx - x[s]; var dz = gz - z[s];
        var d = Math.Sqrt(dx * dx + dz * dz);
        if d < 0.05 { return; }
        if navReady[s] == 1 {
            var agent = navAgent[s];
            G3D.NavAgent3D.set_DesiredSpeed(agent, speed);
            navRetargetT[s] = navRetargetT[s] - dt;

            // A teleport or behavior switch may move the goal a long way. Cap
            // that response at 60 ms while preserving slot-based staggering.
            if navTargetSet[s] == 1 {
                var goalDx = gx - navTargetX[s];
                var goalDz = gz - navTargetZ[s];
                if goalDx * goalDx + goalDz * goalDz > NAV_RETARGET_JUMP_DISTANCE_SQ {
                    var jumpPhaseSlot = (s * 7) % cap;
                    var jumpDelay = (jumpPhaseSlot + 0.0) * NAV_RETARGET_JUMP_WINDOW / (cap + 0.0);
                    if navRetargetT[s] > jumpDelay { navRetargetT[s] = jumpDelay; }
                }
            }
            if navRetargetT[s] <= 0.0 {
                G3D.NavAgent3D.SetTarget(agent, Math.Vec3.New(gx, 0.0, gz));
                navTargetX[s] = gx;
                navTargetZ[s] = gz;
                navTargetSet[s] = 1;
                navRetargetT[s] = NAV_RETARGET_INTERVAL;
                navRetargetCount = navRetargetCount + 1;
            }

            if navTargetSet[s] == 1 {
                G3D.NavAgent3D.Update(agent, dt);
                var np = G3D.NavAgent3D.get_Position(agent);
                var nx = Math.Vec3.get_X(np); var ny = Math.Vec3.get_Y(np);
                var nz = Math.Vec3.get_Z(np);
                if M.distXZ(x[s], z[s], nx, nz) > 0.0001 {
                    yaw[s] = M.toDeg(Math.Atan2(nx - x[s], 0.0 - (nz - z[s])));
                    x[s] = nx; y[s] = ny; z[s] = nz;
                    return;
                }
            }
            // Once navigation owns this slot, do not advance the parallel game
            // position with fallback steering: that would desynchronize it
            // from the agent between retargets and cause a later position snap.
            return;
        }
        moveCollisionAware(s, dt, dx, dz, d, speed);
    }

    hide func moveCollisionAware(s: Integer, dt: Float, dx0: Float, dz0: Float,
                                  d0: Float, speed: Float) {
        var dx = dx0 / d0;
        var dz = dz0 / d0;
        // Local separation keeps the fallback path from forming a single stack.
        var repelX = 0.0; var repelZ = 0.0;
        var j = 0;
        while j < cap {
            if j != s && alive[j] == 1 && defs.isFlyer(arch[j]) == false {
                var sx = x[s] - x[j]; var sz = z[s] - z[j];
                var sd = Math.Sqrt(sx * sx + sz * sz);
                var keep = defs.bodyHalfWidthOf(arch[s]) + defs.bodyHalfWidthOf(arch[j]) + 0.18;
                if sd > 0.001 && sd < keep {
                    var push = (keep - sd) / keep;
                    repelX = repelX + sx / sd * push;
                    repelZ = repelZ + sz / sd * push;
                }
            }
            j = j + 1;
        }
        dx = dx + repelX * 1.4;
        dz = dz + repelZ * 1.4;
        var dl = Math.Sqrt(dx * dx + dz * dz);
        if dl < 0.001 { return; }
        dx = dx / dl; dz = dz / dl;
        var step = speed * dt;
        if step > d0 { step = d0; }
        var mx = dx * step; var mz = dz * step;
        var center = Math.Vec3.New(x[s], y[s] + defs.bodyHalfHeightOf(arch[s]), z[s]);
        var delta = Math.Vec3.New(mx, 0.0, mz);
        var hit = phys.SweepSphere(center, defs.bodyHalfWidthOf(arch[s]), delta, config.LAYER_WORLD);
        if hit == null {
            x[s] = x[s] + mx;
            z[s] = z[s] + mz;
        } else {
            var normal = G3D.PhysicsHit3D.get_Normal(hit);
            var nx = Math.Vec3.get_X(normal); var nz = Math.Vec3.get_Z(normal);
            var into = mx * nx + mz * nz;
            var slideX = mx - into * nx; var slideZ = mz - into * nz;
            x[s] = x[s] + slideX * 0.75;
            z[s] = z[s] + slideZ * 0.75;
        }
        yaw[s] = M.toDeg(Math.Atan2(dx, 0.0 - dz));
    }

    // Common: lock an aim point during the telegraph, then resolve a range-checked
    // melee strike or launch a world-space projectile when the wind-up elapses.
    hide func tryAttack(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                        canStart: Boolean, dmgKind: Integer) -> Boolean {
        var a = arch[s];
        if telegraphKind[s] == 1 {
            telegraphT[s] = telegraphT[s] - dt;
            if telegraphT[s] <= 0.0 {
                telegraphKind[s] = 0;
                if dmgKind == config.DMG_MELEE {
                    if canStart { strikePlayer(s, px, pz, dmgKind); }
                } else {
                    fireEnemyShot(s, dmgKind);
                }
                atkCd[s] = defs.atkCooldownOf(a);
                return true;
            }
            return false;
        }
        if canStart && atkCd[s] <= 0.0 && hasToken[s] == 1 {
            telegraphKind[s] = 1;
            telegraphT[s] = defs.telegraphOf(a);
            aimX[s] = px; aimY[s] = py; aimZ[s] = pz;
        }
        return false;
    }

    hide func fireEnemyShot(s: Integer, dmgKind: Integer) {
        var a = arch[s];
        var eye = defs.silHof(a) * 1.35;
        if eye < 0.35 { eye = 0.35; }
        var ox = x[s]; var oy = y[s] + eye; var oz = z[s];
        hostileShots.spawn(a, ox, oy, oz, aimX[s], aimY[s], aimZ[s],
                           defs.projectileSpeedOf(a), defs.atkDamageOf(a), dmgKind);
    }

    hide func strikePlayer(s: Integer, px: Float, pz: Float, dmgKind: Integer) {
        var a = arch[s];
        var dmg = defs.atkDamageOf(a);
        var dirDeg = M.toDeg(Math.Atan2(x[s] - px, 0.0 - (z[s] - pz)));
        // Player-directed damage consistently stores the source archetype in b;
        // projectile and melee death attribution therefore use the same layout.
        bus.push(config.EV_DAMAGE, config.TGT_PLAYER, a, config.REGION_BODY, dmg, dirDeg,
                 dmgKind + 0.0);
        attacksLanded = attacksLanded + 1;
    }

    hide func combatMelee(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                          dist: Float, playerAlive: Boolean) {
        var a = arch[s];
        var range = defs.atkRangeOf(a);
        if dist > range * 0.9 {
            moveToward(s, dt, px, pz, defs.speedOf(a));
        }
        if playerAlive {
            tryAttack(s, dt, px, py, pz, dist <= range, config.DMG_MELEE);
        }
    }

    hide func combatKamikaze(s: Integer, dt: Float, px: Float, pz: Float,
                             dist: Float, playerAlive: Boolean) {
        var a = arch[s];
        moveToward(s, dt, px, pz, defs.speedOf(a));
        if dist <= defs.atkRangeOf(a) && playerAlive {
            detonate(s);
        }
    }

    hide func detonate(s: Integer) {
        var a = arch[s];
        var r = defs.blastRof(a);
        var bx = x[s]; var by = y[s] + 0.9; var bz = z[s];
        var blastDamage = defs.atkDamageOf(a);
        // Despawn first so the Sapper cannot hit its own overlapping regions.
        // The shared blast event applies occluded falloff to machines and player.
        killSelf(s);
        ball.blast(bx, by, bz, r, blastDamage, config.DMG_EXPLOSION);
    }

    hide func combatRanged(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                           dist: Float, seen: Boolean, playerAlive: Boolean) {
        var a = arch[s];
        var band = defs.atkRangeOf(a);
        var cover = bestCoverFor(s, px, pz, band);
        var flank = bestFlankFor(s, px, pz, band);
        // Hold a firing band: approach if too far, back off if too close.
        if dist > band { moveToward(s, dt, px, pz, defs.speedOf(a)); }
        else if cover >= 0 && dist < band * 0.9 {
            moveToward(s, dt, coverX[cover], coverZ[cover], defs.speedOf(a) * 0.78);
        } else if dist < band * 0.4 {
            moveToward(s, dt, x[s] * 2.0 - px, z[s] * 2.0 - pz, defs.speedOf(a) * 0.6);
        } else {
            if flankChoice[s] < 0 && flank >= 0 && repositionT[s] <= 0.0 {
                flankChoice[s] = flank;
                repositionT[s] = 2.2;
            }
            if flankChoice[s] >= 0 {
                var fc = flankChoice[s];
                if M.distXZ(x[s], z[s], flankX[fc], flankZ[fc]) > 1.3 {
                    moveToward(s, dt, flankX[fc], flankZ[fc], defs.speedOf(a) * 0.55);
                } else {
                    flankChoice[s] = -1;
                    repositionT[s] = 1.5;
                }
            }
        }
        if playerAlive {
            tryAttack(s, dt, px, py, pz, dist <= band && seen, config.DMG_HITSCAN);
        }
    }

    /// Pick the nearest useful authored cover point for a ranged enemy.
    ///
    /// The score favors points the enemy can reach quickly while avoiding cover
    /// that sits too close to the player, which would make the unit charge into
    /// melee range instead of taking a firing pocket.
    hide func bestCoverFor(s: Integer, px: Float, pz: Float, band: Float) -> Integer {
        var best = -1;
        var bestScore = 1000000.0;
        var i = 0;
        while i < coverX.Count {
            var pd = M.distXZ(coverX[i], coverZ[i], px, pz);
            if pd > band * 0.35 && pd < band * 1.35 {
                var ed = M.distXZ(coverX[i], coverZ[i], x[s], z[s]);
                var prefer = M.absf(pd - band * 0.72);
                var score = ed + prefer * 0.55;
                if score < bestScore {
                    bestScore = score;
                    best = i;
                }
            }
            i = i + 1;
        }
        return best;
    }

    hide func bestFlankFor(s: Integer, px: Float, pz: Float, band: Float) -> Integer {
        var best = -1;
        var bestScore = 1000000.0;
        var i = 0;
        while i < flankX.Count {
            var pd = M.distXZ(flankX[i], flankZ[i], px, pz);
            if pd > band * 0.45 && pd < band * 1.15 {
                var ed = M.distXZ(flankX[i], flankZ[i], x[s], z[s]);
                var prefer = M.absf(pd - band * 0.75);
                var score = ed + prefer * 0.4;
                if score < bestScore {
                    bestScore = score;
                    best = i;
                }
            }
            i = i + 1;
        }
        return best;
    }

    hide func combatFlyer(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                          dist: Float, seen: Boolean, playerAlive: Boolean) {
        var a = arch[s];
        // Orbit the player at a hover radius; keep altitude.
        orbitPhase[s] = orbitPhase[s] + dt * 0.9;
        var orbitR = 9.0;
        var tx = px + Math.Cos(orbitPhase[s]) * orbitR;
        var tz = pz + Math.Sin(orbitPhase[s]) * orbitR;
        moveToward(s, dt, tx, tz, defs.speedOf(a));
        y[s] = M.approach(y[s], defs.hoverHeightOf(a), 0.2, dt);
        yaw[s] = M.toDeg(Math.Atan2(px - x[s], 0.0 - (pz - z[s])));
        if playerAlive {
            var dmgKind = config.DMG_HITSCAN;
            if defs.blastRof(a) > 0.0 { dmgKind = config.DMG_EXPLOSION; }
            tryAttack(s, dt, px, py, pz, dist <= defs.atkRangeOf(a) && seen, dmgKind);
        }
    }

    hide func combatTurret(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                           dist: Float, seen: Boolean, playerAlive: Boolean) {
        var a = arch[s];
        // Stationary: face the player, spin up, stream fire.
        yaw[s] = M.toDeg(Math.Atan2(px - x[s], 0.0 - (pz - z[s])));
        if playerAlive {
            tryAttack(s, dt, px, py, pz, dist <= defs.atkRangeOf(a) && seen, config.DMG_HITSCAN);
        }
    }

    hide func combatBoss(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                         dist: Float, seen: Boolean, playerAlive: Boolean) {
        var a = arch[s];
        var maxHp = defs.hpOf(a) * healthScale;
        var frac = health[s] / maxHp;
        var ph = 0;
        if frac < 0.66 { ph = 1; }
        if frac < 0.33 { ph = 2; }
        phase[s] = ph;
        if bossPulseT[s] > 0.0 { bossPulseT[s] = bossPulseT[s] - dt; }
        if a == config.BOSS_WARDEN { combatWarden(s, dt, px, py, pz, dist, seen, playerAlive, ph); }
        else if a == config.BOSS_SHRIKE { combatShrikePrime(s, dt, px, py, pz, dist, seen, playerAlive, ph); }
        else { combatHelix(s, dt, px, py, pz, dist, seen, playerAlive, ph); }
    }

    hide func combatWarden(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                           dist: Float, seen: Boolean, playerAlive: Boolean, ph: Integer) {
        // WARDEN owns the ground: close pressure, armor, and radial forge bolts.
        if dist > 5.0 { moveToward(s, dt, px, pz, defs.speedOf(arch[s]) * (1.0 + ph * 0.22)); }
        if bossPulseT[s] <= 0.0 {
            radialBurst(s, 8 + ph * 2, 16.0 + ph * 3.0, 16.0 + ph * 5.0);
            bossPulseT[s] = 6.0 - ph * 0.8;
        }
        if playerAlive {
            if dist <= 4.2 {
                tryAttack(s, dt, px, py, pz, true, config.DMG_MELEE);
            } else {
                tryAttack(s, dt, px, py, pz, dist <= 30.0 && seen, config.DMG_EXPLOSION);
            }
        }
    }

    hide func combatShrikePrime(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                                dist: Float, seen: Boolean, playerAlive: Boolean, ph: Integer) {
        // SHRIKE owns the air: a tightening orbit, altitude changes, and aimed fans.
        orbitPhase[s] = orbitPhase[s] + dt * (0.75 + ph * 0.22);
        var orbitR = 15.0 - ph * 2.5;
        var tx = px + Math.Cos(orbitPhase[s]) * orbitR;
        var tz = pz + Math.Sin(orbitPhase[s]) * orbitR;
        moveToward(s, dt, tx, tz, defs.speedOf(arch[s]) * (0.72 + ph * 0.10));
        var hover = defs.hoverHeightOf(arch[s]) + Math.Sin(orbitPhase[s] * 1.7) * (1.0 + ph * 0.35);
        y[s] = M.approach(y[s], hover, 0.24, dt);
        yaw[s] = M.toDeg(Math.Atan2(px - x[s], 0.0 - (pz - z[s])));
        if bossPulseT[s] <= 0.0 {
            aimedFan(s, px, py, pz, 5 + ph * 2, 3.0 + ph, 30.0 + ph * 3.0,
                     14.0 + ph * 4.0);
            bossPulseT[s] = 5.2 - ph * 0.7;
        }
        if playerAlive {
            tryAttack(s, dt, px, py, pz, dist <= 50.0 && seen, config.DMG_HITSCAN);
        }
    }

    hide func combatHelix(s: Integer, dt: Float, px: Float, py: Float, pz: Float,
                          dist: Float, seen: Boolean, playerAlive: Boolean, ph: Integer) {
        // HELIX controls the chamber: lateral repositioning and alternating
        // radial grids plus precise core bolts.
        orbitPhase[s] = orbitPhase[s] + dt * (0.35 + ph * 0.12);
        var tx = Math.Cos(orbitPhase[s]) * (10.0 + ph * 2.0);
        var tz = Math.Sin(orbitPhase[s]) * (10.0 + ph * 2.0);
        moveToward(s, dt, tx, tz, defs.speedOf(arch[s]) * (1.0 + ph * 0.25));
        yaw[s] = M.toDeg(Math.Atan2(px - x[s], 0.0 - (pz - z[s])));
        if bossPulseT[s] <= 0.0 {
            radialBurst(s, 10 + ph * 2, 18.0 + ph * 3.0, 15.0 + ph * 5.0);
            bossPulseT[s] = 5.6 - ph * 0.8;
        }
        if playerAlive {
            tryAttack(s, dt, px, py, pz, dist <= 55.0 && seen, config.DMG_BEAM);
        }
    }

    hide func radialBurst(s: Integer, count: Integer, speed: Float, damage0: Float) {
        var a = arch[s];
        // Radial rings travel through the player's dodge plane. The old core-top
        // height sailed harmlessly over the player's chest for both ground bosses.
        var oy = y[s] + M.clampf(defs.silHof(a) * 0.55, 0.7, 1.35);
        bus.pushAt(config.EV_EXPLOSION, a, 4, x[s], oy, z[s]);
        var i = 0;
        while i < count {
            var ang = (i + 0.0) / (count + 0.0) * 6.2831853 + orbitPhase[s] * 0.35;
            hostileShots.spawn(a, x[s], oy, z[s], x[s] + Math.Cos(ang) * 24.0, oy,
                               z[s] + Math.Sin(ang) * 24.0, speed, damage0, config.DMG_EXPLOSION);
            i = i + 1;
        }
    }

    hide func aimedFan(s: Integer, px: Float, py: Float, pz: Float, count: Integer,
                       spacing: Float, speed: Float, damage0: Float) {
        var a = arch[s];
        var oy = y[s] + M.maxf(0.5, defs.silHof(a) * 1.1);
        var dx = px - x[s]; var dz = pz - z[s];
        var len = Math.Sqrt(dx * dx + dz * dz);
        var sideX = 1.0; var sideZ = 0.0;
        if len > 0.01 { sideX = 0.0 - dz / len; sideZ = dx / len; }
        var i = 0;
        while i < count {
            var off = (i + 0.0) - (count - 1.0) * 0.5;
            hostileShots.spawn(a, x[s], oy, z[s], px + sideX * off * spacing, py,
                               pz + sideZ * off * spacing, speed, damage0, config.DMG_HITSCAN);
            i = i + 1;
        }
    }

    // --- Director: attack tokens ---------------------------------------------
    hide func grantTokens(px: Float, pz: Float) {
        // Clear tokens, then grant to the closest engaged AIs up to the caps.
        var i = 0;
        while i < cap { if alive[i] == 1 { hasToken[i] = 0; } i = i + 1; }
        var meleeGiven = 0;
        var rangedGiven = 0;
        // Simple nearest-first grant; a real director scores by LOS/time too.
        var pass = 0;
        while pass < cap {
            var best = -1;
            var bestD = 1000000.0;
            var j = 0;
            while j < cap {
                if alive[j] == 1 && state[j] == AI_COMBAT && hasToken[j] == 0 {
                    var d = M.distXZ(x[j], z[j], px, pz);
                    if d < bestD { bestD = d; best = j; }
                }
                j = j + 1;
            }
            if best < 0 { pass = cap; }
            else {
                var bc = defs.behaviorOf(arch[best]);
                var isMelee = bc == enemy_defs.BC_MELEE || bc == enemy_defs.BC_KAMIKAZE || bc == enemy_defs.BC_SWARM;
                if isMelee && meleeGiven < meleeTokenCap { hasToken[best] = 1; meleeGiven = meleeGiven + 1; }
                else if isMelee == false && rangedGiven < rangedTokenCap { hasToken[best] = 1; rangedGiven = rangedGiven + 1; }
                else { hasToken[best] = 2; }   // mark considered-but-denied
                pass = pass + 1;
            }
        }
        // Normalize the "denied" marker back to 0 (only 1 means holds a token).
        i = 0;
        while i < cap { if alive[i] == 1 && hasToken[i] == 2 { hasToken[i] = 0; } i = i + 1; }
    }

    // --- Damage intake -------------------------------------------------------
    // Drain EV_DAMAGE(TGT_ENEMY) rows and apply plates/shield/health.
    expose func applyDamageEvents() {
        var n = bus.getCount();
        var e = 0;
        while e < n {
            if bus.kindAt(e) == config.EV_DAMAGE && bus.aAt(e) == config.TGT_ENEMY {
                var s = bus.bAt(e);
                var region = bus.cAt(e);
                var amt = bus.xAt(e);
                var dmgKind = M.roundi(bus.yAt(e));
                if dmgKind == config.DMG_DOT {
                    applyDot(s, amt, bus.zAt(e));
                } else {
                    damageEnemy(s, amt, region, dmgKind, bus.zAt(e));
                }
            }
            e = e + 1;
        }
    }

    hide func applyDot(s: Integer, dps: Float, duration: Float) {
        if s < 0 || s >= cap || alive[s] == 0 { return; }
        if dps > dotDps[s] { dotDps[s] = dps; }
        if duration > dotTimer[s] { dotTimer[s] = duration; }
        if dotTickT[s] <= 0.0 { dotTickT[s] = 0.25; }
        awaken(s);
    }

    hide func damageEnemy(s: Integer, amt: Float, region: Integer, dmgKind: Integer,
                          sourceBearing: Float) {
        if s < 0 || s >= cap || alive[s] == 0 { return; }
        // EMP disables instead of damaging.
        if dmgKind == config.DMG_EMP {
            disabledT[s] = 4.0;
            state[s] = AI_DISABLED;
            shield[s] = 0.0;
            return;
        }
        var remaining = amt;
        // Vanguard shields cover a readable 150-degree frontal arc. Flanking,
        // rear fire and the exposed weakpoint bypass the shield entirely.
        var shieldFacingHit = true;
        if sourceBearing < 900.0 {
            shieldFacingHit = M.absf(M.wrapDeg(sourceBearing - yaw[s])) <= 75.0;
        }
        if dmgKind != config.DMG_DOT && shield[s] > 0.0 &&
           region != config.REGION_WEAKPOINT && shieldFacingHit {
            var ab = M.minf(shield[s], remaining);
            shield[s] = shield[s] - ab;
            remaining = remaining - ab;
        }
        if arch[s] == config.EN_SAPPER && region == config.REGION_WEAKPOINT {
            remaining = remaining * 1.35;
        }
        if remaining <= 0.0 { awaken(s); return; }
        // Plates ablate before the core (region ARMOR untouched here — plates are
        // the explicit front armor). Rail penetration ignores one plate.
        if dmgKind != config.DMG_DOT && platesLeft[s] > 0 {
            if dmgKind == config.DMG_HITSCAN && region == config.REGION_WEAKPOINT {
                // core-exposed weakpoint bypasses plates
            } else {
                var take = M.minf(plateHp[s], remaining);
                plateHp[s] = plateHp[s] - take;
                remaining = remaining - take;
                if plateHp[s] <= 0.0 {
                    platesLeft[s] = platesLeft[s] - 1;
                    plateHp[s] = defs.plateHpOf(arch[s]);
                }
                awaken(s);
                if remaining <= 0.0 { return; }
            }
        }
        health[s] = health[s] - remaining;
        models.hitFlash(s);
        // Stagger on a big hit.
        if remaining > 40.0 && staggerT[s] <= 0.0 && defs.isBoss(arch[s]) == false {
            staggerT[s] = 0.6;
            state[s] = AI_STAGGER;
        }
        awaken(s);
        if health[s] <= 0.0 {
            killSelf(s);
        }
    }

    hide func awaken(s: Integer) {
        awareness[s] = 100.0;
        if state[s] == AI_IDLE || state[s] == AI_PATROL || state[s] == AI_SUSPICIOUS || state[s] == AI_SEARCHING {
            enterCombat(s);
        }
    }

    hide func killSelf(s: Integer) {
        killCount = killCount + 1;
        models.startDeath(s, arch[s], x[s], y[s], z[s], yaw[s],
                          defs.colRof(arch[s]), defs.colGof(arch[s]), defs.colBof(arch[s]));
        bus.pushKind(config.EV_KILL, config.TGT_ENEMY, arch[s]);
        bus.pushKind(config.EV_ENEMY_DIED, arch[s], s);
        // Salvage drop is posted for the economy to pick up.
        bus.push(config.EV_PICKUP, config.PK_SALVAGE, defs.salvageOf(arch[s]), 0, x[s], y[s], z[s]);
        despawn(s);
    }
}
