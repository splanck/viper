//===----------------------------------------------------------------------===//
//
// File: examples/games/ashfall/probes/stress_combat_probe.zia
// Purpose: Gate sustained Ashfall combat against broadphase and navigation
//          work amplification over roughly one thousand fixed simulation ticks.
// Key invariants:
//   - The workload reaches the full mixed-enemy active cap.
//   - Broadphase rebuilds and synchronous path retargets remain O(ticks), with
//     a small deterministic constant independent of frame wall time.
// Ownership/Lifetime:
//   - The probe owns one transient Game and its baked navigation mesh.
//   - Game owns all spawned combat and runtime objects through process exit.
// Links: examples/games/ashfall/ai/ai_core.zia, examples/games/ashfall/game.zia
//
//===----------------------------------------------------------------------===//
module stress_combat_probe;

bind Zanna.Terminal as Terminal;
bind Zanna.Math;
bind "../config" as config;
bind "../core/strings" as S;
bind "../game" as game;

func fail(msg: String) { Terminal.Say("FAIL: " + msg); }

func start() {
    var g = new game.Game();
    game.setGame(g);
    g.initCore(0x57E55EED);
    g.setScripted(true);
    g.boot(true, false);
    g.getEnemies().setNavigation(g.getWorld().BakeNavMesh(
        config.NAV_AGENT_RADIUS, config.NAV_AGENT_HEIGHT,
        config.NAV_MAX_SLOPE, config.NAV_CELL_SIZE));
    g.devSpawnPlayer(0.0, 0.2, 0.0);

    // Warmup: settle spawn/boot transients before snapshotting the counter.
    var i = 0;
    while i < 120 {
        g.scriptMove(0.0, 1.0);
        g.tickSim(config.FIXED_DT);
        g.stepPhysics(config.FIXED_DT);
        i = i + 1;
    }

    var phys = g.getPhys();
    var rebuildStart = phys.QueryBroadphaseRebuildCount;
    var retargetStart = g.getEnemies().navigationRetargetCount();

    // Sustained combat: top the field up with a mixed wave every 1.5 seconds,
    // strafe continuously, and hold fire at a target dummy so every tick runs
    // hitscan rays, AI perception rays, enemy bolts, impacts, and audio events.
    var ticks = 900;
    var spawned = 0;
    var t = 0;
    while t < ticks {
        if t % 90 == 0 {
            var wave = 0;
            while wave < 4 {
                var ang = ((spawned % 12) + 0.0) * 0.5236;
                var arch = config.EN_HUSK;
                if spawned % 3 == 1 { arch = config.EN_RANGER; }
                if spawned % 3 == 2 { arch = config.EN_DRONE; }
                if g.devSpawnEnemy(arch, Cos(ang) * 18.0, Sin(ang) * 18.0) >= 0 {
                    spawned = spawned + 1;
                }
                wave = wave + 1;
            }
        }
        var mz = 1.0;
        if (t / 60) % 2 == 1 { mz = -1.0; }
        g.scriptMove(0.4, mz);
        g.scriptAimAt(g.getArena().dummyPosX(0), 1.2, g.getArena().dummyPosZ(0));
        g.scriptFire(true);
        g.tickSim(config.FIXED_DT);
        g.stepPhysics(config.FIXED_DT);
        t = t + 1;
    }
    g.scriptFire(false);

    var rebuilds = phys.QueryBroadphaseRebuildCount - rebuildStart;
    var fallbacks = phys.BroadphaseFallbackCount;
    var retargets = g.getEnemies().navigationRetargetCount() - retargetStart;
    var alive = g.getEnemies().aliveCount();

    Terminal.Say("stress ticks=" + S.intStr(ticks) +
                 " spawned=" + S.intStr(spawned) +
                 " alive=" + S.intStr(alive) +
                 " rebuilds=" + S.intStr(rebuilds) +
                 " retargets=" + S.intStr(retargets) +
                 " fallbacks=" + S.intStr(fallbacks));

    if spawned < 12 {
        fail("combat never ramped — only " + S.intStr(spawned) + " spawns"); return;
    }
    // Fat-AABB reuse keeps rebuilds near escape/spawn rate; the pre-fix
    // invalidate-on-every-SetPosition behavior lands far above 2 per tick.
    if rebuilds > ticks * 2 {
        fail("query broadphase rebuilt " + S.intStr(rebuilds) + " times in " +
             S.intStr(ticks) + " ticks — cache is not being reused"); return;
    }
    if fallbacks > 0 {
        fail("broadphase fell back to brute-force scans " + S.intStr(fallbacks) +
             " times"); return;
    }
    if retargets <= 0 {
        fail("navigation retarget path was not exercised"); return;
    }
    // Twelve SetTarget calls every tick was the native 5-10 FPS regression.
    // The staggered 4 Hz policy stays below two queries per simulation tick,
    // including spawn and discontinuous-goal transients.
    if retargets > ticks * 2 {
        fail("navigation rebuilt " + S.intStr(retargets) + " paths in " +
             S.intStr(ticks) + " ticks — retarget work is not bounded"); return;
    }
    var diag = g.getDiag();
    if diag.hasFailed() {
        fail("budget assertion — " + diag.getViolation()); return;
    }

    Terminal.Say("RESULT: ok");
    Terminal.Say("PASS");
}
