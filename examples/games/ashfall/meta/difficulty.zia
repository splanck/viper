// =============================================================================
// meta/difficulty.zia — difficulty scalars + NG+ mutators
// =============================================================================
//
// Difficulty is a set of multipliers the combat systems query: incoming-damage
// scale, enemy-health scale, awareness-rate scale, and squad token counts. NG+
// layers mutators on top (tougher, denser). Kept as pure data so probes can
// assert the scalars deterministically.
// =============================================================================
module difficulty;

bind "../config" as config;

class Difficulty {
    hide Integer level;       // config.DIFF_*
    hide Boolean ngPlus;

    expose func init() {
        level = config.DIFF_SOLDIER;
        ngPlus = false;
    }

    expose func setLevel(d: Integer) {
        var v = d;
        if v < 0 { v = 0; }
        if v >= config.DIFF_COUNT { v = config.DIFF_COUNT - 1; }
        level = v;
    }
    expose func getLevel() -> Integer { return level; }
    expose func setNgPlus(v: Boolean) { ngPlus = v; }
    expose func isNgPlus() -> Boolean { return ngPlus; }

    expose func name() -> String {
        var n = "Soldier";
        if level == config.DIFF_STORY { n = "Story"; }
        else if level == config.DIFF_VETERAN { n = "Veteran"; }
        if ngPlus { n = n + "+"; }
        return n;
    }

    // Damage the PLAYER takes is scaled by this.
    expose func incomingDamageScale() -> Float {
        var s = 1.0;
        if level == config.DIFF_STORY { s = 0.6; }
        else if level == config.DIFF_VETERAN { s = 1.4; }
        if ngPlus { s = s * 1.25; }
        return s;
    }

    // Enemy health scale.
    expose func enemyHealthScale() -> Float {
        var s = 1.0;
        if level == config.DIFF_STORY { s = 0.85; }
        else if level == config.DIFF_VETERAN { s = 1.25; }
        if ngPlus { s = s * 1.3; }
        return s;
    }

    // Awareness fill-rate scale (how fast enemies detect the player).
    expose func awarenessScale() -> Float {
        var s = 1.0;
        if level == config.DIFF_STORY { s = 0.75; }
        else if level == config.DIFF_VETERAN { s = 1.3; }
        return s;
    }
}
