//
// File: examples/games/ashfall/game.zia
// Purpose: Own and orchestrate Ashfall's state, simulation, presentation, and
//          fixed-timestep interactive loop.
// Key invariants:
//   - Simulation advances only in FIXED_DT increments with bounded catch-up.
//   - Normal and measured play share one frame-loop implementation.
// Ownership/Lifetime:
//   - Game owns every gameplay subsystem and its World3D graph.
//   - The interactive loop destroys World3D exactly once before returning.
// Links: examples/games/ashfall/main.zia, examples/games/ashfall/config.zia
//
//===----------------------------------------------------------------------===//
module game;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D as G3D;
bind Zanna.Math as Math;
bind Zanna.Terminal as Terminal;
bind Zanna.Collections.Map as Map;
bind Zanna.Input.Key as Key;
bind Zanna.Runtime.GC as GC;
bind Zanna.Text.Fmt as Fmt;
bind Zanna.Time.Clock as Clock;

bind "./config" as config;
bind "./core/mathutil" as M;
bind "./core/entity" as entity;
bind "./core/events" as events;
bind "./core/rng" as rng;
bind "./core/savegame" as savegame;
bind "./core/devtools" as devtools;
bind "./core/strings" as S;
bind "./player/actions" as actions;
bind "./player/playerctl" as playerctl;
bind "./player/camera_rig" as camera_rig;
bind "./player/viewmodel" as viewmodel;
bind "./player/health" as health;
bind "./world/arena" as arena;
bind "./world/level_env" as level_env;
bind "./fx/sky" as sky;
bind "./fx/lighting" as lighting;
bind "./assets/textures" as textures;
bind "./assets/registry" as registry;
bind "./assets/enemy_models" as enemy_models;
bind "./world/pickups" as pickups;
bind "./world/level_manager" as level_manager;
bind "./world/objectives" as objectives;
bind "./weapons/weapon_defs" as weapon_defs;
bind "./weapons/targets" as targets;
bind "./weapons/ballistics" as ballistics;
bind "./weapons/projectiles" as projectiles;
bind "./weapons/weapon_base" as weapon_base;
bind "./weapons/weapon_models" as weapon_models;
bind "./ai/enemy_defs" as enemy_defs;
bind "./ai/ai_core" as ai_core;
bind "./ui/hud" as hud;
bind "./ui/menu" as menu;
bind "./ui/cinematics" as cinematics;
bind "./fx/effects" as effects;
bind "./fx/postfx" as postfx;
bind "./audio/mix" as mix;
bind "./meta/economy" as economy;
bind "./meta/difficulty" as difficulty;
bind "./meta/scoring" as scoring;

class Game {
    // --- Core logic systems --------------------------------------------------
    hide entity.EntityReg reg;
    hide events.EventBus bus;
    hide rng.RngStreams rngs;
    hide savegame.SaveManager save;
    hide devtools.Diagnostics diag;

    // --- Graphics / world ----------------------------------------------------
    hide Game3D.World3D world;
    hide G3D.Canvas3D canvas;
    hide G3D.Camera3D camera;
    hide G3D.PhysicsWorld3D phys;
    hide Game3D.Input3D input;
    hide Boolean graphicsUp;
    hide Boolean fullscreenWanted;

    // --- Subsystems ----------------------------------------------------------
    hide actions.ActionMap actionMap;
    hide playerctl.PlayerCtl player;
    hide camera_rig.CameraRig camRig;
    hide viewmodel.ViewModel vm;
    hide arena.Arena arenaMap;

    // --- Weapons -------------------------------------------------------------
    hide weapon_defs.WeaponDefs wdefs;
    hide targets.TargetRegistry targetReg;
    hide ballistics.Ballistics ball;
    hide projectiles.Projectiles proj;
    hide weapon_base.WeaponController weapons;
    hide weapon_models.WeaponModels weaponVis;
    hide G3D.Mesh3D objBeaconMesh;
    hide G3D.Mesh3D objBeaconTopMesh;
    hide G3D.Material3D objBeaconMat;
    hide G3D.Material3D objReadyMat;
    hide G3D.Material3D objEnemyMat;
    hide Boolean objBeaconReady;

    // --- Combatants ----------------------------------------------------------
    hide health.PlayerHealth playerHealth;
    hide enemy_defs.EnemyDefs edefs;
    hide ai_core.EnemyManager enemies;

    // --- World / levels ------------------------------------------------------
    hide pickups.Pickups pickupSys;
    hide level_manager.LevelManager levelMgr;

    // --- UI / FX / audio / meta ----------------------------------------------
    hide hud.Hud hudSys;
    hide menu.MenuSystem menuSys;
    hide cinematics.Cinematics cine;
    hide Integer menuStateSeen;      // last ST_* the menu layer was told about
    hide String lastDamagerName;
    hide String bossName; hide Float bossFrac; hide Integer bossPhase;
    hide effects.Effects fx;
    hide postfx.PostFX postfxSys;
    hide level_env.LevelEnv env;
    hide sky.SkyFactory skyFactory;
    hide lighting.LightRig lightRig;
    hide textures.TextureLib texLib;
    hide registry.AssetRegistry assetReg;
    hide enemy_models.EnemyModels models;
    hide Float clearR; hide Float clearG; hide Float clearB;
    hide mix.Mixer mixer;
    hide economy.Economy econ;
    hide difficulty.Difficulty diffSys;
    hide scoring.Scoring score;
    hide Integer highestUnlocked;

    // --- Per-tick input (real path fills from Input3D; probes set directly) --
    hide Boolean scripted;
    hide Float inMoveX; hide Float inMoveZ;
    hide Float inLookDX; hide Float inLookDY;
    hide Boolean inJump; hide Boolean inCrouch; hide Boolean inSprint;
    hide Boolean inFire; hide Boolean inADS; hide Boolean inInteract;
    hide Boolean inReload; hide Boolean inNextWeapon; hide Boolean inPrevWeapon;
    hide Integer inDirectWeapon;
    hide Boolean inGrenade; hide Boolean inCycleGrenade; hide Boolean inMelee; hide Boolean inFlashlight;
    hide Integer grenadeSelected;
    hide List[Integer] grenadeStock;
    hide Float grenadeCd;
    hide Float meleeCd;
    hide Boolean flashlightOn;

    // --- State machine -------------------------------------------------------
    hide Integer state;
    hide Integer prevState;
    hide Integer pendingState;
    hide Integer currentLevel;
    hide Integer difficulty;
    hide Integer tickCount;
    hide Boolean headless;
    hide Boolean running;
    hide Boolean mouseCaptured;
    hide Float playTime;

    expose func init() {
        reg = new entity.EntityReg();
        bus = new events.EventBus();
        rngs = new rng.RngStreams();
        save = new savegame.SaveManager();
        diag = new devtools.Diagnostics();
        actionMap = new actions.ActionMap();
        player = new playerctl.PlayerCtl();
        camRig = new camera_rig.CameraRig();
        vm = new viewmodel.ViewModel();
        arenaMap = new arena.Arena();
        wdefs = new weapon_defs.WeaponDefs();
        targetReg = new targets.TargetRegistry();
        ball = new ballistics.Ballistics();
        proj = new projectiles.Projectiles();
        weapons = new weapon_base.WeaponController();
        weaponVis = new weapon_models.WeaponModels();
        playerHealth = new health.PlayerHealth();
        edefs = new enemy_defs.EnemyDefs();
        enemies = new ai_core.EnemyManager();
        pickupSys = new pickups.Pickups();
        levelMgr = new level_manager.LevelManager();
        hudSys = new hud.Hud();
        menuSys = new menu.MenuSystem();
        cine = new cinematics.Cinematics();
        menuStateSeen = -1;
        lastDamagerName = "";
        bossName = ""; bossFrac = 0.0; bossPhase = 0;
        fx = new effects.Effects();
        postfxSys = new postfx.PostFX();
        mixer = new mix.Mixer();
        env = new level_env.LevelEnv();
        skyFactory = new sky.SkyFactory();
        lightRig = new lighting.LightRig();
        texLib = new textures.TextureLib();
        assetReg = new registry.AssetRegistry();
        models = new enemy_models.EnemyModels();
        clearR = config.CLEAR_R; clearG = config.CLEAR_G; clearB = config.CLEAR_B;
        econ = new economy.Economy();
        diffSys = new difficulty.Difficulty();
        score = new scoring.Scoring();
        highestUnlocked = config.LV_L1;
        graphicsUp = false;
        objBeaconReady = false;
        fullscreenWanted = true;
        scripted = false;
        inMoveX = 0.0; inMoveZ = 0.0; inLookDX = 0.0; inLookDY = 0.0;
        inJump = false; inCrouch = false; inSprint = false;
        inFire = false; inADS = false; inInteract = false;
        inReload = false; inNextWeapon = false; inPrevWeapon = false;
        inDirectWeapon = -1;
        inGrenade = false; inCycleGrenade = false; inMelee = false; inFlashlight = false;
        grenadeSelected = config.GRENADE_FRAG;
        grenadeStock = [];
        grenadeStock.Add(2); grenadeStock.Add(1); grenadeStock.Add(1);
        grenadeCd = 0.0;
        meleeCd = 0.0;
        flashlightOn = false;
        state = config.ST_BOOT;
        prevState = config.ST_BOOT;
        pendingState = -1;
        currentLevel = config.LV_ARENA;
        difficulty = config.DIFF_SOLDIER;
        tickCount = 0;
        headless = false;
        running = true;
        mouseCaptured = false;
        playTime = 0.0;
    }

    expose func initCore(masterSeed: Integer) {
        reg.setup();
        rngs.reseed(masterSeed);
    }

    // --- Accessors -----------------------------------------------------------
    expose func setHeadless(v: Boolean) { headless = v; }
    expose func isHeadless() -> Boolean { return headless; }
    expose func setFullscreen(v: Boolean) { fullscreenWanted = v; }
    expose func getReg() -> entity.EntityReg { return reg; }
    expose func getBus() -> events.EventBus { return bus; }
    expose func getRng() -> rng.RngStreams { return rngs; }
    expose func getSave() -> savegame.SaveManager { return save; }
    expose func getDiag() -> devtools.Diagnostics { return diag; }
    expose func getWorld() -> Game3D.World3D { return world; }
    expose func getCanvas() -> G3D.Canvas3D { return canvas; }
    expose func getPlayer() -> playerctl.PlayerCtl { return player; }
    expose func getCamRig() -> camera_rig.CameraRig { return camRig; }
    expose func getArena() -> arena.Arena { return arenaMap; }
    expose func getState() -> Integer { return state; }
    expose func getLevel() -> Integer { return currentLevel; }
    expose func setLevel(l: Integer) { currentLevel = l; }
    expose func getDifficulty() -> Integer { return difficulty; }
    expose func setDifficulty(d: Integer) {
        diffSys.setLevel(d);
        difficulty = diffSys.getLevel();
        enemies.setHealthScale(diffSys.enemyHealthScale());
        enemies.setCombatTuning(diffSys.awarenessScale(), diffSys.meleeTokenCap(),
                                diffSys.rangedTokenCap());
    }
    expose func getTickCount() -> Integer { return tickCount; }
    expose func getPlayTime() -> Float { return playTime; }
    expose func isRunning() -> Boolean { return running; }
    expose func stop() { running = false; }

    // --- Scripted-input control (probes) -------------------------------------
    expose func setScripted(v: Boolean) { scripted = v; }
    expose func scriptMove(mx: Float, mz: Float) { inMoveX = mx; inMoveZ = mz; }
    expose func scriptLook(dx: Float, dy: Float) { inLookDX = dx; inLookDY = dy; }
    expose func scriptJump(v: Boolean) { inJump = v; }
    expose func scriptCrouch(v: Boolean) { inCrouch = v; }
    expose func scriptSprint(v: Boolean) { inSprint = v; }
    expose func scriptFire(v: Boolean) { inFire = v; }
    expose func scriptADS(v: Boolean) { inADS = v; }
    expose func scriptReload(v: Boolean) { inReload = v; }
    expose func scriptWeapon(w: Integer) { inDirectWeapon = w; }
    /// Set scripted grenade input for headless probes.
    expose func scriptGrenade(v: Boolean) { inGrenade = v; }
    /// Set scripted grenade cycling input for headless probes.
    expose func scriptCycleGrenade(v: Boolean) { inCycleGrenade = v; }
    /// Set scripted melee input for headless probes.
    expose func scriptMelee(v: Boolean) { inMelee = v; }
    /// Set scripted flashlight toggle input for headless probes.
    expose func scriptFlashlight(v: Boolean) { inFlashlight = v; }
    expose func scriptAimAt(tx: Float, ty: Float, tz: Float) {
        // Point the camera yaw/pitch at a world target (probe aiming helper).
        var ex = camRig.getEyeX(); var ey = camRig.getEyeY(); var ez = camRig.getEyeZ();
        var dx = tx - ex; var dy = ty - ey; var dz = tz - ez;
        var horiz = Math.Sqrt(dx * dx + dz * dz);
        var yaw = Math.Atan2(dx, 0.0 - dz) * 57.2957795130823;
        var pitch = Math.Atan2(dy, horiz) * 57.2957795130823;
        camRig.setYaw(yaw);
        camRig.setPitchDeg(pitch);
    }

    // --- State machine -------------------------------------------------------
    hide func legal(from: Integer, to: Integer) -> Boolean {
        if from == to { return false; }
        if to == config.ST_PAUSED { return from == config.ST_PLAYING; }
        if from == config.ST_PAUSED {
            return to == config.ST_PLAYING || to == config.ST_TITLE || to == config.ST_HUB;
        }
        if to == config.ST_PHOTO { return from == config.ST_PLAYING; }
        if from == config.ST_PHOTO { return to == config.ST_PLAYING; }
        if from == config.ST_BOOT { return to == config.ST_TITLE; }
        if from == config.ST_TITLE { return to == config.ST_HUB || to == config.ST_LOADING || to == config.ST_CREDITS; }
        if from == config.ST_HUB { return to == config.ST_LOADING || to == config.ST_TITLE || to == config.ST_CREDITS; }
        if from == config.ST_LOADING { return to == config.ST_PLAYING; }
        if from == config.ST_PLAYING {
            return to == config.ST_DEATH || to == config.ST_LEVEL_COMPLETE || to == config.ST_HUB || to == config.ST_TITLE;
        }
        if from == config.ST_DEATH { return to == config.ST_LOADING || to == config.ST_TITLE || to == config.ST_HUB; }
        if from == config.ST_LEVEL_COMPLETE { return to == config.ST_HUB || to == config.ST_LOADING || to == config.ST_CREDITS; }
        if from == config.ST_CREDITS { return to == config.ST_TITLE; }
        return false;
    }

    expose func requestState(to: Integer) {
        if legal(state, to) { pendingState = to; }
    }
    expose func forceState(to: Integer) { pendingState = to; }
    hide func applyPending() {
        if pendingState < 0 { return; }
        prevState = state;
        state = pendingState;
        bus.pushKind(config.EV_STATE_CHANGE, prevState, state);
        pendingState = -1;
    }
    expose func inState(s: Integer) -> Boolean { return state == s; }

    // --- Boot ----------------------------------------------------------------
    expose func boot(hl: Boolean, fullscreen: Boolean) {
        headless = hl;
        // Load settings before creating the window so the persisted fullscreen
        // preference actually controls launch. Generic headless probes use an
        // in-memory save backend unless they explicitly install a test folder.
        if save.isReady() == false {
            if hl { save.setupTransient(); } else { save.setupDefault(); }
        }
        menuSys.setup(save);
        var launchFullscreen = fullscreen && fullscreenWanted;
        if launchFullscreen { launchFullscreen = menuSys.fullscreenOn(); }
        if hl {
            world = Game3D.World3D.WithCamera(config.WINDOW_TITLE, 160, 90,
                config.CAMERA_FOV, config.CAMERA_NEAR, config.CAMERA_FAR);
        } else if launchFullscreen {
            world = Game3D.World3D.NewFullscreenWithHorizontalCamera(config.WINDOW_TITLE,
                config.CAMERA_FOV, config.CAMERA_NEAR, config.CAMERA_FAR);
        } else {
            world = Game3D.World3D.WithCamera(config.WINDOW_TITLE, config.WINDOW_WIDTH, config.WINDOW_HEIGHT,
                config.CAMERA_FOV, config.CAMERA_NEAR, config.CAMERA_FAR);
        }
        canvas = world.Canvas;
        camera = world.Camera;
        phys = world.Physics;
        input = world.Input;
        if hl {
            G3D.Canvas3D.SetInputSource(canvas, 1);
            G3D.Canvas3D.SetClockSource(canvas, 1);
            G3D.Canvas3D.SetSyntheticDeltaTimeSec(canvas, config.FIXED_DT);
        } else {
            input.SetRelativeLook(true);
        }
        G3D.Canvas3D.SetShadowBudget(canvas, config.BUDGET_SHADOW_SLOTS);
        actionMap.setupDefaults();
        player.setup(phys);

        // Weapons.
        wdefs.setup();
        targetReg.clear();
        ball.setup(phys, bus, targetReg, rngs.getSpread());
        proj.setup(phys, bus, ball, targetReg);
        econ.setup();
        weapons.setup(wdefs, ball, proj, camRig, vm, bus, rngs.getSpread(), econ);
        weaponVis.setup(texLib, assetReg);
        setupObjectiveBeacon();
        giveStartingLoadout();

        // Combatants + world systems.
        edefs.setup();
        assetReg.setup();
        assetReg.setEnabled(hl == false);
        models.setup(world, texLib, assetReg, config.POOL_AI);
        enemies.setup(world, edefs, targetReg, ball, bus, rngs.getAi(), models);
        pickupSys.setup(world, bus, playerHealth);
        levelMgr.setup(world, canvas, phys, enemies, pickupSys, bus, texLib, hl == false,
                       ball, targetReg);
        playerHealth.reset();

        // Environment systems (env table, sky, light rig, texture library).
        env.setup();
        skyFactory.setup(env, headless);
        lightRig.setup(env, world, canvas, headless, rngs.getCosmetic());
        texLib.setup(headless);

        // UI / FX / audio / meta.
        fx.setup(canvas);
        mixer.setup(world, headless);
        enemies.setHealthScale(diffSys.enemyHealthScale());
        if headless == false { postfxSys.setup(canvas, postfx.TIER_BALANCED); }

        loadProfileProgress();
        menuSys.setHighestLevel(highestUnlocked);
        refreshArmory();
        applySettings();
        graphicsUp = true;

        // Build the initial scene: the standing arena (dev/probes) or a campaign level.
        if currentLevel == config.LV_ARENA {
            loadArenaScene();
        } else {
            loadCampaignLevel(currentLevel);
        }
    }

    // Push the persisted/edited options into the live subsystems.
    hide func applySettings() {
        camRig.setSensitivity(menuSys.sensValue());
        camRig.setFovBase(menuSys.fovValue());
        camRig.setInvertY(menuSys.invertYOn());
        camRig.setShakeScale(menuSys.shakeValue());
        mixer.setMasterVolume(M.roundi(menuSys.volumeValue() * 100.0));
        setDifficulty(menuSys.difficultyValue());
        hudSys.setAccessibility(menuSys.flashValue(), menuSys.highContrastOn());
        if headless == false {
            lightRig.applyShadowTier(menuSys.qualityTier());
            var tier = postfx.TIER_BALANCED;
            if menuSys.qualityTier() == 0 { tier = postfx.TIER_PERFORMANCE; }
            if menuSys.qualityTier() == 2 { tier = postfx.TIER_CINEMATIC; }
            postfxSys.setup(canvas, tier);
            // Public 3D visibility/scaling controls: preserve native resolution
            // for the two quality tiers and use a conservative dynamic target
            // for Performance. TrySetRenderScale is a no-trap capability probe,
            // so unsupported window backends simply remain at native scale.
            var renderScale = 1.0;
            if menuSys.qualityTier() == 0 { renderScale = 0.85; }
            G3D.Canvas3D.TrySetRenderScale(canvas, renderScale);

            // Spread first-use texture transfers over frames. Stable textures
            // remain cached, while a level transition cannot submit an
            // unbounded upload burst on a lower-bandwidth GPU.
            var uploadBudget = 8388608;
            if menuSys.qualityTier() == 0 { uploadBudget = 4194304; }
            if menuSys.qualityTier() == 2 { uploadBudget = 16777216; }
            G3D.Canvas3D.SetTextureUploadBudget(canvas, uploadBudget);
        }
        // These public visibility/light controls are deterministic on the
        // software backend too, so render probes exercise the same path.
        G3D.Canvas3D.SetFrustumCulling(canvas, true);
        G3D.Canvas3D.SetOcclusionCulling(canvas, true);
        // More than sixteen practical/pulse lights can be visible in boss
        // rooms. The try-form preserves the fixed-forward fallback.
        if G3D.Canvas3D.TrySetClusteredLighting(canvas, true) {
            var lightBudget = 40;
            if menuSys.qualityTier() == 0 { lightBudget = 24; }
            if menuSys.qualityTier() == 2 { lightBudget = 64; }
            G3D.Canvas3D.SetClusterLightBudget(canvas, lightBudget);
        }
    }

    hide func setupObjectiveBeacon() {
        objBeaconMesh = G3D.Mesh3D.Box(0.16, 2.2, 0.16);
        objBeaconTopMesh = G3D.Mesh3D.Sphere(0.34, 12);
        objBeaconMat = G3D.Material3D.FromColor(1.0, 0.68, 0.24);
        G3D.Material3D.SetEmissiveColor(objBeaconMat, 1.0, 0.62, 0.18);
        objBeaconMat.EmissiveIntensity = 2.4;
        objReadyMat = G3D.Material3D.FromColor(0.55, 1.0, 0.72);
        G3D.Material3D.SetEmissiveColor(objReadyMat, 0.55, 1.0, 0.72);
        objReadyMat.EmissiveIntensity = 3.0;
        objEnemyMat = G3D.Material3D.FromColor(1.0, 0.25, 0.18);
        G3D.Material3D.SetEmissiveColor(objEnemyMat, 1.0, 0.25, 0.18);
        objEnemyMat.EmissiveIntensity = 2.8;
        objBeaconReady = true;
    }

    // Point the texture library at a level's accent hue + sky env map. Must run
    // BEFORE the level builder so its materials resolve in the new context.
    hide func prepareLevelMaterials(l: Integer) {
        texLib.setLevelContext(env.accentR(l), env.accentG(l), env.accentB(l),
                               skyFactory.build(l));
    }

    // Install a level's full environment: skybox, light rig, fog, clear color,
    // ambient atmosphere. Runs AFTER the level builder (practicals at slots 8+).
    hide func applyEnvironment(l: Integer) {
        G3D.Canvas3D.SetSkybox(canvas, skyFactory.build(l));
        // Let the authored sky light PBR surfaces instead of using only a flat
        // ambient term. This is capability-gated because environment prefiltering
        // is intended for the windowed GPU path; direct/fill lights remain the
        // deterministic fallback on software and headless backends.
        if headless == false && G3D.Canvas3D.BackendSupports(canvas, "gpu_postfx") {
            G3D.Canvas3D.set_IblEnabled(canvas, true);
            var ibl = 0.28;
            if l == config.LV_L2 || l == config.LV_L5 || l == config.LV_L7 || l == config.LV_L9 {
                ibl = 0.20;
            }
            G3D.Canvas3D.set_IblIntensity(canvas, ibl);
        }
        lightRig.applyRig(l);
        clearR = env.horizonR(l); clearG = env.horizonG(l); clearB = env.horizonB(l);
        if headless == false {
            var count = 128;
            if menuSys.qualityTier() == 0 { count = 48; }
            if menuSys.qualityTier() == 2 { count = 192; }
            fx.ambientSetup(env.atmoKind(l), count);
        }
    }

    // Load a campaign level: build it, spawn the player at its start, reset combat.
    expose func loadCampaignLevel(id: Integer) {
        arenaMap.unload(targetReg);
        proj.clear();
        currentLevel = id;
        score.beginLevel(parForLevel(id), 0);
        ball.resetStats();
        mixer.beginLevel();
        lastDamagerName = "combat systems failure";
        bossName = ""; bossFrac = 0.0; bossPhase = 0;
        prepareLevelMaterials(id);
        levelMgr.load(id);
        applyEnvironment(id);
        grantCampaignLoadout(id);
        resetGrenadesForLevel(id);
        player.spawn(levelMgr.startX(), levelMgr.startY(), levelMgr.startZ());
        camRig.setYaw(levelMgr.startYaw());
        playerHealth.reset();
        forceState(config.ST_PLAYING);
        applyPending();
    }

    // Load the standalone combat sandbox with the same teardown/reset contract
    // used by campaign maps.
    hide func loadArenaScene() {
        levelMgr.unload();
        arenaMap.unload(targetReg);
        proj.clear();
        currentLevel = config.LV_ARENA;
        score.beginLevel(parForLevel(config.LV_ARENA), 0);
        ball.resetStats();
        mixer.beginLevel();
        lastDamagerName = "combat systems failure";
        bossName = ""; bossFrac = 0.0; bossPhase = 0;
        prepareLevelMaterials(config.LV_ARENA);
        giveStartingLoadout();
        arenaMap.setup(world, texLib);
        arenaMap.registerTargets(targetReg);
        if headless == false {
            enemies.setNavigation(world.BakeNavMesh(config.NAV_AGENT_RADIUS,
                config.NAV_AGENT_HEIGHT, config.NAV_MAX_SLOPE, config.NAV_CELL_SIZE));
        }
        applyEnvironment(config.LV_ARENA);
        playerHealth.reset();
        spawnIntoArena();
    }

    // Interactive frontend entry (main.zia only; probes boot straight to PLAYING).
    expose func enterTitle() {
        // Vista backdrop: L1 built empty (no combatants) behind the logotype.
        arenaMap.unload(targetReg);
        proj.clear();
        mixer.beginLevel();
        bossName = ""; bossFrac = 0.0; bossPhase = 0;
        prepareLevelMaterials(config.LV_L1);
        levelMgr.load(config.LV_L1);
        applyEnvironment(config.LV_L1);
        enemies.clearAll();
        pickupSys.clear();
        currentLevel = config.LV_L1;
        menuSys.setHighestLevel(highestUnlocked);
        refreshArmory();
        menuSys.enterTitle(save.hasCheckpoint());
        forceState(config.ST_TITLE);
        applyPending();
    }

    // Menu-driven level start: load, then fly the intro in from the vantage.
    hide func startLevelFromMenu(id: Integer) {
        loadCampaignLevel(id);
        saveCheckpointNow();
        var vx = levelMgr.startX() + env.vantageX(id);
        var vy = levelMgr.startY() + env.vantageY(id);
        var vz = levelMgr.startZ() + env.vantageZ(id);
        cine.startIntro(vx, vy, vz,
                        player.getX(), player.getFeetY() + 1.62, player.getZ(),
                        levelMgr.startYaw(), levelMgr.levelName());
    }

    hide func parForLevel(id: Integer) -> Integer {
        if id == config.LV_L1 { return 210; }
        if id == config.LV_L2 { return 190; }
        if id == config.LV_L3 { return 220; }
        if id == config.LV_L4 { return 230; }
        if id == config.LV_L5 { return 210; }
        if id == config.LV_L6 { return 180; }
        if id == config.LV_L7 { return 200; }
        if id == config.LV_L8 { return 210; }
        if id == config.LV_L9 { return 240; }
        return 180;
    }

    hide func giveStartingLoadout() {
        grantAllWeapons();
    }

    /// Grant every weapon and select the Bolt sidearm.
    ///
    /// The arena and probes use the full arsenal as a sandbox. The campaign
    /// calls `grantCampaignLoadout` after loading a level to stage weapons more
    /// deliberately for real play.
    hide func grantAllWeapons() {
        weapons.clearLoadout();
        weapons.give(config.W_BOLT);
        weapons.give(config.W_SCATTER);
        weapons.give(config.W_CYCLER);
        weapons.give(config.W_PULSE);
        weapons.give(config.W_RAIL);
        weapons.give(config.W_ARC);
        weapons.give(config.W_RIVET);
        weapons.give(config.W_SHARD);
        weapons.give(config.W_EMP);
        weapons.give(config.W_LANCE);
        weapons.switchTo(config.W_BOLT);
    }

    /// Grant the interactive campaign loadout appropriate for `levelId`.
    ///
    /// Early missions stay legible with a small kit, then later missions add
    /// counter-tools before the enemy roster demands them. Headless runs keep
    /// the full arsenal so existing probes remain broad regression coverage.
    hide func grantCampaignLoadout(levelId: Integer) {
        if headless {
            grantAllWeapons();
            return;
        }
        weapons.clearLoadout();
        var first = config.W_BOLT;
        if levelId == config.LV_L1 {
            weapons.give(config.W_BOLT); weapons.give(config.W_SCATTER); weapons.give(config.W_CYCLER);
        } else if levelId == config.LV_L2 {
            weapons.give(config.W_BOLT); weapons.give(config.W_CYCLER); weapons.give(config.W_PULSE);
        } else if levelId == config.LV_L3 {
            first = config.W_SCATTER;
            weapons.give(config.W_SCATTER); weapons.give(config.W_PULSE); weapons.give(config.W_RAIL);
        } else if levelId == config.LV_L4 {
            first = config.W_PULSE;
            weapons.give(config.W_PULSE); weapons.give(config.W_ARC); weapons.give(config.W_EMP);
        } else if levelId == config.LV_L5 {
            first = config.W_SCATTER;
            weapons.give(config.W_SCATTER); weapons.give(config.W_RIVET); weapons.give(config.W_SHARD);
        } else if levelId == config.LV_L6 {
            first = config.W_CYCLER;
            weapons.give(config.W_CYCLER); weapons.give(config.W_ARC); weapons.give(config.W_RIVET);
        } else if levelId == config.LV_L7 {
            first = config.W_PULSE;
            weapons.give(config.W_PULSE); weapons.give(config.W_RAIL); weapons.give(config.W_EMP);
        } else if levelId == config.LV_L8 {
            first = config.W_CYCLER;
            weapons.give(config.W_CYCLER); weapons.give(config.W_SHARD); weapons.give(config.W_EMP);
        } else {
            first = config.W_RAIL;
            weapons.give(config.W_RAIL); weapons.give(config.W_SHARD); weapons.give(config.W_LANCE);
        }
        weapons.switchTo(first);
    }

    /// Reset grenade inventory for a newly loaded campaign level.
    ///
    /// Grenade availability escalates with mission complexity: frag first,
    /// EMP once shields/turrets matter, and decoys once stealthier enemies and
    /// routed encounters appear.
    hide func resetGrenadesForLevel(levelId: Integer) {
        if grenadeStock.Count < config.GRENADE_COUNT {
            grenadeStock = [];
            var gi = 0;
            while gi < config.GRENADE_COUNT { grenadeStock.Add(0); gi = gi + 1; }
        }
        grenadeStock[config.GRENADE_FRAG] = 2 + levelId / 3;
        grenadeStock[config.GRENADE_EMP] = 0;
        grenadeStock[config.GRENADE_DECOY] = 0;
        if levelId >= config.LV_L2 { grenadeStock[config.GRENADE_EMP] = 1 + levelId / 5; }
        if levelId >= config.LV_L3 { grenadeStock[config.GRENADE_DECOY] = 1 + levelId / 6; }
        if headless {
            grenadeStock[config.GRENADE_FRAG] = 4;
            grenadeStock[config.GRENADE_EMP] = 3;
            grenadeStock[config.GRENADE_DECOY] = 3;
        }
        grenadeSelected = config.GRENADE_FRAG;
        grenadeCd = 0.0;
        meleeCd = 0.0;
        flashlightOn = false;
    }

    // --- Profile persistence ------------------------------------------------
    hide func loadProfileProgress() {
        var p = save.loadProfile();
        highestUnlocked = M.clampi(Map.GetIntOr(p, "highestLevel", config.LV_L1),
                                   config.LV_L1, config.LV_L9);
        econ.setSalvage(Map.GetIntOr(p, "salvage", 0));
        var w = 0;
        while w < config.WEAPON_COUNT {
            econ.setTier(w, Map.GetIntOr(p, "tier" + S.intStr(w), 0));
            w = w + 1;
        }
        var l = config.LV_L1;
        while l <= config.LV_L9 {
            score.restoreMedal(l, Map.GetIntOr(p, "medal" + S.intStr(l), scoring.MEDAL_NONE));
            l = l + 1;
        }
        score.restoreTotals(Map.GetIntOr(p, "totalKills", 0),
                            Map.GetIntOr(p, "totalDeaths", 0),
                            Map.GetFloatOr(p, "totalTime", 0.0));
    }

    hide func saveProfileProgress(completedLevel: Integer) {
        if completedLevel >= config.LV_L1 && completedLevel < config.LV_L9 {
            highestUnlocked = M.maxi(highestUnlocked, completedLevel + 1);
        } else if completedLevel == config.LV_L9 {
            highestUnlocked = config.LV_L9;
        }
        saveProfileState();
    }

    hide func saveProfileState() {
        var p = Map.New();
        Map.SetInt(p, "highestLevel", highestUnlocked);
        Map.SetInt(p, "salvage", econ.available());
        Map.SetInt(p, "totalKills", score.getTotalKills());
        Map.SetInt(p, "totalDeaths", score.getTotalDeaths());
        Map.SetFloat(p, "totalTime", score.getTotalTime());
        var w = 0;
        while w < config.WEAPON_COUNT {
            Map.SetInt(p, "tier" + S.intStr(w), econ.tierOf(w));
            w = w + 1;
        }
        var l = config.LV_L1;
        while l <= config.LV_L9 {
            Map.SetInt(p, "medal" + S.intStr(l), score.medalOf(l));
            l = l + 1;
        }
        save.saveProfile(p);
        menuSys.setHighestLevel(highestUnlocked);
    }

    // Refresh the menu-owned snapshot without coupling MenuSystem to Economy.
    hide func refreshArmory() {
        menuSys.setArmorySalvage(econ.available());
        var w = 0;
        while w < config.WEAPON_COUNT {
            menuSys.setArmoryWeapon(w, econ.tierOf(w), econ.nextCost(w));
            w = w + 1;
        }
    }

    // Persist the beginning of the current encounter. Typed JSON fields keep
    // Continue deterministic and make a malformed file fall back safely via
    // SaveManager's existing corruption handling.
    expose func saveCheckpointNow() -> Boolean {
        if currentLevel < config.LV_L1 || currentLevel > config.LV_L9 { return false; }
        var c = Map.New();
        Map.SetInt(c, "level", currentLevel);
        Map.SetInt(c, "wave", levelMgr.currentWaveIndex());
        Map.SetFloat(c, "px", player.getX());
        Map.SetFloat(c, "py", player.getFeetY());
        Map.SetFloat(c, "pz", player.getZ());
        Map.SetFloat(c, "yaw", camRig.getYaw());
        Map.SetFloat(c, "pitch", camRig.getPitch());
        Map.SetFloat(c, "health", playerHealth.getHealth());
        Map.SetFloat(c, "shield", playerHealth.getShield());
        Map.SetFloat(c, "armor", playerHealth.getArmor());
        Map.SetInt(c, "difficulty", difficulty);
        Map.SetInt(c, "salvage", econ.available());
        Map.SetInt(c, "weapon", weapons.getCurrent());
        var w = 0;
        while w < config.WEAPON_COUNT {
            Map.SetInt(c, "tier" + S.intStr(w), econ.tierOf(w));
            Map.SetBool(c, "own" + S.intStr(w), weapons.isOwned(w));
            Map.SetInt(c, "mag" + S.intStr(w), weapons.getMagFor(w));
            Map.SetInt(c, "reserve" + S.intStr(w), weapons.getReserveFor(w));
            w = w + 1;
        }
        var g = 0;
        while g < config.GRENADE_COUNT {
            Map.SetInt(c, "grenade" + S.intStr(g), grenadeStock[g]);
            g = g + 1;
        }
        Map.SetInt(c, "grenadeSelected", grenadeSelected);
        Map.SetInt(c, "rngGameplay", rngs.getGameplay().getState());
        Map.SetInt(c, "rngSpread", rngs.getSpread().getState());
        Map.SetInt(c, "rngAi", rngs.getAi().getState());
        Map.SetFloat(c, "scoreTime", score.getLevelTime());
        Map.SetInt(c, "scoreKills", score.getKills());
        Map.SetInt(c, "scoreDamage", score.getDamageTaken());
        Map.SetInt(c, "scoreSecrets", score.getSecrets());
        Map.SetInt(c, "scoreSecretsTotal", score.getSecretsTotal());
        Map.SetInt(c, "scorePar", score.getParTime());
        Map.SetInt(c, "totalKills", score.getTotalKills());
        Map.SetInt(c, "totalDeaths", score.getTotalDeaths());
        Map.SetFloat(c, "totalTime", score.getTotalTime());
        Map.SetInt(c, "shots", ball.getShotsFired());
        Map.SetInt(c, "hits", ball.getHitsLanded());
        var obj = levelMgr.getObjectives();
        Map.SetInt(c, "objectiveCount", obj.count());
        var oi = 0;
        while oi < obj.count() {
            Map.SetBool(c, "objDone" + S.intStr(oi), obj.isDone(oi));
            Map.SetInt(c, "objProgress" + S.intStr(oi), obj.progressOf(oi));
            Map.SetFloat(c, "objTimer" + S.intStr(oi), obj.timerOf(oi));
            oi = oi + 1;
        }
        // A checkpoint also durably records salvage earned since the previous
        // mission completion; armory purchases use the same profile writer.
        saveProfileState();
        return save.saveCheckpoint(c);
    }

    expose func continueCheckpoint() -> Boolean {
        if save.hasCheckpoint() == false { return false; }
        var c = save.loadCheckpoint();
        var id = Map.GetIntOr(c, "level", -1);
        if id < config.LV_L1 || id > config.LV_L9 { return false; }
        setDifficulty(Map.GetIntOr(c, "difficulty", difficulty));
        loadCampaignLevel(id);
        econ.setSalvage(Map.GetIntOr(c, "salvage", econ.available()));
        var tw = 0;
        while tw < config.WEAPON_COUNT {
            econ.setTier(tw, Map.GetIntOr(c, "tier" + S.intStr(tw), econ.tierOf(tw)));
            tw = tw + 1;
        }
        levelMgr.resumeAtWave(Map.GetIntOr(c, "wave", 0));
        player.spawn(Map.GetFloatOr(c, "px", levelMgr.startX()),
                     Map.GetFloatOr(c, "py", levelMgr.startY()),
                     Map.GetFloatOr(c, "pz", levelMgr.startZ()));
        camRig.setYaw(Map.GetFloatOr(c, "yaw", levelMgr.startYaw()));
        camRig.setPitchDeg(Map.GetFloatOr(c, "pitch", 0.0));
        playerHealth.restore(Map.GetFloatOr(c, "health", config.PLAYER_HEALTH_MAX),
                             Map.GetFloatOr(c, "shield", config.PLAYER_SHIELD_MAX),
                             Map.GetFloatOr(c, "armor", 0.0));
        weapons.clearLoadout();
        var w = 0;
        var ownedCount = 0;
        while w < config.WEAPON_COUNT {
            var own = Map.GetBoolOr(c, "own" + S.intStr(w), false);
            weapons.restoreSlot(w, own,
                                Map.GetIntOr(c, "mag" + S.intStr(w), 0),
                                Map.GetIntOr(c, "reserve" + S.intStr(w), 0));
            if own { ownedCount = ownedCount + 1; }
            w = w + 1;
        }
        if ownedCount == 0 { grantCampaignLoadout(id); }
        weapons.switchTo(Map.GetIntOr(c, "weapon", config.W_BOLT));
        var g = 0;
        while g < config.GRENADE_COUNT {
            grenadeStock[g] = M.clampi(Map.GetIntOr(c, "grenade" + S.intStr(g), 0), 0, 99);
            g = g + 1;
        }
        grenadeSelected = M.clampi(Map.GetIntOr(c, "grenadeSelected", 0), 0,
                                   config.GRENADE_COUNT - 1);
        rngs.getGameplay().setState(Map.GetIntOr(c, "rngGameplay", rngs.getGameplay().getState()));
        rngs.getSpread().setState(Map.GetIntOr(c, "rngSpread", rngs.getSpread().getState()));
        rngs.getAi().setState(Map.GetIntOr(c, "rngAi", rngs.getAi().getState()));
        score.restoreRun(Map.GetFloatOr(c, "scoreTime", 0.0),
                         Map.GetIntOr(c, "scoreKills", 0),
                         Map.GetIntOr(c, "scoreDamage", 0),
                         Map.GetIntOr(c, "scoreSecrets", 0),
                         Map.GetIntOr(c, "scoreSecretsTotal", 0),
                         Map.GetIntOr(c, "scorePar", parForLevel(id)));
        score.restoreTotals(Map.GetIntOr(c, "totalKills", score.getTotalKills()),
                            Map.GetIntOr(c, "totalDeaths", score.getTotalDeaths()),
                            Map.GetFloatOr(c, "totalTime", score.getTotalTime()));
        ball.restoreStats(Map.GetIntOr(c, "shots", 0), Map.GetIntOr(c, "hits", 0));
        var obj = levelMgr.getObjectives();
        var savedCount = Map.GetIntOr(c, "objectiveCount", 0);
        var oi = 0;
        while oi < obj.count() && oi < savedCount {
            obj.restoreAt(oi, Map.GetBoolOr(c, "objDone" + S.intStr(oi), false),
                          Map.GetIntOr(c, "objProgress" + S.intStr(oi), 0),
                          Map.GetFloatOr(c, "objTimer" + S.intStr(oi), 0.0));
            oi = oi + 1;
        }
        return true;
    }

    /// Return the display name for the currently selected grenade.
    hide func grenadeName() -> String {
        if grenadeSelected == config.GRENADE_EMP { return "EMP"; }
        if grenadeSelected == config.GRENADE_DECOY { return "DECOY"; }
        return "FRAG";
    }

    /// Return the remaining count for the currently selected grenade.
    hide func grenadeCount() -> Integer {
        if grenadeSelected < 0 || grenadeSelected >= grenadeStock.Count { return 0; }
        return grenadeStock[grenadeSelected];
    }

    expose func getWeapons() -> weapon_base.WeaponController { return weapons; }
    expose func getBallistics() -> ballistics.Ballistics { return ball; }
    expose func getProjectiles() -> projectiles.Projectiles { return proj; }
    expose func getTargetReg() -> targets.TargetRegistry { return targetReg; }
    expose func getPlayerHealth() -> health.PlayerHealth { return playerHealth; }
    expose func getEnemies() -> ai_core.EnemyManager { return enemies; }
    // Probe helper: physics world handle for diagnostic counters
    // (query-broadphase rebuilds, broadphase fallbacks).
    expose func getPhys() -> G3D.PhysicsWorld3D { return phys; }
    expose func devViewOffX() -> Float { return vm.getOffX(); }
    expose func devViewOffY() -> Float { return vm.getOffY(); }
    expose func devViewOffZ() -> Float { return vm.getOffZ(); }
    expose func devFlashlightActive() -> Boolean { return lightRig.isFlashlightActive(); }

    // Probe helper: spawn an enemy of `archetype` at (x, z).
    expose func devSpawnEnemy(archetype: Integer, ex: Float, ez: Float) -> Integer {
        return enemies.spawn(archetype, ex, ez);
    }
    // Probe helper: point an enemy toward a world point.
    expose func devFaceEnemy(slot: Integer, tx: Float, tz: Float) {
        enemies.devFace(slot, tx, tz);
    }
    expose func devSetGod(v: Boolean) { playerHealth.setGod(v); }
    expose func devKillAllEnemies() { enemies.devKillAll(); }
    // Force the downloaded-asset registry on (assets probe; headless boots
    // default it off).
    expose func devForceAssets(v: Boolean) { assetReg.devForceAssets(v); }
    expose func devAssetsLoaded() -> Integer { return assetReg.getLoadedCount(); }
    // Menu-probe hooks: drive the frontend headless (no key input source).
    expose func devSetSaveDir(dir: String) { save.setup(dir); }
    expose func devMenuNav(down: Boolean) {
        var cmd = menuSys.update(0.016, down == false, down, false, false, false, false);
        runMenuCommand(cmd);
    }
    expose func devMenuAdjust(right: Boolean) {
        var cmd = menuSys.update(0.016, false, false, right == false, right, false, false);
        runMenuCommand(cmd);
    }
    expose func devMenuConfirm() {
        var cmd = menuSys.update(0.016, false, false, false, false, true, false);
        runMenuCommand(cmd);
    }
    expose func devMenuBack() {
        var cmd = menuSys.update(0.016, false, false, false, false, false, true);
        runMenuCommand(cmd);
    }
    expose func devMenuCtx() -> Integer { return menuSys.currentCtx(); }
    expose func devMenuSub() -> Integer { return menuSys.currentSub(); }
    expose func devMenuFov() -> Float { return menuSys.fovValue(); }
    expose func devMenuFlash() -> Float { return menuSys.flashValue(); }
    expose func devMenuHighContrast() -> Boolean { return menuSys.highContrastOn(); }
    expose func devCurrentLevel() -> Integer { return currentLevel; }
    expose func devGiveWeapon(w: Integer) { weapons.give(w); }
    expose func devSwitchWeapon(w: Integer) { weapons.switchTo(w); }
    /// Return remaining grenades of the selected type for gameplay probes.
    expose func devGrenadeCount() -> Integer { return grenadeCount(); }
    expose func devKillPlayer() {
        bus.push(config.EV_DAMAGE, config.TGT_PLAYER, -1, config.REGION_BODY,
                 10000.0, 0.0, config.DMG_HITSCAN + 0.0);
    }
    expose func devInteract() { if currentLevel != config.LV_ARENA { levelMgr.onInteract(player.getX(), player.getZ()); } }

    expose func devDamagePlayer(amt: Float) { playerHealth.applyDamage(amt, 0.0); }

    hide func spawnIntoArena() {
        // Corner spawn with a clear -Z lane (the dummy ring sits within r=11).
        player.spawn(16.0, 0.2, 16.0);
        camRig.setYaw(0.0);       // face -Z down the open lane
        forceState(config.ST_PLAYING);
        applyPending();
    }

    // Probe helper: reposition the player (e.g. to the arena center for clear
    // firing lanes to the target ring).
    expose func devSpawnPlayer(x: Float, y: Float, z: Float) {
        player.spawn(x, y, z);
    }

    // --- Input gather --------------------------------------------------------
    hide func gatherInput() {
        if scripted { return; }
        var md = input.MouseDelta();
        inLookDX = Math.Vec2.get_X(md);
        inLookDY = Math.Vec2.get_Y(md);
        inMoveX = 0.0; inMoveZ = 0.0;
        if actionMap.held(input, config.A_FORWARD) { inMoveZ = inMoveZ + 1.0; }
        if actionMap.held(input, config.A_BACK) { inMoveZ = inMoveZ - 1.0; }
        if actionMap.held(input, config.A_RIGHT) { inMoveX = inMoveX + 1.0; }
        if actionMap.held(input, config.A_LEFT) { inMoveX = inMoveX - 1.0; }
        inJump = actionMap.pressed(input, config.A_JUMP);
        inCrouch = actionMap.held(input, config.A_CROUCH);
        inSprint = actionMap.held(input, config.A_SPRINT);
        inFire = actionMap.held(input, config.A_FIRE);
        inADS = actionMap.held(input, config.A_ADS);
        inInteract = actionMap.pressed(input, config.A_INTERACT);
        inReload = actionMap.pressed(input, config.A_RELOAD);
        inNextWeapon = actionMap.pressed(input, config.A_NEXT_WEAPON);
        inPrevWeapon = actionMap.pressed(input, config.A_PREV_WEAPON);
        inDirectWeapon = -1;
        if actionMap.pressed(input, config.A_WEAPON_1) { inDirectWeapon = config.W_BOLT; }
        else if actionMap.pressed(input, config.A_WEAPON_2) { inDirectWeapon = config.W_SCATTER; }
        else if actionMap.pressed(input, config.A_WEAPON_3) { inDirectWeapon = config.W_CYCLER; }
        else if actionMap.pressed(input, config.A_WEAPON_4) { inDirectWeapon = config.W_PULSE; }
        else if actionMap.pressed(input, config.A_WEAPON_5) { inDirectWeapon = config.W_RAIL; }
        else if actionMap.pressed(input, config.A_WEAPON_6) { inDirectWeapon = config.W_ARC; }
        else if actionMap.pressed(input, config.A_WEAPON_7) { inDirectWeapon = config.W_RIVET; }
        else if actionMap.pressed(input, config.A_WEAPON_8) { inDirectWeapon = config.W_SHARD; }
        else if actionMap.pressed(input, config.A_WEAPON_9) { inDirectWeapon = config.W_EMP; }
        else if actionMap.pressed(input, config.A_WEAPON_10) { inDirectWeapon = config.W_LANCE; }
        var wheel = input.WheelY();
        if wheel > 0 { inPrevWeapon = true; }
        if wheel < 0 { inNextWeapon = true; }
        inGrenade = actionMap.pressed(input, config.A_GRENADE);
        inCycleGrenade = actionMap.pressed(input, config.A_CYCLE_GRENADE);
        inMelee = actionMap.pressed(input, config.A_MELEE);
        inFlashlight = actionMap.pressed(input, config.A_FLASHLIGHT);
        // Toggles.
        if actionMap.pressed(input, config.A_DIAG) { diag.toggle(); }
        if actionMap.pressed(input, config.A_DEV_LIGHTS) { arenaMap.cycleLighting(); }
        if actionMap.pressed(input, config.A_PAUSE) {
            if state == config.ST_PLAYING { requestState(config.ST_PAUSED); }
            else if state == config.ST_PAUSED { requestState(config.ST_PLAYING); }
        }
    }

    // Damaging EV_EXPLOSION rows carry enough metadata to resolve player splash.
    // The player is intentionally not registered as a ballistics target, so this
    // bridge applies the same linear falloff and half-damage cover rule here.
    hide func applyExplosionDamageToPlayer() {
        if playerHealth.isDead() { return; }
        var n = bus.getCount();
        var i = 0;
        while i < n {
            if bus.kindAt(i) == config.EV_EXPLOSION && bus.cAt(i) > 0 {
                var radius = bus.bAt(i) + 0.0;
                var damage = bus.aAt(i) + 0.0;
                var cx = bus.xAt(i); var cy = bus.yAt(i); var cz = bus.zAt(i);
                var px = player.getX(); var py = player.getFeetY() + 1.2; var pz = player.getZ();
                var d = M.dist3(cx, cy, cz, px, py, pz);
                if radius > 0.0 && d < radius {
                    var cover = 1.0;
                    if d > 0.05 {
                        var dir = Math.Vec3.New((px - cx) / d, (py - cy) / d, (pz - cz) / d);
                        var hit = phys.Raycast(Math.Vec3.New(cx, cy, cz), dir, d - 0.05,
                                               config.LAYER_WORLD);
                        if hit != null { cover = 0.5; }
                    }
                    var amount = damage * M.clampf(1.0 - d / radius, 0.0, 1.0) * cover;
                    if amount > 0.5 {
                        var bearing = M.toDeg(Math.Atan2(cx - px, 0.0 - (cz - pz)));
                        bus.push(config.EV_DAMAGE, config.TGT_PLAYER, -1, config.REGION_BODY,
                                 amount, bearing, bus.cAt(i) - 1.0);
                    }
                }
            }
            i = i + 1;
        }
    }

    // Score events before evaluating completion. Otherwise a final-frame kill or
    // damage event would miss the medal/profile snapshot and appear only on the
    // following completion screen.
    hide func applyScoringEvents() {
        var n = bus.getCount();
        var i = 0;
        while i < n {
            if bus.kindAt(i) == config.EV_KILL {
                score.addKill();
            } else if bus.kindAt(i) == config.EV_DAMAGE && bus.aAt(i) == config.TGT_PLAYER {
                score.addDamage(M.roundi(bus.xAt(i)));
            }
            i = i + 1;
        }
    }

    // Drain feedback rows: muzzle/blast particles, hitmarkers, kills, damage flash.
    hide func drainFeedbackEvents() {
        var n = bus.getCount();
        var i = 0;
        while i < n {
            var k = bus.kindAt(i);
            if k == config.EV_GUNSHOT {
                gunshotFeedback(bus.aAt(i), bus.bAt(i), bus.xAt(i), bus.yAt(i), bus.zAt(i));
            } else if k == config.EV_EXPLOSION {
                fx.explosion(bus.xAt(i), bus.yAt(i), bus.zAt(i), bus.bAt(i) + 0.0);
                lightRig.pulse(bus.xAt(i), bus.yAt(i) + 0.5, bus.zAt(i),
                               1.6, 0.9, 0.35, (bus.bAt(i) + 0.0) * 2.0, 0.25);
            } else if k == config.EV_ENEMY_SHOT {
                fx.muzzleColored(bus.xAt(i), bus.yAt(i), bus.zAt(i), 1.0, 0.22, 0.12);
                lightRig.pulse(bus.xAt(i), bus.yAt(i), bus.zAt(i), 1.4, 0.22, 0.10, 5.0, 0.10);
            } else if k == config.EV_IMPACT {
                fx.impact(bus.xAt(i), bus.yAt(i), bus.zAt(i));
            } else if k == config.EV_HITMARKER {
                hudSys.pulseHitmarker(bus.aAt(i));
            } else if k == config.EV_CHECKPOINT {
                // A gate can open on the same tick that a mission completes or
                // the player dies. Never recreate a checkpoint after completion
                // cleared it, and never snapshot a dead player.
                if playerHealth.isDead() == false && levelMgr.isComplete() == false {
                    saveCheckpointNow();
                }
            } else if k == config.EV_KILL {
                hudSys.pushKill(edefs.nameOf(bus.bAt(i)));
            } else if k == config.EV_DAMAGE && bus.aAt(i) == config.TGT_PLAYER {
                hudSys.pulseDamage();
                hudSys.pulseDamageDir(bus.yAt(i) - camRig.getYaw());
                var sourceArch = bus.bAt(i);
                if sourceArch >= 0 && sourceArch < config.EN_TYPE_COUNT {
                    lastDamagerName = "killed by " + edefs.nameOf(sourceArch);
                } else if M.roundi(bus.zAt(i)) == config.DMG_EXPLOSION {
                    lastDamagerName = "killed by an explosion";
                } else {
                    lastDamagerName = "combat systems failure";
                }
            }
            i = i + 1;
        }
    }

    // A shot's visual feedback: colored muzzle flash + reserved light pulse at
    // the muzzle, a tracer to the ray's real endpoint, and an impact + scorch on
    // solid hits. (ox,oy,oz) is the eye; the muzzle sits forward-right-below.
    hide func gunshotFeedback(w: Integer, loudness: Integer, ox: Float, oy: Float, oz: Float) {
        var fxx = camRig.forwardX(); var fxy = camRig.forwardY(); var fxz = camRig.forwardZ();
        var rx = 0.0 - fxz; var rz = fxx;
        var mx = ox + fxx * 0.5 + rx * 0.13;
        var my = oy + fxy * 0.5 - 0.12;
        var mz = oz + fxz * 0.5 + rz * 0.13;
        var cr = weapon_models.flashR(w);
        var cg = weapon_models.flashG(w);
        var cb = weapon_models.flashB(w);
        fx.muzzleColored(mx, my, mz, cr, cg, cb);
        if loudness >= 18 {
            lightRig.pulse(mx, my, mz, cr * 1.6, cg * 1.6, cb * 1.6, 7.0, 0.08);
        }
        // Hitscan visuals: tracer to the traced endpoint + impact on solids.
        if wdefs.isProjectile(w) == false {
            if wdefs.isRicochet(w) {
                var rsx = mx; var rsy = my; var rsz = mz;
                var ri = 0;
                while ri < ball.ricochetPointCount() {
                    var rex = ball.ricochetXat(ri);
                    var rey = ball.ricochetYat(ri);
                    var rez = ball.ricochetZat(ri);
                    fx.tracer(rsx, rsy, rsz, rex, rey, rez,
                              cr, cg, cb, weapon_models.tracerTtl(w));
                    rsx = rex; rsy = rey; rsz = rez;
                    ri = ri + 1;
                }
            } else {
                fx.tracer(mx, my, mz, ball.lastEndX(), ball.lastEndY(), ball.lastEndZ(),
                          cr, cg, cb, weapon_models.tracerTtl(w));
            }
            if ball.lastHitSolid() {
                fx.impact(ball.lastEndX(), ball.lastEndY(), ball.lastEndZ());
                fx.scorch(ball.lastEndX(), ball.lastEndY(), ball.lastEndZ(),
                          ball.lastNormalX(), ball.lastNormalY(), ball.lastNormalZ());
            }
        }
    }

    // Drain "collected pickup" rows (EV_PICKUP with the collected marker c==1).
    hide func drainCollectedPickups() {
        var n = bus.getCount();
        var i = 0;
        while i < n {
            if bus.kindAt(i) == config.EV_PICKUP && bus.cAt(i) == 1 {
                var k = bus.aAt(i);
                if k == config.PK_AMMO { weapons.addReserveAll(bus.bAt(i)); }
                else if k == config.PK_SALVAGE { econ.addSalvage(bus.bAt(i)); }
                else if k == config.PK_DATACORE { levelMgr.getObjectives().addCollect(bus); }
            }
            i = i + 1;
        }
    }

    expose func getLevelMgr() -> level_manager.LevelManager { return levelMgr; }
    expose func getPickups() -> pickups.Pickups { return pickupSys; }

    // --- One fixed simulation tick (no physics step, no render) --------------
    expose func tickSim(dt: Float) {
        applyPending();
        tickCount = tickCount + 1;
        playTime = playTime + dt;

        cine.update(dt);
        if state != config.ST_PLAYING {
            tickMenus(dt);
        }
        if state == config.ST_PLAYING {
            if cine.isIntroActive() && headless == false {
                // Intro flight: the world simulates visuals only; input waits.
                lightRig.update(dt);
                levelMgr.updateProps(dt);
                fx.update(dt);
                hudSys.tick(dt);
                if introSkipPressed() { cine.skipIntro(); }
                updateDiag();
                diag.checkBudgets();
                bus.drain();
                return;
            }
            gatherInput();
            score.tick(dt);
            camRig.applyLook(inLookDX, inLookDY);
            player.update(dt, inMoveX, inMoveZ, inJump, inCrouch, inSprint, camRig.getYaw(), bus);
            camRig.updateSim(dt, player, inADS, weapons.adsFov());
            vm.updateSim(dt, inLookDX, inLookDY, player.getSpeed(), player.isGrounded(), camRig.getAdsT());

            // Weapon switch.
            if inNextWeapon { weapons.nextWeapon(); }
            if inPrevWeapon { weapons.prevWeapon(); }
            if inDirectWeapon >= 0 { weapons.switchTo(inDirectWeapon); }
            if inCycleGrenade { cycleGrenade(); }
            if grenadeCd > 0.0 { grenadeCd = grenadeCd - dt; }
            if meleeCd > 0.0 { meleeCd = meleeCd - dt; }

            // Fire from the camera eye along the aim direction.
            var ex = camRig.getEyeX(); var ey = camRig.getEyeY(); var ez = camRig.getEyeZ();
            var fdx = camRig.forwardX(); var fdy = camRig.forwardY(); var fdz = camRig.forwardZ();
            if inGrenade { throwGrenade(ex, ey, ez, fdx, fdy, fdz); }
            if inMelee { meleeAttack(ex, ey, ez, fdx, fdy, fdz); }
            updateFlashlight(ex, ey, ez, fdx, fdy, fdz);
            weapons.update(dt, inFire, inADS, inReload, ex, ey, ez, fdx, fdy, fdz);
            weapons.autoReloadIfEmpty();
            proj.update(dt);

            // Enemies perceive (hearing reads this tick's gunshots), act, and may
            // post EV_DAMAGE(TGT_PLAYER) + chain EV_DAMAGE(TGT_ENEMY).
            var chestY = player.getFeetY() + 1.2;
            var alive = playerHealth.isDead() == false;
            enemies.update(dt, player.getX(), chestY, player.getZ(), alive);
            if currentLevel == config.LV_ARENA { arenaMap.update(dt); }

            // Consumers: apply this tick's damage events before the bus drains.
            if currentLevel == config.LV_ARENA { arenaMap.applyDamageEvents(bus, targetReg); }
            if currentLevel != config.LV_ARENA { levelMgr.applyHazardDamageEvents(); }
            enemies.applyDamageEvents();
            applyExplosionDamageToPlayer();
            playerHealth.update(dt, bus, diffSys.incomingDamageScale());
            applyScoringEvents();
            if playerHealth.isDead() { requestState(config.ST_DEATH); }

            // Campaign world systems (arena is standalone).
            if currentLevel != config.LV_ARENA {
                pickupSys.drainDrops();
                pickupSys.update(dt, player.getX(), player.getFeetY() + 0.9, player.getZ());
                drainCollectedPickups();
                if inInteract { levelMgr.onInteract(player.getX(), player.getZ()); }
                levelMgr.update(dt, player.getX(), player.getZ());
                // Death wins a simultaneous trade. This prevents a final-frame
                // enemy kill from replacing the death/retry checkpoint flow.
                if levelMgr.isComplete() && playerHealth.isDead() == false {
                    score.recordLevel(currentLevel);
                    saveProfileProgress(currentLevel);
                    save.clearCheckpoint();
                    requestState(config.ST_LEVEL_COMPLETE);
                }
            }

            // Feedback: fx / hitmarkers / audio / scoring from the frame's events.
            lightRig.update(dt);
            levelMgr.updateProps(dt);
            fx.ambientTrack(player.getX(), player.getFeetY(), player.getZ());
            scanBoss();
            if currentLevel == config.LV_L9 { lightRig.setHelixPhase(bossPhase); }
            drainFeedbackEvents();
            mixer.update(dt, bus, bossFrac > 0.0, enemies.aliveCount() > 0);
            fx.update(dt);
            hudSys.tick(dt);
        }

        updateDiag();
        diag.checkBudgets();
        bus.drain();
    }

    // --- Frontend state handling ------------------------------------------------
    hide func introSkipPressed() -> Boolean {
        if headless { return false; }
        return input.Pressed(Key.get_Enter()) || input.Pressed(Key.get_Space()) ||
               input.MousePressed(0);
    }

    // Tell the menu layer about a state it hasn't seen, gather nav input, and
    // execute whatever command the menu returns.
    hide func tickMenus(dt: Float) {
        if state != menuStateSeen {
            menuStateSeen = state;
            if state == config.ST_PAUSED { menuSys.enterPause(); }
            else if state == config.ST_DEATH {
                score.addDeath();
                saveProfileState();
                mixer.playDefeat();
                menuSys.enterDeath(lastDamagerName);
            } else if state == config.ST_LEVEL_COMPLETE { enterCompleteMenu(); }
            else if state == config.ST_CREDITS { menuSys.enterCredits(); }
        }
        // Title vista + world dressing keep animating behind the menus.
        if state == config.ST_TITLE || state == config.ST_CREDITS {
            lightRig.update(dt);
            levelMgr.updateProps(dt);
            fx.update(dt);
        }
        var up = false; var down = false; var left = false; var right = false;
        var confirm = false; var back = false;
        if headless == false {
            up = input.Pressed(Key.get_W()) || input.Pressed(Key.get_Up());
            down = input.Pressed(Key.get_S()) || input.Pressed(Key.get_Down());
            left = input.Pressed(Key.get_A()) || input.Pressed(Key.get_Left());
            right = input.Pressed(Key.get_D()) || input.Pressed(Key.get_Right());
            confirm = input.Pressed(Key.get_Enter()) || input.Pressed(Key.get_Space());
            back = input.Pressed(Key.get_Escape());
        }
        var cmd = menuSys.update(dt, up, down, left, right, confirm, back);
        runMenuCommand(cmd);
    }

    hide func enterCompleteMenu() {
        mixer.playVictory();
        refreshArmory();
        var lines: List[String] = [];
        lines.Add("TIME      " + S.intStr(M.roundi(score.getLevelTime())) + "s");
        lines.Add("KILLS     " + S.intStr(score.getKills()));
        var shots = ball.getShotsFired();
        var acc = 0;
        if shots > 0 { acc = ball.getHitsLanded() * 100 / shots; }
        lines.Add("ACCURACY  " + S.intStr(acc) + "%");
        lines.Add("SALVAGE   " + S.intStr(econ.available()));
        var medalTxt = "";
        var md = score.medal();
        if md == scoring.MEDAL_ASHBORN { medalTxt = "MEDAL: ASHBORN"; }
        else if md == scoring.MEDAL_GOLD { medalTxt = "MEDAL: GOLD"; }
        else if md == scoring.MEDAL_SILVER { medalTxt = "MEDAL: SILVER"; }
        else { medalTxt = "MEDAL: BRONZE"; }
        menuSys.enterComplete(lines, medalTxt);
    }

    hide func runMenuCommand(cmd: Integer) {
        if cmd == menu.CMD_NONE { return; }
        if cmd == menu.CMD_SETTINGS_CHANGED { applySettings(); return; }
        if cmd == menu.CMD_BUY_UPGRADE {
            var uw = menuSys.selectedUpgradeWeapon();
            var cost = econ.nextCost(uw);
            if cost < 0 {
                menuSys.setArmoryMessage("WEAPON ALREADY AT MAXIMUM TIER");
            } else if econ.buyUpgrade(uw) {
                saveProfileState();
                menuSys.setArmoryMessage("UPGRADE INSTALLED");
            } else {
                menuSys.setArmoryMessage("NEED " + S.intStr(cost) + " SALVAGE");
            }
            refreshArmory();
            return;
        }
        if cmd == menu.CMD_NEW_GAME {
            save.clearCheckpoint();
            forceState(config.ST_LOADING);
            applyPending();
            startLevelFromMenu(config.LV_L1);
            return;
        }
        if cmd == menu.CMD_CONTINUE {
            forceState(config.ST_LOADING);
            applyPending();
            if continueCheckpoint() == false { startLevelFromMenu(config.LV_L1); }
            return;
        }
        if cmd == menu.CMD_LOAD_LEVEL {
            var id = menuSys.selectedLevelId();
            if id == config.LV_ARENA {
                loadArenaScene();
                return;
            }
            forceState(config.ST_LOADING);
            applyPending();
            startLevelFromMenu(id);
            return;
        }
        if cmd == menu.CMD_RESUME { forceState(config.ST_PLAYING); return; }
        if cmd == menu.CMD_RESTART {
            forceState(config.ST_LOADING);
            applyPending();
            if menuSys.currentCtx() == menu.CTX_DEATH {
                var killsNow = score.getTotalKills();
                var deathsNow = score.getTotalDeaths();
                var timeNow = score.getTotalTime();
                if continueCheckpoint() {
                    score.restoreTotals(killsNow, deathsNow, timeNow);
                    saveProfileState();
                    return;
                }
            }
            startLevelFromMenu(currentLevel);
            return;
        }
        if cmd == menu.CMD_REPLAY {
            forceState(config.ST_LOADING);
            applyPending();
            startLevelFromMenu(currentLevel);
            return;
        }
        if cmd == menu.CMD_NEXT_LEVEL {
            var next = currentLevel + 1;
            if currentLevel >= config.LV_L9 {
                menuSys.enterCredits();
                forceState(config.ST_CREDITS);
                return;
            }
            forceState(config.ST_LOADING);
            applyPending();
            startLevelFromMenu(next);
            return;
        }
        if cmd == menu.CMD_QUIT_TITLE {
            enterTitle();
            return;
        }
        if cmd == menu.CMD_CREDITS_DONE {
            enterTitle();
            return;
        }
        if cmd == menu.CMD_QUIT_APP { running = false; return; }
    }

    // Track the first live boss (HUD bar + L9 phase lighting read this).
    hide func scanBoss() {
        bossName = "";
        bossFrac = 0.0;
        bossPhase = 0;
        var bi = 0;
        while bi < config.POOL_AI {
            if enemies.isAlive(bi) && edefs.isBoss(enemies.archOf(bi)) {
                var ba = enemies.archOf(bi);
                bossName = edefs.nameOf(ba);
                var mx = enemies.maxHealthOf(bi);
                if mx > 0.5 { bossFrac = enemies.healthOf(bi) / mx; }
                if bossFrac < 0.66 { bossPhase = 1; }
                if bossFrac < 0.33 { bossPhase = 2; }
                return;
            }
            bi = bi + 1;
        }
    }

    /// Cycle to the next grenade type that has stock, if any.
    hide func cycleGrenade() {
        var tries = 0;
        while tries < config.GRENADE_COUNT {
            grenadeSelected = (grenadeSelected + 1) % config.GRENADE_COUNT;
            if grenadeStock[grenadeSelected] > 0 { return; }
            tries = tries + 1;
        }
    }

    /// Throw the selected grenade from the camera eye with a light upward arc.
    hide func throwGrenade(ox: Float, oy: Float, oz: Float,
                           fdx: Float, fdy: Float, fdz: Float) {
        if grenadeCd > 0.0 { return; }
        if grenadeSelected < 0 || grenadeSelected >= grenadeStock.Count { return; }
        if grenadeStock[grenadeSelected] <= 0 { return; }
        grenadeStock[grenadeSelected] = grenadeStock[grenadeSelected] - 1;
        grenadeCd = 0.85;
        var dx = fdx;
        var dy = fdy + 0.18;
        var dz = fdz;
        var len = Math.Sqrt(dx * dx + dy * dy + dz * dz);
        if len > 0.01 { dx = dx / len; dy = dy / len; dz = dz / len; }
        var dmg = 110.0;
        var radius = 6.0;
        var kind = config.DMG_EXPLOSION;
        var life = 2.6;
        if grenadeSelected == config.GRENADE_EMP {
            dmg = 6.0; radius = 7.0; kind = config.DMG_EMP; life = 2.4;
        } else if grenadeSelected == config.GRENADE_DECOY {
            dmg = 0.0; radius = 0.0; kind = config.DMG_DECOY; life = 2.1;
        }
        proj.spawn(ox + fdx * 0.35, oy - 0.12, oz + fdz * 0.35,
                   dx, dy, dz, 18.0, dmg, radius, 0.0, 0.0, -14.0, 1, life, kind);
        bus.pushAt(config.EV_GUNSHOT, weapons.getCurrent(), 14, ox, oy, oz);
        camRig.addShake(0.04);
        vm.addKick(2.0);
        cycleGrenadeIfEmpty();
    }

    /// Advance grenade selection after a throw empties the current type.
    hide func cycleGrenadeIfEmpty() {
        if grenadeSelected >= 0 && grenadeSelected < grenadeStock.Count {
            if grenadeStock[grenadeSelected] > 0 { return; }
        }
        cycleGrenade();
    }

    /// Perform a short-range melee strike using the shared ballistics pipeline.
    hide func meleeAttack(ox: Float, oy: Float, oz: Float,
                          fdx: Float, fdy: Float, fdz: Float) {
        if meleeCd > 0.0 { return; }
        meleeCd = 0.55;
        ball.fireHitscan(ox, oy, oz, fdx, fdy, fdz, 1, 0.0, 70.0, 1, 2.4, config.DMG_MELEE);
        bus.pushAt(config.EV_MELEE, 0, 8, ox, oy, oz);
        camRig.addShake(0.035);
        vm.addKick(3.0);
    }

    /// Toggle and pulse the flashlight as a narrow forward utility light.
    hide func updateFlashlight(ox: Float, oy: Float, oz: Float,
                               fdx: Float, fdy: Float, fdz: Float) {
        if inFlashlight {
            flashlightOn = flashlightOn == false;
        }
        lightRig.setFlashlight(flashlightOn, ox, oy, oz, fdx, fdy, fdz);
    }

    // Step the physics world one fixed increment (called after tickSim).
    expose func stepPhysics(dt: Float) {
        if graphicsUp { G3D.PhysicsWorld3D.Step(phys, dt); }
    }

    hide func updateDiag() {
        diag.setTiming(canvas.Fps + 0.0, canvas.DeltaTimeSec * 1000.0);
        diag.setDraws(canvas.DrawsSubmitted,
                      canvas.FrustumCulledDrawCount + canvas.CpuOccludedDrawCount);
        diag.setLights(canvas.LightCount, canvas.DroppedLightCount, canvas.ClusterOverflowCount);
        diag.setShadows(canvas.ShadowSlotsUsed, canvas.ShadowRequestsDropped);
        diag.setPhysics(phys.LastSolverActiveBodyCount, phys.CcdToiCount);
        diag.setCounts(reg.countOf(config.ARCH_ENEMY), reg.countOf(config.ARCH_PROJECTILE), 0, 0);
    }

    hide func drawObjectiveBeacon() {
        if objBeaconReady == false { return; }
        if currentLevel == config.LV_ARENA { return; }
        if state != config.ST_PLAYING && state != config.ST_PAUSED { return; }
        var obj = levelMgr.getObjectives();
        var oi = obj.activeIndex();
        if oi < 0 { return; }
        var k = obj.kindOf(oi);
        var mx = obj.txAt(oi);
        var mz = obj.tzAt(oi);
        var hasMarker = false;
        var ready = false;
        var enemyMarker = false;
        if k == objectives.OBJ_REACH || k == objectives.OBJ_ACTIVATE ||
           k == objectives.OBJ_SURVIVE || k == objectives.OBJ_COLLECT {
            hasMarker = true;
            if k == objectives.OBJ_ACTIVATE {
                ready = M.distXZ(player.getX(), player.getZ(), mx, mz) <= obj.radiusOf(oi);
            }
        } else if k == objectives.OBJ_CLEAR || k == objectives.OBJ_KILL {
            var target = enemies.nearestAliveTo(player.getX(), player.getZ());
            if target >= 0 {
                mx = enemies.posX(target);
                mz = enemies.posZ(target);
                hasMarker = true;
                enemyMarker = true;
            }
        }
        if hasMarker == false { return; }
        var mat = objBeaconMat;
        if ready { mat = objReadyMat; }
        if enemyMarker { mat = objEnemyMat; }
        var bob = Math.Sin(playTime * 4.0) * 0.18;
        G3D.Canvas3D.DrawMesh(canvas, objBeaconMesh, Math.Mat4.Translate(mx, 1.10, mz), mat);
        G3D.Canvas3D.DrawMesh(canvas, objBeaconTopMesh, Math.Mat4.Translate(mx, 2.55 + bob, mz), mat);
    }

    // --- Render (manual scene + overlay) -------------------------------------
    hide func render(alpha: Float, profileFrame: Integer) {
        var measureStages = profileFrame > 0 && profileFrame <= 3;
        var stageStartUs = 0;
        var beginUs = 0;
        var sceneUs = 0;
        var effectsUs = 0;
        var endSceneUs = 0;
        var weaponUs = 0;
        var overlayUs = 0;
        if measureStages { stageStartUs = Clock.NowMicros(); }
        world.BeginFrame();
        G3D.Canvas3D.Clear(canvas, clearR, clearG, clearB);
        if state == config.ST_TITLE || state == config.ST_CREDITS {
            cine.applyOrbit(camera, 0.0, 0.0, -6.0, 34.0, 13.0);
        } else if cine.isIntroActive() {
            cine.applyIntroCamera(camera);
        } else {
            camRig.applyToCamera(camera, alpha);
        }
        if measureStages {
            beginUs = Clock.NowMicros() - stageStartUs;
            stageStartUs = Clock.NowMicros();
        }
        // Exterior terrain first (visual backdrop; playfield colliders are slabs).
        if levelMgr.hasTerrain() {
            G3D.Canvas3D.DrawTerrainAt(canvas, levelMgr.terrainObj(),
                                       levelMgr.terrainOffX(), levelMgr.terrainOffY(),
                                       levelMgr.terrainOffZ());
        }
        world.DrawScene();
        if measureStages {
            sceneUs = Clock.NowMicros() - stageStartUs;
            stageStartUs = Clock.NowMicros();
        }
        levelMgr.drawProps();
        drawObjectiveBeacon();
        if proj.activeProjectiles() > 0 {
            proj.draw(canvas);
        }
        if enemies.hostileProjectileCount() > 0 { enemies.drawProjectiles(canvas); }
        fx.draw(canvas, camera);
        if levelMgr.hasWater() { G3D.Canvas3D.DrawWater(canvas, levelMgr.waterObj(), camera); }
        world.DrawEffects();
        lightRig.drawFlare();
        if measureStages {
            effectsUs = Clock.NowMicros() - stageStartUs;
            stageStartUs = Clock.NowMicros();
        }
        world.EndScene();
        if measureStages {
            endSceneUs = Clock.NowMicros() - stageStartUs;
            stageStartUs = Clock.NowMicros();
        }
        // First-person weapon (independent-FOV pass; never clips the world).
        if (state == config.ST_PLAYING || state == config.ST_PAUSED) &&
           cine.isIntroActive() == false {
            weaponVis.drawViewModel(canvas, camera, camRig, vm, weapons);
        }
        if measureStages {
            weaponUs = Clock.NowMicros() - stageStartUs;
            stageStartUs = Clock.NowMicros();
        }
        G3D.Canvas3D.BeginOverlay(canvas);
        drawHud();
        G3D.Canvas3D.EndOverlay(canvas);
        if measureStages { overlayUs = Clock.NowMicros() - stageStartUs; }
        if measureStages {
            Terminal.Say("PLAY_PERF_RENDER: frame=" + Fmt.Int(profileFrame) +
                         " begin_ms=" + Fmt.NumFixed((beginUs + 0.0) / 1000.0, 3) +
                         " scene_ms=" + Fmt.NumFixed((sceneUs + 0.0) / 1000.0, 3) +
                         " effects_ms=" + Fmt.NumFixed((effectsUs + 0.0) / 1000.0, 3) +
                         " end_scene_ms=" + Fmt.NumFixed((endSceneUs + 0.0) / 1000.0, 3) +
                         " weapon_ms=" + Fmt.NumFixed((weaponUs + 0.0) / 1000.0, 3) +
                         " overlay_ms=" + Fmt.NumFixed((overlayUs + 0.0) / 1000.0, 3));
        }
    }

    hide func drawHud() {
        // Overlay coordinates follow the live drawable, including fullscreen,
        // resize and render-scale changes.
        var w = canvas.Width;
        var h = canvas.Height;
        if w <= 0 { w = config.WINDOW_WIDTH; }
        if h <= 0 { h = config.WINDOW_HEIGHT; }
        var campaign = currentLevel != config.LV_ARENA;
        if state == config.ST_PLAYING && cine.isIntroActive() == false {
            // Compass bearing toward the active positional objective.
            var objBearing = 0.0;
            var hasMarker = false;
            var objDistance = -1.0;
            var objPrompt = "";
            var objReady = false;
            if campaign {
                var obj = levelMgr.getObjectives();
                var oi = obj.activeIndex();
                if oi >= 0 {
                    var k = obj.kindOf(oi);
                    objPrompt = obj.promptOf(oi);
                    if k == objectives.OBJ_REACH || k == objectives.OBJ_ACTIVATE ||
                       k == objectives.OBJ_SURVIVE || k == objectives.OBJ_COLLECT {
                        var dx = obj.txAt(oi) - player.getX();
                        var dz = obj.tzAt(oi) - player.getZ();
                        objBearing = M.toDeg(Math.Atan2(dx, 0.0 - dz));
                        objDistance = Math.Sqrt(dx * dx + dz * dz);
                        hasMarker = true;
                        if k == objectives.OBJ_ACTIVATE {
                            if objDistance <= obj.radiusOf(oi) {
                                objPrompt = "PRESS E TO ACTIVATE";
                                objReady = true;
                            }
                        }
                    } else if k == objectives.OBJ_CLEAR || k == objectives.OBJ_KILL {
                        var target = enemies.nearestAliveTo(player.getX(), player.getZ());
                        if target >= 0 {
                            var edx = enemies.posX(target) - player.getX();
                            var edz = enemies.posZ(target) - player.getZ();
                            objBearing = M.toDeg(Math.Atan2(edx, 0.0 - edz));
                            objDistance = Math.Sqrt(edx * edx + edz * edz);
                            hasMarker = true;
                            objPrompt = "ELIMINATE HOSTILES: " + S.intStr(enemies.aliveCount()) + " REMAIN";
                        }
                    }
                }
            }
            var waveIndex = 0;
            var waveCount = 0;
            if campaign {
                waveIndex = levelMgr.currentWaveIndex();
                waveCount = levelMgr.waveTotal();
            }
            hudSys.draw(canvas, w, h, playerHealth, weapons, levelMgr.getObjectives(),
                        campaign, camRig.getYaw(),
                        objBearing, hasMarker, objDistance, objPrompt, objReady,
                        grenadeName(), grenadeCount(), flashlightOn, bossName, bossFrac,
                        enemies.aliveCount(), waveIndex, waveCount, econ.available());
        }
        if diag.isEnabled() {
            G3D.Canvas3D.DrawText2D(canvas, 8, 8, diag.line1(), 0xFFFFFF);
            G3D.Canvas3D.DrawText2D(canvas, 8, 22, diag.line2(), 0xFFFFFF);
            G3D.Canvas3D.DrawText2D(canvas, 8, 36, diag.line3(), 0xFFFFFF);
        }
        // Frontend screens.
        if state == config.ST_TITLE || state == config.ST_PAUSED ||
           state == config.ST_DEATH || state == config.ST_LEVEL_COMPLETE ||
           state == config.ST_CREDITS {
            menuSys.draw(canvas, w, h);
        } else if state == config.ST_LOADING {
            menuSys.drawLoading(canvas, w, h, currentLevel);
        }
        // L6 lightning strobe: a brief full-screen sky flash.
        var sa = lightRig.strobeOverlayAlpha() * menuSys.flashValue();
        if sa > 0.01 { G3D.Canvas3D.DrawRect2DAlpha(canvas, 0, 0, w, h, 0xE8F0FF, sa); }
        // Cinematic bars + fades sit on top of everything.
        cine.drawOverlay(canvas, w, h);
    }

    expose func getEconomy() -> economy.Economy { return econ; }
    expose func getDifficulty2() -> difficulty.Difficulty { return diffSys; }
    expose func getScoring() -> scoring.Scoring { return score; }
    expose func getMixer() -> mix.Mixer { return mixer; }

    hide func handleMouseCapture() {
        if headless { return; }
        if state == config.ST_PLAYING && mouseCaptured == false {
            input.CaptureMouse();
            mouseCaptured = true;
        }
        if state != config.ST_PLAYING && mouseCaptured {
            input.ReleaseMouse();
            mouseCaptured = false;
        }
    }

    // --- The interactive loop (assumes boot() already ran) -------------------
    // A positive profileFrames enables bounded telemetry without changing the
    // boot, update, simulation, render, post-FX, or presentation path.
    hide func runLoop(profileFrames: Integer) {
        var frameLimit = profileFrames;
        if frameLimit < 0 { frameLimit = 0; }
        var profiling = frameLimit > 0;
        var accum = 0.0;
        var frame = 0;
        var intervalFrames = 120;
        var intervalStartUs = 0;
        var totalStartUs = 0;
        var intervalUpdateUs = 0;
        var intervalSimUs = 0;
        var intervalRenderUs = 0;
        var intervalPresentUs = 0;
        var intervalSteps = 0;
        var intervalWorstUs = 0;
        var totalWorstUs = 0;
        var totalSteps = 0;
        var startTracked = 0;

        if profiling {
            intervalStartUs = Clock.NowMicros();
            totalStartUs = intervalStartUs;
            startTracked = GC.TrackedCount();
            Terminal.Say("PLAY_PERF_START: backend=" + canvas.Backend +
                         " frames=" + Fmt.Int(frameLimit) +
                         " canvas=" + Fmt.Int(canvas.Width) + "x" + Fmt.Int(canvas.Height) +
                         " window=" + Fmt.Int(canvas.WindowWidth) + "x" +
                                      Fmt.Int(canvas.WindowHeight) +
                         " output=" + Fmt.Int(canvas.ActiveOutputWidth) + "x" +
                                      Fmt.Int(canvas.ActiveOutputHeight) +
                         " scale=" + Fmt.NumFixed(canvas.RenderScale, 3));
        }

        while running {
            var frameStartUs = 0;
            var stageStartUs = 0;
            var updateUs = 0;
            var simUs = 0;
            var renderUs = 0;
            var presentUs = 0;
            if profiling {
                frameStartUs = Clock.NowMicros();
                stageStartUs = frameStartUs;
            }
            if world.Update() == false { break; }
            if profiling { updateUs = Clock.NowMicros() - stageStartUs; }
            handleMouseCapture();
            var frameDt = world.DeltaTime;
            if frameDt > 0.1 { frameDt = 0.1; }
            accum = accum + frameDt;
            var steps = 0;
            if profiling { stageStartUs = Clock.NowMicros(); }
            while accum >= config.FIXED_DT && steps < config.MAX_SUBSTEPS {
                tickSim(config.FIXED_DT);
                stepPhysics(config.FIXED_DT);
                accum = accum - config.FIXED_DT;
                steps = steps + 1;
            }
            if profiling { simUs = Clock.NowMicros() - stageStartUs; }
            if accum > config.FIXED_DT * (config.MAX_SUBSTEPS + 0.0) { accum = 0.0; }
            var alpha = accum / config.FIXED_DT;
            if profiling { stageStartUs = Clock.NowMicros(); }
            var profileRenderFrame = 0;
            if profiling && frame < 3 { profileRenderFrame = frame + 1; }
            render(alpha, profileRenderFrame);
            if profiling {
                renderUs = Clock.NowMicros() - stageStartUs;
                stageStartUs = Clock.NowMicros();
            }
            world.Present();
            if profiling { presentUs = Clock.NowMicros() - stageStartUs; }

            frame = frame + 1;
            if profiling {
                var frameUs = Clock.NowMicros() - frameStartUs;
                intervalUpdateUs = intervalUpdateUs + updateUs;
                intervalSimUs = intervalSimUs + simUs;
                intervalRenderUs = intervalRenderUs + renderUs;
                intervalPresentUs = intervalPresentUs + presentUs;
                intervalSteps = intervalSteps + steps;
                totalSteps = totalSteps + steps;
                if frameUs > intervalWorstUs { intervalWorstUs = frameUs; }
                if frameUs > totalWorstUs { totalWorstUs = frameUs; }

                if frame % intervalFrames == 0 || frame >= frameLimit {
                    var reportFrames = frame % intervalFrames;
                    if reportFrames == 0 { reportFrames = intervalFrames; }
                    var nowUs = Clock.NowMicros();
                    var elapsedUs = nowUs - intervalStartUs;
                    Terminal.Say("PLAY_PERF_INTERVAL: frame=" + Fmt.Int(frame) +
                                 " fps=" + Fmt.NumFixed((reportFrames * 1000000.0) /
                                                           elapsedUs, 3) +
                                 " canvas_fps=" + Fmt.Int(canvas.Fps) +
                                 " avg_ms=" + Fmt.NumFixed((elapsedUs + 0.0) /
                                                              (reportFrames * 1000.0), 3) +
                                 " worst_ms=" + Fmt.NumFixed((intervalWorstUs + 0.0) / 1000.0, 3) +
                                 " update_ms=" + Fmt.NumFixed((intervalUpdateUs + 0.0) /
                                                                 (reportFrames * 1000.0), 3) +
                                 " sim_ms=" + Fmt.NumFixed((intervalSimUs + 0.0) /
                                                              (reportFrames * 1000.0), 3) +
                                 " render_ms=" + Fmt.NumFixed((intervalRenderUs + 0.0) /
                                                                 (reportFrames * 1000.0), 3) +
                                 " present_ms=" + Fmt.NumFixed((intervalPresentUs + 0.0) /
                                                                  (reportFrames * 1000.0), 3) +
                                 " steps=" + Fmt.NumFixed((intervalSteps + 0.0) /
                                                             (reportFrames + 0.0), 3) +
                                 " dt_ms=" + Fmt.NumFixed(world.DeltaTime * 1000.0, 3) +
                                 " gpu_ms=" + Fmt.NumFixed((canvas.FrameGpuTimeUs + 0.0) / 1000.0, 3) +
                                 " passes_ms=" + Fmt.NumFixed(canvas.PassCpuMs(0), 3) + "/" +
                                                    Fmt.NumFixed(canvas.PassCpuMs(1), 3) + "/" +
                                                    Fmt.NumFixed(canvas.PassCpuMs(2), 3) + "/" +
                                                    Fmt.NumFixed(canvas.PassCpuMs(3), 3) +
                                 " draws=" + Fmt.Int(canvas.DrawsSubmitted) +
                                 " tracked=" + Fmt.Int(GC.TrackedCount()) +
                                 " output=" + Fmt.Int(canvas.ActiveOutputWidth) + "x" +
                                              Fmt.Int(canvas.ActiveOutputHeight));
                    intervalStartUs = Clock.NowMicros();
                    intervalUpdateUs = 0;
                    intervalSimUs = 0;
                    intervalRenderUs = 0;
                    intervalPresentUs = 0;
                    intervalSteps = 0;
                    intervalWorstUs = 0;
                }
                if frame >= frameLimit { break; }
            }
        }
        if profiling {
            var totalUs = Clock.NowMicros() - totalStartUs;
            Terminal.Say("PLAY_PERF_SUMMARY: backend=" + canvas.Backend +
                         " frames=" + Fmt.Int(frame) +
                         " fps=" + Fmt.NumFixed((frame * 1000000.0) / totalUs, 3) +
                         " avg_ms=" + Fmt.NumFixed((totalUs + 0.0) / (frame * 1000.0), 3) +
                         " worst_ms=" + Fmt.NumFixed((totalWorstUs + 0.0) / 1000.0, 3) +
                         " steps=" + Fmt.NumFixed((totalSteps + 0.0) / (frame + 0.0), 3) +
                         " tracked_delta=" + Fmt.Int(GC.TrackedCount() - startTracked));
        }
        if mouseCaptured { input.ReleaseMouse(); }
        world.Destroy();
    }

    expose func run() { runLoop(0); }

    // Bounded real-play profiler used by main.zia's --profile-frames option.
    expose func runProfile(frames: Integer) {
        var boundedFrames = frames;
        if boundedFrames <= 0 { boundedFrames = 600; }
        runLoop(boundedFrames);
    }

    // Probe helper: run one full render frame (scene + fx + HUD + present),
    // exercising the render pipeline headless. Optionally enable post-FX first.
    expose func devEnablePostfx() {
        if graphicsUp { postfxSys.setup(canvas, postfx.TIER_BALANCED); }
    }
    expose func devRenderFrame() {
        if graphicsUp == false { return; }
        render(1.0, 0);
        world.Present();
    }

    // --- Bounded headless integration smoke (assumes boot(true,...)) ---------
    expose func runSmoke(frames: Integer) {
        var i = 0;
        while i < frames {
            tickSim(config.FIXED_DT);
            stepPhysics(config.FIXED_DT);
            i = i + 1;
        }
    }

    // --- Pure-logic tick (graphics-free; used by the P1a smoke_probe) --------
    expose func tickLogic(dt: Float) {
        applyPending();
        playTime = playTime + dt;
        tickCount = tickCount + 1;
        diag.checkBudgets();
        bus.drain();
    }
}

// --- Module-global singleton -------------------------------------------------
var g_game: Game = null;
func setGame(g: Game) { g_game = g; }
func getGame() -> Game { return g_game; }
