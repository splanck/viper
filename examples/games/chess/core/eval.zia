module eval;

bind "./config";
bind "./board";

// ============================================================================
// MODULE: eval
// PURPOSE: Static board evaluation. Combines material balance (centipawn
//          values) with piece-square tables (PSTs) that nudge pieces
//          toward strategically good squares.
//
// WHERE-THIS-FITS: Called by ChessAI from leaf nodes of the negamax
//          search and from the quiescence search's stand-pat. Pure
//          function — no internal state.
//
// KEY-DESIGN-CHOICES:
//   * SCORE FROM WHITE'S PERSPECTIVE. `evaluate` returns positive when
//     White has the edge. The AI flips sign for negamax when needed
//     (`staticEval` in ai.zia).
//   * PIECE-SQUARE TABLES. Each piece type has a 64-entry table giving
//     a positional bonus for being on that square. Values are taken
//     from standard chess engine literature (e.g., the canonical
//     "centipede" engine). The tables encode classic principles: pawns
//     advance toward promotion, knights avoid the rim, bishops want
//     diagonals, rooks want open files / 7th rank, kings hide behind
//     pawns in the middlegame and become active in the endgame.
//   * MIRRORED INDEXING. The PSTs are written from Black's perspective
//     (rank 0 at the top). For a white piece on square `sq`, we mirror
//     the rank: `pstIdx = (7 - rank) * 8 + file`. This lets a single
//     table serve both colours.
//   * SEPARATE KING MIDDLE / ENDGAME PSTS. `pstKingMid` rewards
//     hiding; `pstKingEnd` rewards centralising. The current
//     `pstBonus` only consults `pstKingMid` — switching dynamically
//     based on remaining material is left as a learning exercise.
// ============================================================================

/// @brief Material + PST evaluator. Score in centipawns, White-positive.
class Evaluator {
    // Piece-square tables (64 integers each, in display order: rank 0 = top)
    hide List[Integer] pstPawn;
    hide List[Integer] pstKnight;
    hide List[Integer] pstBishop;
    hide List[Integer] pstRook;
    hide List[Integer] pstQueen;
    hide List[Integer] pstKingMid;
    hide List[Integer] pstKingEnd;

    /// @brief Initialize the PST tables. One-time cost at construction.
    expose func init() {
        initPSTs();
    }

    // -------------------------------------------------------------------------
    // Main evaluation entry point.
    // Returns score in centipawns from White's perspective.
    // -------------------------------------------------------------------------
    /// @brief Score the position in centipawns from White's perspective.
    /// @details Walks every square; for each occupied square, adds the
    ///          piece's material value plus its PST bonus. White
    ///          contributes positively; black contributes negatively.
    expose func evaluate(b: Board) -> Integer {
        var score = 0;
        for sq in 0..64 {
            var piece = b.get(sq);
            if piece == 0 { continue; }

            var type_ = b.pieceType(piece);
            var white = b.isWhitePiece(piece);

            // Material value
            var mat = materialValue(type_);

            // PST index: white uses mirrored rank, black uses natural rank
            var pstIdx = sq;
            if white {
                var rank = sq / 8;
                var file = sq % 8;
                pstIdx = (7 - rank) * 8 + file;
            }

            var positional = pstBonus(type_, pstIdx);

            if white {
                score = score + mat + positional;
            } else {
                score = score - mat - positional;
            }
        }
        return score;
    }

    /// @brief Centipawn value of a piece type (PAWN..KING).
    expose func materialValue(type_: Integer) -> Integer {
        if type_ == PAWN   { return VAL_PAWN;   }
        if type_ == KNIGHT { return VAL_KNIGHT; }
        if type_ == BISHOP { return VAL_BISHOP; }
        if type_ == ROOK   { return VAL_ROOK;   }
        if type_ == QUEEN  { return VAL_QUEEN;  }
        if type_ == KING   { return VAL_KING;   }
        return 0;
    }

    /// @brief PST positional bonus for a piece type at a mirrored index.
    hide func pstBonus(type_: Integer, idx: Integer) -> Integer {
        if type_ == PAWN   { return pstPawn.get(idx);   }
        if type_ == KNIGHT { return pstKnight.get(idx); }
        if type_ == BISHOP { return pstBishop.get(idx); }
        if type_ == ROOK   { return pstRook.get(idx);   }
        if type_ == QUEEN  { return pstQueen.get(idx);  }
        if type_ == KING   { return pstKingMid.get(idx);}
        return 0;
    }

    // -------------------------------------------------------------------------
    // Piece-square table initialization.
    //
    // Values in centipawns added to (or subtracted from) material score.
    // Positive = square is good for that piece color.
    // -------------------------------------------------------------------------
    /// @brief Populate the seven 64-entry piece-square tables.
    /// @details Values are in centipawns. The `pstKingEnd` table is
    ///          allocated but not currently consulted — extending
    ///          `pstBonus` to switch on remaining material is a great
    ///          next step for anyone learning chess engines.
    hide func initPSTs() {
        // --- PAWN ---
        // Encourage center pawns to advance; penalize edge pawns.
        pstPawn = [
             0,  0,  0,  0,  0,  0,  0,  0,
            50, 50, 50, 50, 50, 50, 50, 50,
            10, 10, 20, 30, 30, 20, 10, 10,
             5,  5, 10, 25, 25, 10,  5,  5,
             0,  0,  0, 20, 20,  0,  0,  0,
             5, -5,-10,  0,  0,-10, -5,  5,
             5, 10, 10,-20,-20, 10, 10,  5,
             0,  0,  0,  0,  0,  0,  0,  0
        ];

        // --- KNIGHT ---
        // Penalize rim; reward center and forward posts.
        pstKnight = [
            -50,-40,-30,-30,-30,-30,-40,-50,
            -40,-20,  0,  0,  0,  0,-20,-40,
            -30,  0, 10, 15, 15, 10,  0,-30,
            -30,  5, 15, 20, 20, 15,  5,-30,
            -30,  0, 15, 20, 20, 15,  0,-30,
            -30,  5, 10, 15, 15, 10,  5,-30,
            -40,-20,  0,  5,  5,  0,-20,-40,
            -50,-40,-30,-30,-30,-30,-40,-50
        ];

        // --- BISHOP ---
        // Reward diagonals; penalize corners and edges.
        pstBishop = [
            -20,-10,-10,-10,-10,-10,-10,-20,
            -10,  0,  0,  0,  0,  0,  0,-10,
            -10,  0,  5, 10, 10,  5,  0,-10,
            -10,  5,  5, 10, 10,  5,  5,-10,
            -10,  0, 10, 10, 10, 10,  0,-10,
            -10, 10, 10, 10, 10, 10, 10,-10,
            -10,  5,  0,  0,  0,  0,  5,-10,
            -20,-10,-10,-10,-10,-10,-10,-20
        ];

        // --- ROOK ---
        // Reward 7th rank (enemy back rank), open files.
        pstRook = [
             0,  0,  0,  0,  0,  0,  0,  0,
             5, 10, 10, 10, 10, 10, 10,  5,
            -5,  0,  0,  0,  0,  0,  0, -5,
            -5,  0,  0,  0,  0,  0,  0, -5,
            -5,  0,  0,  0,  0,  0,  0, -5,
            -5,  0,  0,  0,  0,  0,  0, -5,
            -5,  0,  0,  0,  0,  0,  0, -5,
             0,  0,  0,  5,  5,  0,  0,  0
        ];

        // --- QUEEN ---
        // Slight penalty for early queen development.
        pstQueen = [
            -20,-10,-10, -5, -5,-10,-10,-20,
            -10,  0,  0,  0,  0,  0,  0,-10,
            -10,  0,  5,  5,  5,  5,  0,-10,
             -5,  0,  5,  5,  5,  5,  0, -5,
              0,  0,  5,  5,  5,  5,  0, -5,
            -10,  5,  5,  5,  5,  5,  0,-10,
            -10,  0,  5,  0,  0,  0,  0,-10,
            -20,-10,-10, -5, -5,-10,-10,-20
        ];

        // --- KING MIDDLEGAME ---
        // King seeks safety behind pawns; penalize center.
        pstKingMid = [
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -30,-40,-40,-50,-50,-40,-40,-30,
            -20,-30,-30,-40,-40,-30,-30,-20,
            -10,-20,-20,-20,-20,-20,-20,-10,
             20, 20,  0,  0,  0,  0, 20, 20,
             20, 30, 10,  0,  0, 10, 30, 20
        ];

        // --- KING ENDGAME ---
        // King should be active in the endgame.
        pstKingEnd = [
            -50,-40,-30,-20,-20,-30,-40,-50,
            -30,-20,-10,  0,  0,-10,-20,-30,
            -30,-10, 20, 30, 30, 20,-10,-30,
            -30,-10, 30, 40, 40, 30,-10,-30,
            -30,-10, 30, 40, 40, 30,-10,-30,
            -30,-10, 20, 30, 30, 20,-10,-30,
            -30,-30,  0,  0,  0,  0,-30,-30,
            -50,-30,-30,-30,-30,-30,-30,-50
        ];
    }
}
