module config;

// ============================================================================
// MODULE: config
// PURPOSE: Centralised constants for the chess demo: piece encoding, piece
//          values (centipawns), window/board layout, color palette, game
//          state and mode tags, AI search depth, transposition-table
//          flags, key codes, and gamepad button indices.
//
// WHERE-THIS-FITS: Leaf module imported by every other chess file. Pure
//          constants — no functions, no state.
//
// KEY-DESIGN-CHOICES:
//   * SIGNED PIECE ENCODING. White pieces are 1..6 (PAWN..KING); black
//     pieces are -1..-6. Empty is 0. `abs(piece)` gives type; `piece >
//     0` gives colour. This squashes (type, colour) into a single
//     integer board cell, which is the standard compact representation
//     for didactic chess engines.
//   * CENTIPAWN VALUES. The Evaluator uses VAL_PAWN=100 etc. so PST
//     adjustments and material balance share a unit. King value is
//     20000 (sentinel — used only to make material-only evaluations
//     refuse to "trade" the king).
//   * COLOR HEX LITERALS. Square / UI colors are 24-bit RGB ints. Using
//     `0xRRGGBB` keeps the source readable; the renderer packs them
//     into the runtime's pixel format.
//   * SEARCH DEPTH BY DIFFICULTY. DIFF_EASY=2, DIFF_MEDIUM=3, etc. Used
//     by the AI's iterative-deepening loop. Each depth bump roughly
//     8x's the search time at typical branching factor 35.
//   * STANDARD INITIAL CASTLE-RIGHTS INDEXING. CR_WK / CR_WQ / CR_BK /
//     CR_BQ are 0..3 indices into the Zobrist castle-key array.
// ============================================================================

// ============================================================================
// Piece IDs
// Positive = White, Negative = Black, 0 = Empty
// abs(piece) gives type; piece > 0 gives colour.
// ============================================================================
final EMPTY  = 0;
final PAWN   = 1;
final KNIGHT = 2;
final BISHOP = 3;
final ROOK   = 4;
final QUEEN  = 5;
final KING   = 6;

// ============================================================================
// Piece Values (centipawns)
// ============================================================================
final VAL_PAWN   = 100;
final VAL_KNIGHT = 320;
final VAL_BISHOP = 330;
final VAL_ROOK   = 500;
final VAL_QUEEN  = 900;
final VAL_KING   = 20000;

// ============================================================================
// Window & Board Layout
// ============================================================================
final WIN_W     = 1280;
final WIN_H     = 820;
final BOARD_X   = 0;     // legacy renderer constant; layout is derived in ui/layout.zia
final BOARD_Y   = 0;     // legacy renderer constant; layout is derived in ui/layout.zia
final SQ_SIZE   = 80;    // pixels per square
final PIECE_SZ  = 70;    // piece Pixels buffer size
final PANEL_X   = 0;     // legacy renderer constant; layout is derived in ui/layout.zia
final PANEL_W   = 0;     // legacy renderer constant; layout is derived in ui/layout.zia
final BAR_H     = 0;     // legacy renderer constant; layout is derived in ui/layout.zia

// ============================================================================
// Board Colors
// ============================================================================
final COL_LIGHT       = 0xF0D9B5;   // warm cream — light squares
final COL_DARK        = 0xB58863;   // warm brown — dark squares
final COL_HL_SEL      = 0xF6F669;   // yellow — selected square
final COL_HL_MOVE     = 0x646D40;   // olive — legal move dot
final COL_HL_CAP      = 0xCC4444;   // red — legal capture ring
final COL_HL_LAST     = 0xCDD52F;   // green-yellow — last move
final COL_HL_CHECK    = 0xFF3030;   // red — king in check

// ============================================================================
// UI Colors
// ============================================================================
final COL_UI_BG       = 0x1A1A2E;   // dark navy — background
final COL_UI_PANEL    = 0x16213E;   // slightly lighter panel blocks
final COL_UI_PANEL2   = 0x0F3460;   // deep blue — top bar, section headers
final COL_UI_TEXT     = 0xE0E0E0;   // light grey — primary text
final COL_UI_ACCENT   = 0xF5A623;   // orange — active player indicator
final COL_UI_DIM      = 0x888888;   // dimmed — secondary text
final COL_UI_WHITE    = 0xFFFFFF;
final COL_UI_SEP      = 0x2A2A4A;   // separator line color

// ============================================================================
// Game States
// ============================================================================
final STATE_MENU      = 0;
final STATE_PLAYING   = 1;
final STATE_PROMO     = 2;
final STATE_AI_THINK  = 3;
final STATE_CHECKMATE = 4;
final STATE_STALEMATE = 5;
final STATE_DRAW      = 6;

// ============================================================================
// Game Modes
// ============================================================================
final MODE_PVP = 0;   // Human vs Human
final MODE_PVC = 1;   // Human vs Computer
final MODE_CVC = 2;   // Computer vs Computer

// ============================================================================
// AI Difficulty (search depth)
// ============================================================================
final DIFF_EASY   = 2;
final DIFF_MEDIUM = 3;
final DIFF_HARD   = 4;
final DIFF_EXPERT = 5;

// ============================================================================
// Castle Rights Indices
// ============================================================================
final CR_WK = 0;   // White kingside
final CR_WQ = 1;   // White queenside
final CR_BK = 2;   // Black kingside
final CR_BQ = 3;   // Black queenside

// ============================================================================
// Transposition Table Flags
// ============================================================================
final TT_EXACT = 0;
final TT_ALPHA = 1;
final TT_BETA  = 2;

// ============================================================================
// Search Constants
// ============================================================================
final INF         = 1000000;
final MATE_SCORE  = 19000;
final MAX_HISTORY = 100;    // move history list display limit

// ============================================================================
// CvC auto-play delay (ms between moves)
// ============================================================================
final CVC_DELAY_MS = 600;

// ============================================================================
// Key Codes (GLFW / vgfx)
// ============================================================================
final KEY_N       = 78;
final KEY_ESCAPE  = 256;
final KEY_ENTER   = 257;
final KEY_UP      = 260;
final KEY_DOWN    = 261;

// ============================================================================
// Action Names
// ============================================================================
final ACT_NEW_GAME = "new_game";
final ACT_BACK     = "back";

// ============================================================================
// Gamepad
// ============================================================================
final PAD_IDX       = 0;
final PAD_BTN_A     = 0;
final PAD_BTN_B     = 1;
final PAD_BTN_START = 7;
