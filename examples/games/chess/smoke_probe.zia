//
// File: examples/games/chess/smoke_probe.zia
// Purpose: Headless correctness probe for Chess board and move generation.
// Key invariants:
//   - Standard-position move counts and perft values remain canonical.
//   - Make/unmake restores both board squares and the exact Zobrist hash.
//   - Capture-only generation excludes quiet moves without losing captures.
// Ownership/Lifetime:
//   - The probe owns one Board and MoveGen for the duration of main.
// Links: examples/games/chess/core/board.zia,
//        examples/games/chess/core/moves.zia
//
//===----------------------------------------------------------------------===//

module smoke_probe;

bind Zanna.Terminal as Terminal;
bind "./core/board";
bind "./core/moves";

// ============================================================================
// MODULE: smoke_probe
// PURPOSE: Headless smoke test for the chess core. Validates move
//          generation, perft counts, and make/unmake symmetry without
//          opening any window.
//
// WHERE-THIS-FITS: Run by the `zia_smoke_chess` ctest target in CI.
//          Catches regressions in board.zia / moves.zia.
//
// KEY-DESIGN-CHOICES:
//   * SUITE OF KNOWN-VALUE CHECKS. Starting position has exactly 20
//     legal moves; perft(2) is 400 and perft(3) is 8,902. These are
//     canonical results; deviations
//     immediately localize the bug.
//   * MAKE/UNMAKE PROOF. Apply e2e4, ensure replies exist, then
//     unmake and verify the board returned to its original state.
//     This catches bugs in UndoInfo capture and unmakeMove restoration.
//   * RESULT: ok / RESULT: fail X. The CI harness greps stdout for
//     these markers — exit code alone wouldn't tell us WHICH check
//     failed.
// ============================================================================

/// @brief Print "RESULT: fail <msg>" and bail. Used by every check.
func fail(msg: String) {
    Terminal.Say("RESULT: fail " + msg);
}

/// @brief Linear search for a (from, to) move in a move list.
func findMove(moves: List[Move], fromSq: Integer, toSq: Integer) -> Move? {
    for i in 0..moves.length() {
        var move = moves.get(i);
        if move.from == fromSq && move.to == toSq {
            return move;
        }
    }
    return null;
}

/// @brief Field-by-field equality check for a Move in a list.
func hasMove(moves: List[Move], target: Move) -> Boolean {
    for i in 0..moves.length() {
        var move = moves.get(i);
        if move.from == target.from &&
           move.to == target.to &&
           move.captured == target.captured &&
           move.enPassant == target.enPassant &&
           move.castleKing == target.castleKing &&
           move.castleQueen == target.castleQueen &&
           move.promotion == target.promotion &&
           move.promotePiece == target.promotePiece {
            return true;
        }
    }
    return false;
}

/// @brief Smoke-probe entry point. Runs all checks; prints RESULT: ok on success.
func main() {
    var board = new Board();
    var moveGen = new MoveGen();
    var startHash = board.getHash();

    var startMoves = moveGen.legalMoves(board);
    if startMoves.length() != 20 {
        fail("start position legal move count");
        return;
    }

    if moveGen.legalCaptures(board).length() != 0 {
        fail("start position capture list");
        return;
    }

    if moveGen.perft(board, 2) != 400 {
        fail("perft depth 2");
        return;
    }
    if moveGen.perft(board, 3) != 8902 {
        fail("perft depth 3");
        return;
    }
    if board.getHash() != startHash {
        fail("perft did not restore starting hash");
        return;
    }

    var e2e4 = findMove(startMoves, 52, 36);
    if e2e4 == null {
        fail("missing e2e4");
        return;
    }

    var undo = board.makeMove(e2e4!);
    var hashAfterE2E4 = board.getHash();
    var replyMoves = moveGen.legalMoves(board);
    if replyMoves.length() == 0 {
        board.unmakeMove(e2e4!, undo);
        fail("reply move list unexpectedly empty");
        return;
    }

    var d7d5 = findMove(replyMoves, 11, 27);
    if d7d5 == null {
        board.unmakeMove(e2e4!, undo);
        fail("missing d7d5");
        return;
    }
    var replyUndo = board.makeMove(d7d5!);
    var whiteCaptures = moveGen.legalCaptures(board);
    if findMove(whiteCaptures, 36, 27) == null {
        board.unmakeMove(d7d5!, replyUndo);
        board.unmakeMove(e2e4!, undo);
        fail("capture-only generator missing e4xd5");
        return;
    }
    board.unmakeMove(d7d5!, replyUndo);
    if board.getHash() != hashAfterE2E4 {
        board.unmakeMove(e2e4!, undo);
        fail("reply unmake did not restore hash");
        return;
    }

    var beforeUnmake = board.get(36);
    board.unmakeMove(e2e4!, undo);
    if beforeUnmake == 0 || board.get(52) == 0 || board.get(36) != 0 {
        fail("make/unmake validation failed");
        return;
    }
    if board.getHash() != startHash {
        fail("opening unmake did not restore starting hash");
        return;
    }

    Terminal.Say("RESULT: ok");
}
