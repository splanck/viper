//
// File: examples/games/chess/ui/widgets.zia
// Purpose: Reusable Canvas widget primitives for the Chess demo.
// Key invariants:
//   - Widget drawing is stateless and consumes layout.Rect values.
//   - Disabled widgets draw inert, muted states and ignore hover/press styling.
// Ownership/Lifetime:
//   - Pure helper module; callers own Canvas and Rect values.
// Links: examples/games/chess/ui/theme.zia, examples/games/chess/ui/renderer.zia
//
//===----------------------------------------------------------------------===//

module widgets;

bind Zanna.Graphics;
bind Color = Zanna.Graphics.Color;
bind "./theme";
bind "./layout";

// ============================================================================
// MODULE: widgets
// PURPOSE: Reusable visual primitives composed from theme colours and the
//          canvas drawing API: card frames, buttons (regular / segmented
//          / hover / active / primary / danger), badges, dividers,
//          insets, and section titles.
//
// WHERE-THIS-FITS: Bridge between theme + layout (input) and renderer
//          (consumer). The renderer composes scenes by calling these.
//
// KEY-DESIGN-CHOICES:
//   * NO STATE. Every widget is a pure rendering function — takes the
//     canvas, the rect, and any styling args. This makes them trivial
//     to compose and test.
//   * STATE FLAGS LAYER ON. drawButton takes hovered / pressed / active
//     / primary / danger as separate booleans. Each modifies the
//     base/border/text colours additively, with later flags overriding
//     earlier ones. The order of the modifiers in the function matches
//     visual priority (active > hover > press).
//   * SHADOWS VIA OFFSET ALPHA-BOXES. Cards and buttons get a soft
//     shadow by drawing a translucent black box offset down/right
//     before the main shape. Cheap and looks decent.
// ============================================================================

/// @brief Draw a panel card with shadow, rounded fill, double border,
///        and a thin accent strip across the top.
func drawCard(canvas: Canvas, r: Rect, accent: Integer, raised: Boolean) {
    var shadowAlpha = 72;
    if !raised { shadowAlpha = 48; }
    canvas.BoxAlpha(r.x + 6, r.y + 8, r.w, r.h, 0x000000, shadowAlpha);
    canvas.RoundBox(r.x, r.y, r.w, r.h, 12, theme.CARD_BG);
    canvas.BoxAlpha(r.x + 8, r.y + 3, r.w - 16, 16, theme.CARD_BG_ALT, 130);
    canvas.RoundFrame(r.x, r.y, r.w, r.h, 12, theme.CARD_BORDER);
    canvas.RoundFrame(r.x + 2, r.y + 2, r.w - 4, r.h - 4, 10, theme.CARD_BORDER_SOFT);
    canvas.Box(r.x + 12, r.y + 8, r.w - 24, 3, Color.Brighten(accent, 20));
}

/// @brief Small muted-text section header (e.g., "MOVE LOG").
func drawSectionTitle(canvas: Canvas, r: Rect, text: String) {
    theme.drawTextScaled(canvas, r.x, r.y, text, 1, theme.TEXT_MUTED);
}

/// @brief Generic button with state flags. See module header for the
///        layering rules.
func drawButton(canvas: Canvas,
                r: Rect,
                label: String,
                hovered: Boolean,
                pressed: Boolean,
                active: Boolean,
                primary: Boolean,
                danger: Boolean) {
    drawButtonEnabled(canvas, r, label, hovered, pressed, active, primary, danger, true);
}

/// @brief Generic button with an explicit enabled state.
/// @details Disabled buttons are still drawn at their normal geometry so the
///          layout remains stable, but hover, press, active, primary, and danger
///          styling are muted to make the control visibly inert.
/// @param canvas Canvas receiving the widget drawing commands.
/// @param r Rectangle that defines the button visual and hit-test region.
/// @param label Button label to center inside @p r.
/// @param hovered True when the mouse is over @p r.
/// @param pressed True when the mouse is actively pressing @p r.
/// @param active True for selected segmented buttons.
/// @param primary True for emphasized commands.
/// @param danger True for destructive commands.
/// @param enabled False to draw an inert disabled control.
func drawButtonEnabled(canvas: Canvas,
                       r: Rect,
                       label: String,
                       hovered: Boolean,
                       pressed: Boolean,
                       active: Boolean,
                       primary: Boolean,
                       danger: Boolean,
                       enabled: Boolean) {
    var base = theme.CARD_BG_ALT;
    var border = theme.CARD_BORDER;
    var textCol = theme.TEXT_SECONDARY;
    var isHovered = hovered;
    var isPressed = pressed;
    var isActive = active;
    var isPrimary = primary;
    var isDanger = danger;

    if !enabled {
        base = theme.darken(theme.CARD_BG_ALT, 18);
        border = theme.CARD_BORDER_SOFT;
        textCol = theme.TEXT_MUTED;
        isHovered = false;
        isPressed = false;
        isActive = false;
        isPrimary = false;
        isDanger = false;
    }

    if isPrimary {
        base = theme.ACCENT_GOLD_SOFT;
        border = theme.ACCENT_GOLD;
        textCol = theme.ACCENT_CREAM;
    }
    if isDanger {
        base = theme.ACCENT_RED;
        border = theme.brighten(theme.ACCENT_RED, 18);
        textCol = theme.ACCENT_CREAM;
    }
    if isActive {
        border = theme.ACCENT_GOLD;
        textCol = theme.TEXT_PRIMARY;
        if !isPrimary && !isDanger {
            base = theme.darken(theme.ACCENT_GOLD_SOFT, 8);
        }
    }
    if isHovered {
        base = theme.brighten(base, 18);
        border = theme.brighten(border, 20);
        textCol = theme.TEXT_PRIMARY;
    }
    if isPressed {
        base = theme.darken(base, 20);
    }

    canvas.BoxAlpha(r.x + 3, r.y + 4, r.w, r.h, 0x000000, 72);
    canvas.RoundBox(r.x, r.y, r.w, r.h, 10, base);
    canvas.BoxAlpha(r.x + 7, r.y + 2, r.w - 14, r.h / 2, theme.brighten(base, 22), 72);
    canvas.RoundFrame(r.x, r.y, r.w, r.h, 10, border);
    canvas.RoundFrame(r.x + 1, r.y + 1, r.w - 2, r.h - 2, 9, theme.CARD_BORDER_SOFT);
    theme.drawTextCenteredClipped(canvas, r.x + 8, theme.textYInRect(r.y, r.h, 1), r.w - 16, label, 1, textCol);
}

/// @brief Tab-style toggle button (no press visual). Used in menu mode/
///        side/difficulty pickers.
func drawSegmentButton(canvas: Canvas,
                       r: Rect,
                       label: String,
                       hovered: Boolean,
                       active: Boolean) {
    drawButton(canvas, r, label, hovered, false, active, false, false);
}

/// @brief Pill-shaped status badge (e.g., "WHITE", "ENGINE", "CHECK").
func drawBadge(canvas: Canvas, r: Rect, label: String, color: Integer) {
    canvas.RoundBox(r.x, r.y, r.w, r.h, 8, color);
    canvas.BoxAlpha(r.x + 6, r.y + 2, r.w - 12, r.h / 2, theme.brighten(color, 28), 70);
    canvas.RoundFrame(r.x, r.y, r.w, r.h, 8, theme.brighten(color, 24));
    theme.drawTextCenteredClipped(canvas, r.x + 6, theme.textYInRect(r.y, r.h, 1), r.w - 12, label, 1, theme.ACCENT_CREAM);
}

/// @brief Horizontal hairline in the soft border colour.
func drawDivider(canvas: Canvas, x: Integer, y: Integer, w: Integer) {
    canvas.Line(x, y, x + w, y, theme.CARD_BORDER_SOFT);
}

/// @brief Recessed inset rect — used to frame the move log.
func drawInset(canvas: Canvas, r: Rect) {
    canvas.RoundBox(r.x, r.y, r.w, r.h, 10, theme.PANEL_BG);
    canvas.BoxAlpha(r.x + 8, r.y + 3, r.w - 16, r.h / 3, theme.CARD_BG, 95);
    canvas.RoundFrame(r.x, r.y, r.w, r.h, 10, theme.CARD_BORDER_SOFT);
}
