//
// File: examples/games/chess/ui/renderer.zia
// Purpose: Stateless Canvas renderer for the Chess board, menus, and dialogs.
// Key invariants:
//   - All interactive controls are drawn from layout.zia rectangles.
//   - Board square colors are deterministic at every square center.
// Ownership/Lifetime:
//   - BoardRenderer stores only the Canvas handle; callers own game state.
// Links: examples/games/chess/ui/layout.zia, examples/games/chess/ui/game.zia
//
//===----------------------------------------------------------------------===//

module renderer;

bind Viper.Graphics;
bind Color = Viper.Graphics.Color;
bind Clock = Viper.Time.Clock;
bind Fmt = Viper.Text.Fmt;
bind "../core/config";
bind "../core/board";
bind "../settings";
bind "./pieces";
bind "./theme";
bind "./layout";
bind "./widgets";

// ============================================================================
// MODULE: renderer
// PURPOSE: All board / panel / dialog rendering. Owns no game state —
//          every method takes the data it needs as arguments.
//
// WHERE-THIS-FITS: Bridge between game logic (in `game.zia`) and the
//          underlying canvas/widgets/theme/pieces/layout modules.
//          ChessGame.render orchestrates calls into here in z-order
//          (background -> board -> highlights -> pieces -> bars ->
//          panel -> overlays).
//
// KEY-DESIGN-CHOICES:
//   * SQUARE COORDINATES BASED ON LAYOUT. squareX/squareY consult
//     `layout.boardRect()` rather than hard-coding offsets so the
//     entire board can be moved by editing one function.
//   * ALTERNATING SQUARE COLORS. We use BOARD_LIGHT_ALT /
//     BOARD_DARK_ALT (slightly tinted) instead of pure light/dark to
//     give the board a more textured look.
//   * HIGHLIGHTS ARE OVERLAYS. lastFrom/lastTo, hover, selected, legal
//     moves, capture circles, check king — all paint translucent
//     overlays on top of the squares. This keeps the base board paint
//     deterministic and the highlight logic localized.
//   * ANIMATION WITH LIFT. drawAnimatedPiece interpolates between
//     squares AND adds a small parabolic lift (rises 14px at midpoint)
//     so moves feel like the piece is being placed rather than
//     sliding flat.
//   * PANEL CARDS ARE COMPOSITIONAL. drawPanel calls drawPlayerCard /
//     drawMoveCard / drawInfoCard for each section. Each card is
//     framed by widgets.drawCard then filled with section-specific
//     content (status dot, name, time, captures).
//
// HOW-TO-READ: setCanvas / square coord helpers / squareAt -> backdrop
//   / menu-backdrop -> drawBoard -> highlights / check / pieces /
//   drag piece / animated piece -> top bar / footer / panel ->
//   sub-renderers (player card / captures / move log / info card /
//   promo dialog / main menu / game-over overlay / thinking
//   indicator) -> formatting helpers.
// ============================================================================

/// @brief Stateless renderer for the chess scene. setCanvas before use.
class BoardRenderer {
    hide Canvas canvas;

    /// @brief No-op constructor; canvas attaches via setCanvas later.
    expose func init() {
    }

    /// @brief Attach the drawing canvas and warm the theme assets.
    expose func setCanvas(cv: Canvas) {
        canvas = cv;
        theme.initAssets();
    }

    /// @brief File (column) of a square index.
    expose func squareFile(sq: Integer) -> Integer { return sq % 8; }
    /// @brief Rank (row) of a square index.
    expose func squareRank(sq: Integer) -> Integer { return sq / 8; }

    /// @brief Pixel X of square's top-left corner.
    expose func squareX(sq: Integer) -> Integer {
        var board = layout.boardRect();
        return board.x + (sq % 8) * SQ_SIZE;
    }

    /// @brief Pixel Y of square's top-left corner.
    expose func squareY(sq: Integer) -> Integer {
        var board = layout.boardRect();
        return board.y + (sq / 8) * SQ_SIZE;
    }

    /// @brief Pixel X of square's centre.
    expose func squareCenterX(sq: Integer) -> Integer {
        return squareX(sq) + SQ_SIZE / 2;
    }

    /// @brief Pixel Y of square's centre.
    expose func squareCenterY(sq: Integer) -> Integer {
        return squareY(sq) + SQ_SIZE / 2;
    }

    /// @brief Reverse-map mouse pixels to a square index, or -1 if outside.
    expose func squareAt(mx: Integer, my: Integer) -> Integer {
        var board = layout.boardRect();
        if mx < board.x || mx >= board.x + board.w { return -1; }
        if my < board.y || my >= board.y + board.h { return -1; }
        var f = (mx - board.x) / SQ_SIZE;
        var r = (my - board.y) / SQ_SIZE;
        return r * 8 + f;
    }

    /// @brief Vertical-gradient background with restrained top/bottom bands.
    expose func drawGameBackdrop() {
        canvas.GradientV(0, 0, WIN_W, WIN_H, theme.BG_TOP, theme.BG_BOTTOM);
        canvas.BoxAlpha(0, 0, WIN_W, 96, theme.BG_NOISE, 38);
        canvas.BoxAlpha(0, WIN_H - 110, WIN_W, 110, 0x000000, 28);
        canvas.Line(0, 92, WIN_W, 92, theme.CARD_BORDER_SOFT);
        canvas.Line(0, WIN_H - 110, WIN_W, WIN_H - 110, theme.CARD_BORDER_SOFT);
    }

    /// @brief Background for the main menu — gradient bands
    ///        + a small chess-board preview off to the left of the card.
    expose func drawMenuBackdrop() {
        canvas.GradientV(0, 0, WIN_W, WIN_H, theme.BG_TOP, theme.BG_BOTTOM);
        canvas.BoxAlpha(0, 0, WIN_W, 108, theme.BG_NOISE, 34);
        canvas.BoxAlpha(0, WIN_H - 128, WIN_W, 128, 0x000000, 24);

        drawMenuPreviewBoard(layout.heroBoardRect());
    }

    /// @brief Draw the decorative menu board preview inside @p preview.
    /// @details The preview uses the same named layout rectangle as hit-test
    ///          probes, avoiding the old hard-coded offset from menuCardRect.
    /// @param preview Outer rectangle reserved for the mini board.
    hide func drawMenuPreviewBoard(preview: Rect) {
        var px = preview.x;
        var py = preview.y;
        var size = preview.w / 8;
        for r in 0..8 {
            for f in 0..8 {
                var isLight = (r + f) % 2 == 0;
                var col = theme.BOARD_DARK_ALT;
                if isLight { col = theme.BOARD_LIGHT_ALT; }
                canvas.Box(px + f * size, py + r * size, size, size, col);
            }
        }
        canvas.BoxAlpha(px - 8, py - 8, preview.w + 16, preview.h + 16, 0x000000, 64);
        canvas.Frame(px - 6, py - 6, preview.w + 12, preview.h + 12, theme.BOARD_FRAME_IN);
        canvas.BlitAlpha(px + 28, py + 132, pieces.getShadow(KING, true));
        canvas.BlitAlpha(px + 24, py + 126, pieces.getPiece(KING, true));
        canvas.BlitAlpha(px + 132, py + 60, pieces.getShadow(QUEEN, false));
        canvas.BlitAlpha(px + 128, py + 54, pieces.getPiece(QUEEN, false));
        canvas.BlitAlpha(px + 156, py + 170, pieces.getShadow(BISHOP, false));
        canvas.BlitAlpha(px + 152, py + 164, pieces.getPiece(BISHOP, false));
    }

    /// @brief Draw the 8×8 board, file/rank labels, and last-move /
    ///        hover overlays. Frame and double border drawn first.
    expose func drawBoard(lastFrom: Integer, lastTo: Integer, hoverSq: Integer,
                          boardTheme: Integer, highContrast: Boolean,
                          showCoordinates: Boolean) {
        var frame = layout.boardFrameRect();
        var board = layout.boardRect();
        var fileLabels = ["a", "b", "c", "d", "e", "f", "g", "h"];
        var effectiveTheme = effectiveBoardTheme(boardTheme, highContrast);
        var dark = boardDark(effectiveTheme);

        canvas.BoxAlpha(frame.x + 10, frame.y + 14, frame.w, frame.h, 0x000000, 96);
        canvas.RoundBox(frame.x, frame.y, frame.w, frame.h, 14, boardFrameOut(effectiveTheme));
        canvas.BoxAlpha(frame.x + 3, frame.y + 3, frame.w - 6, 44, boardFrameIn(effectiveTheme), 82);
        canvas.RoundFrame(frame.x, frame.y, frame.w, frame.h, 14, theme.ACCENT_GOLD_SOFT);
        canvas.RoundFrame(frame.x + 2, frame.y + 2, frame.w - 4, frame.h - 4, 12, boardFrameIn(effectiveTheme));

        canvas.Box(board.x, board.y, board.w, board.h, dark);
        for r in 0..8 {
            for f in 0..8 {
                var sq = r * 8 + f;
                var bx = board.x + f * SQ_SIZE;
                var by = board.y + r * SQ_SIZE;
                var isLight = (r + f) % 2 == 0;
                var sqCol = boardSquareColor(effectiveTheme, isLight);

                canvas.Box(bx, by, SQ_SIZE, SQ_SIZE, sqCol);
                canvas.BoxAlpha(bx, by, SQ_SIZE, SQ_SIZE / 2, theme.ACCENT_CREAM, 14);

                if sq == lastFrom || sq == lastTo {
                    canvas.BoxAlpha(bx, by, SQ_SIZE, SQ_SIZE, theme.HILITE_LAST, 84);
                }
                if sq == hoverSq {
                    canvas.BoxAlpha(bx, by, SQ_SIZE, SQ_SIZE, theme.ACCENT_CREAM, 26);
                    canvas.RoundFrame(bx + 6, by + 6, SQ_SIZE - 12, SQ_SIZE - 12, 10, theme.ACCENT_GOLD_SOFT);
                }

                if showCoordinates && f == 0 {
                    var rankLabel = Fmt.Int(8 - r);
                    var labelCol = theme.BOARD_LABEL;
                    if isLight { labelCol = theme.BOARD_LABEL_DIM; }
                    theme.drawTextScaled(canvas, bx + 6, by + 5, rankLabel, 1, labelCol);
                }

                if showCoordinates && r == 7 {
                    var labelCol = theme.BOARD_LABEL;
                    if isLight { labelCol = theme.BOARD_LABEL_DIM; }
                    var label = fileLabels.get(f);
                    theme.drawTextScaled(canvas,
                                         bx + SQ_SIZE - theme.textWidth(label, 1) - 6,
                                         by + SQ_SIZE - theme.lineHeight(1) - 5,
                                         label,
                                         1,
                                         labelCol);
                }
            }
        }

        canvas.Frame(board.x, board.y, board.w, board.h, boardFrameOut(effectiveTheme));
        canvas.Frame(board.x - 1, board.y - 1, board.w + 2, board.h + 2, boardFrameIn(effectiveTheme));
    }

    /// @brief Highlight the selected square and overlay legal-move
    ///        markers (dot for quiet move, ring for capture).
    expose func drawHighlights(selectedSq: Integer, legalMoves: List[Move]) {
        if selectedSq < 0 { return; }

        var sx = squareX(selectedSq);
        var sy = squareY(selectedSq);
        canvas.BoxAlpha(sx, sy, SQ_SIZE, SQ_SIZE, theme.HILITE_SELECTED, 120);
        canvas.RoundFrame(sx + 4, sy + 4, SQ_SIZE - 8, SQ_SIZE - 8, 10, theme.brighten(theme.HILITE_SELECTED, 24));

        for i in 0..legalMoves.length() {
            var m = legalMoves.get(i);
            if m.from != selectedSq { continue; }
            var tx = squareCenterX(m.to);
            var ty = squareCenterY(m.to);
            if m.captured != 0 || m.enPassant {
                canvas.Ring(tx, ty, SQ_SIZE / 2 - 8, theme.HILITE_CAPTURE);
                canvas.Ring(tx, ty, SQ_SIZE / 2 - 10, theme.brighten(theme.HILITE_CAPTURE, 16));
            } else {
                canvas.DiscAlpha(tx, ty, 12, theme.HILITE_MOVE, 210);
                canvas.DiscAlpha(tx, ty, 6, theme.ACCENT_CREAM, 180);
            }
        }
    }

    /// @brief Tint the king's square red when it's in check.
    expose func drawCheckHighlight(kingSq: Integer) {
        if kingSq < 0 { return; }
        canvas.BoxAlpha(squareX(kingSq), squareY(kingSq), SQ_SIZE, SQ_SIZE, theme.HILITE_CHECK, 120);
        canvas.RoundFrame(squareX(kingSq) + 4, squareY(kingSq) + 4, SQ_SIZE - 8, SQ_SIZE - 8, 10, theme.brighten(theme.HILITE_CHECK, 16));
    }

    /// @brief Render every static piece (skipping the drag-source and
    ///        the animation-destination squares).
    expose func drawPieces(b: Board, dragFrom: Integer, skipSq: Integer) {
        for sq in 0..64 {
            if sq == dragFrom { continue; }
            if sq == skipSq { continue; }
            var piece = b.get(sq);
            if piece == 0 { continue; }
            blitPieceWithShadow(b.pieceType(piece), b.isWhitePiece(piece),
                                squareCenterX(sq), squareCenterY(sq));
        }
    }

    /// @brief Render the piece currently being dragged, centered at (x,y).
    expose func drawDragPiece(pieceType: Integer, white: Boolean, x: Integer, y: Integer) {
        if pieceType == 0 { return; }
        var shadow = pieces.getShadow(pieceType, white);
        if shadow != null {
            canvas.BlitAlpha(x - PIECE_SZ / 2 + 7, y - PIECE_SZ / 2 + 10, shadow);
        }
        blitPiece(pieceType, white, x, y - 4);
    }

    /// @brief Render an in-flight piece animation between two squares.
    /// @param progressPermille Animation progress in 0..1000 (per-mille).
    /// @details Linear interpolation in (x, y) plus a triangular lift
    ///          (peaks 14px above the path at midpoint) so the piece
    ///          appears to be lifted, carried, and set down.
    expose func drawAnimatedPiece(pieceType: Integer,
                                  white: Boolean,
                                  fromSq: Integer,
                                  toSq: Integer,
                                  progressPermille: Integer) {
        if pieceType == 0 { return; }
        var fromX = squareCenterX(fromSq);
        var fromY = squareCenterY(fromSq);
        var toX = squareCenterX(toSq);
        var toY = squareCenterY(toSq);

        var cx = fromX + (toX - fromX) * progressPermille / 1000;
        var cy = fromY + (toY - fromY) * progressPermille / 1000;

        var lift = 0;
        if progressPermille < 500 {
            lift = progressPermille * 14 / 500;
        } else {
            lift = (1000 - progressPermille) * 14 / 500;
        }

        var shadow = pieces.getShadow(pieceType, white);
        if shadow != null {
            canvas.BlitAlpha(cx - PIECE_SZ / 2 + 8, cy - PIECE_SZ / 2 + 10, shadow);
        }
        blitPiece(pieceType, white, cx, cy - lift);
    }

    hide func blitPiece(type_: Integer, white: Boolean, cx: Integer, cy: Integer) {
        var sprite = pieces.getPiece(type_, white);
        if sprite == null { return; }
        canvas.BlitAlpha(cx - PIECE_SZ / 2, cy - PIECE_SZ / 2, sprite);
    }

    hide func blitPieceWithShadow(type_: Integer, white: Boolean, cx: Integer, cy: Integer) {
        var shadow = pieces.getShadow(type_, white);
        if shadow != null {
            canvas.BlitAlpha(cx - PIECE_SZ / 2 + 5, cy - PIECE_SZ / 2 + 8, shadow);
        }
        blitPiece(type_, white, cx, cy);
    }

    /// @brief Top toolbar: title, turn badge, mode badge, NEW + MENU buttons.
    expose func drawTopBar(turnText: String, gameMode: Integer, mx: Integer, my: Integer, mouseDown: Boolean) {
        var top = layout.topBar();
        var newBtn = layout.newButtonRect();
        var menuBtn = layout.menuButtonRect();
        var turnBadge = layout.rect((WIN_W - 260) / 2, 14, 260, 36);
        var modeBadge = layout.rect(OUTER_MODE_X(), 14, 120, 36);

        canvas.GradientV(top.x, top.y, top.w, top.h, theme.CARD_BG_ALT, theme.PANEL_BG);
        canvas.Line(0, top.h - 1, WIN_W, top.h - 1, theme.CARD_BORDER_SOFT);

        theme.drawTextScaled(canvas, 30, 18, "VIPER CHESS", 2, theme.ACCENT_GOLD);

        widgets.drawBadge(canvas, turnBadge, turnText, theme.ACCENT_BLUE);
        widgets.drawBadge(canvas, modeBadge, modeString(gameMode), theme.ACCENT_GOLD_SOFT);

        widgets.drawButton(canvas, newBtn, "NEW", layout.contains(newBtn, mx, my), mouseDown and layout.contains(newBtn, mx, my), false, false, false);
        widgets.drawButton(canvas, menuBtn, "MENU", layout.contains(menuBtn, mx, my), mouseDown and layout.contains(menuBtn, mx, my), false, false, false);
    }

    /// @brief Bottom footer: DRAW + RESIGN buttons, status text, key hints.
    expose func drawFooter(statusText: String, mx: Integer, my: Integer, mouseDown: Boolean) {
        var foot = layout.footerBar();
        var drawBtn = layout.drawButtonRect();
        var resignBtn = layout.resignButtonRect();

        canvas.GradientV(foot.x, foot.y, foot.w, foot.h, theme.PANEL_BG, theme.CARD_BG);
        canvas.Line(0, foot.y, WIN_W, foot.y, theme.CARD_BORDER_SOFT);

        widgets.drawButton(canvas, drawBtn, "DRAW", layout.contains(drawBtn, mx, my), mouseDown and layout.contains(drawBtn, mx, my), false, false, false);
        widgets.drawButton(canvas, resignBtn, "RESIGN", layout.contains(resignBtn, mx, my), mouseDown and layout.contains(resignBtn, mx, my), false, false, true);

        var statusX = resignBtn.x + resignBtn.w + 22;
        var hintText = "Ctrl+Z undo";
        var hintW = theme.textWidth(hintText, 1);
        theme.drawTextClipped(canvas, statusX, foot.y + 18, WIN_W - statusX - hintW - 54, statusText, 1, theme.TEXT_SECONDARY);
        theme.drawTextRightClipped(canvas, WIN_W - hintW - 28, foot.y + 18, hintW, hintText, 1, theme.TEXT_MUTED);
    }

    /// @brief Right-side info panel: black card / move log / white card / info card.
    expose func drawPanel(b: Board,
                          whiteTimeSec: Integer, blackTimeSec: Integer,
                          sanHistory: List[String],
                          whiteCaps: List[Integer], blackCaps: List[Integer],
                          gameMode: Integer, aiDepth: Integer, playerIsWhite: Boolean,
                          aiThinking: Boolean, checkedKingSq: Integer) {
        var panel = layout.sidePanelRect();
        var blackCard = layout.blackCardRect();
        var moveCard = layout.moveCardRect();
        var whiteCard = layout.whiteCardRect();
        var infoCard = layout.infoCardRect();
        var whiteGain = captureMaterialValue(whiteCaps);
        var blackGain = captureMaterialValue(blackCaps);

        canvas.BoxAlpha(panel.x + 8, panel.y + 10, panel.w, panel.h, 0x000000, 90);

        widgets.drawCard(canvas, blackCard, theme.ACCENT_BLUE, true);
        drawPlayerCard(blackCard, "BLACK", blackTimeSec, blackCaps, false,
                       !b.whiteToMove, cardHasHuman(false, gameMode, playerIsWhite),
                       aiThinking and !b.whiteToMove,
                       checkedKingSq >= 0 and !b.whiteToMove,
                       blackGain - whiteGain);

        widgets.drawCard(canvas, moveCard, theme.ACCENT_GOLD_SOFT, false);
        drawMoveCard(moveCard, sanHistory);

        widgets.drawCard(canvas, whiteCard, theme.ACCENT_GREEN, true);
        drawPlayerCard(whiteCard, "WHITE", whiteTimeSec, whiteCaps, true,
                       b.whiteToMove, cardHasHuman(true, gameMode, playerIsWhite),
                       aiThinking and b.whiteToMove,
                       checkedKingSq >= 0 and b.whiteToMove,
                       whiteGain - blackGain);

        widgets.drawCard(canvas, infoCard, theme.ACCENT_GOLD_SOFT, false);
        drawInfoCard(infoCard, gameMode, aiDepth, playerIsWhite);
    }

    hide func drawPlayerCard(card: Rect,
                             sideName: String,
                             timeSec: Integer,
                             captures: List[Integer],
                             whiteCard: Boolean,
                             active: Boolean,
                             humanSide: Boolean,
                             thinking: Boolean,
                             checked: Boolean,
                             materialLead: Integer) {
        var statusCol = theme.ACCENT_GOLD_SOFT;
        if active { statusCol = theme.ACCENT_GOLD; }
        if checked { statusCol = theme.ACCENT_RED; }
        if thinking { statusCol = theme.ACCENT_BLUE; }

        var tick = Clock.NowMs();
        var dotCol = statusCol;
        if active {
            dotCol = theme.pulseColor(statusCol, 18, tick, 1200);
        }

        canvas.Disc(card.x + 26, card.y + 28, 8, dotCol);
        theme.drawTextClipped(canvas, card.x + 44, card.y + 18, card.w / 2, sideName, 2, theme.TEXT_PRIMARY);
        theme.drawTextRightClipped(canvas, card.x + card.w - 154, card.y + 18, 136, formatClock(timeSec), 2, theme.ACCENT_CREAM);

        var badge = "";
        if humanSide { badge = "HUMAN"; } else { badge = "ENGINE"; }
        if thinking { badge = "THINKING"; }
        if checked { badge = "CHECK"; }

        var badgeRect = layout.rect(card.x + 18, card.y + 54, 116, 26);
        widgets.drawBadge(canvas, badgeRect, badge, statusCol);

        if materialLead > 0 {
            theme.drawTextRightClipped(canvas, card.x + card.w - 96, card.y + 60, 78, "+" + Fmt.Int(materialLead / 100), 2, theme.ACCENT_GOLD);
        }

        widgets.drawDivider(canvas, card.x + 18, card.y + 88, card.w - 36);
        theme.drawTextScaled(canvas, card.x + 18, card.y + 102, "CAPTURED", 1, theme.TEXT_MUTED);
        drawCapturedPieces(card.x + 118, card.y + 95, captures, !whiteCard, card.w - 136);
    }

    hide func drawCapturedPieces(x: Integer, y: Integer, captures: List[Integer], capturedAreWhite: Boolean, maxW: Integer) {
        var iconStep = 22;
        var maxIcons = maxW / iconStep;
        if maxIcons <= 0 { return; }

        canvas.SetClipRect(x, y, maxW, iconStep);
        for i in 0..captures.length() {
            if i >= maxIcons {
                canvas.ClearClipRect();
                theme.drawTextScaled(canvas, x + maxW - 24, y + 7, "+" + Fmt.Int(captures.length() - i), 1, theme.TEXT_MUTED);
                return;
            }
            var sprite = pieces.getMiniPiece(captures.get(i), capturedAreWhite);
            if sprite == null { continue; }
            var px = x + i * iconStep;
            var py = y;
            canvas.BlitAlpha(px, py, sprite);
        }
        canvas.ClearClipRect();
    }

    hide func drawMoveCard(card: Rect, history: List[String]) {
        var list = layout.moveListRect();
        widgets.drawSectionTitle(canvas, layout.rect(card.x + 18, card.y + 18, 0, 0), "MOVE LOG");
        widgets.drawInset(canvas, list);

        canvas.SetClipRect(list.x + 8, list.y + 8, list.w - 16, list.h - 16);
        theme.drawTextScaled(canvas, list.x + 10, list.y + 10, "No.", 1, theme.TEXT_MUTED);
        theme.drawTextScaled(canvas, list.x + 58, list.y + 10, "White", 1, theme.TEXT_MUTED);
        theme.drawTextScaled(canvas, list.x + 186, list.y + 10, "Black", 1, theme.TEXT_MUTED);

        var total = history.length();
        var rowH = 18;
        var visibleRows = (list.h - 42) / rowH;
        if visibleRows < 1 { visibleRows = 1; }
        var start = total - visibleRows * 2;
        if start < 0 { start = 0; }
        if start % 2 != 0 { start = start - 1; }

        var row = 0;
        var i = start;
        while i < total && row < visibleRows {
            var rowY = list.y + 34 + row * rowH;
            var moveNum = i / 2 + 1;
            var whiteMove = history.get(i);
            var blackMove = "";
            if i + 1 < total { blackMove = history.get(i + 1); }

            if i + 2 >= total {
                canvas.BoxAlpha(list.x + 6, rowY - 2, list.w - 12, rowH, theme.ACCENT_GOLD_SOFT, 48);
            }

            theme.drawTextClipped(canvas, list.x + 10, rowY, 42, Fmt.Int(moveNum) + ".", 1, theme.TEXT_MUTED);
            theme.drawTextClipped(canvas, list.x + 58, rowY, 118, whiteMove, 1, theme.TEXT_PRIMARY);
            theme.drawTextClipped(canvas, list.x + 186, rowY, list.w - 204, blackMove, 1, theme.TEXT_PRIMARY);

            i = i + 2;
            row = row + 1;
        }
        canvas.ClearClipRect();
    }

    hide func drawInfoCard(card: Rect, gameMode: Integer, aiDepth: Integer, playerIsWhite: Boolean) {
        widgets.drawSectionTitle(canvas, layout.rect(card.x + 18, card.y + 18, 0, 0), "MATCH");
        theme.drawTextScaled(canvas, card.x + 18, card.y + 42, "MODE", 1, theme.TEXT_MUTED);
        theme.drawTextClipped(canvas, card.x + 110, card.y + 42, card.w - 128, modeVerbose(gameMode), 1, theme.TEXT_PRIMARY);

        theme.drawTextScaled(canvas, card.x + 18, card.y + 62, "LEVEL", 1, theme.TEXT_MUTED);
        theme.drawTextClipped(canvas, card.x + 110, card.y + 62, card.w - 128, difficultyString(aiDepth), 1, theme.TEXT_PRIMARY);

        if gameMode == MODE_PVC {
            theme.drawTextScaled(canvas, card.x + 18, card.y + 82, "YOU", 1, theme.TEXT_MUTED);
            if playerIsWhite {
                theme.drawTextClipped(canvas, card.x + 110, card.y + 82, card.w - 128, "WHITE", 1, theme.TEXT_PRIMARY);
            } else {
                theme.drawTextClipped(canvas, card.x + 110, card.y + 82, card.w - 128, "BLACK", 1, theme.TEXT_PRIMARY);
            }
        }

        widgets.drawDivider(canvas, card.x + 18, card.y + card.h - 20, card.w - 36);
        theme.drawTextClipped(canvas, card.x + 18, card.y + card.h - 10, card.w - 36, "Click or drag pieces.", 1, theme.TEXT_MUTED);
    }

    /// @brief Modal pawn-promotion dialog with four piece choices.
    expose func drawPromoDialog(white: Boolean, mx: Integer, my: Integer, mouseDown: Boolean) {
        canvas.BoxAlpha(0, 0, WIN_W, WIN_H, theme.SCRIM, 165);
        var dialog = layout.promoDialogRect();
        widgets.drawCard(canvas, dialog, theme.ACCENT_GOLD, true);
        theme.drawTextCenteredClipped(canvas, dialog.x + 18, dialog.y + 18, dialog.w - 36, "PROMOTE PAWN", 2, theme.ACCENT_GOLD);
        theme.drawTextCenteredClipped(canvas, dialog.x + 18, dialog.y + 52, dialog.w - 36, "Choose a piece", 1, theme.TEXT_SECONDARY);

        var promoTypes = [QUEEN, ROOK, BISHOP, KNIGHT];
        for i in 0..4 {
            var tile = layout.promoOptionRect(i);
            widgets.drawButton(canvas, tile, "", layout.contains(tile, mx, my), mouseDown and layout.contains(tile, mx, my), false, false, false);
            var sprite = pieces.getPiece(promoTypes.get(i), white);
            if sprite != null {
                canvas.BlitAlpha(tile.x + (tile.w - PIECE_SZ) / 2, tile.y + 8, sprite);
            }
            theme.drawTextCenteredClipped(canvas, tile.x + 4, tile.y + 66, tile.w - 8, promoName(promoTypes.get(i)), 1, theme.TEXT_SECONDARY);
        }
    }

    /// @brief Main-menu screen: title card, mode/side/difficulty pickers,
    ///        START GAME button.
    expose func drawMainMenu(gameMode: Integer,
                             aiDepth: Integer,
                             playerIsWhite: Boolean,
                             slot0Present: Boolean,
                             slot1Present: Boolean,
                             slot2Present: Boolean,
                             canSaveCurrent: Boolean,
                             timeControl: Integer,
                             boardTheme: Integer,
                             highContrast: Boolean,
                             mx: Integer,
                             my: Integer,
                             mouseDown: Boolean) {
        drawMenuBackdrop();

        var card = layout.menuCardRect();
        widgets.drawCard(canvas, card, theme.ACCENT_GOLD, true);

        theme.drawTextScaled(canvas, card.x + 42, card.y + 30, "VIPER", 2, theme.TEXT_MUTED);
        theme.drawTextScaled(canvas, card.x + 42, card.y + 56, "CHESS", 4, theme.ACCENT_GOLD);
        theme.drawTextClipped(canvas, card.x + 42, card.y + 104, card.w - 84,
                              "Native Zia chess with saved games, puzzles, clocks, and engine play.",
                              1,
                              theme.TEXT_SECONDARY);

        theme.drawTextScaled(canvas, card.x + 42, card.y + 150, "GAME MODE", 1, theme.TEXT_MUTED);
        widgets.drawSegmentButton(canvas, layout.modeButtonRect(0), "PVP",
                                  layout.contains(layout.modeButtonRect(0), mx, my),
                                  gameMode == MODE_PVP);
        widgets.drawSegmentButton(canvas, layout.modeButtonRect(1), "PVC",
                                  layout.contains(layout.modeButtonRect(1), mx, my),
                                  gameMode == MODE_PVC);
        widgets.drawSegmentButton(canvas, layout.modeButtonRect(2), "CVC",
                                  layout.contains(layout.modeButtonRect(2), mx, my),
                                  gameMode == MODE_CVC);

        theme.drawTextScaled(canvas, card.x + 42, card.y + 228, "PLAY AS", 1, theme.TEXT_MUTED);
        widgets.drawSegmentButton(canvas, layout.sideButtonRect(0), "WHITE",
                                  layout.contains(layout.sideButtonRect(0), mx, my),
                                  playerIsWhite);
        widgets.drawSegmentButton(canvas, layout.sideButtonRect(1), "BLACK",
                                  layout.contains(layout.sideButtonRect(1), mx, my),
                                  !playerIsWhite);

        theme.drawTextScaled(canvas, card.x + 42, card.y + 306, "ENGINE LEVEL", 1, theme.TEXT_MUTED);
        widgets.drawSegmentButton(canvas, layout.difficultyButtonRect(0), "BEGINNER",
                                  layout.contains(layout.difficultyButtonRect(0), mx, my),
                                  aiDepth == DIFF_EASY);
        widgets.drawSegmentButton(canvas, layout.difficultyButtonRect(1), "CLUB",
                                  layout.contains(layout.difficultyButtonRect(1), mx, my),
                                  aiDepth == DIFF_MEDIUM);
        widgets.drawSegmentButton(canvas, layout.difficultyButtonRect(2), "TOURNEY",
                                  layout.contains(layout.difficultyButtonRect(2), mx, my),
                                  aiDepth == DIFF_HARD);
        widgets.drawSegmentButton(canvas, layout.difficultyButtonRect(3), "MASTER",
                                  layout.contains(layout.difficultyButtonRect(3), mx, my),
                                  aiDepth == DIFF_EXPERT);

        widgets.drawButton(canvas, layout.startButtonRect(), "START GAME",
                           layout.contains(layout.startButtonRect(), mx, my),
                           mouseDown and layout.contains(layout.startButtonRect(), mx, my),
                           false,
                           true,
                           false);
        theme.drawTextClipped(canvas, card.x + 42, card.y + 488, 480,
                              "Clock: " + settings.timeControlName(timeControl) +
                              "   Board: " + displayBoardThemeName(boardTheme, highContrast),
                              1,
                              theme.TEXT_MUTED);

        theme.drawTextScaled(canvas, card.x + 560, card.y + 118, "RELEASE MENU", 1, theme.TEXT_MUTED);
        widgets.drawButtonEnabled(canvas, layout.continueButtonRect(), "CONTINUE",
                                  layout.contains(layout.continueButtonRect(), mx, my),
                                  mouseDown and layout.contains(layout.continueButtonRect(), mx, my),
                                  false,
                                  false,
                                  false,
                                  slot0Present);

        drawMenuSlotRow(0, slot0Present, canSaveCurrent, mx, my, mouseDown);
        drawMenuSlotRow(1, slot1Present, canSaveCurrent, mx, my, mouseDown);
        drawMenuSlotRow(2, slot2Present, canSaveCurrent, mx, my, mouseDown);

        widgets.drawButton(canvas, layout.puzzleButtonRect(), "PUZZLES",
                           layout.contains(layout.puzzleButtonRect(), mx, my),
                           mouseDown and layout.contains(layout.puzzleButtonRect(), mx, my),
                           false,
                           false,
                           false);
        widgets.drawButton(canvas, layout.analysisButtonRect(), "ANALYSIS",
                           layout.contains(layout.analysisButtonRect(), mx, my),
                           mouseDown and layout.contains(layout.analysisButtonRect(), mx, my),
                           false,
                           false,
                           false);
        widgets.drawButton(canvas, layout.settingsButtonRect(), "SETTINGS",
                           layout.contains(layout.settingsButtonRect(), mx, my),
                           mouseDown and layout.contains(layout.settingsButtonRect(), mx, my),
                           false,
                           false,
                           false);
        theme.drawTextClipped(canvas, card.x + 560, card.y + 548, 238,
                              "Esc opens menu in-game. Ctrl+S quick-saves slot 1.",
                              1,
                              theme.TEXT_MUTED);
        theme.drawTextCenteredClipped(canvas, card.x + 42, card.y + 604, card.w - 84, "Press Enter to start a configured match.", 1, theme.TEXT_MUTED);
    }

    /// @brief Draw one save-slot row in the main release menu.
    /// @details Each row exposes independent Load and Save buttons. Load is
    ///          disabled until the slot has persisted data; Save is disabled
    ///          until the controller reports that a live or recently-active
    ///          game exists.
    /// @param idx Zero-based save slot index.
    /// @param slotPresent True when SaveData has this slot.
    /// @param canSaveCurrent True when saving the current board is meaningful.
    /// @param mx Current mouse x coordinate.
    /// @param my Current mouse y coordinate.
    /// @param mouseDown True while the left mouse button is down.
    hide func drawMenuSlotRow(idx: Integer,
                              slotPresent: Boolean,
                              canSaveCurrent: Boolean,
                              mx: Integer,
                              my: Integer,
                              mouseDown: Boolean) {
        var label = layout.slotLabelRect(idx);
        var loadBtn = layout.slotLoadButtonRect(idx);
        var saveBtn = layout.slotSaveButtonRect(idx);
        theme.drawTextClipped(canvas, label.x, theme.textYInRect(label.y, label.h, 1),
                              label.w, "S" + Fmt.Int(idx + 1), 1, theme.TEXT_MUTED);
        widgets.drawButtonEnabled(canvas, loadBtn, "LOAD",
                                  layout.contains(loadBtn, mx, my),
                                  mouseDown and layout.contains(loadBtn, mx, my),
                                  false,
                                  false,
                                  false,
                                  slotPresent);
        widgets.drawButtonEnabled(canvas, saveBtn, "SAVE",
                                  layout.contains(saveBtn, mx, my),
                                  mouseDown and layout.contains(saveBtn, mx, my),
                                  false,
                                  false,
                                  false,
                                  canSaveCurrent);
    }

    /// @brief Settings screen with direct toggle/cycle rows.
    expose func drawSettingsMenu(boardTheme: Integer,
                                 pieceTheme: Integer,
                                 timeControl: Integer,
                                 showLegalMoves: Boolean,
                                 showCoordinates: Boolean,
                                 showAttackMap: Boolean,
                                 highContrast: Boolean,
                                 reducedMotion: Boolean,
                                 largeText: Boolean,
                                 masterVolume: Integer,
                                 musicVolume: Integer,
                                 sfxVolume: Integer,
                                 muted: Boolean,
                                 mx: Integer,
                                 my: Integer,
                                 mouseDown: Boolean) {
        drawMenuBackdrop();
        var card = layout.settingsCardRect();
        widgets.drawCard(canvas, card, theme.ACCENT_GOLD, true);

        theme.drawTextScaled(canvas, card.x + 42, card.y + 36, "SETTINGS", 3, theme.ACCENT_GOLD);
        theme.drawTextClipped(canvas, card.x + 42, card.y + 82, card.w - 84,
                              "Click rows to cycle or toggle. Volume rows step by 10.",
                              1,
                              theme.TEXT_SECONDARY);

        drawSettingRow(0, "Board Theme", settings.boardThemeName(boardTheme), mx, my, mouseDown);
        drawSettingRow(1, "Piece Theme", settings.pieceThemeName(pieceTheme), mx, my, mouseDown);
        drawSettingRow(2, "Clock", settings.timeControlName(timeControl), mx, my, mouseDown);
        drawSettingRow(3, "Legal Moves", boolLabel(showLegalMoves), mx, my, mouseDown);
        drawSettingRow(4, "Coordinates", boolLabel(showCoordinates), mx, my, mouseDown);
        drawSettingRow(5, "Attack Map", boolLabel(showAttackMap), mx, my, mouseDown);
        drawSettingRow(6, "High Contrast", boolLabel(highContrast), mx, my, mouseDown);
        drawSettingRow(7, "Reduced Motion", boolLabel(reducedMotion), mx, my, mouseDown);
        drawSettingRow(8, "Large Text", boolLabel(largeText), mx, my, mouseDown);
        drawSettingRow(9, "Master Volume", Fmt.Int(masterVolume) + "%", mx, my, mouseDown);
        drawSettingRow(10, "Music Volume", Fmt.Int(musicVolume) + "%", mx, my, mouseDown);
        drawSettingRow(11, "SFX Volume", Fmt.Int(sfxVolume) + "%", mx, my, mouseDown);
        drawSettingRow(12, "Muted", boolLabel(muted), mx, my, mouseDown);

        widgets.drawButton(canvas, layout.settingsBackRect(), "BACK",
                           layout.contains(layout.settingsBackRect(), mx, my),
                           mouseDown and layout.contains(layout.settingsBackRect(), mx, my),
                           false,
                           true,
                           false);
    }

    /// @brief In-game pause overlay.
    expose func drawPauseOverlay(mx: Integer, my: Integer, mouseDown: Boolean) {
        canvas.BoxAlpha(0, 0, WIN_W, WIN_H, theme.SCRIM, 165);
        var dialog = layout.pauseDialogRect();
        widgets.drawCard(canvas, dialog, theme.ACCENT_GOLD, true);
        theme.drawTextCenteredClipped(canvas, dialog.x + 24, dialog.y + 28, dialog.w - 48, "PAUSED", 3, theme.ACCENT_GOLD);
        widgets.drawButton(canvas, layout.pauseButtonRect(0), "RESUME",
                           layout.contains(layout.pauseButtonRect(0), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(0), mx, my),
                           false, true, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(1), "SAVE SLOT 1",
                           layout.contains(layout.pauseButtonRect(1), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(1), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(2), "SAVE SLOT 2",
                           layout.contains(layout.pauseButtonRect(2), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(2), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(3), "SAVE SLOT 3",
                           layout.contains(layout.pauseButtonRect(3), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(3), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(4), "COPY FEN",
                           layout.contains(layout.pauseButtonRect(4), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(4), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(5), "COPY PGN",
                           layout.contains(layout.pauseButtonRect(5), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(5), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(6), "SETTINGS",
                           layout.contains(layout.pauseButtonRect(6), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(6), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(7), "RESTART",
                           layout.contains(layout.pauseButtonRect(7), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(7), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(8), "MAIN MENU",
                           layout.contains(layout.pauseButtonRect(8), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(8), mx, my),
                           false, false, false);
        widgets.drawButton(canvas, layout.pauseButtonRect(9), "RESIGN",
                           layout.contains(layout.pauseButtonRect(9), mx, my),
                           mouseDown and layout.contains(layout.pauseButtonRect(9), mx, my),
                           false, false, true);
    }

    hide func drawSettingRow(idx: Integer,
                             label: String,
                             value: String,
                             mx: Integer,
                             my: Integer,
                             mouseDown: Boolean) {
        var r = layout.settingsOptionRect(idx);
        widgets.drawButton(canvas, r, "",
                           layout.contains(r, mx, my),
                           mouseDown and layout.contains(r, mx, my),
                           false,
                           false,
                           false);
        theme.drawTextClipped(canvas, r.x + 16, theme.textYInRect(r.y, r.h, 1), r.w / 2, label, 1, theme.TEXT_SECONDARY);
        theme.drawTextRightClipped(canvas, r.x + r.w / 2, theme.textYInRect(r.y, r.h, 1), r.w / 2 - 16, value, 1, theme.TEXT_PRIMARY);
    }

    hide func boolLabel(v: Boolean) -> String {
        if v { return "On"; }
        return "Off";
    }

    /// @brief Modal game-over overlay with reason + winner + NEW/MENU.
    expose func drawGameOverOverlay(reason: String, winnerText: String, mx: Integer, my: Integer, mouseDown: Boolean) {
        canvas.BoxAlpha(0, 0, WIN_W, WIN_H, theme.SCRIM, 180);
        var dialog = layout.gameOverDialogRect();
        widgets.drawCard(canvas, dialog, theme.ACCENT_GOLD, true);

        theme.drawTextCenteredClipped(canvas, dialog.x + 24, dialog.y + 26, dialog.w - 48, winnerText, 3, theme.ACCENT_GOLD);
        theme.drawTextCenteredClipped(canvas, dialog.x + 24, dialog.y + 88, dialog.w - 48, reason, 1, theme.TEXT_SECONDARY);

        widgets.drawButton(canvas, layout.gameOverNewRect(), "NEW GAME",
                           layout.contains(layout.gameOverNewRect(), mx, my),
                           mouseDown and layout.contains(layout.gameOverNewRect(), mx, my),
                           false, true, false);
        widgets.drawButton(canvas, layout.gameOverMenuRect(), "MAIN MENU",
                           layout.contains(layout.gameOverMenuRect(), mx, my),
                           mouseDown and layout.contains(layout.gameOverMenuRect(), mx, my),
                           false, false, false);
    }

    /// @brief Small "ENGINE THINKING" badge above the board.
    expose func drawThinkingIndicator() {
        var badge = layout.rect(layout.boardFrameRect().x + 420, layout.boardFrameRect().y - 20, 170, 28);
        widgets.drawBadge(canvas, badge, "ENGINE THINKING", theme.ACCENT_BLUE);
    }

    /// @brief Show attacked squares as a restrained tactical overlay.
    expose func drawAttackMap(attacked: List[Integer]) {
        for i in 0..attacked.length() {
            var sq = attacked.get(i);
            if sq < 0 || sq >= 64 { continue; }
            canvas.BoxAlpha(squareX(sq), squareY(sq), SQ_SIZE, SQ_SIZE, theme.ACCENT_RED, 34);
        }
    }

    hide func promoName(pieceType: Integer) -> String {
        if pieceType == QUEEN  { return "QUEEN"; }
        if pieceType == ROOK   { return "ROOK"; }
        if pieceType == BISHOP { return "BISHOP"; }
        return "KNIGHT";
    }

    hide func formatClock(timeSec: Integer) -> String {
        var mins = timeSec / 60;
        var secs = timeSec % 60;
        var secStr = Fmt.Int(secs);
        if secs < 10 { secStr = "0" + Fmt.Int(secs); }
        return Fmt.Int(mins) + ":" + secStr;
    }

    hide func modeString(gameMode: Integer) -> String {
        if gameMode == MODE_PVP { return "PVP"; }
        if gameMode == MODE_PVC { return "PVC"; }
        return "CVC";
    }

    hide func modeVerbose(gameMode: Integer) -> String {
        if gameMode == MODE_PVP { return "PLAYER VS PLAYER"; }
        if gameMode == MODE_PVC { return "PLAYER VS COMPUTER"; }
        return "COMPUTER VS COMPUTER";
    }

    hide func difficultyString(aiDepth: Integer) -> String {
        if aiDepth == DIFF_EASY   { return "BEGINNER"; }
        if aiDepth == DIFF_MEDIUM { return "CLUB"; }
        if aiDepth == DIFF_HARD   { return "TOURNAMENT"; }
        return "MASTER";
    }

    hide func captureMaterialValue(captures: List[Integer]) -> Integer {
        var total = 0;
        for i in 0..captures.length() {
            total = total + pieceMaterialValue(captures.get(i));
        }
        return total;
    }

    hide func pieceMaterialValue(pieceType: Integer) -> Integer {
        if pieceType == PAWN   { return VAL_PAWN; }
        if pieceType == KNIGHT { return VAL_KNIGHT; }
        if pieceType == BISHOP { return VAL_BISHOP; }
        if pieceType == ROOK   { return VAL_ROOK; }
        if pieceType == QUEEN  { return VAL_QUEEN; }
        return 0;
    }

    hide func cardHasHuman(cardIsWhite: Boolean, gameMode: Integer, playerIsWhite: Boolean) -> Boolean {
        if gameMode == MODE_PVP { return true; }
        if gameMode == MODE_CVC { return false; }
        return cardIsWhite == playerIsWhite;
    }

    hide func OUTER_MODE_X() -> Integer {
        return WIN_W / 2 - 190;
    }

    /// @brief Resolve the board theme after accessibility overrides.
    /// @param boardTheme User-selected persistent board theme.
    /// @param highContrast True to force the high-contrast palette.
    /// @return Effective theme id used for board paint this frame.
    hide func effectiveBoardTheme(boardTheme: Integer, highContrast: Boolean) -> Integer {
        if highContrast { return BOARD_HIGH_CONTRAST; }
        return boardTheme;
    }

    /// @brief Human-readable board-theme name after accessibility overrides.
    /// @param boardTheme User-selected persistent board theme.
    /// @param highContrast True to report high-contrast as the active view.
    /// @return Display label for menu summaries.
    hide func displayBoardThemeName(boardTheme: Integer, highContrast: Boolean) -> String {
        return settings.boardThemeName(effectiveBoardTheme(boardTheme, highContrast));
    }

    /// @brief Color for a board square's center pixel.
    /// @details The board render probe samples square centers and expects this
    ///          exact alternating color. Decorative top-half highlights are
    ///          layered away from the center sample.
    /// @param boardTheme Effective board theme id.
    /// @param isLight True for light-color squares.
    /// @return RGB color used for the square fill.
    hide func boardSquareColor(boardTheme: Integer, isLight: Boolean) -> Integer {
        if isLight { return boardLightAlt(boardTheme); }
        return boardDarkAlt(boardTheme);
    }

    hide func boardLight(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_SLATE { return 0xD7DEE0; }
        if boardTheme == BOARD_MARBLE { return 0xECE7DA; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0xF4F4F4; }
        if boardTheme == BOARD_CLASSIC { return 0xEEEED2; }
        return theme.BOARD_LIGHT;
    }

    hide func boardDark(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_SLATE { return 0x58646B; }
        if boardTheme == BOARD_MARBLE { return 0x9B9180; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0x222222; }
        if boardTheme == BOARD_CLASSIC { return 0x769656; }
        return theme.BOARD_DARK;
    }

    hide func boardLightAlt(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_SLATE { return 0xE8EEF0; }
        if boardTheme == BOARD_MARBLE { return 0xF6F0E2; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0xFFFFFF; }
        if boardTheme == BOARD_CLASSIC { return 0xF4F4DA; }
        return theme.BOARD_LIGHT_ALT;
    }

    hide func boardDarkAlt(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_SLATE { return 0x4B5962; }
        if boardTheme == BOARD_MARBLE { return 0x857B6F; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0x111111; }
        if boardTheme == BOARD_CLASSIC { return 0x66884A; }
        return theme.BOARD_DARK_ALT;
    }

    hide func boardFrameOut(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_MARBLE { return 0x4C4740; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0x000000; }
        return theme.BOARD_FRAME_OUT;
    }

    hide func boardFrameIn(boardTheme: Integer) -> Integer {
        if boardTheme == BOARD_MARBLE { return 0xC4B9A4; }
        if boardTheme == BOARD_HIGH_CONTRAST { return 0xFFFFFF; }
        return theme.BOARD_FRAME_IN;
    }
}
