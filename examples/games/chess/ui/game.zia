module game;

bind Viper.Graphics;
bind Viper.Input;
bind Viper.Time;
bind Viper.Fmt;
bind Viper.Terminal;
bind Thread = Viper.Threads.Thread;
bind Monitor = Viper.Threads.Monitor;
bind "../core/config";
bind "../core/board";
bind "../core/moves";
bind "../core/eval";
bind "./renderer";
bind "./pieces";
bind "./layout";
bind "../engine/ai";

// ============================================================================
// MODULE: game (ChessGame)
// PURPOSE: The chess demo's main controller. Owns the game state machine,
//          input handling, AI threading, animation, undo stacks, clock,
//          and per-frame rendering orchestration.
//
// WHERE-THIS-FITS: Top of the chess UI tree. Constructed by main.zia;
//          its `run()` method is the program's main loop.
//
// KEY-DESIGN-CHOICES:
//   * STATE MACHINE. `gameState` is one of STATE_MENU / PLAYING / PROMO
//     / AI_THINK / CHECKMATE / STALEMATE / DRAW. Input handling and
//     rendering branch on it. Transitions happen in startNewGame /
//     applyMove / checkGameOver / handleHudClick.
//   * AI ON A WORKER THREAD. The search would freeze the UI if run on
//     the render thread. We start a background thread, copy the board
//     to it, and poll for completion in pollAITurn. Module-level locks
//     and result fields (aiWorkerLock, aiWorkerHasResult, aiMoveFrom
//     etc.) shuttle the result back across the thread boundary.
//     Module-level rather than instance-level because chess only ever
//     runs one game at a time.
//   * UNDO STACKS. Five parallel arrays (undoMoveStack / undoInfoStack
//     / undoPrevFromStack / undoPrevToStack / undoCaptureColorStack)
//     capture every piece of state needed to walk back. PvC undoes
//     TWO moves at once so the human gets to retry their own move,
//     not the AI's reply.
//   * INPUT MODEL: CLICK OR DRAG. handleMousePress / handleMouseRelease
//     support both "click source then click destination" and
//     "drag-and-drop." Dragging requires no special state — we just
//     track `dragFrom` and update `dragX/dragY` while the mouse is
//     held.
//   * LEGAL MOVES CACHE. `cachedLegalMoves_` + `legalMovesValid_`
//     avoid recomputing on every input event. Invalidated whenever
//     the board changes (applyMove / unmake).
//   * MOVE ANIMATION + LIFT. Pieces animate over `animDurationMs`
//     (180 ms). The renderer's drawAnimatedPiece adds a triangular
//     vertical lift so the piece appears to be carried, not slid.
//   * THREEFOLD-REPETITION DETECTION. positionHashes records the
//     Zobrist hash before each move; checkGameOver counts repeats and
//     flags STATE_DRAW after the third occurrence.
//
// HOW-TO-READ: Module-level AI worker state -> nullMove /
//   clearAIWorkerResult / storeAIWorkerResult / loadAIWorkerResult /
//   aiSearchWorker (thread side) -> ChessGame fields -> init / setupActions
//   -> run (main loop) -> handleInput / handleMousePress / handleMouseRelease
//   / handleMenuInput / handleGameOverInput / handlePromoInput /
//   handleHudClick -> handleUndo / undoLastMove -> tryMove / executePromo
//   / findLegalMove / applyMove -> AI turn (isAITurn / startAITurn /
//   pollAITurn / cleanupAIWorker) -> animation -> game-over detection
//   -> startNewGame -> updateClocks -> render -> getLegalMoves /
//   invalidateLegalMoves / legalMovesFrom / buildSAN.
// ============================================================================

// Background AI search state. Chess only runs one game instance at a time, so
// a single module-level worker slot is enough and keeps the UI thread isolated
// from the search board copy.
var aiWorkerLock: List[Integer] = [];
var aiWorkerThread: Thread? = null;
var aiWorkerBoard: Board? = null;
var aiWorkerDepth: Integer = DIFF_HARD;
var aiWorkerHasResult: Boolean = false;
var aiMoveFrom: Integer = -1;
var aiMoveTo: Integer = -1;
var aiMoveCaptured: Integer = 0;
var aiMoveEnPassant: Boolean = false;
var aiMoveCastleKing: Boolean = false;
var aiMoveCastleQueen: Boolean = false;
var aiMovePromotion: Boolean = false;
var aiMovePromotePiece: Integer = 0;

/// @brief Sentinel "no move" used when the AI returns nothing.
func nullMove() -> Move {
    return new Move(-1, -1, 0, false, false, false, false, 0);
}

/// @brief Wipe the worker-result fields. Call inside the lock.
func clearAIWorkerResult() {
    aiMoveFrom = -1;
    aiMoveTo = -1;
    aiMoveCaptured = 0;
    aiMoveEnPassant = false;
    aiMoveCastleKing = false;
    aiMoveCastleQueen = false;
    aiMovePromotion = false;
    aiMovePromotePiece = 0;
}

/// @brief Pack a Move into the cross-thread result fields. Call inside lock.
func storeAIWorkerResult(m: Move) {
    aiMoveFrom = m.from;
    aiMoveTo = m.to;
    aiMoveCaptured = m.captured;
    aiMoveEnPassant = m.enPassant;
    aiMoveCastleKing = m.castleKing;
    aiMoveCastleQueen = m.castleQueen;
    aiMovePromotion = m.promotion;
    aiMovePromotePiece = m.promotePiece;
}

/// @brief Unpack the result fields back into a Move. Call inside lock.
func loadAIWorkerResult() -> Move {
    return new Move(aiMoveFrom, aiMoveTo, aiMoveCaptured,
                    aiMoveEnPassant, aiMoveCastleKing, aiMoveCastleQueen,
                    aiMovePromotion, aiMovePromotePiece);
}

/// @brief Worker-thread entry point. Runs the AI search, stores the
///        result, and returns. Reads `aiWorkerBoard` / `aiWorkerDepth`
///        which were set by startAITurn before this thread was started.
func aiSearchWorker() {
    if aiWorkerBoard == null { return; }

    var ai = new ChessAI();
    ai.setDepth(aiWorkerDepth);
    var best = ai.findBestMove(aiWorkerBoard!);

    Monitor.Enter(aiWorkerLock);
    storeAIWorkerResult(best);
    aiWorkerHasResult = true;
    Monitor.Exit(aiWorkerLock);
}

/// @brief Main chess controller. Wraps board + ai + renderer + state machine.
class ChessGame {
    hide Canvas        canvas;
    hide Board         board;
    hide MoveGen       moveGen;
    hide BoardRenderer renderer;

    // --- Game configuration ---
    hide Integer gameState;
    hide Integer gameMode;
    hide Integer aiDepth;
    hide Boolean playerIsWhite;   // which color the human plays in PvC

    // --- Input state ---
    hide Integer selectedSq;          // square clicked/selected (-1 = none)
    hide Integer dragFrom;            // square being dragged from (-1 = not dragging)
    hide Integer dragX;               // current drag cursor pixel X
    hide Integer dragY;               // current drag cursor pixel Y
    hide List[Move] movesForSelected; // legal moves from selectedSq

    // --- Board display state ---
    hide Integer lastFrom;
    hide Integer lastTo;
    hide Integer checkedKingSq;       // king sq if in check, else -1
    hide Boolean animActive;
    hide Integer animFromSq;
    hide Integer animToSq;
    hide Integer animPieceType;
    hide Boolean animPieceWhite;
    hide Integer animStartMs;
    hide Integer animDurationMs;

    // --- Move history & captures ---
    hide List[String]  sanHistory;
    hide List[Integer] whiteCaptured; // piece types captured by white
    hide List[Integer] blackCaptured; // piece types captured by black
    hide Integer moveCount;

    // --- Clock state (count-up from 0, seconds per side) ---
    hide Integer whiteTimeSec;
    hide Integer blackTimeSec;
    hide Integer lastTickMs;

    // --- Promotion ---
    hide Integer promoFrom;
    hide Integer promoTo;

    // --- Threefold repetition ---
    hide List[Integer] positionHashes;

    // --- Game over ---
    hide String gameOverReason;
    hide String gameOverWinner;

    // --- AI ---
    hide Integer aiThinkStartMs;

    // --- Undo stacks (parallel arrays, one entry per applied move) ---
    hide List[Move]     undoMoveStack;
    hide List[UndoInfo] undoInfoStack;
    hide List[Integer]  undoPrevFromStack;       // lastFrom before the move
    hide List[Integer]  undoPrevToStack;         // lastTo before the move
    hide List[Integer]  undoCaptureColorStack;   // 1=white captured, -1=black, 0=none

    // --- Key debounce flag (Ctrl+Z needs manual debounce — modifier combo) ---
    hide Boolean ctrlZWasDown;

    // --- Legal moves cache (invalidated after each board change) ---
    hide List[Move] cachedLegalMoves_;
    hide Boolean    legalMovesValid_;

    /// @brief Build the canvas, board, move generator, renderer; pre-render
    ///        sprites; reset all state to MENU defaults.
    expose func init() {
        canvas   = Canvas.New("Viper Chess", WIN_W, WIN_H);
        board    = new Board();
        moveGen  = new MoveGen();
        renderer = new BoardRenderer();

        renderer.setCanvas(canvas);

        // Pre-render piece sprites for high-quality rendering
        pieces.initSprites();

        gameState     = STATE_MENU;
        gameMode      = MODE_PVC;
        aiDepth       = DIFF_HARD;
        playerIsWhite = true;

        selectedSq       = -1;
        dragFrom         = -1;
        dragX            = 0;
        dragY            = 0;
        movesForSelected = [];

        lastFrom      = -1;
        lastTo        = -1;
        checkedKingSq = -1;
        animActive    = false;
        animFromSq    = -1;
        animToSq      = -1;
        animPieceType = 0;
        animPieceWhite = true;
        animStartMs   = 0;
        animDurationMs = 180;

        sanHistory    = [];
        whiteCaptured = [];
        blackCaptured = [];
        moveCount     = 0;

        // Clocks count up from 0
        whiteTimeSec = 0;
        blackTimeSec = 0;
        lastTickMs   = 0;

        promoFrom = -1;
        promoTo   = -1;

        positionHashes = [];

        gameOverReason = "";
        gameOverWinner = "";

        aiThinkStartMs = 0;

        undoMoveStack         = [];
        undoInfoStack         = [];
        undoPrevFromStack     = [];
        undoPrevToStack       = [];
        undoCaptureColorStack = [];

        ctrlZWasDown      = false;

        setupActions();
        cleanupAIWorker();

        cachedLegalMoves_ = [];
        legalMovesValid_  = false;
    }

    /// @brief Define keyboard / gamepad action bindings (N = new, ESC = back).
    hide func setupActions() {
        Action.Define(ACT_NEW_GAME);
        Action.BindKey(ACT_NEW_GAME, KEY_N);

        Action.Define(ACT_BACK);
        Action.BindKey(ACT_BACK, KEY_ESCAPE);

        // Gamepad bindings
        Action.BindPadButton(ACT_BACK, PAD_IDX, PAD_BTN_B);
        Action.BindPadButton(ACT_BACK, PAD_IDX, PAD_BTN_START);
    }

    // =========================================================================
    // Main game loop
    // =========================================================================

    /// @brief Main loop. ~120 FPS cap (sleep 8ms). Handles input, ticks
    ///        clocks, polls the AI worker, and renders every frame
    ///        until the window closes.
    expose func run() {
        lastTickMs = Viper.Time.GetTickCount();

        while canvas.get_ShouldClose() == 0 {
            canvas.Poll();

            handleInput();
            updateClocks();

            if gameState == STATE_AI_THINK {
                pollAITurn();
            }

            render();
            Viper.Time.SleepMs(8);   // ~120 FPS cap
        }

        cleanupAIWorker();
    }

    // =========================================================================
    // Input handling
    // =========================================================================

    /// @brief Top-level input dispatcher. Routes by gameState to the
    ///        appropriate handler; also handles the global Ctrl+Z undo
    ///        and ESC-to-menu shortcuts.
    hide func handleInput() {
        var mx = Viper.Input.Mouse.X();
        var my = Viper.Input.Mouse.Y();

        if gameState == STATE_MENU {
            handleMenuInput(mx, my);
            return;
        }

        if Action.Pressed(ACT_BACK) {
            cleanupAIWorker();
            gameState = STATE_MENU;
            return;
        }

        // Ctrl+Z — undo (SDL_SCANCODE_LCTRL=224, SDL_SCANCODE_Z=29)
        // Works from any non-menu game state including game-over screens.
        var ctrlZ = canvas.KeyHeld(224) != 0 && canvas.KeyHeld(29) != 0;
        if !ctrlZ { ctrlZWasDown = false; }
        if ctrlZ && !ctrlZWasDown {
            ctrlZWasDown = true;
            handleUndo();
        }

        if gameState == STATE_CHECKMATE || gameState == STATE_STALEMATE || gameState == STATE_DRAW {
            handleGameOverInput(mx, my);
            return;
        }

        if gameState == STATE_PROMO {
            handlePromoInput(mx, my);
            return;
        }

        if gameState == STATE_PLAYING || gameState == STATE_AI_THINK {
            if handleHudClick(mx, my) { return; }
        }

        if animationProgressPermille() >= 0 {
            return;
        }

        if gameState != STATE_PLAYING { return; }

        // 'N' — new game (Action-based, edge-detected)
        if Action.Pressed(ACT_NEW_GAME) {
            startNewGame();
            return;
        }

        // Mouse press — pick up a piece
        if Viper.Input.Mouse.WasPressed(0) {
            handleMousePress(mx, my);
        }

        // Mouse hold — update drag position
        if Viper.Input.Mouse.Left() {
            if dragFrom >= 0 {
                dragX = mx;
                dragY = my;
            }
        }

        // Mouse release — drop piece
        if Viper.Input.Mouse.WasReleased(0) {
            handleMouseRelease(mx, my);
        }
    }

    /// @brief Mouse-down handler: select a piece (start of click-or-drag)
    ///        or commit a click-to-move if a piece is already selected.
    hide func handleMousePress(mx: Integer, my: Integer) {
        var sq = renderer.squareAt(mx, my);

        if sq < 0 {
            selectedSq       = -1;
            movesForSelected = [];
            return;
        }

        var piece = board.get(sq);
        var isMyPiece = false;

        if gameMode == MODE_PVP {
            // In PvP, current player's piece
            isMyPiece = piece != 0 && board.isWhitePiece(piece) == board.whiteToMove;
        } else {
            // In PvC, only the human's pieces on the human's turn
            isMyPiece = piece != 0 && board.isWhitePiece(piece) == playerIsWhite &&
                        board.whiteToMove == playerIsWhite;
        }

        if isMyPiece {
            selectedSq = sq;
            dragFrom   = sq;
            dragX      = mx;
            dragY      = my;
            movesForSelected = legalMovesFrom(sq);
        } else if selectedSq >= 0 {
            // Try click-to-move to this square
            if tryMove(selectedSq, sq) {
                selectedSq       = -1;
                movesForSelected = [];
            } else {
                selectedSq       = -1;
                movesForSelected = [];
                dragFrom         = -1;
            }
        }
    }

    /// @brief Mouse-up handler: commit drag-and-drop move, or toggle
    ///        selection if dropped back on origin.
    hide func handleMouseRelease(mx: Integer, my: Integer) {
        if dragFrom < 0 { return; }

        var sq = renderer.squareAt(mx, my);

        if sq >= 0 && sq != dragFrom {
            // Drag-and-drop: attempt move
            if tryMove(dragFrom, sq) {
                selectedSq       = -1;
                movesForSelected = [];
            } else {
                // Invalid drop: keep piece selected at origin
                selectedSq       = dragFrom;
                movesForSelected = legalMovesFrom(dragFrom);
            }
        } else if sq == dragFrom {
            // Dropped back on origin: toggle selection
            if selectedSq == dragFrom {
                selectedSq       = -1;
                movesForSelected = [];
            } else {
                selectedSq       = dragFrom;
                movesForSelected = legalMovesFrom(dragFrom);
            }
        }

        dragFrom = -1;
    }

    /// @brief Main-menu click + ENTER handling. Selects mode/side/diff
    ///        or starts the game on START / ENTER.
    hide func handleMenuInput(mx: Integer, my: Integer) {
        if Keyboard.WasPressed(KEY_ENTER) {
            startNewGame();
            return;
        }

        if !Viper.Input.Mouse.WasClicked(0) { return; }

        if layout.contains(layout.modeButtonRect(0), mx, my) { gameMode = MODE_PVP; }
        if layout.contains(layout.modeButtonRect(1), mx, my) { gameMode = MODE_PVC; }
        if layout.contains(layout.modeButtonRect(2), mx, my) { gameMode = MODE_CVC; }

        if layout.contains(layout.sideButtonRect(0), mx, my) { playerIsWhite = true; }
        if layout.contains(layout.sideButtonRect(1), mx, my) { playerIsWhite = false; }

        if layout.contains(layout.difficultyButtonRect(0), mx, my) { aiDepth = DIFF_EASY; }
        if layout.contains(layout.difficultyButtonRect(1), mx, my) { aiDepth = DIFF_MEDIUM; }
        if layout.contains(layout.difficultyButtonRect(2), mx, my) { aiDepth = DIFF_HARD; }
        if layout.contains(layout.difficultyButtonRect(3), mx, my) { aiDepth = DIFF_EXPERT; }

        if layout.contains(layout.startButtonRect(), mx, my) {
            startNewGame();
        }
    }

    /// @brief Game-over overlay click handler (NEW GAME / MAIN MENU).
    hide func handleGameOverInput(mx: Integer, my: Integer) {
        if !Viper.Input.Mouse.WasClicked(0) { return; }

        if layout.contains(layout.gameOverNewRect(), mx, my) {
            startNewGame();
        }

        if layout.contains(layout.gameOverMenuRect(), mx, my) {
            cleanupAIWorker();
            gameState = STATE_MENU;
        }
    }

    /// @brief Promotion-dialog click handler (Q / R / B / N choice).
    hide func handlePromoInput(mx: Integer, my: Integer) {
        if !Viper.Input.Mouse.WasClicked(0) { return; }

        var pieces = [QUEEN, ROOK, BISHOP, KNIGHT];
        for i in 0..4 {
            if layout.contains(layout.promoOptionRect(i), mx, my) {
                executePromo(pieces.get(i));
                return;
            }
        }
    }

    /// @brief Top/footer chrome click handler (NEW / MENU / DRAW / RESIGN).
    /// @return true if a chrome button was clicked (caller stops further handling).
    hide func handleHudClick(mx: Integer, my: Integer) -> Boolean {
        if !Viper.Input.Mouse.WasClicked(0) { return false; }

        if layout.contains(layout.newButtonRect(), mx, my) {
            startNewGame();
            return true;
        }

        if layout.contains(layout.menuButtonRect(), mx, my) {
            cleanupAIWorker();
            gameState = STATE_MENU;
            return true;
        }

        if layout.contains(layout.drawButtonRect(), mx, my) {
            cleanupAIWorker();
            gameState = STATE_DRAW;
            gameOverReason = "Draw agreed";
            gameOverWinner = "Draw";
            return true;
        }

        if layout.contains(layout.resignButtonRect(), mx, my) {
            cleanupAIWorker();
            gameState = STATE_CHECKMATE;
            gameOverReason = "Resignation";
            if board.whiteToMove {
                gameOverWinner = "Black wins!";
            } else {
                gameOverWinner = "White wins!";
            }
            return true;
        }

        return false;
    }

    // =========================================================================
    // Undo handling
    // =========================================================================

    /// @brief Ctrl+Z undo. PvC undoes TWO plies so the human gets to
    ///        replay their own move rather than the AI's reply.
    hide func handleUndo() {
        if gameState == STATE_AI_THINK { return; }   // unsafe while AI is mid-search
        if undoMoveStack.length() == 0 { return; }

        // Undo the last move
        undoLastMove();

        // In PvC mode: also undo the AI's preceding response so the human
        // gets to replay their own move (not the AI's reply).
        if gameMode == MODE_PVC && undoMoveStack.length() > 0 {
            undoLastMove();
        }

    }

    /// @brief Pop one ply from every undo stack and restore board + UI.
    hide func undoLastMove() {
        if undoMoveStack.length() == 0 { return; }

        var m        = undoMoveStack.pop();
        var undo     = undoInfoStack.pop();
        var prevFrom = undoPrevFromStack.pop();
        var prevTo   = undoPrevToStack.pop();
        var capColor = undoCaptureColorStack.pop();

        // Restore board state
        board.unmakeMove(m, undo);
        invalidateLegalMoves();

        // Restore last-move highlight
        lastFrom = prevFrom;
        lastTo   = prevTo;

        // Undo capture tracking
        if capColor == 1 && whiteCaptured.length() > 0  { whiteCaptured.pop(); }
        if capColor == -1 && blackCaptured.length() > 0 { blackCaptured.pop(); }

        // Undo position-hash and SAN history entries
        if positionHashes.length() > 0 { positionHashes.pop(); }
        if sanHistory.length() > 0     { sanHistory.pop(); }

        moveCount = moveCount - 1;

        // Recompute check highlight for the restored position
        checkedKingSq = -1;
        if moveGen.isInCheck(board, board.whiteToMove) {
            checkedKingSq = board.kingSquare(board.whiteToMove);
        }

        // Clear selection
        selectedSq       = -1;
        movesForSelected = [];
        dragFrom         = -1;
        stopAnimation();

        gameState = STATE_PLAYING;
    }

    // =========================================================================
    // Move execution
    // =========================================================================

    /// @brief Try a (from, to) move. Promotions queue the promo dialog;
    ///        non-promotions apply immediately.
    /// @return true if a legal move was found and applied (or queued).
    hide func tryMove(fromSq: Integer, toSq: Integer) -> Boolean {
        var m = findLegalMove(fromSq, toSq, 0);
        if m.from == -1 { return false; }

        // Pawn reaching the back rank: show promotion dialog first
        if m.promotion {
            promoFrom = fromSq;
            promoTo   = toSq;
            gameState = STATE_PROMO;
            return true;
        }

        applyMove(m);
        return true;
    }

    /// @brief Apply the queued promotion move with the chosen piece type.
    hide func executePromo(pieceType: Integer) {
        var m = findLegalMove(promoFrom, promoTo, pieceType);
        if m.from >= 0 {
            applyMove(m);
        }
        gameState = STATE_PLAYING;
    }

    /// @brief Lookup a legal move matching (from, to, promoPiece).
    /// @param promoPiece 0 to match any promotion (caller will dialog).
    /// @return The matching Move, or sentinel `from=-1` Move if none.
    hide func findLegalMove(fromSq: Integer, toSq: Integer, promoPiece: Integer) -> Move {
        var all = getLegalMoves();
        for i in 0..all.length() {
            var m = all.get(i);
            if m.from != fromSq { continue; }
            if m.to   != toSq   { continue; }
            if m.promotion && promoPiece > 0 && m.promotePiece != promoPiece { continue; }
            if m.promotion && promoPiece == 0 { return m; }  // any promo (caller shows dialog)
            return m;
        }
        return new Move(-1, -1, 0, false, false, false, false, 0);
    }

    /// @brief Commit a move: push undo state, track captures, update
    ///        last-move highlight, snapshot hash for repetition,
    ///        invoke board.makeMove, build SAN, animate, check
    ///        terminal conditions, and queue the AI if it's its turn.
    hide func applyMove(m: Move) {
        var movingPiece = board.get(m.from);
        var movingWhite = board.isWhitePiece(movingPiece);
        var movingType = board.pieceType(movingPiece);
        if m.promotion {
            movingType = m.promotePiece;
        }

        // --- Push undo state BEFORE modifying anything ---
        undoPrevFromStack.add(lastFrom);
        undoPrevToStack.add(lastTo);

        // Track captures. board.whiteToMove = the side making this move.
        var captureColor = 0;
        if m.captured != 0 {
            if board.whiteToMove {
                whiteCaptured.add(m.captured);
                captureColor = 1;
            } else {
                blackCaptured.add(m.captured);
                captureColor = -1;
            }
        }
        undoCaptureColorStack.add(captureColor);

        // Update move highlight
        lastFrom = m.from;
        lastTo   = m.to;

        // Record hash of the position BEFORE this move (for threefold detection)
        positionHashes.add(board.getHash());

        // Apply the move; capture the undo struct
        var undo = board.makeMove(m);
        invalidateLegalMoves();

        // Push move + undo for later unmaking
        undoMoveStack.add(m);
        undoInfoStack.add(undo);

        // SAN notation (board now reflects the post-move state)
        var san = buildSAN(m);
        sanHistory.add(san);

        moveCount = moveCount + 1;
        startMoveAnimation(m.from, m.to, movingType, movingWhite);

        // Check for terminal conditions
        checkGameOver();

        // Schedule AI move if it is now the AI's turn
        if gameState == STATE_PLAYING {
            if isAITurn() {
                startAITurn();
            }
        }
    }

    // =========================================================================
    // AI turn
    // =========================================================================

    /// @brief Is it the AI's turn to move? CvC always; PvC when not the human's side.
    hide func isAITurn() -> Boolean {
        if gameMode == MODE_CVC { return true; }
        if gameMode == MODE_PVC && board.whiteToMove != playerIsWhite { return true; }
        return false;
    }

    /// @brief Spawn the AI worker thread on a copy of the current board.
    hide func startAITurn() {
        cleanupAIWorker();

        aiWorkerBoard = board.copy();
        aiWorkerDepth = aiDepth;

        Monitor.Enter(aiWorkerLock);
        clearAIWorkerResult();
        aiWorkerHasResult = false;
        Monitor.Exit(aiWorkerLock);

        aiWorkerThread = Thread.StartSafe(&aiSearchWorker, 0);
        gameState      = STATE_AI_THINK;
        aiThinkStartMs = Viper.Time.GetTickCount();
    }

    /// @brief Per-frame check on the AI worker. If the worker finished,
    ///        unpack the result, apply the move, and (in CvC) enforce
    ///        a minimum CVC_DELAY_MS between moves so the game is
    ///        watchable.
    hide func pollAITurn() {
        if aiWorkerThread == null { return; }
        if aiWorkerThread!.SafeIsAlive() { return; }

        aiWorkerThread!.SafeJoin();
        var thread = aiWorkerThread!;
        aiWorkerThread = null;
        aiWorkerBoard  = null;

        gameState = STATE_PLAYING;

        if thread.HasError {
            Say("Chess AI worker error: " + thread.Error);
            var legalFallback = getLegalMoves();
            if legalFallback.length() == 0 {
                checkGameOver();
                return;
            }
            applyMove(legalFallback.get(0));
            return;
        }

        var m = nullMove();
        Monitor.Enter(aiWorkerLock);
        if aiWorkerHasResult {
            m = loadAIWorkerResult();
        }
        clearAIWorkerResult();
        aiWorkerHasResult = false;
        Monitor.Exit(aiWorkerLock);

        // Sentinel: from < 0 means no legal moves — let checkGameOver handle it
        if m.from < 0 {
            checkGameOver();
            return;
        }

        // For CvC: enforce a minimum delay between AI moves so the game is watchable
        if gameMode == MODE_CVC {
            var elapsed = Viper.Time.GetTickCount() - aiThinkStartMs;
            if elapsed < CVC_DELAY_MS {
                Viper.Time.SleepMs(CVC_DELAY_MS - elapsed);
            }
        }

        applyMove(m);
    }

    /// @brief Join any in-flight AI thread + clear its result. Idempotent.
    hide func cleanupAIWorker() {
        if aiWorkerThread != null {
            aiWorkerThread!.SafeJoin();
            aiWorkerThread = null;
        }
        aiWorkerBoard = null;
        Monitor.Enter(aiWorkerLock);
        clearAIWorkerResult();
        aiWorkerHasResult = false;
        Monitor.Exit(aiWorkerLock);
    }

    /// @brief Begin a 180-ms slide+lift animation between two squares.
    hide func startMoveAnimation(fromSq: Integer, toSq: Integer, pieceType: Integer, white: Boolean) {
        animActive = true;
        animFromSq = fromSq;
        animToSq = toSq;
        animPieceType = pieceType;
        animPieceWhite = white;
        animStartMs = Viper.Time.GetTickCount();
    }

    /// @brief Cancel any in-flight animation.
    hide func stopAnimation() {
        animActive = false;
        animFromSq = -1;
        animToSq = -1;
        animPieceType = 0;
        animStartMs = 0;
    }

    /// @brief Return current animation progress in 0..1000 per-mille,
    ///        or -1 if no animation. Auto-stops when complete.
    hide func animationProgressPermille() -> Integer {
        if !animActive { return -1; }
        var elapsed = Viper.Time.GetTickCount() - animStartMs;
        if elapsed >= animDurationMs {
            stopAnimation();
            return -1;
        }
        if elapsed <= 0 { return 0; }
        return elapsed * 1000 / animDurationMs;
    }

    // =========================================================================
    // Game over detection
    // =========================================================================

    /// @brief Check for terminal conditions: checkmate, stalemate, 50-move
    ///        rule, threefold repetition. Updates `gameState` accordingly.
    hide func checkGameOver() {
        var legal   = getLegalMoves();
        var inCheck = moveGen.isInCheck(board, board.whiteToMove);

        checkedKingSq = -1;
        if inCheck { checkedKingSq = board.kingSquare(board.whiteToMove); }

        if legal.length() == 0 {
            if inCheck {
                // Checkmate
                gameState = STATE_CHECKMATE;
                gameOverReason = "Checkmate";
                if board.whiteToMove {
                    gameOverWinner = "Black wins!";
                } else {
                    gameOverWinner = "White wins!";
                }
            } else {
                // Stalemate
                gameState = STATE_STALEMATE;
                gameOverReason = "Stalemate";
                gameOverWinner = "Draw";
            }
            return;
        }

        // 50-move rule
        if board.halfMoveClock >= 100 {
            gameState = STATE_DRAW;
            gameOverReason = "50-move rule";
            gameOverWinner = "Draw";
            return;
        }

        // Threefold repetition: current hash matches 2+ earlier positions
        var currentHash = board.getHash();
        var count = 0;
        for i in 0..positionHashes.length() {
            if positionHashes.get(i) == currentHash { count = count + 1; }
        }
        if count >= 2 {
            gameState = STATE_DRAW;
            gameOverReason = "Threefold repetition";
            gameOverWinner = "Draw";
            return;
        }
    }

    // =========================================================================
    // Game management
    // =========================================================================

    /// @brief Reset to STATE_PLAYING with a fresh starting position and
    ///        empty undo / clock / capture / animation state.
    hide func startNewGame() {
        cleanupAIWorker();

        // new Board() automatically calls init() → setupStartPosition()
        board = new Board();
        invalidateLegalMoves();

        selectedSq       = -1;
        dragFrom         = -1;
        movesForSelected = [];
        sanHistory       = [];
        whiteCaptured    = [];
        blackCaptured    = [];
        positionHashes   = [];
        moveCount        = 0;
        lastFrom         = -1;
        lastTo           = -1;
        checkedKingSq    = -1;
        stopAnimation();

        // Clocks count up from 0
        whiteTimeSec = 0;
        blackTimeSec = 0;
        lastTickMs   = Viper.Time.GetTickCount();

        undoMoveStack         = [];
        undoInfoStack         = [];
        undoPrevFromStack     = [];
        undoPrevToStack       = [];
        undoCaptureColorStack = [];

        gameState = STATE_PLAYING;

        // In PvC with AI as white, trigger AI immediately
        if isAITurn() {
            startAITurn();
        }
    }

    // =========================================================================
    // Clock update (count-up: increment the active player's clock each second)
    // =========================================================================

    /// @brief Tick the active player's count-up clock once per second.
    hide func updateClocks() {
        if gameState != STATE_PLAYING { return; }

        var now     = Viper.Time.GetTickCount();
        var elapsed = (now - lastTickMs) / 1000;  // ms → seconds

        if elapsed >= 1 {
            lastTickMs = now;
            if board.whiteToMove {
                whiteTimeSec = whiteTimeSec + 1;
            } else {
                blackTimeSec = blackTimeSec + 1;
            }
        }
    }

    // =========================================================================
    // Rendering
    // =========================================================================

    /// @brief Per-frame paint. Z-order: backdrop -> board -> highlights ->
    ///        pieces -> drag/animation overlay -> top bar -> footer ->
    ///        side panel -> promo / thinking / game-over overlays.
    hide func render() {
        var mx = Viper.Input.Mouse.X();
        var my = Viper.Input.Mouse.Y();
        var mouseDown = Viper.Input.Mouse.Left() != 0;
        var animProgress = animationProgressPermille();
        var hoverSq = renderer.squareAt(mx, my);
        if dragFrom >= 0 || animProgress >= 0 {
            hoverSq = -1;
        }

        if gameState == STATE_MENU {
            renderer.drawMainMenu(gameMode, aiDepth, playerIsWhite, mx, my, mouseDown);
            canvas.Flip();
            return;
        }

        renderer.drawGameBackdrop();

        // Draw board and pieces
        renderer.drawBoard(lastFrom, lastTo, hoverSq);
        renderer.drawCheckHighlight(checkedKingSq);
        renderer.drawHighlights(selectedSq, movesForSelected);
        var skipSq = -1;
        if animProgress >= 0 {
            skipSq = animToSq;
        }
        renderer.drawPieces(board, dragFrom, skipSq);

        // Draw dragged piece following the cursor
        if dragFrom >= 0 {
            var piece = board.get(dragFrom);
            if piece != 0 {
                renderer.drawDragPiece(board.pieceType(piece), board.isWhitePiece(piece), dragX, dragY);
            }
        } else if animProgress >= 0 {
            renderer.drawAnimatedPiece(animPieceType, animPieceWhite, animFromSq, animToSq, animProgress);
        }

        // Top and bottom bars
        var turnStr = "White to move";
        if !board.whiteToMove   { turnStr = "Black to move"; }
        if gameState == STATE_AI_THINK { turnStr = "AI thinking..."; }
        renderer.drawTopBar(turnStr, gameMode, mx, my, mouseDown);

        var statusStr = "Move " + Int(board.fullMoveNumber) + "  Halfmove " + Int(board.halfMoveClock);
        renderer.drawFooter(statusStr, mx, my, mouseDown);

        // Side panel
        renderer.drawPanel(board,
                          whiteTimeSec, blackTimeSec,
                          sanHistory,
                          whiteCaptured, blackCaptured,
                          gameMode, aiDepth, playerIsWhite,
                          gameState == STATE_AI_THINK, checkedKingSq);

        // Overlays (in order of priority)
        if gameState == STATE_PROMO {
            renderer.drawPromoDialog(board.whiteToMove, mx, my, mouseDown);
        }

        if gameState == STATE_AI_THINK {
            renderer.drawThinkingIndicator();
        }

        if gameState == STATE_CHECKMATE || gameState == STATE_STALEMATE || gameState == STATE_DRAW {
            renderer.drawGameOverOverlay(gameOverReason, gameOverWinner, mx, my, mouseDown);
        }

        canvas.Flip();
    }

    // =========================================================================
    // Helpers
    // =========================================================================

    /// @brief Cached legal-move list for the current position.
    hide func getLegalMoves() -> List[Move] {
        if !legalMovesValid_ {
            cachedLegalMoves_ = moveGen.legalMoves(board);
            legalMovesValid_  = true;
        }
        return cachedLegalMoves_;
    }

    /// @brief Invalidate the legal-move cache. Call after every board change.
    hide func invalidateLegalMoves() {
        legalMovesValid_ = false;
    }

    /// @brief Filter the legal-move list to those originating at `sq`.
    hide func legalMovesFrom(sq: Integer) -> List[Move] {
        var all    = getLegalMoves();
        var result = [];
        for i in 0..all.length() {
            var m = all.get(i);
            if m.from == sq { result.add(m); }
        }
        return result;
    }

    /// @brief Build simplified Standard Algebraic Notation for move `m`.
    /// @details Precondition: `m` has been applied to the board.
    ///   Promotion handling: when `m.promotion` is true, the mover was
    ///   a pawn — reading board.get(m.to) would return the PROMOTED
    ///   piece (e.g. QUEEN) and produce "Qd8=Q". We force type_ = PAWN
    ///   so the prefix letter is suppressed per SAN rules.
    hide func buildSAN(m: Move) -> String {
        var files    = ["a", "b", "c", "d", "e", "f", "g", "h"];
        var fromFile = m.from % 8;
        var toFile   = m.to % 8;
        var toRank   = 8 - m.to / 8;

        // Castling
        if m.castleKing  { return "O-O"; }
        if m.castleQueen { return "O-O-O"; }

        // Determine moving piece type.
        // For promotions the mover was always a pawn → no prefix letter.
        // For normal moves read the piece now at the destination.
        var type_ = PAWN;
        if !m.promotion {
            type_ = board.pieceType(board.get(m.to));
        }

        var san = "";
        if type_ == KNIGHT { san = "N"; }
        if type_ == BISHOP { san = "B"; }
        if type_ == ROOK   { san = "R"; }
        if type_ == QUEEN  { san = "Q"; }
        if type_ == KING   { san = "K"; }

        // Capture prefix (file letter for pawn captures, piece letter for others)
        if m.captured != 0 || m.enPassant {
            if san == "" { san = files.get(fromFile); }
            san = san + "x";
        }

        san = san + files.get(toFile) + Int(toRank);

        // Promotion suffix
        if m.promotion {
            if m.promotePiece == QUEEN  { san = san + "=Q"; }
            if m.promotePiece == ROOK   { san = san + "=R"; }
            if m.promotePiece == BISHOP { san = san + "=B"; }
            if m.promotePiece == KNIGHT { san = san + "=N"; }
        }

        return san;
    }
}
