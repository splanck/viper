module pieces;

bind Viper.Graphics;
bind "../core/config";

// ============================================================================
// MODULE: pieces (PieceSprites)
// PURPOSE: Pre-render the twelve piece sprites + drop-shadows + miniature
//          versions at startup, then provide getPiece / getShadow /
//          getMiniPiece accessors that the renderer blits each frame.
//
// WHERE-THIS-FITS: Imported by renderer.zia. The chess game's main
//          init flow: ChessGame.init -> pieces.initSprites() -> first
//          frame can render.
//
// KEY-DESIGN-CHOICES:
//   * RENDER ONCE, BLIT MANY. Each piece is drawn into a 70×70 Pixels
//     buffer using the rich Pixels.Draw* API (anti-aliased ellipses,
//     thick lines, triangles, Bezier curves). The sprite is then
//     stamped on the canvas each frame via Canvas.BlitAlpha, which is
//     dramatically faster than re-running the draw calls per frame.
//   * THREE SIZES PER PIECE. Full sprite (70×70), tinted-and-blurred
//     shadow (same size, dropped behind the piece for depth), and
//     mini (28×28, shown in the captured-pieces row of the side
//     panel).
//   * LAYERED DRAWING TECHNIQUE. Each piece draws an outline layer
//     first (slightly larger shapes in outline color), then a fill
//     layer (slightly smaller in fill color). The visible difference
//     between the layers IS the outline. This is the same trick used
//     by old console-game sprite editors.
//   * COLOR PALETTE BY SIDE. White pieces use a warm cream fill
//     (`0xF6E9CE`) with a dark brown outline; black uses a deep brown
//     fill with a cream outline. The colour pairing keeps both colours
//     legible against either light or dark squares.
//
// HOW-TO-READ: Sprite-cache field declarations -> Public API
//   (initSprites / getPiece / getShadow / getMiniPiece) -> color
//   helpers (fillColor / outlineColor / accentColor / detailColor) ->
//   buildShadow -> per-piece renderers (renderPawn, renderRook, etc.).
// ============================================================================

// 12 pre-rendered sprites: 6 piece types × 2 colors
var whitePawn:   Pixels;
var whiteRook:   Pixels;
var whiteKnight: Pixels;
var whiteBishop: Pixels;
var whiteQueen:  Pixels;
var whiteKing:   Pixels;
var blackPawn:   Pixels;
var blackRook:   Pixels;
var blackKnight: Pixels;
var blackBishop: Pixels;
var blackQueen:  Pixels;
var blackKing:   Pixels;

var whitePawnShadow:   Pixels;
var whiteRookShadow:   Pixels;
var whiteKnightShadow: Pixels;
var whiteBishopShadow: Pixels;
var whiteQueenShadow:  Pixels;
var whiteKingShadow:   Pixels;
var blackPawnShadow:   Pixels;
var blackRookShadow:   Pixels;
var blackKnightShadow: Pixels;
var blackBishopShadow: Pixels;
var blackQueenShadow:  Pixels;
var blackKingShadow:   Pixels;

var whitePawnMini:   Pixels;
var whiteRookMini:   Pixels;
var whiteKnightMini: Pixels;
var whiteBishopMini: Pixels;
var whiteQueenMini:  Pixels;
var whiteKingMini:   Pixels;
var blackPawnMini:   Pixels;
var blackRookMini:   Pixels;
var blackKnightMini: Pixels;
var blackBishopMini: Pixels;
var blackQueenMini:  Pixels;
var blackKingMini:   Pixels;

final SP = PIECE_SZ;           // sprite size (70×70)
final CX = PIECE_SZ / 2;      // center X
final CY = PIECE_SZ / 2;      // center Y

// ============================================================================
// Public API
// ============================================================================

/// @brief Pre-render every piece sprite + shadow + mini at 70×70 / 28×28.
/// @note Call once at game startup. Subsequent calls re-render — the
///       function is idempotent in effect but not free in time.
func initSprites() {
    whitePawn   = renderPawn(true);
    whiteRook   = renderRook(true);
    whiteKnight = renderKnight(true);
    whiteBishop = renderBishop(true);
    whiteQueen  = renderQueen(true);
    whiteKing   = renderKing(true);
    blackPawn   = renderPawn(false);
    blackRook   = renderRook(false);
    blackKnight = renderKnight(false);
    blackBishop = renderBishop(false);
    blackQueen  = renderQueen(false);
    blackKing   = renderKing(false);

    whitePawnShadow   = buildShadow(whitePawn);
    whiteRookShadow   = buildShadow(whiteRook);
    whiteKnightShadow = buildShadow(whiteKnight);
    whiteBishopShadow = buildShadow(whiteBishop);
    whiteQueenShadow  = buildShadow(whiteQueen);
    whiteKingShadow   = buildShadow(whiteKing);
    blackPawnShadow   = buildShadow(blackPawn);
    blackRookShadow   = buildShadow(blackRook);
    blackKnightShadow = buildShadow(blackKnight);
    blackBishopShadow = buildShadow(blackBishop);
    blackQueenShadow  = buildShadow(blackQueen);
    blackKingShadow   = buildShadow(blackKing);

    whitePawnMini   = whitePawn.Scale(28, 28);
    whiteRookMini   = whiteRook.Scale(28, 28);
    whiteKnightMini = whiteKnight.Scale(28, 28);
    whiteBishopMini = whiteBishop.Scale(28, 28);
    whiteQueenMini  = whiteQueen.Scale(28, 28);
    whiteKingMini   = whiteKing.Scale(28, 28);
    blackPawnMini   = blackPawn.Scale(28, 28);
    blackRookMini   = blackRook.Scale(28, 28);
    blackKnightMini = blackKnight.Scale(28, 28);
    blackBishopMini = blackBishop.Scale(28, 28);
    blackQueenMini  = blackQueen.Scale(28, 28);
    blackKingMini   = blackKing.Scale(28, 28);
}

/// @brief Look up the full-size sprite for a piece. Null on invalid type.
func getPiece(pieceType: Integer, isWhite: Boolean) -> Pixels {
    if isWhite {
        if pieceType == PAWN   { return whitePawn; }
        if pieceType == ROOK   { return whiteRook; }
        if pieceType == KNIGHT { return whiteKnight; }
        if pieceType == BISHOP { return whiteBishop; }
        if pieceType == QUEEN  { return whiteQueen; }
        if pieceType == KING   { return whiteKing; }
    } else {
        if pieceType == PAWN   { return blackPawn; }
        if pieceType == ROOK   { return blackRook; }
        if pieceType == KNIGHT { return blackKnight; }
        if pieceType == BISHOP { return blackBishop; }
        if pieceType == QUEEN  { return blackQueen; }
        if pieceType == KING   { return blackKing; }
    }
    return null;
}

/// @brief Look up the drop-shadow Pixels for a piece. Null on invalid type.
func getShadow(pieceType: Integer, isWhite: Boolean) -> Pixels {
    if isWhite {
        if pieceType == PAWN   { return whitePawnShadow; }
        if pieceType == ROOK   { return whiteRookShadow; }
        if pieceType == KNIGHT { return whiteKnightShadow; }
        if pieceType == BISHOP { return whiteBishopShadow; }
        if pieceType == QUEEN  { return whiteQueenShadow; }
        if pieceType == KING   { return whiteKingShadow; }
    } else {
        if pieceType == PAWN   { return blackPawnShadow; }
        if pieceType == ROOK   { return blackRookShadow; }
        if pieceType == KNIGHT { return blackKnightShadow; }
        if pieceType == BISHOP { return blackBishopShadow; }
        if pieceType == QUEEN  { return blackQueenShadow; }
        if pieceType == KING   { return blackKingShadow; }
    }
    return null;
}

/// @brief Look up the 28×28 mini sprite for the captures display.
func getMiniPiece(pieceType: Integer, isWhite: Boolean) -> Pixels {
    if isWhite {
        if pieceType == PAWN   { return whitePawnMini; }
        if pieceType == ROOK   { return whiteRookMini; }
        if pieceType == KNIGHT { return whiteKnightMini; }
        if pieceType == BISHOP { return whiteBishopMini; }
        if pieceType == QUEEN  { return whiteQueenMini; }
        if pieceType == KING   { return whiteKingMini; }
    } else {
        if pieceType == PAWN   { return blackPawnMini; }
        if pieceType == ROOK   { return blackRookMini; }
        if pieceType == KNIGHT { return blackKnightMini; }
        if pieceType == BISHOP { return blackBishopMini; }
        if pieceType == QUEEN  { return blackQueenMini; }
        if pieceType == KING   { return blackKingMini; }
    }
    return null;
}

// ============================================================================
// Color helpers
// ============================================================================

func fillColor(white: Boolean) -> Integer {
    if white { return 0xF6E9CE; }
    return 0x2E2521;
}

func outlineColor(white: Boolean) -> Integer {
    if white { return 0x433127; }
    return 0xD7C5A1;
}

func accentColor(white: Boolean) -> Integer {
    if white { return 0xD8BD86; }
    return 0x69564A;
}

func detailColor(white: Boolean) -> Integer {
    if white { return 0xFFF9EA; }
    return 0xB79F85;
}

/// @brief Build a soft drop shadow from a sprite by tinting black + blur.
/// @details Tint preserves alpha so the shadow's silhouette matches the
///          sprite's; Blur(1) softens edges so the shadow doesn't look
///          like a hard offset duplicate.
func buildShadow(src: Pixels) -> Pixels {
    var shadow = src.Tint(0x000000);
    return shadow.Blur(1);
}

// ============================================================================
// Piece rendering — each returns a new Pixels buffer (SP × SP)
//
// Technique: draw outline layer first (larger shapes in outline color),
// then fill layer on top (slightly smaller in fill color). The layering
// creates a clean border effect. Detail marks (eyes, cross bars, slashes)
// use accent color or outline for visibility.
//
// All coordinates relative to center (CX, CY) of the sprite buffer.
// ============================================================================

/// @brief Render a pawn into a fresh 70×70 Pixels buffer.
/// @details Base ellipse + body trapezoid (overlapping ellipse + box) +
///          round head. Outline-then-fill layering creates the border.
func renderPawn(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base — wide ellipse
    px.DrawEllipse(CX, CY + 22, 20, 8, out);
    px.DrawEllipse(CX, CY + 22, 17, 6, fill);

    // Body — connecting trapezoid via overlapping shapes
    px.DrawBox(CX - 8, CY + 6, 16, 18, fill);
    px.DrawEllipse(CX, CY + 8, 12, 10, out);
    px.DrawEllipse(CX, CY + 8, 10, 8, fill);

    // Head — round
    px.DrawDisc(CX, CY - 6, 14, out);
    px.DrawDisc(CX, CY - 6, 12, fill);

    // Subtle shadow line on body
    px.DrawLine(CX - 6, CY + 16, CX + 6, CY + 16, acc);
    px.DrawLine(CX - 5, CY - 10, CX + 5, CY - 10, detail);

    return px;
}

/// @brief Render a rook (castle tower) into a fresh 70×70 Pixels buffer.
/// @details Base + body column + top platform + three crenellations
///          (the alternating box pattern at the top).
func renderRook(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base
    px.DrawEllipse(CX, CY + 22, 21, 8, out);
    px.DrawEllipse(CX, CY + 22, 18, 6, fill);

    // Body column
    px.DrawBox(CX - 12, CY - 4, 24, 28, out);
    px.DrawBox(CX - 10, CY - 2, 20, 24, fill);

    // Top platform
    px.DrawBox(CX - 15, CY - 14, 30, 12, out);
    px.DrawBox(CX - 13, CY - 12, 26, 10, fill);

    // Three crenellations (the castle battlements)
    px.DrawBox(CX - 14, CY - 26, 8, 14, out);
    px.DrawBox(CX - 13, CY - 25, 6, 12, fill);
    px.DrawBox(CX - 3,  CY - 26, 6, 14, out);
    px.DrawBox(CX - 2,  CY - 25, 4, 12, fill);
    px.DrawBox(CX + 6,  CY - 26, 8, 14, out);
    px.DrawBox(CX + 7,  CY - 25, 6, 12, fill);

    // Horizontal accent line across body
    px.DrawLine(CX - 9, CY + 8, CX + 9, CY + 8, acc);
    px.DrawLine(CX - 8, CY + 2, CX + 8, CY + 2, detail);

    return px;
}

/// @brief Render a knight (horse profile, facing right) into a 70×70 buffer.
/// @details The asymmetry — head offset right, ear pointing forward — is
///          what gives the knight its distinctive silhouette.
func renderKnight(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base
    px.DrawEllipse(CX, CY + 22, 20, 8, out);
    px.DrawEllipse(CX, CY + 22, 17, 6, fill);

    // Neck — angled block (left-of-center)
    px.DrawBox(CX - 10, CY, 16, 24, out);
    px.DrawBox(CX - 9, CY + 1, 14, 22, fill);

    // Head — large disc offset right for profile look
    px.DrawDisc(CX + 4, CY - 8, 16, out);
    px.DrawDisc(CX + 4, CY - 8, 14, fill);

    // Muzzle — extends to the right
    px.DrawEllipse(CX + 14, CY - 2, 8, 6, out);
    px.DrawEllipse(CX + 14, CY - 2, 6, 4, fill);

    // Ear — pointed triangle at top
    px.DrawTriangle(CX + 4, CY - 28, CX - 2, CY - 16, CX + 10, CY - 16, out);
    px.DrawTriangle(CX + 4, CY - 26, CX, CY - 17, CX + 8, CY - 17, fill);

    // Eye — contrasting dot
    px.DrawDisc(CX + 10, CY - 10, 3, out);

    // Nostril mark
    px.DrawDisc(CX + 19, CY - 2, 2, acc);
    px.DrawLine(CX - 1, CY + 8, CX + 8, CY + 2, detail);

    return px;
}

/// @brief Render a bishop into a 70×70 buffer.
/// @details Tapered tall ellipse + ball + pointed tip + the
///          characteristic diagonal slash mark.
func renderBishop(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base
    px.DrawEllipse(CX, CY + 22, 20, 8, out);
    px.DrawEllipse(CX, CY + 22, 17, 6, fill);

    // Tapered body — tall narrow ellipse
    px.DrawEllipse(CX, CY + 3, 12, 22, out);
    px.DrawEllipse(CX, CY + 3, 10, 20, fill);

    // Ball at top
    px.DrawDisc(CX, CY - 18, 10, out);
    px.DrawDisc(CX, CY - 18, 8, fill);

    // Pointed tip
    px.DrawDisc(CX, CY - 29, 4, out);
    px.DrawDisc(CX, CY - 29, 2, fill);

    // Diagonal slash — the bishop's characteristic mark
    px.DrawThickLine(CX - 6, CY - 14, CX + 6, CY - 22, 2, out);

    // Horizontal sash
    px.DrawLine(CX - 8, CY + 6, CX + 8, CY + 6, acc);
    px.DrawDisc(CX, CY - 18, 3, detail);

    return px;
}

/// @brief Render a queen with the classic 5-point crown.
/// @details Body ellipse + 5 discs in a curved arc for the crown +
///          connecting V lines between adjacent crown points.
func renderQueen(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base — slightly wider than other pieces
    px.DrawEllipse(CX, CY + 22, 22, 9, out);
    px.DrawEllipse(CX, CY + 22, 19, 7, fill);

    // Body — tall wide ellipse
    px.DrawEllipse(CX, CY, 14, 24, out);
    px.DrawEllipse(CX, CY, 12, 22, fill);

    // Crown — 5 points radiating outward
    // Center point
    px.DrawDisc(CX, CY - 26, 6, out);
    px.DrawDisc(CX, CY - 26, 4, fill);

    // Inner pair — angled outward
    px.DrawDisc(CX - 11, CY - 22, 6, out);
    px.DrawDisc(CX - 11, CY - 22, 4, fill);
    px.DrawDisc(CX + 11, CY - 22, 6, out);
    px.DrawDisc(CX + 11, CY - 22, 4, fill);

    // Outer pair — further out and lower
    px.DrawDisc(CX - 20, CY - 15, 6, out);
    px.DrawDisc(CX - 20, CY - 15, 4, fill);
    px.DrawDisc(CX + 20, CY - 15, 6, out);
    px.DrawDisc(CX + 20, CY - 15, 4, fill);

    // Crown connecting arcs (V shapes between points)
    px.DrawLine(CX - 20, CY - 15, CX - 6, CY - 10, acc);
    px.DrawLine(CX - 6, CY - 10, CX - 11, CY - 22, acc);
    px.DrawLine(CX - 11, CY - 22, CX, CY - 12, acc);
    px.DrawLine(CX, CY - 12, CX + 11, CY - 22, acc);
    px.DrawLine(CX + 11, CY - 22, CX + 6, CY - 10, acc);
    px.DrawLine(CX + 6, CY - 10, CX + 20, CY - 15, acc);
    px.DrawLine(CX - 9, CY + 5, CX + 9, CY + 5, detail);

    return px;
}

/// @brief Render a king (body + cross at the top).
/// @details Body ellipse + horizontal + vertical bars forming the cross.
func renderKing(white: Boolean) -> Pixels {
    var px = Pixels.New(SP, SP);
    var fill = fillColor(white);
    var out = outlineColor(white);
    var acc = accentColor(white);
    var detail = detailColor(white);

    // Base — wide
    px.DrawEllipse(CX, CY + 22, 22, 9, out);
    px.DrawEllipse(CX, CY + 22, 19, 7, fill);

    // Body — tall wide ellipse
    px.DrawEllipse(CX, CY, 14, 24, out);
    px.DrawEllipse(CX, CY, 12, 22, fill);

    // Cross — horizontal bar
    px.DrawBox(CX - 14, CY - 24, 28, 8, out);
    px.DrawBox(CX - 12, CY - 23, 24, 6, fill);

    // Cross — vertical bar
    px.DrawBox(CX - 4, CY - 34, 8, 22, out);
    px.DrawBox(CX - 3, CY - 33, 6, 20, fill);

    // Horizontal sash across body
    px.DrawLine(CX - 10, CY + 6, CX + 10, CY + 6, acc);

    // Small jewel at cross intersection
    px.DrawDisc(CX, CY - 20, 3, acc);
    px.DrawLine(CX - 9, CY + 4, CX + 9, CY + 4, detail);

    return px;
}
