module ai_thread_probe;

bind Viper.Terminal as Terminal;
bind Viper.Time;
bind Thread = Viper.Threads.Thread;
bind Monitor = Viper.Threads.Monitor;
bind "./core/config";
bind "./core/board";
bind "./core/moves";
bind "./engine/ai";

var workerLock: List[Integer] = [];
var workerThread: Thread? = null;
var workerBoard: Board? = null;
var workerDepth: Integer = DIFF_HARD;
var workerHasResult: Boolean = false;
var moveFrom: Integer = -1;
var moveTo: Integer = -1;
var moveCaptured: Integer = 0;
var moveEnPassant: Boolean = false;
var moveCastleKing: Boolean = false;
var moveCastleQueen: Boolean = false;
var movePromotion: Boolean = false;
var movePromotePiece: Integer = 0;

func fail(msg: String) {
    Terminal.Say("RESULT: fail " + msg);
}

func storeResult(m: Move) {
    moveFrom = m.from;
    moveTo = m.to;
    moveCaptured = m.captured;
    moveEnPassant = m.enPassant;
    moveCastleKing = m.castleKing;
    moveCastleQueen = m.castleQueen;
    movePromotion = m.promotion;
    movePromotePiece = m.promotePiece;
}

func loadResult() -> Move {
    return new Move(moveFrom, moveTo, moveCaptured,
                    moveEnPassant, moveCastleKing, moveCastleQueen,
                    movePromotion, movePromotePiece);
}

func aiWorker() {
    if workerBoard == null { return; }

    var ai = new ChessAI();
    ai.setDepth(workerDepth);
    var best = ai.findBestMove(workerBoard!);

    Monitor.Enter(workerLock);
    storeResult(best);
    workerHasResult = true;
    Monitor.Exit(workerLock);
}

func sameMove(a: Move, b: Move) -> Boolean {
    return a.from == b.from &&
           a.to == b.to &&
           a.captured == b.captured &&
           a.enPassant == b.enPassant &&
           a.castleKing == b.castleKing &&
           a.castleQueen == b.castleQueen &&
           a.promotion == b.promotion &&
           a.promotePiece == b.promotePiece;
}

func containsMove(moves: List[Move], target: Move) -> Boolean {
    for i in 0..moves.length() {
        if sameMove(moves.get(i), target) {
            return true;
        }
    }
    return false;
}

func main() {
    var board = new Board();
    var moveGen = new MoveGen();

    var ply = 0;
    while ply < 6 {
        var legal = moveGen.legalMoves(board);
        if legal.length() == 0 {
            Terminal.Say("RESULT: ok");
            return;
        }

        workerBoard = board.copy();
        workerHasResult = false;
        workerThread = Thread.StartSafe(&aiWorker, 0);
        while workerThread!.SafeIsAlive() {
            Viper.Time.SleepMs(1);
        }
        workerThread!.SafeJoin();
        if workerThread!.HasError {
            fail("worker error: " + workerThread!.Error);
            return;
        }
        workerThread = null;
        workerBoard = null;

        var best = new Move(-1, -1, 0, false, false, false, false, 0);
        Monitor.Enter(workerLock);
        if workerHasResult {
            best = loadResult();
        }
        workerHasResult = false;
        Monitor.Exit(workerLock);

        if best.from < 0 {
            fail("worker returned no move");
            return;
        }
        if !containsMove(legal, best) {
            fail("worker returned illegal move");
            return;
        }

        board.makeMove(best);
        ply = ply + 1;
    }

    Terminal.Say("RESULT: ok");
}
