//
// File: examples/games/xenoscape/render_probe.zia
// Purpose: Verifies key authored, fallback, profile, pause, and debrief surfaces.
// Key invariants:
//   - Authored key art and procedural fallback both fill the 1280x720 frame.
//   - Their sparse signatures differ, proving the feature toggle changes paths.
//   - Every title row and focus rectangle stays inside the authored menu panel.
//   - Large-text profile, pause, ability, and debrief surfaces render safely.
// Ownership/Lifetime:
//   - Probe owns one temporary Canvas, Palette, MenuSystem, and two screenshots.
// Links: menu.zia, assets/art/title-key-art.png, src/tests/CMakeLists.txt
//
//===----------------------------------------------------------------------===//

module render_probe;

bind Zanna.Graphics;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./hud";
bind "./menu";
bind "./palette";
bind "./profile_flow";
bind "./tutorials";

/// @brief Emit one deterministic render-probe failure.
///
/// @param message Concise violated presentation invariant.
/// @return Nothing. Omits the success marker expected by CTest.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Calculate a sparse deterministic RGB signature for one frame.
///
/// Sampling a fixed 16-by-9 grid is cheap while still distinguishing authored
/// key art from the procedural parallax fallback. Alpha/order are irrelevant to
/// the invariant; the bounded modulo prevents signed integer overflow.
///
/// @param pixels Borrowed 1280x720 screenshot buffer.
/// @return Nonnegative signature below 1,000,003.
func sparseFrameSignature(pixels: Pixels) -> Integer {
    if pixels == null { return -1; }
    var signature = 0;
    var row = 0;
    while row < 9 {
        var col = 0;
        while col < 16 {
            var x = col * (SCREEN_W - 1) / 15;
            var y = row * (SCREEN_H - 1) / 8;
            signature = (signature * 131 + pixels.Get(x, y)) % 1000003;
            if signature < 0 { signature = 0 - signature; }
            col = col + 1;
        }
        row = row + 1;
    }
    return signature;
}

/// @brief Verify the title rows fit the authored panel at one text scale.
///
/// The built-in font is 8x8 and LOAD GAME is the widest live title label.
/// Checking both normal and accessibility scales prevents status text or row
/// offsets from escaping the panel without relying on a fragile golden image.
///
/// @param scale Integer bitmap-font scale used for the bounds calculation.
/// @return True when text, selection arrow, and focus rectangle all fit.
func titleLayoutFits(scale: Integer) -> Boolean {
    var panelRight = TITLE_PANEL_X + TITLE_PANEL_W;
    var panelBottom = TITLE_PANEL_Y + TITLE_PANEL_H;
    var lastRowY = TITLE_MENU_Y + TITLE_MENU_ROW_STEP * 6;
    var textRight = TITLE_MENU_X + Canvas.TextWidth("LOAD GAME") * scale;
    var textBottom = lastRowY + Canvas.TextHeight() * scale;
    var arrowLeft = TITLE_MENU_X - (Canvas.TextWidth(">") * scale + 8);
    var highlightRight = TITLE_MENU_HIGHLIGHT_X + TITLE_MENU_HIGHLIGHT_W;
    var highlightBottom = lastRowY + 28;
    return arrowLeft >= TITLE_PANEL_X and
           TITLE_MENU_Y - 4 >= TITLE_PANEL_Y and
           textRight <= panelRight and textBottom <= panelBottom and
           highlightRight <= panelRight and highlightBottom <= panelBottom;
}

/// @brief Render and compare authored and procedural title paths.
///
/// @return Nothing. Prints `RESULT: ok` only after both screenshots are valid.
func main() {
    if titleLayoutFits(3) == false or titleLayoutFits(4) == false {
        fail("title menu exceeds authored panel bounds"); return;
    }
    var canvas = Canvas.New("XENOSCAPE Render Probe", SCREEN_W, SCREEN_H);
    canvas.SetFps(60);
    if canvas.BeginFrame() == 0 {
        fail("canvas unavailable"); return;
    }
    var pal = new Palette();
    var menu = new MenuSystem(pal);
    if menu.hasAuthoredTitleArt() == false {
        canvas.Close();
        fail("mandatory title key art unavailable"); return;
    }

    menu.setAccessibility(100, false, false, true);
    menu.setAuthoredTitleArtEnabled(true);
    menu.drawTitle(canvas);
    var authored = canvas.Screenshot();
    if authored == null or authored.get_Width() != SCREEN_W or
       authored.get_Height() != SCREEN_H {
        canvas.Close();
        fail("authored title screenshot dimensions"); return;
    }
    var authoredSignature = sparseFrameSignature(authored);

    menu.setAuthoredTitleArtEnabled(false);
    menu.drawTitle(canvas);
    var fallback = canvas.Screenshot();
    if fallback == null or fallback.get_Width() != SCREEN_W or
       fallback.get_Height() != SCREEN_H {
        canvas.Close();
        fail("fallback title screenshot dimensions"); return;
    }
    var fallbackSignature = sparseFrameSignature(fallback);
    if authoredSignature <= 0 or fallbackSignature <= 0 or
       authoredSignature == fallbackSignature {
        canvas.Close();
        fail("authored/fallback title signatures"); return;
    }

    // Render the highest-risk text surfaces at the largest supported scale.
    // These calls also exercise the `(scale, color)` TextScaled contract that
    // previously made several labels explode beyond their panels.
    var profiles = new ProfileFlow();
    profiles.setAccessibility(150, true, true);
    profiles.refreshSlots(
        "Area 2 | CP A2 | 18m04s | Standard | Salvage 14",
        "Empty", "Area 8 | Entrance | 2h11m | Explorer | Salvage 77",
        true, false, true);
    profiles.beginLoad();
    profiles.draw(canvas, pal);
    var profileFrame = canvas.Screenshot();
    if profileFrame == null or profileFrame.get_Width() != SCREEN_W or
       profileFrame.get_Height() != SCREEN_H {
        canvas.Close(); fail("large-text profile frame"); return;
    }

    menu.setAccessibility(150, true, true, true);
    menu.drawEnhancedPause(canvas, pal, 8, 7865000, 77, 7, 9, 14320, 6);
    var pauseFrame = canvas.Screenshot();
    if pauseFrame == null or pauseFrame.get_Width() != SCREEN_W or
       pauseFrame.get_Height() != SCREEN_H {
        canvas.Close(); fail("enhanced pause frame"); return;
    }
    menu.drawAbilityScreen(canvas, pal, 63);
    var abilityFrame = canvas.Screenshot();
    if abilityFrame == null or abilityFrame.get_Width() != SCREEN_W or
       abilityFrame.get_Height() != SCREEN_H {
        canvas.Close(); fail("ability frame"); return;
    }
    menu.drawEnhancedLevelComplete(canvas, pal, 8, 546321, 2, 4, "A",
                                   873, 24, 31, 7, 14320, 900);
    var debriefFrame = canvas.Screenshot();
    if debriefFrame == null or debriefFrame.get_Width() != SCREEN_W or
       debriefFrame.get_Height() != SCREEN_H {
        canvas.Close(); fail("regional debrief frame"); return;
    }

    var hud = new HUD(pal);
    hud.setAccessibility(150, true, true);
    hud.update(9999999, 9999, 16);
    hud.drawHUD(canvas, 9, 12, 9999999, 9999, 8, 1200, 1, 2200);
    var tutorial = new TutorialSystem();
    tutorial.setAccessibility(150, true, true);
    tutorial.replay(TUTORIAL_INTERACT);
    tutorial.update(300);
    tutorial.draw(canvas, pal);
    var guidanceFrame = canvas.Screenshot();
    if guidanceFrame == null or guidanceFrame.get_Width() != SCREEN_W or
       guidanceFrame.get_Height() != SCREEN_H {
        canvas.Close(); fail("large-text HUD or tutorial frame"); return;
    }
    canvas.Close();
    Terminal.Say("RESULT: ok");
}
