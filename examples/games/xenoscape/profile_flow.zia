//
// File: examples/games/xenoscape/profile_flow.zia
// Purpose: Implements release-quality New Game and Load Game profile menus.
// Key invariants:
//   - New Game cannot start without an explicit slot and difficulty selection.
//   - Occupied-slot overwrite and deletion each require a separate confirmation.
// Ownership/Lifetime:
//   - Game owns one ProfileFlow; cached slot summaries are refreshed on entry.
// Links: game.zia, save.zia, difficulty.zia, menu.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module profile_flow;

bind Viper.Graphics;
bind Viper.Input;
bind Viper.Text.Fmt;
bind "./accessibility";
bind "./config";
bind "./difficulty";
bind "./palette";

final PROFILE_MODE_NEW = 0;
final PROFILE_MODE_LOAD = 1;

final PROFILE_STAGE_SLOTS = 0;
final PROFILE_STAGE_DIFFICULTY = 1;
final PROFILE_STAGE_OVERWRITE = 2;
final PROFILE_STAGE_DELETE = 3;

final PROFILE_ACTION_NONE = 0;
final PROFILE_ACTION_BACK = 1;
final PROFILE_ACTION_CREATE = 2;
final PROFILE_ACTION_LOAD = 3;
final PROFILE_ACTION_DELETE = 4;
final PROFILE_ACTION_EMPTY = 5;

/// @brief Stateful controller and renderer for expedition profile selection.
class ProfileFlow {
    hide Integer mode;
    hide Integer stage;
    hide Integer selectedSlot;
    hide Integer selectedDifficulty;
    hide Integer confirmationChoice;
    hide List[String] slotSummaries;
    hide List[Integer] slotUsed;
    hide Integer accessibilityUiScale;
    hide Boolean accessibilityHighContrast;
    hide Boolean accessibilityLargeText;

    /// @brief Construct an empty New Game flow with deterministic defaults.
    ///
    /// @return Nothing. Allocates fixed three-entry summary and occupancy caches.
    expose func init() {
        mode = PROFILE_MODE_NEW;
        stage = PROFILE_STAGE_SLOTS;
        selectedSlot = 0;
        selectedDifficulty = DIFFICULTY_STANDARD;
        confirmationChoice = 0;
        slotSummaries = ["Empty", "Empty", "Empty"];
        slotUsed = [0, 0, 0];
        accessibilityUiScale = 100;
        accessibilityHighContrast = false;
        accessibilityLargeText = false;
    }

    /// @brief Apply global scale, contrast, and large-text preferences live.
    ///
    /// @param uiScale Advertised 100, 125, or 150 percent UI scale.
    /// @param highContrast True for opaque slot and modal backgrounds.
    /// @param largeText True for one bounded heading/prompt scale step.
    /// @return Nothing. Invalid scale values normalize to 100 percent.
    expose func setAccessibility(uiScale: Integer, highContrast: Boolean,
                                 largeText: Boolean) {
        accessibilityUiScale = uiScale;
        if accessibilityUiScale != 100 and accessibilityUiScale != 125 and
           accessibilityUiScale != 150 { accessibilityUiScale = 100; }
        accessibilityHighContrast = highContrast;
        accessibilityLargeText = largeText;
    }

    /// @brief Resolve a bounded profile-screen text scale.
    ///
    /// @param baseScale Positive authored bitmap-font scale.
    /// @param maximum Maximum layout-safe scale for the current element.
    /// @return Accessible scale clamped to `maximum` and at least one.
    hide func profileTextScale(baseScale: Integer,
                               maximum: Integer) -> Integer {
        var scale = accessibleTextScale(
            baseScale, accessibilityUiScale, accessibilityLargeText);
        if scale < 1 { scale = 1; }
        if scale > maximum { scale = maximum; }
        return scale;
    }

    /// @brief Enter the explicit slot-then-difficulty New Game workflow.
    ///
    /// @return Nothing. Resets focus to slot one and Standard difficulty.
    expose func beginNew() {
        mode = PROFILE_MODE_NEW;
        stage = PROFILE_STAGE_SLOTS;
        selectedSlot = 0;
        selectedDifficulty = DIFFICULTY_STANDARD;
        confirmationChoice = 0;
    }

    /// @brief Enter the existing-expedition Load Game workflow.
    ///
    /// @return Nothing. Resets focus to slot one and clears confirmation state.
    expose func beginLoad() {
        mode = PROFILE_MODE_LOAD;
        stage = PROFILE_STAGE_SLOTS;
        selectedSlot = 0;
        confirmationChoice = 0;
    }

    /// @brief Replace the three cached slot cards without per-frame allocation.
    ///
    /// Occupancy values are normalized to zero or one. Game calls this on screen
    /// entry and after deletion so input and rendering observe the same snapshot.
    ///
    /// @param summary0 Release summary for slot zero.
    /// @param summary1 Release summary for slot one.
    /// @param summary2 Release summary for slot two.
    /// @param used0 Whether slot zero is populated.
    /// @param used1 Whether slot one is populated.
    /// @param used2 Whether slot two is populated.
    /// @return Nothing. Mutates only the profile menu's cached presentation data.
    expose func refreshSlots(summary0: String, summary1: String,
                             summary2: String, used0: Boolean,
                             used1: Boolean, used2: Boolean) {
        slotSummaries.set(0, summary0);
        slotSummaries.set(1, summary1);
        slotSummaries.set(2, summary2);
        slotUsed.set(0, boolInt(used0));
        slotUsed.set(1, boolInt(used1));
        slotUsed.set(2, boolInt(used2));
    }

    /// @brief Consume one frame of keyboard/gamepad profile navigation.
    ///
    /// Slot selection uses up/down, difficulty accepts either axis, and every
    /// destructive operation passes through a Cancel/Confirm stage. The interact
    /// action opens deletion so the same semantic binding works on keyboard and
    /// gamepad.
    ///
    /// @return One `PROFILE_ACTION_*` result for Game, or NONE while browsing.
    expose func update() -> Integer {
        if stage == PROFILE_STAGE_SLOTS { return updateSlots(); }
        if stage == PROFILE_STAGE_DIFFICULTY { return updateDifficulty(); }
        return updateConfirmation();
    }

    /// @brief Draw the complete profile flow over a self-contained backdrop.
    ///
    /// Slot cards always remain visible behind difficulty and confirmation panels,
    /// preserving context. Action hints query live bindings instead of hard-coding
    /// keys that can disagree with the active input source.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed release palette.
    /// @return Nothing. Does not mutate campaign or persistent data.
    expose func draw(canvas: Canvas, pal: Palette) {
        canvas.GradientV(0, 0, SCREEN_W, SCREEN_H,
                         Color.RGB(5, 9, 22), Color.RGB(18, 25, 48));
        if accessibilityHighContrast {
            canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 120);
        }
        drawStars(canvas, pal);

        var heading = "NEW EXPEDITION";
        var subheading = "Select a profile slot";
        if mode == PROFILE_MODE_LOAD {
            heading = "EXPEDITION ARCHIVE";
            subheading = "Resume a saved descent";
        }
        canvas.TextCenteredScaled(54, heading, pal.white,
                                  profileTextScale(4, 5));
        canvas.TextCenteredScaled(102, subheading, pal.hudGray,
                                  profileTextScale(2, 3));

        var i = 0;
        while i < 3 {
            drawSlotCard(canvas, pal, i);
            i = i + 1;
        }

        if stage == PROFILE_STAGE_DIFFICULTY {
            drawDifficultyPanel(canvas, pal);
        }
        if stage == PROFILE_STAGE_OVERWRITE or stage == PROFILE_STAGE_DELETE {
            drawConfirmationPanel(canvas, pal);
        }

        var confirmBind = Action.BindingsStr(ACT_CONFIRM);
        var backBind = Action.BindingsStr(ACT_BACK);
        var interactBind = Action.BindingsStr(ACT_INTERACT);
        canvas.TextCenteredScaled(
            SCREEN_H - 46,
            "CONFIRM  " + confirmBind + "    BACK  " + backBind +
            "    DELETE  " + interactBind,
            pal.hudGray, profileTextScale(1, 2));
    }

    /// @brief Read the zero-based slot currently selected by the user.
    ///
    /// @return Integer in 0..2.
    expose func getSelectedSlot() -> Integer { return selectedSlot; }

    /// @brief Read the difficulty chosen for a pending New Game.
    ///
    /// @return One valid `DIFFICULTY_*` id.
    expose func getSelectedDifficulty() -> Integer { return selectedDifficulty; }

    /// @brief Report whether this flow is creating instead of loading a profile.
    ///
    /// @return True in New Game mode; false in Load Game mode.
    expose func isNewMode() -> Boolean { return mode == PROFILE_MODE_NEW; }

    /// @brief Convert a Boolean occupancy value into the menu's integer cache.
    ///
    /// @param value Boolean to normalize.
    /// @return One for true and zero for false.
    hide func boolInt(value: Boolean) -> Integer {
        if value { return 1; }
        return 0;
    }

    /// @brief Handle slot focus, load/create activation, and delete entry.
    ///
    /// @return One `PROFILE_ACTION_*` value for this frame.
    hide func updateSlots() -> Integer {
        if Action.Pressed(ACT_BACK) { return PROFILE_ACTION_BACK; }
        if Action.Pressed(ACT_UP) {
            selectedSlot = selectedSlot - 1;
            if selectedSlot < 0 { selectedSlot = 2; }
        }
        if Action.Pressed(ACT_DOWN) {
            selectedSlot = selectedSlot + 1;
            if selectedSlot > 2 { selectedSlot = 0; }
        }
        if Action.Pressed(ACT_INTERACT) and slotUsed.get(selectedSlot) == 1 {
            stage = PROFILE_STAGE_DELETE;
            confirmationChoice = 0;
            return PROFILE_ACTION_NONE;
        }
        if Action.Pressed(ACT_CONFIRM) {
            if mode == PROFILE_MODE_LOAD {
                if slotUsed.get(selectedSlot) == 0 { return PROFILE_ACTION_EMPTY; }
                return PROFILE_ACTION_LOAD;
            }
            if slotUsed.get(selectedSlot) == 1 {
                stage = PROFILE_STAGE_OVERWRITE;
                confirmationChoice = 0;
            } else {
                stage = PROFILE_STAGE_DIFFICULTY;
            }
        }
        return PROFILE_ACTION_NONE;
    }

    /// @brief Handle difficulty selection for a new expedition.
    ///
    /// @return CREATE on confirmation, BACK/NONE semantics otherwise.
    hide func updateDifficulty() -> Integer {
        if Action.Pressed(ACT_BACK) {
            stage = PROFILE_STAGE_SLOTS;
            return PROFILE_ACTION_NONE;
        }
        if Action.Pressed(ACT_LEFT) or Action.Pressed(ACT_UP) {
            selectedDifficulty = selectedDifficulty - 1;
            if selectedDifficulty < 0 { selectedDifficulty = DIFFICULTY_VETERAN; }
        }
        if Action.Pressed(ACT_RIGHT) or Action.Pressed(ACT_DOWN) {
            selectedDifficulty = selectedDifficulty + 1;
            if selectedDifficulty >= DIFFICULTY_COUNT {
                selectedDifficulty = DIFFICULTY_EXPLORER;
            }
        }
        if Action.Pressed(ACT_CONFIRM) { return PROFILE_ACTION_CREATE; }
        return PROFILE_ACTION_NONE;
    }

    /// @brief Handle Cancel/Confirm choice for overwrite or deletion.
    ///
    /// @return DELETE after confirmed deletion; overwrite confirmation advances
    ///         to difficulty selection and otherwise returns NONE.
    hide func updateConfirmation() -> Integer {
        if Action.Pressed(ACT_BACK) {
            stage = PROFILE_STAGE_SLOTS;
            confirmationChoice = 0;
            return PROFILE_ACTION_NONE;
        }
        if Action.Pressed(ACT_LEFT) or Action.Pressed(ACT_RIGHT) or
           Action.Pressed(ACT_UP) or Action.Pressed(ACT_DOWN) {
            confirmationChoice = 1 - confirmationChoice;
        }
        if Action.Pressed(ACT_CONFIRM) {
            if confirmationChoice == 0 {
                stage = PROFILE_STAGE_SLOTS;
                return PROFILE_ACTION_NONE;
            }
            if stage == PROFILE_STAGE_DELETE {
                stage = PROFILE_STAGE_SLOTS;
                confirmationChoice = 0;
                return PROFILE_ACTION_DELETE;
            }
            stage = PROFILE_STAGE_DIFFICULTY;
            confirmationChoice = 0;
        }
        return PROFILE_ACTION_NONE;
    }

    /// @brief Draw one cached slot card and its occupancy treatment.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed palette.
    /// @param slot Zero-based slot id in 0..2.
    /// @return Nothing. Draws a selected outline only during slot browsing.
    hide func drawSlotCard(canvas: Canvas, pal: Palette, slot: Integer) {
        var x = 190;
        var y = 145 + slot * 130;
        var selected = stage == PROFILE_STAGE_SLOTS and selectedSlot == slot;
        var border = Color.RGB(65, 82, 120);
        if selected { border = pal.crystalBlue; }
        var cardAlpha = 225;
        if accessibilityHighContrast { cardAlpha = 255; }
        canvas.BoxAlpha(x, y, 900, 104, Color.RGB(12, 18, 36), cardAlpha);
        canvas.Frame(x, y, 900, 104, border);
        if selected {
            canvas.Frame(x - 4, y - 4, 908, 112, pal.menuHighlight);
            canvas.TextScaled(x - 34, y + 34, ">", pal.titleOrange, 3);
        }
        canvas.TextScaled(x + 24, y + 15, "SLOT " + Int(slot + 1),
                          pal.white, 2);
        var status = "AVAILABLE";
        var statusColor = pal.hudGreen;
        if slotUsed.get(slot) == 1 {
            status = "ACTIVE EXPEDITION";
            statusColor = pal.crystalBlue;
        }
        canvas.Text(x + 690, y + 20, status, statusColor);
        canvas.TextScaled(x + 24, y + 57, slotSummaries.get(slot),
                          pal.hudGray, 1);
    }

    /// @brief Draw the Explorer/Standard/Veteran decision panel.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed palette.
    /// @return Nothing. Shows exact combat and salvage consequences.
    hide func drawDifficultyPanel(canvas: Canvas, pal: Palette) {
        var x = 250;
        var y = 170;
        var w = 780;
        var h = 390;
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 170);
        canvas.Box(x, y, w, h, Color.RGB(14, 20, 38));
        canvas.Frame(x, y, w, h, pal.crystalBlue);
        canvas.TextCenteredScaled(y + 26, "SELECT DIFFICULTY", pal.white,
                                  profileTextScale(3, 4));
        canvas.TextCenteredScaled(y + 70,
                                  difficultyName(selectedDifficulty),
                                  pal.titleYellow, profileTextScale(3, 4));

        var incoming = difficultyIncomingPercent(selectedDifficulty);
        var enemyHp = difficultyEnemyHpPercent(selectedDifficulty);
        var aggression = difficultyAggressionPercent(selectedDifficulty);
        var gemLoss = difficultyGemLossPercent(selectedDifficulty);
        canvas.TextScaled(x + 90, y + 140,
                          "Incoming damage        " + Int(incoming) + "%",
                          pal.menuText, 2);
        canvas.TextScaled(x + 90, y + 185,
                          "Enemy integrity        " + Int(enemyHp) + "%",
                          pal.menuText, 2);
        canvas.TextScaled(x + 90, y + 230,
                          "Enemy aggression       " + Int(aggression) + "%",
                          pal.menuText, 2);
        canvas.TextScaled(x + 90, y + 275,
                          "Unbanked salvage loss  " + Int(gemLoss) + "%",
                          pal.menuText, 2);
        canvas.TextCenteredScaled(y + 340,
                                  Action.BindingsStr(ACT_LEFT) + " / " +
                                  Action.BindingsStr(ACT_RIGHT) +
                                  " compare   " +
                                  Action.BindingsStr(ACT_CONFIRM) + " deploy",
                                  pal.hudGray, 1);
    }

    /// @brief Draw an explicit destructive-action confirmation modal.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed palette.
    /// @return Nothing. Presents Cancel as the safe default focus.
    hide func drawConfirmationPanel(canvas: Canvas, pal: Palette) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 190);
        var x = 330;
        var y = 235;
        var w = 620;
        var h = 250;
        canvas.Box(x, y, w, h, Color.RGB(24, 18, 30));
        canvas.Frame(x, y, w, h, pal.hudRed);
        var title = "OVERWRITE SLOT " + Int(selectedSlot + 1) + "?";
        var detail = "Existing expedition progress will be replaced.";
        if stage == PROFILE_STAGE_DELETE {
            title = "DELETE SLOT " + Int(selectedSlot + 1) + "?";
            detail = "This expedition cannot be restored from the game menu.";
        }
        canvas.TextCenteredScaled(y + 30, title, pal.white, 3);
        canvas.TextCenteredScaled(y + 90, detail, pal.hudGray, 1);

        var cancelColor = pal.white;
        var confirmColor = pal.hudGray;
        if confirmationChoice == 1 {
            cancelColor = pal.hudGray;
            confirmColor = pal.hudRed;
        }
        canvas.TextScaled(x + 105, y + 160, "CANCEL", cancelColor, 2);
        canvas.TextScaled(x + 385, y + 160, "CONFIRM", confirmColor, 2);
    }

    /// @brief Draw a deterministic low-cost star field behind profile cards.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed palette used for the foreground accent.
    /// @return Nothing. Performs a bounded 48-iteration draw loop.
    hide func drawStars(canvas: Canvas, pal: Palette) {
        var i = 0;
        while i < 48 {
            var x = (i * 173 + 41) % SCREEN_W;
            var y = (i * 97 + 29) % SCREEN_H;
            var color = Color.RGB(70, 88, 125);
            if i % 11 == 0 { color = pal.crystalBlue; }
            canvas.Box(x, y, 2, 2, color);
            i = i + 1;
        }
    }
}
