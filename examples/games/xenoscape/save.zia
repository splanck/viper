//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/save.zia
// Purpose: Persists and migrates three Xenoscape expedition-slot snapshots.
// Key invariants:
//   - Older schemas migrate to deterministic development-preview defaults.
//   - Every populated schema-v4 slot carries a checksum over its full snapshot.
//   - Cache and SaveData keys are updated together before a single flush result.
// Ownership/Lifetime:
//   - Game owns one SaveManager; it owns one runtime SaveData store and caches.
// Links: game.zia, world_state.zia, progression_probe.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — HOW A PLATFORMER REMEMBERS YOU
// -----------------------------------------
// Every platformer past the 80s has some form of save.  The
// design question is: *how much state to save?*  You have
// extremes:
//
//   * **Checkpoint games** — save only which checkpoint the
//     player last touched.  Everything else resets.  Cheap,
//     simple, works for linear levels.
//
//   * **Save-anywhere games** — snapshot every enemy, every
//     pickup, every door state.  Flexible but the save file
//     can be huge and the code must serialise every entity.
//
// Xenoscape uses the sweet spot most metroidvanias adopt: save
// *slot-wide progress* (level index, abilities unlocked, max HP,
// gems collected, time played).  Enemies and pickups reset when
// you re-enter a room, but your permanent progress survives.
//
// This file handles that slot-wide progress.  The storage
// backend is `Zanna.IO.SaveData`, a simple key-value persistent
// store the Zanna runtime provides — no need to manage files,
// schemas, or serialisers by hand.
//
// WHY KEY-VALUE INSTEAD OF A BLOB?
// --------------------------------
// We could stuff all five fields into one struct and serialise
// that.  Instead we store each as its own `SaveData` key
// (`s0lv`, `s0ab`, `s0hp`, ...).  Benefits:
//
//   * Forward-compat: adding a new field (e.g. `s0dl` for
//     "difficulty level") doesn't break old saves — old keys
//     are unchanged; the new key is missing and
//     `GetInt(..., default)` returns its default.
//
//   * Backward-compat: removing a field just orphans a key;
//     `SaveData` tolerates unknown keys.
//
//   * Additive migration: the explicit schema and checksum let
//     old key sets move forward while rejecting partial writes.
//
// Per-field writes *are* chattier on disk, but `SaveData.Save()`
// batches them, so the overhead is cosmetic.
//
// WHERE THIS FITS
// ---------------
//     menu.zia   ──►  title screen lists slots (via `getSlotSummary`);
//                     "new game" creates a fresh slot, "continue"
//                     loads one.
//
//     game.zia   ──►  holds a SaveManager, calls `saveSlot(...)`
//                     whenever the player touches a save station.
//
//     Zanna.IO.SaveData  (runtime key-value store)
//
// =============================================================================

module save;

bind Zanna.IO;
bind Zanna.Text.Fmt;
bind Zanna.Time.DateTime as DateTime;
bind "./config";

/// @brief Maximum concurrent save slots.  Three is a classic
///        number (fits most menu layouts on a small screen).
final MAX_SAVE_SLOTS = 3;
final XENOSCAPE_SAVE_SCHEMA = 4;
final XENOSCAPE_BASELINE_ABILITY_MASK = 3;
final XENOSCAPE_CHECKSUM_MODULUS = 2147483629;

//=============================================================================
// SAVE MANAGER
//=============================================================================

/// @brief Owns the SaveData store and a per-slot cache of the
///        last-known values.  Zero-indexed: slots 0..MAX_SAVE_SLOTS-1.
///
/// The cache lets read queries (`getSlotLevel`, `isSlotUsed`,
/// ...) avoid round-trips through SaveData; writes always
/// update both the cache and the store, then `Save()` to flush.
class SaveManager {
    /// @brief Stub — use `initSave()` for the real setup.  The
    ///        two-phase init lets Game allocate the field with
    ///        `= new SaveManager()` then wire it up later.
    expose func init() {}
    hide SaveData store;
    hide Boolean recoveredCorrupt;

    // Per-slot state, parallel lists indexed by slot 0..2.
    hide List[Integer] slotLevel;      // farthest biome reached
    hide List[Integer] slotAbilities;  // ability-bitset (see abilities.zia)
    hide List[Integer] slotMaxHp;      // max HP unlocked
    hide List[Integer] slotGems;       // currency collected
    hide List[Integer] slotTime;       // play-time in seconds
    hide List[Integer] slotUsed;       // 0 = empty, 1 = populated
    hide List[Integer] slotBosses;     // defeated boss/level mask
    hide List[Integer] slotLore;       // collected lore mask
    hide List[Integer] slotBestiary;   // unlocked bestiary mask
    hide List[Integer] slotComplete;   // completed-level mask
    hide List[Integer] slotDeaths;     // run death count
    hide List[Integer] slotSchema;     // serialized schema version
    hide List[Integer] slotKeys;       // permanent region keycards
    hide List[Integer] slotSwitches;   // persistent switch channels
    hide List[Integer] slotDoors;      // permanently opened keyed doors
    hide List[Integer] slotShrines;    // consumed ability shrines
    hide List[Integer] slotTeleporters;// discovered fast-travel pads
    hide List[Integer] slotRooms;      // flattened slot*10 + region room masks
    hide List[Integer] slotUpgrades;   // packed four-branch workbench tiers
    hide List[Integer] slotDifficulty; // active difficulty profile
    hide List[Integer] slotCheckpointLevel; // latest activated checkpoint region
    hide List[Integer] slotCheckpointX;     // checkpoint world X in pixels
    hide List[Integer] slotCheckpointY;     // checkpoint world Y in pixels
    hide List[Integer] slotTutorials;       // acknowledged contextual tutorials
    hide List[Integer] slotRankPacks;       // ten base-six best-rank digits
    hide List[Integer] slotNgPlus;          // active New Game+ mode flag
    hide List[Integer] slotBestTimes;       // flattened slot*10 + region times
    hide List[Integer] slotLastWrite;       // Unix milliseconds, zero for legacy
    hide List[Integer] slotChecksums;       // schema-v4 full-slot integrity hash
    hide Integer lastObservedWrite;         // monotonic within this manager

    /// @brief Open the "xenoscape_saves" store and load every
    ///        slot into the cache.
    expose func initSave() {
        initSaveWithName("xenoscape_saves");
    }

    /// @brief Open a named SaveData store.  Production uses
    ///        `xenoscape_saves`; probes pass an isolated name.
    expose func initSaveWithName(name: String) {
        store = SaveData.New(name);
        recoveredCorrupt = false;
        slotLevel = [0, 0, 0];
        slotAbilities = [XENOSCAPE_BASELINE_ABILITY_MASK,
                         XENOSCAPE_BASELINE_ABILITY_MASK,
                         XENOSCAPE_BASELINE_ABILITY_MASK];
        slotMaxHp = [5, 5, 5];
        slotGems = [0, 0, 0];
        slotTime = [0, 0, 0];
        slotUsed = [0, 0, 0];
        slotBosses = [0, 0, 0];
        slotLore = [0, 0, 0];
        slotBestiary = [0, 0, 0];
        slotComplete = [0, 0, 0];
        slotDeaths = [0, 0, 0];
        slotSchema = [XENOSCAPE_SAVE_SCHEMA, XENOSCAPE_SAVE_SCHEMA,
                      XENOSCAPE_SAVE_SCHEMA];
        slotKeys = [0, 0, 0];
        slotSwitches = [0, 0, 0];
        slotDoors = [0, 0, 0];
        slotShrines = [0, 0, 0];
        slotTeleporters = [0, 0, 0];
        slotRooms = [];
        slotUpgrades = [0, 0, 0];
        slotDifficulty = [1, 1, 1];
        slotCheckpointLevel = [0, 0, 0];
        slotCheckpointX = [0, 0, 0];
        slotCheckpointY = [0, 0, 0];
        slotTutorials = [0, 0, 0];
        slotRankPacks = [0, 0, 0];
        slotNgPlus = [0, 0, 0];
        slotBestTimes = [];
        slotLastWrite = [0, 0, 0];
        slotChecksums = [0, 0, 0];
        lastObservedWrite = 0;
        var roomFill = 0;
        while roomFill < MAX_SAVE_SLOTS * LEVEL_COUNT {
            slotRooms.add(0);
            slotBestTimes.add(0);
            roomFill = roomFill + 1;
        }
        loadAll();
    }

    /// @brief Pull every slot's keys from SaveData into the cache.
    ///
    /// A slot counts as "used" if either its `lv` or `ab` key has
    /// a non-default value — that way a brand-new install with
    /// no keys at all reads as three empty slots, and the first
    /// save promotes the slot to "used".
    hide func loadAll() {
        if store.Load() == false {
            backupCorruptStore();
            store.Clear();
            store.Save();
            recoveredCorrupt = true;
            return;
        }
        var anyMigrated = false;
        var i = 0;
        while i < MAX_SAVE_SLOTS {
            var lv = store.GetInt("s" + Int(i) + "lv", 0);
            var ab = store.GetInt("s" + Int(i) + "ab", 0);
            var hp = store.GetInt("s" + Int(i) + "hp", 5);
            var gm = store.GetInt("s" + Int(i) + "gm", 0);
            var tm = store.GetInt("s" + Int(i) + "tm", 0);
            var bs = store.GetInt("s" + Int(i) + "bs", 0);
            var lr = store.GetInt("s" + Int(i) + "lr", 0);
            var be = store.GetInt("s" + Int(i) + "be", 0);
            var cp = store.GetInt("s" + Int(i) + "cp", 0);
            var de = store.GetInt("s" + Int(i) + "de", 0);
            var sv = store.GetInt("s" + Int(i) + "sv", 1);
            var ky = store.GetInt("s" + Int(i) + "ky", 0);
            var sw = store.GetInt("s" + Int(i) + "sw", 0);
            var dr = store.GetInt("s" + Int(i) + "dr", 0);
            var sh = store.GetInt("s" + Int(i) + "sh", 0);
            var tp = store.GetInt("s" + Int(i) + "tp", 0);
            var up = store.GetInt("s" + Int(i) + "up", 0);
            var df = store.GetInt("s" + Int(i) + "df", 1);
            var cl = store.GetInt("s" + Int(i) + "cl", 0);
            var cx = store.GetInt("s" + Int(i) + "cx", 0);
            var cy = store.GetInt("s" + Int(i) + "cy", 0);
            var tu = store.GetInt("s" + Int(i) + "tu", 0);
            var rk = store.GetInt("s" + Int(i) + "rk", 0);
            var ng = store.GetInt("s" + Int(i) + "ng", 0);
            var wr = store.GetInt("s" + Int(i) + "wr", 0);
            var storedChecksum = store.GetInt("s" + Int(i) + "ck", 0);
            var used = ab > 0 or lv > 0;
            var valid = slotCoreIsValid(lv, ab, hp, gm, tm, sv,
                                        bs, lr, be, cp, de, cl, cx, cy);
            if used and valid and sv >= 4 {
                if storedChecksum != checksumStoredSlot(i) { valid = false; }
            }
            if used and valid == false {
                if recoveredCorrupt == false { backupCorruptStore(); }
                recoveredCorrupt = true;
                store.SetInt("s" + Int(i) + "lv", 0);
                store.SetInt("s" + Int(i) + "ab", 0);
                store.SetInt("s" + Int(i) + "sv", XENOSCAPE_SAVE_SCHEMA);
                store.SetInt("s" + Int(i) + "ck", 0);
            }
            if used and valid {
                var slotMigrated = sv < XENOSCAPE_SAVE_SCHEMA;
                // Schema 1/2/3 profiles predate the traversal repair and may
                // contain only Wall Jump. Double Jump is now a baseline suit
                // module, so migrate the bit in memory and persist it below.
                if (ab / 2) % 2 == 0 {
                    ab = ab + 2;
                    slotMigrated = true;
                }
                if up < 0 { up = 0; slotMigrated = true; }
                if up > 255 { up = 255; slotMigrated = true; }
                if df < 0 or df > 2 { df = 1; slotMigrated = true; }
                if ky < 0 { ky = 0; slotMigrated = true; }
                if sw < 0 { sw = 0; slotMigrated = true; }
                if dr < 0 { dr = 0; slotMigrated = true; }
                if sh < 0 { sh = 0; slotMigrated = true; }
                if tp < 0 { tp = 0; slotMigrated = true; }
                if tu < 0 { tu = 0; slotMigrated = true; }
                if tu > 4095 { tu = 4095; slotMigrated = true; }
                if rk < 0 { rk = 0; slotMigrated = true; }
                if ng != 0 and ng != 1 { ng = 1; slotMigrated = true; }
                if wr < 0 { wr = 0; slotMigrated = true; }
                slotLevel.set(i, lv);
                slotAbilities.set(i, ab);
                slotMaxHp.set(i, hp);
                slotGems.set(i, gm);
                slotTime.set(i, tm);
                slotUsed.set(i, 1);
                slotBosses.set(i, bs);
                slotLore.set(i, lr);
                slotBestiary.set(i, be);
                slotComplete.set(i, cp);
                slotDeaths.set(i, de);
                slotSchema.set(i, XENOSCAPE_SAVE_SCHEMA);
                slotKeys.set(i, ky);
                slotSwitches.set(i, sw);
                slotDoors.set(i, dr);
                slotShrines.set(i, sh);
                slotTeleporters.set(i, tp);
                slotUpgrades.set(i, up);
                slotDifficulty.set(i, df);
                slotCheckpointLevel.set(i, cl);
                slotCheckpointX.set(i, cx);
                slotCheckpointY.set(i, cy);
                slotTutorials.set(i, tu);
                slotRankPacks.set(i, rk);
                slotNgPlus.set(i, ng);
                slotLastWrite.set(i, wr);
                slotChecksums.set(i, storedChecksum);
                if wr > lastObservedWrite { lastObservedWrite = wr; }
                var region = 0;
                while region < LEVEL_COUNT {
                    var rooms = store.GetInt("s" + Int(i) + "r" + Int(region), 0);
                    if rooms < 0 { rooms = 0; slotMigrated = true; }
                    if rooms > 255 { rooms = 255; slotMigrated = true; }
                    slotRooms.set(i * LEVEL_COUNT + region, rooms);
                    var bestTime = store.GetInt(
                        "s" + Int(i) + "t" + Int(region), 0);
                    if bestTime < 0 { bestTime = 0; slotMigrated = true; }
                    slotBestTimes.set(i * LEVEL_COUNT + region, bestTime);
                    region = region + 1;
                }
                if slotMigrated {
                    stageCachedSlotSnapshot(i);
                    anyMigrated = true;
                }
            }
            i = i + 1;
        }
        if recoveredCorrupt or anyMigrated { store.Save(); }
    }

    /// @brief Fold one signed value into the bounded slot checksum.
    ///
    /// The rolling checksum is intended to detect truncated, partially updated,
    /// or manually damaged snapshots. It is not an authentication mechanism.
    /// Reducing before multiplication keeps arithmetic inside signed 64-bit
    /// range even when the source store contains hostile integer values.
    ///
    /// @param hash Existing bounded rolling value.
    /// @param value Signed serialized field to incorporate.
    /// @return New nonnegative checksum below `XENOSCAPE_CHECKSUM_MODULUS`.
    hide func checksumAppend(hash: Integer, value: Integer) -> Integer {
        var normalized = value % XENOSCAPE_CHECKSUM_MODULUS;
        if normalized < 0 {
            normalized = normalized + XENOSCAPE_CHECKSUM_MODULUS;
        }
        return (hash * 131 + normalized + 17) %
               XENOSCAPE_CHECKSUM_MODULUS;
    }

    /// @brief Calculate the checksum directly from one serialized slot.
    ///
    /// Schema-v4 loading uses the store, not sanitized cache values, so a
    /// damaged optional field cannot be silently clamped past integrity checks.
    ///
    /// @param slot Valid zero-based serialized slot.
    /// @return Checksum calculated from every stored snapshot field.
    hide func checksumStoredSlot(slot: Integer) -> Integer {
        var prefix = "s" + Int(slot);
        var hash = 97;
        hash = checksumAppend(hash, store.GetInt(prefix + "lv", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "ab", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "hp", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "gm", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "tm", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "bs", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "lr", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "be", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "cp", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "de", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "sv", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "ky", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "sw", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "dr", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "sh", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "tp", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "up", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "df", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "cl", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "cx", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "cy", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "tu", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "rk", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "ng", 0));
        hash = checksumAppend(hash, store.GetInt(prefix + "wr", 0));
        var region = 0;
        while region < LEVEL_COUNT {
            hash = checksumAppend(
                hash, store.GetInt(prefix + "r" + Int(region), 0));
            hash = checksumAppend(
                hash, store.GetInt(prefix + "t" + Int(region), 0));
            region = region + 1;
        }
        return hash;
    }

    /// @brief Calculate the full schema-v4 checksum from sanitized cache state.
    /// @param slot Valid zero-based cached slot.
    /// @return Checksum calculated from every cached snapshot field.
    hide func checksumCachedSlot(slot: Integer) -> Integer {
        var hash = 97;
        hash = checksumAppend(hash, slotLevel.get(slot));
        hash = checksumAppend(hash, slotAbilities.get(slot));
        hash = checksumAppend(hash, slotMaxHp.get(slot));
        hash = checksumAppend(hash, slotGems.get(slot));
        hash = checksumAppend(hash, slotTime.get(slot));
        hash = checksumAppend(hash, slotBosses.get(slot));
        hash = checksumAppend(hash, slotLore.get(slot));
        hash = checksumAppend(hash, slotBestiary.get(slot));
        hash = checksumAppend(hash, slotComplete.get(slot));
        hash = checksumAppend(hash, slotDeaths.get(slot));
        hash = checksumAppend(hash, XENOSCAPE_SAVE_SCHEMA);
        hash = checksumAppend(hash, slotKeys.get(slot));
        hash = checksumAppend(hash, slotSwitches.get(slot));
        hash = checksumAppend(hash, slotDoors.get(slot));
        hash = checksumAppend(hash, slotShrines.get(slot));
        hash = checksumAppend(hash, slotTeleporters.get(slot));
        hash = checksumAppend(hash, slotUpgrades.get(slot));
        hash = checksumAppend(hash, slotDifficulty.get(slot));
        hash = checksumAppend(hash, slotCheckpointLevel.get(slot));
        hash = checksumAppend(hash, slotCheckpointX.get(slot));
        hash = checksumAppend(hash, slotCheckpointY.get(slot));
        hash = checksumAppend(hash, slotTutorials.get(slot));
        hash = checksumAppend(hash, slotRankPacks.get(slot));
        hash = checksumAppend(hash, slotNgPlus.get(slot));
        hash = checksumAppend(hash, slotLastWrite.get(slot));
        var region = 0;
        while region < LEVEL_COUNT {
            hash = checksumAppend(
                hash, slotRooms.get(slot * LEVEL_COUNT + region));
            hash = checksumAppend(
                hash, slotBestTimes.get(slot * LEVEL_COUNT + region));
            region = region + 1;
        }
        return hash;
    }

    /// @brief Stage every cached field plus its checksum in one SaveData batch.
    ///
    /// Callers perform the single final `Save()` after all cache mutations. The
    /// checksum is deliberately written last so an interrupted pre-flush batch
    /// cannot validate against a previous snapshot.
    ///
    /// @param slot Valid zero-based cached slot to stage.
    /// @return Nothing. Does not flush the SaveData batch.
    hide func stageCachedSlotSnapshot(slot: Integer) {
        var prefix = "s" + Int(slot);
        slotSchema.set(slot, XENOSCAPE_SAVE_SCHEMA);
        store.SetInt(prefix + "lv", slotLevel.get(slot));
        store.SetInt(prefix + "ab", slotAbilities.get(slot));
        store.SetInt(prefix + "hp", slotMaxHp.get(slot));
        store.SetInt(prefix + "gm", slotGems.get(slot));
        store.SetInt(prefix + "tm", slotTime.get(slot));
        store.SetInt(prefix + "bs", slotBosses.get(slot));
        store.SetInt(prefix + "lr", slotLore.get(slot));
        store.SetInt(prefix + "be", slotBestiary.get(slot));
        store.SetInt(prefix + "cp", slotComplete.get(slot));
        store.SetInt(prefix + "de", slotDeaths.get(slot));
        store.SetInt(prefix + "sv", XENOSCAPE_SAVE_SCHEMA);
        store.SetInt(prefix + "ky", slotKeys.get(slot));
        store.SetInt(prefix + "sw", slotSwitches.get(slot));
        store.SetInt(prefix + "dr", slotDoors.get(slot));
        store.SetInt(prefix + "sh", slotShrines.get(slot));
        store.SetInt(prefix + "tp", slotTeleporters.get(slot));
        store.SetInt(prefix + "up", slotUpgrades.get(slot));
        store.SetInt(prefix + "df", slotDifficulty.get(slot));
        store.SetInt(prefix + "cl", slotCheckpointLevel.get(slot));
        store.SetInt(prefix + "cx", slotCheckpointX.get(slot));
        store.SetInt(prefix + "cy", slotCheckpointY.get(slot));
        store.SetInt(prefix + "tu", slotTutorials.get(slot));
        store.SetInt(prefix + "rk", slotRankPacks.get(slot));
        store.SetInt(prefix + "ng", slotNgPlus.get(slot));
        store.SetInt(prefix + "wr", slotLastWrite.get(slot));
        var region = 0;
        while region < LEVEL_COUNT {
            store.SetInt(prefix + "r" + Int(region),
                         slotRooms.get(slot * LEVEL_COUNT + region));
            store.SetInt(prefix + "t" + Int(region),
                         slotBestTimes.get(slot * LEVEL_COUNT + region));
            region = region + 1;
        }
        var checksum = checksumCachedSlot(slot);
        slotChecksums.set(slot, checksum);
        store.SetInt(prefix + "ck", checksum);
    }

    /// @brief Validate the mandatory core of one populated expedition slot.
    ///
    /// Optional additive fields are clamped separately. Core values
    /// outside representable campaign bounds indicate a structurally corrupt slot
    /// that must not be offered by Continue or Load Game.
    ///
    /// @param level One-based region id.
    /// @param abilities Permanent ability mask.
    /// @param maxHp Serialized maximum health.
    /// @param gems Serialized salvage total.
    /// @param time Serialized played seconds.
    /// @param schema Serialized schema version.
    /// @param bosses Defeated-boss mask.
    /// @param lore Lore-discovery mask.
    /// @param bestiary Bestiary-discovery mask.
    /// @param completion Completion mask.
    /// @param deaths Campaign death count.
    /// @param checkpointLevel Latest checkpoint region or zero.
    /// @param checkpointX Latest checkpoint X in pixels.
    /// @param checkpointY Latest checkpoint Y in pixels.
    /// @return True only when all mandatory values are safe to restore.
    hide func slotCoreIsValid(level: Integer, abilities: Integer,
                              maxHp: Integer, gems: Integer,
                              time: Integer, schema: Integer,
                              bosses: Integer, lore: Integer,
                              bestiary: Integer, completion: Integer,
                              deaths: Integer, checkpointLevel: Integer,
                              checkpointX: Integer,
                              checkpointY: Integer) -> Boolean {
        if level < 1 or level > LEVEL_COUNT { return false; }
        if abilities < 1 or abilities > 63 { return false; }
        if maxHp < 1 or maxHp > 99 { return false; }
        if gems < 0 or time < 0 or deaths < 0 { return false; }
        if bosses < 0 or lore < 0 or bestiary < 0 or completion < 0 {
            return false;
        }
        if schema < 1 or schema > XENOSCAPE_SAVE_SCHEMA { return false; }
        if checkpointLevel < 0 or checkpointLevel > LEVEL_COUNT {
            return false;
        }
        if checkpointX < 0 or checkpointY < 0 { return false; }
        return true;
    }

    /// @brief Preserve the unreadable/invalid live save file beside its source.
    ///
    /// SaveData exposes its cross-platform absolute path. The backup uses a stable
    /// `.corrupt.bak` suffix and is replaced only when a new recovery occurs.
    /// Missing files need no backup and return false without mutation.
    ///
    /// @return True when an existing source file was copied; false when absent.
    hide func backupCorruptStore() -> Boolean {
        var source = store.get_Path();
        if File.Exists(source) == false { return false; }
        var backup = source + ".corrupt.bak";
        if File.Exists(backup) { File.Delete(backup); }
        File.Copy(source, backup);
        return File.Exists(backup);
    }

    /// @brief Write a slot's full state.  Call from the save
    ///        station on touch.
    ///
    /// Updates the cache first, then pushes each field through
    /// SaveData.  One Save() call flushes the batch.  Out-of-
    /// range slot ids are ignored silently — the menu shouldn't
    /// be able to pass one, but defensive is cheap.
    expose func saveSlot(slot: Integer, level: Integer, abilities: Integer,
                         maxHp: Integer, gems: Integer, time: Integer) {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return; }
        saveSlotFull(slot, level, abilities, maxHp, gems, time,
                     slotBosses.get(slot), slotLore.get(slot),
                     slotBestiary.get(slot), slotComplete.get(slot),
                     slotDeaths.get(slot));
    }

    /// @brief Write a complete development-preview slot snapshot with campaign
    ///        metadata used by Continue/Load Game.
    expose func saveSlotFull(slot: Integer, level: Integer, abilities: Integer,
                             maxHp: Integer, gems: Integer, time: Integer,
                             bosses: Integer, lore: Integer,
                             bestiary: Integer, completion: Integer,
                             deaths: Integer) {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return; }
        writeSlotCore(slot, level, abilities, maxHp, gems, time,
                      bosses, lore, bestiary, completion, deaths);
        stageCachedSlotSnapshot(slot);
        store.Save();
    }

    /// @brief Stage legacy-compatible core fields in cache and SaveData.
    ///
    /// This helper deliberately does not flush. Public writers append any
    /// schema-specific fields and perform exactly one `Save()` at their batch
    /// boundary, keeping snapshots internally consistent.
    ///
    /// @param slot Validated zero-based destination slot.
    /// @param level One-based current area.
    /// @param abilities Permanent ability mask.
    /// @param maxHp Permanent maximum health.
    /// @param gems Banked salvage.
    /// @param time Played seconds.
    /// @param bosses Defeated-boss mask.
    /// @param lore Collected-lore mask.
    /// @param bestiary Discovered-bestiary mask.
    /// @param completion Completed-area mask.
    /// @param deaths Campaign death count.
    /// @return Nothing. Mutates cache and staged SaveData values only.
    hide func writeSlotCore(slot: Integer, level: Integer,
                            abilities: Integer, maxHp: Integer,
                            gems: Integer, time: Integer,
                            bosses: Integer, lore: Integer,
                            bestiary: Integer, completion: Integer,
                            deaths: Integer) {
        slotLevel.set(slot, level);
        slotAbilities.set(slot, abilities);
        slotMaxHp.set(slot, maxHp);
        slotGems.set(slot, gems);
        slotTime.set(slot, time);
        slotUsed.set(slot, 1);
        slotBosses.set(slot, bosses);
        slotLore.set(slot, lore);
        slotBestiary.set(slot, bestiary);
        slotComplete.set(slot, completion);
        slotDeaths.set(slot, deaths);
        slotSchema.set(slot, XENOSCAPE_SAVE_SCHEMA);
        var writeTimestamp = DateTime.NowMs();
        if writeTimestamp <= lastObservedWrite {
            writeTimestamp = lastObservedWrite + 1;
        }
        lastObservedWrite = writeTimestamp;
        slotLastWrite.set(slot, writeTimestamp);

        store.SetInt("s" + Int(slot) + "lv", level);
        store.SetInt("s" + Int(slot) + "ab", abilities);
        store.SetInt("s" + Int(slot) + "hp", maxHp);
        store.SetInt("s" + Int(slot) + "gm", gems);
        store.SetInt("s" + Int(slot) + "tm", time);
        store.SetInt("s" + Int(slot) + "bs", bosses);
        store.SetInt("s" + Int(slot) + "lr", lore);
        store.SetInt("s" + Int(slot) + "be", bestiary);
        store.SetInt("s" + Int(slot) + "cp", completion);
        store.SetInt("s" + Int(slot) + "de", deaths);
        store.SetInt("s" + Int(slot) + "sv", XENOSCAPE_SAVE_SCHEMA);
        store.SetInt("s" + Int(slot) + "ky", slotKeys.get(slot));
        store.SetInt("s" + Int(slot) + "sw", slotSwitches.get(slot));
        store.SetInt("s" + Int(slot) + "dr", slotDoors.get(slot));
        store.SetInt("s" + Int(slot) + "sh", slotShrines.get(slot));
        store.SetInt("s" + Int(slot) + "tp", slotTeleporters.get(slot));
        store.SetInt("s" + Int(slot) + "cl", slotCheckpointLevel.get(slot));
        store.SetInt("s" + Int(slot) + "cx", slotCheckpointX.get(slot));
        store.SetInt("s" + Int(slot) + "cy", slotCheckpointY.get(slot));
        store.SetInt("s" + Int(slot) + "tu", slotTutorials.get(slot));
        store.SetInt("s" + Int(slot) + "rk", slotRankPacks.get(slot));
        store.SetInt("s" + Int(slot) + "ng", slotNgPlus.get(slot));
        store.SetInt("s" + Int(slot) + "wr", writeTimestamp);
    }

    /// @brief Write a schema-v4 snapshot including persistent world state.
    ///
    /// Core campaign fields use the same keys as version 1. New interaction masks
    /// are additive, so loading an old slot produces zero/default masks and the
    /// next successful write migrates it to `XENOSCAPE_SAVE_SCHEMA` atomically at
    /// the SaveData batch boundary.
    ///
    /// @param slot Zero-based destination slot in 0..2.
    /// @param level One-based current campaign area.
    /// @param abilities Permanent ability bitmask.
    /// @param maxHp Permanent maximum player health.
    /// @param gems Banked salvage currency.
    /// @param time Total played seconds.
    /// @param bosses Defeated-boss mask.
    /// @param lore Collected authored-lore mask.
    /// @param bestiary Discovered bestiary mask.
    /// @param completion Completed-area mask.
    /// @param deaths Campaign death count.
    /// @param keys Permanently owned keycard mask.
    /// @param switches Persistent switch-channel polarity mask.
    /// @param doors Permanently opened keyed-door mask.
    /// @param shrines Permanently consumed ability-shrine mask.
    /// @param teleporters Discovered teleporter-pad mask.
    /// @param rooms Ten borrowed eight-bit room-discovery masks by region id.
    /// @param upgradeTiers Packed four-branch workbench tier value.
    /// @param difficultyProfile Active `DIFFICULTY_*` profile id.
    /// @param checkpointLevel One-based latest checkpoint region, or zero.
    /// @param checkpointX Latest checkpoint world X in pixels.
    /// @param checkpointY Latest checkpoint world Y in pixels.
    /// @param tutorialMask Acknowledged contextual tutorial bits.
    /// @param bestTimes Ten per-region best completion times in milliseconds.
    /// @param packedRanks Ten base-six best rank ids.
    /// @param newGamePlusActive One when NG+ scaling is active, otherwise zero.
    /// @return True when the final store flush succeeds; false for invalid slots
    ///         or a storage write failure.
    expose func saveSlotRelease(slot: Integer, level: Integer,
                                abilities: Integer, maxHp: Integer,
                                gems: Integer, time: Integer,
                                bosses: Integer, lore: Integer,
                                bestiary: Integer, completion: Integer,
                                deaths: Integer, keys: Integer,
                                switches: Integer, doors: Integer,
                                shrines: Integer,
                                teleporters: Integer,
                                rooms: List[Integer],
                                upgradeTiers: Integer,
                                difficultyProfile: Integer,
                                checkpointLevel: Integer,
                                checkpointX: Integer,
                                checkpointY: Integer,
                                tutorialMask: Integer,
                                bestTimes: List[Integer],
                                packedRanks: Integer,
                                newGamePlusActive: Integer) -> Boolean {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return false; }

        writeSlotCore(slot, level, abilities, maxHp, gems, time,
                      bosses, lore, bestiary, completion, deaths);
        slotKeys.set(slot, keys);
        slotSwitches.set(slot, switches);
        slotDoors.set(slot, doors);
        slotShrines.set(slot, shrines);
        slotTeleporters.set(slot, teleporters);
        store.SetInt("s" + Int(slot) + "ky", keys);
        store.SetInt("s" + Int(slot) + "sw", switches);
        store.SetInt("s" + Int(slot) + "dr", doors);
        store.SetInt("s" + Int(slot) + "sh", shrines);
        store.SetInt("s" + Int(slot) + "tp", teleporters);
        store.SetInt("s" + Int(slot) + "sv", XENOSCAPE_SAVE_SCHEMA);
        slotUpgrades.set(slot, upgradeTiers);
        slotDifficulty.set(slot, difficultyProfile);
        store.SetInt("s" + Int(slot) + "up", upgradeTiers);
        store.SetInt("s" + Int(slot) + "df", difficultyProfile);
        var boundedCheckpointLevel = checkpointLevel;
        var boundedCheckpointX = checkpointX;
        var boundedCheckpointY = checkpointY;
        if boundedCheckpointLevel < 0 or boundedCheckpointLevel > LEVEL_COUNT {
            boundedCheckpointLevel = 0;
        }
        if boundedCheckpointX < 0 { boundedCheckpointX = 0; }
        if boundedCheckpointY < 0 { boundedCheckpointY = 0; }
        slotCheckpointLevel.set(slot, boundedCheckpointLevel);
        slotCheckpointX.set(slot, boundedCheckpointX);
        slotCheckpointY.set(slot, boundedCheckpointY);
        store.SetInt("s" + Int(slot) + "cl", boundedCheckpointLevel);
        store.SetInt("s" + Int(slot) + "cx", boundedCheckpointX);
        store.SetInt("s" + Int(slot) + "cy", boundedCheckpointY);
        var boundedTutorialMask = tutorialMask;
        if boundedTutorialMask < 0 { boundedTutorialMask = 0; }
        if boundedTutorialMask > 4095 { boundedTutorialMask = 4095; }
        slotTutorials.set(slot, boundedTutorialMask);
        store.SetInt("s" + Int(slot) + "tu", boundedTutorialMask);
        var boundedRanks = packedRanks;
        if boundedRanks < 0 { boundedRanks = 0; }
        var boundedNgPlus = 0;
        if newGamePlusActive != 0 { boundedNgPlus = 1; }
        slotRankPacks.set(slot, boundedRanks);
        slotNgPlus.set(slot, boundedNgPlus);
        store.SetInt("s" + Int(slot) + "rk", boundedRanks);
        store.SetInt("s" + Int(slot) + "ng", boundedNgPlus);
        var region = 0;
        while region < LEVEL_COUNT {
            var roomMask = 0;
            if region < rooms.length() { roomMask = rooms.get(region); }
            if roomMask < 0 { roomMask = 0; }
            if roomMask > 255 { roomMask = 255; }
            slotRooms.set(slot * LEVEL_COUNT + region, roomMask);
            store.SetInt("s" + Int(slot) + "r" + Int(region), roomMask);
            var bestTime = 0;
            if region < bestTimes.length() { bestTime = bestTimes.get(region); }
            if bestTime < 0 { bestTime = 0; }
            slotBestTimes.set(slot * LEVEL_COUNT + region, bestTime);
            store.SetInt("s" + Int(slot) + "t" + Int(region), bestTime);
            region = region + 1;
        }
        stageCachedSlotSnapshot(slot);
        return store.Save();
    }

    /// @brief "Has anyone ever saved to this slot?"
    expose func isSlotUsed(slot: Integer) -> Boolean {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return false; }
        return slotUsed.get(slot) == 1;
    }

    /// @brief Report whether initialization recovered unreadable/invalid data.
    ///
    /// @return True when a corrupt file or slot was backed up and reset during
    ///         this SaveManager initialization.
    expose func didRecoverCorruptSave() -> Boolean {
        return recoveredCorrupt;
    }

    /// @brief Accessor for the slot's level index.  Out-of-range
    ///        returns 0 (no loaded level) as a safe default.
    expose func getSlotLevel(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotLevel.get(slot);
    }

    /// @brief Ability-bitset accessor.  See `abilities.zia` for
    ///        the bit layout. Default `3` is Wall Jump plus Double Jump.
    expose func getSlotAbilities(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS {
            return XENOSCAPE_BASELINE_ABILITY_MASK;
        }
        return slotAbilities.get(slot);
    }

    /// @brief Max HP accessor — default 5 matches new-game HP.
    expose func getSlotMaxHp(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 5; }
        return slotMaxHp.get(slot);
    }

    /// @brief Currency accessor.
    expose func getSlotGems(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotGems.get(slot);
    }

    /// @brief Play time (seconds) accessor.  Used to render
    ///        "12m 34s" on the save-select menu.
    expose func getSlotTime(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotTime.get(slot);
    }

    expose func getSlotBosses(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotBosses.get(slot);
    }

    expose func getSlotLoreMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotLore.get(slot);
    }

    expose func getSlotBestiaryMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotBestiary.get(slot);
    }

    expose func getSlotCompletionMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotComplete.get(slot);
    }

    expose func getSlotDeaths(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotDeaths.get(slot);
    }

    /// @brief Read the serialized schema version of one used slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Stored schema, or the current schema for an invalid/empty slot.
    expose func getSlotSchema(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return XENOSCAPE_SAVE_SCHEMA; }
        return slotSchema.get(slot);
    }

    /// @brief Read permanently owned authored keycards for one slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Keycard mask, or zero for an invalid slot.
    expose func getSlotKeyMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotKeys.get(slot);
    }

    /// @brief Read persistent switch-channel polarity for one slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Switch mask, or zero for an invalid slot.
    expose func getSlotSwitchMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotSwitches.get(slot);
    }

    /// @brief Read permanently opened keyed doors for one slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Door mask, or zero for an invalid slot.
    expose func getSlotDoorMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotDoors.get(slot);
    }

    /// @brief Read permanently consumed ability shrines for one slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Shrine mask, or zero for an invalid slot.
    expose func getSlotShrineMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotShrines.get(slot);
    }

    /// @brief Read discovered fast-travel pads for one slot.
    ///
    /// @param slot Zero-based slot index.
    /// @return Teleporter mask, or zero for an invalid slot.
    expose func getSlotTeleporterMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotTeleporters.get(slot);
    }

    /// @brief Read one region's persisted eight-room discovery mask.
    ///
    /// @param slot Zero-based save slot.
    /// @param region Zero-based stable region id.
    /// @return Room mask in 0..255, or zero for invalid input.
    expose func getSlotRoomMask(slot: Integer, region: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS or
           region < 0 or region >= LEVEL_COUNT { return 0; }
        return slotRooms.get(slot * LEVEL_COUNT + region);
    }

    /// @brief Read packed permanent workbench tiers for one slot.
    ///
    /// @param slot Zero-based save slot.
    /// @return Packed base-four tier value, or zero for invalid input.
    expose func getSlotUpgradeTiers(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotUpgrades.get(slot);
    }

    /// @brief Read the active saved difficulty profile.
    ///
    /// @param slot Zero-based save slot.
    /// @return Saved profile id, or Standard (1) for invalid input.
    expose func getSlotDifficulty(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 1; }
        return slotDifficulty.get(slot);
    }

    /// @brief Read the latest activated checkpoint's region.
    ///
    /// @param slot Zero-based save slot.
    /// @return One-based region id, or zero when the slot has no checkpoint.
    expose func getSlotCheckpointLevel(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotCheckpointLevel.get(slot);
    }

    /// @brief Read the latest activated checkpoint's world X coordinate.
    ///
    /// @param slot Zero-based save slot.
    /// @return Nonnegative world-space X in pixels, or zero for invalid input.
    expose func getSlotCheckpointX(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotCheckpointX.get(slot);
    }

    /// @brief Read the latest activated checkpoint's world Y coordinate.
    ///
    /// @param slot Zero-based save slot.
    /// @return Nonnegative world-space Y in pixels, or zero for invalid input.
    expose func getSlotCheckpointY(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotCheckpointY.get(slot);
    }

    /// @brief Read per-profile contextual tutorial acknowledgements.
    ///
    /// @param slot Zero-based save slot.
    /// @return Twelve-bit acknowledgement mask, or zero for invalid input.
    expose func getSlotTutorialMask(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotTutorials.get(slot);
    }

    /// @brief Copy ten persisted regional best times for MetaProgression restore.
    ///
    /// @param slot Zero-based save slot.
    /// @return New ten-entry list; invalid slots return ten zeroes.
    expose func getSlotBestTimes(slot: Integer) -> List[Integer] {
        var result = [];
        var region = 0;
        while region < LEVEL_COUNT {
            var value = 0;
            if slot >= 0 and slot < MAX_SAVE_SLOTS {
                value = slotBestTimes.get(slot * LEVEL_COUNT + region);
            }
            result.add(value);
            region = region + 1;
        }
        return result;
    }

    /// @brief Read the packed ten-region best-rank value.
    ///
    /// @param slot Zero-based save slot.
    /// @return Nonnegative base-six rank pack, or zero for invalid input.
    expose func getSlotPackedRanks(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotRankPacks.get(slot);
    }

    /// @brief Read whether the saved expedition is running in New Game+ mode.
    ///
    /// @param slot Zero-based save slot.
    /// @return True only for a serialized active flag.
    expose func getSlotNewGamePlusActive(slot: Integer) -> Boolean {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return false; }
        return slotNgPlus.get(slot) == 1;
    }

    /// @brief Read the latest write timestamp recorded for one profile.
    ///
    /// Version-1 and early version-2 saves migrate with zero until their next
    /// successful snapshot. Values use Unix milliseconds when available and a
    /// monotonic in-process sequence if the platform clock cannot advance.
    ///
    /// @param slot Zero-based profile slot.
    /// @return Nonnegative write timestamp, or zero for invalid/legacy slots.
    expose func getSlotLastWrite(slot: Integer) -> Integer {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return 0; }
        return slotLastWrite.get(slot);
    }

    /// @brief Most recently written valid slot for Continue.
    ///
    /// Legacy slots without timestamps fall back to farthest region, longer
    /// playtime, then lower slot id. Timestamp ties use the same deterministic
    /// fallback so coarse or unavailable platform clocks remain harmless.
    ///
    /// @return Zero-based used slot id, or -1 when no expedition exists.
    expose func getContinueSlot() -> Integer {
        var best = -1;
        var bestWrite = -1;
        var bestLevel = -1;
        var bestTime = -1;
        var i = 0;
        while i < MAX_SAVE_SLOTS {
            if slotUsed.get(i) == 1 {
                var lv = slotLevel.get(i);
                var tm = slotTime.get(i);
                var wr = slotLastWrite.get(i);
                if wr > bestWrite or
                   (wr == bestWrite and
                    (lv > bestLevel or
                     (lv == bestLevel and tm > bestTime))) {
                    best = i;
                    bestWrite = wr;
                    bestLevel = lv;
                    bestTime = tm;
                }
            }
            i = i + 1;
        }
        return best;
    }

    /// @brief Clear a slot.  Cache resets to defaults; the
    ///        store flips `lv`/`ab` to 0 so the next `loadAll`
    ///        re-reads as empty.  We leave the other keys at
    ///        their previous values — they become unreachable
    ///        (gated by `isSlotUsed`), which is fine.
    expose func deleteSlot(slot: Integer) {
        if slot < 0 or slot >= MAX_SAVE_SLOTS { return; }
        slotLevel.set(slot, 0);
        slotAbilities.set(slot, XENOSCAPE_BASELINE_ABILITY_MASK);
        slotMaxHp.set(slot, 5);
        slotGems.set(slot, 0);
        slotTime.set(slot, 0);
        slotUsed.set(slot, 0);
        slotBosses.set(slot, 0);
        slotLore.set(slot, 0);
        slotBestiary.set(slot, 0);
        slotComplete.set(slot, 0);
        slotDeaths.set(slot, 0);
        slotSchema.set(slot, XENOSCAPE_SAVE_SCHEMA);
        slotKeys.set(slot, 0);
        slotSwitches.set(slot, 0);
        slotDoors.set(slot, 0);
        slotShrines.set(slot, 0);
        slotTeleporters.set(slot, 0);
        slotUpgrades.set(slot, 0);
        slotDifficulty.set(slot, 1);
        slotCheckpointLevel.set(slot, 0);
        slotCheckpointX.set(slot, 0);
        slotCheckpointY.set(slot, 0);
        slotTutorials.set(slot, 0);
        slotRankPacks.set(slot, 0);
        slotNgPlus.set(slot, 0);
        slotLastWrite.set(slot, 0);
        slotChecksums.set(slot, 0);
        var region = 0;
        while region < LEVEL_COUNT {
            slotRooms.set(slot * LEVEL_COUNT + region, 0);
            slotBestTimes.set(slot * LEVEL_COUNT + region, 0);
            region = region + 1;
        }
        store.SetInt("s" + Int(slot) + "lv", 0);
        store.SetInt("s" + Int(slot) + "ab", 0);
        store.SetInt("s" + Int(slot) + "bs", 0);
        store.SetInt("s" + Int(slot) + "lr", 0);
        store.SetInt("s" + Int(slot) + "be", 0);
        store.SetInt("s" + Int(slot) + "cp", 0);
        store.SetInt("s" + Int(slot) + "de", 0);
        store.SetInt("s" + Int(slot) + "sv", XENOSCAPE_SAVE_SCHEMA);
        store.SetInt("s" + Int(slot) + "ky", 0);
        store.SetInt("s" + Int(slot) + "sw", 0);
        store.SetInt("s" + Int(slot) + "dr", 0);
        store.SetInt("s" + Int(slot) + "sh", 0);
        store.SetInt("s" + Int(slot) + "tp", 0);
        store.SetInt("s" + Int(slot) + "up", 0);
        store.SetInt("s" + Int(slot) + "df", 1);
        store.SetInt("s" + Int(slot) + "cl", 0);
        store.SetInt("s" + Int(slot) + "cx", 0);
        store.SetInt("s" + Int(slot) + "cy", 0);
        store.SetInt("s" + Int(slot) + "tu", 0);
        store.SetInt("s" + Int(slot) + "rk", 0);
        store.SetInt("s" + Int(slot) + "ng", 0);
        store.SetInt("s" + Int(slot) + "wr", 0);
        store.SetInt("s" + Int(slot) + "ck", 0);
        region = 0;
        while region < LEVEL_COUNT {
            store.SetInt("s" + Int(slot) + "r" + Int(region), 0);
            store.SetInt("s" + Int(slot) + "t" + Int(region), 0);
            region = region + 1;
        }
        store.Save();
    }

    /// @brief Build a compact profile-card summary.
    ///
    /// Empty slots remain explicit. Populated slots expose area, checkpoint,
    /// playtime, completion, difficulty, max HP, ability count, and salvage in a
    /// stable order so New Game and Load Game share one truthful presentation.
    ///
    /// @param slot Zero-based profile slot.
    /// @return `Empty` or the complete single-line release summary.
    expose func getSlotSummary(slot: Integer) -> String {
        if not isSlotUsed(slot) { return "Empty"; }
        var lv = slotLevel.get(slot);
        if lv < 1 { lv = 1; }
        var tm = slotTime.get(slot);
        var mins = tm / 60;
        var secs = tm % 60;
        var complete = countBits(slotComplete.get(slot));
        var completionPct = complete * 100 / LEVEL_COUNT;
        var checkpoint = "Entrance";
        if slotCheckpointLevel.get(slot) > 0 {
            checkpoint = "CP A" + Int(slotCheckpointLevel.get(slot));
        }
        var abilities = countBits(slotAbilities.get(slot));
        var savedLabel = "";
        var written = slotLastWrite.get(slot);
        if written > 0 {
            var formattedWrite =
                DateTime.Format(written / 1000, "%b%d %H:%M");
            if formattedWrite != "" {
                savedLabel = " | " + formattedWrite;
            }
        }
        return "Area " + Int(lv) + " | " + checkpoint + " | " +
               Int(mins) + "m" + Int(secs) + "s | " +
               Int(completionPct) + "% | " +
               saveDifficultyName(slotDifficulty.get(slot)) + " | HP " +
               Int(slotMaxHp.get(slot)) + " | Mods " + Int(abilities) +
               "/6 | Salvage " + Int(slotGems.get(slot)) + savedLabel;
    }

    /// @brief Map a serialized difficulty id to profile-card text.
    ///
    /// Kept local to persistence so save.zia does not depend on gameplay's
    /// DifficultySystem solely for presentation. Invalid values migrate visibly
    /// to Standard's safe label.
    ///
    /// @param profile Serialized difficulty id.
    /// @return Explorer, Standard, or Veteran.
    hide func saveDifficultyName(profile: Integer) -> String {
        if profile == 0 { return "Explorer"; }
        if profile == 2 { return "Veteran"; }
        return "Standard";
    }

    /// @brief Count set bits in a non-negative mask.
    hide func countBits(mask: Integer) -> Integer {
        var m = mask;
        var count = 0;
        while m > 0 {
            if m % 2 == 1 { count = count + 1; }
            m = m / 2;
        }
        return count;
    }
}
