//
// File: examples/games/xenoscape/accessibility.zia
// Purpose: Maps persistent accessibility choices to deterministic presentation.
// Key invariants:
//   - Text scales remain readable and bounded for every advertised UI scale.
//   - Disabled rumble always produces zero output strength.
// Ownership/Lifetime:
//   - Functions are pure and own no resources or mutable state.
// Links: game.zia, menu.zia, hud.zia, settings.zia, settings_probe.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module accessibility;

/// @brief Convert base bitmap-text scale through UI Scale and Large Text.
///
/// @param baseScale Positive authored bitmap-font scale.
/// @param uiScale Advertised 100, 125, or 150 percent setting.
/// @param largeText Whether the additional legibility step is enabled.
/// @return Integer scale clamped to 1..6.
func accessibleTextScale(baseScale: Integer, uiScale: Integer,
                         largeText: Boolean) -> Integer {
    var base = baseScale;
    if base < 1 { base = 1; }
    var scalePercent = uiScale;
    if scalePercent != 100 and scalePercent != 125 and scalePercent != 150 {
        scalePercent = 100;
    }
    var result = (base * scalePercent + 99) / 100;
    if largeText { result = result + 1; }
    if result < 1 { result = 1; }
    if result > 6 { result = 6; }
    return result;
}

/// @brief Choose HUD/menu backing opacity for normal or high-contrast mode.
///
/// @param highContrast Persistent high-contrast toggle.
/// @return 235 in high-contrast mode and 180 otherwise.
func accessiblePanelAlpha(highContrast: Boolean) -> Integer {
    if highContrast { return 235; }
    return 180;
}

/// @brief Gate a normalized controller-rumble magnitude through its setting.
///
/// @param requested Authored magnitude in 0..100.
/// @param enabled Persistent rumble toggle.
/// @return Requested magnitude clamped to 0..100, or zero when disabled.
func accessibleRumbleStrength(requested: Integer,
                              enabled: Boolean) -> Integer {
    if enabled == false { return 0; }
    if requested < 0 { return 0; }
    if requested > 100 { return 100; }
    return requested;
}
