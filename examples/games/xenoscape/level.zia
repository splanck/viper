        addPlatform(168, 10, 3);

        addPickup(PICKUP_RAPIDFIRE, 159, 7);
        addPickup(PICKUP_HEALTH, 170, 9);

        var i = 142;
        while i < 175 {
            addPickup(PICKUP_COIN, i, 14);
            i = i + 4;
        }

        addEnemy(ENEMY_SLIME, 150, 14);
        addEnemy(ENEMY_SLIME, 162, 14);
        addEnemy(ENEMY_BAT, 170, 4);

        // --- Section 5: Final stretch (cols 185-225) ---
        // Spike pits
        clearGround(188, 192);
        fillRow(FLOOR_ROW, 188, 192, TILE_SPIKE);
        fillRow(13, 188, 192, TILE_BRIDGE);

        addPlatform(195, 11, 4);
        addPlatform(202, 9, 4);
        addPlatform(208, 11, 3);

