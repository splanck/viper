        fillArea(50, 2, 51, 14, TILE_RUIN_STONE);
        tilemap.SetTile(50, 3, TILE_VINE);
        tilemap.SetTile(51, 5, TILE_VINE);

        fillRow(GROUND_ROW, 52, 95, TILE_RUIN_STONE);
        fillRow(FLOOR_ROW, 52, 95, TILE_RUIN_STONE);

        addPlatform(56, 12, 4);
        addPlatform(63, 10, 4);
        addPlatform(70, 8, 3);
        addPlatform(76, 11, 4);
        addPlatform(83, 9, 3);

        // Spike pits
        clearGround(60, 62);
        fillRow(FLOOR_ROW, 60, 62, TILE_SPIKE);
        clearGround(72, 74);
        fillRow(FLOOR_ROW, 72, 74, TILE_SPIKE);

        addPickup(PICKUP_COIN, 57, 11);
