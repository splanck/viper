        addPickup(PICKUP_HEALTH, 183, 14);
        addPickup(PICKUP_HEALTH, 185, 14);
        addPickup(PICKUP_SHIELD, 187, 14);

        // Final boss — Magma Core (stationary, AOE attacks)
        bossX = 210 * TILE_SIZE;
        bossY = (GROUND_ROW - 3) * TILE_SIZE;
        hasBoss = true;
        bossType = ENEMY_MAGMA_CORE;

        // End sign
        tilemap.SetTile(245, GROUND_ROW - 1, TILE_SIGN_END);
    }

    // =========================================================================
    // Level builder helpers
    // =========================================================================

    hide func addPlatform(col: Integer, row: Integer, width: Integer) {
        var c = col;
        while c < col + width {
            tilemap.SetTile(c, row, TILE_PLATFORM);
            c = c + 1;
        }
    }

    hide func clearGround(startCol: Integer, endCol: Integer) {
        var c = startCol;
        while c <= endCol {
            tilemap.SetTile(c, GROUND_ROW, TILE_EMPTY);
            tilemap.SetTile(c, FLOOR_ROW, TILE_EMPTY);
            c = c + 1;
        }
    }

    // =========================================================================
    // =========================================================================
    // Post-build enemy enrichment — adds new enemy types to existing levels
    // =========================================================================
    expose func enrichEnemies(levelNum: Integer) {
        if levelNum == 1 {
            enemyTypes.add(ENEMY_PATROL_DRONE);
            enemyX.add(60 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_BOMB_CARRIER);
            enemyX.add(90 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
        }
        if levelNum == 2 {
            enemyTypes.add(ENEMY_SPOREWALKER);
            enemyX.add(30 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_SPOREWALKER);
            enemyX.add(55 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(40 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(70 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_FUNGAL_TURRET);
            enemyX.add(85 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_MYCELIUM);
            enemyX.add(95 * TILE_SIZE); enemyY.add(4 * TILE_SIZE);
            // Spore Mother boss is spawned via level.bossType — not here
        }
        if levelNum == 3 {
            enemyTypes.add(ENEMY_CRYSTAL_GOLEM);
            enemyX.add(35 * TILE_SIZE); enemyY.add(12 * TILE_SIZE);
            enemyTypes.add(ENEMY_SHARD_BAT);
            enemyX.add(50 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_SHARD_BAT);
            enemyX.add(75 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_RESONANCE_ORB);
            enemyX.add(60 * TILE_SIZE); enemyY.add(10 * TILE_SIZE);
            enemyTypes.add(ENEMY_MIRROR_SLIME);
            enemyX.add(90 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            // Crystal Wyrm boss is spawned via level.bossType — not here
        }
        if levelNum == 4 {
            enemyTypes.add(ENEMY_VINE_WHIP);
            enemyX.add(25 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_RUIN_GUARDIAN);
            enemyX.add(80 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_PATROL_DRONE);
            enemyX.add(100 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
        }
        if levelNum == 5 {
            enemyTypes.add(ENEMY_FROST_BEETLE);
            enemyX.add(40 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_GLOWMOTH);
            enemyX.add(60 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_BOMB_CARRIER);
            enemyX.add(100 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
        }
        if levelNum == 6 {
            enemyTypes.add(ENEMY_MAGMA_SLUG);
            enemyX.add(30 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_MAGMA_SLUG);
            enemyX.add(60 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            enemyTypes.add(ENEMY_EMBER_WASP);
            enemyX.add(45 * TILE_SIZE); enemyY.add(6 * TILE_SIZE);
            enemyTypes.add(ENEMY_EMBER_WASP);
            enemyX.add(75 * TILE_SIZE); enemyY.add(8 * TILE_SIZE);
            enemyTypes.add(ENEMY_FORGE_SENTINEL);
            enemyX.add(105 * TILE_SIZE); enemyY.add(14 * TILE_SIZE);
            // Magma Core boss is spawned via level.bossType — not here
