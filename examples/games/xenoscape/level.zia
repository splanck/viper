        fillArea(50, 6, 51, 14, TILE_OBSIDIAN);
        fillArea(55, 4, 56, 14, TILE_OBSIDIAN);
        fillArea(60, 2, 61, 14, TILE_OBSIDIAN);

        addPickup(PICKUP_COIN, 53, 5);
        addPickup(PICKUP_COIN, 58, 3);
        addPickup(PICKUP_COIN, 63, 2);

        addEnemy(ENEMY_BAT, 52, 3);
        addEnemy(ENEMY_BAT, 57, 2);

