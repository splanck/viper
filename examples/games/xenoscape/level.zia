//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/level.zia
// Purpose: Owns campaign tilemaps, dynamic tiles, and authored spawn records.
// Key invariants:
//   - Tile coordinates are bounds-checked before mutation or property lookup.
//   - Dynamic durability state is reset whenever an authored level is rebuilt.
// Ownership/Lifetime:
//   - Game owns one Level and replaces its content on regional transitions.
//   - Level owns the active Tilemap and all parallel spawn/dynamic-state lists.
// Links: physics.zia, projectile.zia, renderer.zia, game.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — STORING A 2D LEVEL
// -----------------------------
// At its core a level in a tile-based platformer is:
//
//   * A 2D grid of tile IDs (the "tilemap" — what each
//     square of the world looks like).
//   * A list of (entity-type, x, y) spawn records
//     (enemies, pickups, save stations, lore terminals,
//     boss).
//   * A few singleton positions (player start, checkpoint,
//     boss-room entry, level-exit door).
//   * Some metadata (theme/biome, music track, darkness
//     level).
//
// That's it.  Everything else — physics, AI, camera — works
// off these four pieces.  This file is the *data* layer: it
// holds the structures and the loader.  None of the gameplay
// systems modify it; they just read from it.
//
// PROCEDURAL VS DATA-DRIVEN LEVELS
// --------------------------------
// Two ways to ship levels:
//
//   1. **External data files** (Tiled `.tmx`, JSON, your own
//      format).  Designers iterate without touching code; the
//      game ships the parser.  The grown-up choice.
//
//   2. **Procedural in code** — every tile and spawn is
//      written in Zia by `buildLevel0()`, `buildLevel1()`,
//      etc.  No parser, no asset pipeline; binary stays
//      tiny; iterating means recompiling.
//
// Xenoscape ships **(2)** because (a) the demo binary must
// be self-contained, and (b) the maintainer is also the
// designer.  In a bigger team option (1) is what you want.
//
// `Tilemap` IS A RUNTIME CLASS
// ----------------------------
// `Viper.Graphics2D.Tilemap` is the runtime's tile-grid structure
// with `Get(x, y)` / `Set(x, y, id)` / bounds checks.  It
// also serves as the input to
// `Viper.Game.Raycast.HasLineOfSight` (used by AI and
// projectiles), so there's no per-game tile-grid type to
// reinvent.
//
// LEVEL LOADING FLOW
// ------------------
//     game.zia → level.loadLevel(index)
//         │
//         ▼
//     buildLevelN(this)        ← writes tilemap + spawn lists
//         │
//         ▼
//     game.zia spawns enemies / pickups from the lists
//
// WHERE THIS FITS
// ---------------
//     game.zia       ──► loads the level on level transition.
//     physics.zia    ──► reads tilemap for collision.
//     ai.zia         ──► reads tilemap for line-of-sight.
//     renderer.zia   ──► iterates visible tiles to draw.
//     enemy.zia, pickups.zia ──► spawn from this level's
//                                 spawn lists.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Level class fields — tilemap + spawn lists +
//      singletons + metadata.
//   2. `init` / `clear` — lifecycle.
//   3. `loadLevel(index)` — dispatcher to per-level builders.
//   4. `buildLevel0()` ... `buildLevelN()` — one big
//      procedural builder per level.  Look at one to see
//      how a room is "drawn" by code.
//   5. Tile-property accessors (`isSolid`, `isHazard`,
//      `getTilePropertyAt`) used by physics + AI.
//
// =============================================================================

module level;

bind Viper.Graphics;
bind Viper.Graphics2D.Tilemap as Tilemap;
bind Viper.Game;
bind "./abilities";
bind "./config";
bind "./world_state";

class Level {
    expose Tilemap tilemap;
    expose Integer levelWidth;
    expose Integer levelHeight;
    expose Integer levelTheme;

    // Spawn points (world pixel coordinates)
    expose Integer playerStartX;
    expose Integer playerStartY;
    expose Integer checkpointX;
    expose Integer checkpointY;
    expose Boolean hasCheckpoint;

    // Enemy spawn data (parallel arrays)
    expose List[Integer] enemyTypes;
    expose List[Integer] enemyX;
    expose List[Integer] enemyY;

    // Pickup spawn data
    expose List[Integer] pickupTypes;
    expose List[Integer] pickupX;
    expose List[Integer] pickupY;

    // Stable authored interaction records. Parallel list index is a room-local
    // handle; `interactionIds` and channels remain stable across rebuilds/saves.
    expose List[Integer] interactionTypes;
    expose List[Integer] interactionIds;
    expose List[Integer] interactionCols;
    expose List[Integer] interactionRows;
    expose List[Integer] interactionChannels;
    expose List[Integer] interactionPayloads;

    // Structural content anchors used by HUD, validation, and deterministic
    // campaign probes. Values are tile columns in the currently loaded region.
    expose Integer landmarkCol;
    expose Integer tutorialStartCol;
    expose Integer masteryStartCol;
    expose Integer setPieceCol;
    expose List[Integer] secretCols;

    // Boss spawn
    expose Integer bossX;
    expose Integer bossY;
    expose Boolean hasBoss;
    expose Integer bossType;

    // Lazily allocated durability records for destructible tiles. The tile key
    // is `col + row * levelWidth`; authored tiles not yet hit implicitly have 2 HP.
    hide List[Integer] destructibleKeys;
    hide List[Integer] destructibleHp;

    // Crumble records are also lazy. Contact time applies only while intact;
    // regeneration time applies only while the authored tile is temporarily empty.
    hide List[Integer] crumbleKeys;
    hide List[Integer] crumbleContactMs;
    hide List[Integer] crumbleRegenMs;
    hide List[Integer] crumbleTouched;

    expose func init() {
        levelWidth = 0;
        levelHeight = 0;
        levelTheme = 0;
        playerStartX = 0;
        playerStartY = 0;
        checkpointX = 0;
        checkpointY = 0;
        hasCheckpoint = false;
        enemyTypes = [];
        enemyX = [];
        enemyY = [];
        pickupTypes = [];
        pickupX = [];
        pickupY = [];
        interactionTypes = [];
        interactionIds = [];
        interactionCols = [];
        interactionRows = [];
        interactionChannels = [];
        interactionPayloads = [];
        landmarkCol = -1;
        tutorialStartCol = -1;
        masteryStartCol = -1;
        setPieceCol = -1;
        secretCols = [];
        bossX = 0;
        bossY = 0;
        hasBoss = false;
        bossType = ENEMY_BOSS;
        destructibleKeys = [];
        destructibleHp = [];
        crumbleKeys = [];
        crumbleContactMs = [];
        crumbleRegenMs = [];
        crumbleTouched = [];
    }

    expose func loadLevel(num: Integer) {
        // Reset spawn arrays
        enemyTypes = [];
        enemyX = [];
        enemyY = [];
        pickupTypes = [];
        pickupX = [];
        pickupY = [];
        interactionTypes = [];
        interactionIds = [];
        interactionCols = [];
        interactionRows = [];
        interactionChannels = [];
        interactionPayloads = [];
        landmarkCol = -1;
        tutorialStartCol = -1;
        masteryStartCol = -1;
        setPieceCol = -1;
        secretCols = [];
        hasCheckpoint = false;
        hasBoss = false;
        bossType = ENEMY_BOSS;
        destructibleKeys = [];
        destructibleHp = [];
        crumbleKeys = [];
        crumbleContactMs = [];
        crumbleRegenMs = [];
        crumbleTouched = [];

        // Xenoscape: 10-level interconnected world
        if num == 1 { buildDescent(); }          // Crash Site / tutorial
        else if num == 2 { buildSalvage(); }     // Fungal Caverns (was Salvage)
        else if num == 3 { buildCrystalCave(); } // Crystal Depths
        else if num == 4 { buildOvergrowth(); }  // Surface Ruins
        else if num == 5 { buildGrasslands(); }  // Underground Lake (repurposed)
        else if num == 6 { buildVolcanicDepths(); } // Thermal Vents
        else if num == 7 { buildAncientRuins(); }   // Overgrowth
        else if num == 8 { buildFrozenAbyss(); }    // Frozen Abyss
        else if num == 9 { buildSkyFortress(); }    // Corrupted Ruins (repurposed)
        else { buildTheCore(); } // Level 10: The Core — final level

        authorReleaseInteractions(num);
        authorRegionalMechanics(num);
        authorCampaignContent(num);
    }

    expose func isSolid(col: Integer, row: Integer) -> Boolean {
        if col < 0 { return true; }
        if row < 0 { return true; }
        if col >= levelWidth { return true; }
        if row >= levelHeight { return true; }
        // Tilemap.IsSolidAt takes PIXEL coordinates (divides by tile size internally)
        return tilemap.IsSolidAt(col * TILE_SIZE, row * TILE_SIZE);
    }

    expose func isHazard(col: Integer, row: Integer) -> Boolean {
        if col < 0 { return false; }
        if row < 0 { return false; }
        if col >= levelWidth { return false; }
        if row >= levelHeight { return false; }
        var t = tilemap.GetTile(col, row);
        return tilemap.GetTileProperty(t, "hazard", 0) != 0;
    }

    expose func getTile(col: Integer, row: Integer) -> Integer {
        if col < 0 { return TILE_EMPTY; }
        if row < 0 { return TILE_EMPTY; }
        if col >= levelWidth { return TILE_EMPTY; }
        if row >= levelHeight { return TILE_EMPTY; }
        return tilemap.GetTile(col, row);
    }

    /// @brief Find the nearest authored interaction of one type.
    ///
    /// Distance is measured from the supplied world point to each authored tile
    /// center using Manhattan distance. This keeps selection deterministic when
    /// two records overlap and avoids deriving gameplay ids from coordinates.
    ///
    /// @param interactionType One `INTERACTION_*` record type.
    /// @param worldX Query point x coordinate in whole world pixels.
    /// @param worldY Query point y coordinate in whole world pixels.
    /// @param radius Maximum inclusive Manhattan distance in pixels.
    /// @return Room-local record index, or -1 when no matching record is nearby.
    expose func findNearbyInteraction(interactionType: Integer,
                                      worldX: Integer, worldY: Integer,
                                      radius: Integer) -> Integer {
        var best = -1;
        var bestDistance = radius + 1;
        var i = 0;
        while i < interactionTypes.length() {
            if interactionTypes.get(i) == interactionType {
                var dx = interactionCols.get(i) * TILE_SIZE + TILE_SIZE / 2 - worldX;
                var dy = interactionRows.get(i) * TILE_SIZE + TILE_SIZE / 2 - worldY;
                if dx < 0 { dx = 0 - dx; }
                if dy < 0 { dy = 0 - dy; }
                var distance = dx + dy;
                if distance <= radius and distance < bestDistance {
                    best = i;
                    bestDistance = distance;
                }
            }
            i = i + 1;
        }
        return best;
    }

    /// @brief Rebuild mutable interaction tiles from persistent save masks.
    ///
    /// Switch targets mirror their channel polarity, keyed doors disappear once
    /// permanently opened, and consumed shrines become inert consoles. Authored
    /// records remain intact so proximity, map metadata, and save ids do not
    /// change when their visible tile changes.
    ///
    /// @param switches Persistent switch-channel mask from `WorldState`.
    /// @param doors Permanently opened keyed-door mask.
    /// @param shrines Permanently consumed ability-shrine mask.
    /// @return Nothing. Mutates only tiles represented by authored records.
    expose func applyPersistentInteractionState(switches: Integer,
                                                doors: Integer,
                                                shrines: Integer) {
        var i = 0;
        while i < interactionTypes.length() {
            var kind = interactionTypes.get(i);
            var col = interactionCols.get(i);
            var row = interactionRows.get(i);
            if kind == INTERACTION_SWITCH_TARGET {
                if worldStateMaskHas(switches, interactionChannels.get(i)) {
                    tilemap.SetTile(col, row, TILE_HOLO_BRIDGE);
                } else {
                    tilemap.SetTile(col, row, TILE_EMPTY);
                }
            }
            if kind == INTERACTION_LOCKED_DOOR {
                if worldStateMaskHas(doors, interactionIds.get(i)) {
                    tilemap.SetTile(col, row, TILE_EMPTY);
                } else {
                    tilemap.SetTile(col, row, TILE_LOCKED_DOOR);
                }
            }
            if kind == INTERACTION_ABILITY_SHRINE {
                if worldStateMaskHas(shrines, interactionIds.get(i)) {
                    tilemap.SetTile(col, row, TILE_CONSOLE);
                } else {
                    tilemap.SetTile(col, row, TILE_ABILITY_SHRINE);
                }
            }
            i = i + 1;
        }
    }

    /// @brief Find the nearest visible authored grapple anchor within range.
    ///
    /// Candidates use squared pixel distance and must have clear tilemap line of
    /// sight from the player query point. Ties prefer the earliest row-major
    /// coordinate, keeping selection identical across VM/native executions.
    ///
    /// @param worldX Player/query x in whole world pixels.
    /// @param worldY Player/query y in whole world pixels.
    /// @param radius Maximum inclusive acquisition radius in pixels.
    /// @return Flattened anchor tile key, or -1 when none is valid and visible.
    expose func findNearestGrappleAnchor(worldX: Integer, worldY: Integer,
                                         radius: Integer) -> Integer {
        if radius < 0 { return -1; }
        var best = -1;
        var bestDistance = radius * radius + 1;
        var row = 0;
        while row < levelHeight {
            var col = 0;
            while col < levelWidth {
                if getTile(col, row) == TILE_GRAPPLE_ANCHOR {
                    var ax = col * TILE_SIZE + TILE_SIZE / 2;
                    var ay = row * TILE_SIZE + TILE_SIZE / 2;
                    var dx = ax - worldX;
                    var dy = ay - worldY;
                    var distance = dx * dx + dy * dy;
                    if distance <= radius * radius and distance < bestDistance {
                        if Raycast.HasLineOfSight(tilemap, worldX, worldY, ax, ay) {
                            best = col + row * levelWidth;
                            bestDistance = distance;
                        }
                    }
                }
                col = col + 1;
            }
            row = row + 1;
        }
        return best;
    }

    /// @brief Read remaining durability for one authored destructible tile.
    ///
    /// Untouched destructible tiles implicitly have two durability, avoiding a
    /// full-map allocation during load. Broken, non-destructible, and out-of-
    /// bounds coordinates report zero.
    ///
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @return Remaining durability in the inclusive range 0..2.
    expose func getDestructibleDurability(col: Integer, row: Integer) -> Integer {
        if getTile(col, row) != TILE_DESTRUCTIBLE { return 0; }
        var key = col + row * levelWidth;
        var idx = findDestructibleRecord(key);
        if idx < 0 { return 2; }
        return destructibleHp.get(idx);
    }

    /// @brief Apply charged-shot power to one destructible tile.
    ///
    /// The first hit lazily creates a two-durability record. Power is clamped by
    /// behavior: nonpositive values do nothing, positive values subtract from
    /// durability, and reaching zero replaces the tile with `TILE_EMPTY` so
    /// collision, raycast, AI navigation on reload, and rendering agree.
    ///
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @param power Positive destructible power from the projectile charge tier.
    /// @return 0 when unaffected, 1 when damaged but intact, or 2 when broken.
    expose func damageDestructible(col: Integer, row: Integer,
                                   power: Integer) -> Integer {
        if power <= 0 { return 0; }
        if getTile(col, row) != TILE_DESTRUCTIBLE { return 0; }

        var key = col + row * levelWidth;
        var idx = findDestructibleRecord(key);
        if idx < 0 {
            destructibleKeys.add(key);
            destructibleHp.add(2);
            idx = destructibleHp.length() - 1;
        }

        var remaining = destructibleHp.get(idx) - power;
        if remaining <= 0 {
            destructibleHp.set(idx, 0);
            tilemap.SetTile(col, row, TILE_EMPTY);
            return 2;
        }
        destructibleHp.set(idx, remaining);
        return 1;
    }

    /// @brief Damage the first destructible crossed by a horizontal shot path.
    ///
    /// Player projectiles currently travel horizontally. Iterating tile columns
    /// prevents a high-speed charged shot from tunnelling over a destructible
    /// wall before the ordinary solid-tile raycast releases the projectile.
    ///
    /// @param fromWorldX Starting world-pixel x coordinate.
    /// @param toWorldX Ending world-pixel x coordinate for this frame.
    /// @param worldY World-pixel y coordinate sampled for the projectile center.
    /// @param power Destructible power; nonpositive input performs no mutation.
    /// @return The 0/1/2 result from `damageDestructible`, or zero when no
    ///         destructible tile intersects the bounded horizontal path.
    expose func damageFirstDestructibleHorizontal(fromWorldX: Integer,
                                                   toWorldX: Integer,
                                                   worldY: Integer,
                                                   power: Integer) -> Integer {
        if power <= 0 or levelWidth <= 0 or levelHeight <= 0 { return 0; }
        var row = worldY / TILE_SIZE;
        if row < 0 or row >= levelHeight { return 0; }

        var fromCol = fromWorldX / TILE_SIZE;
        var toCol = toWorldX / TILE_SIZE;
        if fromCol < 0 { fromCol = 0; }
        if toCol < 0 { toCol = 0; }
        if fromCol >= levelWidth { fromCol = levelWidth - 1; }
        if toCol >= levelWidth { toCol = levelWidth - 1; }

        var step = 1;
        if toCol < fromCol { step = -1; }
        var col = fromCol;
        while true {
            if getTile(col, row) == TILE_DESTRUCTIBLE {
                return damageDestructible(col, row, power);
            }
            if col == toCol { break; }
            col = col + step;
        }
        return 0;
    }

    /// @brief Damage a destructible tile at one world-pixel sample point.
    ///
    /// Ground-pound landing uses the player's center foot point; converting in
    /// Level keeps tile bounds and durability policy centralized with projectiles.
    ///
    /// @param worldX World-pixel x coordinate inside the candidate floor tile.
    /// @param worldY World-pixel y coordinate inside the candidate floor tile.
    /// @param power Positive destructible power, normally full power for pound.
    /// @return The 0/1/2 result from `damageDestructible`.
    expose func damageDestructibleAtWorld(worldX: Integer,
                                          worldY: Integer,
                                          power: Integer) -> Integer {
        return damageDestructible(worldX / TILE_SIZE,
                                  worldY / TILE_SIZE, power);
    }

    /// @brief Find a lazily allocated destructible record by flattened tile key.
    ///
    /// @param key Flattened `col + row * levelWidth` tile coordinate.
    /// @return Record index, or -1 when the authored tile has not been hit yet.
    hide func findDestructibleRecord(key: Integer) -> Integer {
        var i = 0;
        while i < destructibleKeys.length() {
            if destructibleKeys.get(i) == key { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Accumulate continuous player contact on one crumble tile.
    ///
    /// The record is created lazily on first contact. Calling this method during
    /// consecutive simulation frames accumulates toward `CRUMBLE_CONTACT_MS`.
    /// Once the threshold is reached, the tile becomes empty and starts its
    /// regeneration timer. `updateDynamicTiles` resets interrupted contact.
    ///
    /// @param col Zero-based authored tile column under the player's feet.
    /// @param row Zero-based authored tile row under the player's feet.
    /// @param dt Nonnegative elapsed simulation time in milliseconds.
    /// @return 0 for no crumble contact, 1 while intact/contacting, or 2 on the
    ///         exact call that removes the tile.
    expose func touchCrumble(col: Integer, row: Integer,
                             dt: Integer) -> Integer {
        if getTile(col, row) != TILE_CRUMBLE { return 0; }

        var key = col + row * levelWidth;
        var idx = findCrumbleRecord(key);
        if idx < 0 {
            crumbleKeys.add(key);
            crumbleContactMs.add(0);
            crumbleRegenMs.add(0);
            crumbleTouched.add(0);
            idx = crumbleKeys.length() - 1;
        }
        if crumbleRegenMs.get(idx) > 0 { return 0; }

        var elapsed = dt;
        if elapsed < 0 { elapsed = 0; }
        crumbleTouched.set(idx, 1);
        var contact = crumbleContactMs.get(idx) + elapsed;
        if contact >= CRUMBLE_CONTACT_MS {
            crumbleContactMs.set(idx, 0);
            crumbleRegenMs.set(idx, CRUMBLE_REGEN_MS);
            tilemap.SetTile(col, row, TILE_EMPTY);
            return 2;
        }
        crumbleContactMs.set(idx, contact);
        return 1;
    }

    /// @brief Advance temporary dynamic-tile state by one live gameplay frame.
    ///
    /// Call this before the player's contact pass. A crumble record untouched in
    /// the preceding frame loses its partial contact progress. Broken tiles count
    /// down and restore their authored `TILE_CRUMBLE` identity after exactly the
    /// configured regeneration interval. Modal overlays intentionally skip this
    /// update so the world remains frozen beneath them.
    ///
    /// @param dt Nonnegative elapsed simulation time in milliseconds.
    /// @return Number of crumble tiles regenerated during this call.
    expose func updateDynamicTiles(dt: Integer) -> Integer {
        var elapsed = dt;
        if elapsed < 0 { elapsed = 0; }
        var regenerated = 0;
        var i = 0;
        while i < crumbleKeys.length() {
            var regen = crumbleRegenMs.get(i);
            if regen > 0 {
                regen = regen - elapsed;
                if regen <= 0 {
                    regen = 0;
                    var key = crumbleKeys.get(i);
                    var col = key % levelWidth;
                    var row = key / levelWidth;
                    tilemap.SetTile(col, row, TILE_CRUMBLE);
                    crumbleContactMs.set(i, 0);
                    regenerated = regenerated + 1;
                }
                crumbleRegenMs.set(i, regen);
            } else if crumbleTouched.get(i) == 0 {
                crumbleContactMs.set(i, 0);
            }
            crumbleTouched.set(i, 0);
            i = i + 1;
        }
        return regenerated;
    }

    /// @brief Read continuous contact time for crumble warning animation.
    ///
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @return Contact milliseconds for an intact recorded tile, otherwise zero.
    expose func getCrumbleContactMs(col: Integer, row: Integer) -> Integer {
        if col < 0 or row < 0 or col >= levelWidth or row >= levelHeight {
            return 0;
        }
        var idx = findCrumbleRecord(col + row * levelWidth);
        if idx < 0 or crumbleRegenMs.get(idx) > 0 { return 0; }
        return crumbleContactMs.get(idx);
    }

    /// @brief Read remaining regeneration time for a broken crumble tile.
    ///
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @return Remaining milliseconds, or zero for intact/untracked coordinates.
    expose func getCrumbleRegenMs(col: Integer, row: Integer) -> Integer {
        if col < 0 or row < 0 or col >= levelWidth or row >= levelHeight {
            return 0;
        }
        var idx = findCrumbleRecord(col + row * levelWidth);
        if idx < 0 { return 0; }
        return crumbleRegenMs.get(idx);
    }

    /// @brief Find a crumble record by flattened tile coordinate.
    ///
    /// @param key Flattened `col + row * levelWidth` tile coordinate.
    /// @return Existing parallel-list index, or -1 if never contacted.
    hide func findCrumbleRecord(key: Integer) -> Integer {
        var i = 0;
        while i < crumbleKeys.length() {
            if crumbleKeys.get(i) == key { return i; }
            i = i + 1;
        }
        return -1;
    }

    expose func getTilePropertyAt(col: Integer, row: Integer,
                                  key: String, defaultValue: Integer) -> Integer {
        if col < 0 { return defaultValue; }
        if row < 0 { return defaultValue; }
        if col >= levelWidth { return defaultValue; }
        if row >= levelHeight { return defaultValue; }
        return tilemap.GetTileProperty(tilemap.GetTile(col, row), key, defaultValue);
    }

    // Update tile animations (call once per frame from game loop)
    expose func updateTileAnims(dt: Integer) {
        tilemap.UpdateAnims(dt);
    }

    // Get the current display tile for a given tile ID (resolves animation)
    expose func resolveAnimTile(tileId: Integer) -> Integer {
        return tilemap.ResolveAnimTile(tileId);
    }

    // Register tile animations (lava, etc.)
    hide func registerTileAnims() {
        tilemap.SetTileAnim(TILE_LAVA, 2, LAVA_ANIM_MS);
    }

    // Register all solid tile types with the Tilemap collision system.
    // Called once after each tilemap creation so IsSolidAt() works.
    hide func registerSolidTiles() {
        tilemap.SetCollision(TILE_GROUND, 1);
        tilemap.SetCollision(TILE_GRASS_TOP, 1);
        tilemap.SetCollision(TILE_STONE, 1);
        tilemap.SetCollision(TILE_DIRT, 1);
        tilemap.SetCollision(TILE_BRICK, 1);
        tilemap.SetCollision(TILE_PLATFORM, 1);
        tilemap.SetCollision(TILE_CAVE_TOP, 1);
        tilemap.SetCollision(TILE_CAVE_WALL, 1);
        tilemap.SetCollision(TILE_BRIDGE, 1);
        tilemap.SetCollision(TILE_MAGMA, 1);
        tilemap.SetCollision(TILE_OBSIDIAN, 1);
        tilemap.SetCollision(TILE_CLOUD, 1);
        tilemap.SetCollision(TILE_SKY_BRICK, 1);
        tilemap.SetCollision(TILE_RUIN_STONE, 1);
        tilemap.SetCollision(TILE_MOSS_STONE, 1);
        tilemap.SetCollision(TILE_JUNGLE_GROUND, 1);
        tilemap.SetCollision(TILE_JUNGLE_PLATFORM, 1);
        tilemap.SetCollision(TILE_MUSHROOM, 1);
        tilemap.SetCollision(TILE_CAVE_CRYSTAL, 1);
        tilemap.SetCollision(TILE_METAL_GRATE, 1);
        tilemap.SetCollision(TILE_MAGMA_ROCK, 1);
        tilemap.SetCollision(TILE_HULL_PLATE, 1);
        tilemap.SetCollision(TILE_GIRDER, 1);
        tilemap.SetCollision(TILE_AIRLOCK, 1);
        tilemap.SetCollision(TILE_PIPE, 1);
        tilemap.SetCollision(TILE_CATWALK, 1);
        tilemap.SetCollision(TILE_CONDUIT, 1);
        tilemap.SetCollision(TILE_CONSOLE, 1);
        tilemap.SetCollision(TILE_HOLO_BRIDGE, 1);
        tilemap.SetCollision(TILE_QUICKSAND, 1);
        tilemap.SetCollision(TILE_CRUMBLE, 1);
        tilemap.SetCollision(TILE_ICE_FLOOR, 1);
        tilemap.SetCollision(TILE_CONVEYOR_L, 1);
        tilemap.SetCollision(TILE_CONVEYOR_R, 1);
        tilemap.SetCollision(TILE_STEAM_VENT, 1);
        tilemap.SetCollision(TILE_DESTRUCTIBLE, 1);
        tilemap.SetCollision(TILE_LOCKED_DOOR, 1);
        registerTileProperties();
    }

    // Register semantic tile metadata once per Tilemap. Physics and interaction
    // code query these properties instead of hard-coding tile ID lists.
    hide func registerTileProperties() {
        tilemap.SetTileProperty(TILE_SPIKE, "hazard", TILE_SPIKE);
        tilemap.SetTileProperty(TILE_LAVA, "hazard", TILE_LAVA);
        tilemap.SetTileProperty(TILE_THORN, "hazard", TILE_THORN);
        tilemap.SetTileProperty(TILE_ELECTRIC, "hazard", TILE_ELECTRIC);
        tilemap.SetTileProperty(TILE_COOLANT, "hazard", TILE_COOLANT);
        tilemap.SetTileProperty(TILE_POISON_POOL, "hazard", TILE_POISON_POOL);

        tilemap.SetTileProperty(TILE_ICE_FLOOR, "surface", 1);
        tilemap.SetTileProperty(TILE_QUICKSAND, "quicksand", 1);
        tilemap.SetTileProperty(TILE_CONVEYOR_L, "conveyor", -1);
        tilemap.SetTileProperty(TILE_CONVEYOR_R, "conveyor", 1);
        tilemap.SetTileProperty(TILE_STEAM_VENT, "steam", 1);
        tilemap.SetTileProperty(TILE_SAVE_STATION, "save", 1);
        tilemap.SetTileProperty(TILE_LORE_TERMINAL, "lore", 1);
        tilemap.SetTileProperty(TILE_CRUMBLE, "crumble", 1);
        tilemap.SetTileProperty(TILE_GRAPPLE_ANCHOR, "grapple", 1);
    }

    /// @brief Add the commercial-release interaction set for one campaign area.
    ///
    /// Every region receives stable save, lore, switch, optional-platform,
    /// keycard, keyed-door, and teleporter records. Underground Lake and
    /// Overgrowth additionally receive their authored ability shrines. Placement
    /// searches for walkable floor near percentage-based design anchors, keeping
    /// procedural fallback builders playable without coordinate-derived ids.
    ///
    /// @param levelNum One-based campaign area number just built by `loadLevel`.
    /// @return Nothing. Appends records, tiles, and one key pickup to the level.
    hide func authorReleaseInteractions(levelNum: Integer) {
        var regionId = levelNum - 1;
        var loreBase = primaryLoreIdForLevel(levelNum);

        // Preserve the original Core fixtures by assigning stable records to
        // their authored coordinates; every other placement uses floor search.
        if levelNum == 10 and getTile(158, levelHeight - 3) == TILE_SAVE_STATION {
            addInteractionRecord(INTERACTION_SAVE_STATION, regionId,
                                 158, levelHeight - 3, regionId, 0);
        } else {
            placeAuthoredInteraction(INTERACTION_SAVE_STATION, regionId,
                                     levelWidth / 5, regionId, 0,
                                     TILE_SAVE_STATION);
        }

        placeAuthoredInteraction(INTERACTION_LORE_TERMINAL, loreBase,
                                 levelWidth * 7 / 20, regionId, loreBase,
                                 TILE_LORE_TERMINAL);
        if levelNum == 10 and getTile(162, levelHeight - 3) == TILE_LORE_TERMINAL {
            addInteractionRecord(INTERACTION_LORE_TERMINAL, loreBase + 1,
                                 162, levelHeight - 3, regionId, loreBase + 1);
        } else {
            placeAuthoredInteraction(INTERACTION_LORE_TERMINAL, loreBase + 1,
                                     levelWidth * 4 / 5, regionId, loreBase + 1,
                                     TILE_LORE_TERMINAL);
        }

        placeAuthoredInteraction(INTERACTION_SWITCH, regionId,
                                 levelWidth * 2 / 5, regionId, 0,
                                 TILE_SWITCH);
        placeSwitchTarget(regionId, levelWidth * 9 / 20);
        addKeyPickupNearFloor(levelWidth / 2);
        placeLockedDoor(regionId, levelWidth * 3 / 5);
        placeAuthoredInteraction(INTERACTION_TELEPORTER, regionId,
                                 levelWidth / 10, regionId, levelNum,
                                 TILE_TELEPORTER);
        placeGrappleAnchors(levelWidth * 3 / 10,
                            levelWidth * 7 / 10);

        if levelNum == 5 {
            placeAuthoredInteraction(INTERACTION_ABILITY_SHRINE, 0,
                                     levelWidth * 11 / 20, regionId,
                                     ABILITY_CHARGE_SHOT, TILE_ABILITY_SHRINE);
        }
        if levelNum == 7 {
            placeAuthoredInteraction(INTERACTION_ABILITY_SHRINE, 1,
                                     levelWidth * 11 / 20, regionId,
                                     ABILITY_GRAPPLE, TILE_ABILITY_SHRINE);
        }
    }

    /// @brief Layer each region's signature traversal surfaces onto its route.
    ///
    /// Placement searches existing safe floor and never assumes a legacy builder's
    /// exact coordinates. Every region receives at least one mechanically active
    /// surface, while later regions combine earlier vocabulary for mastery beats.
    /// The Core retains its original fixtures and gains the complete mechanic set.
    ///
    /// @param levelNum One-based campaign region.
    /// @return Nothing. Replaces bounded surface tiles and adds optional platforms.
    hide func authorRegionalMechanics(levelNum: Integer) {
        if levelNum == 1 {
            placeSurfaceStrip(levelWidth / 4, 4, TILE_CONVEYOR_R);
            placeOneWayBridge(levelWidth * 7 / 20, 4);
            authorGoldSliceLandmark(levelNum);
        }
        if levelNum == 2 {
            placeSurfaceStrip(levelWidth / 3, 5, TILE_QUICKSAND);
            placeSurfaceStrip(levelWidth * 2 / 3, 4, TILE_CRUMBLE);
            authorGoldSliceLandmark(levelNum);
        }
        if levelNum == 3 {
            placeSurfaceStrip(levelWidth / 3, 5, TILE_CRUMBLE);
            placeDestructibleColumn(levelWidth * 3 / 4);
        }
        if levelNum == 4 {
            placeOneWayBridge(levelWidth / 3, 5);
            placeSurfaceStrip(levelWidth * 2 / 3, 5, TILE_CONVEYOR_L);
        }
        if levelNum == 5 {
            placeSurfaceStrip(levelWidth / 3, 6, TILE_QUICKSAND);
            placeOneWayBridge(levelWidth * 2 / 3, 5);
        }
        if levelNum == 6 {
            placeSurfaceStrip(levelWidth / 3, 2, TILE_STEAM_VENT);
            placeSurfaceStrip(levelWidth * 2 / 3, 4, TILE_CONVEYOR_R);
        }
        if levelNum == 7 {
            placeSurfaceStrip(levelWidth / 3, 5, TILE_CRUMBLE);
            placeOneWayBridge(levelWidth * 2 / 3, 6);
        }
        if levelNum == 8 {
            placeSurfaceStrip(levelWidth / 3, 7, TILE_ICE_FLOOR);
            placeSurfaceStrip(levelWidth * 2 / 3, 7, TILE_ICE_FLOOR);
        }
        if levelNum == 9 {
            placeDestructibleColumn(levelWidth / 2);
            placeSurfaceStrip(levelWidth * 3 / 4, 5, TILE_CRUMBLE);
        }
        if levelNum == 10 {
            placeSurfaceStrip(levelWidth / 4, 5, TILE_ICE_FLOOR);
            placeSurfaceStrip(levelWidth / 2, 4, TILE_CONVEYOR_L);
            placeSurfaceStrip(levelWidth * 3 / 4, 2, TILE_STEAM_VENT);
            placeOneWayBridge(levelWidth * 2 / 3, 5);
        }
    }

    /// @brief Add unmistakable Crash Site and Fungal Caverns landmark silhouettes.
    ///
    /// The broken ship spine and elder mushroom crown occupy elevated space so
    /// they enrich navigation without closing the principal ground route. Two
    /// optional salvage pickups reinforce stable secret-room bands 2 and 6.
    ///
    /// @param levelNum One-based region; values other than one/two are no-ops.
    /// @return Nothing. Adds deterministic tiles and pickup records.
    hide func authorGoldSliceLandmark(levelNum: Integer) {
        if levelNum == 1 {
            var i = 0;
            while i < 7 {
                tilemap.SetTile(70 + i, 7 - i / 2, TILE_HULL_PLATE);
                i = i + 1;
            }
            tilemap.SetTile(73, 3, TILE_CONSOLE);
            tilemap.SetTile(74, 3, TILE_CONSOLE);
            addPickup(PICKUP_GEM, levelWidth * 5 / 16, 8);
            addPickup(PICKUP_GEM, levelWidth * 13 / 16, 8);
        }
        if levelNum == 2 {
            addPlatformTile(70, 6, 9, TILE_MUSHROOM);
            var stemRow = 7;
            while stemRow < GROUND_ROW {
                tilemap.SetTile(74, stemRow, TILE_VINE);
                stemRow = stemRow + 1;
            }
            tilemap.SetTile(69, 7, TILE_CRYSTAL);
            tilemap.SetTile(79, 7, TILE_CRYSTAL);
            addPickup(PICKUP_GEM, levelWidth * 5 / 16, 8);
            addPickup(PICKUP_GEM, levelWidth * 13 / 16, 8);
        }
    }

    /// @brief Author the release content anchors shared by all ten regions.
    ///
    /// Every region records a tutorial band, a later mastery band, two elevated
    /// optional caches, a landmark column, and a region-specific combat set piece.
    /// Crash Site/Fungal retain their hand-authored gold-slice landmarks; later
    /// regions receive equally recognizable silhouettes from their own tile set.
    ///
    /// @param levelNum One-based campaign region just built by `loadLevel`.
    /// @return Nothing. Adds visible content and stable structural metadata.
    hide func authorCampaignContent(levelNum: Integer) {
        landmarkCol = levelWidth / 2;
        tutorialStartCol = levelWidth / 4;
        masteryStartCol = levelWidth * 2 / 3;
        setPieceCol = levelWidth * 3 / 4;
        if levelNum > 2 { authorCampaignLandmark(levelNum); }

        var firstSecret = placeSecretCache(levelWidth * 5 / 16);
        var secondSecret = placeSecretCache(levelWidth * 13 / 16);
        if firstSecret >= 0 { secretCols.add(firstSecret); }
        if secondSecret >= 0 { secretCols.add(secondSecret); }
        authorRegionalSetPiece(levelNum);
    }

    /// @brief Draw one unmistakable elevated silhouette for regions three to ten.
    ///
    /// @param levelNum One-based campaign region in 3..10.
    /// @return Nothing. Writes only a bounded landmark around `landmarkCol`.
    hide func authorCampaignLandmark(levelNum: Integer) {
        var center = landmarkCol;
        var baseRow = levelHeight / 2;
        if baseRow < 6 { baseRow = 6; }
        if baseRow > levelHeight - 5 { baseRow = levelHeight - 5; }
        var i = -4;
        while i <= 4 {
            var height = 2 + (4 - absLevelValue(i)) / 2;
            var tile = TILE_CRYSTAL;
            if levelNum == 4 { tile = TILE_RUIN_STONE; }
            if levelNum == 5 { tile = TILE_CAVE_CRYSTAL; }
            if levelNum == 6 { tile = TILE_PIPE; }
            if levelNum == 7 { tile = TILE_MOSS_STONE; }
            if levelNum == 8 { tile = TILE_ICE_FLOOR; }
            if levelNum == 9 { tile = TILE_OBSIDIAN; }
            if levelNum == 10 { tile = TILE_CONSOLE; }
            var h = 0;
            while h < height {
                var col = center + i;
                var row = baseRow - h;
                if col > 1 and col < levelWidth - 2 and row > 1 and
                   getTile(col, row) == TILE_EMPTY {
                    tilemap.SetTile(col, row, tile);
                }
                h = h + 1;
            }
            i = i + 1;
        }
        if levelNum == 6 {
            tilemap.SetTile(center, baseRow + 1, TILE_STEAM_VENT);
        }
        if levelNum == 7 {
            var vineRow = baseRow + 1;
            while vineRow < levelHeight - 2 {
                if getTile(center, vineRow) == TILE_EMPTY {
                    tilemap.SetTile(center, vineRow, TILE_VINE);
                }
                vineRow = vineRow + 1;
            }
        }
        if levelNum == 9 or levelNum == 10 {
            tilemap.SetTile(center - 5, baseRow - 3, TILE_GRAPPLE_ANCHOR);
            tilemap.SetTile(center + 5, baseRow - 3, TILE_GRAPPLE_ANCHOR);
        }
    }

    /// @brief Place one elevated salvage cache near a stable secret-room band.
    ///
    /// @param preferredCol Approximate room-band center column.
    /// @return Actual cache column, or -1 when no safe placement exists.
    hide func placeSecretCache(preferredCol: Integer) -> Integer {
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return -1; }
        var col = key % levelWidth;
        var floorRow = key / levelWidth;
        var row = floorRow - 3;
        if row < 1 { row = 1; }
        while row < floorRow and getTile(col, row) != TILE_EMPTY {
            row = row + 1;
        }
        if row >= floorRow { return -1; }
        addPickup(PICKUP_GEM, col, row);
        return col;
    }

    /// @brief Add a three-enemy regional combat composition near its climax band.
    ///
    /// @param levelNum One-based campaign region selecting the enemy vocabulary.
    /// @return Nothing. Failed individual floor searches are safely skipped.
    hide func authorRegionalSetPiece(levelNum: Integer) {
        var first = ENEMY_SLIME;
        var second = ENEMY_BAT;
        var third = ENEMY_TURRET;
        if levelNum == 1 {
            first = ENEMY_PATROL_DRONE; second = ENEMY_BOMB_CARRIER;
        }
        if levelNum == 2 {
            first = ENEMY_SPOREWALKER; second = ENEMY_GLOWMOTH;
            third = ENEMY_FUNGAL_TURRET;
        }
        if levelNum == 3 {
            first = ENEMY_CRYSTAL_GOLEM; second = ENEMY_SHARD_BAT;
            third = ENEMY_RESONANCE_ORB;
        }
        if levelNum == 4 {
            first = ENEMY_RUIN_GUARDIAN; second = ENEMY_VINE_WHIP;
            third = ENEMY_PATROL_DRONE;
        }
        if levelNum == 5 {
            first = ENEMY_FROST_BEETLE; second = ENEMY_GLOWMOTH;
            third = ENEMY_BOMB_CARRIER;
        }
        if levelNum == 6 {
            first = ENEMY_MAGMA_SLUG; second = ENEMY_EMBER_WASP;
            third = ENEMY_FORGE_SENTINEL;
        }
        if levelNum == 7 {
            first = ENEMY_MOSS_GOLEM; second = ENEMY_VINE_WHIP;
            third = ENEMY_SPOREWALKER;
        }
        if levelNum == 8 {
            first = ENEMY_ICE_WRAITH; second = ENEMY_FROST_BEETLE;
            third = ENEMY_STALACTITE_BAT;
        }
        if levelNum == 9 {
            first = ENEMY_SHADOW_CLONE; second = ENEMY_CORRUPTION;
            third = ENEMY_PATROL_DRONE;
        }
        if levelNum == 10 {
            first = ENEMY_SHADOW_CLONE; second = ENEMY_CORRUPTION;
            third = ENEMY_FORGE_SENTINEL;
        }
        addSetPieceEnemy(first, setPieceCol - 4);
        addSetPieceEnemy(second, setPieceCol);
        addSetPieceEnemy(third, setPieceCol + 4);
    }

    /// @brief Place one set-piece enemy on the nearest safe floor.
    ///
    /// @param enemyType One `ENEMY_*` archetype id.
    /// @param preferredCol Approximate encounter column.
    /// @return True when a spawn record was appended; false if no floor exists.
    hide func addSetPieceEnemy(enemyType: Integer,
                               preferredCol: Integer) -> Boolean {
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return false; }
        addEnemy(enemyType, key % levelWidth, key / levelWidth);
        return true;
    }

    /// @brief Return the nonnegative absolute value used by landmark profiles.
    ///
    /// @param value Signed small integer.
    /// @return Absolute magnitude.
    hide func absLevelValue(value: Integer) -> Integer {
        if value < 0 { return 0 - value; }
        return value;
    }

    /// @brief Replace a bounded safe-floor run with one dynamic surface type.
    ///
    /// @param preferredCol Approximate center column.
    /// @param width Desired positive strip width.
    /// @param tile Registered solid surface tile id.
    /// @return Number of existing solid floor tiles replaced.
    hide func placeSurfaceStrip(preferredCol: Integer, width: Integer,
                               tile: Integer) -> Integer {
        if width <= 0 { return 0; }
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return 0; }
        var centerCol = key % levelWidth;
        var surfaceRow = key / levelWidth + 1;
        var start = centerCol - width / 2;
        if start < 1 { start = 1; }
        if start + width >= levelWidth - 1 {
            start = levelWidth - width - 2;
        }
        var placed = 0;
        var i = 0;
        while i < width {
            var col = start + i;
            if col > 0 and col < levelWidth - 1 and
               surfaceRow > 0 and surfaceRow < levelHeight and
               isSolid(col, surfaceRow) and
               hasInteractionAt(col, surfaceRow) == false {
                tilemap.SetTile(col, surfaceRow, tile);
                placed = placed + 1;
            }
            i = i + 1;
        }
        return placed;
    }

    /// @brief Add an elevated pass-through bridge above an existing safe route.
    ///
    /// @param preferredCol Approximate bridge center.
    /// @param width Desired positive platform width.
    /// @return Number of empty tiles converted to one-way platform tiles.
    hide func placeOneWayBridge(preferredCol: Integer,
                                width: Integer) -> Integer {
        if width <= 0 { return 0; }
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return 0; }
        var centerCol = key % levelWidth;
        var row = key / levelWidth - 3;
        if row < 2 { row = 2; }
        var start = centerCol - width / 2;
        var placed = 0;
        var i = 0;
        while i < width {
            var col = start + i;
            if col > 0 and col < levelWidth - 1 and
               getTile(col, row) == TILE_EMPTY and
               hasInteractionAt(col, row) == false {
                tilemap.SetTile(col, row, TILE_ONE_WAY);
                placed = placed + 1;
            }
            i = i + 1;
        }
        return placed;
    }

    /// @brief Author a three-tile optional charge-shot wall near a safe floor.
    ///
    /// @param preferredCol Approximate wall column.
    /// @return Number of destructible tiles placed in 0..3.
    hide func placeDestructibleColumn(preferredCol: Integer) -> Integer {
        var key = findTallDoorPlacement(preferredCol);
        if key < 0 { return 0; }
        var col = key % levelWidth;
        var baseRow = key / levelWidth - 4;
        if baseRow < 3 { baseRow = 3; }
        var placed = 0;
        var dy = 0;
        while dy < 3 {
            var row = baseRow - dy;
            if row >= 1 and getTile(col, row) == TILE_EMPTY and
               hasInteractionAt(col, row) == false {
                tilemap.SetTile(col, row, TILE_DESTRUCTIBLE);
                placed = placed + 1;
            }
            dy = dy + 1;
        }
        return placed;
    }

    /// @brief Count tiles of one type for structural validation and probes.
    ///
    /// @param tile Tile id to count across the complete regional tilemap.
    /// @return Nonnegative occurrence count, or zero before a level is loaded.
    expose func countTilesOfType(tile: Integer) -> Integer {
        var count = 0;
        var row = 0;
        while row < levelHeight {
            var col = 0;
            while col < levelWidth {
                if getTile(col, row) == tile { count = count + 1; }
                col = col + 1;
            }
            row = row + 1;
        }
        return count;
    }

    /// @brief Map a campaign area to its first stable LoreSystem entry id.
    ///
    /// The lore list is organized by narrative region rather than numeric level
    /// order for Overgrowth/Frozen Abyss, so an explicit mapping prevents content
    /// drift and replaces the former coordinate-modulo behavior.
    ///
    /// @param levelNum One-based area number.
    /// @return Stable zero-based id of the area's first primary lore entry.
    hide func primaryLoreIdForLevel(levelNum: Integer) -> Integer {
        if levelNum == 1 { return 0; }
        if levelNum == 2 { return 2; }
        if levelNum == 3 { return 5; }
        if levelNum == 4 { return 8; }
        if levelNum == 5 { return 10; }
        if levelNum == 6 { return 12; }
        if levelNum == 7 { return 17; }
        if levelNum == 8 { return 15; }
        if levelNum == 9 { return 19; }
        return 21;
    }

    /// @brief Place one visible interaction near a walkable floor anchor.
    ///
    /// @param kind One `INTERACTION_*` type.
    /// @param id Stable authored id stored in saves/content references.
    /// @param preferredCol Preferred tile column before bounded floor search.
    /// @param channel Stable linked channel or owning region id.
    /// @param payload Type-specific value such as lore id or ability flag.
    /// @param tileId Visible tile identity written at the selected coordinate.
    /// @return Room-local record index, or -1 when no safe floor was found.
    hide func placeAuthoredInteraction(kind: Integer, id: Integer,
                                       preferredCol: Integer,
                                       channel: Integer, payload: Integer,
                                       tileId: Integer) -> Integer {
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return -1; }
        var col = key % levelWidth;
        var row = key / levelWidth;
        tilemap.SetTile(col, row, tileId);
        return addInteractionRecord(kind, id, col, row, channel, payload);
    }

    /// @brief Append one stable interaction record without changing its tile.
    ///
    /// @param kind One `INTERACTION_*` type.
    /// @param id Stable authored content/save id.
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @param channel Stable linked switch/region channel.
    /// @param payload Type-specific authored integer.
    /// @return Newly appended room-local record index.
    hide func addInteractionRecord(kind: Integer, id: Integer,
                                   col: Integer, row: Integer,
                                   channel: Integer,
                                   payload: Integer) -> Integer {
        interactionTypes.add(kind);
        interactionIds.add(id);
        interactionCols.add(col);
        interactionRows.add(row);
        interactionChannels.add(channel);
        interactionPayloads.add(payload);
        return interactionTypes.length() - 1;
    }

    /// @brief Locate an empty tile directly above solid walkable geometry.
    ///
    /// Candidate columns alternate right/left around the preferred anchor. Rows
    /// scan bottom-up so interactions favor the main ground route. Existing
    /// authored interaction coordinates are excluded to avoid visual overlap.
    ///
    /// @param preferredCol Desired approximate tile column.
    /// @return Flattened `col + row * levelWidth`, or -1 when unavailable.
    hide func findInteractionPlacement(preferredCol: Integer) -> Integer {
        var offset = 0;
        while offset < levelWidth {
            var candidate = preferredCol;
            if offset > 0 {
                if offset % 2 == 1 {
                    candidate = preferredCol + (offset + 1) / 2;
                } else {
                    candidate = preferredCol - offset / 2;
                }
            }
            if candidate > 1 and candidate < levelWidth - 2 {
                var row = levelHeight - 2;
                while row >= 1 {
                    if getTile(candidate, row) == TILE_EMPTY and
                       isSolid(candidate, row + 1) and
                       hasInteractionAt(candidate, row) == false {
                        return candidate + row * levelWidth;
                    }
                    row = row - 1;
                }
            }
            offset = offset + 1;
        }
        return -1;
    }

    /// @brief Test whether a record already owns one authored tile coordinate.
    ///
    /// @param col Zero-based tile column.
    /// @param row Zero-based tile row.
    /// @return True when any existing interaction record uses the coordinate.
    hide func hasInteractionAt(col: Integer, row: Integer) -> Boolean {
        var i = 0;
        while i < interactionTypes.length() {
            if interactionCols.get(i) == col and interactionRows.get(i) == row {
                return true;
            }
            i = i + 1;
        }
        return false;
    }

    /// @brief Author a three-tile optional holographic platform for one switch.
    ///
    /// The platform sits three tiles above nearby ground and starts absent. Each
    /// tile shares the same channel so `applyPersistentInteractionState` toggles
    /// the full shortcut atomically on later loads.
    ///
    /// @param channel Stable switch channel.
    /// @param preferredCol Approximate platform center column.
    /// @return Nothing when placement is unavailable; otherwise appends records.
    hide func placeSwitchTarget(channel: Integer, preferredCol: Integer) {
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return; }
        var centerCol = key % levelWidth;
        var targetRow = key / levelWidth - 3;
        if targetRow < 1 { return; }
        var dx = -1;
        while dx <= 1 {
            var col = centerCol + dx;
            if getTile(col, targetRow) == TILE_EMPTY {
                addInteractionRecord(INTERACTION_SWITCH_TARGET,
                                     channel * 3 + dx + 1,
                                     col, targetRow, channel, 0);
                tilemap.SetTile(col, targetRow, TILE_EMPTY);
            }
            dx = dx + 1;
        }
    }

    /// @brief Place two elevated, non-solid grapple anchors in every region.
    ///
    /// Early regions preview the eventual traversal language; later areas use
    /// the same deterministic fallback anchors for required Grapple routing.
    /// Placement derives an open point above safe floor without creating a new
    /// persistent interaction id.
    ///
    /// @param firstCol Preferred column for the first anchor.
    /// @param secondCol Preferred column for the second anchor.
    /// @return Nothing. Unavailable candidates are skipped independently.
    hide func placeGrappleAnchors(firstCol: Integer, secondCol: Integer) {
        placeGrappleAnchor(firstCol);
        placeGrappleAnchor(secondCol);
    }

    /// @brief Place one elevated grapple anchor above a walkable-floor result.
    ///
    /// @param preferredCol Approximate horizontal placement column.
    /// @return True when an empty anchor tile was written; false otherwise.
    hide func placeGrappleAnchor(preferredCol: Integer) -> Boolean {
        var key = findGrappleAnchorPlacement(preferredCol);
        if key < 0 { return false; }
        var col = key % levelWidth;
        var row = key / levelWidth;
        tilemap.SetTile(col, row, TILE_GRAPPLE_ANCHOR);
        return true;
    }

    /// @brief Locate open elevated space near an authored horizontal anchor.
    ///
    /// Search begins six rows above the bottom and moves upward, keeping anchors
    /// within acquisition range of the principal ground route while avoiding
    /// solid platforms. Candidate columns alternate around the preferred value.
    ///
    /// @param preferredCol Desired approximate anchor column.
    /// @return Flattened empty tile coordinate, or -1 when the level is full.
    hide func findGrappleAnchorPlacement(preferredCol: Integer) -> Integer {
        var offset = 0;
        while offset < levelWidth {
            var candidate = preferredCol;
            if offset > 0 {
                if offset % 2 == 1 {
                    candidate = preferredCol + (offset + 1) / 2;
                } else {
                    candidate = preferredCol - offset / 2;
                }
            }
            if candidate > 1 and candidate < levelWidth - 2 {
                var row = levelHeight - 6;
                while row >= 2 {
                    if getTile(candidate, row) == TILE_EMPTY and
                       hasInteractionAt(candidate, row) == false {
                        return candidate + row * levelWidth;
                    }
                    row = row - 1;
                }
            }
            offset = offset + 1;
        }
        return -1;
    }

    /// @brief Add the region keycard pickup before its keyed door anchor.
    ///
    /// Pickup type remains the existing `PICKUP_KEY`; Game maps it to the stable
    /// current-region id, making repeated room spawns harmless and idempotent.
    ///
    /// @param preferredCol Approximate pickup column.
    /// @return Nothing when no safe floor placement exists.
    hide func addKeyPickupNearFloor(preferredCol: Integer) {
        var key = findInteractionPlacement(preferredCol);
        if key < 0 { return; }
        addPickup(PICKUP_KEY, key % levelWidth, key / levelWidth);
    }

    /// @brief Author a three-tile-high keyed door sharing one persistent id.
    ///
    /// @param doorId Stable door/keycard id, normally the region id.
    /// @param preferredCol Approximate main-route gate column.
    /// @return Nothing when suitable empty vertical space cannot be authored.
    hide func placeLockedDoor(doorId: Integer, preferredCol: Integer) {
        var key = findTallDoorPlacement(preferredCol);
        if key < 0 { return; }
        var col = key % levelWidth;
        var baseRow = key / levelWidth;
        var dy = 0;
        while dy < 3 {
            var row = baseRow - dy;
            if row >= 1 and getTile(col, row) == TILE_EMPTY {
                tilemap.SetTile(col, row, TILE_LOCKED_DOOR);
                addInteractionRecord(INTERACTION_LOCKED_DOOR, doorId,
                                     col, row, doorId, doorId);
            }
            dy = dy + 1;
        }
    }

    /// @brief Locate three empty vertical tiles above a solid floor for a door.
    ///
    /// The search mirrors `findInteractionPlacement` but rejects low ceilings
    /// and platform clutter so every keyed door forms the intended three-tile
    /// barrier instead of silently authoring a partial, jumpable gate.
    ///
    /// @param preferredCol Desired approximate gate column.
    /// @return Flattened coordinate of the lowest door tile, or -1 if unavailable.
    hide func findTallDoorPlacement(preferredCol: Integer) -> Integer {
        var offset = 0;
        while offset < levelWidth {
            var candidate = preferredCol;
            if offset > 0 {
                if offset % 2 == 1 {
                    candidate = preferredCol + (offset + 1) / 2;
                } else {
                    candidate = preferredCol - offset / 2;
                }
            }
            if candidate > 1 and candidate < levelWidth - 2 {
                var row = levelHeight - 2;
                while row >= 3 {
                    if getTile(candidate, row) == TILE_EMPTY and
                       getTile(candidate, row - 1) == TILE_EMPTY and
                       getTile(candidate, row - 2) == TILE_EMPTY and
                       isSolid(candidate, row + 1) and
                       hasInteractionAt(candidate, row) == false and
                       hasInteractionAt(candidate, row - 1) == false and
                       hasInteractionAt(candidate, row - 2) == false {
                        return candidate + row * levelWidth;
                    }
                    row = row - 1;
                }
            }
            offset = offset + 1;
        }
        return -1;
    }

    // Add enemy spawn
    hide func addEnemy(etype: Integer, col: Integer, row: Integer) {
        enemyTypes.add(etype);
        enemyX.add(col * TILE_SIZE);
        enemyY.add(row * TILE_SIZE);
    }

    // Add pickup spawn
    hide func addPickup(ptype: Integer, col: Integer, row: Integer) {
        pickupTypes.add(ptype);
        pickupX.add(col * TILE_SIZE + TILE_SIZE / 4);
        pickupY.add(row * TILE_SIZE + TILE_SIZE / 4);
    }

    // Fill a row range with a tile
    hide func fillRow(row: Integer, startCol: Integer, endCol: Integer, tile: Integer) {
        var c = startCol;
        while c <= endCol {
            tilemap.SetTile(c, row, tile);
            c = c + 1;
        }
    }

    // Fill a rectangular area with a tile
    hide func fillArea(startCol: Integer, startRow: Integer, endCol: Integer, endRow: Integer, tile: Integer) {
        var r = startRow;
        while r <= endRow {
            fillRow(r, startCol, endCol, tile);
            r = r + 1;
        }
    }

    // Helper: fill a row with a specific tile type
    hide func fillRowTile(row: Integer, startCol: Integer, endCol: Integer, tile: Integer) {
        var c = startCol;
        while c <= endCol {
            tilemap.SetTile(c, row, tile);
            c = c + 1;
        }
    }

    // Helper: place a platform of a specific tile type
    hide func addPlatformTile(col: Integer, row: Integer, width: Integer, tile: Integer) {
        var c = col;
        while c < col + width {
            tilemap.SetTile(c, row, tile);
            c = c + 1;
        }
    }

    // =========================================================================
    // XENOSCAPE LEVEL: "Descent"
    // Single 150-tile level: Jungle(0-49) → Caves(50-99) → Thermal(100-149)
    // =========================================================================

    hide func buildDescent() {
        levelWidth = 150;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_GRASSLANDS;     // background switches dynamically by column

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        // Player starts in the jungle canopy
        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

        // ==== BIOME 1: ALIEN JUNGLE (cols 0-49) ====

        // Ground: jungle soil across the full jungle section
        fillRowTile(GROUND_ROW, 0, 49, TILE_JUNGLE_GROUND);
        fillRowTile(FLOOR_ROW, 0, 49, TILE_DIRT);

        // --- Jungle Section 1: Landing zone (cols 0-12) ---
        // Gentle intro, scattered coins
        addPlatformTile(6, 12, 4, TILE_JUNGLE_PLATFORM);
        addPlatformTile(11, 10, 3, TILE_JUNGLE_PLATFORM);
        addPickup(PICKUP_COIN, 7, 11);
        addPickup(PICKUP_COIN, 8, 11);
        addPickup(PICKUP_COIN, 12, 9);
        addPickup(PICKUP_COIN, 5, 14);
        addPickup(PICKUP_COIN, 9, 14);

        // --- Jungle Section 2: Canopy climb (cols 13-25) ---
        addPlatformTile(14, 12, 3, TILE_JUNGLE_PLATFORM);
        addPlatformTile(18, 10, 4, TILE_JUNGLE_PLATFORM);
        addPlatformTile(23, 8, 3, TILE_JUNGLE_PLATFORM);
        addPlatformTile(16, 14, 2, TILE_MUSHROOM);            // bouncy!
        // Vine bridge (narrow platform)
        addPlatformTile(20, 13, 5, TILE_BRIDGE);
        // First enemy
        addEnemy(ENEMY_SLIME, 22, 14);
        addPickup(PICKUP_COIN, 19, 9);
        addPickup(PICKUP_COIN, 20, 9);
        addPickup(PICKUP_COIN, 24, 7);
        addPickup(PICKUP_HEALTH, 24, 12);

        // --- Jungle Section 3: Gap crossing (cols 26-38) ---
        // Gap in the ground
        clearGround(28, 31);
        // Thorns in the gap
        fillRowTile(FLOOR_ROW, 28, 31, TILE_THORN);
        // Platforms over the gap
        addPlatformTile(28, 12, 2, TILE_JUNGLE_PLATFORM);
        addPlatformTile(31, 10, 2, TILE_JUNGLE_PLATFORM);
        addPlatformTile(27, 14, 1, TILE_MUSHROOM);
        // Bat patrolling the canopy
        addEnemy(ENEMY_BAT, 30, 8);
        addEnemy(ENEMY_SLIME, 35, 14);
        addPickup(PICKUP_COIN, 29, 11);
        addPickup(PICKUP_COIN, 32, 9);
        addPickup(PICKUP_SPEED, 34, 14);

        // --- Jungle Section 4: Descent entry (cols 39-49) ---
        // Ground slopes down (step platforms at lower rows)
        addPlatformTile(40, 13, 3, TILE_JUNGLE_GROUND);
        addPlatformTile(43, 12, 3, TILE_JUNGLE_GROUND);
        fillArea(44, 13, 49, FLOOR_ROW, TILE_DIRT);
        // Checkpoint before cave entrance
        tilemap.SetTile(46, 11, TILE_CHECKPOINT);
        checkpointX = 46 * TILE_SIZE;
        checkpointY = 10 * TILE_SIZE;
        hasCheckpoint = true;
        addPickup(PICKUP_COIN, 41, 12);
        addPickup(PICKUP_COIN, 44, 11);
        addEnemy(ENEMY_SLIME, 48, 11);

        // ==== BIOME 2: CRYSTAL CAVERNS (cols 50-99) ====

        // Cave ceiling and floor
        fillRowTile(0, 50, 99, TILE_CAVE_TOP);
        fillRowTile(1, 50, 99, TILE_CAVE_WALL);
        fillRowTile(GROUND_ROW, 50, 99, TILE_CAVE_WALL);
        fillRowTile(FLOOR_ROW, 50, 99, TILE_CAVE_WALL);

        // --- Cave Section 1: Crystal entrance (cols 50-62) ---
        addPlatformTile(52, 12, 4, TILE_CAVE_CRYSTAL);
        addPlatformTile(57, 10, 3, TILE_CAVE_CRYSTAL);
        addPlatformTile(61, 12, 3, TILE_STONE);
        // Crystal decorations
        tilemap.SetTile(54, 13, TILE_CRYSTAL);
        tilemap.SetTile(59, 11, TILE_CRYSTAL);
        addPickup(PICKUP_COIN, 53, 11);
        addPickup(PICKUP_COIN, 58, 9);
        addPickup(PICKUP_COIN, 62, 11);
        addEnemy(ENEMY_BAT, 56, 8);

        // --- Cave Section 2: Turret gauntlet (cols 63-75) ---
        addPlatformTile(64, 12, 5, TILE_STONE);
        addPlatformTile(70, 10, 4, TILE_STONE);
        addPlatformTile(66, 8, 3, TILE_CAVE_CRYSTAL);
        // Turrets on walls
        addEnemy(ENEMY_TURRET, 68, 11);
        addEnemy(ENEMY_TURRET, 73, 9);
        addPickup(PICKUP_COIN, 65, 11);
        addPickup(PICKUP_COIN, 67, 7);
        addPickup(PICKUP_COIN, 71, 9);
        addPickup(PICKUP_SHIELD, 72, 11);

        // --- Cave Section 3: Underground river (cols 76-88) ---
        // Gap with lava below
        clearGround(78, 83);
        fillRowTile(FLOOR_ROW, 78, 83, TILE_LAVA);
        // Narrow platforms over lava
        addPlatformTile(78, 12, 2, TILE_STONE);
        addPlatformTile(81, 10, 2, TILE_CAVE_CRYSTAL);
        addPlatformTile(84, 12, 2, TILE_STONE);
        addEnemy(ENEMY_BAT, 80, 7);
        addEnemy(ENEMY_BAT, 83, 9);
        addPickup(PICKUP_COIN, 79, 11);
        addPickup(PICKUP_COIN, 82, 9);

        // --- Cave Section 4: Cave exit (cols 89-99) ---
        addPlatformTile(90, 11, 4, TILE_STONE);
        addPlatformTile(95, 13, 3, TILE_STONE);
        addEnemy(ENEMY_SLIME, 92, 10);
        addEnemy(ENEMY_TURRET, 97, 12);
        addPickup(PICKUP_COIN, 91, 10);
        addPickup(PICKUP_COIN, 96, 12);
        addPickup(PICKUP_RAPIDFIRE, 93, 14);
        // Checkpoint before thermal zone
        tilemap.SetTile(98, 12, TILE_CHECKPOINT);

        // ==== BIOME 3: THERMAL VENTS (cols 100-149) ====

        // Magma rock ground
        fillRowTile(GROUND_ROW, 100, 149, TILE_MAGMA_ROCK);
        fillRowTile(FLOOR_ROW, 100, 149, TILE_MAGMA_ROCK);

        // --- Thermal Section 1: Grate walkways (cols 100-112) ---
        addPlatformTile(101, 12, 5, TILE_METAL_GRATE);
        addPlatformTile(107, 10, 4, TILE_METAL_GRATE);
        addPlatformTile(112, 12, 3, TILE_METAL_GRATE);
        // Lava pit
        clearGround(104, 106);
        fillRowTile(FLOOR_ROW, 104, 106, TILE_LAVA);
        addEnemy(ENEMY_SLIME, 103, 11);
        addEnemy(ENEMY_SLIME, 110, 9);
        addPickup(PICKUP_COIN, 102, 11);
        addPickup(PICKUP_COIN, 108, 9);
        addPickup(PICKUP_COIN, 113, 11);
        addPickup(PICKUP_HEALTH, 105, 8);

        // --- Thermal Section 2: Lava river (cols 113-125) ---
        clearGround(115, 122);
        fillRowTile(FLOOR_ROW, 115, 122, TILE_LAVA);
        // Platforms above lava
        addPlatformTile(115, 11, 2, TILE_METAL_GRATE);
        addPlatformTile(118, 9, 2, TILE_METAL_GRATE);
        addPlatformTile(121, 11, 2, TILE_METAL_GRATE);
        addPlatformTile(124, 13, 2, TILE_MAGMA_ROCK);
        addEnemy(ENEMY_TURRET, 117, 10);
        addEnemy(ENEMY_BAT, 120, 6);
        addPickup(PICKUP_COIN, 116, 10);
        addPickup(PICKUP_COIN, 119, 8);
        addPickup(PICKUP_COIN, 122, 10);

        // --- Thermal Section 3: Boss approach (cols 126-135) ---
        addPlatformTile(127, 12, 4, TILE_METAL_GRATE);
        addPlatformTile(132, 10, 3, TILE_METAL_GRATE);
        addEnemy(ENEMY_SLIME, 130, 11);
        addEnemy(ENEMY_TURRET, 134, 9);
        addPickup(PICKUP_HEALTH, 128, 11);
        addPickup(PICKUP_SHIELD, 133, 9);

        // --- Thermal Section 4: Boss arena (cols 130-149) ---
        // Wide flat arena with solid ground and containment walls
        fillRowTile(GROUND_ROW, 130, 149, TILE_METAL_GRATE);
        // Left wall to contain boss (prevents falling into lava river)
        fillArea(130, 8, 130, FLOOR_ROW, TILE_MAGMA_ROCK);
        // Right wall at level edge
        fillArea(149, 8, 149, FLOOR_ROW, TILE_MAGMA_ROCK);
        // Boss spawn — centered in arena
        bossX = 140 * TILE_SIZE;
        bossY = (GROUND_ROW - 3) * TILE_SIZE;
        hasBoss = true;
        // End sign (after boss area)
        tilemap.SetTile(148, GROUND_ROW - 1, TILE_SIGN_END);
    }

    // =========================================================================
    // Reusable Section Helpers
    // =========================================================================

    // Build a platform run with coins spaced above it.
    hide func buildPlatformRun(col: Integer, row: Integer, width: Integer,
                                tile: Integer, coinRow: Integer) {
        addPlatformTile(col, row, width, tile);
        // Place coins every 2-3 tiles above the platform
        var c = col + 1;
        while c < col + width - 1 {
            addPickup(PICKUP_COIN, c, coinRow);
            c = c + 2;
        }
    }

    // Build a gap in the ground with a hazard tile at the bottom.
    hide func buildGapWithHazard(gapStart: Integer, gapEnd: Integer,
                                  hazardTile: Integer) {
        clearGround(gapStart, gapEnd);
        fillRowTile(FLOOR_ROW, gapStart, gapEnd, hazardTile);
    }

    // Build a flat boss arena with containment walls on both sides.
    hide func buildArena(startCol: Integer, endCol: Integer,
                          floorTile: Integer, wallTile: Integer) {
        fillRowTile(GROUND_ROW, startCol, endCol, floorTile);
        // Left wall
        fillArea(startCol, 6, startCol, FLOOR_ROW, wallTile);
        // Right wall
        fillArea(endCol, 6, endCol, FLOOR_ROW, wallTile);
    }

    // =========================================================================
    // Level 2: "Salvage" — Crashed Space Station
    // Biome 1: Outer Hull (cols 0-49)
    // Biome 2: Reactor Core (cols 50-99)
    // Biome 3: Command Bridge + ARIA Boss (cols 100-149)
    // =========================================================================

    hide func buildSalvage() {
        levelWidth = 150;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_CAVE;

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

        // ==== BIOME 1: OUTER HULL (cols 0-49) ====

        // The wreck's outer hull has been absorbed into a living fungal shelf.
        fillRowTile(GROUND_ROW, 0, 49, TILE_MOSS_STONE);
        fillRowTile(FLOOR_ROW, 0, 49, TILE_DIRT);
        fillRowTile(0, 0, 49, TILE_CAVE_TOP);
        fillRowTile(1, 0, 49, TILE_CAVE_WALL);

        // --- Hull Section 1: Entry airlock (cols 0-12) ---
        buildPlatformRun(6, 12, 4, TILE_MUSHROOM, 11);
        buildPlatformRun(11, 10, 3, TILE_JUNGLE_PLATFORM, 9);
        addPickup(PICKUP_COIN, 4, 14);
        addPickup(PICKUP_COIN, 8, 14);

        // --- Hull Section 2: Hull breach gap (cols 13-25) ---
        buildGapWithHazard(16, 20, TILE_POISON_POOL);
        buildPlatformRun(16, 11, 2, TILE_MUSHROOM, 10);
        buildPlatformRun(19, 9, 2, TILE_MUSHROOM, 8);
        addEnemy(ENEMY_GLOWMOTH, 18, 7);
        addPickup(PICKUP_COIN, 17, 10);
        addPickup(PICKUP_COIN, 20, 8);
        addPickup(PICKUP_HEALTH, 22, 14);

        // --- Hull Section 3: Debris field (cols 26-38) ---
        buildPlatformRun(27, 12, 3, TILE_HULL_PLATE, 11);
        buildPlatformRun(31, 10, 4, TILE_GIRDER, 9);
        buildPlatformRun(36, 12, 3, TILE_HULL_PLATE, 11);
        addEnemy(ENEMY_SPOREWALKER, 29, 11);
        addEnemy(ENEMY_GLOWMOTH, 34, 7);
        addPickup(PICKUP_COIN, 28, 11);
        addPickup(PICKUP_COIN, 33, 9);
        addPickup(PICKUP_COIN, 37, 11);
        addPickup(PICKUP_SPEED, 35, 14);

        // --- Hull Section 4: Transition to reactor (cols 39-49) ---
        buildPlatformRun(40, 13, 3, TILE_HULL_PLATE, 12);
        buildPlatformRun(44, 11, 4, TILE_HULL_PLATE, 10);
        addEnemy(ENEMY_SPOREWALKER, 42, 12);
        addEnemy(ENEMY_GLOWMOTH, 46, 8);
        addPickup(PICKUP_COIN, 41, 12);
        addPickup(PICKUP_COIN, 45, 10);
        // Checkpoint
        tilemap.SetTile(48, GROUND_ROW - 1, TILE_CHECKPOINT);
        checkpointX = 48 * TILE_SIZE;
        checkpointY = (GROUND_ROW - 2) * TILE_SIZE;
        hasCheckpoint = true;

        // ==== BIOME 2: REACTOR CORE (cols 50-99) ====

        // Mycelial sink: old machinery is visible only beneath root tissue.
        fillRowTile(0, 50, 99, TILE_CAVE_TOP);
        fillRowTile(1, 50, 99, TILE_CAVE_WALL);
        fillRowTile(GROUND_ROW, 50, 99, TILE_MOSS_STONE);
        fillRowTile(FLOOR_ROW, 50, 99, TILE_CAVE_WALL);

        // --- Reactor Section 1: Pipe walkways (cols 50-62) ---
        buildPlatformRun(52, 12, 4, TILE_PIPE, 11);
        buildPlatformRun(57, 10, 3, TILE_PIPE, 9);
        buildPlatformRun(61, 12, 3, TILE_CATWALK, 11);
        addEnemy(ENEMY_FUNGAL_TURRET, 55, 11);
        addPickup(PICKUP_COIN, 53, 11);
        addPickup(PICKUP_COIN, 58, 9);
        addPickup(PICKUP_COIN, 62, 11);

        // --- Reactor Section 2: Coolant river (cols 63-75) ---
        buildGapWithHazard(66, 72, TILE_QUICKSAND);
        buildPlatformRun(66, 11, 2, TILE_CATWALK, 10);
        buildPlatformRun(69, 9, 2, TILE_PIPE, 8);
        buildPlatformRun(72, 11, 2, TILE_CATWALK, 10);
        addEnemy(ENEMY_GLOWMOTH, 68, 6);
        addEnemy(ENEMY_GLOWMOTH, 71, 8);
        addPickup(PICKUP_COIN, 67, 10);
        addPickup(PICKUP_COIN, 70, 8);
        addPickup(PICKUP_COIN, 73, 10);
        addPickup(PICKUP_SHIELD, 75, 14);

        // --- Reactor Section 3: Turret gauntlet (cols 76-90) ---
        buildPlatformRun(77, 12, 5, TILE_CATWALK, 11);
        buildPlatformRun(83, 10, 4, TILE_PIPE, 9);
        buildPlatformRun(88, 12, 3, TILE_CATWALK, 11);
        addEnemy(ENEMY_FUNGAL_TURRET, 80, 11);
        addEnemy(ENEMY_MYCELIUM, 86, 9);
        addEnemy(ENEMY_SPOREWALKER, 90, 11);
        addPickup(PICKUP_COIN, 78, 11);
        addPickup(PICKUP_COIN, 84, 9);
        addPickup(PICKUP_COIN, 89, 11);
        addPickup(PICKUP_RAPIDFIRE, 82, 14);

        // --- Reactor Section 4: Bridge approach (cols 91-99) ---
        buildPlatformRun(92, 11, 4, TILE_CATWALK, 10);
        addEnemy(ENEMY_FUNGAL_TURRET, 96, 10);
        addPickup(PICKUP_HEALTH, 93, 10);
        addPickup(PICKUP_COIN, 97, 14);
        // Checkpoint
        tilemap.SetTile(98, GROUND_ROW - 1, TILE_CHECKPOINT);

        // ==== BIOME 3: COMMAND BRIDGE (cols 100-149) ====

        // Brood galleries and the Spore Mother's root chamber.
        fillRowTile(0, 100, 149, TILE_CAVE_TOP);
        fillRowTile(GROUND_ROW, 100, 149, TILE_MOSS_STONE);
        fillRowTile(FLOOR_ROW, 100, 149, TILE_CAVE_WALL);

        // --- Bridge Section 1: Console corridors (cols 100-115) ---
        buildPlatformRun(102, 12, 4, TILE_HOLO_BRIDGE, 11);
        buildPlatformRun(107, 10, 3, TILE_CONSOLE, 9);
        buildPlatformRun(112, 12, 3, TILE_HOLO_BRIDGE, 11);
        addEnemy(ENEMY_GLOWMOTH, 105, 7);
        addEnemy(ENEMY_FUNGAL_TURRET, 110, 9);
        addPickup(PICKUP_COIN, 103, 11);
        addPickup(PICKUP_COIN, 108, 9);
        addPickup(PICKUP_COIN, 113, 11);

        // --- Bridge Section 2: Data stream gap (cols 116-128) ---
        buildGapWithHazard(118, 124, TILE_POISON_POOL);
        buildPlatformRun(118, 11, 2, TILE_HOLO_BRIDGE, 10);
        buildPlatformRun(121, 9, 2, TILE_HOLO_BRIDGE, 8);
        buildPlatformRun(124, 11, 2, TILE_HOLO_BRIDGE, 10);
        addEnemy(ENEMY_GLOWMOTH, 120, 6);
        addEnemy(ENEMY_MYCELIUM, 126, 10);
        addPickup(PICKUP_COIN, 119, 10);
        addPickup(PICKUP_COIN, 122, 8);
        addPickup(PICKUP_HEALTH, 127, 14);
        addPickup(PICKUP_SHIELD, 125, 10);

        // --- Bridge Section 3: Boss arena (cols 129-149) ---
        buildArena(129, 149, TILE_MOSS_STONE, TILE_CAVE_WALL);
        bossX = 140 * TILE_SIZE;
        bossY = (GROUND_ROW - 3) * TILE_SIZE;
        hasBoss = true;
        bossType = ENEMY_SPORE_MOTHER;
        tilemap.SetTile(148, GROUND_ROW - 1, TILE_SIGN_END);
    }

    // =========================================================================
    // Level 3: "Frozen Abyss" — Ice Caverns
    // Uses existing tile types: STONE, CRYSTAL, CAVE_WALL, SPIKE, BRIDGE
    // Reuses cave/crystal biome backgrounds with a frozen color twist
    // =========================================================================

    hide func buildFrozenAbyss() {
        levelWidth = 150;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_CAVE;  // reuse cave background (blue-purple works for ice)

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

        // ==== BIOME 1: Frozen Surface (cols 0-49) ====
        fillRowTile(GROUND_ROW, 0, 49, TILE_STONE);
        fillRowTile(FLOOR_ROW, 0, 49, TILE_STONE);

        // Intro platforms
        buildPlatformRun(6, 12, 4, TILE_PLATFORM, 11);
        buildPlatformRun(12, 10, 3, TILE_STONE, 9);
