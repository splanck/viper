        addPickup(PICKUP_SHIELD, 180, 14);

        // Boss spawn — Crystal Wyrm (unique to this level)
        bossX = 195 * TILE_SIZE;
        bossY = (GROUND_ROW - 3) * TILE_SIZE;
        hasBoss = true;
        bossType = ENEMY_CRYSTAL_WYRM;

        // End sign (after boss)
        tilemap.SetTile(215, GROUND_ROW - 1, TILE_SIGN_END);
