        addPickup(PICKUP_COIN, 209, 10);

        addEnemy(ENEMY_BAT, 200, 4);
        addEnemy(ENEMY_SLIME, 212, 14);

        // Thermal Vents now has the boss encounter promised by progression.
        // The ground-pound unlock is tied to defeating this Magma Core.
        fillRow(GROUND_ROW, 213, 225, TILE_MAGMA);
        fillRow(FLOOR_ROW, 213, 225, TILE_MAGMA);
        addPickup(PICKUP_HEALTH, 216, 14);
        addPickup(PICKUP_SHIELD, 218, 14);
        bossX = 214 * TILE_SIZE;
        bossY = (GROUND_ROW - 3) * TILE_SIZE;
        hasBoss = true;
        bossType = ENEMY_MAGMA_CORE;

        // End sign
        tilemap.SetTile(225, GROUND_ROW - 1, TILE_SIGN_END);
    }

    // =========================================================================
    // Level 4: Sky Fortress
    // =========================================================================

    hide func buildSkyFortress() {
        levelWidth = LEVEL4_WIDTH;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_SKY;

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        // Cloud ground (no bottom row — sky below)
        fillRow(GROUND_ROW, 0, 30, TILE_CLOUD);
        fillRow(FLOOR_ROW, 0, 30, TILE_SKY_BRICK);

        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

        // --- Section 1: Cloud platforms (cols 0-45) ---
        addPlatform(8, 12, 5);
        addPlatform(15, 10, 4);
