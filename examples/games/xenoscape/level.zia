        // Obsidian stepping stones over lava
        fillArea(35, 13, 37, 13, TILE_OBSIDIAN);
        fillArea(40, 11, 42, 11, TILE_OBSIDIAN);
        fillArea(44, 13, 45, 13, TILE_OBSIDIAN);

