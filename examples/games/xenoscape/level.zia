        addPickup(PICKUP_COIN, 41, 10);
        addPickup(PICKUP_HEALTH, 44, 12);

        addEnemy(ENEMY_BAT, 38, 5);
        addEnemy(ENEMY_BAT, 43, 4);

        // --- Section 2: Ascending volcano (cols 45-90) ---
