        addPickup(PICKUP_COIN, 106, 10);
        addPickup(PICKUP_COIN, 113, 12);
        addPickup(PICKUP_COIN, 120, 9);
        addPickup(PICKUP_COIN, 127, 11);
        addPickup(PICKUP_SHIELD, 115, 12);

        addEnemy(ENEMY_BAT, 103, 4);
        addEnemy(ENEMY_BAT, 117, 5);
        addEnemy(ENEMY_TURRET, 130, 14);

        // --- Section 4: Magma chamber + turret gauntlet (cols 140-185) ---
        fillRow(GROUND_ROW, 138, 180, TILE_MAGMA);
        fillRow(FLOOR_ROW, 138, 180, TILE_MAGMA);

        addEnemy(ENEMY_TURRET, 145, 14);
        addEnemy(ENEMY_TURRET, 155, 14);
        addEnemy(ENEMY_TURRET, 165, 14);

        addPlatform(148, 10, 3);
