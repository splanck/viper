    hide func buildOvergrowth() {
        levelWidth = 150;
        levelHeight = LEVEL_HEIGHT;
        levelTheme = THEME_RUINS;

        tilemap = Tilemap.New(levelWidth, levelHeight, TILE_SIZE, TILE_SIZE);
        registerSolidTiles();
        registerTileAnims();

        playerStartX = 3 * TILE_SIZE;
        playerStartY = (GROUND_ROW - 2) * TILE_SIZE;

