        addEnemy(ENEMY_BAT, 78, 3);

        // Checkpoint
        tilemap.SetTile(90, GROUND_ROW - 1, TILE_CHECKPOINT);
        checkpointX = 90 * TILE_SIZE;
        checkpointY = (GROUND_ROW - 2) * TILE_SIZE;
        hasCheckpoint = true;

        // --- Section 3: Deep sanctum (cols 100-180) ---
        // Descending corridor with moss stone walls
        fillArea(100, 4, 101, 14, TILE_MOSS_STONE);
        fillArea(105, 6, 106, 14, TILE_MOSS_STONE);
        fillArea(110, 4, 111, 14, TILE_MOSS_STONE);

        addPlatform(102, 10, 3);
        addPlatform(107, 8, 3);
        addPlatform(112, 6, 3);

        addPickup(PICKUP_COIN, 103, 9);
        addPickup(PICKUP_COIN, 108, 7);
        addPickup(PICKUP_COIN, 113, 5);
        addPickup(PICKUP_SPEED, 108, 6);

        addEnemy(ENEMY_BAT, 104, 3);
