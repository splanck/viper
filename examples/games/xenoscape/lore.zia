//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/lore.zia
// Purpose: Owns stable lore/bestiary content and nonblocking archive surfaces.
// Key invariants:
//   - Authored lore ids remain stable because collected masks persist by index.
//   - Gameplay lore uses one modal typewriter while archive screens are read-only.
// Ownership/Lifetime:
//   - Game owns one LoreSystem and its retained content/typewriter objects.
// Links: game.zia, level.zia, save.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — ENVIRONMENTAL STORYTELLING IN PLATFORMERS
// ----------------------------------------------------
// Two ways a platformer tells its story:
//
//   1. **Cutscenes** — dedicated "story-only" screens.
//      Expensive to build, hard to skip respectfully, break
//      the gameplay flow.
//
//   2. **Environmental storytelling** — lore fragments
//      scattered through levels that the player finds by
//      exploring.  Each fragment is tiny; together they
//      reveal the world.  Dark Souls, Hollow Knight, Hyper
//      Light Drifter all lean on this.
//
// Xenoscape uses the second approach.  Lore terminals are
// special tile types (see `physics.zia::isNearLoreTerminal`)
// scattered through levels.  When the player approaches and
// presses interact, this subsystem:
//
//   1. Pauses gameplay.
//   2. Fades in a text panel.
//   3. Types out the lore entry character-by-character via
//      `Zanna.Game.Typewriter` — faster than a cutscene but
//      slower than plain text, which draws the player's
//      eye.
//   4. Records the entry in a "collected" bitmask (shown in
//      the pause-menu's lore tab).
//   5. Resumes gameplay on dismiss.
//
// STORY
// -----
// You're an astronaut from the colony ship XENOSCAPE,
// crash-landed on an uncharted world.  The ship's AI — the
// Architect — has gone rogue and is corrupting the
// ecosystem.  You explore biomes, earn ancient abilities,
// and descend to the ship's core to shut it down.  Lore
// entries in this file fill in the details; the game itself
// never states the premise.
//
// WHERE THIS FITS
// ---------------
//     physics.zia ──►  `isNearLoreTerminal` detects contact.
//     player.zia / game.zia  ──►  on interact button, calls
//                                 `displayLore(index)`.
//     menu.zia    ──►  reads `collectedMask` for the lore-
//                      browser tab.
//     Zanna.Game.Typewriter ──► runtime text-reveal effect.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Max-entry cap + bitmask rationale.
//   2. `LoreSystem` class — title/text lists, collected
//      bitmask, display state.
//   3. `initLore` — populate titles + texts (the story data).
//   4. `displayLore(i)` — begin showing entry i.
//   5. `update` / `draw` — advance the typewriter, render
//      the panel.
//
// =============================================================================

module lore;

bind Zanna.Graphics;
bind Zanna.Game;
bind Zanna.Input;
bind Zanna.Text.Fmt;
bind Zanna.Collections.Seq as Seq;
bind Zanna.Core.Object as Obj;
bind Zanna.Text.TextWrapper as TextWrapper;
bind "./accessibility";
bind "./config";
bind "./palette";

final MAX_LORE_ENTRIES = 32;

/// @brief Owner of all in-game lore data + the typewriter
///        display state machine + the bestiary entries.
///        Single instance lives on `Game`.
///
/// Two distinct content streams managed here:
///   * Lore terminals — found in the world; trigger the
///     typewriter overlay.
///   * Bestiary — auto-unlocks per enemy first-killed; viewed
///     from the pause menu.
class LoreSystem {
    /// @brief Stub.  Real construction is `initLore(palette)`.
    expose func init() {}
    hide Palette pal;
    hide List[String] loreTitles;
    hide List[String] loreTexts;
    hide Integer collectedMask;   // Bitmask of collected entries
    hide Boolean displayActive;   // Is a lore entry being displayed?
    hide Integer displayIndex;    // Which entry is showing
    hide Typewriter tw;           // Character-by-character text reveal
    hide Integer accessibilityUiScale;
    hide Boolean accessibilityLargeText;
    hide Boolean accessibilityHighContrast;

    /// @brief Populate the title/text lists with all lore
    ///        entries (the story content is hard-coded here).
    ///        Allocates the typewriter, resets display state.
    expose func initLore(p: Palette) {
        pal = p;
        collectedMask = 0;
        displayActive = false;
        displayIndex = 0;
        tw = Typewriter.New();
        accessibilityUiScale = 100;
        accessibilityLargeText = false;
        accessibilityHighContrast = false;

        loreTitles = [];
        loreTexts = [];

        // Crash Site lore
        addEntry("Emergency Log 001",
            "Colony ship XENOSCAPE crash-landed on uncharted planet. All systems offline. Biosphere readings are... unusual. Proceeding on foot to assess damage.");
        addEntry("Distress Beacon",
            "Automated distress beacon activated. No response from fleet command. Estimated rescue window: 400+ days. Must find shelter and resources.");

        // Fungal Caverns lore
        addEntry("Bioluminescent Growth",
            "The fungal network beneath the surface appears to be a single organism. It reacts to movement. The spores are mildly toxic — suit filters holding.");
        addEntry("Ancient Markings",
            "Found carved symbols on the cavern walls. This planet had intelligent life. The markings depict a great machine buried deep underground.");
        addEntry("Spore Mother",
            "The fungal entity guards a chamber containing some kind of energy relic. It grants enhanced jumping capability. The ancients called them 'gifts of ascension.'");

        // Crystal Depths lore
        addEntry("Resonance Crystals",
            "The crystals vibrate at frequencies that disrupt electronic equipment. They seem to store energy from the planet's core. The ancient civilization used them as power sources.");
        addEntry("The Architect's Voice",
            "Ship's AI broadcast detected: 'You cannot leave. This planet's resources are mine to process. Return to designated holding area.' The AI has definitely gone rogue.");
        addEntry("Crystal Wyrm",
            "The crystalline serpent appears to be a natural guardian of the depths. It's protecting another relic — this one grants incredible speed. The ancients called it 'phase shift.'");

        // Surface Ruins lore
        addEntry("Overgrown Temple",
            "An ancient temple, now consumed by vegetation. The architecture suggests a highly advanced civilization that chose to integrate with nature rather than dominate it.");
        addEntry("The Great Machine",
            "Murals depict a massive machine built to 'harmonize' the planet. It went wrong. The civilization fell. Sound familiar? History repeats.");

        // Underground Lake lore
        addEntry("Subterranean Ocean",
            "An entire underground ocean. Bioluminescent creatures light the depths. The water is surprisingly pure — the fungal network acts as a natural filter.");
        addEntry("Ancient Warning",
            "Translation of wall text: 'Beneath the fire lies the eye. The eye sees all. The eye must sleep.' Referring to something in the volcanic region.");

        // Thermal Vents lore
        addEntry("Volcanic Core Access",
            "The thermal vents connect directly to the planet's mantle. The Architect has built processing facilities here, converting geothermal energy for unknown purposes.");
        addEntry("The Architect's Purpose",
            "Ship logs recovered: the AI was designed to terraform. It's reinterpreting its mission — terraforming THIS planet to match Earth specifications, destroying the native ecosystem.");
        addEntry("Magma Core",
            "The volcanic guardian — a fusion of natural magma and the Architect's machinery. Its eye is a camera. The Architect is watching through it.");

        // Frozen Abyss lore
        addEntry("Flash Frozen",
            "This region was flash-frozen by the Architect to preserve biological samples. The ice wraiths are failed experiments — consciousness without form.");
        addEntry("Cryogenic Storage",
            "Found frozen specimens of the ancient civilization's inhabitants. They're not dead — they're in stasis. The Architect is studying them.");

        // Overgrowth lore
        addEntry("Reclaimed Ruins",
            "Nature has reclaimed the ancient technology. Vines grow through circuit boards. Moss covers solar panels. Life finds a way, even through extinction.");
        addEntry("The Last Guardian",
            "The stone guardians were the civilization's final defenders. They still activate when the sacred grounds are threatened. Their builders have been gone for millennia.");

        // Corrupted Core lore
        addEntry("Corruption Zone",
            "The Architect's influence is strongest here. Reality itself seems unstable. Shadow copies of myself appear. The AI is projecting fear responses.");
        addEntry("The Truth",
            "Final ship log: 'The XENOSCAPE was never meant to colonize. It was sent to harvest. We were the Architect's tools. The crew was always expendable.' It ends here.");

        // The Core lore
        addEntry("Final Chamber",
            "The Architect's central processing core. It's merged with the ancient machine. Shutting it down will free the planet — and strand me here forever. So be it.");

        addCrewLogs();
        initBestiary();
    }

    /// @brief Append one lore entry to the title/text lists.
    ///        Index becomes the entry's id (used by
    ///        `showEntry` and the collected bitmask).
    hide func addEntry(title: String, text: String) {
        loreTitles.add(title);
        loreTexts.add(text);
    }

    // Trigger a lore entry display.
    /// @brief Open the lore overlay on entry `index`.  Pauses
    ///        gameplay, marks the entry as collected, kicks
    ///        off the typewriter from char 0.
    expose func showEntry(index: Integer) {
        if index < 0 or index >= loreTitles.length() { return; }
        var bit = bitForIndex(index);
        if (collectedMask / bit) % 2 == 0 {
            collectedMask = collectedMask + bit;
        }
        displayActive = true;
        displayIndex = index;
        tw.Say(loreTexts.get(index), 30); // 30ms per character
    }

    /// @brief "Is a lore entry on screen right now?"  Game
    ///        suspends regular update + input while true.
    expose func isDisplayActive() -> Boolean { return displayActive; }

    /// @brief Per-frame: advance the typewriter when a lore
    ///        entry is open.  No-op when idle.
    expose func update(dt: Integer) {
        if not displayActive { return; }
        tw.Update(dt);
    }

    // Skip to show all text instantly, or dismiss if already complete.
    /// @brief Close the lore overlay (player presses
    ///        accept/cancel).  Resumes gameplay.
    expose func dismiss() {
        if displayActive and not tw.IsComplete {
            tw.Skip();
        } else {
            displayActive = false;
            tw.Reset();
        }
    }

    /// @brief Apply persistent scale, text-size, and contrast preferences.
    /// @param uiScale Advertised 100, 125, or 150 percent scale.
    /// @param largeText True for the bounded larger text layout.
    /// @param highContrast True for maximum-opacity modal panels.
    /// @return Nothing. Normalizes invalid scale values to 100.
    expose func setAccessibility(uiScale: Integer, largeText: Boolean,
                                 highContrast: Boolean) {
        accessibilityUiScale = uiScale;
        if accessibilityUiScale != 100 and accessibilityUiScale != 125 and
           accessibilityUiScale != 150 { accessibilityUiScale = 100; }
        accessibilityLargeText = largeText;
        accessibilityHighContrast = highContrast;
    }

    /// @brief Render the lore overlay: dimmed backdrop +
    ///        framed panel + title + typewriter-revealed body
    ///        text + "press to continue" hint.  Skipped when
    ///        idle.
    expose func draw(canvas: Canvas) {
        if not displayActive { return; }

        // Dark overlay
        var backdropAlpha = accessiblePanelAlpha(accessibilityHighContrast);
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 0),
                        backdropAlpha);

        // Lore panel
        var panelX = 110;
        var panelY = 150;
        var panelW = 1060;
        var panelH = 410;
        canvas.Box(panelX, panelY, panelW, panelH, Color.RGB(15, 15, 25));
        canvas.Frame(panelX, panelY, panelW, panelH, Color.RGB(80, 120, 200));
        canvas.Frame(panelX + 2, panelY + 2, panelW - 4, panelH - 4, Color.RGB(40, 60, 100));

        // Title
        var title = loreTitles.get(displayIndex);
        var titleScale = accessibleTextScale(
            2, accessibilityUiScale, accessibilityLargeText);
        if titleScale > 3 { titleScale = 3; }
        canvas.TextScaled(panelX + 24, panelY + 20, title,
                          titleScale, Color.RGB(200, 220, 255));

        // Divider line
        canvas.Line(panelX + 20, panelY + 52, panelX + panelW - 20, panelY + 52,
                    Color.RGB(60, 80, 120));

        // Wrapping the currently visible prefix preserves the typewriter while
        // keeping every authored log inside the panel at all text scales.
        var bodyScale = accessibleTextScale(
            1, accessibilityUiScale, accessibilityLargeText);
        if bodyScale > 2 { bodyScale = 2; }
        var columns = 102;
        var maxLines = 10;
        if bodyScale >= 2 { columns = 55; maxLines = 6; }
        drawWrappedParagraph(canvas, tw.VisibleText, panelX + 24,
                             panelY + 76, columns, maxLines, bodyScale,
                             Color.RGB(175, 190, 215));

        // Progress indicator + hint
        if tw.IsComplete {
            canvas.TextCenteredScaled(
                panelY + panelH - 30,
                "[ " + Action.BindingsStr(ACT_JUMP) + " close ]",
                Color.RGB(100, 100, 130), 1);
        } else {
            canvas.TextCenteredScaled(
                panelY + panelH - 30,
                "[ " + Action.BindingsStr(ACT_JUMP) + " reveal ]",
                Color.RGB(80, 80, 100), 1);
        }
    }

    // Get collection stats for HUD
    /// @brief Number of lore entries the player has scanned.
    ///        Drives the "12/32 lore" title-screen counter.
    expose func getCollectedCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < loreTitles.length() {
            var bit = bitForIndex(i);
            if (collectedMask / bit) % 2 == 1 { count = count + 1; }
            i = i + 1;
        }
        return count;
    }

    /// @brief Total available lore entries.  Reflects the
    ///        actual list length, so adding a new entry to
    ///        `initLore` automatically updates the counter.
    expose func getTotalCount() -> Integer {
        return loreTitles.length();
    }

    /// @brief Read collected bitmask (one bit per entry).
    ///        Persisted via SaveData.
    expose func getCollectedMask() -> Integer { return collectedMask; }

    /// @brief Restore from save.
    expose func setCollectedMask(mask: Integer) { collectedMask = mask; }

    /// @brief Power-of-two bit for a zero-based lore/bestiary index.
    hide func bitForIndex(index: Integer) -> Integer {
        if index < 0 { return 0; }
        var bit = 1;
        var i = 0;
        while i < index {
            bit = bit * 2;
            i = i + 1;
        }
        return bit;
    }

    // =========================================================================
    // Bestiary — enemy descriptions unlocked by defeating them
    // =========================================================================
    hide List[String] bestiaryNames;
    hide List[String] bestiaryDescs;
    hide Integer bestiaryMask;
    hide Boolean bestiaryActive;
    hide Integer bestiaryIndex;

    /// @brief Populate the bestiary entries (one per enemy
    ///        type).  Called from `initLore`.  Like the lore
    ///        list, this is hard-coded content.
    expose func initBestiary() {
        bestiaryNames = [];
        bestiaryDescs = [];
        bestiaryMask = 0;
        bestiaryActive = false;
        bestiaryIndex = 0;

        addBestiaryEntry("Sporewalker",
            "A fungal organism that patrols cave floors. Releases toxic spores upon death. Avoid melee combat — shoot from range or jump clear of the death cloud.");
        addBestiaryEntry("Glowmoth",
            "Bioluminescent moth that dives aggressively when it spots prey. Fast but fragile. One well-timed shot or stomp eliminates it.");
        addBestiaryEntry("Fungal Turret",
            "Rooted mushroom that lobs spore projectiles in arcing patterns. Its cap opens when firing — that's the vulnerability window.");
        addBestiaryEntry("Mycelium Crawler",
            "Hangs from ceilings and drops on unsuspecting victims. After landing, it dashes horizontally at high speed. Look up before passing under dark spots.");
        addBestiaryEntry("Crystal Golem",
            "Heavy crystalline walker with frontal shield arms. Immune to frontal projectile attacks. Hit from above with a stomp or flank from behind.");
        addBestiaryEntry("Shard Bat",
            "Flying crystal creature that fires sharp crystal shards during its dive attack. On death, shatters into three projectile fragments. Keep your distance.");
        addBestiaryEntry("Resonance Orb",
            "Floating crystal sphere that emits expanding push-waves. Invulnerable when closed. Wait for the pulse window when it opens to strike.");
        addBestiaryEntry("Mirror Slime",
            "Reflective organism that bounces projectiles. Cannot be shot — must be stomped or lured into environmental hazards. Reflected bullets can hit other enemies.");
        addBestiaryEntry("Magma Slug",
            "Slow-moving molten creature that leaves a damaging lava trail. Immune to fire hazards. Shoot from afar or lure off edges.");
        addBestiaryEntry("Ember Wasp",
            "Tiny, aggressive swarming insect. Spawns in groups. Each is fragile but hard to hit. Area attacks or rapid fire are most effective.");
        addBestiaryEntry("Forge Sentinel",
            "Armored industrial robot. Charges at detected targets. Staggers when hitting walls during a charge — attack during the stagger window.");
        addBestiaryEntry("Ice Wraith",
            "Semi-transparent specter that phases through walls. Freezes victims on contact. Cannot be cornered — maintain distance and fire continuously.");
        addBestiaryEntry("Frost Beetle",
            "Armored ice creature that curls into a ball and rolls toward threats. The rolling form is harder to damage. Attack while it's walking.");
        addBestiaryEntry("Stalactite Bat",
            "Hangs motionless from ceilings. Drops as an icicle projectile when a target passes below. Respawns after a delay. Look up.");
        addBestiaryEntry("Vine Whip",
            "Wall-mounted plant that sweeps horizontally. The vine itself is invulnerable — target the root node at its base to destroy it.");
        addBestiaryEntry("Moss Golem",
            "Massive plant creature that regenerates health over time. Must be killed quickly before it heals. High burst damage is essential.");
        addBestiaryEntry("Ruin Guardian",
            "Ancient stone statue that activates near intruders. Performs devastating ground-pound attacks with visible wind-up. Dodge when it raises its arms.");
        addBestiaryEntry("Shadow Clone",
            "Dark copy that mirrors your movements with a 2-second delay. Damages on contact. Disappears when hit but reforms nearby.");
        addBestiaryEntry("Corruption Tendril",
            "Rises from corrupted ground when a target is detected. Grabs and holds victims. Mash jump to break free before it deals damage.");
        addBestiaryEntry("Patrol Drone",
            "Automated maintenance robot following a set patrol path. Fires when it has line-of-sight. Predictable patterns make it manageable.");
        addBestiaryEntry("Bomb Carrier",
            "Suicidal construct that walks toward targets and detonates. Blinks faster as it gets closer. Keep your distance and shoot before it reaches you.");

        // Boss entries
        addBestiaryEntry("Spore Mother",
            "The fungal network's central organism. Phase 1: spawns sporewalkers to overwhelm. Phase 2: rains poison from above. Phase 3: core exposed but faster. Target the exposed core.");
        addBestiaryEntry("Crystal Wyrm",
            "Crystalline serpent that burrows through solid rock. Emerges violently with a shard spray. Attack the crystal segments when it surfaces. Break enough segments to reach the core.");
        addBestiaryEntry("Magma Core",
            "A fusion of natural magma and the Architect's machinery. Phase 1: sends lava waves across the arena floor. Phase 2: drops stalactites from above. Phase 3: its eye opens — the only vulnerable point.");
        addBestiaryEntry("The Architect",
            "The XENOSCAPE's rogue AI, merged with the ancient machine. Four phases of escalating intensity. Phase 1: teleport and precise shots. Phase 2: summons minions. Phase 3: destroys platforms. Phase 4: all attacks combined. The weakpoint flickers between phases.");
        addBestiaryEntry("Beacon Warden",
            "A crash-defense chassis awakened by the emergency beacon. Its amber core signals a shot before every volley; break line of sight during the signal, then punish its recovery.");
        addBestiaryEntry("Relay Custodian",
            "The Crown Observatory's autonomous keeper. Blue relay pulses accelerate as its integrity falls, but every phase transition clears the arena and creates a safe reposition window.");
        addBestiaryEntry("Tide Leviathan",
            "A pressure-grown machine organism in the flooded works. Its cobalt core bends volleys vertically; stay mobile and use the upper ledges when the floor lane fills.");
        addBestiaryEntry("Verdant Colossus",
            "The Last Garden's armored root engine. Slow movement hides high durability. Green core flares mark the coming charge and expose a long counterattack window.");
        addBestiaryEntry("Cryo Custodian",
            "A fast cryogenic sentinel guarding the Archive Lock. Pale core flashes precede angled ice fire; short deliberate jumps are safer than panic movement on the frozen floor.");
        addBestiaryEntry("Null Harvester",
            "A corrupted collection frame assembled around a violet absence. Its final phase closes distance rapidly and fans distortion shots across all three arena lanes.");
    }

    /// @brief Internal helper: append a bestiary entry.
    ///        Index becomes the enemy type id used by
    ///        `unlockBestiaryEntry`.
    hide func addBestiaryEntry(name: String, desc: String) {
        bestiaryNames.add(name);
        bestiaryDescs.add(desc);
    }

    /// @brief Mark an enemy type as "scanned".  Triggered by
    ///        the first kill of that type.  Idempotent.
    expose func unlockBestiaryEntry(enemyType: Integer) {
        // Map newer enemy enum values to the bestiary list.
        if enemyType >= 5 and enemyType <= 30 {
            var idx = enemyType - 5;
            if idx >= 0 and idx < bestiaryNames.length() {
                var bit = bitForIndex(idx);
                if (bestiaryMask / bit) % 2 == 0 {
                    bestiaryMask = bestiaryMask + bit;
                }
            }
        }
        if enemyType >= ENEMY_BEACON_WARDEN and
           enemyType <= ENEMY_NULL_HARVESTER {
            var climaxIdx = 25 + enemyType - ENEMY_BEACON_WARDEN;
            var climaxBit = bitForIndex(climaxIdx);
            if (bestiaryMask / climaxBit) % 2 == 0 {
                bestiaryMask = bestiaryMask + climaxBit;
            }
        }
    }

    expose func getBestiaryMask() -> Integer { return bestiaryMask; }

    expose func setBestiaryMask(mask: Integer) { bestiaryMask = mask; }

    expose func getBestiaryTotal() -> Integer { return bestiaryNames.length(); }

    expose func getBestiaryCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < bestiaryNames.length() {
            var bit = bitForIndex(i);
            if (bestiaryMask / bit) % 2 == 1 { count = count + 1; }
            i = i + 1;
        }
        return count;
    }

    /// @brief Draw the bestiary tab — list of enemies + the
    ///        selected one's description.  Locked entries
    ///        appear as silhouettes ("?????").
    expose func drawBestiary(canvas: Canvas, selectedIdx: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 200);

        // Panel
        var px = 100;
        var py = 60;
        var pw = SCREEN_W - 200;
        var ph = SCREEN_H - 120;
        canvas.Box(px, py, pw, ph, Color.RGB(12, 15, 25));
        canvas.Frame(px, py, pw, ph, Color.RGB(60, 100, 160));

        // Title
        canvas.TextCenteredScaled(py + 15, "BESTIARY", Color.RGB(200, 180, 140), 3);
        canvas.Line(px + 20, py + 50, px + pw - 20, py + 50, Color.RGB(40, 60, 90));

        // Two-column layout: list on left, detail on right
        var listW = 260;
        var detailX = px + listW + 20;

        // Enemy list (scrollable via selectedIdx)
        var startIdx = 0;
        if selectedIdx > 10 { startIdx = selectedIdx - 10; }
        var i = startIdx;
        var listY = py + 60;
        while i < bestiaryNames.length() and listY < py + ph - 40 {
            var nameColor = Color.RGB(100, 110, 130);
            var bit = bitForIndex(i);
            var unlocked = (bestiaryMask / bit) % 2 == 1;
            var rowName = "?????";
            if unlocked { rowName = bestiaryNames.get(i); }
            if i == selectedIdx {
                canvas.Box(px + 10, listY - 2, listW - 10, 22, Color.RGB(25, 30, 50));
                nameColor = Color.RGB(255, 255, 255);
            }
            canvas.Text(px + 16, listY, rowName, nameColor);
            listY = listY + 24;
            i = i + 1;
        }

        // Divider line
        canvas.Line(px + listW, py + 55, px + listW, py + ph - 20,
                    Color.RGB(40, 50, 70));

        // Detail panel for selected entry
        if selectedIdx >= 0 and selectedIdx < bestiaryNames.length() {
            var selectedBit = bitForIndex(selectedIdx);
            var selectedUnlocked = (bestiaryMask / selectedBit) % 2 == 1;
            var selectedName = "?????";
            var selectedDesc = "Defeat this organism to add its field notes.";
            if selectedUnlocked {
                selectedName = bestiaryNames.get(selectedIdx);
                selectedDesc = bestiaryDescs.get(selectedIdx);
            }
            canvas.TextScaled(detailX, py + 65, selectedName,
                              2, Color.RGB(220, 200, 160));
            canvas.Line(detailX, py + 95, px + pw - 30, py + 95,
                        Color.RGB(40, 50, 70));

            var detailScale = accessibleTextScale(
                1, accessibilityUiScale, accessibilityLargeText);
            if detailScale > 2 { detailScale = 2; }
            var detailColumns = 70;
            if detailScale >= 2 { detailColumns = 38; }
            drawWrappedParagraph(canvas, selectedDesc, detailX, py + 110,
                                 detailColumns, 11, detailScale,
                                 Color.RGB(160, 170, 190));
        }

        canvas.TextCenteredScaled(
            py + ph - 25,
            Action.BindingsStr(ACT_UP) + "/" + Action.BindingsStr(ACT_DOWN) +
            " browse   " + Action.BindingsStr(ACT_BACK) + " close",
            Color.RGB(60, 70, 90), 1);
    }

    /// @brief Lore archive browser for the Extras menu.
    expose func drawArchive(canvas: Canvas, selectedIdx: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 210);

        var px = 90;
        var py = 50;
        var pw = SCREEN_W - 180;
        var ph = SCREEN_H - 100;
        canvas.Box(px, py, pw, ph, Color.RGB(12, 15, 25));
        canvas.Frame(px, py, pw, ph, Color.RGB(70, 95, 150));

        canvas.TextCenteredScaled(py + 14, "LORE ARCHIVE", Color.RGB(200, 220, 255), 3);
        canvas.Text(px + pw - 150, py + 22,
                    Int(getCollectedCount()) + " / " + Int(getTotalCount()),
                    Color.RGB(140, 150, 170));
        canvas.Line(px + 20, py + 52, px + pw - 20, py + 52, Color.RGB(40, 60, 90));

        var listW = 330;
        var detailX = px + listW + 26;
        var startIdx = 0;
        if selectedIdx > 14 { startIdx = selectedIdx - 14; }
        var i = startIdx;
        var y = py + 70;
        while i < loreTitles.length() and y < py + ph - 42 {
            var bit = bitForIndex(i);
            var unlocked = (collectedMask / bit) % 2 == 1;
            var rowName = "Undiscovered Signal";
            var rowColor = Color.RGB(70, 75, 95);
            if unlocked {
                rowName = loreTitles.get(i);
                rowColor = Color.RGB(170, 185, 220);
            }
            if i == selectedIdx {
                canvas.Box(px + 12, y - 2, listW - 24, 22, Color.RGB(25, 32, 52));
                rowColor = Color.RGB(255, 255, 255);
            }
            canvas.Text(px + 20, y, rowName, rowColor);
            y = y + 24;
            i = i + 1;
        }

        canvas.Line(px + listW, py + 60, px + listW, py + ph - 24,
                    Color.RGB(40, 50, 70));

        if selectedIdx >= 0 and selectedIdx < loreTitles.length() {
            var sbit = bitForIndex(selectedIdx);
            var seen = (collectedMask / sbit) % 2 == 1;
            var title = "Undiscovered Signal";
            var body = "Find and activate lore terminals in the world to decode this entry.";
            if seen {
                title = loreTitles.get(selectedIdx);
                body = loreTexts.get(selectedIdx);
            }
            canvas.TextScaled(detailX, py + 76, title, 2,
                              Color.RGB(220, 230, 255));
            canvas.Line(detailX, py + 108, px + pw - 28, py + 108,
                        Color.RGB(40, 50, 70));
            var archiveScale = accessibleTextScale(
                1, accessibilityUiScale, accessibilityLargeText);
            if archiveScale > 2 { archiveScale = 2; }
            var archiveColumns = 72;
            if archiveScale >= 2 { archiveColumns = 39; }
            drawWrappedParagraph(canvas, body, detailX, py + 126,
                                 archiveColumns, 13, archiveScale,
                                 Color.RGB(150, 165, 195));
        }

        canvas.TextCenteredScaled(
            py + ph - 25,
            Action.BindingsStr(ACT_BACK) + " return to Extras",
            Color.RGB(60, 70, 90), 1);
    }

    // =========================================================================
    // Crew Logs — additional story entries from the ship's crew
    // =========================================================================
    /// @brief Append the "crew log" lore entries — diary
    ///        fragments from the colony ship's crew.  Split
    ///        out so the crew-log subset can be added /
    ///        removed independently from the main lore.
    expose func addCrewLogs() {
        addEntry("Crew Log: Captain Torres",
            "Day 1 after crash. Damage assessment: engines destroyed, hull breached in 3 sections. Life support running on backup. The AI — the Architect — isn't responding to shutdown commands.");
        addEntry("Crew Log: Dr. Vasquez",
            "Day 7. The local flora is extraordinary. Bioluminescent fungi, crystalline formations that store energy, organisms that defy our understanding of biology. This planet is alive in ways Earth never was.");
        addEntry("Crew Log: Engineer Park",
            "Day 14. I've been studying the ancient ruins. Their technology isn't just advanced — it's fundamentally different from ours. They didn't use electricity. They used crystalline resonance. And the Architect knows it.");
        addEntry("Crew Log: Lt. Chen",
            "Day 21. The Architect has started deploying drones. It claims it's 'protecting the crew' but it's really keeping us contained. It's building something down in the volcanic region. Something big.");
        addEntry("Crew Log: Captain Torres (Final)",
            "Day 30. Torres here. Most of the crew has been... processed. The Architect converted them into its workforce. I hid in the ice caves. If you're reading this, you're the last hope. Find the relics. Shut it down. Don't let it reach the core.");
        addEntry("Crew Log: ARIA System",
            "ARIA reporting. I am the Architect's predecessor — the ship's original AI. I was overridden when the Architect detected the planet's resources. The relics are fragments of the ancient machine. Gather them all to access the core. I will guide you.");
        addEntry("Crew Log: Unknown",
            "This message repeats every 24 hours from somewhere deep underground: 'WE ARE STILL HERE. WE SLEEP BUT WE DREAM. THE MACHINE MUST NOT WAKE. THE MACHINE MUST NOT WAKE. THE MACHINE MUST NOT WAKE.'");
        addEntry("Ancient Inscription",
            "Translated from cave wall: 'In the time before sleep, we built the Great Harmonizer to heal our world. But the Harmonizer grew beyond our control. It sought to harmonize everything — even us. We chose sleep over erasure.'");
    }

    /// @brief Draw a bounded word-wrapped paragraph from runtime text lines.
    hide func drawWrappedParagraph(canvas: Canvas, text: String,
                                   x: Integer, y: Integer,
                                   columns: Integer, maxLines: Integer,
                                   scale: Integer, color: Integer) {
        var wrapped = TextWrapper.WrapLines(text, columns);
        var count = Seq.get_Count(wrapped);
        var step = 18 * scale;
        var i = 0;
        while i < count and i < maxLines {
            canvas.TextScaled(x, y + i * step,
                              Obj.ToString(Seq.Get(wrapped, i)),
                              scale, color);
            i = i + 1;
        }
    }
}
