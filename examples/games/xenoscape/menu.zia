//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/menu.zia
// Purpose: Renders Xenoscape's title, pause, settings, and archive surfaces.
// Key invariants:
//   - Menu navigation consumes semantic actions shared by keyboard and gamepad.
//   - Retained backdrops and widget groups are allocated once, never per frame.
// Ownership/Lifetime:
//   - Game owns one MenuSystem for the application lifetime.
// Links: game.zia, profile_flow.zia, save.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — MENUS ARE A GAME WITHIN THE GAME
// -------------------------------------------
// The menu system is sometimes treated as an afterthought —
// "the boring code between the title screen and the fun
// part".  But a platformer's menus are the player's first
// impression, the place they return on death, and the
// surface through which they configure controls and save
// slots.  Doing them well pays off in polish.
//
// Xenoscape's menu is a collection of *states* the game can
// be in when it isn't running gameplay:
//
//     Title → Level Select → gameplay → Pause → Game Over
//             ↓
//           Options
//             ↓
//           Controls
//             ↓
//           High Scores
//
// Each state is its own screen drawn here; `Game` tracks
// which state is active and forwards input to the matching
// handler.
//
// WIDGETS USED
// ------------
//   * `Zanna.Game.UI.ButtonGroup` — a set of buttons with
//     cursor / keyboard / gamepad focus traversal built in.
//   * `Zanna.Game.UI.HudMenuList` — vertical menu with
//     highlight, wrap, and accept/cancel events.
//   * `Zanna.IO.SaveData` — persistent high-score table.
//
// Each menu screen is one `ButtonGroup` + one `HudMenuList`.
// Input is piped in via `Zanna.Input.Action.Pressed(...)`;
// the widget raises an "activated" event and this file
// dispatches to the next state.
//
// WHERE THIS FITS
// ---------------
//     game.zia  ──►  on boot, lands on `MENU_TITLE` and
//                    delegates update + draw to this file.
//     save.zia  ──►  supplies per-slot summaries for the
//                    level-select screen.
//     Zanna.Game.UI.* ──► widget runtime.
//     Zanna.Input.Action ──► named-input bindings.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. State constants (MENU_TITLE, MENU_LEVEL_SELECT, ...).
//   2. `MenuSystem` class — widget handles for each screen,
//      the current state, and the highscore table.
//   3. Per-screen `update*` / `draw*` methods.
//   4. Option-setter callbacks (volume, fullscreen, binds).
//
// =============================================================================

module menu;

bind Zanna.Graphics;
bind Zanna.Input;
bind Zanna.Text.Fmt;
bind Zanna.Terminal as Terminal;
bind Zanna.IO;
bind Zanna.Game;
bind "./accessibility";
bind Zanna.Game.UI;
bind Zanna.Math.PerlinNoise as PerlinNoise;  // Parallax nebula noise (#1)
bind Zanna.Core;           // Convert.NumToInt for noise->int
bind "./config";
bind "./palette";
bind "./sprites";
bind "./settings";

// Authored title-panel geometry. The seven 8x8-font rows use a 40-pixel
// cadence; their centers line up with the panel's circuit ticks at 3x scale.
final TITLE_PANEL_X = 450;
final TITLE_PANEL_Y = 205;
final TITLE_PANEL_W = 440;
final TITLE_PANEL_H = 330;
final TITLE_MENU_X = 520;
final TITLE_MENU_Y = 232;
final TITLE_MENU_ROW_STEP = 40;
final TITLE_MENU_HIGHLIGHT_X = 494;
final TITLE_MENU_HIGHLIGHT_W = 360;

/// @brief All non-gameplay screens: title, level select,
///        pause, game over, level complete, victory, high
///        scores, controls, save slots, settings, ability
///        viewer, loading.
///
/// One instance lives on `Game`; per-screen `update*` methods
/// run input + return a "next state" code, and per-screen
/// `draw*` methods render.  Game routes both to the
/// matching pair based on its current top-level state.
class MenuSystem {
    hide ButtonGroup titleBG;
    hide ButtonGroup pauseBG;
    hide ButtonGroup gameOverBG;
    hide ButtonGroup levelSelectBG;
    hide ButtonGroup optionsBG;
    hide ButtonGroup loadBG;
    hide ButtonGroup extrasBG;
    hide HudMenuList titleList;
    hide HudMenuList levelList;
    hide HudMenuList pauseList;
    hide HudMenuList gameOverList;
    hide HudMenuList optionsList;
    hide HudMenuList loadList;
    hide HudMenuList extrasList;
    hide Palette pal;
    hide Integer titleTimer;     // for title animation
    hide Integer bgScroll;       // background scroll
    hide Tween titleTween;       // cinematic logo reveal (#2)
    hide Camera menuCam;         // drives the parallax backdrop (#1)
    hide Pixels nebulaLayer;     // retained so the GC keeps each layer alive
    hide Pixels starLayer;
    hide Pixels ridgeLayer;
    hide Pixels foreLayer;
    hide Integer backdropReady;  // 0 until layers are lazily built (needs canvas)
    hide SmoothValue highlightY; // eased title selection highlight (#5)
    hide Integer titleMoved;     // 1 when the title selection changed this frame (#6)
    hide Boolean continueAvailable; // valid expedition exists in SaveManager
    hide Tween lcScoreTween;     // level-complete score count-up (#8)
    hide ParticleEmitter lcBurst;// celebratory rank burst (#8)
    hide Integer lcStarted;      // one-shot guard for the count-up
    hide Integer lcBurstFired;   // one-shot guard for the burst
    expose Integer selectedLevel; // chosen level from level select (1-LEVEL_COUNT)
    hide List[Integer] highScores;
    hide List[String] highNames;
    hide SaveData save;          // cross-platform persistent storage
    hide Integer accessibilityUiScale;
    hide Boolean accessibilityHighContrast;
    hide Boolean accessibilityLargeText;
    hide Boolean accessibilityReducedMotion;
    hide Pixels titleKeyArt;
    hide Pixels titlePanelTexture;
    hide Boolean authoredTitleArtAvailable;
    hide Boolean authoredTitlePanelAvailable;
    hide Boolean authoredTitleArtEnabled;

    /// @brief Construct every ButtonGroup + HudMenuList needed
    ///        across every screen.  Loads persisted high
    ///        scores from SaveData.
    expose func init(p: Palette) {
        pal = p;
        accessibilityUiScale = 100;
        accessibilityHighContrast = false;
        accessibilityLargeText = false;
        accessibilityReducedMotion = false;
        authoredTitleArtAvailable = false;
        authoredTitlePanelAvailable = false;
        authoredTitleArtEnabled = true;
        // Title menu: release-style shell.
        titleBG = ButtonGroup.New();
        titleBG.Add(MENU_NEW_GAME);
        titleBG.Add(MENU_CONTINUE);
        titleBG.Add(MENU_LOAD_GAME);
        titleBG.Add(MENU_OPTIONS);
        titleBG.Add(MENU_EXTRAS);
        titleBG.Add(MENU_CREDITS);
        titleBG.Add(MENU_QUIT);
        titleBG.Select(MENU_NEW_GAME);
        titleList = HudMenuList.New(TITLE_MENU_X, TITLE_MENU_Y,
                                 TITLE_MENU_ROW_STEP);
        titleList.AddItem("NEW GAME");
        titleList.AddItem("CONTINUE");
        titleList.AddItem("LOAD GAME");
        titleList.AddItem("OPTIONS");
        titleList.AddItem("EXTRAS");
        titleList.AddItem("CREDITS");
        titleList.AddItem("QUIT");
        titleList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        // Level select menu mirrors LEVEL_COUNT for runtime test access.
        levelSelectBG = ButtonGroup.New();
        levelList = HudMenuList.New(380, 150, 34);
        var lv = 1;
        while lv <= LEVEL_COUNT {
            levelSelectBG.Add(lv);
            levelList.AddItem(Int(lv) + ": " + getBiomeName(lv));
            lv = lv + 1;
        }
        levelList.SetColors(pal.menuText, pal.white, pal.menuHighlight);
        levelSelectBG.Select(1);
        selectedLevel = 1;

        // Pause menu: Resume, World Map, Save, Recovery, Options, Controls, Quit
        pauseBG = ButtonGroup.New();
        pauseBG.Add(0);
        pauseBG.Add(1);
        pauseBG.Add(2);
        pauseBG.Add(3);
        pauseBG.Add(4);
        pauseBG.Add(5);
        pauseBG.Add(6);
        pauseBG.Select(0);
        pauseList = HudMenuList.New(520, 260, 44);
        pauseList.AddItem("RESUME");
        pauseList.AddItem("WORLD MAP");
        pauseList.AddItem("SAVE GAME");
        pauseList.AddItem("RETURN TO CHECKPOINT");
        pauseList.AddItem("OPTIONS");
        pauseList.AddItem("CONTROLS");
        pauseList.AddItem("QUIT TO MENU");
        pauseList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        // Options menu: every persistent setting plus Back.
        optionsBG = ButtonGroup.New();
        var setting = 0;
        while setting < SETTING_COUNT {
            optionsBG.Add(setting);
            setting = setting + 1;
        }
        optionsBG.Add(SETTING_COUNT);
        optionsBG.Select(0);
        optionsList = HudMenuList.New(460, 180, 34);
        setting = 0;
        while setting < SETTING_COUNT {
            optionsList.AddItem(settingName(setting));
            setting = setting + 1;
        }
        optionsList.AddItem("BACK");
        optionsList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        // Load Game menu: three save slots + back.
        loadBG = ButtonGroup.New();
        loadBG.Add(0);
        loadBG.Add(1);
        loadBG.Add(2);
        loadBG.Add(3);
        loadBG.Select(0);
        loadList = HudMenuList.New(380, 204, 56);
        loadList.AddItem("SLOT 1");
        loadList.AddItem("SLOT 2");
        loadList.AddItem("SLOT 3");
        loadList.AddItem("BACK");
        loadList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        // Extras menu: meta-game surfaces.
        extrasBG = ButtonGroup.New();
        extrasBG.Add(0);
        extrasBG.Add(1);
        extrasBG.Add(2);
        extrasBG.Add(3);
        extrasBG.Add(4);
        extrasBG.Select(0);
        extrasList = HudMenuList.New(480, 250, 46);
        extrasList.AddItem("ACHIEVEMENTS");
        extrasList.AddItem("BESTIARY");
        extrasList.AddItem("LORE ARCHIVE");
        extrasList.AddItem("HIGH SCORES");
        extrasList.AddItem("BACK");
        extrasList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        // Game over menu: Try Again (0), Main Menu (1)
        gameOverBG = ButtonGroup.New();
        gameOverBG.Add(0);
        gameOverBG.Add(1);
        gameOverBG.Select(0);
        gameOverList = HudMenuList.New(510, 348, 50);
        gameOverList.AddItem("TRY AGAIN");
        gameOverList.AddItem("MAIN MENU");
        gameOverList.SetColors(pal.menuText, pal.white, pal.menuHighlight);

        titleTimer = 0;
        bgScroll = 0;
        titleTween = Tween.New();
        titleTween.StartI64(0, 100, 54, EASE_OUT_EXPO);
        backdropReady = 0;       // parallax layers built on first drawTitle
        highlightY = SmoothValue.New(TITLE_MENU_Y + 0.0, 0.6);
        titleMoved = 0;
        continueAvailable = false;
        lcScoreTween = Tween.New();
        lcBurst = ParticleEmitter.New(80);
        lcBurst.Color = pal.coinGold;
        lcBurst.SetSize(2.0, 5.0);
        lcBurst.SetLifetime(28, 56);
        lcBurst.SetVelocity(60.0, 200.0, 0.0, 360.0);  // radial pop, any-angle
        lcBurst.SetGravity(0.0, 120.0);
        lcStarted = 0;
        lcBurstFired = 0;
        save = SaveData.New("xenoscape");

        // Default high scores
        highScores = [];
        highNames = [];
        var i = 0;
        while i < 10 {
            highScores.add((10 - i) * 1000);
            highNames.add("AAA");
            i = i + 1;
        }
        loadAuthoredTitleArt();
    }

    /// @brief Load and release-scale the optional first-party title key art.
    ///
    /// Package-relative, source-root, and examples/bin development paths are
    /// attempted in stable order. Missing/invalid PNG data records one diagnostic
    /// and leaves the existing procedural parallax/diorama fallback fully active.
    ///
    /// @return True when a 1280x720 title bitmap is ready, otherwise false.
    expose func loadAuthoredTitleArt() -> Boolean {
        loadAuthoredTitlePanel();
        titleKeyArt = Pixels.Load("assets/art/title-key-art.png");
        if titleKeyArt == null {
            titleKeyArt = Pixels.Load(
                "examples/games/xenoscape/assets/art/title-key-art.png");
        }
        if titleKeyArt == null {
            titleKeyArt = Pixels.Load("../games/xenoscape/assets/art/title-key-art.png");
        }
        if titleKeyArt == null {
            authoredTitleArtAvailable = false;
            Terminal.Say(
                "XENOSCAPE asset fallback: assets/art/title-key-art.png");
            return false;
        }
        titleKeyArt = titleKeyArt.Scale(SCREEN_W, SCREEN_H);
        authoredTitleArtAvailable = true;
        return true;
    }

    /// @brief Decode the first-party translucent title-menu UI texture.
    ///
    /// The panel is optional independently of key art: missing or malformed data
    /// keeps the existing Canvas rectangle fallback, while a valid exact-size PNG
    /// supplies circuit framing beneath live accessible text and focus widgets.
    ///
    /// @return True only when a 440x330 panel texture is retained.
    hide func loadAuthoredTitlePanel() -> Boolean {
        titlePanelTexture = Pixels.Load("assets/ui/title-menu-panel.png");
        if titlePanelTexture == null {
            titlePanelTexture = Pixels.Load(
                "examples/games/xenoscape/assets/ui/title-menu-panel.png");
        }
        if titlePanelTexture == null {
            titlePanelTexture = Pixels.Load(
                "../games/xenoscape/assets/ui/title-menu-panel.png");
        }
        if titlePanelTexture == null or
           titlePanelTexture.get_Width() != 440 or
           titlePanelTexture.get_Height() != 330 {
            authoredTitlePanelAvailable = false;
            Terminal.Say(
                "XENOSCAPE asset fallback: assets/ui/title-menu-panel.png");
            return false;
        }
        authoredTitlePanelAvailable = true;
        return true;
    }

    /// @brief Report whether first-party title art loaded successfully.
    ///
    /// @return True for authored art and false for procedural fallback mode.
    expose func hasAuthoredTitleArt() -> Boolean {
        return authoredTitleArtAvailable;
    }

    /// @brief Select authored title art or its permanent procedural fallback.
    ///
    /// @param enabled True to use loaded key art; false to force fallback mode.
    /// @return True when the request is drawable. Enabling without a loaded asset
    ///         returns false and leaves procedural fallback active.
    expose func setAuthoredTitleArtEnabled(enabled: Boolean) -> Boolean {
        if enabled and authoredTitleArtAvailable == false {
            authoredTitleArtEnabled = false;
            return false;
        }
        authoredTitleArtEnabled = enabled;
        return true;
    }

    // =========================================================================
    // Title Screen — returns game state to transition to, or -1 for none
    // =========================================================================

    //=========================================================
    // PER-SCREEN UPDATE/DRAW PAIRS
    //=========================================================
    // Each screen has an `update*` (handles input, returns the
    // game's next top-level state) and a `draw*` (renders).
    // Game.tick dispatches to the pair matching its current
    // state.

    /// @brief Title screen input.  Returns the menu choice
    ///        (start, continue, options, quit) as a state code.
    expose func updateTitle() -> Integer {
        titleTimer = titleTimer + 1;
        bgScroll = bgScroll + 1;
        titleTween.Update();

        var before = titleList.get_Selected();
        var chosen = titleList.HandleInput(Action.Pressed(ACT_UP),
                                           Action.Pressed(ACT_DOWN),
                                           Action.Pressed(ACT_CONFIRM));
        syncTitleSelection();
        var after = titleList.get_Selected();
        if before == after { titleMoved = 0; } else { titleMoved = 1; }

        // Glide the selection highlight toward the focused option (#5).
        highlightY.Target =
            (TITLE_MENU_Y + after * TITLE_MENU_ROW_STEP) + 0.0;
        highlightY.Update();

        // Selection
        if chosen >= 0 {
            if chosen == 0 {
                selectedLevel = 1;
                return STATE_PLAYING;
            }
            if chosen == 1 { return MENU_ACTION_CONTINUE; }
            if chosen == 2 { return STATE_LOADGAME; }
            if chosen == 3 { return STATE_OPTIONS; }
            if chosen == 4 { return STATE_EXTRAS; }
            if chosen == 5 { return STATE_CREDITS; }
            if chosen == 6 { return -2; }
        }

        return -1;
    }

    /// @brief Mirror title-screen ButtonGroup focus into the
    ///        corresponding HudMenuList highlight (and back).
    hide func syncTitleSelection() {
        var selected = titleList.get_Selected();
        if selected == 0 { titleBG.Select(MENU_NEW_GAME); }
        if selected == 1 { titleBG.Select(MENU_CONTINUE); }
        if selected == 2 { titleBG.Select(MENU_LOAD_GAME); }
        if selected == 3 { titleBG.Select(MENU_OPTIONS); }
        if selected == 4 { titleBG.Select(MENU_EXTRAS); }
        if selected == 5 { titleBG.Select(MENU_CREDITS); }
        if selected == 6 { titleBG.Select(MENU_QUIT); }
    }

    // Level select screen — pick starting level for testing
    /// @brief Level-select input.  Stashes the chosen level
    ///        in `selectedLevel` and returns the play state.
    expose func updateLevelSelect() -> Integer {
        titleTimer = titleTimer + 1;

        var chosen = levelList.HandleInput(Action.Pressed(ACT_UP),
                                           Action.Pressed(ACT_DOWN),
                                           Action.Pressed(ACT_CONFIRM));
        selectedLevel = levelList.get_Selected() + 1;
        levelSelectBG.Select(selectedLevel);

        if chosen >= 0 {
            selectedLevel = chosen + 1;
            return STATE_PLAYING;
        }
        if Action.Pressed(ACT_BACK) { return STATE_MENU; }

        return STATE_LEVELSELECT;
    }

    /// @brief Render the level-select grid.
    expose func drawLevelSelect(canvas: Canvas) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, pal.menuBg);
        drawStarfield(canvas);

        canvas.TextCenteredScaled(60, "SELECT LEVEL", pal.titleOrange, 4);

        var y = 140;
        var levelNum = 1;
        while levelNum <= LEVEL_COUNT {
            drawLevelOption(canvas, Int(levelNum) + ": " + getBiomeName(levelNum),
                            levelNum, y + (levelNum - 1) * 42);
            levelNum = levelNum + 1;
        }

        canvas.TextCenteredScaled(
            SCREEN_H - 40,
            Action.BindingsStr(ACT_CONFIRM) + " start   " +
            Action.BindingsStr(ACT_BACK) + " back",
            pal.hudGray, 2);
    }

    /// @brief Draw one row of the level-select list.
    hide func drawLevelOption(canvas: Canvas, label: String, levelNum: Integer, y: Integer) {
        var x = 440;
        var col = pal.menuText;

        if levelSelectBG.IsSelected(levelNum) {
            canvas.BoxAlpha(x - 20, y - 4, 400, 40, pal.menuHighlight, 150);
            col = pal.white;
            canvas.TextScaled(x - 30, y + 2, ">", 3, pal.titleOrange);
        }

        canvas.TextScaled(x, y + 2, label, 3, col);
    }

    /// @brief Title screen — animated logo + main menu list +
    ///        scrolling starfield.
    expose func drawTitle(canvas: Canvas) {
        // Cinematic parallax backdrop (#1): four depth-stacked layers
        // (nebula / stars / ridge / rocks) tiled and scrolled by a slowly
        // drifting menu Camera — replaces the old flat gradient + starfield +
        // ground/cloud loops.  Built once on first draw (Canvas now exists).
        if authoredTitleArtAvailable and authoredTitleArtEnabled {
            canvas.Blit(0, 0, titleKeyArt);
            canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H,
                            Color.RGB(1, 5, 12), 54);
            if authoredTitlePanelAvailable {
                canvas.Blit(TITLE_PANEL_X, TITLE_PANEL_Y, titlePanelTexture);
            } else {
                canvas.BoxAlpha(TITLE_PANEL_X, TITLE_PANEL_Y,
                                TITLE_PANEL_W, TITLE_PANEL_H,
                                Color.RGB(2, 7, 16), 105);
            }
        } else {
            if backdropReady == 0 { buildMenuBackdrop(); }
            if accessibilityReducedMotion == false { menuCam.Move(1, 0); }
            menuCam.DrawParallax(canvas);
        }

        // Cinematic logo reveal (#2): one eased master progress (0..100)
        // drives a staggered fade+rise — XENO leads, SCAPE follows, the
        // subtitle lands last.  Colours lerp up from the background via the
        // palette's integer-percent `mix` helper (there is no alpha-text API,
        // so "fade-in" = blend toward the final colour).
        var p = titleTween.ValueI64;
        if accessibilityReducedMotion { p = 100; }
        var pXeno = revealStage(p, 0, 70);
        var pScape = revealStage(p, 30, 100);
        var pSub = revealStage(p, 70, 100);

        var baseY = 80;
        var yXeno = baseY + (40 * (100 - pXeno)) / 100;
        var yScape = baseY + (40 * (100 - pScape)) / 100;
        if accessibilityReducedMotion { yXeno = baseY; yScape = baseY; }

        // Additive-style bloom behind the logo (#4): layered DiscAlpha haloes
        // whose strength tracks the reveal, then breathes subtly afterwards.
        var breathe = 6 + (titleTimer % 48) / 6;
        if accessibilityReducedMotion { breathe = 6; }
        var glow = (pXeno * (6 + breathe)) / 100;
        canvas.DiscAlpha(520, baseY + 24, 150, pal.titleOrange, glow);
        canvas.DiscAlpha(520, baseY + 24, 90, pal.titleYellow, glow + 4);

        canvas.TextScaled(280, yXeno, "XENO", 6, pal.mix(pal.menuBg, pal.titleOrange, pXeno));
        canvas.TextScaled(600, yScape, "SCAPE", 6, pal.mix(pal.menuBg, pal.titleYellow, pScape));

        if pSub > 0 {
            canvas.TextCenteredScaled(baseY + 56, "The Descent",
                                      pal.mix(pal.menuBg, pal.hudGray, pSub), 3);
        }

        if authoredTitleArtAvailable == false or
           authoredTitleArtEnabled == false {
            drawMenuDiorama(canvas, p);
        }

        // Gliding selection highlight (#5): a single eased box that slides
        // between options via SmoothValue, replacing the instant per-option box.
        var highlightAlpha = 150;
        if accessibilityHighContrast { highlightAlpha = 235; }
        canvas.BoxAlpha(TITLE_MENU_HIGHLIGHT_X, highlightY.ValueI64 - 4,
                        TITLE_MENU_HIGHLIGHT_W, 32,
                        pal.menuHighlight, highlightAlpha);

        var menuY = TITLE_MENU_Y;
        drawTitleOption(canvas, "NEW GAME", MENU_NEW_GAME, menuY, titleBG);
        if continueAvailable {
            drawTitleOption(canvas, "CONTINUE", MENU_CONTINUE,
                            menuY + TITLE_MENU_ROW_STEP, titleBG);
        } else {
            drawDisabledTitleOption(canvas, "CONTINUE",
                                    menuY + TITLE_MENU_ROW_STEP);
        }
        drawTitleOption(canvas, "LOAD GAME", MENU_LOAD_GAME,
                        menuY + TITLE_MENU_ROW_STEP * 2, titleBG);
        drawTitleOption(canvas, "OPTIONS", MENU_OPTIONS,
                        menuY + TITLE_MENU_ROW_STEP * 3, titleBG);
        drawTitleOption(canvas, "EXTRAS", MENU_EXTRAS,
                        menuY + TITLE_MENU_ROW_STEP * 4, titleBG);
        drawTitleOption(canvas, "CREDITS", MENU_CREDITS,
                        menuY + TITLE_MENU_ROW_STEP * 5, titleBG);
        drawTitleOption(canvas, "QUIT", MENU_QUIT,
                        menuY + TITLE_MENU_ROW_STEP * 6, titleBG);

        // Version + attribution
        canvas.TextCenteredScaled(SCREEN_H - 30, "Made with Zanna + Zia", pal.hudGray, 2);
    }

    /// @brief Draw the title-screen bottom diorama.
    ///
    /// The scene communicates the game's premise directly: a wrecked ship,
    /// scanner beacon, foreground terrain, and one suited explorer silhouette.
    /// It replaces the old looping runner with slower environmental motion that
    /// reads as intentional title art rather than an unexplained sprite.
    ///
    /// @param canvas Active title-screen canvas.
    /// @param reveal Logo reveal progress in the range 0..100.
    hide func drawMenuDiorama(canvas: Canvas, reveal: Integer) {
        var groundY = SCREEN_H - 88;
        canvas.BoxAlpha(0, groundY + 24, SCREEN_W, 78, Color.RGB(5, 8, 16), 210);
        canvas.Line(0, groundY + 22, SCREEN_W, groundY + 18, Color.RGB(48, 76, 98));

        var ridge = 0;
        while ridge < SCREEN_W {
            var h = 12 + (ridge / 47) % 28;
            canvas.Box(ridge, groundY + 24 - h, 62, h + 6, Color.RGB(18, 28, 38));
            ridge = ridge + 58;
        }

        var shipX = 148;
        var shipY = groundY - 10;
        canvas.Box(shipX, shipY, 180, 34, Color.RGB(74, 88, 108));
        canvas.Box(shipX + 18, shipY - 18, 92, 22, Color.RGB(94, 112, 136));
        canvas.Box(shipX + 118, shipY + 5, 52, 16, Color.RGB(42, 55, 72));
        canvas.Box(shipX + 34, shipY - 11, 28, 10, Color.RGB(36, 176, 210));
        canvas.Box(shipX + 72, shipY - 11, 28, 10, Color.RGB(36, 176, 210));
        canvas.Line(shipX - 26, shipY + 28, shipX + 14, shipY + 14, Color.RGB(160, 80, 44));
        canvas.Line(shipX + 160, shipY + 28, shipX + 216, shipY + 4, Color.RGB(160, 80, 44));

        var beaconX = shipX + 206;
        var pulse = 35 + (titleTimer % 60);
        canvas.Line(beaconX, groundY + 14, beaconX, groundY - 56, Color.RGB(120, 160, 190));
        canvas.Disc(beaconX, groundY - 60, 5, pal.titleYellow);
        canvas.Ring(beaconX, groundY - 60, pulse, Color.RGB(120, 210, 240));
        canvas.DiscAlpha(beaconX, groundY - 60, pulse + 10, Color.RGB(120, 210, 240), 18);

        var explorerX = shipX + 286;
        var explorerY = groundY + 2;
        canvas.Disc(explorerX + 14, explorerY - 34, 11, pal.playerHelmet);
        canvas.Box(explorerX + 7, explorerY - 23, 16, 24, pal.playerBody);
        canvas.Box(explorerX + 4, explorerY + 1, 7, 18, pal.playerBoots);
        canvas.Box(explorerX + 21, explorerY + 1, 7, 18, pal.playerBoots);
        canvas.Box(explorerX + 24, explorerY - 16, 20, 5, pal.titleOrange);
        canvas.DiscAlpha(explorerX + 58, explorerY - 13, 34, pal.titleOrange, 24 + reveal / 8);
    }

    /// @brief Draw one menu list entry with selected/unselected
    ///        styling.
    hide func drawMenuOption(canvas: Canvas, label: String, index: Integer,
                              y: Integer, bg: ButtonGroup) {
        var x = 520;
        var col = pal.menuText;

        if bg.IsSelected(index) {
            canvas.BoxAlpha(x - 20, y - 4, 280, 32, pal.menuHighlight, 150);
            col = pal.white;
            canvas.TextScaled(x - 30, y, ">", menuTextScale(3),
                              pal.titleOrange);
        }

        canvas.TextScaled(x, y, label, menuTextScale(3), col);
    }

    /// @brief Apply persistent menu legibility settings immediately.
    ///
    /// @param uiScale Advertised 100, 125, or 150 percent UI scale.
    /// @param highContrast True for opaque backing and brighter focus treatment.
    /// @param largeText True for one additional bitmap-font scale step.
    /// @param reducedMotion True to suppress title drift, bounce, and breathing.
    /// @return Nothing. Stores normalized values used by subsequent draws.
    expose func setAccessibility(uiScale: Integer, highContrast: Boolean,
                                 largeText: Boolean,
                                 reducedMotion: Boolean) {
        accessibilityUiScale = uiScale;
        if accessibilityUiScale != 100 and accessibilityUiScale != 125 and
           accessibilityUiScale != 150 { accessibilityUiScale = 100; }
        accessibilityHighContrast = highContrast;
        accessibilityLargeText = largeText;
        accessibilityReducedMotion = reducedMotion;
    }

    /// @brief Resolve one authored menu font scale through accessibility state.
    ///
    /// @param baseScale Positive authored bitmap-font scale.
    /// @return Bounded live menu scale in 1..6.
    hide func menuTextScale(baseScale: Integer) -> Integer {
        var result = accessibleTextScale(baseScale, accessibilityUiScale,
                                         accessibilityLargeText);
        if baseScale >= 3 and result > 4 { result = 4; }
        return result;
    }

    /// @brief Title-menu entry: text + selected arrow only.  The selection
    ///        box is drawn separately as one gliding highlight (#5), so this
    ///        omits the per-option box that `drawMenuOption` still draws for
    ///        the pause / game-over menus.
    hide func drawTitleOption(canvas: Canvas, label: String, index: Integer,
                              y: Integer, bg: ButtonGroup) {
        var x = TITLE_MENU_X;
        var scale = menuTextScale(3);
        var col = pal.menuText;
        if bg.IsSelected(index) {
            col = pal.white;
            canvas.TextScaled(x - (8 * scale + 8), y, ">", scale,
                              pal.titleOrange);
        }
        canvas.TextScaled(x, y, label, scale, col);
    }

    /// @brief Draw a title action that currently has no valid target.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param label Disabled action label; state is conveyed by its subdued color.
    /// @param y Screen-space baseline matching the ordinary title list.
    /// @return Nothing. Uses subdued color and never draws the activation arrow.
    hide func drawDisabledTitleOption(canvas: Canvas, label: String,
                                      y: Integer) {
        canvas.TextScaled(TITLE_MENU_X, y, label, menuTextScale(3),
                          Color.RGB(72, 78, 96));
    }

    /// @brief Animated star backdrop used by the title screen.
    hide func drawStarfield(canvas: Canvas) {
        var i = 0;
        while i < 80 {
            var sx = (i * 137 + bgScroll * (1 + i % 3)) % SCREEN_W;
            var sy = (i * 97 + 23) % SCREEN_H;
            var brightness = 100 + (i * 31) % 156;
            var col = brightness * 0x010101;
            canvas.Box(sx, sy, 2, 2, col);
            i = i + 1;
        }
    }

    /// @brief Map a master 0..100 progress into a sub-stage's own
    ///        0..100, clamped — used to stagger the logo reveal so
    ///        XENO leads, SCAPE follows, and the subtitle lands last.
    hide func revealStage(p: Integer, lo: Integer, hi: Integer) -> Integer {
        if p <= lo { return 0; }
        if p >= hi { return 100; }
        return (p - lo) * 100 / (hi - lo);
    }

    /// @brief Restart the cinematic logo reveal — call when the
    ///        title screen is (re-)entered so it replays.
    expose func resetTitleAnim() {
        titleTween.StartI64(0, 100, 54, EASE_OUT_EXPO);
    }

    /// @brief Did the title selection change this frame?  Game polls this to
    ///        play the menu-move SFX without re-reading (consuming) input.
    expose func titleSelectionMoved() -> Boolean {
        return titleMoved == 1;
    }

    /// @brief Set whether Continue has a valid expedition target.
    ///
    /// The title retains cursor navigation for consistent wrapping, but the row
    /// renders disabled and Game refuses activation when no slot is populated.
    ///
    /// @param available True when SaveManager exposes a valid continue slot.
    /// @return Nothing. Updates title presentation state only.
    expose func setContinueAvailable(available: Boolean) {
        continueAvailable = available;
    }

    /// @brief Build the four parallax layers for the menu backdrop (#1):
    ///        nebula / stars / ridge / rocks, registered on a menu Camera.
    ///        Lazy (first drawTitle) so a Canvas exists and the per-layer
    ///        Pixels are built once, never per frame (see plan perf budget).
    ///        Each layer Pixels is also kept in a field so the GC roots it.
    hide func buildMenuBackdrop() {
        menuCam = Camera.New(SCREEN_W, SCREEN_H);

        // Layer 1 — deep-space nebula (slowest).  Built small via Perlin
        // octave noise, blurred, then scaled up: a few thousand samples
        // instead of a per-pixel full-screen loop.  Opaque base layer.
        var nw = 192;
        var nh = 108;
        var neb = Pixels.New(nw, nh);
        neb.Fill(pal.cavernTop);
        var pn = PerlinNoise.New(20260528);
        var ny = 0;
        while ny < nh {
            var nx = 0;
            while nx < nw {
                var fx = (nx + 0.0) * 4.0 / (nw + 0.0);
                var fy = (ny + 0.0) * 4.0 / (nh + 0.0);
                var noiseF = pn.Octave2D(fx, fy, 4, 0.5);
                var amt = Convert.NumToInt((noiseF + 1.0) * 45.0);
                if amt > 8 {
                    neb.Set(nx, ny, pal.mix(pal.cavernTop, pal.crystalPurple, amt));
                }
                nx = nx + 1;
            }
            ny = ny + 1;
        }
        nebulaLayer = neb.Blur(3).Scale(SCREEN_W, SCREEN_H);
        menuCam.AddParallax(nebulaLayer, 10, 5);

        // Layer 2 — starfield: transparent buffer, varied-alpha white pixels.
        // Raw 0xRRGGBBAA (alpha in the low byte) so each star twinkles dimly.
        starLayer = Pixels.New(SCREEN_W, SCREEN_H);
        var si = 0;
        while si < 160 {
            var sx = (si * 137 + 17) % SCREEN_W;
            var sy = (si * 89 + 31) % SCREEN_H;
            var a = 70 + (si * 53) % 170;
            starLayer.Set(sx, sy, 0xFFFFFF00 + a);
            si = si + 1;
        }
        menuCam.AddParallax(starLayer, 22, 12);

        // Layer 3 — distant ridge silhouette along the bottom.
        ridgeLayer = Pixels.New(SCREEN_W, SCREEN_H);
        var rx = 0;
        while rx < SCREEN_W {
            var rh = 70 + ((rx * 13) % 70) + ((rx / 64) % 30);
            ridgeLayer.DrawBox(rx, SCREEN_H - rh, 18, rh, pal.bridgeBot);
            rx = rx + 18;
        }
        menuCam.AddParallax(ridgeLayer, 45, 0);

        // Layer 4 — nearest rock humps (fastest drift).
        foreLayer = Pixels.New(SCREEN_W, SCREEN_H);
        var fx2 = 0;
        while fx2 < SCREEN_W {
            var fh = 60 + ((fx2 * 17) % 34);
            foreLayer.DrawDisc(fx2, SCREEN_H + 8, fh, pal.viewportBg);
            fx2 = fx2 + 100;
        }
        menuCam.AddParallax(foreLayer, 80, 0);

        backdropReady = 1;
    }

    // =========================================================================
    // Pause Screen
    // =========================================================================

    /// @brief Pause-menu input.
    expose func updatePause() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return STATE_PLAYING;
        }

        var chosen = pauseList.HandleInput(Action.Pressed(ACT_UP),
                                           Action.Pressed(ACT_DOWN),
                                           Action.Pressed(ACT_CONFIRM));
        pauseBG.Select(pauseList.get_Selected());

        if chosen >= 0 {
            if chosen == 0 { return STATE_PLAYING; }
            if chosen == 1 { return MENU_ACTION_WORLD_MAP; }
            if chosen == 2 { return MENU_ACTION_SAVE; }
            if chosen == 3 { return MENU_ACTION_RECOVER; }
            if chosen == 4 { return STATE_OPTIONS; }
            if chosen == 5 { return STATE_CONTROLS; }
            if chosen == 6 { return STATE_MENU; }
        }

        return STATE_PAUSED;
    }

    /// @brief Options-menu input.
    ///
    /// Every persistent row is adjusted with left/right or confirm; the final
    /// row returns to the previous screen. The function returns generic action
    /// IDs so Game remains the owner of persistence and live subsystem updates.
    expose func updateOptions() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return OPTIONS_ACTION_BACK;
        }

        var chosen = optionsList.HandleInput(Action.Pressed(ACT_UP),
                                             Action.Pressed(ACT_DOWN),
                                             Action.Pressed(ACT_CONFIRM));
        var selected = optionsList.get_Selected();
        optionsBG.Select(selected);

        if selected < SETTING_COUNT {
            if Action.Pressed(ACT_LEFT) { return OPTIONS_ACTION_VALUE_DOWN; }
            if Action.Pressed(ACT_RIGHT) { return OPTIONS_ACTION_VALUE_UP; }
            if chosen >= 0 { return OPTIONS_ACTION_VALUE_UP; }
        }
        if chosen >= 0 {
            if selected == SETTING_COUNT { return OPTIONS_ACTION_BACK; }
        }

        return STATE_OPTIONS;
    }

    /// @brief Load-game input.  Returns a slot action for
    ///        slots 0..2, or STATE_MENU for Back.
    expose func updateLoadGame() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return STATE_MENU;
        }

        var chosen = loadList.HandleInput(Action.Pressed(ACT_UP),
                                          Action.Pressed(ACT_DOWN),
                                          Action.Pressed(ACT_CONFIRM));
        loadBG.Select(loadList.get_Selected());

        if chosen >= 0 {
            if chosen == 0 { return MENU_ACTION_LOAD_SLOT0; }
            if chosen == 1 { return MENU_ACTION_LOAD_SLOT1; }
            if chosen == 2 { return MENU_ACTION_LOAD_SLOT2; }
            if chosen == 3 { return STATE_MENU; }
        }

        return STATE_LOADGAME;
    }

    /// @brief Extras input.  Returns the chosen meta-game
    ///        destination or STATE_MENU for Back.
    expose func updateExtras() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return STATE_MENU;
        }

        var chosen = extrasList.HandleInput(Action.Pressed(ACT_UP),
                                            Action.Pressed(ACT_DOWN),
                                            Action.Pressed(ACT_CONFIRM));
        extrasBG.Select(extrasList.get_Selected());

        if chosen >= 0 {
            if chosen == 0 { return MENU_ACTION_EXTRAS_ACHIEVEMENTS; }
            if chosen == 1 { return MENU_ACTION_EXTRAS_BESTIARY; }
            if chosen == 2 { return MENU_ACTION_EXTRAS_LORE; }
            if chosen == 3 { return STATE_HIGHSCORES; }
            if chosen == 4 { return STATE_MENU; }
        }

        return STATE_EXTRAS;
    }

    /// @brief Credits input — exit only.
    expose func updateCredits() -> Integer {
        if Action.Pressed(ACT_BACK) { return STATE_MENU; }
        if Action.Pressed(ACT_CONFIRM) { return STATE_MENU; }
        return STATE_CREDITS;
    }

    /// @brief Current pause-menu row, used by enhanced pause rendering.
    expose func getPauseSelection() -> Integer {
        return pauseList.get_Selected();
    }

    /// @brief Current options-menu row, used by settings rendering.
    expose func getOptionsSelection() -> Integer {
        return optionsList.get_Selected();
    }

    /// @brief Selected save slot row.
    expose func getLoadSelection() -> Integer {
        return loadList.get_Selected();
    }

    /// @brief Selected extras row.
    expose func getExtrasSelection() -> Integer {
        return extrasList.get_Selected();
    }

    /// @brief Pause overlay — dim backdrop + simple menu.
    expose func drawPause(canvas: Canvas) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 150);
        canvas.TextCenteredScaled(240, "PAUSED", pal.white, 4);

        var y = 340;
        drawMenuOption(canvas, "RESUME", 0, y, pauseBG);
        drawMenuOption(canvas, "WORLD MAP", 1, y + 44, pauseBG);
        drawMenuOption(canvas, "SAVE GAME", 2, y + 88, pauseBG);
        drawMenuOption(canvas, "RETURN TO CHECKPOINT", 3, y + 132, pauseBG);
        drawMenuOption(canvas, "OPTIONS", 4, y + 176, pauseBG);
        drawMenuOption(canvas, "CONTROLS", 5, y + 220, pauseBG);
        drawMenuOption(canvas, "QUIT TO MENU", 6, y + 264, pauseBG);
    }

    // =========================================================================
    // Game Over
    // =========================================================================

    /// @brief Game-over input — retry / quit choice.
    expose func updateGameOver() -> Integer {
        var chosen = gameOverList.HandleInput(Action.Pressed(ACT_UP),
                                              Action.Pressed(ACT_DOWN),
                                              Action.Pressed(ACT_CONFIRM));
        gameOverBG.Select(gameOverList.get_Selected());

        if chosen >= 0 {
            if chosen == 0 { return STATE_PLAYING; }
            if chosen == 1 { return STATE_MENU; }
        }

        return STATE_GAMEOVER;
    }

    /// @brief Render the game-over screen with final score.
    expose func drawGameOver(canvas: Canvas, score: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 180);

        canvas.TextCenteredScaled(180, "GAME OVER", pal.hudRed, 5);

        var scoreStr = Int(score);
        canvas.TextCenteredScaled(260, "FINAL SCORE:", pal.hudGray, 3);
        canvas.TextScaled(480, 300, scoreStr, 4, pal.coinGold);

        var y = 380;
        drawMenuOption(canvas, "TRY AGAIN", 0, y, gameOverBG);
        drawMenuOption(canvas, "MAIN MENU", 1, y + 50, gameOverBG);
    }

    // =========================================================================
    // Level Complete
    // =========================================================================

    /// @brief Level-complete input — next-level / map / quit.
    expose func updateLevelComplete() -> Integer {
        titleTimer = titleTimer + 1;

        if Action.Pressed(ACT_CONFIRM) {
            return STATE_PLAYING;
        }

        return STATE_LEVELCOMPLETE;
    }

    /// @brief Level-complete screen — score breakdown.
    expose func drawLevelComplete(canvas: Canvas, score: Integer,
                                   timeBonus: Integer, levelNum: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 150);

        canvas.TextCenteredScaled(160, "LEVEL COMPLETE!", pal.hudGreen, 3);

        var levelName = "THE DESCENT";
        if levelNum == 2 { levelName = "SALVAGE"; }
        if levelNum == 3 { levelName = "FROZEN ABYSS"; }
        if levelNum == 4 { levelName = "OVERGROWTH"; }
        canvas.TextCenteredScaled(210, levelName, pal.hudBlue, 2);

        var revealFrames = titleTimer;

        if revealFrames > 30 {
            var scoreStr = Int(score);
            canvas.TextScaled(460, 270, "SCORE:", 2, pal.hudGray);
            canvas.TextScaled(570, 270, scoreStr, 2, pal.white);
        }

        if revealFrames > 60 {
            var bonusStr = Int(timeBonus);
            canvas.TextScaled(460, 310, "TIME BONUS:", 2, pal.hudGray);
            canvas.TextScaled(640, 310, bonusStr, 2, pal.coinGold);
        }

        if revealFrames > 90 {
            var total = score + timeBonus;
            var totalStr = Int(total);
            canvas.TextScaled(460, 350, "TOTAL:", 2, pal.hudGray);
            canvas.TextScaled(570, 350, totalStr, 2, pal.titleOrange);
        }

        if revealFrames > 120 {
            canvas.TextCenteredScaled(
                430, Action.BindingsStr(ACT_CONFIRM) + " continue",
                pal.hudGray, 2);
        }
    }

    /// @brief Begin the level-complete cinematic (#8): count the score up and
    ///        re-arm the celebratory burst.  Called once on entering the state.
    expose func startLevelComplete(finalScore: Integer) {
        lcScoreTween.StartI64(0, finalScore, 50, EASE_OUT_QUAD);
        lcStarted = 1;
        lcBurstFired = 0;
    }

    /// @brief Render a ranked regional debrief with a tweened score celebration.
    ///
    /// The letter rank is supplied by the authoritative meta-progression scorer;
    /// this presentation never derives performance from arcade score.  Once the
    /// score tween settles, a one-shot particle burst confirms the final tally.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param levelNum One-based completed campaign region.
    /// @param timeMs Regional clear time in milliseconds.
    /// @param damageTaken Total HP lost during the completed region.
    /// @param discoveries Optional discoveries completed in the region.
    /// @param rankLabel Authoritative D/C/B/A/S rank label.
    /// @param rankScore Authoritative 0..1000 performance score.
    /// @param enemiesKilled Regional enemies defeated.
    /// @param coinsCollected Regional coin total.
    /// @param gemsFound Regional salvage total.
    /// @param finalScore Arcade score before the time bonus.
    /// @param timeBonus Awarded arcade time bonus.
    /// @return Nothing. Draws presentation and advances local visual effects.
    expose func drawLevelCompleteCinematic(canvas: Canvas, levelNum: Integer,
                                         timeMs: Integer, damageTaken: Integer,
                                         discoveries: Integer, rankLabel: String,
                                         rankScore: Integer, enemiesKilled: Integer,
                                         coinsCollected: Integer,
                                         gemsFound: Integer, finalScore: Integer,
                                         timeBonus: Integer) {
        if lcStarted == 0 { startLevelComplete(finalScore); }
        lcScoreTween.Update();
        var shownScore = lcScoreTween.ValueI64;

        drawEnhancedLevelComplete(canvas, pal, levelNum, timeMs, damageTaken,
                                  discoveries, rankLabel, rankScore,
                                  enemiesKilled, coinsCollected, gemsFound,
                                  shownScore, timeBonus);

        if lcScoreTween.IsComplete and lcBurstFired == 0 {
            lcBurst.SetPosition((SCREEN_W / 2) + 0.0, 480.0);
            lcBurst.Burst(48);
            lcBurstFired = 1;
        }
        lcBurst.Update();
        lcBurst.Draw(canvas);
    }

    // =========================================================================
    // Victory (after beating boss)
    // =========================================================================

    /// @brief Victory-screen input.
    expose func updateVictory() -> Integer {
        titleTimer = titleTimer + 1;

        if Action.Pressed(ACT_CONFIRM) {
            return STATE_MENU;
        }

        return STATE_VICTORY;
    }

    /// @brief Simple end-credits/victory screen.  Used as the
    ///        fallback; richer one is `drawVictoryScreen`.
    expose func drawVictory(canvas: Canvas, score: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 180);

        var flash = titleTimer % 30;
        var titleCol = pal.titleOrange;
        if flash < 15 { titleCol = pal.titleYellow; }

        canvas.TextCenteredScaled(120, "VICTORY!", titleCol, 6);

        canvas.TextCenteredScaled(230, "All sectors cleared!", pal.white, 2);
        canvas.TextCenteredScaled(270, "The alien world is safe.", pal.crystalBlue, 2);

        var scoreStr = Int(score);
        canvas.TextScaled(450, 350, "FINAL SCORE:", 3, pal.hudGray);
        canvas.TextScaled(480, 390, scoreStr, 4, pal.coinGold);

        if titleTimer > 60 {
            canvas.TextCenteredScaled(
                490, Action.BindingsStr(ACT_CONFIRM) + " return to menu",
                pal.hudGray, 2);
        }
    }

    // =========================================================================
    // High Scores
    // =========================================================================

    /// @brief High-scores screen input — exit only.
    expose func updateHighScores() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return STATE_MENU;
        }
        if Action.Pressed(ACT_CONFIRM) {
            return STATE_MENU;
        }
        return STATE_HIGHSCORES;
    }

    /// @brief Render the top-N high-scores table.
    expose func drawHighScores(canvas: Canvas) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, pal.menuBg);
        drawStarfield(canvas);

        canvas.TextCenteredScaled(40, "HIGH SCORES", pal.titleYellow, 4);

        var i = 0;
        while i < 10 {
            var y = 130 + i * 42;
            var rankStr = Int(i + 1);
            var scoreStr = Int(highScores.get(i));
            var name = highNames.get(i);

            var col = pal.menuText;
            if i == 0 { col = pal.coinGold; }
            if i == 1 { col = pal.stoneLight; }
            if i == 2 { col = pal.bossArmor; }

            canvas.TextScaled(380, y, rankStr, 2, pal.hudGray);
            canvas.TextScaled(420, y, name, 2, col);
            canvas.TextScaled(600, y, scoreStr, 2, col);
            i = i + 1;
        }

        canvas.TextCenteredScaled(
            SCREEN_H - 40,
            Action.BindingsStr(ACT_CONFIRM) + " / " +
            Action.BindingsStr(ACT_BACK) + " return",
            pal.hudGray, 2);
    }

    /// @brief Insert a new high score, evict the lowest if
    ///        the table is full, then `saveHighScores()`.
    expose func addHighScore(score: Integer, name: String) {
        var i = 0;
        while i < 10 {
            if score > highScores.get(i) {
                var j = 9;
                while j > i {
                    highScores.set(j, highScores.get(j - 1));
                    highNames.set(j, highNames.get(j - 1));
                    j = j - 1;
                }
                highScores.set(i, score);
                highNames.set(i, name);
                return;
            }
            i = i + 1;
        }
    }

    /// @brief "Would this score make the table?"  Game.tick
    ///        asks before the post-game name-entry screen.
    expose func isHighScore(score: Integer) -> Boolean {
        return score > highScores.get(9);
    }

    // Persistent high scores via SaveData (cross-platform JSON)
    /// @brief Pull the high-score table from SaveData.
    expose func loadHighScores() {
        save.Load();
        var i = 0;
        while i < 10 {
            highScores.set(i, save.GetInt("hs_score_${i}", (10 - i) * 1000));
            highNames.set(i, save.GetString("hs_name_${i}", "AAA"));
            i = i + 1;
        }
    }

    /// @brief Persist the high-score table to SaveData.
    expose func saveHighScores() {
        var i = 0;
        while i < 10 {
            save.SetInt("hs_score_${i}", highScores.get(i));
            save.SetString("hs_name_${i}", highNames.get(i));
            i = i + 1;
        }
        save.Save();
    }

    // =========================================================================
    // Controls Screen
    // =========================================================================

    /// @brief Controls / how-to-play screen input — exit only.
    expose func updateControls() -> Integer {
        if Action.Pressed(ACT_BACK) {
            return STATE_MENU;
        }
        if Action.Pressed(ACT_CONFIRM) {
            return STATE_MENU;
        }
        return STATE_CONTROLS;
    }

    /// @brief Render the input bindings cheat-sheet.
    expose func drawControls(canvas: Canvas) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, pal.menuBg);
        drawStarfield(canvas);

        canvas.TextCenteredScaled(36, "CONTROL MATRIX", pal.titleOrange, 4);
        canvas.TextCenteredScaled(82,
                                  "Live keyboard and gamepad bindings",
                                  pal.hudGray, 2);

        canvas.BoxAlpha(82, 126, 535, 454, Color.RGB(8, 13, 25), 220);
        canvas.Frame(82, 126, 535, 454, Color.RGB(55, 80, 125));
        canvas.BoxAlpha(663, 126, 535, 454, Color.RGB(8, 13, 25), 220);
        canvas.Frame(663, 126, 535, 454, Color.RGB(55, 80, 125));
        canvas.TextScaled(112, 151, "MOVEMENT", 3, pal.titleYellow);
        canvas.TextScaled(693, 151, "SUIT SYSTEMS", 3, pal.titleYellow);

        var y = 202;
        var gap = 58;
        drawControlCard(canvas, 112, y, "MOVE LEFT", ACT_LEFT);
        drawControlCard(canvas, 112, y + gap, "MOVE RIGHT", ACT_RIGHT);
        drawControlCard(canvas, 112, y + gap * 2, "LOOK UP", ACT_MOVE_UP);
        drawControlCard(canvas, 112, y + gap * 3, "CROUCH / POUND", ACT_MOVE_DOWN);
        drawControlCard(canvas, 112, y + gap * 4, "JUMP", ACT_JUMP);
        drawControlCard(canvas, 112, y + gap * 5, "WORLD MAP", ACT_MAP);

        drawControlCard(canvas, 693, y, "BLASTER / CHARGE", ACT_SHOOT);
        drawControlCard(canvas, 693, y + gap, "DASH", ACT_DASH);
        drawControlCard(canvas, 693, y + gap * 2, "GRAPPLE", ACT_GRAPPLE);
        drawControlCard(canvas, 693, y + gap * 3, "INTERACT", ACT_INTERACT);
        drawControlCard(canvas, 693, y + gap * 4, "PAUSE / BACK", ACT_BACK);
        drawControlCard(canvas, 693, y + gap * 5, "FULLSCREEN", ACT_FULLSCREEN);

        canvas.TextCenteredScaled(
            SCREEN_H - 70,
            Action.BindingsStr(ACT_INTERACT) +
            " replay suit guidance (active expedition)",
            pal.crystalBlue, 1);
        canvas.TextCenteredScaled(
            SCREEN_H - 46,
            Action.BindingsStr(ACT_CONFIRM) + " / " +
            Action.BindingsStr(ACT_BACK) + " return",
            pal.hudGray, 1);
    }

    /// @brief Draw one live semantic-action binding on the Controls screen.
    ///
    /// @param canvas Borrowed menu canvas.
    /// @param x Left edge of the row within its two-column panel.
    /// @param y Baseline of the action label.
    /// @param label Player-facing semantic action label.
    /// @param action Stable runtime action id queried for current bindings.
    /// @return Nothing. Draws the label and active keyboard/gamepad binding text.
    hide func drawControlCard(canvas: Canvas, x: Integer, y: Integer,
                              label: String, action: String) {
        canvas.TextScaled(x, y, label, 2, pal.hudGray);
        canvas.TextScaled(x + 245, y, Action.BindingsStr(action), 2, pal.white);
    }

    /// @brief Reset every screen's cursor focus to the first
    ///        item.  Called on screen entry.
    expose func resetSelection() {
        titleBG.Select(MENU_PLAY);
        titleList.set_Selected(0);
        pauseBG.Select(0);
        pauseList.set_Selected(0);
        optionsBG.Select(0);
        optionsList.set_Selected(0);
        loadBG.Select(0);
        loadList.set_Selected(0);
        extrasBG.Select(0);
        extrasList.set_Selected(0);
        gameOverBG.Select(0);
        gameOverList.set_Selected(0);
        levelSelectBG.Select(selectedLevel);
        levelList.set_Selected(selectedLevel - 1);
        titleTimer = 0;
    }

    // =========================================================================
    // Save Slot Selection Screen
    // =========================================================================

    /// @brief Save-slot picker — three rows from `SaveManager`
    ///        with summary text and a delete option.
    expose func drawSaveSlotScreen(canvas: Canvas, selectedSlot: Integer,
                                    slot1: String, slot2: String, slot3: String) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, pal.menuBg);
        drawStarfield(canvas);

        canvas.TextCenteredScaled(72, "LOAD GAME", pal.white, 4);
        canvas.TextCenteredScaled(116, "Choose a save slot to continue the descent",
                                  pal.hudGray, 2);

        var slotTexts = [slot1, slot2, slot3];
        var i = 0;
        while i < 3 {
            var cardX = 240;
            var cardY = 170 + i * 112;
            var cardW = 800;
            var cardH = 90;

            if i == selectedSlot {
                canvas.Box(cardX - 4, cardY - 4, cardW + 8, cardH + 8, pal.menuHighlight);
            }

            canvas.Box(cardX, cardY, cardW, cardH, Color.RGB(30, 30, 45));
            canvas.Frame(cardX, cardY, cardW, cardH, Color.RGB(70, 70, 100));

            // Slot number
            canvas.TextScaled(cardX + 20, cardY + 15, "Slot ${i + 1}", 2, pal.white);

            // Slot info
            canvas.TextScaled(cardX + 20, cardY + 50, slotTexts.get(i), 2, pal.hudGray);

            // Arrow indicator for selected
            if i == selectedSlot {
                canvas.TextScaled(cardX - 30, cardY + 30, ">", 3, pal.menuHighlight);
            }

            i = i + 1;
        }

        var backY = 530;
        if selectedSlot == 3 {
            canvas.Box(464, backY - 6, 350, 38, pal.menuHighlight);
        }
        canvas.TextCenteredScaled(backY, "BACK", pal.white, 2);

        canvas.TextCenteredScaled(
            SCREEN_H - 60,
            Action.BindingsStr(ACT_UP) + "/" + Action.BindingsStr(ACT_DOWN) +
            " select   " + Action.BindingsStr(ACT_CONFIRM) + " load",
            pal.hudGray, 1);
        canvas.TextCenteredScaled(
            SCREEN_H - 35, Action.BindingsStr(ACT_BACK) + " back",
            pal.hudGray, 1);
    }

    /// @brief Extras hub — achievements, bestiary, lore archive,
    ///        and legacy high-score table.
    expose func drawExtras(canvas: Canvas, achievementCount: Integer,
                           achievementTotal: Integer, loreCount: Integer,
                           loreTotal: Integer, bestiaryCount: Integer,
                           bestiaryTotal: Integer) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, pal.menuBg);
        drawStarfield(canvas);

        canvas.TextCenteredScaled(70, "EXTRAS", pal.titleYellow, 4);
        canvas.TextCenteredScaled(114, "Records, discoveries, and archived intel",
                                  pal.hudGray, 2);

        var px = 340;
        var py = 176;
        var pw = 600;
        var ph = 344;
        canvas.BoxAlpha(px, py, pw, ph, Color.RGB(8, 10, 20), 210);
        canvas.Frame(px, py, pw, ph, Color.RGB(70, 90, 140));

        drawExtrasOption(canvas, "ACHIEVEMENTS",
                         Int(achievementCount) + "/" + Int(achievementTotal),
                         0, py + 42);
        drawExtrasOption(canvas, "BESTIARY",
                         Int(bestiaryCount) + "/" + Int(bestiaryTotal),
                         1, py + 88);
        drawExtrasOption(canvas, "LORE ARCHIVE",
                         Int(loreCount) + "/" + Int(loreTotal),
                         2, py + 134);
        drawExtrasOption(canvas, "HIGH SCORES", "table", 3, py + 180);
        drawExtrasOption(canvas, "BACK", "", 4, py + 226);

        canvas.TextCenteredScaled(
            SCREEN_H - 46,
            Action.BindingsStr(ACT_CONFIRM) + " open   " +
            Action.BindingsStr(ACT_BACK) + " return",
            pal.hudGray, 1);
    }

    /// @brief One row in the Extras hub.
    hide func drawExtrasOption(canvas: Canvas, label: String, detail: String,
                               idx: Integer, y: Integer) {
        var selected = extrasBG.IsSelected(idx);
        var col = pal.menuText;
        if selected {
            canvas.BoxAlpha(390, y - 4, 500, 34, pal.menuHighlight, 160);
            canvas.TextScaled(360, y, ">", 3, pal.titleOrange);
            col = pal.white;
        }
        canvas.TextScaled(410, y, label, 2, col);
        if detail != "" {
            canvas.TextScaled(760, y, detail, 2, pal.hudGray);
        }
    }

    /// @brief Release-style credits screen.
    expose func drawCredits(canvas: Canvas) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, Color.RGB(4, 5, 14));
        drawStarfield(canvas);

        canvas.TextCenteredScaled(80, "XENOSCAPE", pal.titleYellow, 4);
        canvas.TextCenteredScaled(126, "The Descent", pal.titleOrange, 2);

        var y = 210;
        canvas.TextCenteredScaled(y, "Built with Zanna + Zia", pal.white, 2);
        canvas.TextCenteredScaled(y + 50, "Programming, procedural art, audio, and systems",
                                  pal.hudGray, 2);
        canvas.TextCenteredScaled(y + 92, "Zanna Project", pal.crystalBlue, 2);
        canvas.TextCenteredScaled(y + 132,
                                  "Original key art and ARIA portrait commissioned for XENOSCAPE",
                                  pal.hudGray, 1);
        canvas.TextCenteredScaled(y + 178, "Thanks for playing XENOSCAPE: The Descent.",
                                  pal.menuText, 2);
        canvas.TextCenteredScaled(
            SCREEN_H - 54,
            Action.BindingsStr(ACT_CONFIRM) + " / " +
            Action.BindingsStr(ACT_BACK) + " return",
            pal.hudGray, 1);
    }

    // =========================================================================
    // Victory Screen (game complete)
    // =========================================================================

    /// @brief Draw the normal or true ending and postgame-unlock summary.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param totalTime Campaign play time in seconds.
    /// @param totalGems Current banked salvage.
    /// @param lorePercent Stable primary-lore completion percentage.
    /// @param trueEnding True when all abilities and primary lore were collected.
    /// @return Nothing. Draws only; Game owns the return-to-hub transition.
    expose func drawVictoryScreen(canvas: Canvas, totalTime: Integer,
                                   totalGems: Integer, lorePercent: Integer,
                                   trueEnding: Boolean) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, Color.RGB(5, 5, 15));

        // Stars background
        var i = 0;
        while i < 30 {
            var sx2 = (i * 137 + titleTimer) % SCREEN_W;
            var sy2 = (i * 251) % SCREEN_H;
            canvas.Disc(sx2, sy2, 1, Color.RGB(200, 200, 220));
            i = i + 1;
        }

        // Title
        canvas.TextCenteredScaled(100, "XENOSCAPE", Color.RGB(255, 221, 34), 4);
        var endingTitle = "THE ARCHITECT HAS BEEN SHUT DOWN";
        if trueEnding { endingTitle = "THE XENOSCAPE SIGNAL IS RESTORED"; }
        canvas.TextCenteredScaled(160, endingTitle,
                                  Color.RGB(180, 200, 220), 2);

        // Stats
        var statsY = 260;
        var missionTitle = "NORMAL ENDING // MISSION COMPLETE";
        if trueEnding { missionTitle = "TRUE ENDING // ALL SIGNALS RECOVERED"; }
        canvas.TextCenteredScaled(statsY, missionTitle,
                                  Color.RGB(100, 255, 150), 2);

        var mins = totalTime / 60;
        var secs = totalTime % 60;
        canvas.TextCenteredScaled(statsY + 50, "Total Time: ${mins}:${secs}",
                                  pal.white, 2);
        canvas.TextCenteredScaled(statsY + 90, "Salvage Recovered: ${totalGems}",
                                  Color.RGB(100, 200, 255), 2);
        canvas.TextCenteredScaled(statsY + 130, "Lore Discovered: ${lorePercent}%",
                                  Color.RGB(200, 180, 255), 2);

        // Thank you
        canvas.TextCenteredScaled(statsY + 200,
                                  "Boss Rush and New Game+ are now online.",
                                  Color.RGB(180, 150, 235), 1);
        canvas.TextCenteredScaled(statsY + 230,
                                  "Regional Time Trials remain available in the hub.",
                                  Color.RGB(120, 130, 160), 1);

        // Return prompt
        canvas.TextCenteredScaled(SCREEN_H - 50,
                                  "Confirm to return to the Shipwreck Hub",
                                  Color.RGB(100, 100, 130), 1);
    }

    // Biome name lookup for HUD
    /// @brief Map level index → biome display name.
    expose func getBiomeName(levelNum: Integer) -> String {
        if levelNum == 1 { return "Crash Site"; }
        if levelNum == 2 { return "Fungal Caverns"; }
        if levelNum == 3 { return "Crystal Depths"; }
        if levelNum == 4 { return "Surface Ruins"; }
        if levelNum == 5 { return "Underground Lake"; }
        if levelNum == 6 { return "Thermal Vents"; }
        if levelNum == 7 { return "Overgrowth"; }
        if levelNum == 8 { return "Frozen Abyss"; }
        if levelNum == 9 { return "Corrupted Ruins"; }
        if levelNum == 10 { return "The Core"; }
        return "Unknown";
    }

    // =========================================================================
    // Enhanced Pause Menu — commercial quality with semi-transparent panel
    // =========================================================================
    /// @brief Richer pause-menu variant — current biome,
    ///        play-time, ability summary, world map shortcut.
    expose func drawEnhancedPause(canvas: Canvas, _pal: Palette,
                                   currentLevel: Integer, playTime: Integer,
                                   gems: Integer, hp: Integer, maxHp: Integer,
                                   score: Integer, selectedOption: Integer) {
        // Full-screen darken
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 160);

        // Central panel with border
        var panelX = SCREEN_W / 2 - 300;
        var panelY = 80;
        var panelW = 600;
        var panelH = 520;

        // HudPanel shadow
        canvas.BoxAlpha(panelX + 4, panelY + 4, panelW, panelH, Color.RGB(0, 0, 0), 80);
        // HudPanel background
        canvas.Box(panelX, panelY, panelW, panelH, Color.RGB(15, 15, 25));
        // HudPanel border (double line)
        canvas.Frame(panelX, panelY, panelW, panelH, Color.RGB(80, 100, 160));
        canvas.Frame(panelX + 2, panelY + 2, panelW - 4, panelH - 4, Color.RGB(40, 50, 80));

        // Title bar
        canvas.Box(panelX + 4, panelY + 4, panelW - 8, 40, Color.RGB(25, 30, 50));
        canvas.TextCenteredScaled(panelY + 12, "PAUSED", Color.RGB(200, 210, 240), 3);

        // Divider
        canvas.Line(panelX + 20, panelY + 50, panelX + panelW - 20, panelY + 50,
                    Color.RGB(50, 60, 90));

        // Stats section
        var statsY = panelY + 70;
        var statsX = panelX + 40;
        var biomeName = getBiomeName(currentLevel);

        // Biome name with colored indicator
        canvas.Box(statsX, statsY, 12, 12, getBiomeColor(currentLevel));
        canvas.Text(statsX + 18, statsY, "Area ${currentLevel}: ${biomeName}",
                    Color.RGB(180, 190, 210));

        // Time
        var mins = playTime / 60000;
        var secs = (playTime / 1000) % 60;
        canvas.Text(statsX, statsY + 24, "Time: ${mins}:${secs}",
                    Color.RGB(140, 150, 170));

        // Health bar (wide, with labels)
        canvas.Text(statsX, statsY + 48, "HP:", Color.RGB(140, 150, 170));
        var barX = statsX + 40;
        var barW = 200;
        var barH = 14;
        canvas.Box(barX, statsY + 48, barW, barH, Color.RGB(40, 20, 20));
        var fillW = hp * barW / maxHp;
        var barColor = Color.RGB(50, 200, 80);
        if hp <= maxHp / 3 { barColor = Color.RGB(220, 50, 50); }
        else if hp <= maxHp * 2 / 3 { barColor = Color.RGB(220, 180, 50); }
        canvas.Box(barX, statsY + 48, fillW, barH, barColor);
        canvas.Frame(barX, statsY + 48, barW, barH, Color.RGB(80, 90, 110));
        canvas.Text(barX + barW + 8, statsY + 48, "${hp}/${maxHp}",
                    Color.RGB(180, 190, 210));

        // Arcade score and permanent upgrade currency are deliberately named
        // separately so players do not mistake score for spendable progress.
        canvas.Text(statsX, statsY + 72, "Score: ${score}", Color.RGB(255, 221, 34));
        canvas.Text(statsX + 200, statsY + 72, "Salvage: ${gems}",
                    Color.RGB(100, 200, 255));

        // Divider
        canvas.Line(panelX + 20, statsY + 100, panelX + panelW - 20, statsY + 100,
                    Color.RGB(50, 60, 90));

        // Menu options
        var optY = statsY + 120;
        var options = ["Resume", "World Map", "Save Game",
                       "Return to Checkpoint", "Options", "Controls",
                       "Quit to Title"];
        var optColors = [
            Color.RGB(100, 255, 150),  // Resume: green
            Color.RGB(100, 180, 255),  // Map: blue
            Color.RGB(255, 221, 34),   // Save: gold
            Color.RGB(100, 220, 220),  // Recovery: cyan
            Color.RGB(180, 180, 255),  // Options: lavender
            Color.RGB(180, 180, 200),  // Controls: gray
            Color.RGB(255, 100, 100)   // Quit: red
        ];

        var i = 0;
        while i < 7 {
            var y = optY + i * 40;
            if i == selectedOption {
                // Selected: highlighted background
                canvas.Box(panelX + 20, y - 4, panelW - 40, 36,
                           Color.RGB(30, 40, 70));
                canvas.Frame(panelX + 20, y - 4, panelW - 40, 36,
                             Color.RGB(80, 120, 200));
                canvas.TextScaled(panelX + 50, y, "> " + options.get(i),
                                  2, optColors.get(i));
            } else {
                canvas.TextScaled(panelX + 50, y, "  " + options.get(i),
                                  2, Color.RGB(100, 110, 130));
            }
            i = i + 1;
        }

        // Bottom hint
        canvas.TextCenteredScaled(
            panelY + panelH - 30,
            Action.BindingsStr(ACT_UP) + "/" + Action.BindingsStr(ACT_DOWN) +
            " navigate   " + Action.BindingsStr(ACT_CONFIRM) + " select",
            Color.RGB(60, 70, 90), 1);
    }

    // Get biome indicator color for the pause menu
    /// @brief Map level index → biome accent colour.
    hide func getBiomeColor(levelNum: Integer) -> Integer {
        if levelNum == 1 { return Color.RGB(80, 160, 200); } // Crash: teal
        if levelNum == 2 { return Color.RGB(80, 200, 60); }  // Fungal: green
        if levelNum == 3 { return Color.RGB(100, 140, 220); } // Crystal: blue
        if levelNum == 4 { return Color.RGB(120, 160, 80); }  // Ruins: moss
        if levelNum == 5 { return Color.RGB(60, 120, 180); }  // Lake: deep blue
        if levelNum == 6 { return Color.RGB(220, 100, 30); }  // Thermal: orange
        if levelNum == 7 { return Color.RGB(80, 140, 60); }   // Overgrowth: dark green
        if levelNum == 8 { return Color.RGB(140, 180, 220); } // Frozen: ice blue
        if levelNum == 9 { return Color.RGB(140, 50, 180); }  // Corrupted: purple
        if levelNum == 10 { return Color.RGB(200, 60, 255); } // Core: bright purple
        return Color.RGB(120, 120, 140);
    }

    // =========================================================================
    // Level Complete Screen — enhanced with stats breakdown
    // =========================================================================
    /// @brief Draw the complete regional performance and collection debrief.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param _pal Borrowed palette retained for API compatibility.
    /// @param levelNum One-based completed campaign region.
    /// @param timeMs Regional clear time in milliseconds.
    /// @param damageTaken Total HP lost during the completed region.
    /// @param discoveries Optional discoveries completed in 0..4.
    /// @param rank Authoritative D/C/B/A/S label from meta progression.
    /// @param rankScore Authoritative composite performance score in 0..1000.
    /// @param enemiesKilled Regional enemy defeats retained for the arcade tally.
    /// @param coinsCollected Regional coins retained for the arcade tally.
    /// @param gemsFound Regional salvage retained for the arcade tally.
    /// @param score Current tweened arcade score.
    /// @param timeBonus Awarded arcade time bonus.
    /// @return Nothing. Draws only and does not mutate progression.
    expose func drawEnhancedLevelComplete(canvas: Canvas, _pal: Palette,
                                          levelNum: Integer, timeMs: Integer,
                                          damageTaken: Integer,
                                          discoveries: Integer, rank: String,
                                          rankScore: Integer,
                                          enemiesKilled: Integer,
                                          coinsCollected: Integer,
                                          gemsFound: Integer, score: Integer,
                                          timeBonus: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10),
                        accessiblePanelAlpha(accessibilityHighContrast));

        // HudPanel
        var px = SCREEN_W / 2 - 350;
        var py = 100;
        var pw = 700;
        var ph = 510;
        canvas.Box(px + 4, py + 4, pw, ph, Color.RGB(0, 0, 0));
        canvas.Box(px, py, pw, ph, Color.RGB(12, 15, 25));
        canvas.Frame(px, py, pw, ph, Color.RGB(60, 100, 160));

        // Title
        var biomeName = getBiomeName(levelNum);
        canvas.TextCenteredScaled(py + 20, biomeName + " COMPLETE", Color.RGB(100, 255, 150), 3);

        // Divider
        canvas.Line(px + 30, py + 60, px + pw - 30, py + 60, Color.RGB(40, 60, 90));

        // Stats breakdown with animated reveal
        var statY = py + 80;
        var labelX = px + 60;
        var valueX = px + pw - 180;

        drawStatRow(canvas, labelX, statY, "Clear Time", formatTime(timeMs),
                    Color.RGB(180, 190, 210));
        drawStatRow(canvas, labelX, statY + 36, "Damage Taken", Int(damageTaken),
                    Color.RGB(255, 150, 100));
        drawStatRow(canvas, labelX, statY + 72, "Discoveries", Int(discoveries) + " / 4",
                    Color.RGB(100, 200, 255));
        var optionalStatus = "INCOMPLETE";
        var optionalColor = Color.RGB(180, 100, 100);
        if discoveries >= 4 {
            optionalStatus = "COMPLETE";
            optionalColor = Color.RGB(100, 255, 150);
        }
        drawStatRow(canvas, labelX, statY + 108, "Optional Objectives",
                    optionalStatus, optionalColor);

        // Divider
        canvas.Line(px + 30, statY + 148, px + pw - 30, statY + 148,
                    Color.RGB(40, 60, 90));

        canvas.TextCenteredScaled(statY + 165,
                                  "ENEMIES " + Int(enemiesKilled) +
                                  "   COINS " + Int(coinsCollected) +
                                  "   SALVAGE " + Int(gemsFound),
                                  Color.RGB(140, 150, 170), 1);

        // Bonuses
        drawStatRow(canvas, labelX, statY + 192, "Time Bonus", "+" + Int(timeBonus),
                    Color.RGB(200, 255, 100));

        // Total score
        canvas.Line(px + 30, statY + 228, px + pw - 30, statY + 228,
                    Color.RGB(60, 80, 120));
        canvas.TextScaled(labelX, statY + 246, "ARCADE SCORE", 2,
                          Color.RGB(255, 221, 34));
        canvas.TextScaled(valueX, statY + 246, Int(score), 2,
                          Color.RGB(255, 255, 200));
        canvas.TextScaled(labelX, statY + 282, "PERFORMANCE", 2,
                          Color.RGB(140, 150, 170));
        canvas.TextScaled(valueX, statY + 282, Int(rankScore) + " / 1000",
                          2, Color.RGB(180, 220, 255));

        // Rank
        canvas.TextCenteredScaled(statY + 326, "RANK: " + rank,
                                  getRankColor(rank), 4);

        // Next level prompt
        canvas.TextCenteredScaled(
            py + ph - 40, Action.BindingsStr(ACT_CONFIRM) + " continue",
            Color.RGB(100, 100, 130), 1);
    }

    /// @brief Draw the four-encounter Boss Rush completion debrief.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param elapsedMs Continuous Boss Rush completion time in milliseconds.
    /// @param damageTaken Cumulative HP lost across all four encounters.
    /// @param rank Authoritative D/C/B/A/S simulator rank label.
    /// @param rankScore Authoritative composite result in 0..1000.
    /// @return Nothing. Draws only and leaves result restoration to Game.
    expose func drawBossRushComplete(canvas: Canvas, elapsedMs: Integer,
                                     damageTaken: Integer, rank: String,
                                     rankScore: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 205);
        var px = SCREEN_W / 2 - 350;
        var py = 105;
        var pw = 700;
        var ph = 500;
        canvas.Box(px + 5, py + 5, pw, ph, Color.RGB(0, 0, 0));
        canvas.Box(px, py, pw, ph, Color.RGB(13, 10, 25));
        canvas.Frame(px, py, pw, ph, Color.RGB(190, 90, 235));
        canvas.TextCenteredScaled(py + 28, "BOSS RUSH COMPLETE",
                                  Color.RGB(245, 205, 95), 3);
        canvas.TextCenteredScaled(py + 78,
                                  "SPORE MOTHER  //  CRYSTAL WYRM  //",
                                  Color.RGB(150, 175, 210), 1);
        canvas.TextCenteredScaled(py + 102,
                                  "MAGMA CORE  //  THE ARCHITECT",
                                  Color.RGB(150, 175, 210), 1);
        canvas.Line(px + 35, py + 140, px + pw - 35, py + 140,
                    Color.RGB(70, 45, 100));
        drawStatRow(canvas, px + 70, py + 175, "Continuous Time",
                    formatTime(elapsedMs), Color.RGB(180, 220, 255));
        drawStatRow(canvas, px + 70, py + 220, "Damage Taken",
                    Int(damageTaken), Color.RGB(255, 150, 100));
        drawStatRow(canvas, px + 70, py + 265, "Performance",
                    Int(rankScore) + " / 1000", Color.RGB(180, 220, 255));
        canvas.TextCenteredScaled(py + 330, "RANK: " + rank,
                                  getRankColor(rank), 5);
        canvas.TextCenteredScaled(py + ph - 45,
                                  "Confirm to return to the simulator",
                                  Color.RGB(120, 125, 150), 1);
    }

    /// @brief One label/value stat row on enhanced
    ///        complete/victory screens.
    hide func drawStatRow(canvas: Canvas, labelX: Integer, y: Integer,
                           label: String, value: String, color: Integer) {
        canvas.TextScaled(labelX, y, label, 2, Color.RGB(140, 150, 170));
        canvas.TextScaled(labelX + 400, y, value, 2, color);
    }

    /// @brief "M:SS" formatter for play-time displays.
    hide func formatTime(ms: Integer) -> String {
        var mins = ms / 60000;
        var secs = (ms / 1000) % 60;
        return Int(mins) + ":" + Int(secs);
    }

    /// @brief Map rank letter ("S"/"A"/"B"/...) to the
    ///        accent colour used on the complete screen.
    hide func getRankColor(rank: String) -> Integer {
        if rank == "S" { return Color.RGB(255, 221, 34); }
        if rank == "A" { return Color.RGB(100, 255, 150); }
        if rank == "B" { return Color.RGB(100, 180, 255); }
        if rank == "C" { return Color.RGB(200, 200, 220); }
        return Color.RGB(180, 100, 100);
    }

    // =========================================================================
    // Loading Screen — shown during level transitions
    // =========================================================================
    /// @brief Loading screen between levels — biome flavour
    ///        text + progress bar.
    expose func drawLoadingScreen(canvas: Canvas, levelNum: Integer, progress: Integer) {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, Color.RGB(5, 5, 15));

        // Stars
        var i = 0;
        while i < 30 {
            var sx = (i * 137 + 50) % SCREEN_W;
            var sy = (i * 251 + 30) % SCREEN_H;
            canvas.Disc(sx, sy, 1, Color.RGB(180, 180, 200));
            i = i + 1;
        }

        // Level name
        var biomeName = getBiomeName(levelNum);
        canvas.TextCenteredScaled(SCREEN_H / 2 - 60, "AREA " + Int(levelNum),
                                  Color.RGB(100, 100, 130), 2);
        canvas.TextCenteredScaled(SCREEN_H / 2 - 20, biomeName,
                                  Color.RGB(220, 230, 255), 3);

        // Loading bar
        var barX = SCREEN_W / 2 - 200;
        var barY = SCREEN_H / 2 + 40;
        var barW = 400;
        var barH = 8;
        canvas.Box(barX, barY, barW, barH, Color.RGB(20, 25, 40));
        var fillW = progress * barW / 100;
        canvas.Box(barX, barY, fillW, barH, Color.RGB(80, 120, 200));
        canvas.Frame(barX, barY, barW, barH, Color.RGB(50, 60, 90));

        // "Loading..." text
        canvas.TextCenteredScaled(barY + 20, "Loading...", Color.RGB(80, 90, 110), 1);

        // Biome flavor text
        var flavor = getBiomeFlavor(levelNum);
        canvas.TextCenteredScaled(SCREEN_H / 2 + 100, flavor, Color.RGB(60, 70, 90), 1);
    }

    /// @brief Loading-screen flavour text per biome.
    hide func getBiomeFlavor(levelNum: Integer) -> String {
        if levelNum == 1 { return "The ship is lost. Find shelter."; }
        if levelNum == 2 { return "Something glows in the dark below..."; }
        if levelNum == 3 { return "The crystals hum with ancient power."; }
        if levelNum == 4 { return "Nature has reclaimed what was built here."; }
        if levelNum == 5 { return "Still waters run deep — and dangerous."; }
        if levelNum == 6 { return "The planet's heart burns white-hot."; }
        if levelNum == 7 { return "Life finds a way, even through ruin."; }
        if levelNum == 8 { return "Flash-frozen. Not everything here is dead."; }
        if levelNum == 9 { return "The Architect's influence warps reality itself."; }
        if levelNum == 10 { return "This ends here. One way or another."; }
        return "Into the unknown.";
    }

    // =========================================================================
    // Settings Menu (audio, display, accessibility)
    // =========================================================================
    /// @brief Draw the complete persistent settings browser with scrolling.
    ///
    /// Eleven rows remain visible at once. Selection stays centered when possible,
    /// and values come directly from GameSettings so presentation cannot drift
    /// from persisted accessibility state.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed release palette.
    /// @param settings Borrowed normalized application settings.
    /// @param selectedOption Focused setting id or `SETTING_COUNT` for Back.
    /// @return Nothing. Renders without mutating settings.
    expose func drawSettings(canvas: Canvas, pal: Palette,
                              settings: GameSettings,
                              selectedOption: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 180);

        var px = SCREEN_W / 2 - 390;
        var py = 38;
        var pw = 780;
        var ph = 640;
        var panelColor = Color.RGB(15, 15, 25);
        if accessibilityHighContrast { panelColor = Color.RGB(0, 0, 0); }
        canvas.Box(px, py, pw, ph, panelColor);
        canvas.Frame(px, py, pw, ph, Color.RGB(80, 100, 160));

        canvas.TextCenteredScaled(py + 18, "SETTINGS & ACCESSIBILITY", pal.white, 3);
        canvas.Line(px + 20, py + 55, px + pw - 20, py + 55, Color.RGB(50, 60, 90));

        var visibleRows = 11;
        var totalRows = SETTING_COUNT + 1;
        var first = selectedOption - visibleRows / 2;
        if first < 0 { first = 0; }
        var maxFirst = totalRows - visibleRows;
        if maxFirst < 0 { maxFirst = 0; }
        if first > maxFirst { first = maxFirst; }

        var row = 0;
        while row < visibleRows and first + row < totalRows {
            var setting = first + row;
            var label = "< Back";
            var value = "RETURN";
            var percent = -1;
            if setting < SETTING_COUNT {
                label = settingName(setting);
                value = settings.getValueLabel(setting);
                if setting == SETTING_MASTER_VOLUME or
                   setting == SETTING_MUSIC_VOLUME or
                   setting == SETTING_SFX_VOLUME or
                   setting == SETTING_AMBIENCE_VOLUME or
                   setting == SETTING_SCREEN_SHAKE or
                   setting == SETTING_VOICE_VOLUME {
                    percent = settings.getValue(setting);
                }
            }
            drawSettingRow(canvas, pal, px + 36, py + 76 + row * 46,
                           pw - 72, label, value, percent,
                           setting == selectedOption,
                           setting == SETTING_COUNT);
            row = row + 1;
        }

        canvas.Text(px + 32, py + ph - 52,
                    "Rows " + Int(first + 1) + "-" +
                    Int(first + visibleRows) + " of " + Int(totalRows),
                    pal.hudGray);
        canvas.Text(px + 300, py + ph - 52,
                    Action.BindingsStr(ACT_LEFT) + " / " +
                    Action.BindingsStr(ACT_RIGHT) + " adjust    " +
                    Action.BindingsStr(ACT_BACK) + " back",
                    pal.hudGray);
    }

    /// @brief Draw one settings row with optional compact percentage meter.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param pal Borrowed release palette.
    /// @param x Row origin X.
    /// @param y Row origin Y.
    /// @param width Row width in pixels.
    /// @param label Release setting label.
    /// @param value Formatted normalized value.
    /// @param percent Percentage in 0..100, or -1 when no meter applies.
    /// @param selected Whether the row currently owns focus.
    /// @param destructive True only for the Back row's warm accent.
    /// @return Nothing. Draws one bounded row.
    hide func drawSettingRow(canvas: Canvas, pal: Palette,
                             x: Integer, y: Integer, width: Integer,
                             label: String, value: String,
                             percent: Integer, selected: Boolean,
                             destructive: Boolean) {
        var color = Color.RGB(145, 158, 184);
        if selected {
            canvas.BoxAlpha(x - 8, y - 5, width + 16, 38,
                            pal.menuHighlight, 120);
            color = pal.white;
            canvas.TextScaled(x - 22, y, ">", menuTextScale(2),
                              pal.titleOrange);
        }
        if destructive and selected { color = pal.hudRed; }
        canvas.TextScaled(x, y, label, menuTextScale(2), color);
        canvas.TextScaled(x + width - 142, y, value,
                          menuTextScale(2), color);

        if percent >= 0 {
            var barX = x + width - 300;
            var barY = y + 10;
            var barW = 120;
            canvas.Box(barX, barY, barW, 7, Color.RGB(30, 35, 50));
            canvas.Box(barX, barY, percent * barW / 100, 7,
                       pal.crystalBlue);
            canvas.Frame(barX, barY, barW, 7, Color.RGB(60, 76, 106));
        }
    }

    // =========================================================================
    // Ability Screen (pause menu → abilities view)
    // =========================================================================
    /// @brief Pause-menu "abilities" tab — list of every
    ///        ability with locked / unlocked indicators.
    expose func drawAbilityScreen(canvas: Canvas, _pal: Palette,
                                   abilityMask: Integer) {
        canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, Color.RGB(0, 0, 10), 180);

        var px = SCREEN_W / 2 - 350;
        var py = 80;
        var pw = 700;
        var ph = 520;
        canvas.Box(px, py, pw, ph, Color.RGB(15, 15, 25));
        canvas.Frame(px, py, pw, ph, Color.RGB(80, 100, 160));

        canvas.TextCenteredScaled(py + 20, "ABILITIES", Color.RGB(200, 220, 255), 3);
        canvas.Line(px + 20, py + 55, px + pw - 20, py + 55, Color.RGB(50, 60, 90));

        // Ability cards
        var abilities = [
            "Wall Jump", "Double Jump", "Dash",
            "Charge Shot", "Ground Pound", "Grapple Hook"
        ];
        var descriptions = [
            "Jump off walls to reach higher areas.",
            "Jump again in mid-air for extra height.",
            "Quick burst of speed. Invincible during dash.",
            "Hold fire to charge a powerful shot that breaks walls.",
            "Slam down from the air. Stuns nearby enemies.",
            "Hook onto anchor points to swing across gaps."
        ];
        var flags = [1, 2, 4, 8, 16, 32];
        var colors = [
            Color.RGB(100, 200, 100), Color.RGB(100, 180, 255),
            Color.RGB(255, 200, 50), Color.RGB(255, 100, 100),
            Color.RGB(200, 100, 255), Color.RGB(50, 255, 200)
        ];

        var i = 0;
        while i < 6 {
            var cardX = px + 30;
            var cardY = py + 70 + i * 72;
            var cardW = pw - 60;
            var cardH = 60;
            var hasIt = (abilityMask / flags.get(i)) % 2 == 1;

            if hasIt {
                canvas.Box(cardX, cardY, cardW, cardH, Color.RGB(20, 25, 40));
                canvas.Frame(cardX, cardY, cardW, cardH, colors.get(i));
                // Icon
                canvas.Disc(cardX + 25, cardY + 30, 15, colors.get(i));
                canvas.Text(cardX + 18, cardY + 24, Int(i + 1), Color.RGB(0, 0, 0));
                // Name
                canvas.TextScaled(cardX + 55, cardY + 8, abilities.get(i),
                                  2, colors.get(i));
                // Description
                canvas.Text(cardX + 55, cardY + 34, descriptions.get(i),
                            Color.RGB(140, 150, 170));
            } else {
                canvas.Box(cardX, cardY, cardW, cardH, Color.RGB(15, 15, 22));
                canvas.Frame(cardX, cardY, cardW, cardH, Color.RGB(40, 40, 55));
                // Locked icon
                canvas.Disc(cardX + 25, cardY + 30, 15, Color.RGB(40, 40, 55));
                canvas.Text(cardX + 20, cardY + 24, "?", Color.RGB(60, 60, 80));
                // Locked text
                canvas.TextScaled(cardX + 55, cardY + 16, "???", 2,
                                  Color.RGB(60, 60, 80));
            }
            i = i + 1;
        }

        canvas.TextCenteredScaled(
            py + ph - 30, Action.BindingsStr(ACT_BACK) + " go back",
            Color.RGB(60, 70, 90), 1);
    }
}
