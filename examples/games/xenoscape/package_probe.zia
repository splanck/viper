//
// File: examples/games/xenoscape/package_probe.zia
// Purpose: Validates runtime assets, QA references, and fallback inventory.
// Key invariants:
//   - Runtime package paths resolve from the project/package working directory.
//   - Development feature toggles default on while fallbacks remain usable.
// Ownership/Lifetime:
//   - Probe owns temporary decoded Pixels and procedural SpriteFactory objects.
// Links: zanna.project, xenoscape.runtime.json, assets/manifest.txt,
//        src/tests/CMakeLists.txt
//
//===----------------------------------------------------------------------===//

module package_probe;

bind Zanna.Graphics;
bind Zanna.IO.File as File;
bind Zanna.Terminal as Terminal;
bind "./config";
bind "./palette";
bind "./player_animation";
bind "./sprites";
bind "./tuning";

/// @brief Emit one deterministic package inventory failure.
///
/// @param message Concise missing or invalid package inventory item.
/// @return Nothing. Omits the success marker expected by CTest.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Verify runtime assets, QA references, toggles, and fallbacks.
///
/// @return Nothing. Prints `RESULT: ok` only for a complete package inventory.
func main() {
    if File.Exists("assets/manifest.txt") == false or
       File.Exists("assets/README.md") == false or
       File.Exists("assets/art/title-key-art.png") == false or
       File.Exists("assets/art/aria-portrait.png") == false or
       File.Exists("assets/sprites/player-release-sheet.png") == false or
       File.Exists("assets/tiles/biome-tile-atlas.png") == false or
       File.Exists("assets/icons/hud-icon-atlas.png") == false or
       File.Exists("assets/ui/title-menu-panel.png") == false or
       File.Exists("xenoscape.runtime.json") == false {
        fail("runtime or QA-reference package path"); return;
    }
    var art = Pixels.Load("assets/art/title-key-art.png");
    if art == null or art.get_Width() < SCREEN_W or
       art.get_Height() < SCREEN_H {
        fail("title key art decode or dimensions"); return;
    }
    var portrait = Pixels.Load("assets/art/aria-portrait.png");
    if portrait == null or portrait.get_Width() < 512 or
       portrait.get_Height() < 512 {
        fail("ARIA portrait decode or dimensions"); return;
    }
    var playerAtlas = Pixels.Load("assets/sprites/player-release-sheet.png");
    var tileAtlas = Pixels.Load("assets/tiles/biome-tile-atlas.png");
    var iconAtlas = Pixels.Load("assets/icons/hud-icon-atlas.png");
    var uiPanel = Pixels.Load("assets/ui/title-menu-panel.png");
    if playerAtlas == null or playerAtlas.get_Width() != PLAYER_SPRITE_W * 8 or
       playerAtlas.get_Height() != PLAYER_SPRITE_H * 6 or
       tileAtlas == null or tileAtlas.get_Width() != TILE_SIZE * 8 or
       tileAtlas.get_Height() != TILE_SIZE * 8 or
       iconAtlas == null or iconAtlas.get_Width() != 512 or
       iconAtlas.get_Height() != 64 or
       uiPanel == null or uiPanel.get_Width() != 440 or
       uiPanel.get_Height() != 330 {
        fail("runtime or QA-reference atlas decode or dimensions"); return;
    }

    var tuning = new RuntimeTuning("xenoscape.runtime.json");
    if tuning.loaded == false or
       tuning.getBool("campaign.worldGraphEnabled", false) == false or
       tuning.getBool("presentation.authoredArtEnabled", false) == false or
       tuning.getBool("presentation.adaptiveMusicEnabled", false) == false or
       tuning.getBool("debug.enabled", true) {
        fail("development feature-toggle defaults"); return;
    }

    var pal = new Palette();
    var sprites = new SpriteFactory(pal);
    if sprites.hasAuthoredPlayerArt() == false or
       sprites.isAuthoredPlayerArtEnabled() == false {
        fail("authored player atlas activation"); return;
    }
    if sprites.setAuthoredPlayerArtEnabled(false) == false or
       sprites.isAuthoredPlayerArtEnabled() or
       sprites.setAuthoredPlayerArtEnabled(true) == false {
        fail("authored player fallback toggle"); return;
    }
    var player = sprites.getPlayerFrame(1, 0);
    var tile = sprites.getTile(TILE_GROUND);
    var boss = sprites.getArchitectFrame(0);
    if sprites.getPlayerFrameCount() != PLAYER_RELEASE_FRAME_COUNT or
       player == null or player.get_Width() <= 0 or
       tile == null or tile.get_Width() != TILE_SIZE or
       boss == null or boss.get_Height() <= 0 {
        fail("procedural art fallback inventory"); return;
    }
    Terminal.Say("RESULT: ok");
}
