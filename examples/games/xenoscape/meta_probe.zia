//
// File: examples/games/xenoscape/meta_probe.zia
// Purpose: Verifies workbench economy, difficulty profiles, and room discovery.
// Key invariants:
//   - Probe is displayless and does not open persistent SaveData stores.
//   - Failed economic/profile operations prove their nonmutation contracts.
// Ownership/Lifetime:
//   - All systems and result objects are probe-local and short lived.
// Links: economy.zia, difficulty.zia, death_loop.zia, meta_modes.zia,
//        tutorials.zia, world_state.zia,
//        src/tests/CMakeLists.txt
//
//===----------------------------------------------------------------------===//

module meta_probe;

bind Zanna.Terminal as Terminal;
bind "./config";
bind "./difficulty";
bind "./death_loop";
bind "./economy";
bind "./meta_modes";
bind "./radio";
bind "./tutorials";
bind "./world_state";

/// @brief Emit one deterministic meta-progression failure.
///
/// @param message Stable failure suffix for CTest diagnostics.
/// @return Nothing. Omits the success marker so regex validation fails.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Verify exact costs, purchase safety, profile scaling, and room masks.
///
/// @return Nothing. Prints `RESULT: ok` only when every contract passes.
func main() {
    if upgradeNextCost(UPGRADE_SUIT_INTEGRITY, 0) != 8 or
       upgradeNextCost(UPGRADE_SUIT_INTEGRITY, 2) != 28 or
       upgradeNextCost(UPGRADE_BLASTER_CAPACITOR, 1) != 20 or
       upgradeNextCost(UPGRADE_SCANNER_RANGE, 2) != 24 {
        fail("upgrade cost table"); return;
    }

    var upgrades = new UpgradeSystem();
    var failed = upgrades.purchase(UPGRADE_THRUSTER_CONTROL, 9);
    if failed.status != PURCHASE_INSUFFICIENT_GEMS or
       failed.remainingGems != 9 or
       upgrades.getTier(UPGRADE_THRUSTER_CONTROL) != 0 {
        fail("unaffordable purchase mutation"); return;
    }
    var bought = upgrades.purchase(UPGRADE_THRUSTER_CONTROL, 10);
    if bought.status != PURCHASE_SUCCESS or bought.remainingGems != 0 or
       upgrades.getDashCooldownPercent() != 92 {
        fail("successful thruster purchase"); return;
    }
    upgrades.setEncodedTiers(255);
    var maxed = upgrades.purchase(UPGRADE_SCANNER_RANGE, 999);
    if maxed.status != PURCHASE_MAX_TIER or maxed.remainingGems != 999 or
       upgrades.getEncodedTiers() != 255 or
       upgrades.getScannerRange() != INTERACTION_RADIUS + 192 {
        fail("max-tier purchase safety"); return;
    }

    if difficultyScaleIncomingDamage(1, DIFFICULTY_EXPLORER) != 1 or
       difficultyScaleIncomingDamage(2, DIFFICULTY_EXPLORER) != 1 or
       difficultyScaleIncomingDamage(2, DIFFICULTY_VETERAN) != 3 or
       difficultyScaleEnemyHp(5, DIFFICULTY_EXPLORER) != 5 or
       difficultyScaleEnemyHp(5, DIFFICULTY_VETERAN) != 7 or
       difficultyGemLossPercent(DIFFICULTY_STANDARD) != 10 or
       deathRecoverableGemLoss(117, 100, DIFFICULTY_EXPLORER) != 0 or
       deathRecoverableGemLoss(117, 100, DIFFICULTY_STANDARD) != 2 or
       deathRecoverableGemLoss(117, 100, DIFFICULTY_VETERAN) != 4 {
        fail("difficulty scaling table"); return;
    }
    var difficulty = new DifficultySystem();
    if difficulty.requestAtSaveStation(DIFFICULTY_VETERAN) == false or
       difficulty.getProfile() != DIFFICULTY_STANDARD or
       difficulty.getPendingProfile() != DIFFICULTY_VETERAN {
        fail("deferred difficulty increase"); return;
    }
    if difficulty.applyPendingOnTransition() == false or
       difficulty.getProfile() != DIFFICULTY_VETERAN {
        fail("difficulty transition apply"); return;
    }
    if difficulty.requestAtSaveStation(DIFFICULTY_EXPLORER) == false or
       difficulty.getProfile() != DIFFICULTY_EXPLORER {
        fail("immediate difficulty decrease"); return;
    }

    var recovery = new DeathRecovery();
    recovery.reset(100);
    var afterDeath = recovery.recordDeath(
        117, DIFFICULTY_STANDARD, 4, 640, 320);
    if afterDeath != 115 or recovery.hasMarker() == false or
       recovery.getMarkerGems() != 2 or
       recovery.recoverIfNear(3, 640, 320, 40) != 0 or
       recovery.recoverIfNear(4, 680, 360, 40) != 2 or
       recovery.hasMarker() or
       recovery.recoverIfNear(4, 640, 320, 40) != 0 {
        fail("single death marker recovery"); return;
    }
    recovery.recordDeath(117, DIFFICULTY_VETERAN, 4, 640, 320);
    recovery.recordDeath(113, DIFFICULTY_EXPLORER, 4, 700, 320);
    if recovery.hasMarker() {
        fail("later death marker replacement"); return;
    }

    var tutorials = new TutorialSystem();
    if tutorials.request(TUTORIAL_MOVE) == false or
       tutorials.request(TUTORIAL_JUMP) or
       tutorials.acknowledge(TUTORIAL_MOVE) == false or
       tutorials.request(TUTORIAL_MOVE) or
       tutorials.request(TUTORIAL_JUMP) == false or
       tutorials.acknowledge(TUTORIAL_JUMP) == false or
       tutorials.getMask() != 3 {
        fail("contextual tutorial acknowledgement"); return;
    }
    tutorials.setMask(99999);
    if tutorials.getMask() != 4095 or
       tutorials.isAcknowledged(TUTORIAL_DEATH_RECOVERY) == false {
        fail("tutorial mask clamp"); return;
    }

    var radio = new RadioSystem();
    radio.queueRegionArrival(1);
    if radio.isActive() == false or
       radio.getLine() != ariaRegionArrivalLine(1) {
        fail("ARIA arrival subtitle"); return;
    }
    var radioTick = 0;
    while radioTick <= RADIO_LINE_DURATION_MS / DT_MAX {
        radio.update(DT_MAX);
        radioTick = radioTick + 1;
    }
    if radio.isActive() {
        fail("ARIA subtitle expiry"); return;
    }

    var perfect = calculateRegionRank(0, regionParTimeMs(0), 0, 4, true);
    var rough = calculateRegionRank(0, regionParTimeMs(0) * 2, 9, 0, false);
    var perfectRush = calculateBossRushRank(BOSS_RUSH_PAR_TIME_MS, 0);
    var roughRush = calculateBossRushRank(BOSS_RUSH_PAR_TIME_MS * 2, 20);
    if perfect.score != 1000 or perfect.rank != REGION_RANK_S or
       rough.rank != REGION_RANK_D or
       perfectRush.score != 1000 or perfectRush.rank != REGION_RANK_S or
       roughRush.rank != REGION_RANK_D or
       timeTrialUnlocked(2, 4) == false or
       timeTrialUnlocked(3, 4) or
       normalEndingUnlocked(511) or normalEndingUnlocked(512) == false or
       trueEndingUnlocked(512, 63, 23, 23) == false or
       trueEndingUnlocked(512, 31, 23, 23) or
       trueEndingUnlocked(512, 63, 22, 23) or
       newGamePlusEnemyHpPercent(true) != 135 or
       newGamePlusEncounterPercent(true) != 150 {
        fail("rank and postgame unlock tables"); return;
    }
    var meta = new MetaProgression();
    if meta.setNewGamePlusActive(true, 0) or
       meta.record(0, perfect, 420000) == false or
       meta.getBestRank(0) != REGION_RANK_S or
       meta.setNewGamePlusActive(true, 512) == false {
        fail("meta progression mutation"); return;
    }
    var restoredMeta = new MetaProgression();
    restoredMeta.restore(meta.getBestTimes(), meta.getPackedRanks(),
                         meta.isNewGamePlusActive());
    if restoredMeta.getBestTime(0) != 420000 or
       restoredMeta.getBestRank(0) != REGION_RANK_S or
       restoredMeta.isNewGamePlusActive() == false {
        fail("meta progression round trip"); return;
    }

    var state = new WorldState();
    if state.discoverRoom(0, 0) == false or state.discoverRoom(0, 0) or
       state.discoverRoom(0, 7) == false or state.getRoomMask(0) != 129 {
        fail("room discovery idempotence"); return;
    }
    state.setRoomMask(9, 999);
    if state.getRoomMask(9) != 255 or state.isRoomDiscovered(9, 7) == false {
        fail("room mask clamp"); return;
    }
    Terminal.Say("RESULT: ok");
}
