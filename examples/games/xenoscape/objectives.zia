//
// File: examples/games/xenoscape/objectives.zia
// Purpose: Defines stable regional objectives and optional discovery progress.
// Key invariants:
//   - Objective ids equal zero-based WorldGraph region ids.
//   - Optional progress derives only from persistent lore and room masks.
// Ownership/Lifetime:
//   - Functions are stateless; Game borrows campaign masks for each query.
// Links: game.zia, world_graph.zia, world_state.zia, lore.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module objectives;

final REGION_OBJECTIVE_COUNT = 10;
final REGION_OPTIONAL_TARGET = 4;

/// @brief Return the concise primary objective title for one region.
///
/// @param region Zero-based stable region id.
/// @return Authored objective title, or `Survey the Unknown` when invalid.
func regionObjectiveTitle(region: Integer) -> String {
    if region == 0 { return "Stabilize the Crash Site"; }
    if region == 1 { return "Silence the Spore Mother"; }
    if region == 2 { return "Break the Crystal Wyrm"; }
    if region == 3 { return "Restore the Surface Relay"; }
    if region == 4 { return "Recover the Capacitor Shrine"; }
    if region == 5 { return "Quench the Magma Core"; }
    if region == 6 { return "Awaken the Grapple Shrine"; }
    if region == 7 { return "Open Cryogenic Storage"; }
    if region == 8 { return "Breach the Corruption Seal"; }
    if region == 9 { return "Defeat the Architect"; }
    return "Survey the Unknown";
}

/// @brief Return the authored mission instruction for one region.
///
/// @param region Zero-based stable region id.
/// @return One-sentence objective suitable for HUD, pause, and hub surfaces.
func regionObjectiveDescription(region: Integer) -> String {
    if region == 0 {
        return "Reach the emergency beacon and map a route into the caverns.";
    }
    if region == 1 {
        return "Trace the spore network to its brood chamber.";
    }
    if region == 2 {
        return "Use resonant crystal routes to reach the buried guardian.";
    }
    if region == 3 {
        return "Re-power the ancient relay overlooking the shipwreck.";
    }
    if region == 4 {
        return "Cross the submerged ruins and recover the blaster capacitor.";
    }
    if region == 5 {
        return "Descend through the pressure vents and disable the magma eye.";
    }
    if region == 6 {
        return "Climb the reclaimed sanctuary and synchronize its grapple rig.";
    }
    if region == 7 {
        return "Thaw the archive locks without destroying the surviving samples.";
    }
    if region == 8 {
        return "Ground the distortion anchors guarding the Core route.";
    }
    if region == 9 {
        return "Sever the Architect from the ancient planetary machine.";
    }
    return "Map the region and locate a safe return route.";
}

/// @brief Determine whether one region's primary objective is complete.
///
/// @param region Zero-based stable region id.
/// @param completionMask Persistent completed-region mask.
/// @return True when the region's bit is set; false for invalid/uncompleted ids.
func regionObjectiveComplete(region: Integer,
                             completionMask: Integer) -> Boolean {
    if region < 0 or region >= REGION_OBJECTIVE_COUNT { return false; }
    return objectiveMaskHas(completionMask, region);
}

/// @brief Count a region's two stable primary lore discoveries.
///
/// The mapping mirrors Level's authored lore ids, including the deliberate
/// Overgrowth/Frozen-Abyss narrative ordering.
///
/// @param region Zero-based stable region id.
/// @param loreMask Persistent global LoreSystem mask.
/// @return Integer in 0..2.
func regionLoreDiscoveryCount(region: Integer,
                              loreMask: Integer) -> Integer {
    var base = regionLoreBase(region);
    if base < 0 { return 0; }
    var count = 0;
    if objectiveMaskHas(loreMask, base) { count = count + 1; }
    if objectiveMaskHas(loreMask, base + 1) { count = count + 1; }
    return count;
}

/// @brief Count the two optional secret-room discoveries in a region.
///
/// Stable room indices 2 and 6 are authored as the side-route secrets for every
/// eight-room regional template. Their discovery is already persisted by
/// WorldState, avoiding a duplicate secret authority.
///
/// @param roomMask Persistent eight-bit room mask for one region.
/// @return Integer in 0..2.
func regionSecretDiscoveryCount(roomMask: Integer) -> Integer {
    var count = 0;
    if objectiveMaskHas(roomMask, 2) { count = count + 1; }
    if objectiveMaskHas(roomMask, 6) { count = count + 1; }
    return count;
}

/// @brief Count all optional discoveries advertised for one region.
///
/// @param region Zero-based stable region id.
/// @param loreMask Persistent global lore mask.
/// @param roomMask Persistent regional room mask.
/// @return Integer in 0..`REGION_OPTIONAL_TARGET`.
func regionOptionalProgress(region: Integer, loreMask: Integer,
                            roomMask: Integer) -> Integer {
    return regionLoreDiscoveryCount(region, loreMask) +
           regionSecretDiscoveryCount(roomMask);
}

/// @brief Return the first stable LoreSystem id authored for one region.
///
/// @param region Zero-based stable region id.
/// @return First lore id, or -1 for invalid regions.
func regionLoreBase(region: Integer) -> Integer {
    if region == 0 { return 0; }
    if region == 1 { return 2; }
    if region == 2 { return 5; }
    if region == 3 { return 8; }
    if region == 4 { return 10; }
    if region == 5 { return 12; }
    if region == 6 { return 17; }
    if region == 7 { return 15; }
    if region == 8 { return 19; }
    if region == 9 { return 21; }
    return -1;
}

/// @brief Test one nonnegative bit index without bitwise runtime dependencies.
///
/// @param mask Nonnegative packed mask.
/// @param index Zero-based bit index.
/// @return True when the indexed power-of-two bit is present.
func objectiveMaskHas(mask: Integer, index: Integer) -> Boolean {
    if mask < 0 or index < 0 or index >= 62 { return false; }
    var bit = 1;
    var i = 0;
    while i < index {
        bit = bit * 2;
        i = i + 1;
    }
    return (mask / bit) % 2 == 1;
}
