//
// File: examples/games/xenoscape/performance_probe.zia
// Purpose: Stress-tests bounded campaign simulation under release encounter load.
// Key invariants:
//   - Two identical full-campaign passes must produce the same checksum.
//   - Veteran New Game+ encounters never exceed fixed enemy/particle pool caps.
// Ownership/Lifetime:
//   - Each pass owns fresh Level, EnemyManager, Palette, and ParticleSystem state.
// Links: enemy.zia, level.zia, particles.zia, src/tests/CMakeLists.txt,
//        docs/testing.md
//
//===----------------------------------------------------------------------===//

module performance_probe;

bind Viper.Terminal as Terminal;
bind Viper.Math.Random as Random;
bind "./config";
bind "./difficulty";
bind "./enemy";
bind "./level";
bind "./palette";
bind "./particles";

final PARTICLE_STRESS_CAPACITY = 256;

/// @brief Emit one deterministic performance-gate failure.
///
/// @param message Stable violated stress invariant for CTest diagnostics.
/// @return Nothing. Omits the success regex marker.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Simulate every Veteran New Game+ region for 120 fixed updates.
///
/// Player coordinates sweep the complete authored width so dormant, tracking,
/// projectile, and boss AI all execute. The test intentionally relies on CTest's
/// wall-clock timeout as its generous performance budget rather than embedding a
/// platform-sensitive timer threshold. A rolling state checksum makes divergent
/// VM/native or repeated execution observable.
///
/// @return Nonnegative deterministic checksum, or -1 if a pool invariant fails.
func runCampaignStressPass() -> Integer {
    Random.Seed(424242);
    var palette = new Palette();
    var particles = new ParticleSystem(palette);
    var enemies = new EnemyManager();
    enemies.setDifficultyProfile(DIFFICULTY_VETERAN);
    enemies.setNewGamePlusActive(true);
    var level = new Level();
    var checksum = 17;
    var region = 1;
    while region <= LEVEL_COUNT {
        level.loadLevel(region);
        level.enrichEnemies(region);
        enemies.reset();
        enemies.setDifficultyProfile(DIFFICULTY_VETERAN);
        enemies.setNewGamePlusActive(true);
        enemies.spawnFromLevel(level);
        particles.reset();
        if enemies.activeCount() > MAX_ENEMIES {
            return -1;
        }

        var frame = 0;
        while frame < 120 {
            var worldWidth = level.levelWidth * TILE_SIZE;
            var playerX = (frame * 53 + region * 97) % worldWidth;
            var playerY = level.playerStartY + (frame % 7) * 12;
            level.updateDynamicTiles(DT_BASE);
            enemies.updateAll(level, playerX, playerY, DT_BASE, particles);
            particles.updateAll();
            if enemies.activeCount() > MAX_ENEMIES or
               particles.activeCount() > PARTICLE_STRESS_CAPACITY {
                return -1;
            }
            checksum = (checksum * 131 + enemies.activeCount() * 7 +
                        particles.activeCount() * 11 + region) % 1000003;
            if checksum < 0 { checksum = 0 - checksum; }
            frame = frame + 1;
        }
        region = region + 1;
    }
    return checksum;
}

/// @brief Run the bounded release-performance gate twice.
///
/// @return Nothing. Prints `RESULT: ok` only after deterministic equal passes.
func main() {
    var first = runCampaignStressPass();
    var second = runCampaignStressPass();
    if first < 0 or second < 0 {
        fail("fixed pool capacity exceeded"); return;
    }
    if first == 0 or first != second {
        fail("campaign stress determinism"); return;
    }
    Terminal.Say("RESULT: ok");
}
