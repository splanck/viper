// See LICENSE for license information.
//
//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/game.zia
// Purpose: Owns XENOSCAPE's application loop, scenes, and subsystem orchestration.
// Key invariants:
//   - Exactly one top-level scene consumes input and presents each frame.
//   - Campaign-owned state is synchronized before player or combat simulation.
// Ownership/Lifetime:
//   - Main owns one Game until the application window closes.
//   - Game owns every gameplay, presentation, audio, and persistence subsystem.
// Links: main.zia, config.zia, player.zia, level.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — THE "GAME" OBJECT IS YOUR ROOT
// -----------------------------------------
// `main.zia::start()` does two things: `new Game()` and
// `g.run()`.  That's it.  Everything else in the program is
// owned by this file's `Game` class.  It's the "root" of the
// game's object graph.
//
// A root class typically holds four kinds of state:
//
//   1. **Subsystems** — Player, LevelManager, EnemyManager,
//      Camera, Renderer, HUD, MenuSystem, SoundManager,
//      ParticleSystem, Lighting, SaveManager, AchievementManager,
//      LoreSystem, TransitionManager, WorldMap, AbilityManager,
//      RuntimeTuning, Palette, SpriteFactory.  Each is a
//      standalone class; `Game` composes them.
//
//   2. **Game state machine** — which top-level screen is
//      active?  TITLE, LEVEL_SELECT, PLAY, PAUSED, GAME_OVER,
//      LEVEL_COMPLETE, CREDITS, ...  `Game` owns the current
//      state and routes update + draw accordingly.
//
//   3. **The main loop** — `run()` is a `while running { poll
//      input; update; render; sleep }` loop.  It's where
//      `dt` (the per-frame delta in milliseconds) is
//      computed and passed down to every subsystem.
//
//   4. **Shared clocks / counters** — global play-time,
//      deaths, bosses-defeated mask, current level index.
//      Things several subsystems read but no one subsystem
//      owns.
//
// WHY ONE BIG ROOT?
// -----------------
// Alternatives to a single `Game` class:
//
//   * Free-floating globals per subsystem.  Works but makes
//     testing hard — you can't have two isolated game
//     instances at once (e.g. a probe + a real game).
//
//   * Dependency injection everywhere.  Clean but tedious in
//     a demo this size.
//
// One root class in a 17-KB-SLOC project is a sweet spot:
// everything is visible in one place, yet tests can still
// spin up a fresh `Game` whenever they want.
//
// INPUT: VIPER.INPUT.ACTION
// -------------------------
// `Game.init` registers every gameplay action by name
// (`ACT_LEFT`, `ACT_JUMP`, `ACT_SHOOT`, ...) and binds it
// to one or more keys/buttons.  The rest of the code then
// uses `Action.Held(ACT_LEFT)` instead of
// `Keyboard.IsDown(KEY_A)`.  Two benefits:
//
//   * Platform independent — gamepad input binds to the
//     same actions as keyboard input; gameplay code doesn't
//     care.
//   * Rebindable — a settings menu can ask the runtime to
//     "next key-press becomes the new jump bind" without
//     touching any gameplay code.
//
// THE FRAME LOOP
// --------------
//     run():
//         while running:
//             dt = clamp(elapsed_ms_since_last_frame, 1, DT_MAX)
//             input.poll()
//             tick(dt)
//             draw(canvas)
//             canvas.Flip()
//
// `dt` drives frame-rate independence — every physics and
// animation step scales by `dt / DT_BASE`.  `DT_MAX` caps
// the dt so one bad lag spike doesn't tunnel the player
// through walls (see `physics.zia` for why that matters).
//
// WHERE THIS FITS
// ---------------
//     main.zia  ──►  constructs and runs the Game.
//     All subsystems are children of this class.
//     Viper.Input.Action      ──►  named input bindings.
//     Viper.Graphics          ──►  canvas / window / pixels.
//     Viper.Game.DebugOverlay ──►  FPS + diagnostics.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `Game` fields: subsystems, state, shared counters.
//   2. `init` — construct every subsystem, bind inputs.
//   3. `run` — the main frame loop.
//   4. `tick(dt)` — per-state update dispatch.
//   5. `draw(canvas)` — per-state render dispatch.
//   6. Per-state handlers (`tickPlay`, `tickMenu`,
//      `tickGameOver`, ...).
//   7. Event hooks: `onPlayerDeath`, `onLevelComplete`,
//      `onBossDefeated`, `onAbilityAcquired`.
//   8. Save / load glue (`saveProgress` / `loadFromSlot`).
//
// =============================================================================

module game;

bind Viper.Graphics;
bind Viper.Input;
bind Viper.Input.Keyboard as Keyboard;
bind Viper.Input.Pad as Pad;
bind Viper.Text.Fmt;
bind Viper.Game;
bind Viper.Game.DebugOverlay as Debug;
bind Viper.IO.File as File;
bind Viper.IO.Path as Path;
bind "./config";
bind "./palette";
bind "./sprites";
bind "./player";
bind "./enemy";
bind "./projectile";
bind "./level";
bind "./physics";
bind "./camera";
bind "./campaign_content";
bind "./combat_feedback";
bind "./particles";
bind "./pickups";
bind "./hud";
bind "./menu";
bind "./renderer";
bind "./sound";
bind "./abilities";
bind "./accessibility";
bind "./save";
bind "./world_state";
bind "./world_graph";
bind "./worldmap";
bind "./lore";
bind "./transitions";
bind "./lighting";
bind "./texture";
bind "./ai";
bind "./achievements";
bind "./tuning";
bind "./economy";
bind "./difficulty";
bind "./hub";
bind "./death_loop";
bind "./profile_flow";
bind "./radio";
bind "./settings";
bind "./objectives";
bind "./tutorials";
bind "./meta_modes";
bind "./ui_coordinator";

final EXPEDITION_MODE_CAMPAIGN = 0;
final EXPEDITION_MODE_TIME_TRIAL = 1;
final EXPEDITION_MODE_BOSS_RUSH = 2;
final BOSS_RUSH_ENCOUNTER_COUNT = 4;
final NEW_GAME_PLUS_CONFIRM_MS = 5000;

/// @brief The whole game.  Owns every subsystem, the
///        top-level state, and the main loop.
///
/// State machine:
///     MENU → LEVEL_SELECT → LOADING → PLAYING
///         ↓                              ↓ pause
///         OPTIONS / CONTROLS         PAUSED
///                                       ↓ die
///                                    GAME_OVER → MENU
///                                       ↓ clear
///                                    LEVEL_COMPLETE → next level
///                                       ↓ all clear
///                                    VICTORY
class Game {
    hide Palette pal;
    hide Canvas canvas;
    hide SceneManager sm;

    // Subsystems
    hide Player player;
    hide EnemyManager enemies;
    hide Level level;
    hide GameCamera camera;
    hide ParticleSystem particles;
    hide PickupManager pickups;
    hide ProjectilePool bullets;
    hide HUD hudObj;
    hide MenuSystem menus;
    hide SpriteFactory sprites;
    hide Renderer renderObj;
    hide PhysicsHelper phys;
    hide SoundManager sfx;
    hide Debug debugOverlay;
    hide RuntimeTuning tuning;
    hide GameSettings settings;
    hide Boolean debugEnabled;

    // New subsystems (XENOSCAPE expansion)
    hide AbilityManager abilities;
    hide SaveManager saveManager;
    hide WorldState worldState;
    hide WorldGraph worldGraph;
    hide WorldMap worldMap;
    hide LoreSystem loreSystem;
    // hide TransitionManager transitions;
    hide LightingSystem lighting;
    hide TextureFactory textures;
    hide TransitionManager transitions;
    hide AchievementSystem achSys;
    hide UpgradeSystem upgrades;
    hide DifficultySystem difficulty;
    hide HubSystem hub;
    hide DeathRecovery deathRecovery;
    hide ProfileFlow profileFlow;
    hide TutorialSystem tutorialSystem;
    hide MetaProgression metaProgression;
    hide RadioSystem radioSystem;
    hide UiCoordinator uiCoordinator;

    // Expansion state
    hide Integer gems;
    hide Integer bossesDefeated;    // bitmask
    hide Integer totalPlaytime;     // seconds
    hide Integer saveSlot;          // active save slot (0-2)
    hide Integer completionMask;    // completed-level mask
    hide Integer deathCount;        // run deaths
    hide Boolean showWorldMap;
    hide Boolean showLore;
    hide Integer poundImpactTimer;  // ground pound visual timer
    hide Boolean wasPounding;       // track pound landing (one-shot)
    hide Boolean fullscreenOn;
    hide Boolean optionsReturnToPause;
    hide Boolean controlsReturnToPause;
    hide Integer bossCueTimer;
    hide Boolean bossIntroPlayed;
    hide Boolean bossCameraLocked;
    hide Integer openingIntroTimer;
    hide Integer achBrowse;
    hide Integer bestiaryBrowse;
    hide Integer loreBrowse;
    hide Integer routeSelection;
    hide Integer hubLaunchLevel;
    hide Integer hubRouteSelection;
    hide Integer currentRoomIndex;
    hide Integer pendingEntryFromRegion;
    hide Integer roomTitleTimer;
    hide String interactionMessage;
    hide Integer interactionMessageTimer;
    hide Integer nearInteractionIndex;
    hide Boolean expeditionActive;
    hide Integer lastRegionRank;
    hide Integer lastRegionRankScore;
    hide Integer lastRegionDiscoveries;
    hide Integer expeditionMode;
    hide Integer hubSimulatorRegion;
    hide Integer bossRushIndex;
    hide Integer bossRushElapsedMs;
    hide Integer bossRushDamageTaken;
    hide Integer newGamePlusConfirmTimer;

    // Death flash tracking (draw bright circle at kill position)
    hide Integer killFlashX;       // world pixel X of last kill
    hide Integer killFlashY;       // world pixel Y of last kill
    hide Integer killFlashTimer;   // frames remaining (0 = inactive)

    // Game state
    hide Integer score;
    hide Integer coins;
    hide Integer enemiesKilled;  // per-level kill tally for the complete screen (#7)
    hide Integer currentLevel;
    hide Integer levelTimer;     // milliseconds elapsed in level
    hide Integer levelDamageTaken;
    hide Boolean reachedCheckpoint;
    hide Integer checkpointLevel;
    hide Integer checkpointX;
    hide Integer checkpointY;

    // Level complete state
    hide Integer levelCompleteTimer;
    hide Integer timeBonus;

    // Frame timing
    hide Integer dt;
    hide Integer frameDt;
    hide Integer hitStopTimer;
    hide Integer rumbleTimer;

    // Menu screen-transition state (#3): deferred fade-out -> switch -> fade-in
    hide Integer menuPending;    // pending action code, or MENU_PENDING_NONE
    hide Integer menuTransT;     // frames since the current menu fade-out began

    // Death/respawn
    hide Integer deathTimer;

    // Sound: track previous player state for jump detection
    hide Integer prevPlayerState;

    // Particle effect tracking
    hide Boolean prevOnGround;
    hide Integer prevVy;
    hide Integer wallSparkTimer;   // ms accumulator for wall-slide sparks
    hide Integer jetFlameTimer;    // ms accumulator for jetpack flame
    hide Integer footstepTimer;    // ms until the next surface-specific step

    /// @brief Construct every subsystem (palette, sprites,
    ///        sound, level, player, camera, hud, menu,
    ///        renderer, ...), wire them up, register input
    ///        actions.  Does NOT run the main loop — that's
    ///        `run()`.
    expose func init() {
        sm = SceneManager.New();
        sm.Add("menu");
        sm.Add("playing");
        sm.Add("paused");
        sm.Add("gameover");
        sm.Add("levelcomplete");
        sm.Add("highscores");
        sm.Add("controls");
        sm.Add("bossfight");
        sm.Add("victory");
        sm.Add("levelselect");
        sm.Add("options");
        sm.Add("loadgame");
        sm.Add("extras");
        sm.Add("credits");
        sm.Add("intro");
        sm.Add("achievements");
        sm.Add("bestiary");
        sm.Add("lorearchive");
        sm.Add("hub");
        sm.Add("profiles");
        sm.Switch("menu");

        score = 0;
        coins = 0;
        currentLevel = 1;
        levelTimer = 0;
        levelDamageTaken = 0;
        reachedCheckpoint = false;
        checkpointLevel = 0;
        checkpointX = 0;
        checkpointY = 0;
        levelCompleteTimer = 0;
        timeBonus = 0;
        dt = 16;
        frameDt = 16;
        hitStopTimer = 0;
        rumbleTimer = 0;
        deathTimer = 0;
        prevPlayerState = PS_IDLE;
        prevOnGround = false;
        prevVy = 0;
        wallSparkTimer = 0;
        jetFlameTimer = 0;
        footstepTimer = 0;
        fullscreenOn = false;
        optionsReturnToPause = false;
        controlsReturnToPause = false;
        bossCueTimer = 0;
        bossIntroPlayed = false;
        bossCameraLocked = false;
        openingIntroTimer = 0;
        achBrowse = 0;
        bestiaryBrowse = 0;
        loreBrowse = 0;
        expeditionActive = false;
        hubLaunchLevel = 1;
        hubRouteSelection = 0;
        lastRegionRank = REGION_RANK_UNRANKED;
        lastRegionRankScore = 0;
        lastRegionDiscoveries = 0;
        expeditionMode = EXPEDITION_MODE_CAMPAIGN;
        hubSimulatorRegion = 0;
        bossRushIndex = 0;
        bossRushElapsedMs = 0;
        bossRushDamageTaken = 0;
        newGamePlusConfirmTimer = 0;

        // Create palette first — passed to all subsystems that use colors
        pal = new Palette();

        // Create subsystems — palette-aware ones receive pal via constructor
        sprites = new SpriteFactory(pal);
        player = new Player();
        enemies = new EnemyManager();
        level = new Level();
        camera = new GameCamera(pal);
        particles = new ParticleSystem(pal);
        pickups = new PickupManager();
        bullets = new ProjectilePool();
        hudObj = new HUD(pal);
        menus = new MenuSystem(pal);
        renderObj = new Renderer(pal);
        phys = new PhysicsHelper();
        settings = new GameSettings();
        syncRendererAccessibility();
        sfx = new SoundManager();
        sfx.setup(resolveAssetBasePath());
        sfx.setMasterVolume(settings.getValue(SETTING_MASTER_VOLUME));
        sfx.setMusicVolume(settings.getValue(SETTING_MUSIC_VOLUME));
        sfx.setSfxVolume(settings.getValue(SETTING_SFX_VOLUME));
        sfx.setAmbienceVolume(settings.getValue(SETTING_AMBIENCE_VOLUME));
        sfx.setVoiceVolume(settings.getValue(SETTING_VOICE_VOLUME));
        fullscreenOn = settings.getValue(SETTING_FULLSCREEN) == 1;
        tuning = new RuntimeTuning(resolveTuningPath());
        debugEnabled = tuning.getBool("debug.enabled", false);
        var authoredArtEnabled =
            tuning.getBool("presentation.authoredArtEnabled", true);
        menus.setAuthoredTitleArtEnabled(authoredArtEnabled);
        sprites.setAuthoredPlayerArtEnabled(authoredArtEnabled);
        debugOverlay = Debug.New();
        if tuning.getBool("debug.showOnStart", false) {
            debugOverlay.Enable();
        }
        currentLevel = tuning.getInt("game.startLevel", 1);
        if currentLevel < 1 { currentLevel = 1; }
        if currentLevel > LEVEL_COUNT { currentLevel = LEVEL_COUNT; }
        hubLaunchLevel = currentLevel;

        // Setup input actions via presets + custom bindings
        setupActions();

        // Load saved high scores from disk
        menus.loadHighScores();

        // Initialize expansion systems (abilities, save, lighting, etc.)
        initNewSystems();
        syncPresentationAccessibility();
        syncPlayerAbilities();

        // Menu transition controller starts idle.
        menuPending = MENU_PENDING_NONE;
        menuTransT = 0;

        // Down action already bound by platformer preset as move_down
        // We reuse it for ground pound detection

        // Start menu music
        sfx.playMenuMusic();
    }

    // =========================================================================
    // Input action setup — binds keyboard keys to named actions
    // =========================================================================

    /// @brief Register every named input action with the
    ///        Action runtime.  Bindings are loaded from the
    ///        platformer preset and then individually
    ///        rebound so we own the mapping.
    hide func setupActions() {
        // Standard presets: defines move_left, move_right, jump, shoot, pause
        // with WASD + arrows + gamepad D-pad/A/X/Start
        Action.LoadPreset("platformer");

        // Menu presets: defines menu_up, menu_down, confirm, back
        // with arrows + WASD + Enter/Space/Escape + gamepad D-pad/A/B
        Action.LoadPreset("menu_navigation");

        // Custom additions beyond what presets provide
        Action.BindKey(ACT_SHOOT, KEY_Z);               // Z key for shoot
        Action.BindPadButton(ACT_SHOOT, PAD_IDX, PAD_BTN_RB);   // RB for shoot
        Action.BindPadButton(ACT_BACK, PAD_IDX, PAD_BTN_START); // Start for back/pause
        Action.Define(ACT_INTERACT);
        Action.BindKey(ACT_INTERACT, KEY_E);
        Action.BindPadButton(ACT_INTERACT, PAD_IDX, PAD_BTN_Y);
        Action.Define(ACT_GRAPPLE);
        Action.BindKey(ACT_GRAPPLE, KEY_C);
        Action.BindPadButton(ACT_GRAPPLE, PAD_IDX, PAD_BTN_LB);
        Action.BindPadButton(ACT_GRAPPLE, PAD_IDX, PAD_BTN_SELECT);
        Action.Define(ACT_DASH);
        Action.BindKey(ACT_DASH, KEY_X);
        Action.BindPadButton(ACT_DASH, PAD_IDX, PAD_BTN_X);
        Action.Define(ACT_MAP);
        Action.BindKey(ACT_MAP, KEY_M);
        Action.BindPadButton(ACT_MAP, PAD_IDX, PAD_BTN_UP);

        // Debug overlay toggle (F3)
        Action.Define("debug");
        Action.BindKey("debug", KEY_F3);

        // Fullscreen toggle (F11)
        Action.Define(ACT_FULLSCREEN);
        Action.BindKey(ACT_FULLSCREEN, KEY_F11);
    }

    // =========================================================================
    // Main game loop
    // =========================================================================

    /// @brief The main loop.  `while running { poll input;
    ///        compute dt; tick(dt); draw(canvas); flip(); }`.
    ///        Returns only on quit; teardown runs after.
    expose func run() {
        canvas = Canvas.New("XENOSCAPE: The Descent", SCREEN_W, SCREEN_H);
        canvas.SetFps(60);
        canvas.SetMaxDeltaTime(DT_MAX);
        if fullscreenOn { canvas.Fullscreen(); }

        while canvas.BeginFrame() != 0 {
            frameDt = canvas.DeltaTime;
            dt = frameDt;
            updateRumble();
            if sm.IsScene("playing") {
                dt = dt * settings.getValue(SETTING_GAME_SPEED) / 100;
                if dt < 1 { dt = 1; }
            }

            // Debug overlay toggle (F3)
            if debugEnabled and Action.Pressed("debug") {
                debugOverlay.Toggle();
            }
            if Keyboard.WasPressed(KEY_F11) {
                toggleFullscreen();
            } else if Action.Pressed(ACT_FULLSCREEN) {
                toggleFullscreen();
            }

            sm.Update(dt);

            if sm.IsScene("menu") {
                updateMenu();
            } else {
            if sm.IsScene("playing") {
                updatePlaying();
            } else {
            if sm.IsScene("paused") {
                updatePaused();
            } else {
            if sm.IsScene("gameover") {
                updateGameOver();
            } else {
            if sm.IsScene("levelcomplete") {
                updateLevelComplete();
            } else {
            if sm.IsScene("highscores") {
                updateHighScores();
            } else {
            if sm.IsScene("controls") {
                updateControls();
            } else {
            if sm.IsScene("options") {
                updateOptions();
            } else {
            if sm.IsScene("loadgame") {
                updateLoadGame();
            } else {
            if sm.IsScene("extras") {
                updateExtras();
            } else {
            if sm.IsScene("credits") {
                updateCredits();
            } else {
            if sm.IsScene("intro") {
                updateIntro();
            } else {
            if sm.IsScene("achievements") {
                updateAchievements();
            } else {
            if sm.IsScene("bestiary") {
                updateBestiary();
            } else {
            if sm.IsScene("lorearchive") {
                updateLoreArchive();
            } else {
            if sm.IsScene("victory") {
                updateVictory();
            } else {
            if sm.IsScene("levelselect") {
                updateLevelSelect();
            } else {
            if sm.IsScene("hub") {
                updateHub();
            } else {
            if sm.IsScene("profiles") {
                updateProfiles();
            }
            }}}}}}}}}}}}}}}}}}

            updateDebugOverlay();

            canvas.Flip();
        }
        saveBeforeReturnToTitle();
        Pad.StopVibration(0);
        sfx.shutdown();
    }

    /// @brief Toggle the game window between fullscreen and windowed modes.
    ///
    /// Uses the Viper `Canvas.Fullscreen()` and `Canvas.Windowed()` APIs so the
    /// same path is available from F11 and the Options menu.
    hide func toggleFullscreen() {
        if fullscreenOn {
            canvas.Windowed();
            fullscreenOn = false;
        } else {
            canvas.Fullscreen();
            fullscreenOn = true;
        }
        settings.setValue(SETTING_FULLSCREEN, boolToSetting(fullscreenOn));
        if settings.save() == false {
            setInteractionMessage(
                "Settings could not be saved. Check storage permissions and try again.");
        }
    }

    /// @brief Convert a Boolean display state to the settings integer encoding.
    ///
    /// @param value Boolean state to serialize.
    /// @return One for true and zero for false.
    hide func boolToSetting(value: Boolean) -> Integer {
        if value { return 1; }
        return 0;
    }

    /// @brief Flush active expedition and application settings on a clean exit.
    ///
    /// The explicit `expeditionActive` guard prevents quitting directly from the
    /// boot title from overwriting a real slot with default in-memory game state.
    /// Failures use nonblocking messages when another frame can still render.
    ///
    /// @return Nothing. Marks any active expedition inactive after its save try.
    hide func saveBeforeReturnToTitle() {
        if expeditionActive {
            if saveProgress() == false {
                setInteractionMessage(
                    "Progress could not be saved. Check storage permissions and try again.");
            }
            expeditionActive = false;
        }
        if settings.save() == false {
            setInteractionMessage(
                "Settings could not be saved. Check storage permissions and try again.");
        }
    }

    /// @brief Locate assets in installed packages or source-tree runs.
    hide func resolveAssetBasePath() -> String {
        if File.Exists("sounds/jump.wav") { return ""; }

        var exeDir = Path.ExeDir();
        var exePath = Path.Join(Path.Join(exeDir, "sounds"), "jump.wav");
        if File.Exists(exePath) { return exeDir + Path.Separator(); }

        var rootPath = "examples/games/xenoscape/sounds/jump.wav";
        if File.Exists(rootPath) { return "examples/games/xenoscape/"; }

        var binPath = "../games/xenoscape/sounds/jump.wav";
        if File.Exists(binPath) { return "../games/xenoscape/"; }

        return "";
    }

    /// @brief Locate the runtime-tuning JSON file (installed
    ///        next to the binary, then source-tree fallbacks).
    hide func resolveTuningPath() -> String {
        var localPath = "xenoscape.runtime.json";
        if File.Exists(localPath) { return localPath; }

        var exePath = Path.Join(Path.ExeDir(), "xenoscape.runtime.json");
        if File.Exists(exePath) { return exePath; }

        var rootPath = "examples/games/xenoscape/xenoscape.runtime.json";
        if File.Exists(rootPath) { return rootPath; }

        // Demo binaries are launched from examples/bin by build_demos_mac.sh.
        var binPath = "../games/xenoscape/xenoscape.runtime.json";
        if File.Exists(binPath) { return binPath; }

        return localPath;
    }

    /// @brief Push current game stats (FPS, position, state)
    ///        into `Viper.Game.DebugOverlay`.  Toggleable in
    ///        options.
    hide func updateDebugOverlay() {
        if debugEnabled == false { return; }
        debugOverlay.Update(dt);
        debugOverlay.Watch("dt", dt);
        debugOverlay.Watch("scene", sceneId());
        debugOverlay.Watch("level", currentLevel);
        debugOverlay.Watch("player_state", player.state);
        debugOverlay.Watch("state_frames", player.stateFrames());
        debugOverlay.Watch("player_vx", player.vx);
        debugOverlay.Watch("player_vy", player.vy);
        debugOverlay.Watch("enemies", enemies.activeCount());
        debugOverlay.Watch("enemy_bullets", enemies.enemyBulletCount());
        debugOverlay.Watch("bullets", bullets.activeCount());
        debugOverlay.Watch("particles", particles.activeCount());
        debugOverlay.Watch("cam_x", camera.x);
        debugOverlay.Watch("cam_y", camera.y);
        debugOverlay.Draw(canvas);
    }

    /// @brief Cheap "what scene am I in?" id used by the
    ///        debug overlay.  Maps the high-level state
    ///        to a small integer.
    hide func sceneId() -> Integer {
        if sm.IsScene("menu") { return 0; }
        if sm.IsScene("playing") { return 1; }
        if sm.IsScene("paused") { return 2; }
        if sm.IsScene("gameover") { return 3; }
        if sm.IsScene("levelcomplete") { return 4; }
        if sm.IsScene("highscores") { return 5; }
        if sm.IsScene("controls") { return 6; }
        if sm.IsScene("options") { return 7; }
        if sm.IsScene("loadgame") { return 8; }
        if sm.IsScene("extras") { return 9; }
        if sm.IsScene("credits") { return 10; }
        if sm.IsScene("intro") { return 11; }
        if sm.IsScene("achievements") { return 12; }
        if sm.IsScene("bestiary") { return 13; }
        if sm.IsScene("lorearchive") { return 14; }
        if sm.IsScene("victory") { return 15; }
        if sm.IsScene("levelselect") { return 16; }
        if sm.IsScene("hub") { return 17; }
        if sm.IsScene("profiles") { return 18; }
        return -1;
    }

    // =========================================================================
    // State: Menu
    // =========================================================================

    /// @brief Per-frame: title / main-menu state.  Routes
    ///        input through `MenuSystem.updateTitle` and
    ///        switches state on its return code.
    hide func updateMenu() {
        menus.setContinueAvailable(saveManager.getContinueSlot() >= 0);
        if interactionMessageTimer > 0 {
            interactionMessageTimer = interactionMessageTimer - dt;
            if interactionMessageTimer < 0 { interactionMessageTimer = 0; }
        }
        // Reuse the renderer's single ScreenFX instance for menu transitions
        // (otherwise dormant in the menu).  ScreenFX is ms-based, so feed it the
        // real frame dt; the menu's Tween-driven logo anim is per-frame.
        renderObj.update(dt);

        // A transition is mid-flight: hold input, keep drawing the darkening
        // title under the fade, and commit the pending action once the overlay
        // is near-opaque.  ScreenFX clears a fade the instant it completes, so
        // we MUST switch at the midpoint (near-black), not at the end, to avoid
        // flashing the old screen.  The frame fallback guarantees no hang.
        if menuPending != MENU_PENDING_NONE {
            menuTransT = menuTransT + 1;
            menus.drawTitle(canvas);
            renderObj.drawNotification(canvas, interactionMessage,
                                       interactionMessageTimer, 2400);
            renderObj.drawTransition(canvas);
            if renderObj.overlayAlpha() >= 200 or menuTransT > 40 {
                commitMenuTransition();
            }
            return;
        }

        var result = menus.updateTitle();
        menus.drawTitle(canvas);
        renderObj.drawNotification(canvas, interactionMessage,
                                   interactionMessageTimer, 2400);
        renderObj.drawTransition(canvas);

        if menus.titleSelectionMoved() {
            sfx.playMenuMove();
        }

        if result == MENU_ACTION_CONTINUE and
           saveManager.getContinueSlot() < 0 {
            setInteractionMessage("No saved expedition is available.");
            sfx.playMenuBack();
            return;
        }

        // A selection darkens the screen first; the switch happens later
        // (commitMenuTransition) once the fade-out covers the screen.
        if result != -1 {
            menuPending = result;
            menuTransT = 0;
            sfx.playMenuSelect();
            renderObj.fadeOut(10);
        }
    }

    /// @brief Commit a deferred menu selection once the fade-out has the
    ///        screen near-black, then fade the destination back in from black.
    hide func commitMenuTransition() {
        var action = menuPending;
        menuPending = MENU_PENDING_NONE;

        if action == -2 {
            canvas.Close();
            return;
        }
        if action == STATE_PLAYING {
            openProfileFlow(PROFILE_MODE_NEW);
        } else {
        if action == MENU_ACTION_CONTINUE {
            if loadMostAdvancedSlot() == false {
                openProfileFlow(PROFILE_MODE_LOAD);
                setInteractionMessage("No saved expedition is available.");
            }
        } else {
        if action == STATE_LEVELSELECT {
            sm.Switch("levelselect");
        } else {
        if action == STATE_OPTIONS {
            optionsReturnToPause = false;
            sm.Switch("options");
            menus.resetSelection();
        } else {
        if action == STATE_LOADGAME {
            openProfileFlow(PROFILE_MODE_LOAD);
        } else {
        if action == STATE_EXTRAS {
            sm.Switch("extras");
            menus.resetSelection();
        } else {
        if action == STATE_CREDITS {
            sm.Switch("credits");
        } else {
        if action == STATE_HIGHSCORES {
            sm.Switch("highscores");
            menus.resetSelection();
        } else {
        if action == STATE_CONTROLS {
            controlsReturnToPause = false;
            sm.Switch("controls");
        }
        }}}}}}}}
        renderObj.menuFadeIn(450);
    }

    /// @brief Per-frame: level-select state.  Calls
    ///        `loadLevel` on choice.
    hide func updateLevelSelect() {
        renderObj.update(dt);
        var result = menus.updateLevelSelect();
        menus.drawLevelSelect(canvas);
        renderObj.drawTransition(canvas);

        if result == STATE_PLAYING {
            sfx.playMenuSelect();
            // Start game at the selected level
            score = 0;
            coins = 0;
            currentLevel = menus.selectedLevel;
            levelTimer = 0;
            reachedCheckpoint = false;
            deathTimer = 0;
            player.reset();
            loadLevel(currentLevel);
            sm.Switch("playing");
            sfx.playGameMusic();
        }
        if result == STATE_MENU {
            sfx.playMenuBack();
            sm.Switch("menu");
            sfx.playMenuMusic();
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
        }
    }

    // =========================================================================
    // State: Playing
    // =========================================================================

    /// @brief Per-frame: in-level gameplay update.  THIS IS
    ///        THE BIG ONE.  Order:
    ///          1. ability inputs (dash, charge, pound)
    ///          2. player.update
    ///          3. enemies.updateAll
    ///          4. bullets.updateAll
    ///          5. pickups.updateAll
    ///          6. particles.updateAll
    ///          7. lighting.update
    ///          8. camera.follow
    ///          9. collision checks (player↔enemy, etc.)
    ///         10. trigger checks (hazards, checkpoints,
    ///             save stations, lore)
    ///         11. level-end + game-over checks
    hide func updatePlaying() {
        // Blocking overlays get first refusal over map/pause input. This keeps
        // Back from opening a second screen over lore or an ability reward.
        syncPlayerAbilities();
        if updateNewSystems() {
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
            return;
        }
        if tutorialSystem.getActiveTutorial() >= 0 and
           Action.Pressed(ACT_BACK) {
            tutorialSystem.dismiss();
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
            return;
        }
        if Action.Pressed(ACT_MAP) {
            tutorialSystem.acknowledge(TUTORIAL_MAP);
            showWorldMap = true;
            sm.Switch("paused");
            menus.resetSelection();
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
            return;
        }
        // Pause check
        if Action.Pressed(ACT_BACK) {
            sm.Switch("paused");
            menus.resetSelection();
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            menus.drawPause(canvas);
            return;
        }
        if hitStopTimer > 0 {
            hitStopTimer = hitStopTimer - frameDt;
            if hitStopTimer < 0 { hitStopTimer = 0; }
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
            return;
        }

        // Dynamic tiles advance only during live simulation. Contact from the
        // previous frame is consumed before Player reports this frame's contact.
        level.updateDynamicTiles(dt);

        // Update player
        player.update(level, dt);
        updateRoomDiscovery();
        if player.didStartJump() { achSys.onJump(); }
        if player.didLaunchFromSteam() {
            particles.burstDust(player.centerX(), player.pixelY() + PLAYER_H);
            sfx.playJump();
        }
        if player.didBreakCrumble() {
            particles.burstCrystalShatter(player.centerX(),
                                          player.pixelY() + PLAYER_H);
            sfx.playCrystalBreak();
        }
        if player.didLandGroundPound() {
            var impactX = player.centerX();
            var impactY = player.pixelY() + PLAYER_H + 2;
            level.damageDestructibleAtWorld(impactX, impactY, 2);
            enemies.staggerInRadius(impactX, impactY,
                                    GROUND_POUND_RADIUS,
                                    GROUND_POUND_STAGGER_MS);
            poundImpactTimer = 12;
            particles.burstPoundImpact(impactX, impactY);
            sfx.playGroundPound();
            startRumble(85, 180);
        }

        // Check if player wants to shoot
        if player.wantsToShoot() {
            var bx = player.pixelX() + PLAYER_W / 2;
            var by = player.pixelY() + PLAYER_H / 2 - 2;
            if player.facing > 0 {
                bx = player.pixelX() + PLAYER_W;
            } else {
                bx = player.pixelX() - BULLET_W;
            }
            if bullets.fire(bx, by, player.facing) {
                player.startShootAnimation();
                sfx.playShoot();
                achSys.onBulletFired();
            }
        }

        // Update camera + background animation
        var cameraVerticalIntent = 0;
        if Action.Held(ACT_MOVE_UP) { cameraVerticalIntent = -1; }
        if Action.Held(ACT_MOVE_DOWN) { cameraVerticalIntent = 1; }
        camera.followWithIntent(
            player.centerX(), player.centerY(), player.vx,
            cameraVerticalIntent, dt,
            settings.getValue(SETTING_REDUCED_MOTION) == 1);
        camera.updateBg(dt);

        // Update enemies (with particle trails for enemy bullets)
        enemies.updateAll(level, player.pixelX(), player.pixelY(), dt, particles);
        if enemies.didFireEnemyProjectile() { sfx.playEnemyTell(); }
        var combatIntensity = 0;
        if enemies.hasThreatNear(player.centerX(), player.centerY(), 820) {
            combatIntensity = 100;
        }
        sfx.setCombatIntensity(combatIntensity);
        if enemies.didBossPhaseChange() {
            var bossX = enemies.getEnemyPixelX(enemies.bossIndex);
            var bossY = enemies.getEnemyPixelY(enemies.bossIndex);
            particles.burstBossPhaseTransition(bossX, bossY, pal.bossEye);
            renderObj.shake(12, 6);
            sfx.playBossPhase();
            startHitStop(bossPhaseHitStopDurationMs());
            startRumble(100, 260);
        }

        // Update bullets (with particle trails)
        bullets.updateAll(level, dt, particles);

        // Update pickups
        pickups.updateAll();

        // Update particles
        particles.updateAll();

        // Update renderer effects + tile animations
        renderObj.update(dt);
        level.updateTileAnims(dt);

        // Update HUD
        hudObj.update(score, coins, dt);
        hudObj.updatePopups();

        // Level timer (ms-based)
        levelTimer = levelTimer + dt;
        if expeditionMode == EXPEDITION_MODE_BOSS_RUSH {
            bossRushElapsedMs = bossRushElapsedMs + dt;
        }

        // Detect jump state transition for sound
        if player.state == PS_JUMP || player.state == PS_DJUMP {
            if prevPlayerState != PS_JUMP {
                if prevPlayerState != PS_DJUMP {
                    sfx.playJump();
                }
            }
        }
        prevPlayerState = player.state;

        // --- Particle effects ---

        // Hard landing dust (transition from airborne to grounded with high downward velocity)
        if player.onGround {
            if prevOnGround == false {
                if prevVy > 600 {
                    particles.burstLandDust(player.pixelX() + PLAYER_W / 2,
                                            player.pixelY() + PLAYER_H);
                } else {
                    // Light landing — small puff
                    particles.burstDust(player.pixelX() + PLAYER_W / 2,
                                        player.pixelY() + PLAYER_H);
                }
            }
        }

        // Wall-slide sparks (every 80ms while sliding)
        if player.state == PS_WALLSLIDE {
            wallSparkTimer = wallSparkTimer + dt;
            if wallSparkTimer >= 80 {
                wallSparkTimer = 0;
                var sparkX = player.pixelX();
                if player.wallDir > 0 {
                    sparkX = sparkX + PLAYER_W;
                }
                particles.burstWallSlideSpark(sparkX,
                                               player.pixelY() + PLAYER_H / 2,
                                               player.wallDir);
            }
        } else {
            wallSparkTimer = 0;
        }

        // Jetpack flame (every 50ms while airborne and moving upward)
        if player.onGround == false {
            if player.vy < 0 {
                jetFlameTimer = jetFlameTimer + dt;
                if jetFlameTimer >= 50 {
                    jetFlameTimer = 0;
                    // Flame comes from jetpack (center-back of player)
                    var flameX = player.pixelX() + PLAYER_W / 2;
                    particles.burstJetpackFlame(flameX,
                                                player.pixelY() + PLAYER_H);
                }
            } else {
                jetFlameTimer = 0;
            }
        } else {
            jetFlameTimer = 0;
        }

        prevOnGround = player.onGround;
        prevVy = player.vy;
        updateFootstepAudio();

        // --- Collision checks ---
        checkPlayerEnemyCollision();
        checkPlayerPickupCollision();
        updateDeathMarkerRecovery();
        checkBulletEnemyCollision();
        checkPlayerEnemyBullets();
        checkPlayerReflectedBullets();
        checkHazards();
        checkCheckpoint();
        updateContextualTutorials();
        checkLevelEnd();
        updateBossDiscoveryCue();

        // Handle player death
        if player.state == PS_DEAD {
            handleDeath();
            return;
        }

        // Render
        renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                bullets, pickups, particles, hudObj, sprites,
                                score, coins, currentLevel);

        // Kill flash — bright expanding circle at enemy death position
        if killFlashTimer > 0 {
            var fx = killFlashX - camera.x;
            var fy = killFlashY - camera.y;
            var flashR = (15 - killFlashTimer) * 6;
            var flashAlpha = killFlashTimer * 16;
            if flashAlpha > 255 { flashAlpha = 255; }
            // Bright white expanding ring
            canvas.DiscAlpha(fx, fy, flashR, Color.RGB(255, 255, 200), flashAlpha);
            canvas.Ring(fx, fy, flashR, Color.RGB(255, 200, 50));
            // Inner bright core
            if killFlashTimer > 8 {
                canvas.Disc(fx, fy, 12, Color.RGB(255, 255, 255));
            }
            killFlashTimer = killFlashTimer - 1;
        }

        drawNewSystems(canvas, camera.x, camera.y);

    }

    // =========================================================================
    // Collision: Player vs Enemies
    // =========================================================================

    /// @brief Dispatch one captured enemy death-effect family to particles.
    ///
    /// Enemy traits are captured before pool release, then routed here after the
    /// kill is confirmed. Unknown effect ids deliberately use the existing gold
    /// enemy burst so malformed content remains visible rather than silent.
    ///
    /// @param effect Stable id from `enemyDeathEffectForType` in the range 0..6.
    /// @param worldX World-pixel horizontal center of the defeated enemy.
    /// @param worldY World-pixel vertical center of the defeated enemy.
    /// @return Nothing. Emits particles only; scoring and audio remain caller-owned.
    hide func spawnEnemyDeathEffect(effect: Integer, worldX: Integer,
                                    worldY: Integer) {
        if effect == 1 { particles.burstPoisonCloud(worldX, worldY); }
        else if effect == 2 { particles.burstCrystalShatter(worldX, worldY); }
        else if effect == 3 { particles.burstLavaSplash(worldX, worldY); }
        else if effect == 4 { particles.burstFrostShatter(worldX, worldY); }
        else if effect == 5 { particles.burstCorruptionDeath(worldX, worldY); }
        else if effect == 6 { particles.burstExplosion(worldX, worldY); }
        else { particles.burstEnemyDeath(worldX, worldY, pal.sparkYellow); }
    }

    /// @brief Player vs each live enemy AABB.  Stomp from
    ///        above kills the enemy; side/below contact
    ///        damages the player (subject to iframes).
    hide func checkPlayerEnemyCollision() {
        if player.iframes > 0 { return; }
        if player.state == PS_DEAD { return; }

        var hit = enemies.checkPlayerHit(player.pixelX(), player.pixelY());
        if hit >= 0 {
            var etype = enemies.getEnemyType(hit);
            var contactDamage = enemies.getContactDamage(hit);
            var freezeDuration = enemies.getFreezeDuration(hit);

            if player.vy > 0 {
                var enemyTop = enemies.getEnemyPixelY(hit);
                var enemyMid = enemyTop + enemies.getEnemyHeight(hit) / 2;
                var playerFeet = player.pixelY() + PLAYER_H;
                if etype != ENEMY_TURRET and playerFeet <= enemyMid + 12 {
                    var ex = enemies.getEnemyPixelX(hit);
                    var ey = enemies.getEnemyPixelY(hit);
                    var defeatedScore = enemies.getEnemyScore(hit);
                    var deathEffect = enemies.getDeathEffectType(hit);
                    var hpBeforeStomp = enemies.getEnemyHp(hit);
                    enemies.damageEnemy(hit, 10);
                    player.vy = PLAYER_JUMP / 2;
                    player.syncVelocity();
                    player.iframes = IFRAMES_STOMP_MS;

                    // Check if enemy actually died
                    if enemies.isActive(hit) == 0 {
                        score = score + defeatedScore;
                        spawnEnemyDeathEffect(deathEffect, ex, ey);
                        renderObj.shake(8, 4);
                        sfx.playEnemyDeath();
                        achSys.onEnemyKilled();
                        loreSystem.unlockBestiaryEntry(etype);
                        enemiesKilled = enemiesKilled + 1;
                        hudObj.spawnPopup(ex, ey, defeatedScore);
                        // Trigger visible kill flash
                        killFlashX = ex;
                        killFlashY = ey;
                        killFlashTimer = 15;
                        startHitStop(killHitStopDurationMs(0));
                    } else {
                        var stompDamage = hpBeforeStomp - enemies.getEnemyHp(hit);
                        if stompDamage > 0 {
                            hudObj.spawnPopup(ex, ey, 0 - stompDamage);
                        }
                        particles.burstSpark(ex, ey, pal.sparkYellow);
                        renderObj.shake(4, 2);
                    }
                    sfx.playStomp();
                    return;
                }
            }

            applyIncomingDamage(contactDamage);
            if freezeDuration > 0 and player.state != PS_DEAD {
                player.freeze(freezeDuration);
                sfx.playFreeze();
            }
            renderObj.shake(8, 4);
            renderObj.flash(pal.hudRed, 6);
            sfx.playHurt();
            achSys.onPlayerHit();
        }
    }

    // =========================================================================
    // Collision: Player vs Pickups
    // =========================================================================

    /// @brief Player vs pickups.  Routes to
    ///        `Player.collectPowerUp` and the matching SFX +
    ///        achievement event.
    hide func checkPlayerPickupCollision() {
        var collected = pickups.checkCollection(player.pixelX(), player.pixelY());

        while collected >= 0 {
            if collected == PICKUP_COIN {
                coins = coins + 1;
                score = score + COIN_SCORE;
                particles.burstCoinCollect(player.centerX(), player.centerY());
                sfx.playCoin();
                achSys.onCoinCollected();
            } else if collected == PICKUP_GEM {
                gems = gems + 1;
                score = score + COIN_SCORE * 2;
                particles.burstCoinCollect(player.centerX(), player.centerY());
                sfx.playCoin();
                achSys.onGemCollected();
            } else if collected == PICKUP_HP_UP {
                player.maxHp = player.maxHp + 1;
                player.hp = player.maxHp;
                particles.burstSpark(player.centerX(), player.centerY(),
                                     pal.sparkYellow);
                sfx.playPowerup();
            } else if collected == PICKUP_KEY {
                if worldState.collectKey(currentLevel - 1) {
                    particles.burstAbilityAcquired(player.centerX(),
                                                   player.centerY());
                    sfx.playAbilityGet();
                    saveProgress();
                }
            } else {
                player.collectPowerUp(collected);
                particles.burstSpark(player.centerX(), player.centerY(),
                                     pal.sparkYellow);
                sfx.playPowerup();
            }

            collected = pickups.checkCollection(player.pixelX(), player.pixelY());
        }
    }

    // =========================================================================
    // Collision: Bullets vs Enemies
    // =========================================================================

    /// @brief Each player bullet vs each enemy AABB (via
    ///        the enemy quadtree).  Hit deals damage scaled
    ///        by the bullet's charge level.
    hide func checkBulletEnemyCollision() {
        var i = 0;
        while i < bullets.getCount() {
            if bullets.isActive(i) == 1 {
                var bx = bullets.getBulletX(i);
                var by = bullets.getBulletY(i);

                var assistPad = settings.getValue(SETTING_AIM_ASSIST) * 6;
                var hit = enemies.checkBulletHit(
                    bx - assistPad, by - assistPad,
                    BULLET_W + assistPad * 2, BULLET_H + assistPad * 2);
                if hit >= 0 {
                    var etype2 = enemies.getEnemyType(hit);
                    if enemies.isProjectileImmune(hit) {
                        if etype2 == ENEMY_MIRROR_SLIME {
                            bullets.reflectBullet(i);
                            particles.burstSpark(bx, by, pal.crystalBlue);
                        } else {
                            bullets.deactivate(i);
                            particles.burstSpark(bx, by, pal.stoneLight);
                        }
                    } else {
                        var charge = bullets.getChargeLevel(i);
                        var damage = projectileDamageForCharge(charge);
                        var defeatedScore = enemies.getEnemyScore(hit);
                        var deathEffect = enemies.getDeathEffectType(hit);
                        var enemyX = enemies.getEnemyPixelX(hit);
                        var enemyY = enemies.getEnemyPixelY(hit);
                        var wasBoss = enemies.isEnemyBoss(hit);
                        var hpBefore = enemies.getEnemyHp(hit);

                        bullets.deactivate(i);
                        enemies.damageEnemy(hit, damage);
                        particles.burstSpark(bx, by, pal.bullet);

                        if enemies.isActive(hit) == 0 {
                            score = score + defeatedScore;
                            spawnEnemyDeathEffect(deathEffect, enemyX, enemyY);
                            if wasBoss {
                                renderObj.shake(15, 8);
                            } else {
                                renderObj.shake(6, 3);
                            }
                            sfx.playEnemyDeath();
                            achSys.onEnemyKilled();
                            loreSystem.unlockBestiaryEntry(etype2);
                            enemiesKilled = enemiesKilled + 1;
                            killFlashX = enemyX;
                            killFlashY = enemyY;
                            hudObj.spawnPopup(enemyX, enemyY, defeatedScore);
                            killFlashTimer = 15;
                            startHitStop(killHitStopDurationMs(charge));
                        } else {
                            var applied = hpBefore - enemies.getEnemyHp(hit);
                            if applied > 0 {
                                hudObj.spawnPopup(enemyX, enemyY, 0 - applied);
                                if charge > 0 { startHitStop(18 + charge * 7); }
                            } else {
                                particles.burstSpark(bx, by, pal.stoneLight);
                            }
                        }
                    }
                }
            }
            i = i + 1;
        }
    }

    /// @brief Arm a nonadditive gameplay-only impact pause.
    ///
    /// A stronger event replaces a shorter remaining pause, while repeated weak
    /// events cannot stretch combat indefinitely. Rendering and input polling
    /// continue during the pause; player, enemy, projectile, timer, and camera
    /// simulation remain frozen until the real-time countdown reaches zero.
    ///
    /// @param durationMs Requested nonnegative pause duration in milliseconds.
    /// @return Nothing. Updates only the owned hit-stop countdown.
    hide func startHitStop(durationMs: Integer) {
        var duration = durationMs;
        if duration < 0 { duration = 0; }
        if duration > hitStopTimer { hitStopTimer = duration; }
    }

    /// @brief Start bounded cross-platform controller vibration when enabled.
    ///
    /// Linux backends safely no-op through the existing runtime adapter, while
    /// macOS and Windows receive equal low/high motor strengths. Repeated events
    /// replace only a shorter remaining vibration window.
    ///
    /// @param requestedStrength Authored magnitude in 0..100.
    /// @param durationMs Requested real-time duration in milliseconds.
    /// @return Nothing. Does not mutate gameplay state.
    hide func startRumble(requestedStrength: Integer, durationMs: Integer) {
        var strength = accessibleRumbleStrength(
            requestedStrength, settings.getValue(SETTING_RUMBLE) == 1);
        if strength <= 0 or durationMs <= 0 { return; }
        var amount = strength + 0.0;
        amount = amount / 100.0;
        Pad.Vibrate(0, amount, amount);
        if durationMs > rumbleTimer { rumbleTimer = durationMs; }
    }

    /// @brief Advance and stop the real-time rumble envelope once per frame.
    ///
    /// @return Nothing. Stops immediately when the setting is disabled or the
    ///         countdown expires; safe no-op platforms use the same call path.
    hide func updateRumble() {
        if settings.getValue(SETTING_RUMBLE) == 0 {
            if rumbleTimer > 0 { Pad.StopVibration(0); }
            rumbleTimer = 0;
            return;
        }
        if rumbleTimer <= 0 { return; }
        rumbleTimer = rumbleTimer - frameDt;
        if rumbleTimer <= 0 {
            rumbleTimer = 0;
            Pad.StopVibration(0);
        }
    }

    // =========================================================================
    // Collision: Enemy bullets vs Player
    // =========================================================================

    /// @brief Player vs incoming enemy bullets.  Damage on
    ///        contact (modulo iframes / shield).
    hide func checkPlayerEnemyBullets() {
        if player.iframes > 0 { return; }
        if player.state == PS_DEAD { return; }

        if enemies.checkEnemyBulletHit(player.pixelX(), player.pixelY()) {
            applyIncomingDamage(1);
            renderObj.shake(8, 4);
            renderObj.flash(pal.hudRed, 6);
            sfx.playHurt();
            achSys.onPlayerHit();
        }
    }

    /// @brief Resolve hostile projectiles returned by reflective enemies.
    ///
    /// Reflected shots stay in the player projectile pool so they can travel
    /// through the same continuous tile collision path and strike other enemies.
    /// This pass adds the missing ownership rule: a reflected slot also damages
    /// the player once, then releases immediately. Ordinary player-owned slots
    /// are ignored even when their sprite overlaps the shooter.
    ///
    /// @return Nothing. May release one projectile, damage the player, update
    ///         level damage, and emit hurt feedback. Iframes suppress the pass.
    hide func checkPlayerReflectedBullets() {
        if player.iframes > 0 or player.state == PS_DEAD { return; }

        var i = 0;
        while i < bullets.getCount() {
            if bullets.isActive(i) == 1 and bullets.isReflected(i) {
                if phys.rectOverlapPx(player.pixelX(), player.pixelY(),
                                      PLAYER_W, PLAYER_H,
                                      bullets.getBulletX(i), bullets.getBulletY(i),
                                      BULLET_W, BULLET_H) {
                    bullets.deactivate(i);
                    applyIncomingDamage(1);
                    particles.burstSpark(player.centerX(), player.centerY(),
                                         pal.enemyBullet);
                    renderObj.shake(8, 4);
                    renderObj.flash(pal.hudRed, 6);
                    sfx.playHurt();
                    achSys.onPlayerHit();
                    return;
                }
            }
            i = i + 1;
        }
    }

    // =========================================================================
    // Hazard check (spikes, lava)
    // =========================================================================

    /// @brief Player vs hazardous tiles (spikes, lava,
    ///        steam vents).  Triggers damage / launch effect
    ///        based on hazard id.
    hide func checkHazards() {
        if player.iframes > 0 { return; }
        if player.state == PS_DEAD { return; }

        if phys.isOnHazard(player.x, player.y, PLAYER_W, PLAYER_H, level) {
            applyIncomingDamage(2);
            renderObj.shake(10, 5);
            renderObj.flash(pal.lavaBright, 8);
            sfx.playHurt();
        }
    }

    /// @brief Apply one difficulty-scaled damage event and record real HP loss.
    ///
    /// Shield absorption and Player iframes remain authoritative: level damage
    /// statistics increase only by the actual HP delta after `takeDamage`.
    /// Positive base hits use the active Explorer/Standard/Veteran multiplier.
    ///
    /// @param baseDamage Unscaled positive gameplay damage units.
    /// @return Actual HP removed, or zero when absorbed or ignored.
    hide func applyIncomingDamage(baseDamage: Integer) -> Integer {
        var scaled = difficultyScaleIncomingDamage(
            baseDamage, difficulty.getProfile());
        scaled = (scaled * settings.getValue(SETTING_DAMAGE_ASSIST) + 99) / 100;
        if scaled < 1 and baseDamage > 0 { scaled = 1; }
        var before = player.hp;
        player.takeDamage(scaled);
        var dealt = before - player.hp;
        if dealt < 0 { dealt = 0; }
        levelDamageTaken = levelDamageTaken + dealt;
        if dealt > 0 { startRumble(72, 170); }
        return dealt;
    }

    // =========================================================================
    // Checkpoint
    // =========================================================================

    /// @brief Player vs checkpoint tile.  On first touch,
    ///        records the spawn point + plays the chime.
    hide func checkCheckpoint() {
        if level.hasCheckpoint == false { return; }
        if reachedCheckpoint { return; }

        var cpx = level.checkpointX;
        var cpy = level.checkpointY;
        var px = player.pixelX();
        var py = player.pixelY();

        var dx = px - cpx;
        if dx < 0 { dx = 0 - dx; }
        var dy = py - cpy;
        if dy < 0 { dy = 0 - dy; }

        if dx < TILE_SIZE * 2 {
            if dy < TILE_SIZE * 2 {
                reachedCheckpoint = true;
                checkpointLevel = currentLevel;
                checkpointX = cpx;
                checkpointY = cpy;
                particles.burstSpark(cpx + 16, cpy + 16, pal.checkpoint);
                sfx.playCheckpoint();
                if saveProgress() {
                    setInteractionMessage("Checkpoint activated. Expedition saved.");
                } else {
                    setInteractionMessage(
                        "Progress could not be saved. Check storage permissions and try again.");
                }
            }
        }
    }

    /// @brief Update one-shot boss discovery state for the active level.
    ///
    /// The cue triggers when the player gets close enough to the boss arena for
    /// the fight to be imminent.  A separate directional marker is drawn while
    /// the boss is alive and still off-screen.
    hide func updateBossDiscoveryCue() {
        if bossCueTimer > 0 {
            bossCueTimer = bossCueTimer - dt;
            if bossCueTimer < 0 { bossCueTimer = 0; }
        }

        if level.hasBoss == false { return; }
        if bossIntroPlayed { return; }
        if enemies.isBossAlive() == false { return; }

        var dx = level.bossX - player.pixelX();
        if dx < 0 { dx = 0 - dx; }
        if dx < SCREEN_W {
            bossIntroPlayed = true;
            bossCueTimer = 1800;
            bossCameraLocked = true;
            camera.setFocusWindow(level.bossX, SCREEN_W / 2 + TILE_SIZE * 3);
            renderObj.shake(5, 2);
            radioSystem.queueBossWarning(currentLevel - 1);
            sfx.playRadioCue();
            sfx.playBossIntro();
            sfx.playBossMusic();
        }
    }

    /// @brief Draw boss direction and discovery UI over gameplay.
    ///
    /// @param canvas Active gameplay canvas.
    /// @param camX Camera world X.
    /// @param camY Camera world Y.
    hide func drawBossCue(canvas: Canvas, camX: Integer, camY: Integer,
                          showBanner: Boolean) {
        if level.hasBoss == false { return; }
        if enemies.isBossAlive() == false { return; }

        var bossScreenX = level.bossX - camX;
        var bossScreenY = level.bossY - camY;

        if bossCueTimer > 0 and showBanner {
            canvas.BoxAlpha(360, 92, 560, 54, Color.RGB(0, 0, 10), 190);
            canvas.Frame(360, 92, 560, 54, Color.RGB(120, 210, 240));
            canvas.TextCenteredScaled(106, "BOSS SIGNATURE DETECTED",
                                      Color.RGB(180, 240, 255), 2);
        }

        if bossScreenX > SCREEN_W - 96 {
            canvas.BoxAlpha(SCREEN_W - 142, 308, 120, 56, Color.RGB(0, 0, 10), 150);
            canvas.TextScaled(SCREEN_W - 122, 320, ">>", 3,
                              Color.RGB(255, 180, 80));
            canvas.Text(SCREEN_W - 118, 348, "BOSS", Color.RGB(255, 220, 160));
        }
        if bossScreenX < 64 {
            canvas.BoxAlpha(22, 308, 120, 56, Color.RGB(0, 0, 10), 150);
            canvas.TextScaled(40, 320, "<<", 3, Color.RGB(255, 180, 80));
            canvas.Text(48, 348, "BOSS", Color.RGB(255, 220, 160));
        }
        if bossScreenX >= 64 {
            if bossScreenX <= SCREEN_W - 96 {
                canvas.Ring(bossScreenX + 32, bossScreenY + 32, 46,
                            Color.RGB(255, 180, 80));
            }
        }
    }

    // =========================================================================
    // Level end check
    // =========================================================================

    /// @brief Player vs level-exit tile.  Transitions to
    ///        LEVEL_COMPLETE state.
    hide func checkLevelEnd() {
        if isTouchingExitSign() {
            if level.hasBoss {
                if enemies.isBossAlive() {
                    return;
                }
            }

            if expeditionMode == EXPEDITION_MODE_TIME_TRIAL {
                beginTimeTrialDebrief();
                return;
            }
            if expeditionMode == EXPEDITION_MODE_BOSS_RUSH {
                advanceBossRush();
                return;
            }

            timeBonus = (600 - levelTimer / 1000) * TIME_BONUS_PER_SEC;
            if timeBonus < 0 { timeBonus = 0; }
            levelCompleteTimer = 0;
            menus.resetSelection();
            grantCompletionAbility();
            markLevelComplete(currentLevel);
            lastRegionDiscoveries = regionOptionalProgress(
                currentLevel - 1, loreSystem.getCollectedMask(),
                worldState.getRoomMask(currentLevel - 1));
            var rankResult = calculateRegionRank(
                currentLevel - 1, levelTimer, levelDamageTaken,
                lastRegionDiscoveries,
                lastRegionDiscoveries >= REGION_OPTIONAL_TARGET);
            lastRegionRank = rankResult.rank;
            lastRegionRankScore = rankResult.score;
            metaProgression.record(currentLevel - 1, rankResult, levelTimer);
            achSys.onLevelComplete(levelTimer, levelDamageTaken);
            achSys.onPacifistLevelComplete(currentLevel, enemiesKilled);
            if trueEndingUnlocked(
                completionMask, abilities.getMask(),
                loreSystem.getCollectedCount(), loreSystem.getTotalCount()) {
                achSys.onTrueEnding();
            }
            saveProgress();
            sfx.playLevelComplete();

            var totalScore = score + timeBonus;
            if menus.isHighScore(totalScore) {
                menus.addHighScore(totalScore, "PLR");
                menus.saveHighScores();
            }

            if currentLevel == 2 or currentLevel == 3 or currentLevel == 6 {
                enterHubAfterMajorBoss();
                return;
            }

            if currentLevel == LEVEL_COUNT {
                sm.Switch("victory");
                sfx.playVictoryMusic();
            } else {
                routeSelection = worldGraph.recommendedNeighborSelection(
                    currentLevel - 1, abilities.getMask(), completionMask);
                sm.Switch("levelcomplete");
                menus.startLevelComplete(score);   // arm the score count-up + burst (#8)
            }
        }
    }

    /// @brief Freeze a completed Time Trial result for the ranked debrief.
    ///
    /// Campaign progression, pickups, and interactions remain uncommitted. The
    /// existing debrief screen still reports all four authoritative rank inputs;
    /// confirmation later restores the pre-simulation save before writing only
    /// an improved regional best.
    ///
    /// @return Nothing. Switches from gameplay to the level-complete scene.
    hide func beginTimeTrialDebrief() {
        timeBonus = (600 - levelTimer / 1000) * TIME_BONUS_PER_SEC;
        if timeBonus < 0 { timeBonus = 0; }
        lastRegionDiscoveries = regionOptionalProgress(
            currentLevel - 1, loreSystem.getCollectedMask(),
            worldState.getRoomMask(currentLevel - 1));
        var rankResult = calculateRegionRank(
            currentLevel - 1, levelTimer, levelDamageTaken,
            lastRegionDiscoveries,
            lastRegionDiscoveries >= REGION_OPTIONAL_TARGET);
        lastRegionRank = rankResult.rank;
        lastRegionRankScore = rankResult.score;
        levelCompleteTimer = 0;
        menus.resetSelection();
        menus.startLevelComplete(score);
        sfx.playLevelComplete();
        sm.Switch("levelcomplete");
    }

    /// @brief Advance a cleared Boss Rush arena or open the final rush debrief.
    ///
    /// Each cleared arena contributes its damage to one cumulative result. The
    /// continuous clock is maintained independently from the per-level timer so
    /// loading the next authored arena cannot reset the run time.
    ///
    /// @return Nothing. Loads the next arena or switches to level-complete.
    hide func advanceBossRush() {
        bossRushDamageTaken = bossRushDamageTaken + levelDamageTaken;
        if bossRushIndex + 1 < BOSS_RUSH_ENCOUNTER_COUNT {
            bossRushIndex = bossRushIndex + 1;
            loadBossRushEncounter();
            sfx.playAbilityGet();
            return;
        }
        var rankResult = calculateBossRushRank(
            bossRushElapsedMs, bossRushDamageTaken);
        lastRegionRank = rankResult.rank;
        lastRegionRankScore = rankResult.score;
        lastRegionDiscoveries = BOSS_RUSH_ENCOUNTER_COUNT;
        timeBonus = 0;
        levelCompleteTimer = 0;
        menus.resetSelection();
        sfx.playVictory();
        sm.Switch("levelcomplete");
    }

    /// @brief Return to the evolving shipwreck after a major campaign boss.
    ///
    /// The graph recommends the first currently traversable uncompleted neighbor
    /// and stores it separately from the still-loaded completed region. Hub Launch
    /// then performs the real regional transition, preserving honest first-entry
    /// autosave semantics and giving the player a workbench/archive breather.
    ///
    /// @return Nothing. Switches to the hub scene and starts its music identity.
    hide func enterHubAfterMajorBoss() {
        var region = currentLevel - 1;
        hubRouteSelection = worldGraph.recommendedNeighborSelection(
            region, abilities.getMask(), completionMask);
        var destination = worldGraph.getAvailableNeighbor(
            region, hubRouteSelection, abilities.getMask());
        if destination < 0 { destination = region; }
        hubLaunchLevel = destination + 1;
        hub.reset();
        setInteractionMessage(
            "ARIA plotted the next launch: " +
            worldGraph.getRegionName(destination) + ".");
        sm.Switch("hub");
        sfx.playHubMusic();
    }

    /// @brief Test whether the player's hitbox overlaps any exit-sign tile.
    ///
    /// Older code checked only `(playerX / TILE_SIZE, GROUND_ROW - 1)`, which
    /// missed exits in taller or non-standard levels.  This scans the tile
    /// range touched by the player's current hitbox with a one-tile margin for
    /// forgiving interaction.
    ///
    /// @return True when a TILE_SIGN_END tile is within the player's overlap
    ///         area.
    hide func isTouchingExitSign() -> Boolean {
        var minCol = player.pixelX() / TILE_SIZE - 1;
        var maxCol = (player.pixelX() + PLAYER_W - 1) / TILE_SIZE + 1;
        var minRow = player.pixelY() / TILE_SIZE - 1;
        var maxRow = (player.pixelY() + PLAYER_H - 1) / TILE_SIZE + 1;

        if minCol < 0 { minCol = 0; }
        if minRow < 0 { minRow = 0; }
        if maxCol >= level.levelWidth { maxCol = level.levelWidth - 1; }
        if maxRow >= level.levelHeight { maxRow = level.levelHeight - 1; }

        var row = minRow;
        while row <= maxRow {
            var col = minCol;
            while col <= maxCol {
                if level.getTile(col, row) == TILE_SIGN_END {
                    return true;
                }
                col = col + 1;
            }
            row = row + 1;
        }

        return false;
    }

    /// @brief Grant non-boss campaign abilities that are earned on completion.
    ///
    /// Boss-granted abilities are handled when the boss dies.  Secret-area
    /// abilities need a reliable fallback in the procedural demo so the world
    /// map gates remain completable during linear testing.
    hide func grantCompletionAbility() {
        var reward = regionAbilityReward(currentLevel - 1);
        if reward > 0 and abilities.has(reward) == false {
            abilities.grant(reward);
            player.startAcquisitionAnimation();
            sfx.playAbilityGet();
        }
        syncPlayerAbilities();
        if abilities.getMask() == 63 { achSys.onAllAbilities(); }
    }

    /// @brief Mark a one-based level as completed in the
    ///        campaign bitmask.
    hide func markLevelComplete(levelNum: Integer) {
        var bit = bitForLevel(levelNum);
        if bit <= 0 { return; }
        if (completionMask / bit) % 2 == 0 {
            completionMask = completionMask + bit;
        }
    }

    /// @brief Convert one-based level number to a power-of-two
    ///        mask bit.
    hide func bitForLevel(levelNum: Integer) -> Integer {
        if levelNum < 1 { return 0; }
        var bit = 1;
        var i = 1;
        while i < levelNum {
            bit = bit * 2;
            i = i + 1;
        }
        return bit;
    }

    // =========================================================================
    // Death handling
    // =========================================================================

    /// @brief Present one campaign death and accept a checkpoint retry.
    ///
    /// The first frame creates a single recoverable salvage marker using the
    /// active difficulty profile. Simulation remains frozen while the short
    /// death beat plays; confirm, interact, or jump becomes a valid retry at
    /// `DEATH_RETRY_MS`, and the retry happens automatically at the full timer.
    /// Campaign mode never consumes a finite life or enters Game Over.
    ///
    /// @return Nothing. May rebuild the active room through `respawnAfterDeath`.
    hide func handleDeath() {
        if deathTimer == 0 {
            var beforeGems = gems;
            gems = deathRecovery.recordDeath(
                gems, difficulty.getProfile(), currentLevel,
                player.centerX(), player.centerY());
            var droppedGems = beforeGems - gems;
            if droppedGems > 0 {
                setInteractionMessage(Int(droppedGems) +
                                      " salvage dropped. Recover the signal.");
            }
            particles.burstDeath(player.centerX(), player.centerY());
            renderObj.shake(12, 6);
            renderObj.flash(pal.hudRed, 10);
            sfx.playDeath();
            achSys.onPlayerDeath();
            deathCount = deathCount + 1;
        }

        deathTimer = deathTimer + dt;

        particles.updateAll();
        renderObj.update(dt);
        renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                bullets, pickups, particles, hudObj, sprites,
                                score, coins, currentLevel);
        drawNewSystems(canvas, camera.x, camera.y);

        if deathTimer >= DEATH_RETRY_MS {
            canvas.BoxAlpha(SCREEN_W / 2 - 250, SCREEN_H - 104,
                            500, 48, pal.black, 190);
            canvas.Frame(SCREEN_W / 2 - 250, SCREEN_H - 104,
                         500, 48, pal.panelBorder);
            canvas.TextScaled(SCREEN_W / 2 - 190, SCREEN_H - 92,
                              Action.BindingsStr(ACT_CONFIRM) +
                              "  RECONSTITUTE",
                              2, pal.uiText);
        }

        var retryRequested = deathTimer >= DEATH_TIMER_MS;
        if deathTimer >= DEATH_RETRY_MS {
            if Action.Pressed(ACT_CONFIRM) or Action.Pressed(ACT_INTERACT) or
               Action.Pressed(ACT_JUMP) {
                retryRequested = true;
            }
        }
        if retryRequested {
            respawnAfterDeath();
        }
    }

    /// @brief Rebuild temporary room state and respawn at the safe campaign point.
    ///
    /// Permanent player, profile, world, lore, economy, and discovery state are
    /// retained. Level construction recreates current-room enemies, pickups,
    /// destructibles, and temporary surfaces; persistent doors/switches/shrines
    /// are projected back afterward. A checkpoint is used only in its own region,
    /// otherwise the authored area entrance is authoritative.
    ///
    /// @return Nothing. Returns the game to live play with full HP and iframes.
    hide func respawnAfterDeath() {
        var permanentMaxHp = player.maxHp;
        var spawnX = level.playerStartX;
        var spawnY = level.playerStartY;
        var useCheckpoint = checkpointLevel == currentLevel and
                            expeditionMode == EXPEDITION_MODE_CAMPAIGN;
        if useCheckpoint {
            spawnX = checkpointX;
            spawnY = checkpointY;
        }
        if expeditionMode == EXPEDITION_MODE_BOSS_RUSH {
            spawnX = level.bossX - TILE_SIZE * 6;
            if spawnX < TILE_SIZE { spawnX = TILE_SIZE; }
            spawnY = level.bossY;
        }

        level.loadLevel(currentLevel);
        level.enrichEnemies(currentLevel);
        level.applyPersistentInteractionState(worldState.getSwitchMask(),
                                              worldState.getDoorMask(),
                                              worldState.getShrineMask());
        camera.setLevelSize(level.levelWidth, level.levelHeight);

        player.reset();
        player.maxHp = permanentMaxHp;
        player.hp = permanentMaxHp;
        syncPlayerAbilities();
        player.spawn(spawnX, spawnY);
        camera.snapTo(player.centerX(), player.centerY());

        enemies.reset();
        enemies.setDifficultyProfile(difficulty.getProfile());
        enemies.setNewGamePlusActive(metaProgression.isNewGamePlusActive());
        enemies.spawnFromLevel(level);
        pickups.reset();
        pickups.spawnFromLevel(level);
        bullets.reset();
        particles.reset();

        reachedCheckpoint = useCheckpoint;
        currentRoomIndex = worldGraph.authoredRoomIndexForColumn(
            currentLevel - 1, player.pixelX() / TILE_SIZE, level.levelWidth);
        worldState.discoverRoom(currentLevel - 1, currentRoomIndex);
        roomTitleTimer = 0;
        footstepTimer = 0;
        deathTimer = 0;
        prevPlayerState = player.state;
        prevOnGround = false;
        prevVy = 0;
        renderObj.fadeIn(30);
    }

    /// @brief Collect the active death marker when the living player returns.
    ///
    /// Recovery is evaluated after ordinary pickup collision so the feedback can
    /// share pickup sound and particles without interfering with entity pools.
    /// The marker system guarantees a single collection and returns zero when the
    /// marker belongs to another region or lies outside the configured radius.
    ///
    /// @return Nothing. May increase carried salvage and consume the marker.
    hide func updateDeathMarkerRecovery() {
        if player.state == PS_DEAD { return; }
        var recovered = deathRecovery.recoverIfNear(
            currentLevel, player.centerX(), player.centerY(),
            DEATH_MARKER_RECOVER_RADIUS);
        if recovered <= 0 { return; }
        gems = gems + recovered;
        tutorialSystem.acknowledge(TUTORIAL_DEATH_RECOVERY);
        particles.burstAbilityAcquired(player.centerX(), player.centerY());
        sfx.playCoin();
        setInteractionMessage("Recovered " + Int(recovered) + " salvage.");
    }

    // =========================================================================
    // State: Paused
    // =========================================================================

    /// @brief Per-frame: paused state input handling.
    hide func updatePaused() {
        if showWorldMap {
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
            if Action.Pressed(ACT_BACK) or Action.Pressed(ACT_CONFIRM) {
                showWorldMap = false;
                sfx.playMenuBack();
            }
            return;
        }

        var result = menus.updatePause();

        renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                bullets, pickups, particles, hudObj, sprites,
                                score, coins, currentLevel);
        drawNewSystems(canvas, camera.x, camera.y);
        menus.drawEnhancedPause(canvas, pal, currentLevel, totalPlaytime, gems,
                                player.hp, player.maxHp, score,
                                menus.getPauseSelection());

        if result == STATE_PLAYING {
            sfx.playMenuSelect();
            sm.Switch("playing");
        }
        if result == MENU_ACTION_WORLD_MAP {
            sfx.playMenuSelect();
            showWorldMap = true;
        }
        if result == MENU_ACTION_SAVE {
            saveProgress();
            sfx.playSave();
        }
        if result == MENU_ACTION_RECOVER {
            sfx.playMenuSelect();
            respawnAfterDeath();
            setInteractionMessage(
                "Returned to the latest safe point. No salvage was lost.");
            sm.Switch("playing");
        }
        if result == STATE_OPTIONS {
            sfx.playMenuSelect();
            optionsReturnToPause = true;
            sm.Switch("options");
        }
        if result == STATE_CONTROLS {
            sfx.playMenuSelect();
            controlsReturnToPause = true;
            sm.Switch("controls");
        }
        if result == STATE_MENU {
            sfx.playMenuSelect();
            saveBeforeReturnToTitle();
            sm.Switch("menu");
            sfx.playMenuMusic();
            menus.resetSelection();
        }
    }

    // =========================================================================
    // State: Game Over
    // =========================================================================

    /// @brief Per-frame: game-over state input handling.
    hide func updateGameOver() {
        var result = menus.updateGameOver();
        menus.drawGameOver(canvas, score);

        if result == STATE_PLAYING {
            sfx.playMenuSelect();
            startNewGame(saveSlot, difficulty.getProfile());
            sfx.playGameMusic();
        }
        if result == STATE_MENU {
            sfx.playMenuSelect();
            saveBeforeReturnToTitle();
            sm.Switch("menu");
            sfx.playMenuMusic();
            menus.resetSelection();
        }
    }

    // =========================================================================
    // State: Level Complete
    // =========================================================================

    /// @brief Per-frame: level-complete state input.
    ///        Advances to the next level on continue.
    hide func updateLevelComplete() {
        levelCompleteTimer = levelCompleteTimer + 1;

        var routeCount = 0;
        if expeditionMode == EXPEDITION_MODE_CAMPAIGN {
            routeCount = worldGraph.getAvailableNeighborCount(
                currentLevel - 1, abilities.getMask());
            if Action.Pressed(ACT_DOWN) and routeCount > 0 {
                routeSelection = routeSelection + 1;
                if routeSelection >= routeCount { routeSelection = 0; }
                sfx.playMenuMove();
            }
            if Action.Pressed(ACT_UP) and routeCount > 0 {
                routeSelection = routeSelection - 1;
                if routeSelection < 0 { routeSelection = routeCount - 1; }
                sfx.playMenuMove();
            }
        }

        var result = menus.updateLevelComplete();

        renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                bullets, pickups, particles, hudObj, sprites,
                                score, coins, currentLevel);
        if expeditionMode == EXPEDITION_MODE_BOSS_RUSH {
            menus.drawBossRushComplete(
                canvas, bossRushElapsedMs, bossRushDamageTaken,
                regionRankLabel(lastRegionRank), lastRegionRankScore);
        } else {
            menus.drawLevelCompleteCinematic(canvas, currentLevel, levelTimer,
                                             levelDamageTaken,
                                             lastRegionDiscoveries,
                                             regionRankLabel(lastRegionRank),
                                             lastRegionRankScore,
                                             enemiesKilled, coins, gems, score,
                                             timeBonus);
        }
        if expeditionMode == EXPEDITION_MODE_CAMPAIGN {
            drawRouteChoices(canvas, routeCount);
        }

        if result == STATE_PLAYING {
            sfx.playMenuSelect();
            if expeditionMode == EXPEDITION_MODE_TIME_TRIAL {
                restoreSimulationSnapshot(true, currentLevel - 1,
                                          levelTimer, lastRegionRank,
                                          lastRegionRankScore);
                return;
            }
            if expeditionMode == EXPEDITION_MODE_BOSS_RUSH {
                restoreSimulationSnapshot(false, -1,
                                          bossRushElapsedMs,
                                          lastRegionRank,
                                          lastRegionRankScore);
                return;
            }
            score = score + timeBonus;
            var destination = worldGraph.getAvailableNeighbor(
                currentLevel - 1, routeSelection, abilities.getMask());
            if destination < 0 { destination = currentLevel - 1; }
            pendingEntryFromRegion = currentLevel - 1;
            loadLevel(destination + 1);
            levelCompleteTimer = 0;
            sm.Switch("playing");
        }
    }

    /// @brief Restore the pre-simulator campaign and commit allowed result data.
    ///
    /// All combat, pickup, interaction, death, and checkpoint mutations from a
    /// simulator run disappear when the saved campaign snapshot is reloaded. A
    /// Time Trial then records only its improved best time/rank; Boss Rush has no
    /// campaign mutation. Both modes return to the same hub profile and route.
    ///
    /// @param recordTrial True to commit a regional Time Trial result.
    /// @param region Zero-based trial region, ignored for Boss Rush.
    /// @param elapsedMs Completed simulation time in milliseconds.
    /// @param rank Authoritative result rank id.
    /// @param rankScore Authoritative composite result in 0..1000.
    /// @return Nothing. Falls back to title if the previously valid slot vanished.
    hide func restoreSimulationSnapshot(recordTrial: Boolean, region: Integer,
                                        elapsedMs: Integer, rank: Integer,
                                        rankScore: Integer) {
        expeditionMode = EXPEDITION_MODE_CAMPAIGN;
        if loadFromSlot(saveSlot) == false {
            expeditionActive = false;
            setInteractionMessage("The expedition snapshot could not be restored.");
            sm.Switch("menu");
            sfx.playMenuMusic();
            return;
        }
        if recordTrial {
            var result = new RegionRankResult(rankScore, rank);
            metaProgression.record(region, result, elapsedMs);
            hubSimulatorRegion = region;
            saveProgress();
            setInteractionMessage(
                "Time Trial recorded: " + Int(elapsedMs / 1000) +
                "s, rank " + regionRankLabel(rank) + ".");
        } else {
            setInteractionMessage(
                "Boss Rush complete: " + Int(elapsedMs / 1000) +
                "s, rank " + regionRankLabel(rank) + ".");
        }
        hubLaunchLevel = currentLevel;
        hub.reset();
        sm.Switch("hub");
        sfx.playHubMusic();
    }

    // =========================================================================
    // State: Shipwreck Hub
    // =========================================================================

    /// @brief Update the five-station shipwreck hub and workbench mutations.
    ///
    /// HubSystem owns only navigation. Game applies purchases, difficulty policy,
    /// save writes, map composition, and launch transitions so permanent state
    /// remains centralized. Launch reapplies pending difficulty at level load.
    ///
    /// @return Nothing. Draws the complete hub frame and may switch to gameplay.
    hide func updateHub() {
        renderObj.update(dt);
        ensureSimulatorRegion();
        if newGamePlusConfirmTimer > 0 {
            newGamePlusConfirmTimer = newGamePlusConfirmTimer - dt;
            if newGamePlusConfirmTimer < 0 { newGamePlusConfirmTimer = 0; }
        }
        if interactionMessageTimer > 0 {
            interactionMessageTimer = interactionMessageTimer - dt;
            if interactionMessageTimer < 0 { interactionMessageTimer = 0; }
        }

        var action = hub.update();
        if action >= HUB_ACTION_PURCHASE_BASE and
           action < HUB_ACTION_PURCHASE_BASE + UPGRADE_BRANCH_COUNT {
            var branch = action - HUB_ACTION_PURCHASE_BASE;
            var result = upgrades.purchase(branch, gems);
            if result.status == PURCHASE_SUCCESS {
                gems = result.remainingGems;
                if branch == UPGRADE_SUIT_INTEGRITY {
                    player.maxHp = player.maxHp + 1;
                    player.hp = player.maxHp;
                }
                syncPlayerAbilities();
                saveProgress();
                setInteractionMessage(upgradeBranchName(branch) +
                                      " upgraded to tier " + Int(result.newTier) + ".");
                sfx.playAbilityGet();
            } else if result.status == PURCHASE_INSUFFICIENT_GEMS {
                setInteractionMessage("Insufficient banked salvage.");
                sfx.playMenuBack();
            } else if result.status == PURCHASE_MAX_TIER {
                setInteractionMessage("That upgrade branch is already complete.");
                sfx.playMenuBack();
            }
        }
        if action == HUB_ACTION_DIFFICULTY_DOWN or
           action == HUB_ACTION_DIFFICULTY_UP {
            var requested = difficulty.getPendingProfile();
            if action == HUB_ACTION_DIFFICULTY_DOWN { requested = requested - 1; }
            if action == HUB_ACTION_DIFFICULTY_UP { requested = requested + 1; }
            if difficulty.requestAtSaveStation(requested) {
                if requested <= difficulty.getProfile() {
                    setInteractionMessage("Difficulty changed to " +
                                          difficultyName(requested) + ".");
                } else {
                    setInteractionMessage("Difficulty will increase on launch.");
                }
                sfx.playMenuMove();
            }
        }
        if action == HUB_ACTION_ROUTE_PREVIOUS or
           action == HUB_ACTION_ROUTE_NEXT {
            var routeCount = worldGraph.getAvailableNeighborCount(
                currentLevel - 1, abilities.getMask());
            if routeCount > 0 {
                if action == HUB_ACTION_ROUTE_PREVIOUS {
                    hubRouteSelection = hubRouteSelection - 1;
                } else {
                    hubRouteSelection = hubRouteSelection + 1;
                }
                if hubRouteSelection < 0 { hubRouteSelection = routeCount - 1; }
                if hubRouteSelection >= routeCount { hubRouteSelection = 0; }
                sfx.playMenuMove();
            }
        }
        if action == HUB_ACTION_ROUTE_SELECT {
            var selectedDestination = worldGraph.getAvailableNeighbor(
                currentLevel - 1, hubRouteSelection, abilities.getMask());
            if selectedDestination >= 0 {
                hubLaunchLevel = selectedDestination + 1;
                setInteractionMessage(
                    "Launch route set: " +
                    worldGraph.getRegionName(selectedDestination) + ".");
                sfx.playMenuSelect();
            }
        }
        if action == HUB_ACTION_TIME_TRIAL_PREVIOUS {
            cycleSimulatorRegion(-1);
            sfx.playMenuMove();
        }
        if action == HUB_ACTION_TIME_TRIAL_NEXT {
            cycleSimulatorRegion(1);
            sfx.playMenuMove();
        }
        if action == HUB_ACTION_TIME_TRIAL_START {
            startTimeTrial(hubSimulatorRegion);
            return;
        }
        if action == HUB_ACTION_BOSS_RUSH_START {
            startBossRush();
            return;
        }
        if action == HUB_ACTION_NEW_GAME_PLUS_START {
            requestNewGamePlus();
            if sm.IsScene("hub") == false { return; }
        }
        if action == HUB_ACTION_LAUNCH {
            hub.reset();
            loadLevel(hubLaunchLevel);
            saveProgress();
            sm.Switch("playing");
            sfx.playGameMusic();
            return;
        }

        hub.draw(canvas, majorBossCount(), gems, upgrades, difficulty,
                 loreSystem.getCollectedCount(), loreSystem.getTotalCount(),
                 loreSystem.getBestiaryCount(), loreSystem.getBestiaryTotal(),
                 achSys.getUnlockedCount(), ACH_COUNT,
                 worldGraph.getRegionName(hubSimulatorRegion),
                 hasAnyCompletedRegion(),
                 metaProgression.getBestTime(hubSimulatorRegion),
                 regionRankLabel(
                     metaProgression.getBestRank(hubSimulatorRegion)),
                 normalEndingUnlocked(completionMask),
                 normalEndingUnlocked(completionMask),
                 metaProgression.isNewGamePlusActive());
        if hub.isMapMode() {
            worldMap.draw(canvas, currentLevel, bossesDefeated,
                          worldState.getTeleporterMask(), abilities);
            var routeDestination = worldGraph.getAvailableNeighbor(
                currentLevel - 1, hubRouteSelection, abilities.getMask());
            if routeDestination >= 0 {
                canvas.BoxAlpha(350, SCREEN_H - 120, 580, 42,
                                Color.RGB(5, 12, 24), 220);
                canvas.Frame(350, SCREEN_H - 120, 580, 42,
                             pal.crystalBlue);
                canvas.TextCenteredScaled(
                    SCREEN_H - 110,
                    "LAUNCH VECTOR: " +
                    worldGraph.getRegionName(routeDestination),
                    pal.white, 1);
            }
        }
        renderObj.drawNotification(canvas, interactionMessage,
                                   interactionMessageTimer, 2400);
    }

    /// @brief Count the four major-boss completion bits for hub restoration art.
    ///
    /// @return Integer in 0..4 for Spore Mother, Crystal Wyrm, Magma Core, and
    ///         The Architect; minor/legacy boss bits do not affect restoration.
    hide func majorBossCount() -> Integer {
        var count = 0;
        var fungal = bitForLevel(2);
        var crystal = bitForLevel(3);
        var magma = bitForLevel(6);
        var architect = bitForLevel(10);
        if (bossesDefeated / fungal) % 2 == 1 { count = count + 1; }
        if (bossesDefeated / crystal) % 2 == 1 { count = count + 1; }
        if (bossesDefeated / magma) % 2 == 1 { count = count + 1; }
        if (bossesDefeated / architect) % 2 == 1 { count = count + 1; }
        return count;
    }

    /// @brief Report whether this profile has unlocked any regional Time Trial.
    ///
    /// @return True when at least one completion-mask bit is set.
    hide func hasAnyCompletedRegion() -> Boolean {
        var region = 0;
        while region < META_REGION_COUNT {
            if timeTrialUnlocked(region, completionMask) { return true; }
            region = region + 1;
        }
        return false;
    }

    /// @brief Move the simulator cursor onto a valid completed region if needed.
    ///
    /// Empty profiles retain region zero so the locked launch card can still show
    /// a stable name. The bounded ten-step search cannot loop indefinitely even
    /// when corrupted completion data contains no recognized campaign bits.
    ///
    /// @return Nothing. May update only the hub-local simulator region cursor.
    hide func ensureSimulatorRegion() {
        if hasAnyCompletedRegion() == false {
            hubSimulatorRegion = 0;
            return;
        }
        if timeTrialUnlocked(hubSimulatorRegion, completionMask) { return; }
        cycleSimulatorRegion(1);
    }

    /// @brief Select the previous or next completed regional simulation.
    ///
    /// @param direction Negative for previous and nonnegative for next.
    /// @return Nothing. Leaves the cursor stable when no trial is unlocked.
    hide func cycleSimulatorRegion(direction: Integer) {
        if hasAnyCompletedRegion() == false { return; }
        var candidate = hubSimulatorRegion;
        var attempts = 0;
        while attempts < META_REGION_COUNT {
            if direction < 0 { candidate = candidate - 1; }
            else { candidate = candidate + 1; }
            if candidate < 0 { candidate = META_REGION_COUNT - 1; }
            if candidate >= META_REGION_COUNT { candidate = 0; }
            if timeTrialUnlocked(candidate, completionMask) {
                hubSimulatorRegion = candidate;
                return;
            }
            attempts = attempts + 1;
        }
    }

    /// @brief Save the campaign snapshot and launch one read-only regional trial.
    ///
    /// Simulation mutations are never serialized; returning from the debrief
    /// reloads this pre-launch snapshot and then commits only the improved result.
    ///
    /// @param region Zero-based selected campaign region.
    /// @return Nothing. On failure, remains in the hub with a nonblocking message.
    hide func startTimeTrial(region: Integer) {
        if timeTrialUnlocked(region, completionMask) == false {
            setInteractionMessage("Complete that region to unlock its Time Trial.");
            sfx.playMenuBack();
            return;
        }
        if saveProgress() == false {
            setInteractionMessage(
                "Progress could not be saved. Check storage permissions and try again.");
            sfx.playMenuBack();
            return;
        }
        expeditionMode = EXPEDITION_MODE_TIME_TRIAL;
        hub.reset();
        loadLevel(region + 1);
        setInteractionMessage("TIME TRIAL // " + worldGraph.getRegionName(region));
        sm.Switch("playing");
        sfx.playGameMusic();
    }

    /// @brief Return the one-based campaign level for a Boss Rush encounter.
    ///
    /// @param index Stable encounter index in 0..3.
    /// @return Levels 2, 3, 6, and 10; invalid indices fall back to level 2.
    hide func bossRushLevel(index: Integer) -> Integer {
        if index == 0 { return 2; }
        if index == 1 { return 3; }
        if index == 2 { return 6; }
        if index == 3 { return 10; }
        return 2;
    }

    /// @brief Save the campaign snapshot and launch the four-boss sequence.
    ///
    /// @return Nothing. Locked or failed-save requests remain safely in the hub.
    hide func startBossRush() {
        if normalEndingUnlocked(completionMask) == false {
            setInteractionMessage("Defeat The Architect to unlock Boss Rush.");
            sfx.playMenuBack();
            return;
        }
        if saveProgress() == false {
            setInteractionMessage(
                "Progress could not be saved. Check storage permissions and try again.");
            sfx.playMenuBack();
            return;
        }
        expeditionMode = EXPEDITION_MODE_BOSS_RUSH;
        bossRushIndex = 0;
        bossRushElapsedMs = 0;
        bossRushDamageTaken = 0;
        hub.reset();
        loadBossRushEncounter();
        sm.Switch("playing");
        sfx.playBossMusic();
    }

    /// @brief Load the current Boss Rush arena and place the player at its gate.
    ///
    /// @return Nothing. Uses existing authored bosses, arenas, AI, and rewards;
    ///         permanent mutations remain isolated by simulation-mode saves.
    hide func loadBossRushEncounter() {
        var encounterLevel = bossRushLevel(bossRushIndex);
        loadLevel(encounterLevel);
        var startX = level.bossX - TILE_SIZE * 6;
        if startX < TILE_SIZE { startX = TILE_SIZE; }
        player.spawn(startX, level.bossY);
        camera.snapTo(player.centerX(), player.centerY());
        setInteractionMessage(
            "BOSS RUSH " + Int(bossRushIndex + 1) + " / " +
            Int(BOSS_RUSH_ENCOUNTER_COUNT) + " // " +
            enemyDisplayName(level.bossType));
    }

    /// @brief Require a second confirmation before replacing campaign progress.
    ///
    /// The first request opens a five-second confirmation window. A second request
    /// begins NG+ only when the normal ending is unlocked and the profile is not
    /// already running the remixed ruleset.
    ///
    /// @return Nothing. Draws feedback or transitions into `beginNewGamePlus`.
    hide func requestNewGamePlus() {
        if metaProgression.isNewGamePlusActive() {
            setInteractionMessage("New Game+ is already active on this expedition.");
            sfx.playMenuBack();
            return;
        }
        if normalEndingUnlocked(completionMask) == false {
            setInteractionMessage("Defeat The Architect to unlock New Game+.");
            sfx.playMenuBack();
            return;
        }
        if newGamePlusConfirmTimer <= 0 {
            newGamePlusConfirmTimer = NEW_GAME_PLUS_CONFIRM_MS;
            setInteractionMessage(
                "Confirm BEGIN NEW GAME+ again to restart the campaign.");
            sfx.playMenuBack();
            return;
        }
        beginNewGamePlus();
    }

    /// @brief Start a remixed campaign while retaining permanent collection data.
    ///
    /// Abilities, max HP, salvage, upgrades, lore, bestiary, keycards, shrines,
    /// teleporters, and discovered map rooms survive. Story bosses, routes,
    /// switches, doors, checkpoints, run time, and deaths reset for a clean loop.
    /// The current completed campaign is flushed before any destructive mutation.
    ///
    /// @return Nothing. A failed save leaves the completed campaign untouched.
    hide func beginNewGamePlus() {
        if saveProgress() == false {
            setInteractionMessage(
                "Progress could not be saved. Check storage permissions and try again.");
            newGamePlusConfirmTimer = 0;
            sfx.playMenuBack();
            return;
        }
        if metaProgression.setNewGamePlusActive(true, completionMask) == false {
            setInteractionMessage("New Game+ could not be unlocked for this profile.");
            newGamePlusConfirmTimer = 0;
            sfx.playMenuBack();
            return;
        }

        var retainedMaxHp = player.maxHp;
        var retainedKeys = worldState.getKeyMask();
        var retainedShrines = worldState.getShrineMask();
        var retainedTeleporters = worldState.getTeleporterMask();
        var retainedRooms = [];
        var region = 0;
        while region < META_REGION_COUNT {
            retainedRooms.add(worldState.getRoomMask(region));
            region = region + 1;
        }

        expeditionMode = EXPEDITION_MODE_CAMPAIGN;
        currentLevel = 1;
        hubLaunchLevel = 1;
        bossesDefeated = 0;
        completionMask = 0;
        checkpointLevel = 0;
        checkpointX = 0;
        checkpointY = 0;
        reachedCheckpoint = false;
        totalPlaytime = 0;
        deathCount = 0;
        score = 0;
        coins = 0;
        deathRecovery.reset(gems);
        worldState.reset();
        worldState.setMasks(retainedKeys, 0, 0, retainedShrines,
                            retainedTeleporters);
        region = 0;
        while region < META_REGION_COUNT {
            worldState.setRoomMask(region, retainedRooms.get(region));
            region = region + 1;
        }
        player.reset();
        player.maxHp = retainedMaxHp;
        player.hp = retainedMaxHp;
        syncPlayerAbilities();
        loadLevel(1);
        saveProgress();
        newGamePlusConfirmTimer = 0;
        openingIntroTimer = 0;
        sm.Switch("intro");
        sfx.playGameMusic();
    }

    /// @brief Draw traversable regional destinations on the completion screen.
    ///
    /// Choices come exclusively from the authoritative WorldGraph and therefore
    /// include bidirectional return routes while excluding locked ability gates.
    /// The selected destination is highlighted and includes its stable region
    /// name; input handling lives in `updateLevelComplete`.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param routeCount Number of currently traversable neighboring regions.
    /// @return Nothing. Draws a compact route selector without mutating state.
    hide func drawRouteChoices(canvas: Canvas, routeCount: Integer) {
        var panelW = 560;
        var panelH = 42 + routeCount * 26;
        var panelX = SCREEN_W / 2 - panelW / 2;
        var panelY = SCREEN_H - panelH - 28;
        canvas.BoxAlpha(panelX, panelY, panelW, panelH,
                        Color.RGB(5, 10, 20), 220);
        canvas.Frame(panelX, panelY, panelW, panelH,
                     Color.RGB(70, 130, 180));
        canvas.Text(panelX + 18, panelY + 10,
                    "SELECT NEXT EXPEDITION ROUTE",
                    Color.RGB(160, 220, 255));
        var i = 0;
        while i < routeCount {
            var destination = worldGraph.getAvailableNeighbor(
                currentLevel - 1, i, abilities.getMask());
            var marker = "  ";
            var color = Color.RGB(130, 150, 170);
            if i == routeSelection {
                marker = "> ";
                color = Color.RGB(255, 220, 120);
            }
            canvas.Text(panelX + 24, panelY + 36 + i * 26,
                        marker + worldGraph.getRegionName(destination), color);
            i = i + 1;
        }
    }

    // =========================================================================
    // State: Victory
    // =========================================================================

    /// @brief Per-frame: end-credits / victory state input.
    hide func updateVictory() {
        var result = menus.updateVictory();
        // Rich victory screen (#7): real total time, gems, and lore-discovery %.
        var loreTotal = loreSystem.getTotalCount();
        var lorePct = 0;
        if loreTotal > 0 {
            lorePct = loreSystem.getCollectedCount() * 100 / loreTotal;
        }
        var trueEnding = trueEndingUnlocked(
            completionMask, abilities.getMask(),
            loreSystem.getCollectedCount(), loreTotal);
        menus.drawVictoryScreen(canvas, totalPlaytime / 1000, gems, lorePct,
                                trueEnding);

        if result == STATE_MENU {
            sfx.playMenuSelect();
            hubLaunchLevel = 1;
            hubSimulatorRegion = currentLevel - 1;
            hub.reset();
            setInteractionMessage(
                "Postgame simulator online: Boss Rush and New Game+ unlocked.");
            sm.Switch("hub");
            sfx.playHubMusic();
        }
    }

    // =========================================================================
    // State: High Scores
    // =========================================================================

    /// @brief Per-frame: high-scores state input.
    hide func updateHighScores() {
        renderObj.update(dt);
        var result = menus.updateHighScores();
        menus.drawHighScores(canvas);
        renderObj.drawTransition(canvas);

        if result == STATE_MENU {
            sfx.playMenuBack();
            sm.Switch("menu");
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
        }
    }

    // =========================================================================
    // State: Controls
    // =========================================================================

    /// @brief Per-frame: controls-screen state input.
    hide func updateControls() {
        renderObj.update(dt);
        if expeditionActive and Action.Pressed(ACT_INTERACT) {
            tutorialSystem.reset();
            saveProgress();
            setInteractionMessage(
                "Suit guidance reset. Context cards will replay in the field.");
            sfx.playMenuSelect();
            if controlsReturnToPause {
                controlsReturnToPause = false;
                sm.Switch("paused");
            } else {
                sm.Switch("menu");
            }
            return;
        }
        var result = menus.updateControls();
        menus.drawControls(canvas);
        renderObj.drawTransition(canvas);

        if result == STATE_MENU {
            sfx.playMenuBack();
            if controlsReturnToPause {
                controlsReturnToPause = false;
                sm.Switch("paused");
            } else {
                sm.Switch("menu");
                menus.resetSelection();
                menus.resetTitleAnim();
                renderObj.menuFadeIn(350);
            }
        }
    }

    // =========================================================================
    // State: Options
    // =========================================================================

    /// @brief Per-frame: options-screen input and rendering.
    ///
    /// Owns settings that live outside MenuSystem: fullscreen on the Canvas and
    /// audio mix values on SoundManager.  The menu only reports row/action IDs.
    hide func updateOptions() {
        renderObj.update(dt);
        if interactionMessageTimer > 0 {
            interactionMessageTimer = interactionMessageTimer - dt;
            if interactionMessageTimer < 0 { interactionMessageTimer = 0; }
        }
        var result = menus.updateOptions();

        if optionsReturnToPause {
            renderObj.renderPlaying(canvas, camera, level, player, enemies,
                                    bullets, pickups, particles, hudObj, sprites,
                                    score, coins, currentLevel);
            drawNewSystems(canvas, camera.x, camera.y);
        } else {
            menus.drawTitle(canvas);
        }

        menus.drawSettings(canvas, pal, settings, menus.getOptionsSelection());
        renderObj.drawNotification(canvas, interactionMessage,
                                   interactionMessageTimer, 2400);
        renderObj.drawTransition(canvas);

        if result == OPTIONS_ACTION_VALUE_DOWN or
           result == OPTIONS_ACTION_VALUE_UP {
            var selectedSetting = menus.getOptionsSelection();
            if selectedSetting < SETTING_COUNT {
                if selectedSetting == SETTING_FULLSCREEN {
                    toggleFullscreen();
                } else {
                    var direction = 1;
                    if result == OPTIONS_ACTION_VALUE_DOWN { direction = -1; }
                    settings.adjust(selectedSetting, direction);
                    applyLiveSetting(selectedSetting);
                    if settings.save() == false {
                        setInteractionMessage(
                            "Settings could not be saved. Check storage permissions and try again.");
                    }
                }
                sfx.playMenuMove();
            }
        }
        if result == OPTIONS_ACTION_BACK {
            sfx.playMenuBack();
            if optionsReturnToPause {
                optionsReturnToPause = false;
                sm.Switch("paused");
            } else {
                sm.Switch("menu");
                menus.resetSelection();
                menus.resetTitleAnim();
                renderObj.menuFadeIn(350);
            }
        }
    }

    /// @brief Apply one changed setting to the relevant live subsystem.
    ///
    /// Persistence remains owned by updateOptions. Settings without immediate
    /// subsystem state (for example navigation hints) are read directly at their
    /// gameplay/render call sites and therefore require no dispatch here.
    ///
    /// @param setting One valid `SETTING_*` id that just changed.
    /// @return Nothing. May update active audio mix state.
    hide func applyLiveSetting(setting: Integer) {
        if setting == SETTING_MASTER_VOLUME {
            sfx.setMasterVolume(settings.getValue(setting));
        }
        if setting == SETTING_MUSIC_VOLUME {
            sfx.setMusicVolume(settings.getValue(setting));
        }
        if setting == SETTING_SFX_VOLUME {
            sfx.setSfxVolume(settings.getValue(setting));
        }
        if setting == SETTING_AMBIENCE_VOLUME {
            sfx.setAmbienceVolume(settings.getValue(setting));
        }
        if setting == SETTING_VOICE_VOLUME {
            sfx.setVoiceVolume(settings.getValue(setting));
        }
        if setting == SETTING_REDUCED_MOTION or
           setting == SETTING_REDUCED_FLASHES or
           setting == SETTING_SCREEN_SHAKE or
           setting == SETTING_HIGH_CONTRAST {
            syncRendererAccessibility();
        }
        if setting == SETTING_UI_SCALE or
           setting == SETTING_HIGH_CONTRAST or
           setting == SETTING_LARGE_TEXT or
           setting == SETTING_REDUCED_MOTION {
            syncPresentationAccessibility();
        }
    }

    /// @brief Copy persistent motion/flash/shake settings into Renderer.
    ///
    /// @return Nothing. Subsequent trails, ambient motion, flashes, and camera
    ///         shakes use the new accessibility values immediately.
    hide func syncRendererAccessibility() {
        renderObj.setAccessibility(
            settings.getValue(SETTING_REDUCED_MOTION) == 1,
            settings.getValue(SETTING_REDUCED_FLASHES) == 1,
            settings.getValue(SETTING_SCREEN_SHAKE),
            settings.getValue(SETTING_HIGH_CONTRAST) == 1);
    }

    /// @brief Push persistent scale/contrast/text choices into menu and HUD.
    ///
    /// @return Nothing. Subsequent menu and gameplay draws immediately use the
    ///         normalized settings without recreating either long-lived system.
    hide func syncPresentationAccessibility() {
        var uiScale = settings.getValue(SETTING_UI_SCALE);
        var highContrast = settings.getValue(SETTING_HIGH_CONTRAST) == 1;
        var largeText = settings.getValue(SETTING_LARGE_TEXT) == 1;
        menus.setAccessibility(
            uiScale, highContrast, largeText,
            settings.getValue(SETTING_REDUCED_MOTION) == 1);
        hudObj.setAccessibility(uiScale, highContrast, largeText);
        profileFlow.setAccessibility(uiScale, highContrast, largeText);
        hub.setAccessibility(uiScale, highContrast, largeText);
        loreSystem.setAccessibility(uiScale, largeText, highContrast);
        tutorialSystem.setAccessibility(uiScale, largeText, highContrast);
        abilities.setAccessibility(uiScale, largeText, highContrast);
        worldMap.setAccessibility(uiScale, largeText, highContrast);
    }

    // =========================================================================
    // State: Load Game / Extras / Credits
    // =========================================================================

    /// @brief Update the explicit New Game / Load Game expedition profile flow.
    ///
    /// ProfileFlow owns navigation and confirmation state. Game remains the sole
    /// authority for persistent deletion, slot loading, difficulty creation, and
    /// audio/scene transitions. Empty slots and destructive actions therefore
    /// receive deterministic, user-visible outcomes.
    ///
    /// @return Nothing. May enter intro/gameplay or return to the title scene.
    hide func updateProfiles() {
        renderObj.update(dt);
        if interactionMessageTimer > 0 {
            interactionMessageTimer = interactionMessageTimer - dt;
            if interactionMessageTimer < 0 { interactionMessageTimer = 0; }
        }

        var action = profileFlow.update();
        profileFlow.draw(canvas, pal);
        renderObj.drawNotification(canvas, interactionMessage,
                                   interactionMessageTimer, 2400);
        renderObj.drawTransition(canvas);

        if action == PROFILE_ACTION_BACK {
            sfx.playMenuBack();
            sm.Switch("menu");
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
            return;
        }
        if action == PROFILE_ACTION_EMPTY {
            setInteractionMessage("This expedition slot is empty.");
            sfx.playMenuBack();
            return;
        }
        if action == PROFILE_ACTION_DELETE {
            saveManager.deleteSlot(profileFlow.getSelectedSlot());
            refreshProfileSlots();
            setInteractionMessage("Expedition slot deleted.");
            sfx.playMenuSelect();
            return;
        }
        if action == PROFILE_ACTION_LOAD {
            if loadFromSlot(profileFlow.getSelectedSlot()) == false {
                setInteractionMessage("This expedition slot is empty.");
                sfx.playMenuBack();
            } else {
                sfx.playMenuSelect();
            }
            return;
        }
        if action == PROFILE_ACTION_CREATE {
            var slot = profileFlow.getSelectedSlot();
            var profile = profileFlow.getSelectedDifficulty();
            saveManager.deleteSlot(slot);
            startNewGame(slot, profile);
            sfx.playMenuSelect();
        }
    }

    /// @brief Enter one profile workflow and cache all release slot summaries.
    ///
    /// @param mode `PROFILE_MODE_NEW` for creation, otherwise load browsing.
    /// @return Nothing. Switches to the profile scene with deterministic focus.
    hide func openProfileFlow(mode: Integer) {
        refreshProfileSlots();
        if mode == PROFILE_MODE_NEW {
            profileFlow.beginNew();
        } else {
            profileFlow.beginLoad();
        }
        sm.Switch("profiles");
    }

    /// @brief Synchronize ProfileFlow's three cached cards from SaveManager.
    ///
    /// @return Nothing. Copies summaries and occupancy without changing saves.
    hide func refreshProfileSlots() {
        profileFlow.refreshSlots(
            saveManager.getSlotSummary(0), saveManager.getSlotSummary(1),
            saveManager.getSlotSummary(2), saveManager.isSlotUsed(0),
            saveManager.isSlotUsed(1), saveManager.isSlotUsed(2));
        menus.setContinueAvailable(saveManager.getContinueSlot() >= 0);
    }

    /// @brief Load-game slot browser.
    hide func updateLoadGame() {
        renderObj.update(dt);
        var result = menus.updateLoadGame();
        menus.drawSaveSlotScreen(canvas, menus.getLoadSelection(),
                                 saveManager.getSlotSummary(0),
                                 saveManager.getSlotSummary(1),
                                 saveManager.getSlotSummary(2));
        renderObj.drawTransition(canvas);

        if result == STATE_MENU {
            sfx.playMenuBack();
            sm.Switch("menu");
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
        }
        if result == MENU_ACTION_LOAD_SLOT0 {
            tryLoadSlot(0);
        }
        if result == MENU_ACTION_LOAD_SLOT1 {
            tryLoadSlot(1);
        }
        if result == MENU_ACTION_LOAD_SLOT2 {
            tryLoadSlot(2);
        }
    }

    /// @brief Extras hub.
    hide func updateExtras() {
        renderObj.update(dt);
        var result = menus.updateExtras();
        menus.drawExtras(canvas,
                         achSys.getUnlockedCount(), ACH_COUNT,
                         loreSystem.getCollectedCount(), loreSystem.getTotalCount(),
                         loreSystem.getBestiaryCount(), loreSystem.getBestiaryTotal());
        renderObj.drawTransition(canvas);

        if result == MENU_ACTION_EXTRAS_ACHIEVEMENTS {
            sfx.playMenuSelect();
            sm.Switch("achievements");
        }
        if result == MENU_ACTION_EXTRAS_BESTIARY {
            sfx.playMenuSelect();
            sm.Switch("bestiary");
        }
        if result == MENU_ACTION_EXTRAS_LORE {
            sfx.playMenuSelect();
            sm.Switch("lorearchive");
        }
        if result == STATE_HIGHSCORES {
            sfx.playMenuSelect();
            sm.Switch("highscores");
        }
        if result == STATE_MENU {
            sfx.playMenuBack();
            sm.Switch("menu");
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
        }
    }

    /// @brief Credits screen.
    hide func updateCredits() {
        renderObj.update(dt);
        var result = menus.updateCredits();
        menus.drawCredits(canvas);
        renderObj.drawTransition(canvas);

        if result == STATE_MENU {
            sfx.playMenuBack();
            sm.Switch("menu");
            menus.resetSelection();
            menus.resetTitleAnim();
            renderObj.menuFadeIn(350);
        }
    }

    /// @brief Skippable opening crash-landing intro.
    hide func updateIntro() {
        openingIntroTimer = openingIntroTimer + dt;
        drawOpeningIntro();

        if Action.Pressed(ACT_CONFIRM) or Action.Pressed(ACT_BACK) {
            openingIntroTimer = 2600;
        }
        if openingIntroTimer >= 2500 {
            openingIntroTimer = 0;
            sm.Switch("playing");
            sfx.playGameMusic();
        }
    }

    /// @brief Render the opening story beat before gameplay.
    hide func drawOpeningIntro() {
        canvas.Box(0, 0, SCREEN_W, SCREEN_H, Color.RGB(3, 5, 14));

        var i = 0;
        while i < 90 {
            var sx = (i * 137 + openingIntroTimer / 12) % SCREEN_W;
            var sy = (i * 89 + 31) % SCREEN_H;
            canvas.Box(sx, sy, 2, 2, Color.RGB(140, 165, 210));
            i = i + 1;
        }

        var shipX = 240 + openingIntroTimer / 18;
        var shipY = 120 + openingIntroTimer / 26;
        canvas.Line(shipX - 120, shipY - 40, shipX + 60, shipY + 34,
                    Color.RGB(255, 120, 50));
        canvas.Line(shipX - 100, shipY - 20, shipX + 48, shipY + 44,
                    Color.RGB(255, 210, 80));
        canvas.Box(shipX, shipY, 160, 34, Color.RGB(90, 108, 132));
        canvas.Box(shipX + 26, shipY - 20, 82, 24, Color.RGB(114, 132, 156));
        canvas.Box(shipX + 34, shipY - 12, 24, 10, Color.RGB(40, 190, 230));
        canvas.Box(shipX + 70, shipY - 12, 24, 10, Color.RGB(40, 190, 230));

        canvas.BoxAlpha(140, 440, 1000, 150, Color.RGB(7, 10, 22), 210);
        canvas.Frame(140, 440, 1000, 150, Color.RGB(70, 95, 150));
        canvas.TextScaled(174, 466, "Emergency Log 001", 2, Color.RGB(220, 230, 255));
        canvas.Text(174, 506,
                    "Colony ship XENOSCAPE has entered uncontrolled descent. Unknown biosphere below. Architect core unresponsive.",
                    Color.RGB(160, 175, 205));
        canvas.Text(174, 536,
                    "Find shelter. Recover the relics. Reach the core before the planet is processed.",
                    Color.RGB(180, 200, 220));
        canvas.TextCenteredScaled(
            628,
            Action.BindingsStr(ACT_CONFIRM) + " / " +
            Action.BindingsStr(ACT_BACK) + " skip",
            Color.RGB(80, 90, 120), 1);
    }

    /// @brief Achievements browser entry from Extras.
    hide func updateAchievements() {
        if Action.Pressed(ACT_DOWN) {
            achBrowse = achBrowse + 1;
            if achBrowse >= ACH_COUNT { achBrowse = 0; }
            sfx.playMenuMove();
        }
        if Action.Pressed(ACT_UP) {
            achBrowse = achBrowse - 1;
            if achBrowse < 0 { achBrowse = ACH_COUNT - 1; }
            sfx.playMenuMove();
        }
        achSys.drawScreen(canvas, achBrowse);
        if Action.Pressed(ACT_BACK) or Action.Pressed(ACT_CONFIRM) {
            sfx.playMenuBack();
            sm.Switch("extras");
        }
    }

    /// @brief Bestiary browser entry from Extras.
    hide func updateBestiary() {
        var total = loreSystem.getBestiaryTotal();
        if Action.Pressed(ACT_DOWN) {
            bestiaryBrowse = bestiaryBrowse + 1;
            if bestiaryBrowse >= total { bestiaryBrowse = 0; }
            sfx.playMenuMove();
        }
        if Action.Pressed(ACT_UP) {
            bestiaryBrowse = bestiaryBrowse - 1;
            if bestiaryBrowse < 0 { bestiaryBrowse = total - 1; }
            sfx.playMenuMove();
        }
        loreSystem.drawBestiary(canvas, bestiaryBrowse);
        if Action.Pressed(ACT_BACK) or Action.Pressed(ACT_CONFIRM) {
            sfx.playMenuBack();
            sm.Switch("extras");
        }
    }

    /// @brief Lore archive entry from Extras.
    hide func updateLoreArchive() {
        var total = loreSystem.getTotalCount();
        if Action.Pressed(ACT_DOWN) {
            loreBrowse = loreBrowse + 1;
            if loreBrowse >= total { loreBrowse = 0; }
            sfx.playMenuMove();
        }
        if Action.Pressed(ACT_UP) {
            loreBrowse = loreBrowse - 1;
            if loreBrowse < 0 { loreBrowse = total - 1; }
            sfx.playMenuMove();
        }
        loreSystem.drawArchive(canvas, loreBrowse);
        if Action.Pressed(ACT_BACK) or Action.Pressed(ACT_CONFIRM) {
            sfx.playMenuBack();
            sm.Switch("extras");
        }
    }

    // =========================================================================
    // Game initialization helpers
    // =========================================================================

    /// @brief Reset all expedition state and load the configured opening area.
    ///
    /// Called only after the profile front end selects a destination slot and
    /// difficulty. Checkpoint, recovery marker, economy, world, lore, and combat
    /// state all return to deterministic clean-profile values.
    ///
    /// @param slot User-confirmed zero-based destination profile slot.
    /// @param profile User-selected `DIFFICULTY_*` profile id.
    /// @return Nothing. Builds the opening area and enters the intro scene.
    hide func startNewGame(slot: Integer, profile: Integer) {
        saveSlot = slot;
        if saveSlot < 0 or saveSlot >= MAX_SAVE_SLOTS { saveSlot = 0; }
        expeditionActive = true;
        expeditionMode = EXPEDITION_MODE_CAMPAIGN;
        pendingEntryFromRegion = -1;
        score = 0;
        coins = 0;
        currentLevel = tuning.getInt("game.startLevel", 1);
        if currentLevel < 1 { currentLevel = 1; }
        if currentLevel > LEVEL_COUNT { currentLevel = LEVEL_COUNT; }
        hubLaunchLevel = currentLevel;
        levelTimer = 0;
        levelDamageTaken = 0;
        reachedCheckpoint = false;
        checkpointLevel = 0;
        checkpointX = 0;
        checkpointY = 0;
        deathTimer = 0;
        bossesDefeated = 0;
        completionMask = 0;
        deathCount = 0;
        gems = 0;
        deathRecovery.reset(0);
        totalPlaytime = 0;
        upgrades.reset();
        difficulty.setProfile(profile);
        abilities.setMask(ABILITY_WALL_JUMP + ABILITY_DOUBLE_JUMP);
        syncPlayerAbilities();
        loreSystem.setCollectedMask(0);
        loreSystem.setBestiaryMask(0);
        tutorialSystem.reset();
        metaProgression.reset();
        worldState.reset();

        player.reset();
        loadLevel(currentLevel);

        openingIntroTimer = 0;
        sm.Switch("intro");
    }

    /// @brief Load the best available save slot for Continue.
    hide func loadMostAdvancedSlot() -> Boolean {
        var slot = saveManager.getContinueSlot();
        if slot < 0 { return false; }
        return loadFromSlot(slot);
    }

    /// @brief Try to load a specific slot from the Load Game
    ///        screen.  Empty slots stay on the browser.
    hide func tryLoadSlot(slot: Integer) {
        if loadFromSlot(slot) {
            sfx.playMenuSelect();
        } else {
            sfx.playMenuBack();
        }
    }

    /// @brief Restore campaign state from a save slot and
    ///        enter gameplay.
    hide func loadFromSlot(slot: Integer) -> Boolean {
        if saveManager.isSlotUsed(slot) == false { return false; }

        saveSlot = slot;
        expeditionActive = true;
        expeditionMode = EXPEDITION_MODE_CAMPAIGN;
        pendingEntryFromRegion = -1;
        currentLevel = saveManager.getSlotLevel(slot);
        if currentLevel < 1 { currentLevel = 1; }
        if currentLevel > LEVEL_COUNT { currentLevel = LEVEL_COUNT; }
        hubLaunchLevel = currentLevel;

        upgrades.setEncodedTiers(saveManager.getSlotUpgradeTiers(slot));
        difficulty.setProfile(saveManager.getSlotDifficulty(slot));
        abilities.setMask(saveManager.getSlotAbilities(slot));
        syncPlayerAbilities();
        player.reset();
        player.maxHp = saveManager.getSlotMaxHp(slot);
        player.hp = player.maxHp;
        gems = saveManager.getSlotGems(slot);
        deathRecovery.reset(gems);
        checkpointLevel = saveManager.getSlotCheckpointLevel(slot);
        checkpointX = saveManager.getSlotCheckpointX(slot);
        checkpointY = saveManager.getSlotCheckpointY(slot);
        totalPlaytime = saveManager.getSlotTime(slot) * 1000;
        bossesDefeated = saveManager.getSlotBosses(slot);
        completionMask = saveManager.getSlotCompletionMask(slot);
        deathCount = saveManager.getSlotDeaths(slot);
        loreSystem.setCollectedMask(saveManager.getSlotLoreMask(slot));
        loreSystem.setBestiaryMask(saveManager.getSlotBestiaryMask(slot));
        tutorialSystem.setMask(saveManager.getSlotTutorialMask(slot));
        metaProgression.restore(
            saveManager.getSlotBestTimes(slot),
            saveManager.getSlotPackedRanks(slot),
            saveManager.getSlotNewGamePlusActive(slot));
        worldState.reset();
        worldState.setMasks(saveManager.getSlotKeyMask(slot),
                            saveManager.getSlotSwitchMask(slot),
                            saveManager.getSlotDoorMask(slot),
                            saveManager.getSlotShrineMask(slot),
                            saveManager.getSlotTeleporterMask(slot));
        var region = 0;
        while region < LEVEL_COUNT {
            worldState.setRoomMask(
                region, saveManager.getSlotRoomMask(slot, region));
            region = region + 1;
        }

        score = 0;
        coins = 0;
        levelTimer = 0;
        levelDamageTaken = 0;
        reachedCheckpoint = false;
        deathTimer = 0;
        loadLevel(currentLevel);
        if checkpointLevel == currentLevel {
            reachedCheckpoint = true;
            player.spawn(checkpointX, checkpointY);
            camera.snapTo(player.centerX(), player.centerY());
        }
        sm.Switch("playing");
        sfx.playGameMusic();
        return true;
    }

    /// @brief Persist the active slot using the schema-v4 full snapshot.
    ///
    /// Core progression and every persistent interaction mask are staged in one
    /// SaveData batch. Callers use the result for user-facing save confirmation
    /// and the required storage-permission failure message.
    ///
    /// @return True when the active slot flush succeeds; false on storage error.
    hide func saveProgress() -> Boolean {
        if expeditionMode != EXPEDITION_MODE_CAMPAIGN { return true; }
        var saved = saveManager.saveSlotRelease(
            saveSlot, currentLevel, abilities.getMask(),
            player.maxHp, gems, totalPlaytime / 1000,
            bossesDefeated, loreSystem.getCollectedMask(),
            loreSystem.getBestiaryMask(), completionMask, deathCount,
            worldState.getKeyMask(), worldState.getSwitchMask(),
            worldState.getDoorMask(), worldState.getShrineMask(),
            worldState.getTeleporterMask(), worldState.getRoomMasks(),
            upgrades.getEncodedTiers(), difficulty.getProfile(),
            checkpointLevel, checkpointX, checkpointY,
            tutorialSystem.getMask(), metaProgression.getBestTimes(),
            metaProgression.getPackedRanks(),
            boolToSetting(metaProgression.isNewGamePlusActive()));
        if saved { deathRecovery.bank(gems); }
        return saved;
    }

    /// @brief Load level `num` — wipes pools, builds the
    ///        new tilemap + spawn lists, snaps the camera,
    ///        triggers the coordinated room-title toast.
    hide func loadLevel(num: Integer) {
        difficulty.applyPendingOnTransition();
        hitStopTimer = 0;
        currentLevel = num;
        enemiesKilled = 0;        // per-level kill tally resets each level (#7)
        achSys.onLevelReached(num);
        level.loadLevel(num);
        level.enrichEnemies(num); // Add new enemy types
        worldState.discoverTeleporter(num - 1);
        level.applyPersistentInteractionState(worldState.getSwitchMask(),
                                              worldState.getDoorMask(),
                                              worldState.getShrineMask());
        camera.setLevelSize(level.levelWidth, level.levelHeight);

        var spawnX = level.playerStartX;
        var spawnY = level.playerStartY;
        if pendingEntryFromRegion >= 0 {
            var entryEdge = worldGraph.findEdge(
                pendingEntryFromRegion, num - 1);
            var entryRecord = level.findInteractionRecord(
                INTERACTION_REGION_GATE, entryEdge);
            if entryRecord >= 0 {
                spawnX = level.interactionCols.get(entryRecord) * TILE_SIZE;
                spawnY = level.interactionRows.get(entryRecord) * TILE_SIZE;
            }
        }
        pendingEntryFromRegion = -1;
        player.spawn(spawnX, spawnY);
        currentRoomIndex = worldGraph.authoredRoomIndexForColumn(
            num - 1, player.pixelX() / TILE_SIZE, level.levelWidth);
        worldState.discoverRoom(num - 1, currentRoomIndex);
        roomTitleTimer = 1800;
        footstepTimer = 0;
        camera.snapTo(player.centerX(), player.centerY());

        enemies.reset();
        enemies.setDifficultyProfile(difficulty.getProfile());
        enemies.setNewGamePlusActive(metaProgression.isNewGamePlusActive());
        enemies.spawnFromLevel(level);

        pickups.reset();
        pickups.spawnFromLevel(level);

        bullets.reset();
        particles.reset();

        // Set biome-specific lighting
        if num == 2 { lighting.setDarkness(160); lighting.setDarkColor(Color.RGB(0, 10, 5)); }
        else if num == 3 { lighting.setDarkness(120); lighting.setDarkColor(Color.RGB(5, 5, 20)); }
        else if num == 5 { lighting.setDarkness(140); lighting.setDarkColor(Color.RGB(5, 15, 30)); }
        else if num == 6 { lighting.setDarkness(80); lighting.setDarkColor(Color.RGB(20, 5, 0)); }
        else if num == 8 { lighting.setDarkness(60); lighting.setDarkColor(Color.RGB(10, 15, 25)); }
        else if num == 9 { lighting.setDarkness(180); lighting.setDarkColor(Color.RGB(10, 0, 15)); }
        else if num == 10 { lighting.setDarkness(200); lighting.setDarkColor(Color.RGB(5, 0, 10)); }
        else { lighting.setDarkness(0); }

        levelTimer = 0;
        levelDamageTaken = 0;
        reachedCheckpoint = false;
        deathTimer = 0;
        bossCueTimer = 0;
        bossIntroPlayed = false;
        bossCameraLocked = false;
        camera.clearFocusWindow();
        // Room-title arbitration owns arrivals; the retired centered splash
        // used to stack over ARIA subtitles and contextual guidance.
        radioSystem.queueRegionArrival(num - 1);
        sfx.playRadioCue();
        sfx.setCombatIntensity(0);
        if tuning.getBool("presentation.adaptiveMusicEnabled", true) {
            sfx.playGameMusicForRegion(num);
        } else {
            sfx.playGameMusic();
        }
        sfx.playAmbienceForRegion(num);
        saveProgress();
    }

    // =========================================================================
    // New subsystem integration
    // =========================================================================

    /// @brief Init the "newer" subsystems added later in
    ///        development (achievements, lore, save-mgr,
    ///        worldmap, lighting, transitions, abilities).
    ///        Kept separate so feature additions are easy to
    ///        track.
    hide func initNewSystems() {
        abilities = new AbilityManager();
        abilities.initAbilities(pal);

        lighting = new LightingSystem();
        lighting.initLighting(pal);

        achSys = new AchievementSystem();
        achSys.initAchievements(pal);

        upgrades = new UpgradeSystem();
        difficulty = new DifficultySystem();
        deathRecovery = new DeathRecovery();
        profileFlow = new ProfileFlow();
        tutorialSystem = new TutorialSystem();
        metaProgression = new MetaProgression();
        radioSystem = new RadioSystem();
        uiCoordinator = new UiCoordinator();

        hub = new HubSystem();
        hub.initHub(pal);

        transitions = new TransitionManager();
        transitions.initTransitions(pal);

        textures = new TextureFactory();
        textures.initFactory(pal);

        loreSystem = new LoreSystem();
        loreSystem.initLore(pal);

        saveManager = new SaveManager();
        saveManager.initSave();

        worldState = new WorldState();

        worldGraph = new WorldGraph();

        worldMap = new WorldMap();
        worldMap.initMap(pal);

        gems = 0;
        bossesDefeated = 0;
        totalPlaytime = 0;
        saveSlot = 0;
        completionMask = 0;
        deathCount = 0;
        showWorldMap = false;
        showLore = false;
        poundImpactTimer = 0;
        killFlashX = 0;
        killFlashY = 0;
        killFlashTimer = 0;
        interactionMessage = "";
        interactionMessageTimer = 0;
        nearInteractionIndex = -1;
        routeSelection = 0;
        currentRoomIndex = 0;
        pendingEntryFromRegion = -1;
        roomTitleTimer = 0;
        if saveManager.didRecoverCorruptSave() {
            setInteractionMessage(
                "Save data was unreadable. A backup was preserved and defaults were restored.");
        }
    }

    /// @brief Copy the authoritative campaign ability mask into Player.
    ///
    /// `AbilityManager` owns unlock persistence while Player owns the hot input
    /// path. Synchronizing once before simulation prevents locked movement from
    /// leaking through reset, spawn, save load, or direct action bindings.
    ///
    /// @return Nothing. Player's local mask and current air-jump availability may
    ///         change according to `Player.setAbilityMask` rules.
    hide func syncPlayerAbilities() {
        player.setAbilityMask(abilities.getMask());
        player.setUpgradeTuning(upgrades.getChargeTimePercent(),
                                upgrades.getDashCooldownPercent());
    }

    /// @brief Update stable room identity from the player's regional column.
    ///
    /// Each procedural region is divided into eight deterministic authored room
    /// bands. Entering a band marks its bit in WorldState; the masks persist at
    /// the next autosave and drive map completion/readable location labels.
    ///
    /// @return Nothing. May update `currentRoomIndex` and one discovery bit.
    hide func updateRoomDiscovery() {
        if roomTitleTimer > 0 {
            roomTitleTimer = roomTitleTimer - dt;
            if roomTitleTimer < 0 { roomTitleTimer = 0; }
        }
        var previousRoom = currentRoomIndex;
        var nextRoom = worldGraph.authoredRoomIndexForColumn(
            currentLevel - 1, player.pixelX() / TILE_SIZE, level.levelWidth);
        currentRoomIndex = nextRoom;
        var newlyDiscovered = worldState.discoverRoom(
            currentLevel - 1, currentRoomIndex);
        if currentRoomIndex != previousRoom { roomTitleTimer = 1800; }
        if newlyDiscovered and
           (currentRoomIndex == 2 or currentRoomIndex == 6) {
            sfx.playSecretFound();
            setInteractionMessage(
                "SECRET ROUTE DISCOVERED // " +
                worldGraph.getRoomName(currentLevel - 1, currentRoomIndex));
        }
    }

    /// @brief Emit cadence-controlled footsteps using the authored floor tile.
    ///
    /// The cadence depends on current horizontal speed but never affects player
    /// movement. Leaving the floor or stopping resets the envelope so the first
    /// deliberate step responds immediately. SoundManager classifies material
    /// and safely no-ops when audio is unavailable.
    ///
    /// @return Nothing. May play one SFX and mutate only `footstepTimer`.
    hide func updateFootstepAudio() {
        var speed = player.vx;
        if speed < 0 { speed = 0 - speed; }
        if player.onGround == false or speed < 90 or
           player.state == PS_HURT or player.state == PS_DEAD {
            footstepTimer = 0;
            return;
        }
        footstepTimer = footstepTimer - dt;
        if footstepTimer > 0 { return; }

        var tileCol = player.centerX() / TILE_SIZE;
        var tileRow = (player.pixelY() + PLAYER_H + 2) / TILE_SIZE;
        sfx.playFootstep(level.getTile(tileCol, tileRow));
        footstepTimer = 245;
        if speed > PLAYER_SPEED * 3 / 4 { footstepTimer = 190; }
    }

    /// @brief Advance and resolve contextual per-profile tutorial guidance.
    ///
    /// Crash Site onboarding is staged by actual route position so prompts appear
    /// near the mechanic they explain. Acknowledgement requires the demonstrated
    /// semantic action, not elapsed time. Ability and death-recovery cards reuse
    /// the same persistent system throughout the campaign.
    ///
    /// @return Nothing. May request or acknowledge one tutorial bit.
    hide func updateContextualTutorials() {
        tutorialSystem.update(dt);
        var col = player.pixelX() / TILE_SIZE;

        if currentLevel == 1 {
            if tutorialSystem.isAcknowledged(TUTORIAL_MOVE) == false {
                tutorialSystem.request(TUTORIAL_MOVE);
                if Action.Held(ACT_LEFT) or Action.Held(ACT_RIGHT) {
                    tutorialSystem.acknowledge(TUTORIAL_MOVE);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_JUMP) == false and col >= 5 {
                tutorialSystem.request(TUTORIAL_JUMP);
                if player.didStartJump() {
                    tutorialSystem.acknowledge(TUTORIAL_JUMP);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_SHOOT) == false and col >= 10 {
                tutorialSystem.request(TUTORIAL_SHOOT);
                if Action.Pressed(ACT_SHOOT) {
                    tutorialSystem.acknowledge(TUTORIAL_SHOOT);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_WALL_JUMP) == false and
               col >= 14 {
                tutorialSystem.request(TUTORIAL_WALL_JUMP);
                if player.didStartJump() and player.wallDir != 0 {
                    tutorialSystem.acknowledge(TUTORIAL_WALL_JUMP);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_INTERACT) == false and
               col >= 24 {
                tutorialSystem.request(TUTORIAL_INTERACT);
                if Action.Pressed(ACT_INTERACT) {
                    tutorialSystem.acknowledge(TUTORIAL_INTERACT);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_CHECKPOINT) == false and
               col >= 38 {
                tutorialSystem.request(TUTORIAL_CHECKPOINT);
                if reachedCheckpoint {
                    tutorialSystem.acknowledge(TUTORIAL_CHECKPOINT);
                }
                return;
            }
            if tutorialSystem.isAcknowledged(TUTORIAL_MAP) == false and
               reachedCheckpoint {
                tutorialSystem.request(TUTORIAL_MAP);
                return;
            }
        }

        if abilities.has(ABILITY_CHARGE_SHOT) and
           tutorialSystem.isAcknowledged(TUTORIAL_CHARGE) == false {
            tutorialSystem.request(TUTORIAL_CHARGE);
            if player.isCharging {
                tutorialSystem.acknowledge(TUTORIAL_CHARGE);
            }
            return;
        }
        if abilities.has(ABILITY_DASH) and
           tutorialSystem.isAcknowledged(TUTORIAL_DASH) == false {
            tutorialSystem.request(TUTORIAL_DASH);
            if player.isDashing {
                tutorialSystem.acknowledge(TUTORIAL_DASH);
            }
            return;
        }
        if abilities.has(ABILITY_GROUND_POUND) and
           tutorialSystem.isAcknowledged(TUTORIAL_GROUND_POUND) == false {
            tutorialSystem.request(TUTORIAL_GROUND_POUND);
            if player.isPounding {
                tutorialSystem.acknowledge(TUTORIAL_GROUND_POUND);
            }
            return;
        }
        if abilities.has(ABILITY_GRAPPLE) and
           tutorialSystem.isAcknowledged(TUTORIAL_GRAPPLE) == false {
            tutorialSystem.request(TUTORIAL_GRAPPLE);
            if player.isGrappling {
                tutorialSystem.acknowledge(TUTORIAL_GRAPPLE);
            }
            return;
        }
        if deathRecovery.hasMarker() and
           tutorialSystem.isAcknowledged(TUTORIAL_DEATH_RECOVERY) == false {
            tutorialSystem.request(TUTORIAL_DEATH_RECOVERY);
        }
    }

    /// @brief Resolve one interact-button press against stable authored records.
    ///
    /// Interaction priority is lore, save station, shrine, switch, keyed door,
    /// regional gateway, then teleporter. Every path reads stable ids/payloads
    /// from Level rather than deriving content from coordinates. Persistent mutations immediately
    /// update the active level and save slot; lore, shrine acquisition, and fast
    /// travel return true so ordinary simulation remains frozen this frame.
    ///
    /// @return True when the interaction opened a modal overlay or transition;
    ///         false for no input, no nearby record, or a nonmodal interaction.
    hide func handleAuthoredInteraction() -> Boolean {
        if Action.Pressed(ACT_INTERACT) == false { return false; }

        var wx = player.centerX();
        var wy = player.centerY();
        var scanRange = upgrades.getScannerRange();
        var idx = level.findNearbyInteraction(
            INTERACTION_LORE_TERMINAL, wx, wy, scanRange);
        if idx >= 0 {
            var loreId = level.interactionPayloads.get(idx);
            loreSystem.showEntry(loreId);
            var loreCount = loreSystem.getCollectedCount();
            achSys.onLoreFound(loreCount);
            if loreCount >= loreSystem.getTotalCount() { achSys.onAllLore(); }
            sfx.playLoreFound();
            return true;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_SAVE_STATION, wx, wy, scanRange);
        if idx >= 0 {
            player.hp = player.maxHp;
            reachedCheckpoint = true;
            level.checkpointX = player.pixelX();
            level.checkpointY = player.pixelY();
            checkpointLevel = currentLevel;
            checkpointX = level.checkpointX;
            checkpointY = level.checkpointY;
            var requestedDifficulty = difficulty.getPendingProfile();
            if Action.Held(ACT_LEFT) { requestedDifficulty = requestedDifficulty - 1; }
            if Action.Held(ACT_RIGHT) { requestedDifficulty = requestedDifficulty + 1; }
            difficulty.requestAtSaveStation(requestedDifficulty);
            if saveProgress() {
                setInteractionMessage("Expedition saved. Suit integrity restored.");
                particles.burstCheckpoint(wx, wy);
                sfx.playSave();
            } else {
                setInteractionMessage(
                    "Progress could not be saved. Check storage permissions and try again.");
            }
            return false;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_ABILITY_SHRINE, wx, wy, scanRange);
        if idx >= 0 {
            var shrineId = level.interactionIds.get(idx);
            var ability = level.interactionPayloads.get(idx);
            if worldState.consumeShrine(shrineId) {
                abilities.grant(ability);
                player.startAcquisitionAnimation();
                syncPlayerAbilities();
                level.applyPersistentInteractionState(worldState.getSwitchMask(),
                                                      worldState.getDoorMask(),
                                                      worldState.getShrineMask());
                saveProgress();
                particles.burstAbilityAcquired(wx, wy);
                sfx.playAbilityGet();
                if abilities.getMask() == 63 { achSys.onAllAbilities(); }
                return true;
            }
            setInteractionMessage("This shrine has already transferred its module.");
            return false;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_SWITCH, wx, wy, scanRange);
        if idx >= 0 {
            var channel = level.interactionChannels.get(idx);
            var enabled = worldState.toggleSwitch(channel);
            level.applyPersistentInteractionState(worldState.getSwitchMask(),
                                                  worldState.getDoorMask(),
                                                  worldState.getShrineMask());
            saveProgress();
            if enabled {
                setInteractionMessage("Holographic shortcut online.");
            } else {
                setInteractionMessage("Holographic shortcut offline.");
            }
            particles.burstElectricSpark(wx, wy);
            sfx.playCheckpoint();
            return false;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_LOCKED_DOOR, wx, wy, scanRange);
        if idx >= 0 {
            var doorId = level.interactionIds.get(idx);
            var opened = worldState.tryOpenDoor(doorId);
            if opened == 0 {
                setInteractionMessage("A matching keycard is required.");
            } else {
                level.applyPersistentInteractionState(worldState.getSwitchMask(),
                                                      worldState.getDoorMask(),
                                                      worldState.getShrineMask());
                saveProgress();
                setInteractionMessage("Keycard accepted. Door permanently unlocked.");
                particles.burstElectricSpark(wx, wy);
                sfx.playCheckpoint();
            }
            return false;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_REGION_GATE, wx, wy, scanRange);
        if idx >= 0 {
            var edgeId = level.interactionIds.get(idx);
            var destinationRegion = level.interactionPayloads.get(idx);
            if worldGraph.canTraverse(
                currentLevel - 1, destinationRegion,
                abilities.getMask()) == false {
                var required = level.interactionChannels.get(idx);
                setInteractionMessage(
                    "ROUTE LOCKED // requires " + abilityName(required));
                return false;
            }
            var completedBit = bitForLevel(currentLevel);
            if completedBit <= 0 or
               (completionMask / completedBit) % 2 == 0 {
                setInteractionMessage(
                    "ROUTE UNSTABLE // complete this region's objective first.");
                return false;
            }
            if worldGraph.getOtherRegion(edgeId, currentLevel - 1) !=
               destinationRegion {
                setInteractionMessage("ROUTE ERROR // gateway link is invalid.");
                return false;
            }
            saveProgress();
            pendingEntryFromRegion = currentLevel - 1;
            transitions.startLevelExit(destinationRegion + 1);
            sfx.playCheckpoint();
            return true;
        }

        idx = level.findNearbyInteraction(
            INTERACTION_TELEPORTER, wx, wy, scanRange);
        if idx >= 0 {
            var padId = level.interactionIds.get(idx);
            worldState.discoverTeleporter(padId);
            if padId == 0 and majorBossCount() > 0 {
                saveProgress();
                hub.reset();
                hubLaunchLevel = currentLevel;
                hubRouteSelection = worldGraph.recommendedNeighborSelection(
                    currentLevel - 1, abilities.getMask(), completionMask);
                sm.Switch("hub");
                sfx.playHubMusic();
                return true;
            }
            var destination = worldState.findTeleporterDestination(padId);
            if destination < 0 {
                setInteractionMessage("Discover another transit pad to enable fast travel.");
                return false;
            }
            saveProgress();
            pendingEntryFromRegion = currentLevel - 1;
            transitions.startLevelExit(destination + 1);
            return true;
        }

        setInteractionMessage("No compatible system is within range.");
        return false;
    }

    /// @brief Display a nonblocking interaction result as a timed HUD toast.
    ///
    /// @param message Player-facing status or failure text.
    /// @return Nothing. Replaces any older toast and resets its 2.4-second timer.
    hide func setInteractionMessage(message: String) {
        interactionMessage = message;
        interactionMessageTimer = 2400;
    }

    /// @brief Update expansion systems that run before ordinary world simulation.
    ///
    /// Lore and transition overlays are modal: when either consumes the frame,
    /// this method updates only that modal state and asks `updatePlaying` to draw
    /// the frozen world without advancing player, enemies, projectiles, pickups,
    /// timers, or collision. Nonmodal ability and interaction work returns false.
    ///
    /// @return True when a modal system consumed the frame; false when ordinary
    ///         gameplay simulation should continue.
    hide func updateNewSystems() -> Boolean {
        abilities.updateUI(dt);
        lighting.update();
        achSys.update(dt);
        if tutorialSystem.getActiveTutorial() < 0 {
            radioSystem.update(dt);
        }
        sfx.setNarrativeFocus(radioSystem.isActive());
        if interactionMessageTimer > 0 {
            interactionMessageTimer = interactionMessageTimer - dt;
            if interactionMessageTimer < 0 { interactionMessageTimer = 0; }
        }

        // AbilityManager is the sole acquisition presenter. The duplicate
        // TransitionManager ability overlay is intentionally no longer used.
        if abilities.isAcquisitionActive() {
            if Action.Pressed(ACT_CONFIRM) or Action.Pressed(ACT_BACK) or
               Action.Pressed(ACT_INTERACT) {
                abilities.dismissAcquisition();
            }
            return true;
        }

        // Lore display (Typewriter-based text reveal)
        if loreSystem.isDisplayActive() {
            loreSystem.update(dt);
            if Action.Pressed(ACT_JUMP) or Action.Pressed(ACT_CONFIRM) or
               Action.Pressed(ACT_BACK) or Action.Pressed(ACT_INTERACT) {
                loreSystem.dismiss(); // First press skips text, second dismisses
            }
            return true;
        }

        // Transitions
        if transitions.isActive() {
            var trans = transitions.getTransition();
            var target = transitions.getTargetLevel();
            var done = transitions.update(dt);
            if done {
                if trans == TRANS_LEVEL_OUT {
                    loadLevel(target);
                }
            }
            return true;
        }

        // Frozen state suppresses all abilities
        if player.isFrozen() {
            // Player.update owns timer decrement and frozen physics so the
            // status advances exactly once per frame.
        } else {
            // Player ability updates (only when not frozen)
            if player.isDashing {
                player.updateDash(dt);
                particles.burstDashTrail(player.pixelX(), player.pixelY() + PLAYER_H / 2, player.facing);
            }
            if player.isCharging {
                player.updateCharge(dt);
            }
            if player.isPounding {
                player.updatePound(dt);
            }
        }
        wasPounding = player.isPounding;
        if poundImpactTimer > 0 {
            poundImpactTimer = poundImpactTimer - 1;
        }

        nearInteractionIndex = level.findNearestInteraction(
            player.centerX(), player.centerY(), upgrades.getScannerRange());
        if handleAuthoredInteraction() { return true; }

        // Environmental tile effects
        var hazard = phys.checkHazardTile(player.x, player.y,
                                           PLAYER_W, PLAYER_H, level);
        if hazard == TILE_POISON_POOL {
            // Poison damage over time (every 500ms)
            if levelTimer % 500 < dt {
                if player.iframes <= 0 {
                    if applyIncomingDamage(1) > 0 { player.iframes = 200; }
                }
            }
        }

        // Ability input handling
        if Action.Pressed(ACT_DASH) and abilities.has(ABILITY_DASH) {
            if player.startDash() {
                sfx.playDash();
                achSys.onDashUsed();
            }
        }
        if Action.Pressed(ACT_SHOOT) and abilities.has(ABILITY_CHARGE_SHOT) {
            if settings.getValue(SETTING_HOLD_TO_CHARGE) == 0 and
               player.isCharging {
                releaseChargedShot();
            } else {
                if player.startCharge() { sfx.playChargeStart(); }
            }
        }
        if settings.getValue(SETTING_HOLD_TO_CHARGE) == 1 and
           Action.Released(ACT_SHOOT) and player.isCharging {
            releaseChargedShot();
        }
        if Action.Pressed(ACT_MOVE_DOWN) and abilities.has(ABILITY_GROUND_POUND) {
            if not player.onGround {
                if player.startPound() { achSys.onPoundUsed(); }
            }
        }
        if Action.Pressed(ACT_GRAPPLE) {
            if player.isGrappling {
                if player.releaseGrapple() { sfx.playDash(); }
            } else if player.startGrapple(level) {
                particles.burstElectricSpark(player.getGrappleAnchorX(),
                                             player.getGrappleAnchorY());
                sfx.playDash();
            }
        }

        // Track playtime
        totalPlaytime = totalPlaytime + dt;

        // Boss defeat tracking
        if level.hasBoss and not enemies.isBossAlive() {
            // Boss just died
            var bossBit = 1;
            var b = 0;
            while b < currentLevel - 1 {
                bossBit = bossBit * 2;
                b = b + 1;
            }
            if (bossesDefeated / bossBit) % 2 == 0 {
                if bossCameraLocked {
                    camera.clearFocusWindow();
                    bossCameraLocked = false;
                }
                bossesDefeated = bossesDefeated + bossBit;
                achSys.onBossDefeated(level.bossType);
                loreSystem.unlockBestiaryEntry(level.bossType);
                var bossReward = regionAbilityReward(currentLevel - 1);
                if bossReward > 0 and abilities.has(bossReward) == false {
                    abilities.grant(bossReward);
                    player.startAcquisitionAnimation();
                    sfx.playAbilityGet();
                }
                syncPlayerAbilities();
                if abilities.getMask() == 63 { achSys.onAllAbilities(); }
                saveProgress();
            }
        }
        return false;
    }

    /// @brief Release the active charge and spawn its normal/charged projectile.
    ///
    /// A quick tap remains a normal shot. Partial/full tiers use the charge pool
    /// path and its exact damage/destructible-power contract. Failed full pools
    /// do not emit sound or achievement events.
    ///
    /// @return True when a projectile was spawned; false when not charging or
    ///         the corresponding projectile pool is full.
    hide func releaseChargedShot() -> Boolean {
        if player.isCharging == false { return false; }
        var chargeLevel = player.releaseCharge();
        var fired = false;
        var bx = player.pixelX() + PLAYER_W / 2;
        var by = player.pixelY() + PLAYER_H / 3;
        if chargeLevel <= 0 {
            fired = bullets.fire(bx, by, player.facing);
        } else {
            fired = bullets.fireCharged(bx, by, player.facing, chargeLevel);
        }
        if fired {
            player.startShootAnimation();
            sfx.playChargeRelease();
            achSys.onBulletFired();
        }
        return fired;
    }

    // Draw all expansion system overlays
    /// @brief Per-frame draws for the "newer" subsystems
    ///        (lighting overlay, transition fades, lore /
    ///        achievement popups).  Always last so they
    ///        composite over gameplay.
    hide func drawNewSystems(canvas: Canvas, camX: Integer, camY: Integer) {
        var tutorialVisible = tutorialSystem.getActiveTutorial() >= 0 and
            settings.getValue(SETTING_NAVIGATION_HINTS) != NAV_HINTS_OFF;
        var radioVisible = radioSystem.isActive() and
            settings.getValue(SETTING_SUBTITLES) == 1;
        uiCoordinator.resolve(
            showWorldMap, loreSystem.isDisplayActive(),
            abilities.isAcquisitionActive(), transitions.isActive(),
            bossCueTimer > 0, interactionMessageTimer > 0,
            roomTitleTimer > 0, achSys.hasNotification(),
            tutorialVisible, radioVisible);

        // Biome ambient particles
        renderObj.drawBiomeAmbient(canvas, camX, camY, currentLevel, levelTimer);

        // Dash trail
        renderObj.drawDashTrail(canvas, camX, camY, player);

        // Charge aura
        renderObj.drawChargeAura(canvas, camX, camY, player);

        // Ground pound impact
        renderObj.drawPoundImpact(canvas, player.pixelX(), player.pixelY(),
                                   camX, camY, poundImpactTimer);

        // Freeze overlay
        renderObj.drawFreezeOverlay(canvas, camX, camY, player);

        // Recoverable campaign salvage remains at the latest death site.
        drawDeathMarker(canvas, camX, camY);
        if uiCoordinator.hasModal() == false {
            drawInteractionPrompt(canvas, camX, camY);
        }

        // Environmental overlays
        var hazard = phys.checkHazardTile(player.x, player.y,
                                           PLAYER_W, PLAYER_H, level);
        renderObj.drawPoisonOverlay(canvas, hazard == TILE_POISON_POOL);
        renderObj.drawIceOverlay(canvas, phys.isOnIce(player.x, player.y,
                                                       PLAYER_W, PLAYER_H, level));

        // Lighting overlay (drawn after everything)
        lighting.draw(canvas, camX, camY,
                      player.pixelX() - camX + PLAYER_W / 2,
                      player.pixelY() - camY + PLAYER_H / 2);

        if uiCoordinator.hasModal() == false {
            var hudDetail = settings.getValue(SETTING_HUD_DETAIL);
            if hudDetail > 0 and uiCoordinator.showAchievement() == false {
                abilities.drawHUD(canvas);
                var biomeName = menus.getBiomeName(currentLevel);
                hudObj.drawExtendedHud(
                    canvas, pal, gems, loreSystem.getCollectedCount(),
                    loreSystem.getTotalCount(), currentLevel, biomeName);
                if enemies.isBossAlive() == false and
                   uiCoordinator.hasTop() == false {
                    drawObjectiveHud(canvas);
                }
            }
            if hudDetail >= 2 {
                var playerCol = player.pixelX() / TILE_SIZE;
                var playerRow = player.pixelY() / TILE_SIZE;
                hudObj.drawMiniMap(canvas, pal, playerCol, playerRow,
                                   level.levelWidth, level.levelHeight);
            }
            hudObj.drawPowerupTimers(
                canvas, pal, player.speedTimer, player.rapidFireTimer,
                player.shieldHits > 0);
        }

        if uiCoordinator.showRoom() { drawRoomTitleToast(canvas); }

        // Floating damage/score popups (#14) — world-space, over the scene.
        hudObj.drawPopups(canvas, camX, camY);

        // Boss direction remains visible; only its banner competes for top lane.
        drawBossCue(canvas, camX, camY, uiCoordinator.showBoss());

        // Nonblocking interaction success/failure feedback.
        if uiCoordinator.showMessage() {
            renderObj.drawNotificationAt(canvas, interactionMessage,
                                         interactionMessageTimer, 2400, 96);
        }

        // Transition overlay (on top of everything)
        if uiCoordinator.getModalOwner() == UI_MODAL_TRANSITION {
            transitions.draw(canvas,
                              player.pixelX() - camX + PLAYER_W / 2,
                              player.pixelY() - camY + PLAYER_H / 2);
        }

        // Ability acquisition UI
        if uiCoordinator.getModalOwner() == UI_MODAL_ABILITY {
            abilities.drawAcquisitionUI(canvas);
        }

        // Lore display (on top of everything)
        if uiCoordinator.getModalOwner() == UI_MODAL_LORE {
            loreSystem.draw(canvas);
        }

        // Achievement notification popup
        if uiCoordinator.showAchievement() { achSys.drawNotification(canvas); }

        // Contextual onboarding is persistent per profile and uses live bindings.
        if uiCoordinator.showTutorial() {
            tutorialSystem.draw(canvas, pal);
        }

        if uiCoordinator.showRadio() {
            radioSystem.draw(
                canvas, pal, true, settings.getValue(SETTING_UI_SCALE),
                settings.getValue(SETTING_LARGE_TEXT) == 1,
                settings.getValue(SETTING_HIGH_CONTRAST) == 1);
        }

        // World map (if open)
        if uiCoordinator.getModalOwner() == UI_MODAL_MAP {
            worldMap.draw(canvas, currentLevel, bossesDefeated,
                          worldState.getTeleporterMask(), abilities);
        }
    }

    /// @brief Draw one world-anchored semantic interaction prompt.
    hide func drawInteractionPrompt(canvas: Canvas,
                                    camX: Integer, camY: Integer) {
        if nearInteractionIndex < 0 or
           nearInteractionIndex >= level.interactionTypes.length() { return; }
        var kind = level.interactionTypes.get(nearInteractionIndex);
        var label = "INTERACT";
        if kind == INTERACTION_SAVE_STATION { label = "SAVE / RESTORE"; }
        if kind == INTERACTION_LORE_TERMINAL { label = "DECODE LOG"; }
        if kind == INTERACTION_ABILITY_SHRINE { label = "TRANSFER MODULE"; }
        if kind == INTERACTION_SWITCH { label = "TOGGLE LINK"; }
        if kind == INTERACTION_LOCKED_DOOR { label = "USE KEYCARD"; }
        if kind == INTERACTION_TELEPORTER { label = "FAST TRAVEL"; }
        if kind == INTERACTION_REGION_GATE {
            var destination = level.interactionPayloads.get(nearInteractionIndex);
            label = "ROUTE: " + worldGraph.getRegionName(destination);
        }

        var sx = level.interactionCols.get(nearInteractionIndex) * TILE_SIZE +
                 TILE_SIZE / 2 - camX;
        var sy = level.interactionRows.get(nearInteractionIndex) * TILE_SIZE -
                 camY;
        if sx < -160 or sx > SCREEN_W + 160 or sy < -80 or sy > SCREEN_H + 80 {
            return;
        }
        var prompt = Action.BindingsStr(ACT_INTERACT) + "  " + label;
        var width = 190;
        if kind == INTERACTION_REGION_GATE { width = 300; }
        var measuredWidth = Canvas.TextWidth(prompt) + 20;
        if measuredWidth > width { width = measuredWidth; }
        if width > 420 { width = 420; }
        canvas.DiscAlpha(sx, sy + TILE_SIZE / 2, 34,
                         Color.RGB(70, 205, 235), 45);
        canvas.Ring(sx, sy + TILE_SIZE / 2, 30,
                    Color.RGB(120, 225, 245));
        canvas.BoxAlpha(sx - width / 2, sy - 34, width, 26,
                        Color.RGB(2, 8, 16), 215);
        canvas.Frame(sx - width / 2, sy - 34, width, 26,
                     Color.RGB(70, 150, 185));
        canvas.Text(sx - width / 2 + 10, sy - 29, prompt,
                    Color.RGB(205, 240, 250));
    }

    /// @brief Draw the current region's recoverable salvage marker in world space.
    ///
    /// A pulsing diamond and ring remain legible against every biome without
    /// requiring authored art. Off-screen and cross-region markers cost no draw
    /// calls. The label exposes the exact recoverable amount before collection.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @param camX Camera world X in pixels.
    /// @param camY Camera world Y in pixels.
    /// @return Nothing. Draws only when a marker is active in the current region.
    hide func drawDeathMarker(canvas: Canvas, camX: Integer, camY: Integer) {
        if deathRecovery.hasMarker() == false or
           deathRecovery.getMarkerLevel() != currentLevel { return; }
        var sx = deathRecovery.getMarkerX() - camX;
        var sy = deathRecovery.getMarkerY() - camY;
        if sx < -48 or sx > SCREEN_W + 48 or
           sy < -48 or sy > SCREEN_H + 48 { return; }

        var phase = (levelTimer % 800) / 100;
        var radius = 18 + phase;
        canvas.DiscAlpha(sx, sy, radius, Color.RGB(40, 180, 255), 70);
        canvas.Ring(sx, sy, radius, Color.RGB(130, 230, 255));
        canvas.Triangle(sx, sy - 14, sx - 10, sy,
                        sx + 10, sy, Color.RGB(210, 250, 255));
        canvas.Triangle(sx, sy + 14, sx - 10, sy,
                        sx + 10, sy, Color.RGB(70, 170, 240));
        canvas.Text(sx - 22, sy + 24,
                    "+" + Int(deathRecovery.getMarkerGems()),
                    Color.RGB(190, 235, 255));
    }

    /// @brief Draw current primary and optional regional objective progress.
    ///
    /// Navigation Hints Off removes the gameplay overlay, Contextual shows the
    /// concise objective, and Always adds its authored instruction. Persistent
    /// completion, lore, and room masks remain the only progress authorities.
    ///
    /// @param canvas Borrowed frame canvas.
    /// @return Nothing. Draws a compact HUD panel according to accessibility.
    hide func drawObjectiveHud(canvas: Canvas) {
        var hintMode = settings.getValue(SETTING_NAVIGATION_HINTS);
        if hintMode == NAV_HINTS_OFF { return; }
        var region = currentLevel - 1;
        var completeText = "ACTIVE";
        var accent = Color.RGB(245, 205, 95);
        if regionObjectiveComplete(region, completionMask) {
            completeText = "COMPLETE";
            accent = Color.RGB(95, 225, 145);
        }
        var optional = regionOptionalProgress(
            region, loreSystem.getCollectedMask(),
            worldState.getRoomMask(region));
        var panelH = 45;
        if hintMode == NAV_HINTS_ALWAYS { panelH = 89; }
        var panelAlpha = 165;
        if settings.getValue(SETTING_HIGH_CONTRAST) == 1 {
            panelAlpha = 235;
        }
        canvas.BoxAlpha(18, 128, 700, panelH, Color.RGB(5, 10, 20),
                        panelAlpha);
        canvas.Frame(18, 128, 700, panelH, Color.RGB(48, 67, 94));
        canvas.Text(28, 136,
                    "OBJECTIVE: " + regionObjectiveTitle(region), accent);
        canvas.Text(520, 136,
                    completeText + "  DISC " + Int(optional) + "/" +
                    Int(REGION_OPTIONAL_TARGET), accent);
        if hintMode == NAV_HINTS_ALWAYS {
            canvas.Text(28, 158, regionObjectiveDescription(region),
                        Color.RGB(155, 175, 205));
            canvas.Text(28, 180,
                        "LANDMARK: " + regionLandmarkName(region) +
                        "  //  " + regionMechanicName(region),
                        Color.RGB(120, 205, 220));
        }
    }

    /// @brief Draw a short room-entry title without interrupting movement.
    ///
    /// @param canvas Borrowed release-resolution gameplay canvas.
    /// @return Nothing. Draws only while `roomTitleTimer` is positive; Reduced
    ///         Motion keeps the panel static while ordinary mode adds a tiny
    ///         bounded vertical settle.
    hide func drawRoomTitleToast(canvas: Canvas) {
        if roomTitleTimer <= 0 { return; }
        var y = 96;
        if settings.getValue(SETTING_REDUCED_MOTION) == 0 and
           roomTitleTimer > 1500 {
            y = y - (roomTitleTimer - 1500) / 30;
        }
        var alpha = 205;
        if roomTitleTimer < 300 { alpha = roomTitleTimer * 205 / 300; }
        canvas.BoxAlpha(430, y, 420, 54, Color.RGB(4, 9, 18), alpha);
        canvas.Frame(430, y, 420, 54, Color.RGB(55, 110, 145));
        canvas.TextCenteredScaled(
            y + 10,
            worldGraph.getRoomName(currentLevel - 1, currentRoomIndex),
            Color.RGB(205, 235, 245), 2);
    }
}
