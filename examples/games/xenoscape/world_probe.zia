//
// File: examples/games/xenoscape/world_probe.zia
// Purpose: Verifies Xenoscape regional topology, gates, routes, and room ids.
// Key invariants:
//   - Probe contains no display or persistent-storage dependency.
//   - Exact graph edges are tested in both traversal directions.
// Ownership/Lifetime:
//   - The probe owns one short-lived WorldGraph and exits after one result line.
// Links: world_graph.zia, worldmap.zia, objectives.zia, src/tests/CMakeLists.txt,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module world_probe;

bind Zanna.Terminal as Terminal;
bind "./abilities";
bind "./objectives";
bind "./world_graph";

/// @brief Emit one deterministic world-probe failure.
///
/// @param message Stable diagnostic suffix for CTest output.
/// @return Nothing. Prints no success marker, causing the regex gate to fail.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Verify exact graph dimensions, gates, reachability, and room ids.
///
/// @return Nothing. Prints `RESULT: ok` only after every assertion passes.
func main() {
    var graph = new WorldGraph();
    if graph.getRegionCount() != WORLD_REGION_COUNT or
       graph.getEdgeCount() != WORLD_EDGE_COUNT {
        fail("graph dimensions"); return;
    }
    if graph.canTraverse(0, 1, ABILITY_WALL_JUMP) == false or
       graph.canTraverse(1, 0, ABILITY_WALL_JUMP) == false {
        fail("bidirectional open edge"); return;
    }
    if graph.canTraverse(1, 2,
                         ABILITY_WALL_JUMP + ABILITY_DOUBLE_JUMP) or
       graph.canTraverse(1, 2, ABILITY_WALL_JUMP + ABILITY_DOUBLE_JUMP +
                               ABILITY_DASH) == false {
        fail("post-Spore dash gate"); return;
    }
    if graph.canTraverse(8, 9, 31) or graph.canTraverse(8, 9, 63) == false {
        fail("core grapple gate"); return;
    }
    if graph.findEdge(0, 9) >= 0 { fail("invented nonedge"); return; }

    var baseline = ABILITY_WALL_JUMP + ABILITY_DOUBLE_JUMP;
    var startReachable = graph.reachableMask(0, baseline);
    if startReachable != 123 {
        // Open baseline component: regions 0,1,3,4,5,6.
        fail("starting reachability"); return;
    }
    if graph.reachableMask(0, 63) != 1023 {
        fail("full campaign reachability"); return;
    }
    if graph.getAvailableNeighborCount(0, baseline) != 2 or
       graph.getAvailableNeighbor(0, 0, baseline) != 1 or
       graph.getAvailableNeighbor(0, 1, baseline) != 3 {
        fail("crash-site route choices"); return;
    }
    if graph.recommendedNeighborSelection(0, baseline, 3) != 1 {
        fail("uncompleted route recommendation"); return;
    }
    if graph.authoredRoomIndexForColumn(0, 0, 160) != 0 or
       graph.authoredRoomIndexForColumn(0, 159, 160) != 7 or
       graph.roomId(9, 7) != 79 or
       graph.getRoomName(0, 0) == "Unknown Room" or
       graph.getEdgeRoom(0, 0) != 7 or graph.getEdgeRoom(0, 1) != 0 {
        fail("stable room namespace"); return;
    }
    if regionObjectiveTitle(9) != "Defeat the Architect" or
       regionObjectiveComplete(1, 2) == false or
       regionObjectiveComplete(2, 2) or
       regionLoreDiscoveryCount(6, 393216) != 2 or
       regionSecretDiscoveryCount(68) != 2 or
       regionOptionalProgress(6, 393216, 68) != REGION_OPTIONAL_TARGET {
        fail("regional objective progress"); return;
    }
    Terminal.Say("RESULT: ok");
}
