//
// File: examples/games/xenoscape/ui_flow_probe.zia
// Purpose: Verifies overlay arbitration and bounded tutorial/ability lifetimes.
// Key invariants:
//   - Modal presentation suppresses every top and bottom overlay lane.
//   - Automatic cards expire, can be dismissed, and remain explicitly replayable.
// Ownership/Lifetime:
//   - Probe owns one coordinator, palette, tutorial system, and ability manager.
// Links: ui_coordinator.zia, tutorials.zia, abilities.zia, docs/internals/testing.md
//
//===----------------------------------------------------------------------===//

module ui_flow_probe;

bind Zanna.Terminal as Terminal;
bind "./abilities";
bind "./config";
bind "./palette";
bind "./tutorials";
bind "./ui_coordinator";

/// @brief Emit one deterministic UI-flow failure.
/// @param message Stable violated invariant.
/// @return Nothing. Omits the success marker.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Exercise modal priority, lane priority, expiry, dismissal, and replay.
///
/// @return Nothing. Prints `RESULT: ok` only after every bounded-flow assertion.
func main() {
    var coordinator = new UiCoordinator();
    coordinator.resolve(true, true, true, true, true, true, true, true,
                        true, true);
    if coordinator.getModalOwner() != UI_MODAL_MAP or
       coordinator.hasTop() or
       coordinator.showBoss() or coordinator.showTutorial() or
       coordinator.showRadio() {
        fail("modal arbitration"); return;
    }

    coordinator.resolve(false, false, false, false,
                        true, true, true, true, true, true);
    if coordinator.showBoss() == false or
       coordinator.hasTop() == false or
       coordinator.showMessage() or coordinator.showRoom() or
       coordinator.showTutorial() == false or coordinator.showRadio() {
        fail("nonmodal lane priority"); return;
    }
    coordinator.resolve(false, false, false, false,
                        false, false, true, true, false, true);
    if coordinator.showRoom() == false or
       coordinator.showAchievement() or coordinator.showRadio() == false {
        fail("fallback lane ownership"); return;
    }

    var tutorials = new TutorialSystem();
    if tutorials.request(TUTORIAL_MOVE) == false or
       tutorials.request(TUTORIAL_JUMP) {
        fail("single tutorial ownership"); return;
    }
    var elapsed = 0;
    while elapsed < TUTORIAL_VISIBLE_MS {
        tutorials.update(DT_MAX);
        elapsed = elapsed + DT_MAX;
    }
    if tutorials.getActiveTutorial() != -1 or
       tutorials.request(TUTORIAL_MOVE) {
        fail("tutorial expiry and cooldown"); return;
    }
    if tutorials.replay(TUTORIAL_MOVE) == false or
       tutorials.getActiveTutorial() != TUTORIAL_MOVE {
        fail("tutorial replay"); return;
    }
    tutorials.dismiss();
    if tutorials.getActiveTutorial() != -1 or
       tutorials.acknowledge(TUTORIAL_MOVE) == false or
       tutorials.isAcknowledged(TUTORIAL_MOVE) == false or
       tutorials.replay(TUTORIAL_MOVE) == false {
        fail("tutorial dismiss or acknowledgement"); return;
    }

    var pal = new Palette();
    var abilities = new AbilityManager();
    abilities.initAbilities(pal);
    if abilities.getMask() != ABILITY_WALL_JUMP + ABILITY_DOUBLE_JUMP {
        fail("baseline movement modules"); return;
    }
    abilities.grant(ABILITY_DASH);
    if abilities.isAcquisitionActive() == false { fail("ability card open"); return; }
    elapsed = 0;
    while elapsed < 1800 {
        abilities.updateUI(DT_MAX);
        elapsed = elapsed + DT_MAX;
    }
    if abilities.isAcquisitionActive() { fail("ability card expiry"); return; }
    abilities.grant(ABILITY_CHARGE_SHOT);
    abilities.dismissAcquisition();
    if abilities.isAcquisitionActive() { fail("ability card dismissal"); return; }

    Terminal.Say("RESULT: ok");
}
