    // =========================================================================
    // Music playback — procedurally generated background tracks
    // =========================================================================

    //=========================================================
    // MUSIC
    //=========================================================

    /// @brief Begin the title-screen track.  Cross-fades from
    ///        whatever music was playing.  Tracks `currentTrack`
    ///        so a redundant call is a no-op.
    expose func playMenuMusic() {
        if ready == false { return; }
        stopAmbience();
        if currentTrack == 0 { return; }
        stopMusic();
        if bank.Has("music_menu") {
            var snd = bank.Get("music_menu");
            musicVoice = snd.PlayLoop(45, 2);
            currentTrack = 0;
        }
    }

    /// @brief Begin the in-level track.  Same cross-fade
    ///        rules as `playMenuMusic`.
    expose func playGameMusic() {
        if ready == false { return; }
        if currentTrack >= 1 and currentTrack <= 10 { return; }
        playGameMusicForRegion(1);
    }

    /// @brief Begin a distinct regional exploration identity.
    ///
    /// @param region One-based campaign region in 1..10; invalid values clamp.
    /// @return Nothing. Redundant requests preserve the current playback position.
    expose func playGameMusicForRegion(region: Integer) {
        var bounded = region;
        if bounded < 1 { bounded = 1; }
        if bounded > 10 { bounded = 10; }
        playIdentity(bounded, bounded, 40);
    }

    /// @brief Begin the independently mixed environmental bed for one region.
    ///
    /// @param region One-based campaign region in 1..10; invalid values clamp.
    /// @return Nothing. Redundant requests preserve playback position.
    expose func playAmbienceForRegion(region: Integer) {
        if ready == false { return; }
        var bounded = region;
        if bounded < 1 { bounded = 1; }
        if bounded > 10 { bounded = 10; }
        if currentAmbience == bounded { return; }
        stopAmbience();
        var key = "ambience_identity_" + Int(bounded);
        if bank.Has(key) {
            var snd = bank.Get(key);
            ambienceVoice = snd.PlayLoop(32, 3);
            currentAmbience = bounded;
        }
    }

    /// @brief Stop the environmental ambience voice without affecting music.
    ///
    /// @return Nothing. Safe when no ambience voice is active.
    expose func stopAmbience() {
        if ambienceVoice >= 0 { Voice.Stop(ambienceVoice); }
        ambienceVoice = -1;
        currentAmbience = -1;
    }

    /// @brief Begin the dedicated evolving-shipwreck hub identity.
    ///
    /// @return Nothing. Redundant requests preserve playback position.
    expose func playHubMusic() {
        stopAmbience();
        playIdentity(11, 20, 38);
    }

    /// @brief Begin the dedicated high-intensity boss identity.
    ///
    /// @return Nothing. Redundant requests preserve playback position.
    expose func playBossMusic() { playIdentity(12, 21, 46); }

    /// @brief Begin the dedicated campaign-victory identity.
    ///
    /// @return Nothing. Redundant requests preserve playback position.
    expose func playVictoryMusic() { playIdentity(13, 22, 44); }

    /// @brief Begin the dedicated game-over identity.
    ///
    /// @return Nothing. Redundant requests preserve playback position.
    expose func playGameOverMusic() { playIdentity(14, 23, 38); }

    /// @brief Switch to one generated music identity through mixer group two.
    ///
    /// @param identity Generated identity key in 1..14.
    /// @param trackId Internal playback id distinct from identity namespace.
    /// @param volume Authored loop voice volume in 0..100.
    /// @return Nothing. Missing synthesis output falls back to `music_game`.
    hide func playIdentity(identity: Integer, trackId: Integer,
                           volume: Integer) {
        if ready == false or currentTrack == trackId { return; }
        stopMusic();
        var key = "music_identity_" + Int(identity);
        if bank.Has(key) {
            var snd = bank.Get(key);
            musicVoice = snd.PlayLoop(volume, 2);
            currentTrack = trackId;
            return;
        }
        if bank.Has("music_game") {
            var fallback = bank.Get("music_game");
            musicVoice = fallback.PlayLoop(volume, 2);
            currentTrack = trackId;
        }
    }

    /// @brief Stop the music voice.  Used during cutscene
    ///        beats and the boss-intro silence.
    expose func stopMusic() {
        if musicVoice >= 0 {
            Voice.Stop(musicVoice);
            musicVoice = -1;
            currentTrack = -1;
        }
    }
}
