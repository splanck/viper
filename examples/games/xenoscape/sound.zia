    /// @brief Play one cadence-controlled step for the sampled floor material.
    ///
    /// @param tile Stable authored tile id under the player's center foot probe.
    /// @return Nothing. Selects exactly one retained sound and uses SFX volume.
    expose func playFootstep(tile: Integer) {
        if ready == false { return; }
        var family = footstepIdentityForTile(tile);
        var name = "footstep_heavy";
        if family == FOOTSTEP_SOFT { name = "footstep_soft"; }
        if family == FOOTSTEP_METAL { name = "footstep_metal"; }
        if family == FOOTSTEP_CRYSTAL { name = "footstep_crystal"; }
        bank.PlayEx(name, scaledSfx(34), 0);
    }

    /// @brief Play the short ARIA channel-open cue at independent voice volume.
    ///
    /// @return Nothing. Missing audio hardware remains a silent safe no-op.
    expose func playRadioCue() {
        if ready == false { return; }
        bank.PlayEx("radio_chirp", 65 * voiceVolume / 100, 0);
    }

