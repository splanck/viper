//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/sound.zia
// Purpose: Coordinates Xenoscape music, semantic SFX, and procedural fallbacks.
// Key invariants:
//   - Missing audio devices/assets never prevent gameplay.
//   - Master, music, SFX, ambience, and voice values remain independently bounded.
// Ownership/Lifetime:
//   - Game owns one SoundManager and explicitly shuts it down at exit.
// Links: game.zia, settings.zia, sounds/README.md,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — AUDIO IS OPTIONAL BUT IT'S CHEAP TO DO WELL
// ------------------------------------------------------
// Sound is often the last thing added to a game prototype and
// the first thing that suffers from ad-hoc code.  "SoundFX.Play(
// sound_jump_wav)" sprinkled through every file; volume
// handling done differently per sound; no cross-fade between
// tracks; no graceful degradation when a platform has no
// audio.  Don't.
//
// A single `SoundManager` object — one instance living on
// `Game` — is all it takes to keep things tidy.  Every other
// file calls `sound.jump()`, `sound.hit()`, `sound.pickup()`,
// and never touches a raw audio API.
//
// This file demonstrates three useful Viper audio patterns:
//
//   1. **Named sound bank** (`Viper.Sound.SoundBank`) — you
//      register sounds under symbolic names ("jump", "hit"),
//      then play them by name.  Renaming a WAV file doesn't
//      ripple through the codebase.
//
//   2. **Procedural fallback** (`Viper.Sound.Synth`) — if the
//      WAV files are absent (say a freshly-checked-out demo
//      with no assets), the synth generates passable tones
//      programmatically.  The game *still ships* and has
//      recognisable feedback.  Great for CI / test probes.
//
//   3. **Graceful init failure** — `Audio.Init()` can fail on
//      headless or audio-disabled platforms.  We flip a
//      `ready` flag and let every `play*()` method early-out
//      silently.  The rest of the game doesn't need to know.
//
// WHERE THIS FITS
// ---------------
//     game.zia   ──►  constructs and `setup(basePath)`s the
//                     SoundManager at boot.
//     player.zia ──►  sound.jump() / land() / hurt().
//     enemy.zia  ──►  sound.enemy_hit() / explode().
//     pickups.zia ──► sound.coin() / health().
//     level.zia   ──► sound.play_music(biome).
//     menu.zia    ──► sound.click() / confirm().
//
// HOW TO READ THIS FILE
// ---------------------
//   1. `init` / `setup` — lifecycle + WAV registration.
//   2. `play*` families — one method per semantic sound.
//      Each guards on `ready` and forwards to the bank.
//   3. Music control — `playMusic(index)` / `stopMusic()`
//      with cross-fade.
//
// =============================================================================

module sound;

bind Viper.Sound;
bind Viper.Text.Fmt;
bind "./config";

final FOOTSTEP_SOFT = 0;
final FOOTSTEP_METAL = 1;
final FOOTSTEP_CRYSTAL = 2;
final FOOTSTEP_HEAVY = 3;

/// @brief Classify one authored floor tile into a stable footstep family.
///
/// The classifier is intentionally pure so movement cadence remains owned by
/// Game while SoundManager owns only timbre and mixer routing. Unknown tiles
/// use the heavy/stone family, which stays audible without implying a special
/// material that the level did not author.
///
/// @param tile Stable `TILE_*` identity sampled under the player's feet.
/// @return One `FOOTSTEP_*` family in the inclusive range 0..3.
func footstepIdentityForTile(tile: Integer) -> Integer {
    if tile == TILE_GRASS_TOP or tile == TILE_DIRT or
       tile == TILE_JUNGLE_GROUND or tile == TILE_JUNGLE_PLATFORM or
       tile == TILE_MUSHROOM or tile == TILE_QUICKSAND or
       tile == TILE_VINE or tile == TILE_MOSS_STONE {
        return FOOTSTEP_SOFT;
    }
    if (tile >= TILE_HULL_PLATE and tile <= TILE_VIEWPORT) or
       tile == TILE_CONVEYOR_L or tile == TILE_CONVEYOR_R or
       tile == TILE_STEAM_VENT {
        return FOOTSTEP_METAL;
    }
    if tile == TILE_CRYSTAL or tile == TILE_CAVE_CRYSTAL or
       tile == TILE_ICE_FLOOR {
        return FOOTSTEP_CRYSTAL;
    }
    return FOOTSTEP_HEAVY;
}

/// @brief Game-wide audio coordinator.  Wraps a SoundBank,
///        falls back to procedural Synth when WAV files
///        aren't available, and tracks the current music
///        voice for cross-fades.
///
/// Every gameplay file calls one of the `play*` methods
/// instead of touching the audio API directly.
class SoundManager {
    hide Boolean ready;
    hide SoundBank bank;
    hide Integer musicVoice;
    hide Integer ambienceVoice;
    hide Integer currentTrack;
    hide Integer currentAmbience;
    hide Integer masterVolume;
    hide Integer musicVolume;
    hide Integer sfxVolume;
    hide Integer ambienceVolume;
    hide Integer voiceVolume;
    hide Integer combatIntensity;

    /// @brief Construct in "not-ready" state.  Real init is
    ///        `setup(basePath)`; until then every `play*`
    ///        no-ops.
    expose func init() {
        ready = false;
        musicVoice = -1;
        ambienceVoice = -1;
        currentTrack = -1;
        currentAmbience = -1;
        masterVolume = 80;
        musicVolume = 55;
        sfxVolume = 85;
        ambienceVolume = 70;
        voiceVolume = 85;
        combatIntensity = 0;
    }

    // Initialize audio system and register all sounds.
    // Attempts to load WAV files from basePath; if unavailable, generates
    // procedural sounds via Synth as a zero-dependency fallback.
    /// @brief Initialise audio, register every named sound.
    ///
    /// For each sound: try to load `<basePath>/<name>.wav`;
    /// on failure, generate a procedural fallback via
    /// `Synth.*`.  Either way the bank gains the named sound
    /// and `play*` methods will work.
    ///
    /// `Audio.Init()` returning 0 (no audio hardware /
    /// permission denied) leaves `ready = false` and every
    /// `play*` becomes a silent no-op.  This is what lets the
    /// game ship to headless CI without a separate "no audio"
    /// build.
    expose func setup(basePath: String) {
        var ok = Audio.Init();
        if ok == 0 { return; }

        applyVolumeSettings();
        bank = SoundBank.New();

        // Try WAV files first — they sound better but require assets.
        // RegisterSound with Synth output serves as fallback when WAVs are
        // missing (e.g., running from a clean checkout without the sounds/ dir).
        bank.Register("jump", basePath + "sounds/jump.wav");
        bank.Register("shoot", basePath + "sounds/shoot.wav");
        bank.Register("coin", basePath + "sounds/coin.wav");
        bank.Register("hurt", basePath + "sounds/hurt.wav");
        bank.Register("enemy_death", basePath + "sounds/enemy_death.wav");
        bank.Register("powerup", basePath + "sounds/powerup.wav");
        bank.Register("checkpoint", basePath + "sounds/checkpoint.wav");
        bank.Register("level_complete", basePath + "sounds/level_complete.wav");
        bank.Register("menu_select", basePath + "sounds/menu_select.wav");
        bank.Register("menu_move", basePath + "sounds/menu_move.wav");
        bank.Register("menu_back", basePath + "sounds/menu_back.wav");
        bank.Register("death", basePath + "sounds/death.wav");
        bank.Register("stomp", basePath + "sounds/stomp.wav");
        bank.Register("radio_chirp", basePath + "sounds/radio_chirp.wav");

        // Synth fallback: if a WAV wasn't found, SoundBank.Has() returns false.
        // Register procedural replacements for any missing sounds.
        if bank.Has("jump") == false {
            bank.RegisterSound("jump", Synth.Sfx(SFX_JUMP));
        }
        if bank.Has("shoot") == false {
            bank.RegisterSound("shoot", Synth.Sfx(SFX_LASER));
        }
        if bank.Has("coin") == false {
            bank.RegisterSound("coin", Synth.Sfx(SFX_COIN));
        }
        if bank.Has("hurt") == false {
            bank.RegisterSound("hurt", Synth.Sfx(SFX_HIT));
        }
        if bank.Has("enemy_death") == false {
            bank.RegisterSound("enemy_death", Synth.Sfx(SFX_EXPLODE));
        }
        if bank.Has("powerup") == false {
            bank.RegisterSound("powerup", Synth.Sfx(SFX_POWERUP));
        }
        if bank.Has("checkpoint") == false {
            bank.RegisterSound("checkpoint", Synth.Sfx(SFX_POWERUP));
        }
        if bank.Has("level_complete") == false {
            bank.RegisterSound("level_complete", Synth.Tone(880, 200, 1));
        }
        if bank.Has("menu_select") == false {
            bank.RegisterSound("menu_select", Synth.Tone(660, 80, 1));
        }
        if bank.Has("menu_move") == false {
            bank.RegisterSound("menu_move", Synth.Tone(440, 50, 1));
        }
        // No menu_back.wav ships yet; a low descending tone reads as "back".
        if bank.Has("menu_back") == false {
            bank.RegisterSound("menu_back", Synth.Tone(330, 70, 1));
        }
        if bank.Has("death") == false {
            bank.RegisterSound("death", Synth.Sfx(SFX_EXPLODE));
        }
        if bank.Has("stomp") == false {
            bank.RegisterSound("stomp", Synth.Sfx(SFX_HIT));
        }
        if bank.Has("radio_chirp") == false {
            bank.RegisterSound("radio_chirp", Synth.Tone(760, 90, 1));
        }

        // First-party procedural effects for release mechanics. Registering
        // retained Sound objects is essential: constructing Synth output alone
        // does not enqueue playback.
        bank.RegisterSound("dash", Synth.Sweep(170, 760, 115, 2));
        bank.RegisterSound("charge_start", Synth.Sweep(210, 520, 130, 1));
        bank.RegisterSound("charge_release", Synth.Sweep(1180, 190, 170, 2));
        bank.RegisterSound("ground_pound", Synth.Sweep(180, 55, 210, 2));
        bank.RegisterSound("freeze", Synth.Sweep(1500, 720, 145, 3));
        bank.RegisterSound("boss_phase", Synth.Sweep(95, 310, 360, 2));
        bank.RegisterSound("enemy_tell", Synth.Sweep(430, 760, 85, 3));
        bank.RegisterSound("ability_get", Synth.Sweep(420, 1180, 330, 1));
        bank.RegisterSound("save", Synth.Sweep(500, 940, 180, 1));
        bank.RegisterSound("lore_found", Synth.Sweep(310, 680, 180, 1));
        bank.RegisterSound("secret_found", Synth.Sweep(760, 1520, 240, 3));
        bank.RegisterSound("boss_intro", Synth.Sweep(70, 260, 440, 2));
        bank.RegisterSound("victory", Synth.Sweep(520, 1320, 520, 1));
        bank.RegisterSound("explosion", Synth.Sfx(SFX_EXPLODE));
        bank.RegisterSound("crystal_break", Synth.Sweep(2100, 620, 150, 3));
        bank.RegisterSound("footstep_soft", Synth.Tone(165, 34, 0));
        bank.RegisterSound("footstep_metal", Synth.Tone(330, 32, 2));
        bank.RegisterSound("footstep_crystal", Synth.Tone(980, 30, 3));
        bank.RegisterSound("footstep_heavy", Synth.Tone(105, 42, 2));

        // =====================================================================
        // Procedural music via MusicGen — zero external assets needed
        // =====================================================================

        // Menu theme: dreamy, atmospheric (sine pad + triangle arpeggio)
        var menuSong = MusicGen.New(90);
        var menuPad = menuSong.AddChannel(0);     // sine pad
        var menuArp = menuSong.AddChannel(3);     // triangle arpeggio
        var menuBass = menuSong.AddChannel(2);    // saw bass

        menuSong.SetEnvelope(menuPad, 300, 200, 60, 400);
        menuSong.SetPan(menuPad, -20);
        menuSong.SetDetune(menuPad, 6);
        menuSong.SetEnvelope(menuArp, 5, 60, 40, 80);
        menuSong.SetArpeggio(menuArp, 4, 7, 1200);
        menuSong.SetPan(menuArp, 30);
        menuSong.SetEnvelope(menuBass, 10, 80, 70, 100);

        // Cm chord progression: Cm - Ab - Eb - Bb (8 bars, 32 beats)
        // Pad: whole notes per chord
        menuSong.AddNote(menuPad, 0, 60, 800);       // C4, 8 beats
        menuSong.AddNote(menuPad, 800, 56, 800);     // Ab3
        menuSong.AddNote(menuPad, 1600, 63, 800);    // Eb4
        menuSong.AddNote(menuPad, 2400, 58, 800);    // Bb3
        // Arpeggio: eighth notes cycling chord tones
        var pos = 0;
        // Cm: C4 E4 G4
        while pos < 800 { menuSong.AddNote(menuArp, pos, 72, 50); pos = pos + 50; }
        // Ab: Ab3 C4 Eb4
        while pos < 1600 { menuSong.AddNote(menuArp, pos, 68, 50); pos = pos + 50; }
        // Eb: Eb4 G4 Bb4
        while pos < 2400 { menuSong.AddNote(menuArp, pos, 75, 50); pos = pos + 50; }
        // Bb: Bb3 D4 F4
        while pos < 3200 { menuSong.AddNote(menuArp, pos, 70, 50); pos = pos + 50; }
        // Bass: root notes, half notes
        menuSong.AddNote(menuBass, 0, 36, 400);      // C2
        menuSong.AddNote(menuBass, 400, 36, 400);
        menuSong.AddNote(menuBass, 800, 44, 400);    // Ab2
        menuSong.AddNote(menuBass, 1200, 44, 400);
        menuSong.AddNote(menuBass, 1600, 39, 400);   // Eb2
        menuSong.AddNote(menuBass, 2000, 39, 400);
        menuSong.AddNote(menuBass, 2400, 46, 400);   // Bb2
        menuSong.AddNote(menuBass, 2800, 46, 400);

        menuSong.Length = 3200;
        menuSong.SetLoopable(true);
        var menuSound = menuSong.Build();
        if menuSound != null {
            bank.RegisterSound("music_menu", menuSound);
        }

        // Gameplay theme: upbeat chiptune (square lead + saw bass + noise drums)
        var gameSong = MusicGen.New(140);
        var lead = gameSong.AddChannel(1);     // square lead
        var gbass = gameSong.AddChannel(2);    // saw bass
        var drums = gameSong.AddChannel(4);    // noise drums

        gameSong.SetEnvelope(lead, 10, 60, 50, 80);
        gameSong.SetDuty(lead, 25);
        gameSong.SetVibrato(lead, 12, 500);
        gameSong.SetPan(lead, -15);
        gameSong.SetEnvelope(gbass, 5, 40, 80, 50);
        gameSong.SetEnvelope(drums, 1, 20, 0, 30);

        // Lead melody — 4 bars of catchy chiptune in C major
        // Bar 1: C E G E
        gameSong.AddNote(lead, 0, 72, 100);       // C5
        gameSong.AddNote(lead, 100, 76, 100);     // E5
        gameSong.AddNote(lead, 200, 79, 100);     // G5
        gameSong.AddNote(lead, 300, 76, 100);     // E5
        // Bar 2: A G F E
        gameSong.AddNote(lead, 400, 81, 100);     // A5
        gameSong.AddNote(lead, 500, 79, 100);     // G5
        gameSong.AddNote(lead, 600, 77, 100);     // F5
        gameSong.AddNote(lead, 700, 76, 100);     // E5
        // Bar 3: D F A F
        gameSong.AddNote(lead, 800, 74, 100);     // D5
        gameSong.AddNote(lead, 900, 77, 100);     // F5
        gameSong.AddNote(lead, 1000, 81, 100);    // A5
        gameSong.AddNote(lead, 1100, 77, 100);    // F5
        // Bar 4: G high, rest, G resolve to C
        gameSong.AddNote(lead, 1200, 84, 100);    // C6
        gameSong.AddNote(lead, 1300, 83, 100);    // B5
        gameSong.AddNote(lead, 1400, 81, 100);    // A5
        gameSong.AddNote(lead, 1500, 79, 100);    // G5

        // Bass: root notes, quarter notes
        // Bar 1-2: C C F F
        gameSong.AddNote(gbass, 0, 48, 200);      // C3
        gameSong.AddNote(gbass, 200, 48, 200);    // C3
        gameSong.AddNote(gbass, 400, 53, 200);    // F3
        gameSong.AddNote(gbass, 600, 53, 200);    // F3
        // Bar 3-4: D D G G
        gameSong.AddNote(gbass, 800, 50, 200);    // D3
        gameSong.AddNote(gbass, 1000, 50, 200);   // D3
        gameSong.AddNote(gbass, 1200, 55, 200);   // G3
        gameSong.AddNote(gbass, 1400, 55, 200);   // G3

        // Drums: kick on 1&3, snare on 2&4 (4 bars)
        var d = 0;
        while d < 1600 {
            gameSong.AddNote(drums, d, 2, 25);           // kick (low noise)
            gameSong.AddNote(drums, d + 50, 12, 15);     // hi-hat
            gameSong.AddNote(drums, d + 100, 8, 30);     // snare (mid noise)
            gameSong.AddNote(drums, d + 150, 12, 15);    // hi-hat
            gameSong.AddNote(drums, d + 200, 2, 25);     // kick
            gameSong.AddNote(drums, d + 250, 12, 15);    // hi-hat
            gameSong.AddNote(drums, d + 300, 8, 30);     // snare
            gameSong.AddNote(drums, d + 350, 12, 15);    // hi-hat
            d = d + 400;
        }

        gameSong.Length = 1600;
        gameSong.SetLoopable(true);
        var gameSound = gameSong.Build();
        if gameSound != null {
            bank.RegisterSound("music_game", gameSound);
        }

        // Ten distinct regional identities plus dedicated hub/boss/ending cues.
        var identity = 1;
        while identity <= 14 {
            var identitySound = buildMusicIdentity(identity);
            if identitySound != null {
                bank.RegisterSound("music_identity_" + Int(identity),
                                   identitySound);
            }
            identity = identity + 1;
        }
        identity = 1;
        while identity <= 10 {
            var ambienceSound = buildAmbienceIdentity(identity);
            if ambienceSound != null {
                bank.RegisterSound("ambience_identity_" + Int(identity),
                                   ambienceSound);
            }
            identity = identity + 1;
        }

        ready = true;
        applyVolumeSettings();
    }

    /// @brief Set the global audio master volume.
    ///
    /// @param value Volume in the inclusive range 0..100.  Values outside the
    /// range are clamped before being applied.
    expose func setMasterVolume(value: Integer) {
        masterVolume = clampVolume(value);
        applyVolumeSettings();
    }

    /// @brief Set the sound-effect mix volume.
    ///
    /// @param value Volume in the inclusive range 0..100.  Values outside the
    /// range are clamped before being applied.
    expose func setSfxVolume(value: Integer) {
        sfxVolume = clampVolume(value);
        applyVolumeSettings();
    }

    /// @brief Set the independent background-music mix volume.
    ///
    /// An active music voice updates immediately without restarting its track.
    ///
    /// @param value Volume in inclusive range 0..100; outliers are clamped.
    /// @return Nothing. Mutates the stored mix and possibly the active voice.
    expose func setMusicVolume(value: Integer) {
        musicVolume = clampVolume(value);
        applyVolumeSettings();
    }

    /// @brief Set the independent environmental ambience mix volume.
    ///
    /// @param value Volume in inclusive range 0..100; outliers are clamped.
    /// @return Nothing. Applies group-three gain without restarting music.
    expose func setAmbienceVolume(value: Integer) {
        ambienceVolume = clampVolume(value);
        applyVolumeSettings();
    }

    /// @brief Set the independent ARIA/radio voice mix volume.
    ///
    /// @param value Volume in inclusive range 0..100; outliers are clamped.
    /// @return Nothing. Applies group-four gain without affecting SFX.
    expose func setVoiceVolume(value: Integer) {
        voiceVolume = clampVolume(value);
        applyVolumeSettings();
    }

    /// @brief Read the current global audio master volume.
    expose func getMasterVolume() -> Integer {
        return masterVolume;
    }

    /// @brief Read the current sound-effect mix volume.
    expose func getSfxVolume() -> Integer {
        return sfxVolume;
    }

    /// @brief Read the independent background-music mix volume.
    ///
    /// @return Integer in 0..100.
    expose func getMusicVolume() -> Integer { return musicVolume; }

    /// @brief Read independent environmental ambience volume.
    ///
    /// @return Integer in 0..100.
    expose func getAmbienceVolume() -> Integer { return ambienceVolume; }

    /// @brief Read independent ARIA/radio voice volume.
    ///
    /// @return Integer in 0..100.
    expose func getVoiceVolume() -> Integer { return voiceVolume; }

    /// @brief Apply exploration-to-combat intensity without restarting a track.
    ///
    /// @param percent Requested intensity in 0..100.
    /// @return Nothing. Updates group gain only when the normalized value changes.
    expose func setCombatIntensity(percent: Integer) {
        var bounded = percent;
        if bounded < 0 { bounded = 0; }
        if bounded > 100 { bounded = 100; }
        if bounded == combatIntensity { return; }
        combatIntensity = bounded;
        applyVolumeSettings();
    }

    /// @brief Clamp a user-facing volume value into the audio API range.
    ///
    /// @param value Candidate volume.
    /// @return `value` clamped to 0..100.
    hide func clampVolume(value: Integer) -> Integer {
        if value < 0 { return 0; }
        if value > 100 { return 100; }
        return value;
    }

    /// @brief Apply stored volume fields to the Viper audio mixer.
    ///
    /// This is safe to call before audio is ready; in that case it only updates
    /// stored state and returns.  Once ready, master volume is set globally and
    /// group 1 is also updated for future grouped SFX calls.
    hide func applyVolumeSettings() {
        if ready == false { return; }
        Audio.SetMasterVolume(masterVolume);
        Audio.SetGroupVolume(1, sfxVolume);
        var adaptiveMusicVolume =
            musicVolume * (85 + combatIntensity * 15 / 100) / 100;
        Audio.SetGroupVolume(2, adaptiveMusicVolume);
        Audio.SetGroupVolume(3, ambienceVolume);
        Audio.SetGroupVolume(4, voiceVolume);
    }

    /// @brief Scale a base sound-effect volume by the current SFX slider.
    ///
    /// @param base The authored per-effect volume, usually 40..80.
    /// @return The effective per-effect volume after SFX scaling.
    hide func scaledSfx(base: Integer) -> Integer {
        return base * sfxVolume / 100;
    }

    /// @brief Procedurally compose one regional or scene-specific music identity.
    ///
    /// Identities 1..10 map to campaign regions; 11 is hub, 12 boss, 13 victory,
    /// and 14 game over. Each receives a distinct root, tempo, waveform, melodic
    /// rotation, bass pulse, and ambient pad while retaining a coherent shared
    /// harmonic language. The returned loop is first-party and dependency-free.
    ///
    /// @param identity Stable music identity in 1..14.
    /// @return Newly built loopable Sound, or null if synthesis fails.
    hide func buildMusicIdentity(identity: Integer) -> Sound {
        var bounded = identity;
        if bounded < 1 { bounded = 1; }
        if bounded > 14 { bounded = 14; }
        var tempo = 76 + bounded * 5;
        if bounded == 11 { tempo = 84; }
        if bounded == 12 { tempo = 152; }
        if bounded == 13 { tempo = 108; }
        if bounded == 14 { tempo = 66; }
        var root = 42 + (bounded * 5) % 12;
        var song = MusicGen.New(tempo);
        var pad = song.AddChannel(0);
        var pulse = song.AddChannel(bounded % 4);
        var bass = song.AddChannel(2);
        var texture = song.AddChannel(4);

        song.SetEnvelope(pad, 180, 160, 46, 220);
        song.SetChannelVol(pad, 28);
        song.SetDetune(pad, 2 + bounded % 7);
        song.SetPan(pad, -22);
        song.SetEnvelope(pulse, 6, 55, 42, 90);
        song.SetChannelVol(pulse, 42);
        song.SetPan(pulse, 20);
        song.SetVibrato(pulse, 4 + bounded % 8, 360 + bounded * 30);
        song.SetEnvelope(bass, 4, 45, 70, 70);
        song.SetChannelVol(bass, 40);
        song.SetPan(bass, -8);
        song.SetEnvelope(texture, 1, 22, 0, 35);
        song.SetChannelVol(texture, 18 + bounded % 12);

        var chord = 0;
        while chord < 4 {
            var chordRoot = root + (chord * 5 + bounded) % 8;
            song.AddNote(pad, chord * 400, chordRoot + 12, 400);
            song.AddNote(bass, chord * 400, chordRoot, 200);
            song.AddNote(bass, chord * 400 + 200, chordRoot + 7, 200);
            chord = chord + 1;
        }

        var step = 0;
        while step < 16 {
            var degree = (step * 3 + bounded) % 7;
            var interval = degree;
            if degree >= 2 { interval = interval + 1; }
            if degree >= 5 { interval = interval + 1; }
            song.AddNote(pulse, step * 100, root + 24 + interval, 82);
            if step % 2 == 0 {
                song.AddNote(texture, step * 100, 4 + bounded % 10, 24);
            }
            step = step + 1;
        }
        song.Length = 1600;
        song.SetLoopable(true);
        return song.Build();
    }

    /// @brief Compose one sparse environmental bed for a campaign biome.
    ///
    /// A quiet detuned pad establishes regional air/pressure while a low-volume
    /// noise channel adds wind, spores, steam, ice, or machine texture according
    /// to its stable region id. It loops separately on ambience mixer group three.
    ///
    /// @param region One-based campaign region in 1..10.
    /// @return Newly built loopable Sound, or null if synthesis fails.
    hide func buildAmbienceIdentity(region: Integer) -> Sound {
        var bounded = region;
        if bounded < 1 { bounded = 1; }
        if bounded > 10 { bounded = 10; }
        var song = MusicGen.New(54 + bounded * 3);
        var air = song.AddChannel(0);
        var texture = song.AddChannel(4);
        song.SetEnvelope(air, 350, 260, 35, 420);
        song.SetChannelVol(air, 24);
        song.SetDetune(air, 4 + bounded);
        song.SetPan(air, -28 + bounded * 5);
        song.SetEnvelope(texture, 2, 90, 4, 120);
        song.SetChannelVol(texture, 9 + bounded);
        song.SetPan(texture, 24 - bounded * 4);
        var root = 34 + (bounded * 7) % 12;
        song.AddNote(air, 0, root + 12, 1600);
        song.AddNote(air, 1600, root + 17, 1600);
        var pulse = 0;
        while pulse < 3200 {
            song.AddNote(texture, pulse + bounded * 17 % 90,
                         2 + bounded, 35 + bounded * 2);
            pulse = pulse + 320;
        }
        song.Length = 3200;
        song.SetLoopable(true);
        return song.Build();
    }

    // Shut down audio system cleanly.
    /// @brief Tear down audio cleanly.  Game calls this
    ///        before exiting so the OS releases the audio
    ///        device.
    expose func shutdown() {
        if ready == false { return; }
        Audio.StopAllSounds();
        Audio.Shutdown();
        ready = false;
    }

    // --- Play methods: one per sound, with volume/pan tuning ---
    // Each method guards on `ready` to avoid crashes if audio init failed.

    //=========================================================
    // SFX — one named-sound dispatch per gameplay event
    //=========================================================
    // Each `play*` is the same shape: guard on `ready`, then
    // `bank.Play("name")`.  A guard at every site avoids the
    // overhead of pushing it into the bank — and lets us
    // skip the parameter encode for any sound that has
    // alternate signatures (volume, pan).
    //
    // To add a new SFX:
    //   1. Register it in `setup` (Synth fallback + WAV load).
    //   2. Add a one-liner `playWhatever` here.
    //   3. Call it from the gameplay event site.

    /// @brief Player jump.  Short upward whoosh.
    expose func playJump() {
        if ready == false { return; }
        bank.PlayEx("jump", scaledSfx(60), 0);
    }

    /// @brief Bullet fired.
    expose func playShoot() {
        if ready == false { return; }
        bank.PlayEx("shoot", scaledSfx(50), 0);
    }

    /// @brief Coin pickup chime.
    expose func playCoin() {
        if ready == false { return; }
        bank.PlayEx("coin", scaledSfx(70), 0);
    }

    /// @brief Player took damage.  Lower-pitched bark.
    expose func playHurt() {
        if ready == false { return; }
        bank.PlayEx("hurt", scaledSfx(80), 0);
    }

    /// @brief Enemy killed.  Sharp pop.
    expose func playEnemyDeath() {
        if ready == false { return; }
        bank.PlayEx("enemy_death", scaledSfx(65), 0);
    }

    /// @brief Powerup pickup arpeggio.
    expose func playPowerup() {
        if ready == false { return; }
        bank.PlayEx("powerup", scaledSfx(70), 0);
    }

    /// @brief Checkpoint activated.
