//
// File: examples/games/xenoscape/level_validation_probe.zia
// Purpose: Proves campaign structure and movement-aware critical reachability.
// Key invariants:
//   - All ten production levels pass through the production enrichment path.
//   - Success requires every level, exit, checkpoint, boss, and named room route.
// Ownership/Lifetime:
//   - Probe owns one validator and its short-lived aggregate report.
// Links: level_validation.zia, level.zia, docs/testing.md
//
//===----------------------------------------------------------------------===//

module level_validation_probe;

bind Viper.Terminal as Terminal;
bind Viper.Text.Fmt;
bind "./level_validation";

/// @brief Probe entry point for targeted campaign structural validation.
///
/// Emits a deterministic summary suitable for local greps or lightweight CI:
/// `RESULT: ok` on success, or `RESULT: validation_failed` with an error count
/// when one or more level-data checks fail.
func main() {
    var validator = new LevelValidator();
    var report = validator.validateCampaign(true);

    if report.ok() and report.checkedLevels == 10 and
       report.reachableLevels == 10 and
       report.criticalPointsChecked >= 100 {
        Terminal.Say("RESULT: ok");
    } else {
        Terminal.Say("RESULT: validation_failed errors=" + Int(report.errors));
    }
}
