//
// File: examples/games/xenoscape/combat_feedback.zia
// Purpose: Defines deterministic impact-pause timing for combat readability.
// Key invariants:
//   - Ordinary kills pause 35 ms, charged kills 60 ms, boss phases 100 ms.
//   - Pure mappings do not read display, input, or mutable combat state.
// Ownership/Lifetime:
//   - Functions and constants own no resources or retained state.
// Links: game.zia, projectile.zia, mechanics_probe.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module combat_feedback;

final HIT_STOP_NORMAL_KILL_MS = 35;
final HIT_STOP_CHARGED_KILL_MS = 60;
final HIT_STOP_BOSS_PHASE_MS = 100;

/// @brief Select kill hit-stop duration from the projectile charge tier.
///
/// Stomps and normal shots use tier zero. Either partial or full charge uses the
/// same stronger pause so feedback is stable even when damage tuning changes.
///
/// @param chargeLevel Projectile tier, with nonpositive values treated as normal.
/// @return 35 ms for normal/stomp kills and 60 ms for charged kills.
func killHitStopDurationMs(chargeLevel: Integer) -> Integer {
    if chargeLevel > 0 { return HIT_STOP_CHARGED_KILL_MS; }
    return HIT_STOP_NORMAL_KILL_MS;
}

/// @brief Return the readable pause applied at every boss phase threshold.
///
/// @return The exact 100-millisecond boss-phase hit stop.
func bossPhaseHitStopDurationMs() -> Integer {
    return HIT_STOP_BOSS_PHASE_MS;
}
