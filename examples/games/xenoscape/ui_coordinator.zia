//
// File: examples/games/xenoscape/ui_coordinator.zia
// Purpose: Resolves modal, top-banner, and lower-third overlay ownership.
// Key invariants:
//   - At most one owner renders in each screen lane during a frame.
//   - Modal presentation suppresses every nonmodal overlay.
// Ownership/Lifetime:
//   - Game owns one coordinator and resolves it before update/draw decisions.
// Links: game.zia, tutorials.zia, radio.zia, abilities.zia
//
//===----------------------------------------------------------------------===//

module ui_coordinator;

final UI_MODAL_NONE = 0;
final UI_MODAL_MAP = 1;
final UI_MODAL_LORE = 2;
final UI_MODAL_ABILITY = 3;
final UI_MODAL_TRANSITION = 4;

final UI_TOP_NONE = 0;
final UI_TOP_BOSS = 1;
final UI_TOP_MESSAGE = 2;
final UI_TOP_ROOM = 3;
final UI_TOP_ACHIEVEMENT = 4;

final UI_BOTTOM_NONE = 0;
final UI_BOTTOM_TUTORIAL = 1;
final UI_BOTTOM_RADIO = 2;

/// @brief Deterministic screen-lane arbitration for gameplay presentation.
class UiCoordinator {
    hide Integer modalOwner;
    hide Integer topOwner;
    hide Integer bottomOwner;

    /// @brief Construct an empty presentation frame.
    /// @return Nothing. All three owners become their NONE values.
    expose func init() { clear(); }

    /// @brief Reset all lane owners.
    /// @return Nothing. Mutates only transient frame ownership.
    expose func clear() {
        modalOwner = UI_MODAL_NONE;
        topOwner = UI_TOP_NONE;
        bottomOwner = UI_BOTTOM_NONE;
    }

    /// @brief Resolve one frame from current subsystem visibility requests.
    ///
    /// Priority is intentional: explicit player modals beat automatic modals;
    /// danger beats flavor text; actionable guidance beats radio narration.
    ///
    /// @param showMap World-map modal request.
    /// @param showLore Lore modal request.
    /// @param showAbility Ability-acquisition modal request.
    /// @param showTransition Level-transition modal request.
    /// @param showBoss Boss-warning top-lane request.
    /// @param showMessage Interaction-result top-lane request.
    /// @param showRoom Room-title top-lane request.
    /// @param showAchievement Achievement top-lane request.
    /// @param showTutorial Contextual-guidance lower-third request.
    /// @param showRadio ARIA subtitle lower-third request.
    /// @return Nothing. Replaces all owners for the current frame.
    expose func resolve(showMap: Boolean, showLore: Boolean,
                        showAbility: Boolean, showTransition: Boolean,
                        showBoss: Boolean, showMessage: Boolean,
                        showRoom: Boolean, showAchievement: Boolean,
                        showTutorial: Boolean, showRadio: Boolean) {
        clear();
        if showMap { modalOwner = UI_MODAL_MAP; }
        else if showLore { modalOwner = UI_MODAL_LORE; }
        else if showAbility { modalOwner = UI_MODAL_ABILITY; }
        else if showTransition { modalOwner = UI_MODAL_TRANSITION; }

        if modalOwner != UI_MODAL_NONE { return; }

        if showBoss { topOwner = UI_TOP_BOSS; }
        else if showMessage { topOwner = UI_TOP_MESSAGE; }
        else if showRoom { topOwner = UI_TOP_ROOM; }
        else if showAchievement { topOwner = UI_TOP_ACHIEVEMENT; }

        if showTutorial { bottomOwner = UI_BOTTOM_TUTORIAL; }
        else if showRadio { bottomOwner = UI_BOTTOM_RADIO; }
    }

    /// @brief Read the winning modal id.
    /// @return One `UI_MODAL_*` value.
    expose func getModalOwner() -> Integer { return modalOwner; }

    /// @brief Report whether the boss banner owns the top lane.
    /// @return True only for `UI_TOP_BOSS`.
    expose func showBoss() -> Boolean { return topOwner == UI_TOP_BOSS; }

    /// @brief Report whether interaction feedback owns the top lane.
    /// @return True only for `UI_TOP_MESSAGE`.
    expose func showMessage() -> Boolean { return topOwner == UI_TOP_MESSAGE; }

    /// @brief Report whether the room title owns the top lane.
    /// @return True only for `UI_TOP_ROOM`.
    expose func showRoom() -> Boolean { return topOwner == UI_TOP_ROOM; }

    /// @brief Report whether an achievement owns the top lane.
    /// @return True only for `UI_TOP_ACHIEVEMENT`.
    expose func showAchievement() -> Boolean {
        return topOwner == UI_TOP_ACHIEVEMENT;
    }

    /// @brief Report whether guidance owns the lower-third lane.
    /// @return True only for `UI_BOTTOM_TUTORIAL`.
    expose func showTutorial() -> Boolean {
        return bottomOwner == UI_BOTTOM_TUTORIAL;
    }

    /// @brief Report whether ARIA owns the lower-third lane.
    /// @return True only for `UI_BOTTOM_RADIO`.
    expose func showRadio() -> Boolean { return bottomOwner == UI_BOTTOM_RADIO; }

    /// @brief Report whether any modal owns the frame.
    /// @return True for Map, Lore, Ability, or Transition.
    expose func hasModal() -> Boolean { return modalOwner != UI_MODAL_NONE; }

    /// @brief Report whether one top-banner request won this frame.
    /// @return True for boss, message, room, or achievement ownership.
    expose func hasTop() -> Boolean { return topOwner != UI_TOP_NONE; }
}
