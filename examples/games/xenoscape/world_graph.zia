//
// File: examples/games/xenoscape/world_graph.zia
// Purpose: Defines authoritative regional topology, ability gates, and room ids.
// Key invariants:
//   - Region indices are stable zero-based ids matching map/save pad ids.
//   - Every edge is bidirectional and uses an existing `ABILITY_*` gate flag.
// Ownership/Lifetime:
//   - WorldGraph owns immutable parallel lists for its object lifetime.
//   - Game and WorldMap each may own a cheap independent topology instance.
// Links: worldmap.zia, game.zia, world_probe.zia, abilities.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module world_graph;

bind "./abilities";
bind "./config";

final WORLD_REGION_COUNT = 10;
final WORLD_EDGE_COUNT = 12;
final WORLD_ROOMS_PER_REGION = 8;

/// @brief Test one ability-gate flag against an acquired ability mask.
///
/// @param abilityMask Sum of stable `ABILITY_*` flags.
/// @param requiredAbility Zero for an open route or one ability flag.
/// @return True for open routes or when the required flag is present.
func worldGraphGateOpen(abilityMask: Integer,
                        requiredAbility: Integer) -> Boolean {
    if requiredAbility == ABILITY_NONE { return true; }
    if requiredAbility < 0 { return false; }
    return (abilityMask / requiredAbility) % 2 == 1;
}

/// @brief Authoritative ten-region campaign graph and stable room namespace.
class WorldGraph {
    hide List[String] nodeNames;
    hide List[Integer] edgeFrom;
    hide List[Integer] edgeTo;
    hide List[Integer] edgeGate;
    hide List[Integer] edgeFromRoom;
    hide List[Integer] edgeToRoom;
    hide List[Integer] roomBoundaries;

    /// @brief Populate the exact approved campaign topology.
    ///
    /// @return Nothing. Reinitializes all immutable parallel lists.
    expose func init() {
        nodeNames = [
            "Crash Site", "Fungal Caverns", "Crystal Depths",
            "Surface Ruins", "Underground Lake", "Thermal Vents",
            "Overgrowth", "Frozen Abyss", "Corrupted Ruins", "The Core"
        ];
        edgeFrom = [0, 1, 0, 1, 2, 3, 4, 5, 3, 6, 7, 8];
        edgeTo =   [1, 2, 3, 4, 5, 4, 5, 8, 6, 7, 8, 9];
        edgeGate = [
            ABILITY_NONE, ABILITY_DASH, ABILITY_NONE, ABILITY_NONE,
            ABILITY_DASH, ABILITY_NONE, ABILITY_NONE, ABILITY_GROUND_POUND,
            ABILITY_NONE, ABILITY_CHARGE_SHOT, ABILITY_GROUND_POUND,
            ABILITY_GRAPPLE
        ];
        // Physical endpoint rooms for each regional connection. These are not
        // inferred from map direction: each route terminates at a named room
        // whose in-level gateway and entry spawn can be validated together.
        edgeFromRoom = [7, 6, 2, 3, 7, 4, 7, 7, 7, 7, 7, 7];
        edgeToRoom =   [0, 0, 0, 0, 0, 2, 2, 0, 0, 0, 2, 0];
        roomBoundaries = [
            0, 87, 173, 333, 420, 593, 753, 907, 1000,
            0, 87, 173, 333, 420, 587, 720, 880, 1000,
            0, 160, 310, 455, 590, 725, 820, 910, 1000,
            0, 105, 230, 355, 480, 610, 735, 870, 1000,
            0, 155, 300, 420, 540, 665, 790, 900, 1000,
            0, 150, 290, 430, 565, 700, 820, 920, 1000,
            0, 140, 275, 410, 545, 680, 805, 910, 1000,
            0, 110, 235, 360, 485, 610, 740, 870, 1000,
            0, 150, 285, 420, 550, 680, 805, 915, 1000,
            0, 120, 250, 400, 535, 670, 800, 900, 1000
        ];
    }

    /// @brief Return the fixed number of campaign regions.
    ///
    /// @return `WORLD_REGION_COUNT` (10).
    expose func getRegionCount() -> Integer { return nodeNames.length(); }

    /// @brief Return the fixed number of bidirectional graph edges.
    ///
    /// @return `WORLD_EDGE_COUNT` (12).
    expose func getEdgeCount() -> Integer { return edgeFrom.length(); }

    /// @brief Read a stable region display name.
    ///
    /// @param region Zero-based region id.
    /// @return Authored name, or `Unknown Region` for invalid input.
    expose func getRegionName(region: Integer) -> String {
        if region < 0 or region >= nodeNames.length() { return "Unknown Region"; }
        return nodeNames.get(region);
    }

    /// @brief Read one edge's first endpoint.
    ///
    /// @param edge Zero-based edge-table index.
    /// @return Zero-based region id, or -1 for invalid input.
    expose func getEdgeFrom(edge: Integer) -> Integer {
        if edge < 0 or edge >= edgeFrom.length() { return -1; }
        return edgeFrom.get(edge);
    }

    /// @brief Read one edge's second endpoint.
    ///
    /// @param edge Zero-based edge-table index.
    /// @return Zero-based region id, or -1 for invalid input.
    expose func getEdgeTo(edge: Integer) -> Integer {
        if edge < 0 or edge >= edgeTo.length() { return -1; }
        return edgeTo.get(edge);
    }

    /// @brief Read one edge's traversal ability requirement.
    ///
    /// @param edge Zero-based edge-table index.
    /// @return `ABILITY_NONE`, one `ABILITY_*` flag, or -1 if invalid.
    expose func getEdgeGate(edge: Integer) -> Integer {
        if edge < 0 or edge >= edgeGate.length() { return -1; }
        return edgeGate.get(edge);
    }

    /// @brief Read the named endpoint room for an edge and incident region.
    ///
    /// @return Local room id 0..7, or -1 when the edge/region pair is invalid.
    expose func getEdgeRoom(edge: Integer, region: Integer) -> Integer {
        if edge < 0 or edge >= edgeFrom.length() { return -1; }
        if edgeFrom.get(edge) == region { return edgeFromRoom.get(edge); }
        if edgeTo.get(edge) == region { return edgeToRoom.get(edge); }
        return -1;
    }

    /// @brief Read the opposite endpoint of an incident edge.
    expose func getOtherRegion(edge: Integer, region: Integer) -> Integer {
        if edge < 0 or edge >= edgeFrom.length() { return -1; }
        if edgeFrom.get(edge) == region { return edgeTo.get(edge); }
        if edgeTo.get(edge) == region { return edgeFrom.get(edge); }
        return -1;
    }

    /// @brief Find the undirected edge connecting two regions.
    ///
    /// @param from Zero-based source region.
    /// @param to Zero-based destination region.
    /// @return Edge-table index, or -1 when the pair is not adjacent.
    expose func findEdge(from: Integer, to: Integer) -> Integer {
        var i = 0;
        while i < edgeFrom.length() {
            if (edgeFrom.get(i) == from and edgeTo.get(i) == to) or
               (edgeFrom.get(i) == to and edgeTo.get(i) == from) {
                return i;
            }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Test adjacency and ability ownership for one route.
    ///
    /// @param from Zero-based source region.
    /// @param to Zero-based destination region.
    /// @param abilityMask Current acquired ability mask.
    /// @return True only for a real edge whose gate is open.
    expose func canTraverse(from: Integer, to: Integer,
                            abilityMask: Integer) -> Boolean {
        var edge = findEdge(from, to);
        if edge < 0 { return false; }
        return worldGraphGateOpen(abilityMask, edgeGate.get(edge));
    }

    /// @brief Count currently traversable neighbors of one region.
    ///
    /// @param region Zero-based source region.
    /// @param abilityMask Current acquired ability mask.
    /// @return Number of adjacent endpoints with open gates.
    expose func getAvailableNeighborCount(region: Integer,
                                          abilityMask: Integer) -> Integer {
        var count = 0;
        var i = 0;
        while i < edgeFrom.length() {
            if worldGraphGateOpen(abilityMask, edgeGate.get(i)) {
                if edgeFrom.get(i) == region or edgeTo.get(i) == region {
                    count = count + 1;
                }
            }
            i = i + 1;
        }
        return count;
    }

    /// @brief Read one traversable neighbor in stable edge-table order.
    ///
    /// @param region Zero-based source region.
    /// @param availableIndex Zero-based index among currently open neighbors.
    /// @param abilityMask Current acquired ability mask.
    /// @return Destination region id, or -1 for invalid/out-of-range selection.
    expose func getAvailableNeighbor(region: Integer,
                                     availableIndex: Integer,
                                     abilityMask: Integer) -> Integer {
        if availableIndex < 0 { return -1; }
        var seen = 0;
        var i = 0;
        while i < edgeFrom.length() {
            if worldGraphGateOpen(abilityMask, edgeGate.get(i)) {
                var destination = -1;
                if edgeFrom.get(i) == region { destination = edgeTo.get(i); }
                if edgeTo.get(i) == region { destination = edgeFrom.get(i); }
                if destination >= 0 {
                    if seen == availableIndex { return destination; }
                    seen = seen + 1;
                }
            }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Choose a default route that favors an uncompleted destination.
    ///
    /// @param region Zero-based current region.
    /// @param abilityMask Current acquired ability mask.
    /// @param completionMask One bit per completed region.
    /// @return Available-neighbor selection index, or zero when none exists.
    expose func recommendedNeighborSelection(region: Integer,
                                              abilityMask: Integer,
                                              completionMask: Integer) -> Integer {
        var count = getAvailableNeighborCount(region, abilityMask);
        var i = 0;
        while i < count {
            var destination = getAvailableNeighbor(region, i, abilityMask);
            var bit = regionBit(destination);
            if bit > 0 and (completionMask / bit) % 2 == 0 { return i; }
            i = i + 1;
        }
        return 0;
    }

    /// @brief Compute all regions reachable under the supplied ability mask.
    ///
    /// Fixed-point propagation repeatedly opens both endpoints of traversable
    /// edges until no mask bit changes. This avoids recursion and allocation.
    ///
    /// @param start Zero-based starting region.
    /// @param abilityMask Current acquired ability mask.
    /// @return Reachable-region bitmask, or zero for an invalid start.
    expose func reachableMask(start: Integer, abilityMask: Integer) -> Integer {
        var startBit = regionBit(start);
        if startBit == 0 { return 0; }
        var reachable = startBit;
        var changed = true;
        while changed {
            changed = false;
            var i = 0;
            while i < edgeFrom.length() {
                if worldGraphGateOpen(abilityMask, edgeGate.get(i)) {
                    var fromBit = regionBit(edgeFrom.get(i));
                    var toBit = regionBit(edgeTo.get(i));
                    if (reachable / fromBit) % 2 == 1 and
                       (reachable / toBit) % 2 == 0 {
                        reachable = reachable + toBit;
                        changed = true;
                    }
                    if (reachable / toBit) % 2 == 1 and
                       (reachable / fromBit) % 2 == 0 {
                        reachable = reachable + fromBit;
                        changed = true;
                    }
                }
                i = i + 1;
            }
        }
        return reachable;
    }

    /// @brief Map a world column to one of eight stable room indices.
    ///
    /// @param column Zero-based tile column inside the active regional level.
    /// @param levelWidth Positive regional width in tiles.
    /// @return Room index 0..7, clamped at both level edges.
    expose func roomIndexForColumn(column: Integer,
                                   levelWidth: Integer) -> Integer {
        if levelWidth <= 0 { return 0; }
        var bounded = column;
        if bounded < 0 { bounded = 0; }
        if bounded >= levelWidth { bounded = levelWidth - 1; }
        var room = bounded * WORLD_ROOMS_PER_REGION / levelWidth;
        if room >= WORLD_ROOMS_PER_REGION { room = WORLD_ROOMS_PER_REGION - 1; }
        return room;
    }

    /// @brief Map a regional column through its authored, nonuniform boundaries.
    expose func authoredRoomIndexForColumn(region: Integer, column: Integer,
                                           levelWidth: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT or levelWidth <= 0 {
            return 0;
        }
        var bounded = column;
        if bounded < 0 { bounded = 0; }
        if bounded >= levelWidth { bounded = levelWidth - 1; }
        var room = 0;
        while room < WORLD_ROOMS_PER_REGION - 1 {
            if bounded < getRoomStartColumn(region, room + 1, levelWidth) {
                return room;
            }
            room = room + 1;
        }
        return WORLD_ROOMS_PER_REGION - 1;
    }

    /// @brief Return the inclusive first tile column of one authored room.
    expose func getRoomStartColumn(region: Integer, room: Integer,
                                   levelWidth: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT or
           room < 0 or room >= WORLD_ROOMS_PER_REGION or levelWidth <= 0 {
            return 0;
        }
        return roomBoundaryPermille(region, room) * levelWidth / 1000;
    }

    /// @brief Return the inclusive final tile column of one authored room.
    expose func getRoomEndColumn(region: Integer, room: Integer,
                                 levelWidth: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT or
           room < 0 or room >= WORLD_ROOMS_PER_REGION or levelWidth <= 0 {
            return 0;
        }
        var result = roomBoundaryPermille(region, room + 1) * levelWidth / 1000 - 1;
        if room == WORLD_ROOMS_PER_REGION - 1 { result = levelWidth - 1; }
        if result < 0 { result = 0; }
        return result;
    }

    /// @brief Return the midpoint column used for content anchors/gateways.
    expose func getRoomCenterColumn(region: Integer, room: Integer,
                                    levelWidth: Integer) -> Integer {
        return (getRoomStartColumn(region, room, levelWidth) +
                getRoomEndColumn(region, room, levelWidth)) / 2;
    }

    /// @brief Authored nonuniform room boundary in thousandths of region width.
    ///
    /// Boundary zero is 0 and boundary eight is 1000. Intermediate values align
    /// with the legacy builders' actual encounter, landmark, and arena seams.
    hide func roomBoundaryPermille(region: Integer,
                                   boundary: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT { return 0; }
        if boundary <= 0 { return 0; }
        if boundary >= WORLD_ROOMS_PER_REGION { return 1000; }
        return roomBoundaries.get(region * 9 + boundary);
    }

    /// @brief Build a stable global room id from region and local room index.
    ///
    /// @param region Zero-based region id.
    /// @param room Zero-based local room index in 0..7.
    /// @return Stable id `region * 8 + room`, or -1 for invalid input.
    expose func roomId(region: Integer, room: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT or
           room < 0 or room >= WORLD_ROOMS_PER_REGION { return -1; }
        return region * WORLD_ROOMS_PER_REGION + room;
    }

    /// @brief Build a readable authored-style room label for HUD/objectives.
    ///
    /// @param region Zero-based region id.
    /// @param room Zero-based local room index.
    /// @return Region name plus a stable room-role suffix, or `Unknown Room`.
    expose func getRoomName(region: Integer, room: Integer) -> String {
        if roomId(region, room) < 0 { return "Unknown Room"; }
        return getRegionName(region) + " — " + authoredRoomName(region, room);
    }

    /// @brief Map one stable regional room id to its memorable authored name.
    ///
    /// All ten regions expose exactly eight names. Explicit branches avoid list
    /// allocation in the per-frame HUD query and make ids resilient to later room
    /// layout edits.
    ///
    /// @param region Zero-based region id in 0..9.
    /// @param room Zero-based room id in 0..7.
    /// @return Authored room suffix, or `Unknown` for defensive invalid input.
    hide func authoredRoomName(region: Integer, room: Integer) -> String {
        if region == 0 {
            if room == 0 { return "Impact Crater"; }
            if room == 1 { return "Broken Keel"; }
            if room == 2 { return "Beacon Hollow"; }
            if room == 3 { return "Shattered Gantry"; }
            if room == 4 { return "Emergency Camp"; }
            if room == 5 { return "Cooling Trench"; }
            if room == 6 { return "Signal Ridge"; }
            return "Cavern Mouth";
        }
        if region == 1 {
            if room == 0 { return "Sporefall Grotto"; }
            if room == 1 { return "Lantern Shelf"; }
            if room == 2 { return "Mycelial Sink"; }
            if room == 3 { return "Puffcap Crossing"; }
            if room == 4 { return "Root Communion"; }
            if room == 5 { return "Brood Galleries"; }
            if room == 6 { return "Nursery Veins"; }
            return "Mother's Hollow";
        }
        if region == 2 {
            if room == 0 { return "Prism Gate"; }
            if room == 1 { return "Singing Shelf"; }
            if room == 2 { return "Facet Mines"; }
            if room == 3 { return "Refraction Span"; }
            if room == 4 { return "Resonance Vault"; }
            if room == 5 { return "Glass Chasm"; }
            if room == 6 { return "Wyrm Tunnels"; }
            return "Geode Heart";
        }
        if region == 3 {
            if room == 0 { return "Sunken Plaza"; }
            if room == 1 { return "Relay Steps"; }
            if room == 2 { return "Wind Temple"; }
            if room == 3 { return "Aqueduct Span"; }
            if room == 4 { return "Observatory Court"; }
            if room == 5 { return "Collapsed Forum"; }
            if room == 6 { return "Skybridge Ward"; }
            return "Relay Crown";
        }
        if region == 4 {
            if room == 0 { return "Flooded Threshold"; }
            if room == 1 { return "Lumen Reefs"; }
            if room == 2 { return "Drowned Works"; }
            if room == 3 { return "Tidal Locks"; }
            if room == 4 { return "Capacitor Shrine"; }
            if room == 5 { return "Silt Galleries"; }
            if room == 6 { return "Leviathan Cut"; }
            return "Spillway Exit";
        }
        if region == 5 {
            if room == 0 { return "Pressure Gate"; }
            if room == 1 { return "Steamworks"; }
            if room == 2 { return "Cinder Lift"; }
            if room == 3 { return "Vent Crossing"; }
            if room == 4 { return "Forge Sanctum"; }
            if room == 5 { return "Magma Artery"; }
            if room == 6 { return "Eye Approach"; }
            return "Caldera Core";
        }
        if region == 6 {
            if room == 0 { return "Green Threshold"; }
            if room == 1 { return "Canopy Wells"; }
            if room == 2 { return "Rootbound Crypt"; }
            if room == 3 { return "Vineway Span"; }
            if room == 4 { return "Guardian Sanctum"; }
            if room == 5 { return "Pollen Deep"; }
            if room == 6 { return "Last Garden"; }
            return "Grapple Spire";
        }
        if region == 7 {
            if room == 0 { return "White Descent"; }
            if room == 1 { return "Frost Reliquary"; }
            if room == 2 { return "Sample Vaults"; }
            if room == 3 { return "Crevasse Span"; }
            if room == 4 { return "Cryogenic Nave"; }
            if room == 5 { return "Zero Gallery"; }
            if room == 6 { return "Wraith Walk"; }
            return "Archive Lock";
        }
        if region == 8 {
            if room == 0 { return "Static Verge"; }
            if room == 1 { return "Echo Works"; }
            if room == 2 { return "Fracture Hall"; }
            if room == 3 { return "Null Crossing"; }
            if room == 4 { return "Anchor Sanctum"; }
            if room == 5 { return "Distortion Deep"; }
            if room == 6 { return "Seal Approach"; }
            return "Core Breach";
        }
        if region == 9 {
            if room == 0 { return "Machine Throat"; }
            if room == 1 { return "Logic Vestibule"; }
            if room == 2 { return "Harvest Works"; }
            if room == 3 { return "Data Chasm"; }
            if room == 4 { return "Ancient Interface"; }
            if room == 5 { return "Memory Furnace"; }
            if room == 6 { return "Architect's Guard"; }
            return "Planetary Heart";
        }
        return "Unknown";
    }

    /// @brief Convert a valid zero-based region to its discovery/completion bit.
    ///
    /// @param region Zero-based region id.
    /// @return Power-of-two flag, or zero for invalid input.
    hide func regionBit(region: Integer) -> Integer {
        if region < 0 or region >= WORLD_REGION_COUNT { return 0; }
        var bit = 1;
        var i = 0;
        while i < region { bit = bit * 2; i = i + 1; }
        return bit;
    }
}
