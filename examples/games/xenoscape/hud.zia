//
// File: examples/games/xenoscape/hud.zia
// Purpose: Composes Xenoscape's animated gameplay HUD and combat feedback.
// Key invariants:
//   - Campaign presentation never exposes the retired finite-lives counter.
//   - Widget animation is updated separately from deterministic game state.
// Ownership/Lifetime:
//   - Game owns one HUD and passes borrowed render-state values each frame.
// Links: game.zia, renderer.zia, palette.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — THE HUD IS A COMPOSITION OF WIDGETS
// ----------------------------------------------
// A good HUD is un-fussy.  The player's eyes are on the action
// 99 % of the time; the HUD needs to communicate instantly
// without being glanced *at*.  In code, that means:
//
//   * Don't hand-roll graphics for HP bars.  Use the runtime's
//     widget classes (`Zanna.Game.UI.HudBar`, `.HudLabel`, `.HudPanel`).
//     They know about colour thresholds, alignment, and
//     re-rendering efficiently.
//
//   * Don't make numbers *snap*.  The score should roll toward
//     its new value over ~10 frames, so a +50 pickup feels
//     earned instead of just appearing.  `Zanna.Game.SmoothValue`
//     does that out of the box.
//
//   * Don't make the boss HP bar jitter.  When the boss takes a
//     hit, lerp its bar downward over a fraction of a second.
//     `Zanna.Game.Tween` handles lerp + ease curves.
//
// This file demonstrates the composition pattern: construct
// named widget instances in `init`, update them in `update`,
// let each draw itself in `draw`.  The HUD itself is a thin
// shell coordinating subordinate widgets.
//
// RUNTIME WIDGETS REFERENCED
// --------------------------
//   HudPanel(x, y, w, h, color, alpha)
//     Semi-transparent rectangle.  Backs the HUD so text is
//     legible over busy scenes.
//   HudBar(x, y, w, h, fillColor, emptyColor)
//     Horizontal fill bar with `HudBar.Value` in 0..1 range.  Used
//     for HP and boss health.
//   HudLabel(x, y, text, color)
//     Positioned text.  `HudLabel.Text` can be mutated each
//     frame (for score).
//   SmoothValue(initial, smoothing)
//     Scalar that tweens toward its current target.
//     `.Target = newVal; .Update(dt);` gives you a smoothed
//     number every frame.
//   Tween()
//     Manual keyframe tween object.  Use `.Start(from, to, ms)`
//     then `.Update(dt)` and `.Value`.
//
// WHERE THIS FITS
// ---------------
//     game.zia   ──►  owns one HUD instance; calls update + draw.
//     player.zia ──►  HUD reads hp, maxHp, score, coins from it.
//     enemy.zia  ──►  boss flags the boss HP bar on visible.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Widget handles (HudPanel/HudBar/HudLabel fields).
//   2. `init` — construct each widget with layout constants
//      from `config.zia`.
//   3. `update(...)` — copy game state into widget state;
//      advance tweens/smoothers by `dt`.
//   4. `draw(canvas)` — invoke each widget's draw.
//   5. Ad-hoc helpers for boss bar show/hide.
//
// =============================================================================

module hud;

bind Zanna.Graphics;
bind Zanna.Text.Fmt;
bind Zanna.Game;
bind Zanna.Game.UI;
bind "./accessibility";
bind "./config";
bind "./palette";

/// @brief The heads-up display.  Owns one widget per UI
///        element (HP bar, score label, coin label, boss bar
///        plus a backing panel) and keeps a SmoothValue +
///        Tween for animations.
///
/// Constructed once at boot.  Per-frame: `update(...)` copies
/// the latest game state into the widgets and ticks any
/// tweens, then `drawHUD(...)` blits them.
class HUD {
    // --- UI Widget instances ---
    hide Palette pal;
    hide HudPanel hudPanel;
    hide HudBar healthBar;
    hide HudBar bossBarWidget;
    hide HudLabel scoreLabel;
    hide HudLabel coinLabel;
    hide HudLabel expeditionLabel;
    hide HudLabel levelLabel;

    // --- Animation state ---
    hide SmoothValue displayScore;
    hide Tween bossBarTween;
    hide Integer bossBarDisplay;
    hide Integer bossBarTarget;

    // --- Timing ---
    hide Integer pulseTimer;
    hide Integer displayCoins;
    hide Integer accessibilityUiScale;
    hide Boolean accessibilityHighContrast;
    hide Boolean accessibilityLargeText;

    // --- Floating damage/score popups (#14) — fixed pool, no per-hit alloc ---
    hide List[Integer] popX;
    hide List[Integer] popY;
    hide List[Integer] popAmt;
    hide List[Integer] popTimer;

    /// @brief Construct every widget with its initial layout
    ///        + colour from the palette.  Score smoother
    ///        starts at 0; boss bar tween is dormant until a
    ///        boss appears.
    expose func init(p: Palette) {
        pal = p;
        accessibilityUiScale = 100;
        accessibilityHighContrast = false;
        accessibilityLargeText = false;
        // SmoothValue: smoothing=0.75 means score rolls quickly but visibly
        displayScore = SmoothValue.New(0.0, 0.75);
        displayCoins = 0;
        pulseTimer = 0;

        // Pre-allocate a fixed pool of damage/score popup slots (#14).
        popX = [];
        popY = [];
        popAmt = [];
        popTimer = [];
        var pi = 0;
        while pi < 16 {
            popX.add(0);
            popY.add(0);
            popAmt.add(0);
            popTimer.add(0);
            pi = pi + 1;
        }

        // HUD background panel — full width, semi-transparent
        hudPanel = HudPanel.New(0, 0, SCREEN_W, 48, pal.panelBg, 190);
        hudPanel.SetBorder(pal.panelBorder, 1);
        hudPanel.set_CornerRadius(0);

        // Health bar — left side
        healthBar = HudBar.New(12, 10, 140, 16, pal.hpBarFull, pal.hpBarEmpty);
        healthBar.set_Border(1);

        // Boss health bar — center, wider (hidden until boss fight)
        var bossX = (SCREEN_W - 400) / 2;
        bossBarWidget = HudBar.New(bossX, 56, 400, 18, pal.bossBarFill, pal.bossBarEmpty);
        bossBarWidget.set_Border(1);
        bossBarTween = Tween.New();
        bossBarDisplay = 0;
        bossBarTarget = 0;

        // Score label
        scoreLabel = HudLabel.New(170, 6, "SCORE 0", pal.uiText);
        scoreLabel.set_Scale(2);

        // Coin label
        coinLabel = HudLabel.New(630, 6, "x0", pal.coinGold);
        coinLabel.set_Scale(2);

        // Campaign status replaces the retired arcade lives counter.
        expeditionLabel = HudLabel.New(SCREEN_W - 230, 6,
                                       "EXPEDITION", pal.uiText);
        expeditionLabel.set_Scale(2);

        // Level name label
        levelLabel = HudLabel.New(SCREEN_W - 400, 30, "GRASSLANDS", pal.hudBlue);
        levelLabel.set_Scale(2);
    }

    /// @brief Apply persistent HUD scale, contrast, and text-size choices.
    ///
    /// Runtime label widgets update immediately. The scale is capped at three for
    /// the compact combat strip, while secondary text uses the same resolver and
    /// high contrast adds an opaque backing layer before all HUD widgets.
    ///
    /// @param uiScale Advertised 100, 125, or 150 percent setting.
    /// @param highContrast True for maximum backing opacity and white outlines.
    /// @param largeText True for one additional bitmap-font scale step.
    /// @return Nothing. Mutates presentation only.
    expose func setAccessibility(uiScale: Integer, highContrast: Boolean,
                                 largeText: Boolean) {
        accessibilityUiScale = uiScale;
        if accessibilityUiScale != 100 and accessibilityUiScale != 125 and
           accessibilityUiScale != 150 { accessibilityUiScale = 100; }
        accessibilityHighContrast = highContrast;
        accessibilityLargeText = largeText;
        var scale = hudTextScale(2);
        scoreLabel.set_Scale(scale);
        coinLabel.set_Scale(scale);
        expeditionLabel.set_Scale(scale);
        levelLabel.set_Scale(scale);
    }

    /// @brief Resolve compact HUD text while preventing top-strip overlap.
    ///
    /// @param baseScale Positive authored bitmap-font scale.
    /// @return Live scale in 1..3.
    hide func hudTextScale(baseScale: Integer) -> Integer {
        var result = accessibleTextScale(
            baseScale, accessibilityUiScale, accessibilityLargeText);
        if result > 3 { result = 3; }
        return result;
    }

    // Update animated values each frame.
    /// @brief Per-frame: feed the new (score, coins) targets
    ///        into the SmoothValue so the displayed digits roll
    ///        toward them.  `dt` is elapsed ms; the smoother
    ///        scales by it internally for frame-rate
    ///        independence.
    expose func update(targetScore: Integer, targetCoins: Integer, dt: Integer) {
        displayScore.set_Target(targetScore + 0.0);
        displayScore.Update();
        displayCoins = targetCoins;
        pulseTimer = pulseTimer + dt;
        if pulseTimer >= 600 { pulseTimer = 0; }

        // Update boss bar tween if active
        if bossBarTween.get_IsRunning() {
            bossBarTween.Update();
            bossBarDisplay = bossBarTween.get_ValueI64();
        }
    }

    // Draw the main HUD. Called every frame during gameplay.
    /// @brief Render the main HUD: backing panel + HP bar
    ///        (colour shifts red as HP drops) + score label
    ///        (smoothed digits) + coin counter + powerup
    ///        timer bars.  Top-anchored so it doesn't overlap
    ///        the action.
    expose func drawHUD(canvas: Canvas, hp: Integer, maxHp: Integer,
                        _score: Integer, coins: Integer,
                        _levelNum: Integer, speedTimer: Integer,
                        shieldHits: Integer, rapidTimer: Integer) {
        if accessibilityHighContrast {
            canvas.BoxAlpha(0, 0, SCREEN_W, 88, pal.black, 235);
        }
        // Background panel
        hudPanel.Draw(canvas);

        // Health bar — color changes based on remaining HP
        if hp * 3 < maxHp {
            // Critical: pulse red
            if pulseTimer < 300 {
                healthBar.SetColors(0xFF6666, pal.hpBarEmpty);
            } else {
                healthBar.SetColors(pal.hpBarLow, pal.hpBarEmpty);
            }
        } else if hp * 5 < maxHp * 3 {
            healthBar.SetColors(pal.hpBarWarn, pal.hpBarEmpty);
        } else {
            healthBar.SetColors(pal.hpBarFull, pal.hpBarEmpty);
        }
        healthBar.SetValue(hp, maxHp);
        healthBar.Draw(canvas);

        // HP number overlay on bar
        canvas.TextScaled(16, 12, "${hp}/${maxHp}", hudTextScale(2),
                          pal.white);

        // Score (animated via SmoothValue)
        scoreLabel.SetText("SCORE ${displayScore.get_ValueI64()}");
        scoreLabel.Draw(canvas);

        // Coins with mini icon
        canvas.Disc(620, 14, 7, pal.coinGold);
        canvas.Disc(620, 14, 4, pal.coinDark);
        canvas.Disc(619, 12, 2, 0xFFEE88);
        coinLabel.SetText("x${coins}");
        coinLabel.Draw(canvas);

        // Region identity and expedition details live in the compact extended
        // HUD. Keeping this strip to health/score/currency guarantees a stable
        // top-right status zone at every supported text scale.

        // Power-up indicator bars
        var pxStart = 12;
        var pyStart = 34;
        if speedTimer > 0 {
            drawPowerupBar(canvas, pxStart, pyStart, "SPD", pal.speed,
                          speedTimer, SPEED_DURATION_MS);
            pxStart = pxStart + 100;
        }
        if shieldHits > 0 {
            drawPowerupBar(canvas, pxStart, pyStart, "SHD", pal.shield, 1, 1);
            pxStart = pxStart + 100;
        }
        if rapidTimer > 0 {
            drawPowerupBar(canvas, pxStart, pyStart, "RPD", pal.rapidfire,
                          rapidTimer, RAPIDFIRE_DURATION_MS);
        }
    }

    /// @brief Tiny progress bar showing seconds left on a
    ///        timed pickup (speed boost, rapid fire).  Hidden
    ///        helper called multiple times by `drawHUD` for
    ///        each active powerup.
    hide func drawPowerupBar(canvas: Canvas, x: Integer, y: Integer,
                              label: String, col: Integer,
                              remaining: Integer, maxDur: Integer) {
        var barW = 85;
        var filled = remaining * barW / maxDur;
        if filled < 1 { filled = 1; }
        canvas.BoxAlpha(x, y, barW, 8, pal.black, 120);
        canvas.Box(x, y, filled, 8, col);
        canvas.Frame(x, y, barW, 8, pal.panelBorder);
        canvas.TextScaled(x + 2, y - 1, label, 1, pal.white);
    }

    // Draw boss health bar with Tween-animated damage lerp.
    /// @brief Render the boss HP bar across the top of the
    ///        screen.  Lerps via the Tween instance so a
    ///        damage event slides the bar smoothly instead of
    ///        snapping.  Skips drawing when no boss is active.
    expose func drawBossBar(canvas: Canvas, bossHp: Integer,
                            bossMaxHpVal: Integer, bossName: String) {
        if bossHp <= 0 { return; }

        // Detect HP change — start tween from current to new value
        if bossHp != bossBarTarget {
            bossBarTween.StartI64(bossBarDisplay, bossHp, 200, EASE_OUT_QUAD);
            bossBarTarget = bossHp;
        }
        if bossBarTween.get_IsRunning() == false {
            bossBarDisplay = bossHp;
        }

        // Background behind boss bar
        var barX = (SCREEN_W - 400) / 2;
        canvas.BoxAlpha(barX - 4, 52, 408, 26, pal.black, 200);
        canvas.TextScaled(barX, 38, bossName, hudTextScale(2), pal.bossEye);

        // Update bar value (tweened) and color
        bossBarWidget.SetValue(bossBarDisplay, bossMaxHpVal);
        if bossHp * 3 < bossMaxHpVal {
            bossBarWidget.SetColors(pal.hpBarLow, pal.bossBarEmpty);
        } else if bossHp * 3 < bossMaxHpVal * 2 {
            bossBarWidget.SetColors(pal.hpBarWarn, pal.bossBarEmpty);
        } else {
            bossBarWidget.SetColors(pal.bossBarFill, pal.bossBarEmpty);
        }
        bossBarWidget.Draw(canvas);

        // HP text on bar
        canvas.TextScaled(barX + 170, 58, "${bossHp}/${bossMaxHpVal}",
                          hudTextScale(2), pal.white);
    }

    /// @brief Initialise the boss bar for a new fight.  Game
    ///        calls this when a boss enters the room.  Sets
    ///        the tween to "full" so the first damage tick
    ///        animates from 100%.
    expose func resetBossBar(maxHp: Integer) {
        bossBarDisplay = maxHp;
        bossBarTarget = maxHp;
    }

    // =========================================================================
    // Extended HUD: gems, lore, ability icons, biome name
    // =========================================================================

    /// @brief Optional second-row HUD: ability icons strip,
    ///        gem counter and region identity. Drawn separately so the
    ///        baseline HUD can show even on title screens that
    ///        don't yet need the full strip.
    expose func drawExtendedHud(canvas: Canvas, _pal: Palette,
                                 gems: Integer, loreCollected: Integer, loreTotal: Integer,
                                 currentLevel: Integer, biomeName: String) {
        // Salvage is the only spendable campaign currency. Arcade coins and
        // score remain left-side performance counters and never buy upgrades.
        var gemX = SCREEN_W - 330;
        var gemY = 8;
        // Gem icon (small diamond shape)
        canvas.Triangle(gemX, gemY + 6, gemX - 6, gemY, gemX + 6, gemY,
                        Color.RGB(100, 200, 255));
        canvas.Triangle(gemX, gemY + 6, gemX - 6, gemY + 12, gemX + 6, gemY + 12,
                        Color.RGB(60, 150, 220));
        canvas.Text(gemX + 10, gemY, "SALVAGE ${gems}",
                    Color.RGB(200, 220, 255));

        // Lore progress (small text below gems)
        canvas.Text(SCREEN_W - 158, gemY,
                    "LORE ${loreCollected}/${loreTotal}",
                    Color.RGB(120, 130, 160));

        // Biome name (bottom-left, faded)
        var identityColor = Color.RGB(80, 90, 110);
        if accessibilityHighContrast { identityColor = pal.white; }
        canvas.TextScaled(12, SCREEN_H - 24, biomeName,
                          hudTextScale(1), identityColor);

        // Level number indicator (bottom-left, above biome name)
        canvas.Text(12, SCREEN_H - 40, "Area ${currentLevel}", Color.RGB(100, 110, 130));
    }

    // Mini-map dot (shows player position in level)
    /// @brief Tiny corner mini-map showing the level outline
    ///        and the player's position.  Cheap to draw — one
    ///        rectangle outline + one dot — but huge for
    ///        navigation in big rooms.
    expose func drawMiniMap(canvas: Canvas, _pal: Palette,
                             playerCol: Integer, playerRow: Integer,
                             levelW: Integer, levelH: Integer) {
        // Small rectangle in top-right corner showing level overview
        var mapX = SCREEN_W - 120;
        var mapY = 84;
        var mapW = 110;
        var mapH = 30;

        // Background
        canvas.BoxAlpha(mapX, mapY, mapW, mapH, Color.RGB(0, 0, 20), 140);
        canvas.Frame(mapX, mapY, mapW, mapH, Color.RGB(60, 70, 90));

        // Player dot (scaled to mini-map)
        if levelW > 0 and levelH > 0 {
            var dotX = mapX + playerCol * mapW / levelW;
            var dotY = mapY + playerRow * mapH / levelH;
            // Blink the dot
            canvas.Disc(dotX, dotY, 2, Color.RGB(50, 255, 100));
        }
    }

    // Damage number popup (floating text showing damage dealt)
    /// @brief Floating "+5" / "-2" damage indicators that pop
    ///        out of an entity on hit.  World-space input;
    ///        the caller passes camera-relative coords.
    expose func drawDamageNumber(canvas: Canvas, wx: Integer, wy: Integer,
                                  camX: Integer, camY: Integer,
                                  amount: Integer, timer: Integer) {
        if timer <= 0 { return; }
        var sx = wx - camX;
        var sy = wy - camY - (20 - timer) * 2; // Float upward
        var alpha = timer * 25;
        if alpha > 255 { alpha = 255; }
        var text = Int(amount);
        if amount >= 5 {
            // Critical hit — larger, gold text
            canvas.TextScaled(sx, sy, text, 2, Color.RGB(255, 220, 50));
        } else {
            canvas.Text(sx, sy, text, Color.RGB(255, 255, 255));
        }
    }

    /// @brief Spawn a floating popup at world (wx,wy) into a free pool slot.
    ///        Silently drops if the pool is full (16 concurrent popups).
    expose func spawnPopup(wx: Integer, wy: Integer, amount: Integer) {
        var i = 0;
        while i < popTimer.length() {
            if popTimer.get(i) <= 0 {
                popX.set(i, wx);
                popY.set(i, wy);
                popAmt.set(i, amount);
                popTimer.set(i, 20);
                return;
            }
            i = i + 1;
        }
    }

    /// @brief Tick every active popup's lifetime down one frame (#14).
    expose func updatePopups() {
        var i = 0;
        while i < popTimer.length() {
            if popTimer.get(i) > 0 {
                popTimer.set(i, popTimer.get(i) - 1);
            }
            i = i + 1;
        }
    }

    /// @brief Draw every active popup, camera-relative, via drawDamageNumber.
    expose func drawPopups(canvas: Canvas, camX: Integer, camY: Integer) {
        var i = 0;
        while i < popTimer.length() {
            if popTimer.get(i) > 0 {
                drawDamageNumber(canvas, popX.get(i), popY.get(i), camX, camY,
                                 popAmt.get(i), popTimer.get(i));
            }
            i = i + 1;
        }
    }

    // Power-up timer bars (below health bar)
    /// @brief Stack of powerup countdown bars in the bottom-
    ///        right.  Rebuilt every frame from the player's
    ///        active timer set; no state of its own.
    expose func drawPowerupTimers(canvas: Canvas, _pal: Palette,
                                   speedTimer: Integer, rapidTimer: Integer,
                                   shieldActive: Boolean) {
        var barY = 42;
        var barW = 80;
        var barH = 4;

        if speedTimer > 0 {
            var fill = speedTimer * barW / SPEED_DURATION;
            canvas.Box(10, barY, fill, barH, Color.RGB(50, 200, 255));
            canvas.Frame(10, barY, barW, barH, Color.RGB(30, 100, 140));
            canvas.Text(barW + 14, barY - 2, "SPD", Color.RGB(50, 200, 255));
            barY = barY + 8;
        }

        if rapidTimer > 0 {
            var fill = rapidTimer * barW / RAPIDFIRE_DURATION;
            canvas.Box(10, barY, fill, barH, Color.RGB(255, 150, 50));
            canvas.Frame(10, barY, barW, barH, Color.RGB(140, 80, 30));
            canvas.Text(barW + 14, barY - 2, "RPD", Color.RGB(255, 150, 50));
            barY = barY + 8;
        }

        if shieldActive {
            canvas.Disc(10 + barW / 2, barY + barH / 2, 6, Color.RGB(100, 200, 255));
            canvas.Ring(10 + barW / 2, barY + barH / 2, 6, Color.RGB(200, 240, 255));
            canvas.Text(barW + 14, barY - 2, "SHD", Color.RGB(100, 200, 255));
        }
    }
}
