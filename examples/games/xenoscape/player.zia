//===----------------------------------------------------------------------===//
//
// File: examples/games/xenoscape/player.zia
// Purpose: Owns player movement, health, animation, and active ability state.
// Key invariants:
//   - Ability-dependent input is accepted only when its synchronized bit is set.
//   - Position and velocity use centipixel fixed-point units between collisions.
// Ownership/Lifetime:
//   - Game owns one Player for the full application lifetime.
//   - Player owns its controller, state machine, and physics helper.
// Links: abilities.zia, physics.zia, game.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//
//
// TUTORIAL — A GOOD PLATFORMER CHARACTER
// --------------------------------------
// "Making the character feel good to control" is 80% of a
// platformer's work.  This file is where every design rule that
// shapes that feel gets concrete:
//
//   * **Named states, not booleans.**  A player can be in
//     exactly one of: IDLE, RUN, JUMP, FALL, DJUMP, WALLSLIDE,
//     HURT, DEAD.  We store `state` as a numeric enum and route
//     through `Viper.Game.StateMachine` so the
//     animation/sound/AI layers can cheaply ask "what are you
//     doing right now?" without decoding a pile of booleans.
//
//   * **Viper's PlatformerController does the boring math.**
//     Instead of implementing jump buffers, coyote time,
//     variable jump height, apex hang, acceleration curves
//     from scratch, we delegate to `Viper.Game.PlatformerController`.
//     Tuning `SetJumpForce(full, cut)`, `SetJumpBuffer(ms)`,
//     `SetCoyoteTime(ms)`, `SetApexBonus(threshold, pct)` gives
//     us PlatformerController's behaviour — all the tricks
//     Nintendo, Sega, and Team Cherry invented baked into one
//     runtime class.
//
//     We STILL own gameplay-specific logic: wall jumps, double
//     jump, dash, charge shot, ground pound — because the
//     controller doesn't know about our ability system.
//
//   * **Named input actions, not raw keys.**  `Action.Held(
//     ACT_LEFT)` vs `Keyboard.IsDown(KEY_A)`.  Binds are
//     data-driven (configurable per player) and platform
//     independent (same code reads a gamepad and a keyboard).
//
//   * **Iframes on damage.**  Taking damage grants ~16 frames
//     of invulnerability.  Without this the player can be
//     one-shot by brushing a chain of enemies.
//
//   * **Fixed-point velocity.**  Same ×100 system as
//     `physics.zia` (read that first — it explains why).
//
// WHERE THIS FITS
// ---------------
//     game.zia              ──►  owns the Player, calls
//                                `update(level, dt)` every
//                                tick.
//     physics.zia           ──►  moveAndCollide + ground/wall
//                                checks.
//     Viper.Game.PlatformerController
//                           ──►  acceleration, gravity, jump
//                                buffer / coyote / apex.
//     Viper.Game.StateMachine
//                           ──►  tracks PS_* states, gives us
//                                "frames in this state" for free.
//     Viper.Input.Action     ──► named input bindings.
//     projectile.zia / abilities.zia
//                           ──►  read the player's ability
//                                flags at fire time.
//
// HOW TO READ THIS FILE
// ---------------------
//   1. Fields — position, velocity, state, health, powerups,
//      ability timers.
//   2. `init` / `reset` / `spawn` — three different entry
//      points for the same object, used at construction, room
//      transitions, and checkpoint respawn.
//   3. `update` — the per-frame driver that decrements timers,
//      runs input, physics, animation.
//   4. `handleInput` — PlatformerController hand-off + wall /
//      double jump overrides.
//   5. `applyPhysics` — collision resolve + state transition.
//   6. Ability blocks: dash, charge shot, ground pound, freeze.
//   7. Rendering helpers: `getSpriteFrame`, `pixelX`/`pixelY`.
//
// =============================================================================

module player;

bind Viper.Graphics;
bind Viper.Input;
bind Viper.Game;
bind "./abilities";
bind "./config";
bind "./environment";
bind "./level";
bind "./physics";
bind "./player_animation";

/// @brief Advance the bounded continuous wall-contact grace timer.
///
/// @param currentMs Existing same-contact duration in milliseconds.
/// @param touchingWall Whether this frame resolved against an airborne wall.
/// @param dt Nonnegative clamped simulation delta in milliseconds.
/// @return Zero without contact, otherwise a value in 0..80 milliseconds.
func advanceWallContactTimer(currentMs: Integer, touchingWall: Boolean,
                             dt: Integer) -> Integer {
    if touchingWall == false { return 0; }
    var result = currentMs;
    if result < 0 { result = 0; }
    var elapsed = dt;
    if elapsed < 0 { elapsed = 0; }
    if elapsed > DT_MAX { elapsed = DT_MAX; }
    result = result + elapsed;
    if result > WALL_STICK_GRACE_MS { result = WALL_STICK_GRACE_MS; }
    return result;
}

/// @brief Report whether wall contact has matured into a visible wall slide.
///
/// @param contactMs Continuous wall-contact duration in milliseconds.
/// @return True at exactly 80 ms and thereafter; false during the grace window.
func wallSlideReady(contactMs: Integer) -> Boolean {
    return contactMs >= WALL_STICK_GRACE_MS;
}

/// @brief The player character.  Owns all of the character's
///        position, physics state, health, inventory, and
///        ability state.  Updated once per frame by `Game.tick`.
class Player {
    // ---- Position + velocity (×100 centipixels) ----
    expose Integer x;
    expose Integer y;
    expose Integer vx;
    expose Integer vy;

    // ---- Logical state ----
    expose Integer state;     // one of PS_* (see config.zia)
    expose Integer facing;    // sprite-facing direction: 1=right, -1=left
    expose Boolean onGround;  // set by physics after collide
    expose Boolean onWall;    // touching a wall (for wall-slide / wall-jump)
    expose Integer wallDir;   // -1 if wall is on left, +1 if on right
    hide Integer wallContactTimer;

    // ---- Health ----
    expose Integer hp;
    expose Integer maxHp;
    expose Integer lives;
    expose Integer iframes;   // remaining invulnerability (ms)

    // ---- Jump mechanics ----
    /// "Has the air-jump been spent since last ground contact?"
    /// Reset on landing.  Wall jumps also reset it, giving a
    /// wall-jump-then-double-jump combo.
    expose Boolean canDoubleJump;
    hide Boolean jumpStartedThisFrame;

    // The runtime's platformer controller does the heavy lifting
    // for acceleration curves, gravity, jump buffer, coyote time,
    // apex bonus, variable jump height.  See the design notes.
    hide PlatformerController ctrl;

    // Formal state machine tracking PS_* states.  Its
    // `FramesInState` is useful for animation timing that
    // doesn't interfere with our own `animTimer`.
    hide StateMachine stateMachine;

    // ---- Animation ----
    expose Integer animFrame;
    hide Integer animTimer;
    hide Integer turnAnimTimer;
    hide Integer landingAnimTimer;
    hide Integer shootAnimTimer;
    hide Integer acquisitionAnimTimer;
    hide Integer deathAnimTimer;

    // ---- Power-ups (timers count down in ms) ----
    expose Integer speedTimer;     // temporary sprint
    expose Integer shieldHits;     // absorb N hits then vanish
    expose Integer rapidFireTimer; // halved shoot cooldown

    // ---- Shooting ----
    expose Integer shootCooldown;  // ms until next shot allowed

    // ---- Ability state ----
    expose Boolean isDashing;
    expose Integer dashTimer;
    expose Integer dashVx;
    expose Boolean isPounding;
    expose Integer poundVy;
    expose Integer chargeLevel;    // 0 / 1 / 2 charge-shot level
    expose Integer chargeTimer;
    expose Boolean isCharging;
    expose Integer dashCooldown;
    expose Integer freezeTimer;    // locked out by ice wraith
    expose Boolean isGrappling;
    hide Integer abilityMask;      // synchronized copy of AbilityManager mask
    hide Integer grappleAnchorX;   // whole world pixels
    hide Integer grappleAnchorY;
    hide Integer grappleRopeLength;// whole pixels
    hide Integer chargeTimePercent;
    hide Integer dashCooldownPercent;

    // Dynamic-surface state. One-frame events let Game own audiovisual feedback
    // without reimplementing contact rules.
    hide Integer oneWayDropTimer;
    hide Integer steamCooldown;
    hide Boolean steamWasOnVent;
    hide Boolean steamLaunchedThisFrame;
    hide Boolean crumbleBrokeThisFrame;
    hide Boolean poundLandedThisFrame;

    // Physics helper — one instance shared across this
    // player's lifetime.
    hide PhysicsHelper phys;

    /// @brief First-time setup: allocate the controller with
    ///        tuning constants, register every state with the
    ///        state machine, then reset to start values.
    ///
    /// Tunables come from `config.zia` so a single source
    /// controls the character's feel.
    expose func init() {
        phys = new PhysicsHelper();
        abilityMask = ABILITY_WALL_JUMP;
        chargeTimePercent = 100;
        dashCooldownPercent = 100;

        // Feed tuning constants to the runtime controller.  Each
        // Set*() is a one-shot configuration call — these are
        // fixed for the character's lifetime.
        ctrl = PlatformerController.New();
        ctrl.SetAcceleration(PLAYER_ACCEL, PLAYER_AIR_ACCEL, PLAYER_DECEL);
        ctrl.SetJumpForce(PLAYER_JUMP, PLAYER_JUMP / 2);  // full & cut (variable jump)
        ctrl.SetMaxSpeed(PLAYER_SPEED, PLAYER_SPEED * 3 / 2);  // walk vs sprint
        ctrl.SetGravity(GRAVITY, MAX_FALL);
        ctrl.SetJumpBuffer(JUMP_BUFFER_MS);                // input forgiveness
        ctrl.SetCoyoteTime(COYOTE_MS);                     // "ran off ledge" grace
        ctrl.SetApexBonus(200, 60);                        // apex-hang curve

        // Every PS_* state registered so the state machine can
        // report "frames in state" correctly.
        stateMachine = StateMachine.New();
        stateMachine.AddState(PS_IDLE);
        stateMachine.AddState(PS_RUN);
        stateMachine.AddState(PS_JUMP);
        stateMachine.AddState(PS_FALL);
        stateMachine.AddState(PS_DJUMP);
        stateMachine.AddState(PS_WALLSLIDE);
        stateMachine.AddState(PS_HURT);
        stateMachine.AddState(PS_DEAD);
        stateMachine.SetInitial(PS_IDLE);

        reset();
    }

    /// @brief Back-to-start-of-run state.  Called after death
    ///        and after major transitions.  Does NOT move the
    ///        player — `spawn(x, y)` does that.
    expose func reset() {
        x = 0;
        y = 0;
        vx = 0;
        vy = 0;
        state = PS_IDLE;
        facing = 1;
        onGround = false;
        onWall = false;
        wallDir = 0;
        wallContactTimer = 0;
        hp = PLAYER_MAX_HP;
        maxHp = PLAYER_MAX_HP;
        lives = PLAYER_START_LIVES;
        iframes = 0;
        canDoubleJump = ownsAbility(ABILITY_DOUBLE_JUMP);
        jumpStartedThisFrame = false;
        animFrame = 0;
        animTimer = 0;
        turnAnimTimer = 0;
        landingAnimTimer = 0;
        shootAnimTimer = 0;
        acquisitionAnimTimer = 0;
        deathAnimTimer = 0;
        speedTimer = 0;
        shieldHits = 0;
        rapidFireTimer = 0;
        shootCooldown = 0;
        isDashing = false;
        dashTimer = 0;
        dashVx = 0;
        isPounding = false;
        poundVy = 0;
        chargeLevel = 0;
        chargeTimer = 0;
        isCharging = false;
        dashCooldown = 0;
        freezeTimer = 0;
        isGrappling = false;
        grappleAnchorX = 0;
        grappleAnchorY = 0;
        grappleRopeLength = 0;
        oneWayDropTimer = 0;
        steamCooldown = 0;
        steamWasOnVent = false;
        steamLaunchedThisFrame = false;
        crumbleBrokeThisFrame = false;
        poundLandedThisFrame = false;
        ctrl.VelocityX = 0;
        ctrl.VelocityY = 0;
        stateMachine.SetInitial(PS_IDLE);
    }

    /// @brief Place the player at a tile-grid position.
    ///        Grants a brief iframe window so spawn-collision
    ///        with enemies doesn't immediately hurt us.
    ///
    /// `sx`/`sy` are tile coords; we multiply by 100 (not
    /// TILE_SIZE * 100) because the caller passes already-
    /// converted pixel positions.
    expose func spawn(sx: Integer, sy: Integer) {
        x = sx * 100;
        y = sy * 100;
        vx = 0;
        vy = 0;
        state = PS_IDLE;
        iframes = IFRAMES_MS;
        canDoubleJump = ownsAbility(ABILITY_DOUBLE_JUMP);
        jumpStartedThisFrame = false;
        turnAnimTimer = 0;
        landingAnimTimer = 0;
        shootAnimTimer = 0;
        acquisitionAnimTimer = 0;
        deathAnimTimer = 0;
        oneWayDropTimer = 0;
        wallContactTimer = 0;
        steamCooldown = 0;
        steamWasOnVent = false;
        steamLaunchedThisFrame = false;
        crumbleBrokeThisFrame = false;
        poundLandedThisFrame = false;
        isGrappling = false;
        grappleAnchorX = 0;
        grappleAnchorY = 0;
        grappleRopeLength = 0;
        ctrl.VelocityX = 0;
        ctrl.VelocityY = 0;
    }

    /// @brief Synchronize the campaign ability bitmask used by input handling.
    ///
    /// `AbilityManager` remains the authoritative campaign owner. Player keeps
    /// this bounded copy so its hot input path can gate wall and air movement
    /// without owning persistence. Acquiring Double Jump immediately grants one
    /// aerial use; removing it immediately clears any pending aerial use.
    ///
    /// @param mask Sum of `ABILITY_*` power-of-two flags. Values outside the
    ///             inclusive range 0..63 are clamped defensively.
    /// @return Nothing. Mutates the local synchronized mask and air-jump state.
    expose func setAbilityMask(mask: Integer) {
        var oldHadDouble = ownsAbility(ABILITY_DOUBLE_JUMP);
        var bounded = mask;
        if bounded < 0 { bounded = 0; }
        if bounded > 63 { bounded = 63; }
        abilityMask = bounded;

        if ownsAbility(ABILITY_DOUBLE_JUMP) == false {
            canDoubleJump = false;
        } else if oldHadDouble == false or onGround {
            canDoubleJump = true;
        }
        if ownsAbility(ABILITY_GRAPPLE) == false and isGrappling {
            releaseGrapple();
        }
    }

    /// @brief Return the synchronized ability mask consulted by Player.
    ///
    /// @return A bounded 0..63 sum of `ABILITY_*` flags. The authoritative
    ///         persistent value remains owned by `AbilityManager`.
    expose func getAbilityMask() -> Integer {
        return abilityMask;
    }

    /// @brief Report whether wall-slide and wall-jump input is unlocked.
    ///
    /// @return True only when `ABILITY_WALL_JUMP` is present in the synchronized
    ///         mask. This reports ownership, not current wall contact.
    expose func canUseWallJump() -> Boolean {
        return ownsAbility(ABILITY_WALL_JUMP);
    }

    /// @brief Report whether the campaign has unlocked Double Jump.
    ///
    /// @return True only when `ABILITY_DOUBLE_JUMP` is present. The separate
    ///         `canDoubleJump` field reports whether the current aerial use has
    ///         already been spent.
    expose func canUseDoubleJump() -> Boolean {
        return ownsAbility(ABILITY_DOUBLE_JUMP);
    }

    /// @brief Report whether this frame's input started any successful jump.
    ///
    /// Ground, coyote, wall, and double jumps all set the same one-frame event.
    /// The flag resets at the start of the next live `update` call, allowing
    /// Game to emit one sound/stat event without re-reading consumed input.
    ///
    /// @return True during the update frame in which a jump began.
    expose func didStartJump() -> Boolean {
        return jumpStartedThisFrame;
    }

    /// @brief Report whether a steam vent launched the player this frame.
    ///
    /// @return True for the single update that accepted a new vent-contact
    ///         entry; false while remaining on the vent or during cooldown.
    expose func didLaunchFromSteam() -> Boolean {
        return steamLaunchedThisFrame;
    }

    /// @brief Report whether continuous contact broke a crumble tile this frame.
    ///
    /// @return True only on the update where the 350 ms threshold removed the
    ///         contacted tile; false during warning and regeneration phases.
    expose func didBreakCrumble() -> Boolean {
        return crumbleBrokeThisFrame;
    }

    /// @brief Report whether an armed ground pound hit a floor this frame.
    ///
    /// @return True on the exact collision update that ends a pound; Game uses
    ///         it to break floors, stagger enemies, and emit one impact effect.
    expose func didLandGroundPound() -> Boolean {
        return poundLandedThisFrame;
    }

    /// @brief Report whether one-way floors are currently suppressed.
    ///
    /// @return True while the down+jump drop-through timer remains positive.
    expose func isDroppingThroughOneWay() -> Boolean {
        return oneWayDropTimer > 0;
    }

    /// @brief Test one power-of-two ability flag against the synchronized mask.
    ///
    /// @param flag One nonzero `ABILITY_*` power-of-two value.
    /// @return True when the flag is present; false for zero or missing flags.
    hide func ownsAbility(flag: Integer) -> Boolean {
        if flag <= 0 { return false; }
        return (abilityMask / flag) % 2 == 1;
    }

    /// @brief Apply permanent workbench timing modifiers to active abilities.
    ///
    /// Values are clamped to a safe 50..100 percent range. Updating tuning does
    /// not retroactively shorten an in-progress charge or cooldown; subsequent
    /// thresholds and newly started dashes use the new permanent percentages.
    ///
    /// @param chargePercent Blaster charge-time percentage.
    /// @param cooldownPercent Dash cooldown percentage.
    /// @return Nothing. Stores bounded nonauthoritative tuning derived from upgrades.
    expose func setUpgradeTuning(chargePercent: Integer,
                                 cooldownPercent: Integer) {
        chargeTimePercent = chargePercent;
        dashCooldownPercent = cooldownPercent;
        if chargeTimePercent < 50 { chargeTimePercent = 50; }
        if chargeTimePercent > 100 { chargeTimePercent = 100; }
        if dashCooldownPercent < 50 { dashCooldownPercent = 50; }
        if dashCooldownPercent > 100 { dashCooldownPercent = 100; }
    }

    /// @brief Per-frame driver.  `dt` is elapsed ms (the caller
    ///        clamps to a sensible maximum so a lag spike can't
    ///        tunnel us through walls).
    ///
    /// Order of operations matters:
    ///   1. Decrement ms timers (iframes, powerups, cooldown).
    ///   2. Read input → velocity.
    ///   3. Apply velocity → collide → new position.
    ///   4. Advance animation frame.
    ///
    /// `state == PS_DEAD` short-circuits — we don't want input
    /// or physics moving a dead player; the death animation is
    /// driven elsewhere.
    expose func update(level: Level, dt: Integer) {
        if state == PS_DEAD {
            deathAnimTimer = deathAnimTimer + dt;
            if deathAnimTimer > DEATH_TIMER_MS {
                deathAnimTimer = DEATH_TIMER_MS;
            }
            return;
        }

        updatePresentationAnimationTimers(dt);

        jumpStartedThisFrame = false;
        steamLaunchedThisFrame = false;
        crumbleBrokeThisFrame = false;
        poundLandedThisFrame = false;

        // Tick each ms timer down, clamped at 0.
        if iframes > 0 { iframes = iframes - dt; if iframes < 0 { iframes = 0; } }
        if speedTimer > 0 { speedTimer = speedTimer - dt; if speedTimer < 0 { speedTimer = 0; } }
        if rapidFireTimer > 0 { rapidFireTimer = rapidFireTimer - dt; if rapidFireTimer < 0 { rapidFireTimer = 0; } }
        if shootCooldown > 0 { shootCooldown = shootCooldown - dt; if shootCooldown < 0 { shootCooldown = 0; } }
        if oneWayDropTimer > 0 { oneWayDropTimer = oneWayDropTimer - dt; if oneWayDropTimer < 0 { oneWayDropTimer = 0; } }
        if steamCooldown > 0 { steamCooldown = steamCooldown - dt; if steamCooldown < 0 { steamCooldown = 0; } }

        configureControllerForSurface(level);

        if isFrozen() {
            updateFreeze(dt);
            applyEnvironmentalForces(level, dt);
            applyPhysics(level, dt);
            updateCrumbleContact(level, dt);
            updateAnimation(dt);
            return;
        }

        handleInput(level, dt);
        updateGrappleForces(level, dt);
        applyPhysics(level, dt);
        updateCrumbleContact(level, dt);
        updateAnimation(dt);
    }

    /// @brief Apply current surface modifiers to the reusable controller.
    ///
    /// Controller tuning is refreshed every frame because contact can change at
    /// a tile boundary. Ice changes only deceleration; quicksand changes walk,
    /// sprint, full-jump, and jump-cut magnitudes. No campaign state is mutated.
    ///
    /// @param level Active level sampled at the player's center foot point.
    hide func configureControllerForSurface(level: Level) {
        var onIce = phys.isOnIce(x, y, PLAYER_W, PLAYER_H, level);
        var inQuicksand = phys.isInQuicksand(x, y, PLAYER_W, PLAYER_H, level);
        ctrl.SetAcceleration(PLAYER_ACCEL, PLAYER_AIR_ACCEL,
                             environmentalGroundDeceleration(onIce));
        ctrl.SetMaxSpeed(environmentalMaxSpeed(inQuicksand, false),
                         environmentalMaxSpeed(inQuicksand, true));
        ctrl.SetJumpForce(environmentalJumpImpulse(inQuicksand),
                          environmentalJumpCutImpulse(inQuicksand));
    }

    /// @brief Sample input, feed the PlatformerController, then
    ///        apply game-specific jump overrides (wall jump,
    ///        double jump).
    ///
    /// The controller handles:
    ///   * acceleration / deceleration curves
    ///   * gravity + apex hang
    ///   * jump buffer (press before landing → jump on landing)
    ///   * coyote time (press after walking off edge → still jump)
    ///   * variable-height jump (release early → small jump)
    ///
    /// We layer on:
    ///   * wall jump: push off the wall
    ///   * double jump: second airborne impulse if unused
    ///   * wall slide: cap fall speed while hugging a wall
    ///   * shoot cooldown scheduling
    hide func handleInput(level: Level, dt: Integer) {
        var inputLeft = Action.Held(ACT_LEFT);
        var inputRight = Action.Held(ACT_RIGHT);
        var jumpPressed = Action.Pressed(ACT_JUMP);
        var jumpHeld = Action.Held(ACT_JUMP);
        var sprint = (speedTimer > 0);

        // Down+jump is consumed only when standing on a one-way tile. Ordinary
        // ground therefore retains normal jump behavior with the same binding.
        if jumpPressed and Action.Held(ACT_MOVE_DOWN) and onGround and
           phys.isOnOneWay(x, y, PLAYER_W, PLAYER_H, level) {
            oneWayDropTimer = ONE_WAY_DROP_MS;
            jumpPressed = false;
            jumpHeld = false;
            onGround = false;
            vy = 100;
            ctrl.VelocityY = vy;
        }

        // Let the controller apply acceleration, gravity, etc.
        ctrl.Update(dt, inputLeft, inputRight, jumpPressed, jumpHeld, onGround, sprint);

        // Pull processed velocity back out of the controller so
        // the rest of this file can read/override vx/vy.
        vx = ctrl.VelocityX;
        vy = ctrl.VelocityY;
        if ctrl.IsMoving {
            var nextFacing = ctrl.Facing;
            if nextFacing != facing {
                turnAnimTimer = PLAYER_TURN_ANIM_MS;
            }
            facing = nextFacing;
        }

        if ctrl.ShouldJump {
            // Controller says "jump now" (ground or coyote).
            var inQuicksand = phys.isInQuicksand(x, y, PLAYER_W, PLAYER_H, level);
            vy = environmentalJumpImpulse(inQuicksand);
            ctrl.VelocityY = vy;
            onGround = false;
            canDoubleJump = ownsAbility(ABILITY_DOUBLE_JUMP);
            state = PS_JUMP;
            jumpStartedThisFrame = true;
        } else if jumpPressed {
            // Controller declined — try our game-specific
            // alternates.
            if onWall and ownsAbility(ABILITY_WALL_JUMP) {
                // Wall jump: angle-away + vertical impulse.
                vy = WALL_JUMP_VY;
                vx = 0 - wallDir * WALL_JUMP_VX;
                facing = 0 - wallDir;        // flip to face away
                ctrl.VelocityX = vx;
                ctrl.VelocityY = vy;
                onWall = false;
                canDoubleJump = ownsAbility(ABILITY_DOUBLE_JUMP);
                state = PS_JUMP;
                jumpStartedThisFrame = true;
            } else if ownsAbility(ABILITY_DOUBLE_JUMP) and canDoubleJump and not onGround {
                // Double jump: smaller impulse, spent once per
                // airtime.
                vy = PLAYER_DJUMP;
                ctrl.VelocityY = vy;
                canDoubleJump = false;
                state = PS_DJUMP;
                jumpStartedThisFrame = true;
            }
        }

        // Wall-slide cap: falling against a wall reads as
        // slowly-sliding rather than plummeting.
        if ownsAbility(ABILITY_WALL_JUMP) and onWall and
           wallSlideReady(wallContactTimer) and vy > WALL_SLIDE_SPEED {
            vy = WALL_SLIDE_SPEED;
            ctrl.VelocityY = vy;
        }

        // Schedule the next bullet.  `wantsToShoot()` is the
        // "just fired" observer the game loop reads later.
        if Action.Pressed(ACT_SHOOT) and
           ownsAbility(ABILITY_CHARGE_SHOT) == false {
            if shootCooldown <= 0 {
                shootCooldown = SHOOT_COOLDOWN_MS;
                shootAnimTimer = PLAYER_SHOOT_ANIM_MS;
                if rapidFireTimer > 0 {
                    shootCooldown = SHOOT_COOLDOWN_MS / 2;
                }
            }
        }

        applyEnvironmentalForces(level, dt);
    }

    /// @brief Apply conveyor and steam forces after ordinary controller input.
    ///
    /// Conveyor push is frame-scaled and bounded, and does not clamp an active
    /// dash. Steam uses contact-entry state plus a cooldown; accepted launches
    /// synchronize public and controller velocity and raise a one-frame event
    /// for Game-owned sound and particles.
    ///
    /// @param level Active level sampled for conveyor and vent properties.
    /// @param dt Elapsed simulation time in milliseconds.
    hide func applyEnvironmentalForces(level: Level, dt: Integer) {
        var conveyor = phys.getConveyorDir(x, y, PLAYER_W, PLAYER_H, level);
        if conveyor != 0 and isDashing == false {
            vx = environmentalConveyorVelocity(vx, conveyor, dt);
            ctrl.VelocityX = vx;
        }

        var onVent = phys.isOnSteamVent(x, y, PLAYER_W, PLAYER_H, level);
        if environmentalShouldLaunchSteam(onVent, steamWasOnVent,
                                          steamCooldown) {
            vy = STEAM_LAUNCH_VY;
            ctrl.VelocityY = vy;
            onGround = false;
            state = PS_JUMP;
            steamCooldown = STEAM_RETRIGGER_MS;
            steamLaunchedThisFrame = true;
        }
        steamWasOnVent = onVent;
    }

    /// @brief Apply vx/vy to (x, y), resolve tile collisions,
    ///        and transition PS_* state based on outcome.
    ///
    /// Displacement is scaled `vx * dt / DT_BASE` so we step a
    /// 16ms frame by one "unit" of velocity and a 32ms lag-
    /// spike frame by two units — frame-rate independent.
    ///
    /// After collide:
    ///   * Zero vx/vy on the axis that hit (and sync back to
    ///     the controller — otherwise it thinks the character
    ///     is still moving into the wall).
    ///   * Compute onGround / onWall / wallDir from the result.
    ///   * Choose PS_* state from (onGround, onWall, vy sign)
    ///     unless we're in HURT.
    ///   * Falling off the bottom of the level kills.
    hide func applyPhysics(level: Level, dt: Integer) {
        var wasGrounded = onGround;
        var dispX = vx * dt / DT_BASE;
        var dispY = vy * dt / DT_BASE;

        var result = phys.movePlayerAndCollide(
            x, y, dispX, dispY, PLAYER_W, PLAYER_H, level,
            oneWayDropTimer > 0);

        x = result.x;
        y = result.y;
        // Cancel velocity on any hit, and mirror into the
        // controller so it doesn't re-accelerate into the wall
        // next frame.
        if result.hitLeft { vx = 0; ctrl.VelocityX = 0; }
        if result.hitRight { vx = 0; ctrl.VelocityX = 0; }
        if result.hitFloor { vy = 0; ctrl.VelocityY = 0; }
        if result.hitCeiling { vy = 0; ctrl.VelocityY = 0; }
        constrainGrapple();

        onGround = result.hitFloor;
        if onGround and wasGrounded == false and vy >= 0 {
            landingAnimTimer = PLAYER_LAND_ANIM_MS;
        }

        if result.hitFloor and isPounding {
            isPounding = false;
            poundVy = 0;
            poundLandedThisFrame = true;
        }

        // Landing: restore the double jump.
        if onGround {
            canDoubleJump = ownsAbility(ABILITY_DOUBLE_JUMP);
        }

        // Wall detection — only meaningful while airborne.
        onWall = false;
        wallDir = 0;
        if onGround == false {
            if result.hitLeft {
                onWall = true;
                wallDir = -1;
            }
            if result.hitRight {
                onWall = true;
                wallDir = 1;
            }
        }
        wallContactTimer = advanceWallContactTimer(
            wallContactTimer, onWall, dt);

        // Decide state.  HURT is exclusive until iframes expire.
        if state != PS_HURT and iframes <= 0 {
            if onGround {
                if vx == 0 {
                    state = PS_IDLE;
                } else {
                    state = PS_RUN;
                }
            } else {
                if onWall and wallSlideReady(wallContactTimer) {
                    state = PS_WALLSLIDE;
                } else {
                    if vy < 0 {
                        // Only switch to PS_JUMP if we weren't
                        // already in PS_DJUMP (so the double-
                        // jump animation plays out).
                        if state != PS_DJUMP {
                            state = PS_JUMP;
                        }
                    } else {
                        state = PS_FALL;
                    }
                }
            }
        }
        stateMachine.Transition(state);
        stateMachine.Update();

        // Bottomless-pit death.
        if y > levelHeight() * TILE_SIZE * 100 {
            die();
        }
    }

    /// @brief Forward grounded crumble contact into Level's dynamic-tile state.
    ///
    /// The center-foot tile is touched only after collision has established a
    /// grounded state. Level owns contact accumulation and regeneration; Player
    /// records only the one-frame break event used for feedback.
    ///
    /// @param level Mutable active level containing crumble records.
    /// @param dt Elapsed contact time in milliseconds.
    hide func updateCrumbleContact(level: Level, dt: Integer) {
        if onGround == false { return; }
        var col = (pixelX() + PLAYER_W / 2) / TILE_SIZE;
        var row = (pixelY() + PLAYER_H + 2) / TILE_SIZE;
        if level.touchCrumble(col, row, dt) == 2 {
            crumbleBrokeThisFrame = true;
        }
    }

    /// @brief Shortcut for the level's tile height.  Kept as a
    ///        method so future multi-level rooms can override
    ///        it without touching the fall-out check above.
    hide func levelHeight() -> Integer {
        return LEVEL_HEIGHT;
    }

    /// @brief Advance the sprite-frame timer.  IDLE alternates
    ///        2 frames; RUN cycles 6.  Other states use a
    ///        single fixed frame and don't need timing.
    hide func updateAnimation(dt: Integer) {
        animTimer = animTimer + dt;
        if state == PS_IDLE {
            if animFrame < 0 or animFrame > 1 { animFrame = 0; }
            if animTimer >= ANIM_IDLE_MS {
                animTimer = 0;
                animFrame = 1 - animFrame;
            }
        }
        if state == PS_RUN {
            if animFrame < 0 or
               animFrame >= playerAnimationFrameCount(PLAYER_ANIM_RUN) {
                animFrame = 0;
            }
            if animTimer >= ANIM_RUN_MS {
                animTimer = 0;
                animFrame = animFrame + 1;
                if animFrame >= playerAnimationFrameCount(PLAYER_ANIM_RUN) {
                    animFrame = 0;
                }
            }
        }
    }

    /// @brief Decrement short presentation-only animation envelopes.
    ///
    /// @param dt Nonnegative clamped live-simulation milliseconds.
    /// @return Nothing. Timers never become negative and own no gameplay rules.
    hide func updatePresentationAnimationTimers(dt: Integer) {
        var elapsed = dt;
        if elapsed < 0 { elapsed = 0; }
        if elapsed > DT_MAX { elapsed = DT_MAX; }
        if turnAnimTimer > 0 {
            turnAnimTimer = turnAnimTimer - elapsed;
            if turnAnimTimer < 0 { turnAnimTimer = 0; }
        }
        if landingAnimTimer > 0 {
            landingAnimTimer = landingAnimTimer - elapsed;
            if landingAnimTimer < 0 { landingAnimTimer = 0; }
        }
        if shootAnimTimer > 0 {
            shootAnimTimer = shootAnimTimer - elapsed;
            if shootAnimTimer < 0 { shootAnimTimer = 0; }
        }
        if acquisitionAnimTimer > 0 {
            acquisitionAnimTimer = acquisitionAnimTimer - elapsed;
            if acquisitionAnimTimer < 0 { acquisitionAnimTimer = 0; }
        }
    }

    /// @brief "Did the player fire this frame?"  Read by
    ///        `game.tick` to decide whether to call
    ///        `ProjectilePool.fire`.
    ///
    /// We flip true the *exact* frame the cooldown was just
    /// reset to its full value — on rapid-fire the half-value
    /// is the fire frame.  Later frames read false until the
    /// next shot.
    expose func wantsToShoot() -> Boolean {
        if shootCooldown == SHOOT_COOLDOWN_MS {
            return true;
        }
        if rapidFireTimer > 0 {
            if shootCooldown == SHOOT_COOLDOWN_MS / 2 {
                return true;
            }
        }
        return false;
    }

    /// @brief Apply damage.  Shield absorbs before HP drops;
    ///        iframes prevent rapid chip-damage.
    ///
    /// Also nudges the player upward (`vy = -450`) so they
    /// "bounce" off the hurter — classic Mario-style knockback.
    expose func takeDamage(amount: Integer) {
        if iframes > 0 { return; }
        if state == PS_DEAD { return; }

        if shieldHits > 0 {
            shieldHits = shieldHits - 1;
            iframes = 480;  // half-second of protection after absorbing
            return;
        }

        hp = hp - amount;
        iframes = IFRAMES_MS;
        state = PS_HURT;
        vy = -450;
        ctrl.VelocityY = vy;

        if hp <= 0 {
            die();
        }
    }

    /// @brief Enter the death state — a little upward pop plus
    ///        zero horizontal motion.  Game.tick watches for
    ///        PS_DEAD and handles the respawn logic.
    hide func die() {
        state = PS_DEAD;
        hp = 0;
        vx = 0;
        vy = -600;
        ctrl.VelocityX = 0;
        ctrl.VelocityY = vy;
    }

    /// @brief Apply a pickup's effect.  See `pickups.zia` for
    ///        the enum, but in short: health restore, speed
    ///        boost, one-hit shield, or rapid-fire window.
    expose func collectPowerUp(ptype: Integer) {
        if ptype == PICKUP_HEALTH {
            hp = hp + 1;
            if hp > maxHp { hp = maxHp; }
        }
        if ptype == PICKUP_SPEED {
            speedTimer = SPEED_DURATION_MS;
        }
        if ptype == PICKUP_SHIELD {
            shieldHits = 1;
        }
        if ptype == PICKUP_RAPIDFIRE {
            rapidFireTimer = RAPIDFIRE_DURATION_MS;
        }
    }

    /// @brief Pick the release-sheet frame for state and presentation envelopes.
    ///
    /// Priority prevents contradictory silhouettes: death, acquisition, active
    /// abilities, firing, landing, turning, then the locomotion state. Every
    /// returned index is defined by `player_animation.zia` and remains below the
    /// fixed 41-frame sheet size.
    ///
    /// @return Absolute player sheet index in 0..40.
    expose func getSpriteFrame() -> Integer {
        if state == PS_DEAD {
            return playerSheetFrame(
                PLAYER_ANIM_DEATH,
                deathAnimTimer * playerAnimationFrameCount(PLAYER_ANIM_DEATH) /
                DEATH_TIMER_MS);
        }
        if acquisitionAnimTimer > 0 {
            return playerSheetFrame(
                PLAYER_ANIM_ACQUIRE,
                playerTimedAnimationFrame(
                    acquisitionAnimTimer, PLAYER_ACQUIRE_ANIM_MS,
                    playerAnimationFrameCount(PLAYER_ANIM_ACQUIRE)));
        }
        if state == PS_HURT {
            return playerSheetFrame(PLAYER_ANIM_HURT,
                                    (iframes / 80) % 2);
        }
        if isPounding {
            return playerSheetFrame(PLAYER_ANIM_POUND,
                                    (animTimer / 80) % 2);
        }
        if isGrappling {
            return playerSheetFrame(PLAYER_ANIM_GRAPPLE,
                                    (animTimer / 100) % 2);
        }
        if isDashing {
            return playerSheetFrame(PLAYER_ANIM_DASH,
                                    (dashTimer / 80) % 2);
        }
        if isCharging {
            return playerSheetFrame(PLAYER_ANIM_CHARGE,
                                    (chargeTimer / 100) % 2);
        }
        if shootAnimTimer > 0 {
            return playerSheetFrame(
                PLAYER_ANIM_SHOOT,
                playerTimedAnimationFrame(
                    shootAnimTimer, PLAYER_SHOOT_ANIM_MS,
                    playerAnimationFrameCount(PLAYER_ANIM_SHOOT)));
        }
        if landingAnimTimer > 0 and onGround {
            return playerSheetFrame(
                PLAYER_ANIM_LAND,
                playerTimedAnimationFrame(
                    landingAnimTimer, PLAYER_LAND_ANIM_MS,
                    playerAnimationFrameCount(PLAYER_ANIM_LAND)));
        }
        if turnAnimTimer > 0 {
            return playerSheetFrame(
                PLAYER_ANIM_TURN,
                playerTimedAnimationFrame(
                    turnAnimTimer, PLAYER_TURN_ANIM_MS,
                    playerAnimationFrameCount(PLAYER_ANIM_TURN)));
        }
        if state == PS_IDLE {
            return playerSheetFrame(PLAYER_ANIM_IDLE, animFrame);
        }
        if state == PS_RUN {
            return playerSheetFrame(PLAYER_ANIM_RUN, animFrame);
        }
        if state == PS_JUMP { return PLAYER_FRAME_JUMP_BASE; }
        if state == PS_FALL { return PLAYER_FRAME_FALL_BASE; }
        if state == PS_DJUMP { return PLAYER_FRAME_DOUBLE_JUMP_BASE; }
        if state == PS_WALLSLIDE { return PLAYER_FRAME_WALL_SLIDE_BASE; }
        return PLAYER_FRAME_IDLE_BASE;
    }

    /// @brief Restart the four-frame weapon recoil/muzzle animation.
    ///
    /// Game calls this only after a projectile pool slot is actually acquired, so
    /// saturated pools never show a false firing pose.
    ///
    /// @return Nothing. Mutates presentation timer only.
    expose func startShootAnimation() {
        shootAnimTimer = PLAYER_SHOOT_ANIM_MS;
    }

    /// @brief Hold the four-frame acquisition pose through the reward transition.
    ///
    /// @return Nothing. Mutates presentation timer only and does not grant power.
    expose func startAcquisitionAnimation() {
        acquisitionAnimTimer = PLAYER_ACQUIRE_ANIM_MS;
    }

    /// @brief Push our current vx/vy into the controller.
    ///        Call this after any game-event that mutates
    ///        velocity (e.g. knockback), otherwise the
    ///        controller's internal state drifts.
    expose func syncVelocity() {
        ctrl.VelocityX = vx;
        ctrl.VelocityY = vy;
    }

    // -------- Pixel accessors for drawing and collision --------
    /// @brief x in whole pixels (for canvas.Blit).
    expose func pixelX() -> Integer { return x / 100; }
    /// @brief y in whole pixels.
    expose func pixelY() -> Integer { return y / 100; }
    /// @brief Horizontal centre in pixels (camera follow).
    expose func centerX() -> Integer { return x / 100 + PLAYER_W / 2; }
    /// @brief Vertical centre in pixels.
    expose func centerY() -> Integer { return y / 100 + PLAYER_H / 2; }

    //=========================================================================
    // ABILITY: DASH
    //=========================================================================
    //
    // A ~160ms horizontal burst.  Grants iframes for its
    // duration so the dash doubles as a panic button.
    // Cooldown prevents spam; players quickly learn to
    // *save* the dash for moments that matter.

    /// @brief Attempt to begin a dash in the current facing direction.
    ///
    /// The request is rejected while Dash is locked, a dash/cooldown is active,
    /// the player is frozen, or the player is hurt/dead. A successful request
    /// grants dash-duration invulnerability and initializes the velocity burst.
    ///
    /// @return True only when a new dash started and feedback/stat events should
    ///         be emitted by Game; false leaves dash state unchanged.
    expose func startDash() -> Boolean {
        if ownsAbility(ABILITY_DASH) == false { return false; }
        if isDashing or dashCooldown > 0 { return false; }
        if isFrozen() or state == PS_HURT or state == PS_DEAD { return false; }
        isDashing = true;
        dashTimer = 160;
        dashCooldown = 480 * dashCooldownPercent / 100;
        dashVx = facing * 2000;
        iframes = 160;
        return true;
    }

    /// @brief Per-frame dash driver.  While `isDashing`, we
    ///        force vx to the dash velocity and vy to 0 so the
    ///        dash is a flat horizontal line regardless of
    ///        falling momentum.
    expose func updateDash(dt: Integer) {
        if dashCooldown > 0 { dashCooldown = dashCooldown - dt; }
        if not isDashing { return; }
        dashTimer = dashTimer - dt;
        if dashTimer <= 0 {
            isDashing = false;
            dashVx = 0;
        } else {
            vx = dashVx;
            vy = 0;
            ctrl.VelocityX = vx;
            ctrl.VelocityY = vy;
        }
    }

    //=========================================================================
    // ABILITY: CHARGE SHOT
    //=========================================================================
    //
    // Hold the shoot button to charge, release for a bigger
    // bullet.  Two tiers: partial (320 ms) and full (640 ms).
    // The projectile layer reads `chargeLevel` via
    // `fireCharged` and scales speed + damage + visuals.

    /// @brief Attempt to start a charge-shot wind-up.
    ///
    /// @return True when Charge Shot is unlocked and a new charge begins; false
    ///         when locked, already charging, frozen, hurt, or dead. A false
    ///         result does not reset an existing timer or charge level.
    expose func startCharge() -> Boolean {
        if ownsAbility(ABILITY_CHARGE_SHOT) == false { return false; }
        if isCharging or isFrozen() { return false; }
        if state == PS_HURT or state == PS_DEAD { return false; }
        isCharging = true;
        chargeTimer = 0;
        chargeLevel = 0;
        return true;
    }

    /// @brief Advance charge timer.  Thresholds are hand-tuned:
    ///        320 ms feels like "a beat" to a player, 640 ms
    ///        like "twice a beat" — comfortable thumb input.
    expose func updateCharge(dt: Integer) {
        if not isCharging { return; }
        chargeTimer = chargeTimer + dt;
        var partialThreshold = 320 * chargeTimePercent / 100;
        var fullThreshold = 640 * chargeTimePercent / 100;
        if chargeTimer >= fullThreshold { chargeLevel = 2; }
        else if chargeTimer >= partialThreshold { chargeLevel = 1; }
    }

    /// @brief Release the charge, return the level (0/1/2) to
    ///        the caller so projectile.zia can spawn the right
    ///        bullet.
    expose func releaseCharge() -> Integer {
        if not isCharging { return 0; }
        isCharging = false;
        var level = chargeLevel;
        chargeTimer = 0;
        chargeLevel = 0;
        return level;
    }

    //=========================================================================
    // ABILITY: GRAPPLE
    //=========================================================================

    /// @brief Attach to the nearest visible authored grapple anchor.
    ///
    /// The request is rejected while locked, already attached, frozen, hurt, or
    /// dead, and when Level cannot find a line-of-sight anchor within 384 pixels.
    /// Rope length starts at the current distance and is bounded by the 448-pixel
    /// release contract. No velocity is discarded on a successful attachment.
    ///
    /// @param level Active level searched for authored anchor tiles.
    /// @return True when a new rope was attached; false without state mutation.
    expose func startGrapple(level: Level) -> Boolean {
        if ownsAbility(ABILITY_GRAPPLE) == false { return false; }
        if isGrappling or isFrozen() { return false; }
        if state == PS_HURT or state == PS_DEAD { return false; }

        var key = level.findNearestGrappleAnchor(
            centerX(), centerY(), GRAPPLE_ACQUIRE_RADIUS);
        if key < 0 { return false; }
        var col = key % level.levelWidth;
        var row = key / level.levelWidth;
        grappleAnchorX = col * TILE_SIZE + TILE_SIZE / 2;
        grappleAnchorY = row * TILE_SIZE + TILE_SIZE / 2;
        var dx = grappleAnchorX - centerX();
        var dy = grappleAnchorY - centerY();
        grappleRopeLength = environmentalIntegerSqrt(dx * dx + dy * dy);
        if grappleRopeLength < 1 { grappleRopeLength = 1; }
        if grappleRopeLength > GRAPPLE_MAX_ROPE_LENGTH {
            grappleRopeLength = GRAPPLE_MAX_ROPE_LENGTH;
        }
        isGrappling = true;
        onGround = false;
        return true;
    }

    /// @brief Release the active rope while preserving bounded swing momentum.
    ///
    /// @return True when an attachment was released. False means no rope was
    ///         active; velocity and controller state remain unchanged.
    expose func releaseGrapple() -> Boolean {
        if isGrappling == false { return false; }
        isGrappling = false;
        grappleAnchorX = 0;
        grappleAnchorY = 0;
        grappleRopeLength = 0;
        vx = environmentalClampGrappleVelocity(vx);
        vy = environmentalClampGrappleVelocity(vy);
        ctrl.VelocityX = vx;
        ctrl.VelocityY = vy;
        return true;
    }

    /// @brief Apply rope pull and player-controlled tangential swing acceleration.
    ///
    /// The anchor must remain authored and within line-of-sight at acquisition;
    /// removing it later safely releases the rope. Pull increases near full rope
    /// extension, while left/right input accelerates along the perpendicular
    /// tangent. Integer normalization keeps behavior deterministic.
    ///
    /// @param level Active level used to validate the retained anchor tile.
    /// @param dt Elapsed simulation time in milliseconds.
    hide func updateGrappleForces(level: Level, dt: Integer) {
        if isGrappling == false { return; }
        var col = grappleAnchorX / TILE_SIZE;
        var row = grappleAnchorY / TILE_SIZE;
        if level.getTile(col, row) != TILE_GRAPPLE_ANCHOR {
            releaseGrapple();
            return;
        }

        var dx = grappleAnchorX * 100 - (x + PLAYER_W * 50);
        var dy = grappleAnchorY * 100 - (y + PLAYER_H * 50);
        var distance = environmentalIntegerSqrt(dx * dx + dy * dy);
        if distance <= 0 { return; }
        var elapsed = dt;
        if elapsed < 0 { elapsed = 0; }

        if distance >= grappleRopeLength * 90 {
            vx = vx + dx * GRAPPLE_PULL_ACCEL * elapsed /
                      distance / DT_BASE;
            vy = vy + dy * GRAPPLE_PULL_ACCEL * elapsed /
                      distance / DT_BASE;
        }

        var swing = 0;
        if Action.Held(ACT_LEFT) { swing = -1; }
        if Action.Held(ACT_RIGHT) { swing = 1; }
        if swing != 0 {
            vx = vx + (0 - dy) * swing * GRAPPLE_TANGENT_ACCEL * elapsed /
                      distance / DT_BASE;
            vy = vy + dx * swing * GRAPPLE_TANGENT_ACCEL * elapsed /
                      distance / DT_BASE;
        }
        vx = environmentalClampGrappleVelocity(vx);
        vy = environmentalClampGrappleVelocity(vy);
        ctrl.VelocityX = vx;
        ctrl.VelocityY = vy;
    }

    /// @brief Constrain the player's center to the active maximum rope length.
    ///
    /// Position correction removes only outward radial velocity, preserving the
    /// tangential component that makes release momentum expressive. The anchor
    /// acquisition radius is below maximum rope length, so correction normally
    /// occurs only after gravity or player swing extends the rope.
    ///
    /// @return Nothing. Mutates position/velocity only while overextended.
    hide func constrainGrapple() {
        if isGrappling == false { return; }
        var center100X = x + PLAYER_W * 50;
        var center100Y = y + PLAYER_H * 50;
        var anchor100X = grappleAnchorX * 100;
        var anchor100Y = grappleAnchorY * 100;
        var offsetX = center100X - anchor100X;
        var offsetY = center100Y - anchor100Y;
        var distance = environmentalIntegerSqrt(
            offsetX * offsetX + offsetY * offsetY);
        var maximum = grappleRopeLength * 100;
        if distance <= maximum or distance <= 0 { return; }

        center100X = anchor100X + offsetX * maximum / distance;
        center100Y = anchor100Y + offsetY * maximum / distance;
        x = center100X - PLAYER_W * 50;
        y = center100Y - PLAYER_H * 50;

        var radialDot = vx * offsetX + vy * offsetY;
        if radialDot > 0 {
            var squared = distance * distance;
            vx = vx - radialDot * offsetX / squared;
            vy = vy - radialDot * offsetY / squared;
            ctrl.VelocityX = vx;
            ctrl.VelocityY = vy;
        }
    }

    /// @brief Read active grapple anchor x for rope rendering.
    ///
    /// @return Whole world-pixel x, or zero when detached.
    expose func getGrappleAnchorX() -> Integer { return grappleAnchorX; }

    /// @brief Read active grapple anchor y for rope rendering.
    ///
    /// @return Whole world-pixel y, or zero when detached.
    expose func getGrappleAnchorY() -> Integer { return grappleAnchorY; }

    /// @brief Read current fixed rope length for HUD/debug rendering.
    ///
    /// @return Whole pixels in 1..448 while attached, otherwise zero.
    expose func getGrappleRopeLength() -> Integer { return grappleRopeLength; }

    //=========================================================================
    // ABILITY: GROUND POUND
    //=========================================================================
    //
    // Slam downward from the air, stopping horizontal motion.
    // Landing produces a shockwave (handled elsewhere — we
    // just clear the flag).

    /// @brief Attempt to start a vertical Ground Pound while airborne.
    ///
    /// A successful request cancels horizontal movement and arms the fixed
    /// downward velocity consumed by `updatePound`. Locked, grounded, duplicate,
    /// frozen, hurt, and dead requests are rejected without state mutation.
    ///
    /// @return True only when a new pound started and Game should emit its stat
    ///         event; false when any prerequisite is not satisfied.
    expose func startPound() -> Boolean {
        if ownsAbility(ABILITY_GROUND_POUND) == false { return false; }
        if onGround or isPounding or isFrozen() { return false; }
        if state == PS_DEAD or state == PS_HURT { return false; }
        isPounding = true;
        poundVy = 2500;
        vx = 0;
        ctrl.VelocityX = 0;
        return true;
    }

    /// @brief Per-frame driver: stay at pound velocity until
    ///        we land, then clear the flag.
    expose func updatePound(_dt: Integer) {
        if not isPounding { return; }
        vy = poundVy;
        ctrl.VelocityY = vy;
        if onGround {
            isPounding = false;
            poundVy = 0;
        }
    }

    //=========================================================================
    // STATUS: FROZEN
    //=========================================================================
    //
    // Ice-wraith enemies can freeze the player for a short
    // window.  While frozen, vx is pinned to 0 and input is
    // ignored (callers check `isFrozen()` to skip input).

    /// @brief Begin freeze.  Wipes velocity so the player
    ///        doesn't slide while frozen.
    expose func freeze(durationMs: Integer) {
        if isGrappling { releaseGrapple(); }
        freezeTimer = durationMs;
        vx = 0;
        vy = 0;
        ctrl.VelocityX = 0;
        ctrl.VelocityY = 0;
    }

    /// @brief Per-frame freeze-timer decrement.  Returns true
    ///        while still frozen so callers can early-exit.
    expose func updateFreeze(dt: Integer) -> Boolean {
        if freezeTimer <= 0 { return false; }
        freezeTimer = freezeTimer - dt;
        vx = 0;
        ctrl.VelocityX = 0;
        return true;
    }

    /// @brief Is the player currently locked by ice?
    expose func isFrozen() -> Boolean { return freezeTimer > 0; }

    /// @brief Frames spent in the current state — routed from
    ///        the StateMachine.  Useful for state-gated
    ///        animation tweaks (e.g. "eye-blink after 3s of
    ///        PS_IDLE").
    expose func stateFrames() -> Integer { return stateMachine.get_FramesInState(); }
}
