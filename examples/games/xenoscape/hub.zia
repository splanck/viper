//
// File: examples/games/xenoscape/hub.zia
// Purpose: Implements the evolving shipwreck hub and its five station menus.
// Key invariants:
//   - Main stations remain Map, Workbench, Archive, Simulator, and Launch.
//   - Hub UI mutates only local selection; Game owns purchases and transitions.
// Ownership/Lifetime:
//   - Game owns one HubSystem; it owns no external resources beyond Palette ref.
// Links: economy.zia, difficulty.zia, game.zia, worldmap.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module hub;

bind Zanna.Graphics;
bind Zanna.Input;
bind Zanna.Text.Fmt;
bind "./accessibility";
bind "./config";
bind "./difficulty";
bind "./economy";
bind "./palette";

final HUB_MODE_MAIN = 0;
final HUB_MODE_MAP = 1;
final HUB_MODE_WORKBENCH = 2;
final HUB_MODE_ARCHIVE = 3;
final HUB_MODE_SIMULATOR = 4;

final HUB_ACTION_NONE = 0;
final HUB_ACTION_LAUNCH = 1;
final HUB_ACTION_PURCHASE_BASE = 100;
final HUB_ACTION_DIFFICULTY_DOWN = 200;
final HUB_ACTION_DIFFICULTY_UP = 201;
final HUB_ACTION_ROUTE_PREVIOUS = 210;
final HUB_ACTION_ROUTE_NEXT = 211;
final HUB_ACTION_ROUTE_SELECT = 212;
final HUB_ACTION_TIME_TRIAL_PREVIOUS = 220;
final HUB_ACTION_TIME_TRIAL_NEXT = 221;
final HUB_ACTION_TIME_TRIAL_START = 222;
final HUB_ACTION_BOSS_RUSH_START = 223;
final HUB_ACTION_NEW_GAME_PLUS_START = 224;

/// @brief Evolving shipwreck station UI and local navigation state.
class HubSystem {
    hide Palette pal;
    hide Integer mode;
    hide Integer selection;
    hide Integer workbenchSelection;
    hide Integer simulatorSelection;
    hide Integer accessibilityUiScale;
    hide Boolean accessibilityHighContrast;
    hide Boolean accessibilityLargeText;

    /// @brief Construct an inert hub shell; call `initHub` before use.
    ///
    /// @return Nothing. Initializes safe default selection values.
    expose func init() {
        mode = HUB_MODE_MAIN;
        selection = 0;
        workbenchSelection = 0;
        simulatorSelection = 0;
        accessibilityUiScale = 100;
        accessibilityHighContrast = false;
        accessibilityLargeText = false;
    }

    /// @brief Apply global hub scale, contrast, and large-text preferences live.
    ///
    /// @param uiScale Advertised 100, 125, or 150 percent UI scale.
    /// @param highContrast True for darker opaque ship/menu backings.
    /// @param largeText True for one bounded heading/prompt scale step.
    /// @return Nothing. Invalid scale values normalize to 100 percent.
    expose func setAccessibility(uiScale: Integer, highContrast: Boolean,
                                 largeText: Boolean) {
        accessibilityUiScale = uiScale;
        if accessibilityUiScale != 100 and accessibilityUiScale != 125 and
           accessibilityUiScale != 150 { accessibilityUiScale = 100; }
        accessibilityHighContrast = highContrast;
        accessibilityLargeText = largeText;
    }

    /// @brief Resolve layout-safe accessible text for the fixed 720p hub.
    ///
    /// @param baseScale Positive authored bitmap-font scale.
    /// @param maximum Maximum safe scale for the element's card or footer.
    /// @return Accessible scale clamped into `1..maximum`.
    hide func hubTextScale(baseScale: Integer, maximum: Integer) -> Integer {
        var scale = accessibleTextScale(
            baseScale, accessibilityUiScale, accessibilityLargeText);
        if scale < 1 { scale = 1; }
        if scale > maximum { scale = maximum; }
        return scale;
    }

    /// @brief Attach the game palette and reset to the main launch deck.
    ///
    /// @param palette Long-lived Game-owned palette reference.
    /// @return Nothing. Stores the borrowed palette and resets navigation.
    expose func initHub(palette: Palette) {
        pal = palette;
        reset();
    }

    /// @brief Return to the five-station main hub menu.
    ///
    /// @return Nothing. Clears submode and restores the first station selection.
    expose func reset() {
        mode = HUB_MODE_MAIN;
        selection = 0;
        workbenchSelection = 0;
        simulatorSelection = 0;
    }

    /// @brief Process one frame of keyboard/gamepad station navigation.
    ///
    /// Subpages return to main on Back. Workbench purchase and difficulty rows
    /// return action codes for Game-owned permanent mutation. Launch returns an
    /// action rather than loading directly, preserving scene ownership in Game.
    ///
    /// @return One `HUB_ACTION_*` value or purchase base plus branch id.
    expose func update() -> Integer {
        if mode == HUB_MODE_MAIN {
            if Action.Pressed(ACT_DOWN) {
                selection = selection + 1;
                if selection > 4 { selection = 0; }
            }
            if Action.Pressed(ACT_UP) {
                selection = selection - 1;
                if selection < 0 { selection = 4; }
            }
            if Action.Pressed(ACT_BACK) { return HUB_ACTION_LAUNCH; }
            if Action.Pressed(ACT_CONFIRM) {
                if selection == 0 { mode = HUB_MODE_MAP; }
                if selection == 1 { mode = HUB_MODE_WORKBENCH; }
                if selection == 2 { mode = HUB_MODE_ARCHIVE; }
                if selection == 3 { mode = HUB_MODE_SIMULATOR; }
                if selection == 4 { return HUB_ACTION_LAUNCH; }
            }
            return HUB_ACTION_NONE;
        }

        if Action.Pressed(ACT_BACK) {
            mode = HUB_MODE_MAIN;
            return HUB_ACTION_NONE;
        }
        if mode == HUB_MODE_MAP {
            if Action.Pressed(ACT_LEFT) { return HUB_ACTION_ROUTE_PREVIOUS; }
            if Action.Pressed(ACT_RIGHT) { return HUB_ACTION_ROUTE_NEXT; }
            if Action.Pressed(ACT_CONFIRM) { return HUB_ACTION_ROUTE_SELECT; }
        }
        if mode == HUB_MODE_WORKBENCH {
            if Action.Pressed(ACT_DOWN) {
                workbenchSelection = workbenchSelection + 1;
                if workbenchSelection > UPGRADE_BRANCH_COUNT { workbenchSelection = 0; }
            }
            if Action.Pressed(ACT_UP) {
                workbenchSelection = workbenchSelection - 1;
                if workbenchSelection < 0 { workbenchSelection = UPGRADE_BRANCH_COUNT; }
            }
            if workbenchSelection < UPGRADE_BRANCH_COUNT and
               Action.Pressed(ACT_CONFIRM) {
                return HUB_ACTION_PURCHASE_BASE + workbenchSelection;
            }
            if workbenchSelection == UPGRADE_BRANCH_COUNT {
                if Action.Pressed(ACT_LEFT) { return HUB_ACTION_DIFFICULTY_DOWN; }
                if Action.Pressed(ACT_RIGHT) { return HUB_ACTION_DIFFICULTY_UP; }
            }
        }
        if mode == HUB_MODE_SIMULATOR {
            if Action.Pressed(ACT_DOWN) {
                simulatorSelection = simulatorSelection + 1;
                if simulatorSelection > 2 { simulatorSelection = 0; }
            }
            if Action.Pressed(ACT_UP) {
                simulatorSelection = simulatorSelection - 1;
                if simulatorSelection < 0 { simulatorSelection = 2; }
            }
            if simulatorSelection == 0 {
                if Action.Pressed(ACT_LEFT) {
                    return HUB_ACTION_TIME_TRIAL_PREVIOUS;
                }
                if Action.Pressed(ACT_RIGHT) {
                    return HUB_ACTION_TIME_TRIAL_NEXT;
                }
                if Action.Pressed(ACT_CONFIRM) {
                    return HUB_ACTION_TIME_TRIAL_START;
                }
            }
            if simulatorSelection == 1 and Action.Pressed(ACT_CONFIRM) {
                return HUB_ACTION_BOSS_RUSH_START;
            }
            if simulatorSelection == 2 and Action.Pressed(ACT_CONFIRM) {
                return HUB_ACTION_NEW_GAME_PLUS_START;
            }
        }
        return HUB_ACTION_NONE;
    }

    /// @brief Draw the repaired ship interior and active station page.
    ///
    /// Boss count visibly restores hull lights, plant life, and the central
    /// navigation core. Page content exposes real progression totals and exact
    /// workbench prices rather than placeholder labels.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param bossCount Number of major bosses defeated in 0..4.
    /// @param gems Current banked salvage balance.
    /// @param upgrades Active permanent UpgradeSystem.
    /// @param difficulty Active/pending DifficultySystem.
    /// @param loreFound Collected lore count.
    /// @param loreTotal Total authored lore count.
    /// @param bestiaryFound Discovered bestiary count.
    /// @param bestiaryTotal Total bestiary count.
    /// @param achievementsUnlocked Unlocked achievement count.
    /// @param achievementsTotal Total achievement count.
    /// @param simulatorRegionName Selected completed Time Trial region.
    /// @param timeTrialAvailable Whether any completed region can be simulated.
    /// @param simulatorBestTime Best selected-region clear time in milliseconds.
    /// @param simulatorBestRank Best selected-region D/C/B/A/S rank label.
    /// @param bossRushUnlocked Whether the normal ending unlocked Boss Rush.
    /// @param newGamePlusUnlocked Whether the normal ending unlocked New Game+.
    /// @param newGamePlusActive Whether the current expedition already uses NG+.
    /// @return Nothing. Draws only and retains local menu state.
    expose func draw(canvas: Canvas, bossCount: Integer, gems: Integer,
                     upgrades: UpgradeSystem, difficulty: DifficultySystem,
                     loreFound: Integer, loreTotal: Integer,
                     bestiaryFound: Integer, bestiaryTotal: Integer,
                     achievementsUnlocked: Integer,
                     achievementsTotal: Integer,
                     simulatorRegionName: String,
                     timeTrialAvailable: Boolean,
                     simulatorBestTime: Integer,
                     simulatorBestRank: String,
                     bossRushUnlocked: Boolean,
                     newGamePlusUnlocked: Boolean,
                     newGamePlusActive: Boolean) {
        drawShipInterior(canvas, bossCount);
        if mode == HUB_MODE_MAIN { drawMain(canvas, bossCount); }
        if mode == HUB_MODE_WORKBENCH {
            drawWorkbench(canvas, gems, upgrades, difficulty);
        }
        if mode == HUB_MODE_ARCHIVE {
            drawArchive(canvas, loreFound, loreTotal,
                        bestiaryFound, bestiaryTotal);
        }
        if mode == HUB_MODE_SIMULATOR {
            drawSimulator(canvas, achievementsUnlocked, achievementsTotal,
                          simulatorRegionName, timeTrialAvailable,
                          simulatorBestTime, simulatorBestRank,
                          bossRushUnlocked, newGamePlusUnlocked,
                          newGamePlusActive);
        }
        if mode == HUB_MODE_MAP {
            canvas.TextCenteredScaled(70, "NAVIGATION ARRAY", pal.white, 3);
            canvas.TextCenteredScaled(
                SCREEN_H - 55,
                Action.BindingsStr(ACT_LEFT) + "/" +
                Action.BindingsStr(ACT_RIGHT) + ": route   " +
                Action.BindingsStr(ACT_CONFIRM) + ": set launch   " +
                Action.BindingsStr(ACT_BACK) + ": back",
                pal.hudGray, 1);
        }
    }

    /// @brief Read whether the navigation-map page is active.
    ///
    /// @return True only while Hub should composite WorldMap over its interior.
    expose func isMapMode() -> Boolean { return mode == HUB_MODE_MAP; }

    /// @brief Draw the evolving damaged/repaired shipwreck interior.
    ///
    /// @param canvas Active canvas.
    /// @param bossCount Defeated major-boss count controlling repair layers.
    /// @return Nothing. Draws deterministic procedural hub art.
    hide func drawShipInterior(canvas: Canvas, bossCount: Integer) {
        canvas.GradientV(0, 0, SCREEN_W, SCREEN_H,
                         Color.RGB(4, 10, 18), Color.RGB(12, 28, 38));
        if accessibilityHighContrast {
            canvas.BoxAlpha(0, 0, SCREEN_W, SCREEN_H, pal.black, 100);
        }
        canvas.Box(80, 55, SCREEN_W - 160, SCREEN_H - 110,
                   Color.RGB(18, 28, 38));
        canvas.Frame(80, 55, SCREEN_W - 160, SCREEN_H - 110,
                     Color.RGB(70, 100, 120));
        var x = 120;
        while x < SCREEN_W - 100 {
            var light = Color.RGB(55, 45, 35);
            if bossCount > (x / 180) % 4 { light = Color.RGB(80, 220, 210); }
            canvas.Disc(x, 82, 5, light);
            x = x + 150;
        }
        canvas.Box(130, SCREEN_H - 150, SCREEN_W - 260, 56,
                   Color.RGB(25, 38, 46));
        canvas.Frame(130, SCREEN_H - 150, SCREEN_W - 260, 56,
                     Color.RGB(55, 85, 105));
        if bossCount >= 2 {
            canvas.Disc(1050, 555, 34, Color.RGB(30, 110, 70));
            canvas.Line(1050, 555, 1030, 500, Color.RGB(80, 180, 100));
            canvas.Line(1050, 555, 1080, 505, Color.RGB(80, 180, 100));
        }
        if bossCount >= 3 {
            canvas.DiscAlpha(SCREEN_W / 2, 165, 72,
                             Color.RGB(80, 220, 255), 45);
            canvas.Ring(SCREEN_W / 2, 165, 45, Color.RGB(80, 220, 255));
        }
        canvas.Text(105, 66, "XENOSCAPE // SURVIVOR OPERATIONS",
                    Color.RGB(130, 180, 200));
    }

    /// @brief Draw the five required hub stations and selection highlight.
    ///
    /// @param canvas Active canvas.
    /// @param bossCount Defeated-boss count shown as repair progress.
    /// @return Nothing. Draws station menu only.
    hide func drawMain(canvas: Canvas, bossCount: Integer) {
        canvas.TextCenteredScaled(115, "SHIPWRECK HUB", pal.titleYellow,
                                  hubTextScale(4, 5));
        canvas.TextCenteredScaled(165,
                                  "Hull restoration " + Int(bossCount) + " / 4",
                                  pal.hudBlue, 1);
        var labels = ["MAP", "WORKBENCH", "ARCHIVE", "SIMULATOR", "LAUNCH"];
        var i = 0;
        while i < labels.length() {
            var y = 230 + i * 58;
            var color = pal.menuText;
            var marker = "  ";
            if i == selection { color = pal.titleYellow; marker = "> "; }
            canvas.BoxAlpha(410, y - 8, 460, 42, Color.RGB(8, 16, 26), 180);
            canvas.TextScaled(455, y, marker + labels.get(i),
                              hubTextScale(2, 3), color);
            i = i + 1;
        }
        canvas.TextCenteredScaled(
            SCREEN_H - 55,
            Action.BindingsStr(ACT_UP) + "/" + Action.BindingsStr(ACT_DOWN) +
            ": station   " + Action.BindingsStr(ACT_CONFIRM) + ": open   " +
            Action.BindingsStr(ACT_BACK) + ": launch",
            pal.hudGray, 1);
    }

    /// @brief Draw exact workbench tiers, costs, effects, and difficulty row.
    ///
    /// @param canvas Active canvas.
    /// @param gems Current banked salvage.
    /// @param upgrades Active upgrade tiers.
    /// @param difficulty Active/pending difficulty state.
    /// @return Nothing. Draws workbench page only.
    hide func drawWorkbench(canvas: Canvas, gems: Integer,
                            upgrades: UpgradeSystem,
                            difficulty: DifficultySystem) {
        canvas.TextCenteredScaled(105, "WORKBENCH", pal.titleYellow, 3);
        canvas.Text(420, 155, "BANKED SALVAGE: " + Int(gems), pal.crystalBlue);
        var i = 0;
        while i < UPGRADE_BRANCH_COUNT {
            var tier = upgrades.getTier(i);
            var cost = upgradeNextCost(i, tier);
            var detail = "TIER " + Int(tier) + " / 3";
            if cost > 0 { detail = detail + "   NEXT: " + Int(cost); }
            else { detail = detail + "   MAX"; }
            var color = pal.menuText;
            if i == workbenchSelection { color = pal.titleYellow; }
            canvas.Text(360, 215 + i * 58, upgradeBranchName(i), color);
            canvas.Text(650, 215 + i * 58, detail, pal.hudGray);
            i = i + 1;
        }
        var diffColor = pal.menuText;
        if workbenchSelection == UPGRADE_BRANCH_COUNT {
            diffColor = pal.titleYellow;
        }
        canvas.Text(360, 215 + UPGRADE_BRANCH_COUNT * 58,
                    "DIFFICULTY", diffColor);
        canvas.Text(650, 215 + UPGRADE_BRANCH_COUNT * 58,
                    "< " + difficultyName(difficulty.getPendingProfile()) + " >",
                    pal.hudGray);
        canvas.TextCenteredScaled(
            SCREEN_H - 55,
            Action.BindingsStr(ACT_CONFIRM) + ": buy   " +
            Action.BindingsStr(ACT_LEFT) + "/" +
            Action.BindingsStr(ACT_RIGHT) + ": difficulty   " +
            Action.BindingsStr(ACT_BACK) + ": back",
            pal.hudGray, 1);
    }

    /// @brief Draw lore and bestiary archive completion summaries.
    ///
    /// @param canvas Active canvas.
    /// @param loreFound Collected lore count.
    /// @param loreTotal Total lore count.
    /// @param bestiaryFound Discovered bestiary count.
    /// @param bestiaryTotal Total bestiary count.
    /// @return Nothing. Draws archive page only.
    hide func drawArchive(canvas: Canvas, loreFound: Integer, loreTotal: Integer,
                          bestiaryFound: Integer, bestiaryTotal: Integer) {
        canvas.TextCenteredScaled(110, "ARIA ARCHIVE", pal.titleYellow, 3);
        canvas.TextCenteredScaled(245,
                                  "LORE RECORDS  " + Int(loreFound) + " / " + Int(loreTotal),
                                  pal.crystalBlue, 2);
        canvas.TextCenteredScaled(315,
                                  "BESTIARY     " + Int(bestiaryFound) + " / " + Int(bestiaryTotal),
                                  pal.hudGreen, 2);
        canvas.TextCenteredScaled(420,
                                  "Recovered discoveries synchronize at save stations.",
                                  pal.hudGray, 1);
    }

    /// @brief Draw three functional simulator/postgame launch rows.
    ///
    /// @param canvas Active canvas.
    /// @param unlocked Unlocked achievement count.
    /// @param total Total achievement count.
    /// @param regionName Selected Time Trial region display name.
    /// @param trialAvailable True when at least one region is complete.
    /// @param bestTime Selected-region best time in milliseconds, or zero.
    /// @param bestRank Selected-region rank label or `--`.
    /// @param rushUnlocked True after the normal ending.
    /// @param ngPlusUnlocked True after the normal ending.
    /// @param ngPlusActive True while the profile is already a NG+ expedition.
    /// @return Nothing. Draws simulator state without mutating campaign data.
    hide func drawSimulator(canvas: Canvas, unlocked: Integer, total: Integer,
                            regionName: String, trialAvailable: Boolean,
                            bestTime: Integer, bestRank: String,
                            rushUnlocked: Boolean,
                            ngPlusUnlocked: Boolean,
                            ngPlusActive: Boolean) {
        canvas.TextCenteredScaled(110, "COMBAT SIMULATOR", pal.titleYellow, 3);
        canvas.TextCenteredScaled(160,
                                  "ACHIEVEMENTS  " + Int(unlocked) + " / " + Int(total),
                                  pal.crystalBlue, 2);

        var trialText = "REGION TIME TRIAL   LOCKED";
        var trialDetail = "Complete one region to calibrate its simulation.";
        if trialAvailable {
            trialText = "<  " + regionName + " TIME TRIAL  >";
            trialDetail = "BEST " + formatSimulatorTime(bestTime) +
                          "   RANK " + bestRank;
        }
        drawSimulatorRow(canvas, 230, 0, trialText, trialDetail,
                         trialAvailable);

        var rushText = "BOSS RUSH   LOCKED";
        var rushDetail = "Defeat The Architect to unlock.";
        if rushUnlocked {
            rushText = "BOSS RUSH";
            rushDetail = "Four major encounters. One continuous clock.";
        }
        drawSimulatorRow(canvas, 335, 1, rushText, rushDetail, rushUnlocked);

        var ngText = "NEW GAME+   LOCKED";
        var ngDetail = "Defeat The Architect to unlock.";
        var ngEnabled = ngPlusUnlocked;
        if ngPlusUnlocked {
            ngText = "BEGIN NEW GAME+";
            ngDetail = "Retain upgrades and discoveries; enemies grow stronger.";
        }
        if ngPlusActive {
            ngText = "NEW GAME+   ACTIVE";
            ngDetail = "This expedition already uses the remixed ruleset.";
            ngEnabled = false;
        }
        drawSimulatorRow(canvas, 440, 2, ngText, ngDetail, ngEnabled);

        canvas.TextCenteredScaled(
            SCREEN_H - 55,
            Action.BindingsStr(ACT_LEFT) + "/" + Action.BindingsStr(ACT_RIGHT) +
            ": select   " + Action.BindingsStr(ACT_CONFIRM) +
            ": launch   " + Action.BindingsStr(ACT_BACK) + ": back",
            pal.hudGray, 1);
    }

    /// @brief Draw one selected, unlocked, or locked simulator launch card.
    ///
    /// @param canvas Active release-resolution canvas.
    /// @param y Top coordinate of the card.
    /// @param row Stable row id in 0..2.
    /// @param title Primary mode label.
    /// @param detail Secondary result or unlock guidance.
    /// @param enabled Whether confirming the card can launch its mode.
    /// @return Nothing. Uses local selection only for visual emphasis.
    hide func drawSimulatorRow(canvas: Canvas, y: Integer, row: Integer,
                               title: String, detail: String,
                               enabled: Boolean) {
        var border = Color.RGB(45, 65, 85);
        var titleColor = pal.menuText;
        if enabled == false { titleColor = Color.RGB(95, 100, 112); }
        if simulatorSelection == row {
            border = pal.titleYellow;
            if enabled { titleColor = pal.titleYellow; }
        }
        canvas.BoxAlpha(250, y, 780, 80, Color.RGB(7, 15, 25), 220);
        canvas.Frame(250, y, 780, 80, border);
        canvas.TextCenteredScaled(y + 13, title, titleColor, 2);
        canvas.TextCenteredScaled(y + 50, detail, pal.hudGray, 1);
    }

    /// @brief Format one simulator best time for a compact launch-card label.
    ///
    /// @param milliseconds Nonnegative best time, with zero meaning no result.
    /// @return `--:--.--` for no result or a `M:SS.hh` value otherwise.
    hide func formatSimulatorTime(milliseconds: Integer) -> String {
        if milliseconds <= 0 { return "--:--.--"; }
        var minutes = milliseconds / 60000;
        var seconds = (milliseconds / 1000) % 60;
        var hundredths = (milliseconds / 10) % 100;
        var secondText = Int(seconds);
        if seconds < 10 { secondText = "0" + secondText; }
        var hundredthText = Int(hundredths);
        if hundredths < 10 { hundredthText = "0" + hundredthText; }
        return Int(minutes) + ":" + secondText + "." + hundredthText;
    }
}
