        if t == ENEMY_PATROL_DRONE { return PATROL_DRONE_H; }
        if t == ENEMY_BOMB_CARRIER { return BOMB_CARRIER_H; }
        return 36;
    }

    // =========================================================================
    // Drawing
    // =========================================================================

    expose func drawAll(canvas: Canvas, camX: Integer, camY: Integer, sprites: SpriteFactory) {
        var i = pool.FirstActive();
        while i >= 0 {
            var next = pool.NextActive(i);
            var sx = ex.get(i) / 100 - camX;
            var sy = ey.get(i) / 100 - camY;

            // Skip if off screen
            if sx > -96 {
                if sx < SCREEN_W + 96 {
                    if sy > -96 {
                        if sy < SCREEN_H + 96 {
                            var t = etype.get(i);
                            var f = eframe.get(i);

                            // Flash when hurt (skip draw every other 2-frame pair)
                            var skipDraw = false;
                            if estate.get(i) == 1 {
                                if etimer.get(i) % 4 < 2 {
                                    skipDraw = true;
                                }
                            }
                            if skipDraw == false {
                                drawEnemy(canvas, t, f, sx, sy, sprites);
                            }
                        }
                    }
                }
            }
            i = next;
        }

        // Draw enemy bullets
        drawEnemyBullets(canvas, camX, camY, sprites);
    }

    hide func drawEnemy(canvas: Canvas, t: Integer, f: Integer,
                        sx: Integer, sy: Integer, sprites: SpriteFactory) {
        if t == ENEMY_SLIME { canvas.BlitAlpha(sx, sy, sprites.getSlimeFrame(f)); return; }
        if t == ENEMY_BAT { canvas.BlitAlpha(sx, sy, sprites.getBatFrame(f)); return; }
        if t == ENEMY_DRONE { canvas.BlitAlpha(sx, sy, sprites.getDroneFrame(f)); return; }
        if t == ENEMY_TURRET { canvas.BlitAlpha(sx, sy, sprites.getTurretBase()); return; }
        if t == ENEMY_BOSS or isRegionalClimaxBoss(t) {
            drawRegionalClimax(canvas, t, f, sx, sy, sprites);
            return;
        }
        if t == ENEMY_SPOREWALKER { canvas.BlitAlpha(sx, sy, sprites.getSporewalkerFrame(f)); return; }
        if t == ENEMY_GLOWMOTH { canvas.BlitAlpha(sx, sy, sprites.getGlowmothFrame(f)); return; }
        if t == ENEMY_FUNGAL_TURRET { canvas.BlitAlpha(sx, sy, sprites.getFungalTurretFrame(f)); return; }
        if t == ENEMY_MYCELIUM { canvas.BlitAlpha(sx, sy, sprites.getMyceliumFrame(f)); return; }
        if t == ENEMY_SPORE_MOTHER { canvas.BlitAlpha(sx, sy, sprites.getSporeMothFrame(f)); return; }
        if t == ENEMY_CRYSTAL_GOLEM { canvas.BlitAlpha(sx, sy, sprites.getCrystalGolemFrame(f)); return; }
        if t == ENEMY_SHARD_BAT { canvas.BlitAlpha(sx, sy, sprites.getShardBatFrame(f)); return; }
        if t == ENEMY_RESONANCE_ORB { canvas.BlitAlpha(sx, sy, sprites.getResonanceOrbFrame(f)); return; }
        if t == ENEMY_MIRROR_SLIME { canvas.BlitAlpha(sx, sy, sprites.getMirrorSlimeFrame(f)); return; }
        if t == ENEMY_CRYSTAL_WYRM { canvas.BlitAlpha(sx, sy, sprites.getCrystalWyrmFrame(f)); return; }
        if t == ENEMY_MAGMA_SLUG { canvas.BlitAlpha(sx, sy, sprites.getMagmaSlugFrame(f)); return; }
        if t == ENEMY_EMBER_WASP { canvas.BlitAlpha(sx, sy, sprites.getEmberWaspFrame(f)); return; }
        if t == ENEMY_FORGE_SENTINEL { canvas.BlitAlpha(sx, sy, sprites.getForgeSentinelFrame(f)); return; }
        if t == ENEMY_MAGMA_CORE { canvas.BlitAlpha(sx, sy, sprites.getMagmaCoreFrame(f)); return; }
        if t == ENEMY_ICE_WRAITH { canvas.BlitAlpha(sx, sy, sprites.getIceWraithFrame(f)); return; }
        if t == ENEMY_FROST_BEETLE { canvas.BlitAlpha(sx, sy, sprites.getFrostBeetleFrame(f)); return; }
        if t == ENEMY_STALACTITE_BAT { canvas.BlitAlpha(sx, sy, sprites.getStalactiteBatFrame(f)); return; }
        if t == ENEMY_VINE_WHIP { canvas.BlitAlpha(sx, sy, sprites.getVineWhipSprite()); return; }
        if t == ENEMY_MOSS_GOLEM { canvas.BlitAlpha(sx, sy, sprites.getMossGolemFrame(f)); return; }
        if t == ENEMY_RUIN_GUARDIAN { canvas.BlitAlpha(sx, sy, sprites.getRuinGuardianFrame(f)); return; }
        if t == ENEMY_SHADOW_CLONE { canvas.BlitAlpha(sx, sy, sprites.getShadowCloneFrame(f)); return; }
        if t == ENEMY_CORRUPTION { canvas.BlitAlpha(sx, sy, sprites.getCorruptionSprite()); return; }
        if t == ENEMY_ARCHITECT { canvas.BlitAlpha(sx, sy, sprites.getArchitectFrame(f)); return; }
        if t == ENEMY_BOMB_CARRIER { canvas.BlitAlpha(sx, sy, sprites.getBombCarrierFrame(f)); return; }

        // Remaining enemies still fall back to procedural rendering where the
        // sprite factory has no dedicated cached sprite yet.
        var w = getEnemyW(t); var h = getEnemyH(t);
        if t == ENEMY_PISTON_TRAP { canvas.Box(sx, sy, w, h, Color.RGB(150, 150, 160)); canvas.Box(sx + 4, sy, w - 8, h / 3, Color.RGB(200, 50, 50)); }
        else if t == ENEMY_PATROL_DRONE { canvas.BlitAlpha(sx, sy, sprites.getDroneFrame(f)); }
        else { canvas.Box(sx, sy, w, h, Color.RGB(255, 0, 255)); } // Fallback: magenta
    }

    /// @brief Draw a shared mechanical silhouette with a unique readable core.
    hide func drawRegionalClimax(canvas: Canvas, t: Integer, f: Integer,
                                 sx: Integer, sy: Integer,
                                 sprites: SpriteFactory) {
        canvas.BlitAlpha(sx, sy, sprites.getBossFrame(f));
        var accent = Color.RGB(240, 190, 70);
        if t == ENEMY_RELAY_CUSTODIAN { accent = Color.RGB(90, 210, 235); }
        if t == ENEMY_TIDE_LEVIATHAN { accent = Color.RGB(70, 150, 255); }
        if t == ENEMY_VERDANT_COLOSSUS { accent = Color.RGB(90, 225, 105); }
        if t == ENEMY_CRYO_CUSTODIAN { accent = Color.RGB(185, 235, 255); }
        if t == ENEMY_NULL_HARVESTER { accent = Color.RGB(210, 80, 240); }
        var cx = sx + BOSS_W / 2;
        var cy = sy + BOSS_H / 2;
        canvas.DiscAlpha(cx, cy, 22, accent, 65);
        canvas.Ring(cx, cy, 18, accent);
        if t == ENEMY_BEACON_WARDEN {
            canvas.Line(cx, cy - 15, cx, cy + 15, accent);
            canvas.Disc(cx, cy, 5, accent);
        }
        if t == ENEMY_RELAY_CUSTODIAN {
            canvas.Triangle(cx, cy - 14, cx - 14, cy + 11,
                            cx + 14, cy + 11, accent);
        }
        if t == ENEMY_TIDE_LEVIATHAN {
            canvas.Line(cx - 16, cy - 7, cx + 16, cy - 7, accent);
            canvas.Line(cx - 16, cy + 7, cx + 16, cy + 7, accent);
        }
        if t == ENEMY_VERDANT_COLOSSUS {
            canvas.Disc(cx - 8, cy, 7, accent);
            canvas.Disc(cx + 8, cy, 7, accent);
        }
        if t == ENEMY_CRYO_CUSTODIAN {
            canvas.Triangle(cx, cy - 16, cx - 13, cy,
                            cx + 13, cy, accent);
            canvas.Triangle(cx, cy + 16, cx - 13, cy,
                            cx + 13, cy, accent);
        }
        if t == ENEMY_NULL_HARVESTER {
            canvas.Line(cx - 14, cy - 14, cx + 14, cy + 14, accent);
            canvas.Line(cx + 14, cy - 14, cx - 14, cy + 14, accent);
        }
    }

    hide func drawEnemyBullets(canvas: Canvas, camX: Integer, camY: Integer,
                                sprites: SpriteFactory) {
        var i = 0;
        while i < ebCount {
            if ebactive.get(i) == 1 {
                var sx = ebx.get(i) - camX;
                var sy = eby.get(i) - camY;
                if sx > -15 {
                    if sx < SCREEN_W + 15 {
                        canvas.BlitAlpha(sx, sy, sprites.getEnemyBullet());
                    }
                }
            }
            i = i + 1;
        }
    }

    // Accessors
    expose func getEnemyType(i: Integer) -> Integer { return etype.get(i); }
    expose func isActive(i: Integer) -> Integer { if pool.IsActive(i) { return 1; } return 0; }
    expose func activeCount() -> Integer { return pool.get_ActiveCount(); }

    /// @brief Report whether any live hostile is near a world-space listener.
    ///
    /// Manhattan distance is sufficient for adaptive audio and avoids square-root
    /// work in the per-frame presentation path. Dead slots and indestructible
    /// piston hazards are ignored so ambient intensity reflects active combat.
    ///
    /// @param worldX Listener center X in world pixels.
    /// @param worldY Listener center Y in world pixels.
    /// @param radius Positive authored proximity radius in pixels.
    /// @return True when one active hostile lies within the bounded radius.
    expose func hasThreatNear(worldX: Integer, worldY: Integer,
                              radius: Integer) -> Boolean {
        if radius <= 0 { return false; }
        var i = pool.FirstActive();
        while i >= 0 {
            var next = pool.NextActive(i);
            if estate.get(i) != 2 and etype.get(i) != ENEMY_PISTON_TRAP {
                var dx = ex.get(i) / 100 - worldX;
                var dy = ey.get(i) / 100 - worldY;
                if dx < 0 { dx = 0 - dx; }
                if dy < 0 { dy = 0 - dy; }
                if dx + dy <= radius { return true; }
            }
            i = next;
        }
        return false;
    }
    expose func enemyBulletCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < ebCount {
            if ebactive.get(i) == 1 { count = count + 1; }
            i = i + 1;
        }
        return count;
    }
    expose func isBossAlive() -> Boolean {
        if bossIndex < 0 { return false; }
        return pool.IsActive(bossIndex);
    }
    expose func getBossHp() -> Integer {
        if bossIndex < 0 { return 0; }
        return ehp.get(bossIndex);
    }
}
