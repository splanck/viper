//
// File: examples/games/xenoscape/campaign_probe.zia
// Purpose: Proves a deterministic clean-profile path to both campaign endings.
// Key invariants:
//   - Every transition follows the authoritative bidirectional WorldGraph.
//   - Ability rewards open later gates in the production acquisition order.
// Ownership/Lifetime:
//   - Probe owns short-lived graph, level-validation, and meta objects only.
//   - No SaveData namespace, display, input, or audio device is opened.
// Links: world_graph.zia, campaign_content.zia, meta_modes.zia,
//        level_validation.zia, src/tests/CMakeLists.txt
//
//===----------------------------------------------------------------------===//

module campaign_probe;

bind Viper.Terminal as Terminal;
bind Viper.Text.Fmt;
bind "./abilities";
bind "./campaign_content";
bind "./level_validation";
bind "./meta_modes";
bind "./world_graph";

/// @brief Emit one stable campaign-path failure for CTest diagnostics.
///
/// @param message Concise violated contract description.
/// @return Nothing. Omits the success marker so regex validation fails.
func fail(message: String) { Terminal.Say("RESULT: fail " + message); }

/// @brief Add one zero-based region to a completion mask idempotently.
///
/// @param mask Existing nonnegative ten-region mask.
/// @param region Zero-based region id in 0..9.
/// @return Mask containing the region bit, or the input for invalid ids.
func campaignMaskAdd(mask: Integer, region: Integer) -> Integer {
    if region < 0 or region >= 10 { return mask; }
    var bit = 1;
    var i = 0;
    while i < region { bit = bit * 2; i = i + 1; }
    if (mask / bit) % 2 == 0 { return mask + bit; }
    return mask;
}

/// @brief Execute the clean-profile route and verify endings/postgame unlocks.
///
/// @return Nothing. Prints `RESULT: ok` only after every campaign gate passes.
func main() {
    var validator = new LevelValidator();
    var report = validator.validateCampaign(false);
    if report.ok() == false or report.checkedLevels != 10 {
        fail("campaign content validation"); return;
    }

    var graph = new WorldGraph();
    var route = [0, 1, 2, 5, 4, 3, 6, 7, 8, 9];
    var abilities = ABILITY_WALL_JUMP;
    var completion = 0;
    var previous = route.get(0);
    completion = campaignMaskAdd(completion, previous);
    var firstReward = regionAbilityReward(previous);
    if firstReward > 0 { abilities = abilities + firstReward; }

    var step = 1;
    while step < route.length() {
        var region = route.get(step);
        if graph.canTraverse(previous, region, abilities) == false {
            fail("route gate at step " + Int(step)); return;
        }
        if regionContentAuthored(region) == false {
            fail("missing authored region content"); return;
        }
        completion = campaignMaskAdd(completion, region);
        var reward = regionAbilityReward(region);
        if reward > 0 and (abilities / reward) % 2 == 0 {
            abilities = abilities + reward;
        }
        previous = region;
        step = step + 1;
    }

    if completion != 1023 or abilities != 63 or
       normalEndingUnlocked(completion) == false or
       trueEndingUnlocked(completion, abilities, 23, 23) == false {
        fail("ending requirements"); return;
    }
    if trueEndingUnlocked(completion, abilities, 22, 23) {
        fail("true ending unlocked without complete lore"); return;
    }

    var meta = new MetaProgression();
    if meta.setNewGamePlusActive(true, completion) == false or
       meta.isNewGamePlusActive() == false or
       newGamePlusEnemyHpPercent(true) != 135 or
       newGamePlusEncounterPercent(true) != 150 {
        fail("postgame unlock path"); return;
    }
    Terminal.Say("RESULT: ok");
}
