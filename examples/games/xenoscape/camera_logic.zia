//
// File: examples/games/xenoscape/camera_logic.zia
// Purpose: Provides displayless deterministic camera-intent calculations.
// Key invariants:
//   - Horizontal and vertical targets never exceed release framing bounds.
//   - Reduced Motion always resolves nonessential framing targets to zero.
// Ownership/Lifetime:
//   - Functions are pure and own no resources or retained state.
// Links: camera.zia, game.zia, mechanics_probe.zia,
//        misc/plans/demos/xenoscape-release-upgrade.md
//
//===----------------------------------------------------------------------===//

module camera_logic;

bind "./config";

final CAMERA_LOOK_AHEAD_MAX = 160;
final CAMERA_VERTICAL_INTENT_MAX = 96;
final CAMERA_VERTICAL_INTENT_DELAY_MS = 250;

/// @brief Calculate the bounded horizontal framing target from run velocity.
///
/// @param playerVx Signed horizontal centipixel velocity.
/// @param reducedMotion True to suppress nonessential camera sweeps.
/// @return Signed look-ahead in -160..160 pixels.
func cameraLookAheadTarget(playerVx: Integer,
                           reducedMotion: Boolean) -> Integer {
    if reducedMotion { return 0; }
    var target = playerVx * CAMERA_LOOK_AHEAD_MAX / PLAYER_SPEED;
    if target < 0 - CAMERA_LOOK_AHEAD_MAX {
        target = 0 - CAMERA_LOOK_AHEAD_MAX;
    }
    if target > CAMERA_LOOK_AHEAD_MAX { target = CAMERA_LOOK_AHEAD_MAX; }
    return target;
}

/// @brief Calculate vertical inspection framing after its deliberate hold delay.
///
/// @param direction Negative for up, positive for down, zero for neutral.
/// @param heldMs Continuous same-direction hold time in milliseconds.
/// @param reducedMotion True to suppress nonessential camera sweeps.
/// @return Negative 96, positive 96, or zero pixels.
func cameraVerticalIntentTarget(direction: Integer, heldMs: Integer,
                                reducedMotion: Boolean) -> Integer {
    if reducedMotion or heldMs < CAMERA_VERTICAL_INTENT_DELAY_MS { return 0; }
    if direction < 0 { return 0 - CAMERA_VERTICAL_INTENT_MAX; }
    if direction > 0 { return CAMERA_VERTICAL_INTENT_MAX; }
    return 0;
}

/// @brief Ease one signed framing offset without overshooting its target.
///
/// @param current Current signed pixel offset.
/// @param target Desired signed pixel offset.
/// @param dt Nonnegative clamped milliseconds.
/// @param settleMs Positive approximate settling window.
/// @return New signed offset between current and target.
func approachCameraOffset(current: Integer, target: Integer,
                          dt: Integer, settleMs: Integer) -> Integer {
    if current == target { return current; }
    var elapsed = dt;
    if elapsed < 0 { elapsed = 0; }
    if elapsed > DT_MAX { elapsed = DT_MAX; }
    var divisor = settleMs;
    if divisor <= 0 { divisor = 1; }
    var step = (target - current) * elapsed / divisor;
    if step == 0 {
        if target > current { step = 1; }
        else { step = -1; }
    }
    var result = current + step;
    if target > current and result > target { result = target; }
    if target < current and result < target { result = target; }
    return result;
}
