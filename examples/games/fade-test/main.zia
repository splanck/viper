// Fade & Rendering Test — Tests two things:
// 1. Does ScreenFX FadeIn actually produce a visible fade?
// 2. Does GradientV + drawing cover the FULL screen?
//
// Press SPACE to toggle between fade test and full-screen coverage test.
// Press Q or ESC to quit.
module main;

bind Viper.Graphics;
bind Viper.Graphics.Canvas;
bind Viper.Graphics.Color;
bind Viper.Game.ScreenFX as FX;
bind Viper.Fmt;
bind Viper.Input;

final W = 640;
final H = 480;
final KEY_SPACE = 32;
final KEY_Q = 81;
final KEY_ESC = 256;

func start() {
    var canvas = Canvas.New("Fade & Coverage Test", W, H);
    canvas.SetFps(60);

    Action.Define("quit");
    Action.BindKey("quit", KEY_Q);
    Action.BindKey("quit", KEY_ESC);
    Action.Define("toggle");
    Action.BindKey("toggle", KEY_SPACE);
    Action.Define("restart");
    Action.BindKey("restart", 82); // R key

    var fx = FX.New();
    var mode = 0;  // 0 = fade test, 1 = coverage test
    var frame = 0;
    var fadeActive = false;

    // Start with a fade-in
    fx.FadeIn(0x000000FF, 2000);
    fadeActive = true;

    while canvas.BeginFrame() != 0 {
        var dt = canvas.DeltaTime;
        if dt < 1 { dt = 16; }

        if Action.Pressed("quit") { return; }

        if Action.Pressed("toggle") {
            if mode == 0 { mode = 1; }
            else { mode = 0; }
        }

        if Action.Pressed("restart") {
            // Restart the fade
            fx.FadeIn(0x000000FF, 2000);
            fadeActive = true;
        }

        fx.Update(dt);

        canvas.Clear(0xFF00FF); // MAGENTA clear — easy to spot if something doesn't draw

        if mode == 0 {
            drawFadeTest(canvas, fx, frame);
        } else {
            drawCoverageTest(canvas, frame);
        }

        frame = frame + 1;
        canvas.Flip();
    }
}

// =============================================================================
// Mode 0: Fade Test — bright scene with ScreenFX overlay
// =============================================================================

func drawFadeTest(canvas: Canvas, fx: FX, frame: Integer) {
    // Draw a bright, colorful scene
    canvas.GradientV(0, 0, W, H, 0x2244AA, 0x88CCFF);

    // Yellow sun
    canvas.Disc(W / 2, 120, 50, 0xFFDD44);

    // Green ground
    canvas.Box(0, 340, W, 140, 0x228822);

    // Red house
    canvas.Box(200, 270, 160, 70, 0xCC3333);
    canvas.Triangle(200, 270, 360, 270, 280, 220, 0x884422);

    // White fence posts across bottom
    var i = 0;
    while i < W {
        canvas.Box(i, 380, 4, 40, 0xFFFFFF);
        canvas.Box(i, 390, 30, 4, 0xFFFFFF);
        i = i + 40;
    }

    // Corner markers — ensure all 4 corners draw
    canvas.Box(0, 0, 30, 30, 0xFF0000);         // top-left RED
    canvas.Box(W - 30, 0, 30, 30, 0x00FF00);    // top-right GREEN
    canvas.Box(0, H - 30, 30, 30, 0x0000FF);    // bottom-left BLUE
    canvas.Box(W - 30, H - 30, 30, 30, 0xFFFF00); // bottom-right YELLOW

    // Instructions
    canvas.Text(10, 10, "FADE TEST (mode 0) - SPACE=toggle R=restart", 0xFFFFFF);
    canvas.Text(10, 30, "You should see scene fade in from BLACK", 0xFFFFFF);

    // Alpha bar
    var alpha = fx.get_OverlayAlpha();
    canvas.Box(10, H - 30, 200, 16, 0x333333);
    if alpha > 0 {
        canvas.Box(10, H - 30, alpha * 200 / 255, 16, 0xFF4444);
    }
    canvas.Text(220, H - 28, "overlay alpha=" + Int(alpha), 0xFFFFFF);

    // Apply the ScreenFX overlay (exactly how the sidescroller does it)
    if alpha > 0 {
        var ocolor = fx.get_OverlayColor();
        canvas.BoxAlpha(0, 0, W, H, ocolor, alpha);
    }
}

// =============================================================================
// Mode 1: Coverage Test — verify drawing reaches all screen regions
// =============================================================================

func drawCoverageTest(canvas: Canvas, frame: Integer) {
    // Full-screen gradient — should cover EVERY pixel
    canvas.GradientV(0, 0, W, H, 0x2244AA, 0x88CCFF);

    // Draw a grid of colored squares to verify coverage
    var row = 0;
    while row < H {
        var col = 0;
        while col < W {
            // Alternating colors based on grid position
            var cellColor = 0x444444;
            if (col / 40 + row / 40) % 2 == 0 {
                cellColor = 0x666688;
            }
            canvas.Box(col + 1, row + 1, 38, 38, cellColor);
            col = col + 40;
        }
        row = row + 40;
    }

    // Draw text at multiple Y positions to verify coverage
    canvas.Text(10, 10, "COVERAGE TEST (mode 1) - SPACE=toggle", 0xFFFFFF);
    canvas.Text(10, 100, "y=100: Can you see this?", 0x00FF00);
    canvas.Text(10, 200, "y=200: Can you see this?", 0x00FF00);
    canvas.Text(10, 300, "y=300: Can you see this?", 0x00FF00);
    canvas.Text(10, 400, "y=400: Can you see this?", 0xFF4444);
    canvas.Text(10, H - 20, "y=BOTTOM: Can you see this?", 0xFF4444);

    // Bright corner markers
    canvas.Disc(20, 20, 15, 0xFF0000);              // top-left
    canvas.Disc(W - 20, 20, 15, 0x00FF00);          // top-right
    canvas.Disc(20, H - 20, 15, 0x0000FF);          // bottom-left
    canvas.Disc(W - 20, H - 20, 15, 0xFFFF00);      // bottom-right
    canvas.Disc(W / 2, H / 2, 20, 0xFF00FF);        // center

    // If ANY area shows MAGENTA (from Clear), something isn't drawing
    canvas.Text(10, 50, "If you see MAGENTA anywhere, drawing is broken!", 0xFF00FF);
}
