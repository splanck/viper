// textures.zia — Procedural texture generators for dungeon surfaces
module textures;

bind Viper.Graphics;

// =========================================================================
// Stone floor — dark gray checkerboard with noise variation
// =========================================================================
func createStoneFloor(size: Integer) -> Pixels {
    var tex = new Pixels(size, size);
    var tileSize = size / 4;
    if (tileSize < 1) { tileSize = 1; }
    var y = 0;
    while (y < size) {
        var x = 0;
        while (x < size) {
            var tileX = x / tileSize;
            var tileY = y / tileSize;
            var checker = (tileX + tileY) % 2;

            // Base gray with checker variation
            var base = 80 + checker * 20;

            // Simple noise: use position-based hash
            var noise = ((x * 7 + y * 13 + x * y) % 20) - 10;
            var gray = base + noise;
            if (gray < 40) { gray = 40; }
            if (gray > 120) { gray = 120; }

            // Mortar lines (darker at tile edges)
            var edgeX = x % tileSize;
            var edgeY = y % tileSize;
            if (edgeX == 0 || edgeY == 0) {
                gray = gray - 30;
                if (gray < 20) { gray = 20; }
            }

            var color = (gray * 65536 + gray * 256 + gray) * 256 + 255;
            Pixels.Set(tex, x, y, color);
            x = x + 1;
        }
        y = y + 1;
    }
    return tex;
}

// =========================================================================
// Brick wall — brown bricks with dark mortar lines
// =========================================================================
func createBrickWall(size: Integer) -> Pixels {
    var tex = new Pixels(size, size);
    var brickW = size / 4;
    var brickH = size / 8;
    if (brickW < 2) { brickW = 2; }
    if (brickH < 2) { brickH = 2; }

    var y = 0;
    while (y < size) {
        var x = 0;
        while (x < size) {
            var row = y / brickH;
            var offset = 0;
            if (row % 2 == 1) { offset = brickW / 2; }
            var bx = (x + offset) % brickW;
            var by = y % brickH;

            // Mortar (dark)
            if (bx == 0 || by == 0) {
                Pixels.Set(tex, x, y, 0x2A2A2AFF);
            } else {
                // Brick body — brown with noise
                var noise = ((x * 11 + y * 7) % 16) - 8;
                var r = 140 + noise;
                var g = 90 + noise;
                var b = 55 + noise;
                if (r < 80) { r = 80; }
                if (r > 180) { r = 180; }
                if (g < 50) { g = 50; }
                if (g > 130) { g = 130; }
                if (b < 30) { b = 30; }
                if (b > 90) { b = 90; }
                var color = (r * 65536 + g * 256 + b) * 256 + 255;
                Pixels.Set(tex, x, y, color);
            }
            x = x + 1;
        }
        y = y + 1;
    }
    return tex;
}

// =========================================================================
// Wood — horizontal grain pattern in brown tones
// =========================================================================
func createWood(size: Integer) -> Pixels {
    var tex = new Pixels(size, size);
    var y = 0;
    while (y < size) {
        var x = 0;
        while (x < size) {
            // Horizontal grain: varies primarily with Y
            var grain = ((y * 3 + x / 4) % 12);
            var r = 120 + grain * 3;
            var g = 75 + grain * 2;
            var b = 40 + grain;
            if (r > 170) { r = 170; }
            if (g > 110) { g = 110; }
            var color = (r * 65536 + g * 256 + b) * 256 + 255;
            Pixels.Set(tex, x, y, color);
            x = x + 1;
        }
        y = y + 1;
    }
    return tex;
}

// =========================================================================
// Blood splat — irregular red circle for decals
// =========================================================================
func createBloodSplat(size: Integer) -> Pixels {
    var tex = new Pixels(size, size);
    var half = size / 2;
    var y = 0;
    while (y < size) {
        var x = 0;
        while (x < size) {
            var dx = x - half;
            var dy = y - half;
            var dist = Viper.Math.Sqrt(1.0 * dx * dx + 1.0 * dy * dy);
            var maxR = half - 1;

            // Irregular edge: use position hash to vary radius
            var edgeNoise = ((x * 13 + y * 7) % 5) - 2;
            var threshold = maxR + edgeNoise;

            if (dist < threshold) {
                // Dark red center, lighter red edge
                Pixels.Set(tex, x, y, 0xCC1111DD);
            } else {
                Pixels.Set(tex, x, y, 0x00000000);
            }
            x = x + 1;
        }
        y = y + 1;
    }
    return tex;
}

// =========================================================================
// Lava — orange/red hot pattern
// =========================================================================
func createLava(size: Integer) -> Pixels {
    var tex = new Pixels(size, size);
    var y = 0;
    while (y < size) {
        var x = 0;
        while (x < size) {
            var noise = ((x * 17 + y * 23 + x * y * 3) % 40);
            var r = 200 + noise;
            if (r > 255) { r = 255; }
            var g = 80 + noise;
            if (g > 150) { g = 150; }
            var b = 10 + noise / 3;
            var color = (r * 65536 + g * 256 + b) * 256 + 255;
            Pixels.Set(tex, x, y, color);
            x = x + 1;
        }
        y = y + 1;
    }
    return tex;
}
