// renderer.zia — Canvas3D setup, post-processing, fog, lighting
module renderer;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;
bind "../config";

class Renderer {
    hide Canvas3D canvas;
    hide Camera3D cam;
    hide PostFX3D postfx;
    hide Light3D sunLight;

    expose func initRenderer() {
        canvas = Canvas3D.New(config.WINDOW_TITLE, config.WINDOW_WIDTH, config.WINDOW_HEIGHT);
        cam = Camera3D.New(config.CAMERA_FOV,
                           1.0 * config.WINDOW_WIDTH / config.WINDOW_HEIGHT,
                           config.CAMERA_NEAR, config.CAMERA_FAR);

        // Initialize FPS camera
        var eye = new Vec3(0.0, config.PLAYER_EYE_HEIGHT, 0.0);
        var target = new Vec3(0.0, config.PLAYER_EYE_HEIGHT, -1.0);
        var up = new Vec3(0.0, 1.0, 0.0);
        Camera3D.LookAt(cam, eye, target, up);
        Camera3D.FPSInit(cam);

        // Sun light (dim, dungeon atmosphere)
        var sunDir = new Vec3(-0.3, -1.0, -0.5);
        sunLight = Light3D.NewDirectional(sunDir, 0.4, 0.35, 0.3);
        Canvas3D.SetLight(canvas, 0, sunLight);
        Canvas3D.SetAmbient(canvas, config.AMBIENT_R, config.AMBIENT_G, config.AMBIENT_B);

        // Fog
        Canvas3D.SetFog(canvas, config.FOG_NEAR, config.FOG_FAR,
                         config.FOG_R, config.FOG_G, config.FOG_B);

        // Post-processing
        postfx = PostFX3D.New();
        PostFX3D.AddBloom(postfx, 0.6, 0.35, 3);
        PostFX3D.AddVignette(postfx, 0.5, 0.3);
        PostFX3D.AddColorGrade(postfx, 1.05, 1.0, 1.1);
        Canvas3D.SetPostFX(canvas, postfx);

        // Mouse capture handled by game state transitions, not here
    }

    expose func getCanvas() -> Canvas3D {
        return canvas;
    }

    expose func getCamera() -> Camera3D {
        return cam;
    }

    expose func poll() -> Integer {
        return Canvas3D.Poll(canvas);
    }

    expose func shouldClose() -> Boolean {
        return Canvas3D.get_ShouldClose(canvas) != 0;
    }

    expose func getDeltaTime() -> Float {
        var dt = Canvas3D.get_DeltaTime(canvas) / 1000.0;
        if (dt > 0.05) { dt = 0.05; }
        return dt;
    }

    expose func getFps() -> Integer {
        return Canvas3D.get_Fps(canvas);
    }

    expose func clear() {
        Canvas3D.Clear(canvas, config.FOG_R, config.FOG_G, config.FOG_B);
    }

    expose func beginFrame() {
        Canvas3D.Begin(canvas, cam);
    }

    expose func endFrame() {
        Canvas3D.End(canvas);
    }

    expose func flip() {
        Canvas3D.Flip(canvas);
    }

    // Begin 2D overlay mode — orthographic projection through Metal pipeline
    expose func begin2D() {
        Canvas3D.Clear(canvas, 0.04, 0.04, 0.08);
        Canvas3D.Begin2D(canvas);
    }

    // End 2D overlay mode
    expose func end2D() {
        Canvas3D.End(canvas);
    }

    // Draw rectangle through 3D pipeline (works on Metal, not software FB)
    expose func drawRect(x: Integer, y: Integer, w: Integer, h: Integer, color: Integer) {
        Canvas3D.DrawRect3D(canvas, x, y, w, h, color);
    }

    expose func setTorchLight(index: Integer, x: Float, y: Float, z: Float, intensity: Float) {
        var pos = new Vec3(x, y, z);
        var light = Light3D.NewPoint(pos,
            config.TORCH_LIGHT_COLOR_R * intensity,
            config.TORCH_LIGHT_COLOR_G * intensity,
            config.TORCH_LIGHT_COLOR_B * intensity,
            config.TORCH_LIGHT_RANGE);
        // Offset by 1 since slot 0 is the sun
        Canvas3D.SetLight(canvas, index + 1, light);
    }

    expose func cleanup() {
        Viper.Input.Mouse.Release();
    }
}
