// =============================================================================
// CENTIPEDE - Particle System (using Viper.Game.ParticleEmitter)
// =============================================================================
// Visual effects for explosions, sparks, and other game events.
// Wraps the runtime ParticleEmitter API with named preset functions.
// =============================================================================

module particle;

bind "./config";

bind Viper.Graphics;
bind Viper.Game.ParticleEmitter as PE;

// =============================================================================
// PARTICLE SYSTEM ENTITY - Runtime-backed particle effects
// =============================================================================

class ParticleSystem {
    hide PE emitter;

    expose func init() {
        emitter = PE.New(256);
        emitter.set_FadeOut(true);
        emitter.set_Shrink(true);
    }

    // Generic radial burst
    expose func spawnExplosion(x: Integer, y: Integer, color: Integer, count: Integer) {
        emitter.SetPosition(x + 0.0, y + 0.0);
        emitter.set_Color(color);
        emitter.SetLifetime(15, 30);
        emitter.SetVelocity(3.0, 12.0, 0.0, 360.0);
        emitter.SetGravity(0.0, 0.3);
        emitter.SetSize(2.0, 4.0);
        emitter.Burst(count);
    }

    // Multi-colored big explosion
    expose func spawnBigExplosion(x: Integer, y: Integer) {
        emitter.SetPosition(x + 0.0, y + 0.0);
        emitter.SetLifetime(15, 30);
        emitter.SetVelocity(5.0, 14.0, 0.0, 360.0);
        emitter.SetGravity(0.0, 0.3);
        emitter.SetSize(2.0, 5.0);

        emitter.set_Color(config.COLOR_WHITE);
        emitter.Burst(8);
        emitter.set_Color(config.COLOR_YELLOW);
        emitter.Burst(6);
        emitter.set_Color(config.COLOR_ORANGE);
        emitter.Burst(4);
        emitter.set_Color(config.COLOR_RED);
        emitter.Burst(3);
    }

    // Medium explosion (color + white sparks)
    expose func spawnMediumExplosion(x: Integer, y: Integer, color: Integer) {
        self.spawnExplosion(x, y, color, 6);
        self.spawnExplosion(x, y, config.COLOR_WHITE, 3);
    }

    // Small explosion
    expose func spawnSmallExplosion(x: Integer, y: Integer, color: Integer) {
        self.spawnExplosion(x, y, color, 4);
    }

    // Single spark
    expose func spawnSpark(x: Integer, y: Integer, color: Integer) {
        emitter.SetPosition(x + 0.0, y + 0.0);
        emitter.set_Color(color);
        emitter.SetLifetime(6, 10);
        emitter.SetVelocity(2.0, 6.0, 0.0, 360.0);
        emitter.SetGravity(0.0, 0.2);
        emitter.SetSize(1.0, 2.0);
        emitter.Burst(1);
    }

    // Mushroom debris
    expose func spawnMushroomDebris(x: Integer, y: Integer) {
        emitter.SetPosition(x + 0.0, y + 0.0);
        emitter.SetLifetime(8, 14);
        emitter.SetVelocity(2.0, 8.0, 0.0, 360.0);
        emitter.SetGravity(0.0, 0.3);
        emitter.SetSize(1.0, 3.0);
        emitter.set_Color(config.COLOR_MUSHROOM_2);
        emitter.Burst(2);
        emitter.set_Color(config.COLOR_MUSHROOM_3);
        emitter.Burst(1);
    }

    // Centipede gore
    expose func spawnCentipedeGore(x: Integer, y: Integer, isHead: Boolean) {
        if isHead {
            self.spawnExplosion(x, y, config.COLOR_CENTIPEDE_HEAD, 8);
        } else {
            self.spawnExplosion(x, y, config.COLOR_CENTIPEDE_BODY, 8);
        }
        self.spawnExplosion(x, y, config.COLOR_GREEN, 4);
    }

    // Spider gore
    expose func spawnSpiderGore(x: Integer, y: Integer) {
        self.spawnExplosion(x, y, config.COLOR_SPIDER, 10);
        self.spawnExplosion(x, y, config.COLOR_BROWN, 5);
    }

    // Flea gore
    expose func spawnFleaGore(x: Integer, y: Integer) {
        self.spawnExplosion(x, y, config.COLOR_FLEA, 8);
        self.spawnExplosion(x, y, config.COLOR_PINK, 4);
    }

    // Scorpion gore
    expose func spawnScorpionGore(x: Integer, y: Integer) {
        self.spawnExplosion(x, y, config.COLOR_SCORPION, 12);
        self.spawnExplosion(x, y, config.COLOR_RED, 6);
    }

    // Player death explosion
    expose func spawnPlayerDeath(x: Integer, y: Integer) {
        self.spawnBigExplosion(x, y);
        self.spawnExplosion(x, y, config.COLOR_PLAYER, 10);
    }

    expose func update() {
        emitter.Update();
    }

    expose func draw(canvas: Canvas) {
        emitter.Draw(canvas);
    }

    expose func getActiveCount() -> Integer {
        return emitter.get_Count();
    }

    expose func clear() {
        emitter.Clear();
    }
}
