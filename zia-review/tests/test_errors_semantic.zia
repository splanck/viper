module TestErrorsSemantic;

// ERROR 1: Undefined variable
func err1() {
    var x = undefinedVar;
}

// ERROR 2: Duplicate variable in same scope
func err2() {
    var x = 1;
    var x = 2;
}

// ERROR 3: Access private member
entity Secret {
    Integer hidden;
    func init() { hidden = 42; }
}

func err3() {
    var s = new Secret();
    var v = s.hidden;
}

func start() {
    err1();
    err2();
    err3();
}
