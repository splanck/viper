module TestInheritance;
bind "./_support";

entity Animal {
    expose String species;
    expose Integer legs;

    func init() {
        species = "unknown";
        legs = 0;
    }

    expose func getSpecies() -> String {
        return species;
    }

    expose func getLegs() -> Integer {
        return legs;
    }

    expose func describe() -> String {
        return species;
    }
}

entity Dog extends Animal {
    expose String name;

    func init() {
        species = "canine";
        legs = 4;
        name = "Rex";
    }

    expose func getName() -> String {
        return name;
    }

    expose override func describe() -> String {
        return "dog:" + name;
    }

    expose func parentDescribe() -> String {
        return super.describe();
    }
}

entity Puppy extends Dog {
    expose Boolean isSmall;

    func init() {
        species = "canine";
        legs = 4;
        name = "Tiny";
        isSmall = true;
    }

    expose override func describe() -> String {
        return "puppy:" + name;
    }
}

entity Cat extends Animal {
    expose Boolean indoor;

    func init() {
        species = "feline";
        legs = 4;
        indoor = true;
    }

    expose override func describe() -> String {
        return "cat";
    }

    expose func isIndoor() -> Boolean {
        return indoor;
    }
}

entity Bird extends Animal {
    expose Integer wingspan;

    func init() {
        species = "avian";
        legs = 2;
        wingspan = 30;
    }

    expose func getWingspan() -> Integer {
        return wingspan;
    }

    expose override func describe() -> String {
        return "bird";
    }
}

func describeAnimal(a: Animal) -> String {
    return a.describe();
}

func start() {
    setTest("inherit parent fields");
    var d = new Dog();
    assertEqInt(d.legs, 4, "inherited field legs");
    assertEqStr(d.species, "canine", "inherited field species");

    setTest("inherit parent methods");
    assertEqInt(d.getLegs(), 4, "inherited method works");

    setTest("override parent method");
    assertEqStr(d.describe(), "dog:Rex", "overridden method");

    setTest("super call");
    assertEqStr(d.parentDescribe(), "canine", "super.describe() returns parent");

    setTest("two-level inheritance");
    var pup = new Puppy();
    assertEqStr(pup.describe(), "puppy:Tiny", "two-level override");
    assertEqInt(pup.getLegs(), 4, "grandparent method");

    setTest("inherited method sees field");
    assertEqStr(d.getSpecies(), "canine", "parent method reads child-set field");

    setTest("override changes behavior");
    var a = new Animal();
    assertEqStr(a.describe(), "unknown", "parent default");
    assertEqStr(d.describe(), "dog:Rex", "child override");

    setTest("polymorphism");
    assertEqStr(describeAnimal(d), "dog:Rex", "polymorphic dispatch");

    setTest("child new fields");
    var cat = new Cat();
    assertTrue(cat.indoor, "child-specific field");

    setTest("child new methods");
    assertTrue(cat.isIndoor(), "child-specific method");

    setTest("child init sets parent fields");
    var bird = new Bird();
    assertEqStr(bird.species, "avian", "child init sets parent field");
    assertEqInt(bird.getWingspan(), 30, "child field set in init");

    setTest("multiple children");
    assertEqStr(cat.describe(), "cat", "cat describe");
    assertEqStr(bird.describe(), "bird", "bird describe");

    report();
}
