module TestOperatorsLogicalBitwise;
bind "./_support";

func start() {
    setTest("operators_logical_bitwise");

    // 1. Logical AND (true && true)
    assertTrue(true && true, "true && true == true");

    // 2. Logical AND short-circuit (true && false)
    assertFalse(true && false, "true && false == false");

    // 3. Logical OR (false || true)
    assertTrue(false || true, "false || true == true");

    // 4. Logical OR short-circuit (true || false)
    assertTrue(true || false, "true || false == true");

    // 5. Logical NOT (!true)
    assertFalse(!true, "!true == false");

    // 6. Logical NOT (!false)
    assertTrue(!false, "!false == true");

    // 7. Bitwise AND
    assertEqInt(0xFF & 0x0F, 0x0F, "0xFF & 0x0F == 0x0F");

    // 8. Bitwise OR
    assertEqInt(0xF0 | 0x0F, 0xFF, "0xF0 | 0x0F == 0xFF");

    // 9. Bitwise XOR
    assertEqInt(0xFF ^ 0x0F, 0xF0, "0xFF ^ 0x0F == 0xF0");

    // 10. Bitwise NOT
    assertEqInt(~0, -1, "~0 == -1");

    // 11. Ternary operator true
    var a: Integer = true ? 1 : 2;
    assertEqInt(a, 1, "true ? 1 : 2 == 1");

    // 12. Ternary operator false
    var b: Integer = false ? 1 : 2;
    assertEqInt(b, 2, "false ? 1 : 2 == 2");

    // 13. String concatenation
    var s: String = "hello" + " " + "world";
    assertEqStr(s, "hello world", "string concatenation");

    // 14. Compound subtraction
    var x: Integer = 20;
    x -= 5;
    assertEqInt(x, 15, "20 -= 5 == 15");

    // 15. Compound modulo
    var y: Integer = 17;
    y %= 3;
    assertEqInt(y, 2, "17 %= 3 == 2");

    report();
}
