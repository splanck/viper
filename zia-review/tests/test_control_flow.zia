module TestControlFlow;
bind "./_support";

func guardTrueHelper() -> Integer {
    guard true else { return 0; }
    return 1;
}

func guardFalseHelper() -> Integer {
    guard false else { return 0; }
    return 1;
}

func start() {
    // 1. If true branch taken
    setTest("if-true-branch");
    var result1 = 0;
    if true {
        result1 = 1;
    } else {
        result1 = 2;
    }
    assertEqInt(result1, 1, "if true should take the true branch");

    // 2. If false, else branch taken
    setTest("if-false-else-branch");
    var result2 = 0;
    if false {
        result2 = 1;
    } else {
        result2 = 2;
    }
    assertEqInt(result2, 2, "if false should take the else branch");

    // 3. If-else-if chain (3 branches)
    setTest("if-else-if-chain");
    var x = 2;
    var result3 = 0;
    if x == 1 {
        result3 = 10;
    } else if x == 2 {
        result3 = 20;
    } else {
        result3 = 30;
    }
    assertEqInt(result3, 20, "else-if chain should match second branch");

    // 4. While loop counting to 10
    setTest("while-count-to-10");
    var count = 0;
    while count < 10 {
        count += 1;
    }
    assertEqInt(count, 10, "while loop should count to 10");

    // 5. While loop with early break
    setTest("while-early-break");
    var breakCount = 0;
    while true {
        breakCount += 1;
        if breakCount == 5 {
            break;
        }
    }
    assertEqInt(breakCount, 5, "while loop should break at 5");

    // 6. C-style for loop sum 1..10
    setTest("for-loop-sum");
    var sum = 0;
    for (var i = 1; i <= 10; i += 1) {
        sum += i;
    }
    assertEqInt(sum, 55, "sum of 1..10 should be 55");

    // 7. For-in range (0..5)
    setTest("for-in-range");
    var rangeSum = 0;
    for i in 0..5 {
        rangeSum += i;
    }
    assertEqInt(rangeSum, 10, "sum of 0..5 (exclusive) should be 0+1+2+3+4=10");

    // 8. For-in inclusive range (0..=4 should include 4)
    setTest("for-in-inclusive-range");
    var inclSum = 0;
    for i in 0..=4 {
        inclSum += i;
    }
    assertEqInt(inclSum, 10, "sum of 0..=4 (inclusive) should be 0+1+2+3+4=10");

    // 9. Break exits innermost loop
    setTest("break-innermost");
    var outer = 0;
    var inner = 0;
    for (var a = 0; a < 3; a += 1) {
        outer += 1;
        for (var b = 0; b < 10; b += 1) {
            if b == 2 {
                break;
            }
            inner += 1;
        }
    }
    assertEqInt(outer, 3, "outer loop should complete all 3 iterations");
    assertEqInt(inner, 6, "inner loop should run 2 times per outer iteration (3*2=6)");

    // 10. Continue skips iteration
    setTest("continue-skips");
    var contSum = 0;
    for (var c = 0; c < 5; c += 1) {
        if c == 2 {
            continue;
        }
        contSum += c;
    }
    assertEqInt(contSum, 8, "sum should be 0+1+3+4=8, skipping 2");

    // 11. Nested loop with break
    setTest("nested-loop-break");
    var totalIter = 0;
    for (var i = 0; i < 3; i += 1) {
        for (var j = 0; j < 3; j += 1) {
            if j == 1 {
                break;
            }
            totalIter += 1;
        }
    }
    assertEqInt(totalIter, 3, "nested loop with break: inner breaks at j==1, so 3 outer * 1 inner = 3");

    // 12. Guard with true condition (continues past)
    setTest("guard-true");
    var guardResult1 = guardTrueHelper();
    assertEqInt(guardResult1, 1, "guard true should continue past guard");

    // 13. Guard with false condition (exits via return from helper)
    setTest("guard-false");
    var guardResult2 = guardFalseHelper();
    assertEqInt(guardResult2, 0, "guard false should return early from else block");

    // 14. Match on integer values
    setTest("match-integer");
    var val = 3;
    var matchResult = 0;
    match val {
        1 => { matchResult = 10; }
        2 => { matchResult = 20; }
        3 => { matchResult = 30; }
        _ => { matchResult = 99; }
    }
    assertEqInt(matchResult, 30, "match should select arm for value 3");

    // 15. Match with wildcard (_) default
    setTest("match-wildcard");
    var val2 = 42;
    var wildResult = 0;
    match val2 {
        1 => { wildResult = 1; }
        2 => { wildResult = 2; }
        _ => { wildResult = 100; }
    }
    assertEqInt(wildResult, 100, "match wildcard should catch unmatched values");

    report();
}
