module TestGenerics;
bind "./_support";

entity Box[T] {
    T value;

    func init(v: T) {
        value = v;
    }

    func get() -> T {
        return value;
    }

    func set(v: T) {
        value = v;
    }
}

entity Pair[A, B] {
    A first;
    B second;

    func init(a: A, b: B) {
        first = a;
        second = b;
    }
}

func start() {
    testGenericEntity();
    testGenericMultipleTypes();
    testGenericCollections();
    report();
}

func testGenericEntity() {
    setTest("generic-entity");

    // 1. Generic entity with Integer
    var intBox = new Box[Integer](42);
    assertEqInt(intBox.get(), 42, "Box[Integer] get");

    // 2. Generic entity set and get
    intBox.set(99);
    assertEqInt(intBox.get(), 99, "Box[Integer] set then get");

    // 3. Generic entity with String
    var strBox = new Box[String]("hello");
    assertEqStr(strBox.get(), "hello", "Box[String] get");

    // 4. Multiple instances are independent
    var box1 = new Box[Integer](10);
    var box2 = new Box[Integer](20);
    assertEqInt(box1.get(), 10, "box1 independent");
    assertEqInt(box2.get(), 20, "box2 independent");
}

func testGenericMultipleTypes() {
    setTest("generic-multi-type");

    // 5. Generic entity with two type params
    var p = new Pair[Integer, String](42, "answer");
    assertEqInt(p.first, 42, "Pair first field");
    assertEqStr(p.second, "answer", "Pair second field");

    // 6. Different Pair instantiations
    var p2 = new Pair[String, Integer]("key", 100);
    assertEqStr(p2.first, "key", "Pair[String,Integer] first");
    assertEqInt(p2.second, 100, "Pair[String,Integer] second");

    // 7. Pair with same types
    var p3 = new Pair[Integer, Integer](1, 2);
    assertEqInt(p3.first, 1, "Pair[Int,Int] first");
    assertEqInt(p3.second, 2, "Pair[Int,Int] second");

    // 8. Generic entity field mutation
    var p4 = new Pair[Integer, Integer](0, 0);
    p4.first = 100;
    p4.second = 200;
    assertEqInt(p4.first, 100, "Pair field mutation first");
    assertEqInt(p4.second, 200, "Pair field mutation second");
}

func testGenericCollections() {
    setTest("generic-collections");

    // 9. List of Integers via literal
    var intList = [1, 2, 3];
    assertEqInt(intList.count(), 3, "list count");

    // 10. Nested generic: Box holding Integer
    var nested = new Box[Integer](0);
    nested.set(555);
    assertEqInt(nested.get(), 555, "nested generic box");

    // 11. Multiple Box instances with different types
    var b1 = new Box[Integer](1);
    var b2 = new Box[String]("two");
    assertEqInt(b1.get(), 1, "multi-type box int");
    assertEqStr(b2.get(), "two", "multi-type box string");

    // 12. Generic entity as function parameter
    var box = new Box[Integer](42);
    var val = extractInt(box);
    assertEqInt(val, 42, "generic entity as param");
}

func extractInt(box: Box[Integer]) -> Integer {
    return box.get();
}
