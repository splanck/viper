module TestPrimitives;
bind "./_support";

func start() {
    setTest("primitives");

    // 1. Integer default value
    var i: Integer;
    assertEqInt(i, 0, "integer default is 0");

    // 2. Number default value
    var n: Number;
    assertApprox(n, 0.0, 0.001, "number default is 0.0");

    // 3. Boolean default value
    var b: Boolean;
    assertFalse(b, "boolean default is false");

    // 4. String default value
    var s: String;
    assertEmpty(s, "string default is empty");

    // 5. Integer max value operations
    var big: Integer = 1000000;
    var result: Integer = big * 1000;
    assertEqInt(result, 1000000000, "integer large multiplication");

    // 6. Number precision
    var pi: Number = 3.14159;
    assertApprox(pi, 3.14159, 0.00001, "number precision 3.14159");

    // 7. Boolean negation
    assertTrue(!false, "!false is true");
    assertFalse(!true, "!true is false");

    // 8. String length via Viper.String.Length
    var greeting: String = "hello";
    assertEqInt(Viper.String.Length(greeting), 5, "string length of hello is 5");

    // 9. Integer hex literal
    var hex: Integer = 0xFF;
    assertEqInt(hex, 255, "0xFF == 255");

    // 10. Integer binary literal
    var bin: Integer = 0b1010;
    assertEqInt(bin, 10, "0b1010 == 10");

    // 11. Type inference with var
    var inferred = 99;
    assertEqInt(inferred, 99, "var infers integer type");

    // 12. Final immutability
    final x = 42;
    assertEqInt(x, 42, "final variable holds value");

    report();
}
