module TestErrorHandling;
bind "./_support";

func start() {
    testGuardBasic();
    testGuardWithValues();
    testGuardNested();
    testTryCatch();
    report();
}

func testGuardBasic() {
    setTest("guard-basic");

    // 1. Guard with true condition passes through
    var passed = guardTrueHelper();
    assertTrue(passed, "guard true passes through");

    // 2. Guard with false condition returns early
    var failed = guardFalseHelper();
    assertFalse(failed, "guard false returns early");

    // 3. Guard with comparison
    var result = guardPositive(5);
    assertTrue(result, "guard positive passes");

    // 4. Guard with zero fails
    var result2 = guardPositive(0);
    assertFalse(result2, "guard zero fails");
}

func testGuardWithValues() {
    setTest("guard-values");

    // 5. Guard returns computed value on pass
    var v = guardAndCompute(10);
    assertEqInt(v, 20, "guard passes and computes");

    // 6. Guard returns default on fail
    var v2 = guardAndCompute(-5);
    assertEqInt(v2, -1, "guard fails and returns default");

    // 7. Guard with string check
    var s = guardNonEmpty("hello");
    assertEqStr(s, "hello!", "guard non-empty passes");

    // 8. Guard with empty string
    var s2 = guardNonEmpty("");
    assertEqStr(s2, "empty", "guard empty fails");
}

func testGuardNested() {
    setTest("guard-nested");

    // 9. Multiple guards in sequence
    var r = multiGuard(5, 3);
    assertEqInt(r, 8, "multi guard both pass");

    // 10. First guard fails
    var r2 = multiGuard(-1, 3);
    assertEqInt(r2, -1, "first guard fails");

    // 11. Second guard fails
    var r3 = multiGuard(5, -1);
    assertEqInt(r3, -2, "second guard fails");

    // 12. Guard in loop
    var sum = guardInLoop();
    assertEqInt(sum, 40, "guard filters in loop");
}

func guardTrueHelper() -> Boolean {
    guard true else {
        return false;
    }
    return true;
}

func guardFalseHelper() -> Boolean {
    guard false else {
        return false;
    }
    return true;
}

func guardPositive(x: Integer) -> Boolean {
    guard x > 0 else {
        return false;
    }
    return true;
}

func guardAndCompute(x: Integer) -> Integer {
    guard x > 0 else {
        return -1;
    }
    return x * 2;
}

func guardNonEmpty(s: String) -> String {
    guard Viper.String.Length(s) > 0 else {
        return "empty";
    }
    return s + "!";
}

func multiGuard(a: Integer, b: Integer) -> Integer {
    guard a > 0 else {
        return -1;
    }
    guard b > 0 else {
        return -2;
    }
    return a + b;
}

func guardInLoop() -> Integer {
    // Sum only values > 5 from 1..10
    var sum = 0;
    for (var i = 1; i <= 10; i += 1) {
        if i <= 5 {
            continue;
        }
        sum += i;
    }
    return sum;
}

func testTryCatch() {
    setTest("try-catch");

    // 13. Try block with no throw executes normally
    var x = 0;
    try {
        x = 42;
    } catch (e) {
        x = -1;
    }
    assertEqInt(x, 42, "try no-throw runs body");

    // 14. Try/catch with finally
    var y = 0;
    try {
        y = 10;
    } catch (e) {
        y = -1;
    } finally {
        y += 1;
    }
    assertEqInt(y, 11, "try/finally runs both");

    // 15. Throw triggers catch block
    var z = 0;
    try {
        throw "error";
    } catch (e) {
        z = 99;
    }
    assertEqInt(z, 99, "throw triggers catch");

    // 16. Throw with finally
    var w = 0;
    try {
        throw "fail";
    } catch (e) {
        w = 50;
    } finally {
        w += 5;
    }
    assertEqInt(w, 55, "throw catch finally all run");
}
