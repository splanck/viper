module TestValues;
bind "./_support";

value Vec2i {
    expose Integer x;
    expose Integer y;

    expose func init(px: Integer, py: Integer) {
        x = px;
        y = py;
    }
}

value Vec3i {
    expose Integer a;
    expose Integer b;
    expose Integer c;

    expose func init(pa: Integer, pb: Integer, pc: Integer) {
        a = pa;
        b = pb;
        c = pc;
    }
}

value NumPair {
    expose Number p;
    expose Number q;

    expose func init(pp: Number, pq: Number) {
        p = pp;
        q = pq;
    }
}

value Flags {
    expose Boolean active;
    expose Boolean visible;

    expose func init(a: Boolean, v: Boolean) {
        active = a;
        visible = v;
    }
}

value Label {
    expose Integer code;
    expose Integer tag;

    expose func init(c: Integer, t: Integer) {
        code = c;
        tag = t;
    }
}

value Named {
    expose String name;
    expose Integer id;

    expose func init(n: String, i: Integer) {
        name = n;
        id = i;
    }
}

value Rect {
    expose Integer w;
    expose Integer h;

    expose func init(pw: Integer, ph: Integer) {
        w = pw;
        h = ph;
    }

    expose func area() -> Integer {
        return w * h;
    }

    expose func perimeter() -> Integer {
        return 2 * (w + h);
    }
}

func addVec(v: Vec2i) -> Integer {
    return v.x + v.y;
}

func start() {
    setTest("value creation");
    var v = new Vec2i(10, 20);
    assertEqInt(v.x, 10, "value field x from init");
    assertEqInt(v.y, 20, "value field y from init");

    setTest("value field mutation");
    v.x = 99;
    assertEqInt(v.x, 99, "value field mutated");

    setTest("value copy semantics");
    var orig = new Vec2i(100, 200);
    var copy = orig;
    copy.x = 999;
    assertEqInt(orig.x, 100, "original unchanged after copy mutation");
    assertEqInt(copy.x, 999, "copy has new value");

    setTest("multiple fields");
    var v3 = new Vec3i(1, 2, 3);
    assertEqInt(v3.a, 1, "first of three fields");
    assertEqInt(v3.b, 2, "second of three fields");
    assertEqInt(v3.c, 3, "third of three fields");

    setTest("value method");
    var r = new Rect(5, 3);
    assertEqInt(r.area(), 15, "value method computes");

    setTest("value computed method");
    var r2 = new Rect(4, 6);
    assertEqInt(r2.perimeter(), 20, "perimeter computed");

    setTest("value pass to function");
    var pv = new Vec2i(3, 7);
    assertEqInt(addVec(pv), 10, "value passed by copy");
    assertEqInt(pv.x, 3, "original unchanged");

    setTest("integer fields arithmetic");
    var iv = new Vec2i(-42, 42);
    assertEqInt(iv.x + iv.y, 0, "integer fields sum to zero");

    setTest("number fields");
    var np = new NumPair(3.14, 2.72);
    assertTrue(np.p > 3.0, "number field p > 3.0");
    assertTrue(np.q > 2.0, "number field q > 2.0");

    setTest("boolean fields");
    var fl = new Flags(true, false);
    assertTrue(fl.active, "boolean field true");
    assertFalse(fl.visible, "boolean field false");

    // BUG-VAL-001 regression: value types with String fields
    setTest("string fields");
    var nm = new Named("hello", 7);
    assertEqStr(nm.name, "hello", "value string field");
    assertEqInt(nm.id, 7, "value int field with string");

    setTest("label fields");
    var lb = new Label(42, 99);
    assertEqInt(lb.code, 42, "label code field");
    assertEqInt(lb.tag, 99, "label tag field");

    setTest("value independence");
    var a = new Vec2i(1, 2);
    var b = new Vec2i(3, 4);
    assertEqInt(a.x, 1, "a.x independent");
    assertEqInt(b.x, 3, "b.x independent");

    report();
}
