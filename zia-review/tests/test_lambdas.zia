module TestLambdas;
bind "./_support";

func start() {
    testBasicLambdas();
    testClosures();
    testHigherOrder();
    report();
}

func testBasicLambdas() {
    setTest("lambda-basics");

    // 1. Simple lambda with one param
    var double = (x: Integer) => x * 2;
    assertEqInt(double(5), 10, "lambda double");

    // 2. Lambda with two params
    var add = (a: Integer, b: Integer) => a + b;
    assertEqInt(add(3, 4), 7, "lambda add two params");

    // 3. Lambda returning string
    var greet = (name: String) => "Hello " + name;
    assertEqStr(greet("World"), "Hello World", "lambda returning string");

    // 4. Lambda with boolean logic
    var isPositive = (n: Integer) => n > 0;
    assertTrue(isPositive(5), "lambda isPositive true");
    assertFalse(isPositive(-3), "lambda isPositive false");
}

func testClosures() {
    setTest("closures");

    // 5. Lambda capturing local variable
    var offset = 10;
    var addOffset = (x: Integer) => x + offset;
    assertEqInt(addOffset(5), 15, "closure captures local var");

    // 6. Lambda capturing multiple variables
    var a = 100;
    var b = 200;
    var sumAB = () => a + b;
    assertEqInt(sumAB(), 300, "closure captures multiple vars");

    // 7. Lambda capturing mutable variable
    var count = 0;
    var increment = () => count + 1;
    assertEqInt(increment(), 1, "closure sees var value");

    // 8. Lambda captures value at call time
    var base = 5;
    var getBase = () => base;
    assertEqInt(getBase(), 5, "closure captures base");
}

func testHigherOrder() {
    setTest("higher-order");

    // 9. Pass lambda to function
    var result = applyOp(10, 3, (a: Integer, b: Integer) => a + b);
    assertEqInt(result, 13, "pass lambda to function - add");

    // 10. Pass different lambda to same function
    var result2 = applyOp(10, 3, (a: Integer, b: Integer) => a * b);
    assertEqInt(result2, 30, "pass lambda to function - multiply");

    // 11. Lambda returning lambda-like behavior
    var x = 42;
    var getX = () => x;
    assertEqInt(getX(), 42, "lambda as getter");

    // 12. Multiple lambda calls
    var sq = (n: Integer) => n * n;
    assertEqInt(sq(1), 1, "square 1");
    assertEqInt(sq(5), 25, "square 5");
    assertEqInt(sq(10), 100, "square 10");
}

func applyOp(a: Integer, b: Integer, op: (Integer, Integer) -> Integer) -> Integer {
    return op(a, b);
}
