module TestEntities;
bind "./_support";

entity Point {
    expose Integer x;
    expose Integer y;

    func init() {
        x = 0;
        y = 0;
    }

    expose func getX() -> Integer {
        return x;
    }

    expose func getY() -> Integer {
        return y;
    }

    expose func setXY(nx: Integer, ny: Integer) {
        self.x = nx;
        self.y = ny;
    }

    expose func sum() -> Integer {
        return x + y;
    }

    expose func doubleX() -> Integer {
        return self.getX() * 2;
    }
}

entity Named {
    expose String name;

    func init() {
        name = "unnamed";
    }

    expose func getName() -> String {
        return name;
    }
}

// NOTE: Static fields/methods have sema issues (BUG-STATIC-001).
// Testing regular entity features only.
entity IdHolder {
    expose Integer id;

    func init(val: Integer) {
        id = val;
    }

    expose func getId() -> Integer {
        return id;
    }
}

entity Defaults {
    expose Integer a;
    expose Integer b;
    expose Integer c;

    func init() {
        a = 10;
        b = 20;
        c = 30;
    }

    expose func total() -> Integer {
        return a + b + c;
    }
}

func acceptEntity(p: Point) -> Integer {
    return p.sum();
}

func start() {
    setTest("entity creation");
    var p = new Point();
    assertEqInt(p.getX(), 0, "new entity init values");

    setTest("field access");
    p.x = 5;
    assertEqInt(p.x, 5, "field set and get");

    setTest("method call");
    p.x = 3;
    p.y = 4;
    assertEqInt(p.sum(), 7, "method returns correct value");

    setTest("init constructor");
    var p2 = new Point();
    assertEqInt(p2.getX(), 0, "init sets x to 0");
    assertEqInt(p2.getY(), 0, "init sets y to 0");

    setTest("multiple fields");
    p2.x = 10;
    p2.y = 20;
    assertEqInt(p2.x, 10, "first field");
    assertEqInt(p2.y, 20, "second field");

    setTest("method returning value");
    p2.x = 7;
    assertEqInt(p2.getX(), 7, "getter returns field");

    setTest("method modifying field");
    var p3 = new Point();
    p3.setXY(100, 200);
    assertEqInt(p3.x, 100, "method modified x");
    assertEqInt(p3.y, 200, "method modified y");

    setTest("self reference");
    var p4 = new Point();
    p4.setXY(42, 58);
    assertEqInt(p4.sum(), 100, "self reference works");

    setTest("string field");
    var n = new Named();
    assertEqStr(n.getName(), "unnamed", "string field default");

    setTest("instance independence");
    var a = new Point();
    var b = new Point();
    a.x = 1;
    b.x = 2;
    assertEqInt(a.x, 1, "first instance unchanged");
    assertEqInt(b.x, 2, "second instance independent");

    setTest("pass entity to function");
    var pf = new Point();
    pf.x = 3;
    pf.y = 7;
    assertEqInt(acceptEntity(pf), 10, "entity passed to function");

    setTest("method calling method");
    var pd = new Point();
    pd.x = 15;
    assertEqInt(pd.doubleX(), 30, "method calls another method");

    setTest("entity id");
    var c1 = new IdHolder(1);
    var c2 = new IdHolder(2);
    assertEqInt(c1.getId(), 1, "first entity id");
    assertEqInt(c2.getId(), 2, "second entity id");

    setTest("entity independence via id");
    assertNeqInt(c1.id, c2.id, "different entities have different ids");

    setTest("default values via init");
    var d = new Defaults();
    assertEqInt(d.total(), 60, "init sets defaults correctly");

    report();
}
