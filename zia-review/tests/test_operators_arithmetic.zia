module TestOperatorsArithmetic;
bind "./_support";

func start() {
    setTest("operators_arithmetic");

    // 1. Addition
    assertEqInt(3 + 4, 7, "3 + 4 == 7");

    // 2. Subtraction
    assertEqInt(10 - 3, 7, "10 - 3 == 7");

    // 3. Multiplication
    assertEqInt(6 * 7, 42, "6 * 7 == 42");

    // 4. Division
    assertEqInt(15 / 3, 5, "15 / 3 == 5");

    // 5. Modulo
    assertEqInt(17 % 5, 2, "17 % 5 == 2");

    // 6. Unary negation
    var neg: Integer = -42;
    assertEqInt(neg, 0 - 42, "-42 == 0 - 42");

    // 7. Equality
    assertTrue(5 == 5, "5 == 5");

    // 8. Inequality
    assertTrue(5 != 6, "5 != 6");

    // 9. Less than
    assertTrue(3 < 5, "3 < 5");

    // 10. Greater than
    assertTrue(5 > 3, "5 > 3");

    // 11. Less or equal
    assertTrue(5 <= 5, "5 <= 5");
    assertTrue(4 <= 5, "4 <= 5");

    // 12. Greater or equal
    assertTrue(5 >= 5, "5 >= 5");
    assertTrue(6 >= 5, "6 >= 5");

    // 13. Compound addition
    var x: Integer = 10;
    x += 3;
    assertEqInt(x, 13, "10 += 3 == 13");

    // 14. Compound multiplication
    var y: Integer = 5;
    y *= 2;
    assertEqInt(y, 10, "5 *= 2 == 10");

    // 15. Operator precedence
    assertEqInt(2 + 3 * 4, 14, "2 + 3 * 4 == 14");

    report();
}
