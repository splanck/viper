module debug_tree_probe;

// ============================================================================
// MODULE: debug_tree_probe
// PURPOSE: Validate plan 13's Variables-tree model against real adapter data:
//          the session's varTree expand/collapse state, the synchronous child
//          fetch + cache, and resume-invalidation that keeps expansion but drops
//          the (now dead) child cache.
//
// WHERE-THIS-FITS: debug_commands renders GUI.VirtualTree rows from
//          DebugSession.varTree (a var_model.VarTreeState) and lazily fills the
//          cache via DebugSession.FetchChildren. This probe drives that model
//          layer headlessly. Requires `--viper-bin <path>`.
// ============================================================================

bind "../build/debug_session";
bind "../build/breakpoints";
bind "../build/var_model";

bind Env = Viper.System.Environment;
bind Time = Viper.Time;
bind File = Viper.IO.File;
bind Path = Viper.IO.Path;
bind TempFile = Viper.IO.TempFile;
bind Str = Viper.String;
bind Terminal = Viper.Terminal;

func argValue(name: String) -> String {
    var i = 0;
    while i < Env.GetArgumentCount() - 1 {
        if Env.GetArgument(i) == name { return Env.GetArgument(i + 1); }
        i = i + 1;
    }
    return "";
}

func fail(reason: String) {
    Terminal.Say("RESULT: fail " + reason);
}

func pollUntilSettled(session: debug_session.DebugSession, budgetMs: Integer) {
    var waited = 0;
    while session.IsActive() and session.stopped == false and waited < budgetMs {
        session.Poll();
        if session.stopped or session.terminated { return; }
        Time.Clock.Sleep(5);
        waited = waited + 5;
    }
    session.Poll();
}

func findLocal(session: debug_session.DebugSession, name: String) -> Integer {
    var i = 0;
    while i < session.LocalCount() {
        if session.LocalName(i) == name { return i; }
        i = i + 1;
    }
    return -1;
}

/// @brief Replicate debug_commands.FetchAndCacheChildren against the session so
///        the probe exercises the same fetch → VarChildRec → cache path.
func fetchAndCache(session: debug_session.DebugSession, path: String, varRef: Integer) -> Boolean {
    if session.FetchChildren(varRef, 0, 100) == false { return false; }
    var wrap = new var_model.VarChildList();
    var n = session.VarChildCount();
    var i = 0;
    while i < n {
        var rec = new var_model.VarChildRec();
        rec.name = session.VarChildName(i);
        rec.value = session.VarChildValue(i);
        rec.typeName = session.VarChildType(i);
        rec.varRef = session.VarChildVarRef(i);
        rec.childCount = session.VarChildChildCount(i);
        wrap.items.add(rec);
        i = i + 1;
    }
    session.varTree.PutCache(path, wrap);
    return true;
}

func main() {
    var viperBin = argValue("--viper-bin");
    if viperBin == "" {
        fail("no --viper-bin argument");
        return;
    }

    var dir = TempFile.CreateDirWithPrefix("viperide_dbgtree_");
    var prog = Path.Join(dir, "tree.zia");
    File.WriteAllText(prog,
        "func main() -> Integer {\n"                 // 1
        + "    var nums: List[Integer] = [];\n"       // 2
        + "    nums.add(10);\n"                        // 3
        + "    nums.add(20);\n"                        // 4
        + "    nums.add(30);\n"                        // 5
        + "    var total = nums.count();\n"           // 6  <- breakpoint
        + "    return total;\n"                         // 7
        + "}\n");                                       // 8

    var store = new breakpoints.BreakpointStore();
    store.Toggle(prog, 6);

    var session = new debug_session.DebugSession();
    if session.Launch(viperBin, prog, store) == false {
        fail("Launch returned false");
        return;
    }

    pollUntilSettled(session, 8000);
    if session.stopped == false {
        fail("did not stop at breakpoint (terminated=" + session.terminated + ")");
        return;
    }

    // varTree must exist and start collapsed.
    if session.varTree == null {
        fail("session.varTree is null");
        return;
    }
    if session.varTree.IsExpanded("nums") {
        fail("nums should start collapsed");
        return;
    }

    var numsIdx = findLocal(session, "nums");
    if numsIdx < 0 { fail("local 'nums' not found"); return; }
    var numsRef = session.LocalVarRef(numsIdx);
    if numsRef <= 0 { fail("nums has no varRef"); return; }

    // Expand → fetch → cache, mirroring the render path.
    if session.varTree.Toggle("nums") == false {
        fail("Toggle('nums') did not expand");
        return;
    }
    if fetchAndCache(session, "nums", numsRef) == false {
        fail("fetchAndCache failed");
        return;
    }
    if session.varTree.HasCache("nums") == false {
        fail("cache missing after fetch");
        return;
    }
    var kids = session.varTree.GetCache("nums");
    if kids == null or kids.items.count() != 3 {
        fail("cached child count wrong");
        return;
    }
    var c0 = kids.items.get(0) as var_model.VarChildRec;
    if c0.value != "10" or c0.name != "[0]" {
        fail("child 0 was name=" + c0.name + " value=" + c0.value);
        return;
    }

    // Resume-invalidation: stepping drops the cache but keeps the expanded set,
    // so the same node re-opens at the next stop.
    if session.StepOver() == false { fail("StepOver rejected"); return; }
    if session.varTree.HasCache("nums") {
        fail("cache should be dropped after resume");
        return;
    }
    if session.varTree.IsExpanded("nums") == false {
        fail("expansion should survive resume (re-expand by name)");
        return;
    }

    // At the next stop, re-fetch works against the fresh varRef.
    pollUntilSettled(session, 8000);
    if session.stopped == false { fail("did not re-stop after StepOver"); return; }
    var numsIdx2 = findLocal(session, "nums");
    if numsIdx2 >= 0 {
        var numsRef2 = session.LocalVarRef(numsIdx2);
        if numsRef2 > 0 {
            if fetchAndCache(session, "nums", numsRef2) == false {
                fail("re-fetch after step failed");
                return;
            }
            var kids2 = session.varTree.GetCache("nums");
            if kids2 == null or kids2.items.count() != 3 {
                fail("re-fetched child count wrong");
                return;
            }
        }
    }

    // ClearAll forgets expansion entirely (new-session semantics).
    session.varTree.ClearAll();
    if session.varTree.IsExpanded("nums") {
        fail("ClearAll should drop expansion");
        return;
    }

    session.Terminate();
    Terminal.Say("RESULT: ok");
}
