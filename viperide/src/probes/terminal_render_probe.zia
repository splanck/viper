//
// File: viperide/src/probes/terminal_render_probe.zia
// Purpose: Headless regression for interactive terminal-mode rendering (Phase
//          5E): non-SGR escapes (OSC, ESC7/8) are swallowed rather than leaked
//          as garbage, and \r / ESC[K / backspace overwrite the current line so
//          shell prompts and line-editing render cleanly.
//
//===----------------------------------------------------------------------===//

module terminal_render_probe;

bind "../ui/app_shell";

bind Viper.GUI as GUI;
bind Terminal = Viper.Terminal;

// ============================================================================
// MODULE: terminal_render_probe
// PURPOSE: Display-backed probe for OutputPane terminal-mode rendering.
//
// WHERE-THIS-FITS: TerminalController owns PTY session state, while OutputPane
//          owns escape handling and visible terminal text. This probe focuses on
//          rendering behavior after terminal bytes are appended.
//
// TEACHING-NOTE: Terminal rendering is intentionally limited. Probe the supported
//          subset explicitly and keep full-screen TUI behavior out of scope.
// ============================================================================

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

func main() {
    var shell = new app_shell.AppShell();
    shell.Build("ViperIDE Terminal Render Probe", 1000, 700);
    var pane = shell.terminalPane;
    pane.SetTerminalMode(true);

    // OSC window-title (swallowed) + SGR color + "hello", then \r + ESC[K + "world".
    // Cursor model: "hello" at col 0, \r -> col 0, ESC[K clears the line, "world".
    pane.Append("\x1b]0;window title\x07\x1b[32mhello\x1b[0m\r\x1b[Kworld");
    pane.SelectAll();
    var text = pane.GetSelection();
    if text.Contains("title") { fail(shell, "OSC leaked: " + text); return; }
    if text.Contains("hello") { fail(shell, "overwrite failed (hello remains): " + text); return; }
    if text.Contains("\x1b") { fail(shell, "escape byte leaked"); return; }
    if text.Contains("world") == false { fail(shell, "expected 'world', got: " + text); return; }

    // ESC 7 / ESC 8 (save/restore cursor) must be swallowed, not printed as "7"/"8".
    pane.Clear();
    pane.Append("\x1b7ok\x1b8");
    pane.SelectAll();
    var t2 = pane.GetSelection();
    if t2.Contains("7") { fail(shell, "ESC7 leaked: " + t2); return; }
    if t2.Contains("ok") == false { fail(shell, "expected 'ok', got: " + t2); return; }

    // Backspace overwrite: "abc" then two backspaces + "X" -> "aXc".
    pane.Clear();
    pane.Append("abc\b\bX");
    pane.SelectAll();
    var t3 = pane.GetSelection();
    if t3.Contains("aXc") == false { fail(shell, "backspace overwrite wrong: " + t3); return; }

    // Cursor row addressing: common shell redraws use CSI H/f to place output
    // on more than one row. The terminal pane should retain separate lines.
    pane.Clear();
    pane.Append("\x1b[2J\x1b[1;1Htop\x1b[2;4Hmid");
    pane.SelectAll();
    var t4 = pane.GetSelection();
    if t4.Contains("top") == false { fail(shell, "row 1 text missing: " + t4); return; }
    if t4.Contains("mid") == false { fail(shell, "row 2 text missing: " + t4); return; }
    if t4.Contains("topmid") { fail(shell, "row addressing collapsed into one line: " + t4); return; }

    shell.Destroy();
    Terminal.Say("RESULT: ok");
}
