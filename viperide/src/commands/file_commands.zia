module file_commands;

bind "../ui/app_shell";
bind "../core/document";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../services/file_utils";

bind Viper.GUI;
bind IO = Viper.IO;
bind Path = Viper.IO.Path;
bind Dir = Viper.IO.Dir;
bind Exec = Viper.System.Exec;
bind Str = Viper.String;
bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;

var confirmDirtyClose = true;
var trimTrailingWhitespaceOnSave = false;
var ensureFinalNewlineOnSave = true;

final CLOSE_CHOICE_CANCEL = 0;
final CLOSE_CHOICE_SAVE = 1;
final CLOSE_CHOICE_DISCARD = 2;

/// @brief Result object returned by Save All so callers can stop destructive work.
/// @details Build, debug, close, and project operations need to distinguish a
///          successful save sweep from a user cancellation or failed disk write.
///          A plain saved-count cannot express those states.
class SaveAllResult {
    expose Boolean success;
    expose Boolean canceled;
    expose Integer savedCount;
    expose String message;

    /// @brief Initialize to a failed/no-op result until a handler marks success.
    expose func init() {
        success = false;
        canceled = false;
        savedCount = 0;
        message = "";
    }
}

// ============================================================================
// MODULE: file_commands
// PURPOSE: File-management command handlers (New, Open, Save, Save As,
//          Save All, Close, Reload, Exit) plus Open Folder for projects.
//          Coordinates DocumentManager, EditorTabs, EditorEngine, and
//          AppShell so a single user action updates every relevant
//          surface (tab title, breadcrumb, status bar, modified marker,
//          tooltip).
//
// WHERE-THIS-FITS: Wired into main.zia's command dispatcher. Most
//          handlers take the same four arguments (shell, docMgr,
//          engine, tabs) — that's the "active document context."
//
// KEY-DESIGN-CHOICES:
//   * SaveEditorState BEFORE EVERY MUTATION. Every handler starts by
//     copying the editor's current cursor / scroll / text into the
//     active Document so subsequent operations work against fresh
//     state. This is the IDE equivalent of "flush the write buffer
//     before fsync."
//   * SAVE OF UNTITLED -> SAVE AS PROMPT. handleSave detects
//     `doc.isNew` and routes to a SaveAs dialog rather than failing.
//   * MODIFIED-PROMPT ON CLOSE. handleClose routes through the shared
//     ConfirmCloseDocuments path so tab close, File > Close, project
//     switch, and exit use the same dirty-document sweep.
//   * BREADCRUMB AUTO-HIDE. SetBreadcrumbPath("") hides the breadcrumb
//     when no path is meaningful (after closing the last document).
//   * STATUS LABEL HELPER. DocStatusLabel renders "Zia | LF" / "Basic |
//     CRLF" — the tiny right-aligned label in the status bar. Reused
//     by every handler that lands on a different document.
// ============================================================================

/// @brief Create a new untitled document and activate its tab.
func handleNew(shell: app_shell.AppShell,
               docMgr: document_manager.DocumentManager,
               engine: editor_engine.EditorEngine,
               tabs: editor_tabs.EditorTabs) {
    SaveEditorState(docMgr, engine);

    var newDoc = docMgr.NewDocument();
    tabs.AddTab(newDoc.fileName, 1);
    tabs.SetTooltip(docMgr.activeIndex, newDoc.fileName);
    tabs.SetActive(docMgr.activeIndex);
    engine.LoadDocument(newDoc);

    shell.SetBreadcrumbPath("");
    shell.SetStatusLeft("New file created");
    shell.SetStatusRight(DocStatusLabel(newDoc));
}

/// @brief File-open dialog -> OpenFileAtPath if a file was picked.
func handleOpen(shell: app_shell.AppShell,
                docMgr: document_manager.DocumentManager,
                engine: editor_engine.EditorEngine,
                tabs: editor_tabs.EditorTabs) {
    var path = FileDialog.Open("Open File", "", file_utils.OpenDialogFilter());
    if path != "" {
        OpenFileAtPath(shell, docMgr, engine, tabs, path);
    }
}

/// @brief Folder-picker dialog -> ProjectManager.OpenFolder for the
///        chosen path. Updates the file-tree sidebar.
func handleOpenFolder(shell: app_shell.AppShell,
                      projMgr: project_manager.ProjectManager) {
    var folderPath = FileDialog.SelectFolder("Open Folder", "");
    if folderPath != "" {
        projMgr.OpenFolder(folderPath);
        shell.SetStatusLeft("Opened project: " + projMgr.project.name);
    }
}

/// @brief Folder-picker dialog -> ProjectManager.AddFolderToWorkspace, adding
///        another root to the tree without closing the current project/docs.
func handleAddFolderToWorkspace(shell: app_shell.AppShell,
                                projMgr: project_manager.ProjectManager) {
    var folderPath = FileDialog.SelectFolder("Add Folder to Workspace", "");
    if folderPath != "" {
        projMgr.AddFolderToWorkspace(folderPath);
        shell.SetStatusLeft("Added folder to workspace: " + folderPath);
    }
}

/// @brief Save active document. Untitled docs route to a Save As prompt.
func handleSave(shell: app_shell.AppShell,
                docMgr: document_manager.DocumentManager,
                engine: editor_engine.EditorEngine,
                tabs: editor_tabs.EditorTabs) -> Boolean {
    SaveEditorState(docMgr, engine);
    var saveDoc = docMgr.GetActive();
    if saveDoc != null {
        if saveDoc.isReadOnlyPreview {
            shell.SetStatusLeft("Read-only preview cannot be saved");
            GUI.Toast.Warning("Open as text is disabled for this file");
            return false;
        }
        if saveDoc.isNew {
            var savePath = FileDialog.Save(
                "Save File", "", file_utils.SaveDialogFilter(saveDoc.kind, saveDoc.language), saveDoc.fileName);
            if savePath != "" {
                NormalizeDocumentForSave(docMgr, engine, docMgr.activeIndex);
                if docMgr.SaveAs(savePath) == false {
                    shell.SetStatusLeft("Save failed: " + saveDoc.fileName);
                    GUI.Toast.Error("Save failed");
                    return false;
                }
                tabs.SetTitle(docMgr.activeIndex, saveDoc.fileName);
                tabs.SetTooltip(docMgr.activeIndex, saveDoc.filePath);
                tabs.SetModified(docMgr.activeIndex, false);
                engine.ClearModified();
                shell.SetBreadcrumbPath(saveDoc.filePath);
                shell.SetStatusLeft("Saved: " + saveDoc.fileName);
                shell.SetStatusRight(DocStatusLabel(saveDoc));
                GUI.Toast.Success("Saved: " + saveDoc.fileName);
                return true;
            }
            shell.SetStatusLeft("Save canceled");
            return false;
        } else {
            if confirmOverwriteExternal(shell, docMgr, docMgr.activeIndex) {
                NormalizeDocumentForSave(docMgr, engine, docMgr.activeIndex);
                if docMgr.SaveActive() == false {
                    shell.SetStatusLeft("Save failed: " + saveDoc.fileName);
                    GUI.Toast.Error("Save failed");
                    return false;
                }
                tabs.SetModified(docMgr.activeIndex, false);
                engine.ClearModified();
                shell.SetStatusLeft("Saved: " + saveDoc.fileName);
                GUI.Toast.Success("Saved: " + saveDoc.fileName);
                return true;
            }
            return false;
        }
    }
    return false;
}

/// @brief Always prompts for path; saves and updates tab title/tooltip.
func handleSaveAs(shell: app_shell.AppShell,
                  docMgr: document_manager.DocumentManager,
                  engine: editor_engine.EditorEngine,
                  tabs: editor_tabs.EditorTabs) -> Boolean {
    SaveEditorState(docMgr, engine);
    var saveAsDoc = docMgr.GetActive();
    if saveAsDoc != null {
        if saveAsDoc.isReadOnlyPreview {
            shell.SetStatusLeft("Read-only preview cannot be saved");
            GUI.Toast.Warning("Open a supported text file before saving");
            return false;
        }
        var saveAsPath = FileDialog.Save(
            "Save As", "", file_utils.SaveDialogFilter(saveAsDoc.kind, saveAsDoc.language), saveAsDoc.fileName);
        if saveAsPath != "" {
            NormalizeDocumentForSave(docMgr, engine, docMgr.activeIndex);
            if docMgr.SaveAs(saveAsPath) == false {
                shell.SetStatusLeft("Save As failed: " + saveAsDoc.fileName);
                GUI.Toast.Error("Save As failed");
                return false;
            }
            tabs.SetTitle(docMgr.activeIndex, saveAsDoc.fileName);
            tabs.SetTooltip(docMgr.activeIndex, saveAsDoc.filePath);
            tabs.SetModified(docMgr.activeIndex, false);
            engine.ClearModified();
            shell.SetBreadcrumbPath(saveAsDoc.filePath);
            shell.SetStatusLeft("Saved as: " + saveAsDoc.fileName);
            shell.SetStatusRight(DocStatusLabel(saveAsDoc));
            return true;
        }
        shell.SetStatusLeft("Save As canceled");
    }
    return false;
}

/// @brief Save every modified non-untitled doc; clear their tab markers.
func handleSaveAll(shell: app_shell.AppShell,
                   docMgr: document_manager.DocumentManager,
                   engine: editor_engine.EditorEngine,
                   tabs: editor_tabs.EditorTabs) -> SaveAllResult {
    var result = new SaveAllResult();
    SaveEditorState(docMgr, engine);
    var savedCount = 0;

    var i = 0;
    while i < docMgr.GetCount() {
        var doc = docMgr.documents.get(i);
        if doc != null and doc.isModified {
            if doc.isReadOnlyPreview {
                result.message = "Read-only preview has unsaved changes: " + doc.fileName;
                shell.SetStatusLeft(result.message);
                GUI.Toast.Warning(result.message);
                return result;
            } else if doc.isNew {
                var savePath = FileDialog.Save(
                    "Save " + doc.fileName, "", file_utils.SaveDialogFilter(doc.kind, doc.language), doc.fileName);
                if savePath != "" {
                    NormalizeDocumentForSave(docMgr, engine, i);
                    if docMgr.SaveDocumentAs(i, savePath) {
                        tabs.SetTitle(i, doc.fileName);
                        tabs.SetTooltip(i, doc.filePath);
                        tabs.SetModified(i, false);
                        savedCount = savedCount + 1;
                    }
                } else {
                    result.canceled = true;
                    result.message = "Save All canceled";
                    shell.SetStatusLeft(result.message);
                    return result;
                }
            } else if confirmOverwriteExternal(shell, docMgr, i) {
                NormalizeDocumentForSave(docMgr, engine, i);
                if docMgr.SaveDocument(i) {
                    tabs.SetModified(i, false);
                    savedCount = savedCount + 1;
                } else {
                    result.message = "Save failed: " + doc.fileName;
                    shell.SetStatusLeft(result.message);
                    GUI.Toast.Error("Save failed");
                    return result;
                }
            } else {
                result.canceled = true;
                result.message = "Save All canceled";
                shell.SetStatusLeft(result.message);
                return result;
            }
        }
        i = i + 1;
    }
    shell.SetStatusLeft("Saved " + savedCount + " files");
    result.success = true;
    result.savedCount = savedCount;
    result.message = "Saved " + savedCount + " files";
    return result;
}

/// @brief Save documents before a build, run, or debug launch.
/// @details The default IDE policy saves every modified file so project builds
///          see fresh dependencies. Users can switch to active-file-only saves
///          to avoid prompts from unrelated dirty tabs; this helper keeps both
///          paths returning the same `SaveAllResult` shape for callers.
/// @param shell Workbench shell for status/toast updates.
/// @param docMgr Document manager containing open files.
/// @param engine Editor whose active text must be flushed first.
/// @param tabs Tab strip whose modified markers may be cleared.
/// @param saveAll True to save every modified document, false for active only.
/// @return Save result with success/cancel/message fields populated.
func handleSaveForExecution(shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            tabs: editor_tabs.EditorTabs,
                            saveAll: Boolean) -> SaveAllResult {
    if saveAll {
        return handleSaveAll(shell, docMgr, engine, tabs);
    }

    var result = new SaveAllResult();
    SaveEditorState(docMgr, engine);
    var doc = docMgr.GetActive();
    if doc == null {
        result.success = true;
        return result;
    }
    if doc.isModified == false {
        result.success = true;
        return result;
    }
    if handleSave(shell, docMgr, engine, tabs) {
        result.success = true;
        result.savedCount = 1;
        result.message = "Saved active file";
        return result;
    }
    result.canceled = true;
    result.message = "Active file was not saved";
    return result;
}

/// @brief Re-read the active file from disk, discarding in-memory edits.
func handleReload(shell: app_shell.AppShell,
                  docMgr: document_manager.DocumentManager,
                  engine: editor_engine.EditorEngine,
                  tabs: editor_tabs.EditorTabs) {
    var reloadDoc = docMgr.GetActive();
    if reloadDoc != null {
        var doc = reloadDoc!;
        if doc.isNew == false {
            if docMgr.ReloadDocument(docMgr.activeIndex) == false {
                if IO.File.Exists(doc.filePath) == false {
                    shell.SetStatusLeft("Reload failed: file is missing on disk");
                    GUI.Toast.Warning("The file was deleted or moved on disk");
                } else {
                    shell.SetStatusLeft("Reload failed: " + doc.fileName);
                    GUI.Toast.Warning("Could not reload file");
                }
                return;
            }
            // Force a content reload (docMgr.ReloadDocument refreshed doc.content
            // from disk); this resets the editor buffer and undo history.
            engine.ReloadDocument(doc, doc.content);
            engine.ClearModified();
            tabs.SetModified(docMgr.activeIndex, false);
            shell.SetStatusLeft("Reloaded: " + doc.fileName);
            GUI.Toast.Success("File reloaded from disk");
        }
    }
}

/// @brief Close the document at index; prompts to confirm if dirty.
/// @return true if closed (caller should clear any pending-reload flag).
func handleClose(shell: app_shell.AppShell,
                 docMgr: document_manager.DocumentManager,
                 engine: editor_engine.EditorEngine,
                 tabs: editor_tabs.EditorTabs,
                 closeIdx: Integer) -> Boolean {
    if closeIdx < 0 or closeIdx >= docMgr.GetCount() {
        return false;
    }

    SaveEditorState(docMgr, engine);

    if ConfirmCloseDocuments(shell, docMgr, engine, "Close File", closeIdx) == false {
        return false;
    }

    docMgr.CloseDocument(closeIdx);
    tabs.RemoveTab(closeIdx);

    var nextDoc = docMgr.GetActive();
    if nextDoc != null {
        tabs.SetActive(docMgr.activeIndex);
        engine.LoadDocument(nextDoc);
        shell.SelectSurface(nextDoc.kind);
        shell.SetBreadcrumbPath(nextDoc.filePath);
        shell.SetStatusRight(DocStatusLabel(nextDoc));
    } else {
        engine.SetText("");
        engine.ClearModified();
        shell.SetBreadcrumbPath("");
        shell.SetStatusRight("No file");
    }
    shell.SetStatusLeft("File closed");
    return true;
}

/// @brief Close every open document after one batch dirty-file confirmation.
/// @details The batch prompt prevents a cancellation on one dirty tab from
///          accidentally continuing through later tabs. After confirmation,
///          documents are removed high-to-low so indices remain stable.
func handleCloseAll(shell: app_shell.AppShell,
                    docMgr: document_manager.DocumentManager,
                    engine: editor_engine.EditorEngine,
                    tabs: editor_tabs.EditorTabs) {
    SaveEditorState(docMgr, engine);
    if ConfirmCloseDocuments(shell, docMgr, engine, "Close All", -1) == false {
        return;
    }

    while docMgr.GetCount() > 0 {
        var idx = docMgr.GetCount() - 1;
        docMgr.CloseDocument(idx);
        tabs.RemoveTab(idx);
    }

    engine.SetText("");
    engine.ClearModified();
    shell.SetBreadcrumbPath("");
    shell.SetStatusRight("No file");
    shell.SetStatusLeft("All files closed");
}

/// @brief Close every document except `keepIdx`. Safe to compare against the
///        loop counter directly: closing a higher index never shifts a lower
///        one, and we visit `keepIdx` before touching anything beneath it.
func handleCloseOthers(shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine,
                       tabs: editor_tabs.EditorTabs,
                       keepIdx: Integer) {
    SaveEditorState(docMgr, engine);
    if ConfirmCloseDocumentsExcept(shell, docMgr, engine, "Close Others", keepIdx) == false {
        return;
    }
    var activeKeepIdx = keepIdx;
    var i = docMgr.GetCount() - 1;
    while i >= 0 {
        if i != activeKeepIdx {
            docMgr.CloseDocument(i);
            tabs.RemoveTab(i);
        }
        i = i - 1;
    }
    if activeKeepIdx >= docMgr.GetCount() {
        activeKeepIdx = docMgr.GetCount() - 1;
    }
    if activeKeepIdx >= 0 {
        docMgr.SetActive(activeKeepIdx);
        tabs.SetActive(docMgr.activeIndex);
        var keptDoc = docMgr.GetActive();
        if keptDoc != null {
            engine.LoadDocument(keptDoc);
            shell.SelectSurface(keptDoc.kind);
            shell.SetBreadcrumbPath(keptDoc.filePath);
            shell.SetStatusRight(DocStatusLabel(keptDoc));
        }
    }
    shell.SetStatusLeft("Closed other files");
}

/// @brief Close all documents with no unsaved changes (dirty tabs stay open).
func handleCloseSaved(shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine,
                      tabs: editor_tabs.EditorTabs) {
    SaveEditorState(docMgr, engine);
    var i = docMgr.GetCount() - 1;
    while i >= 0 {
        var maybeDoc = docMgr.GetDocument(i);
        if maybeDoc != null {
            var doc = maybeDoc!;
            if doc.isModified == false {
                handleClose(shell, docMgr, engine, tabs, i);
            }
        }
        i = i - 1;
    }
}

/// @brief Confirm that the IDE can exit.
/// @details Main owns process teardown so build jobs, debug sessions, watchers,
///          indexers, and the shell are stopped in one shared cleanup path.
func handleExit(shell: app_shell.AppShell,
                docMgr: document_manager.DocumentManager,
                engine: editor_engine.EditorEngine) -> Boolean {
    if ConfirmCloseDocuments(shell, docMgr, engine, "Exit", -1) == false {
        return false;
    }
    return true;
}

// ============================================================================
// Shared helpers
// ============================================================================

func SetConfirmDirtyClose(enabled: Boolean) {
    confirmDirtyClose = enabled;
}

func SetSaveFormatOptions(trimWhitespace: Boolean,
                          finalNewline: Boolean) {
    trimTrailingWhitespaceOnSave = trimWhitespace;
    ensureFinalNewlineOnSave = finalNewline;
}

func AutoSaveActive(shell: app_shell.AppShell,
                    docMgr: document_manager.DocumentManager,
                    engine: editor_engine.EditorEngine,
                    tabs: editor_tabs.EditorTabs) -> Boolean {
    if shell == null or docMgr == null or engine == null { return false; }
    SaveEditorState(docMgr, engine);
    var doc = docMgr.GetActive();
    if doc == null { return false; }
    if doc.isNew or doc.isModified == false { return false; }
    if doc.isReadOnlyPreview { return false; }
    if docMgr.HasExternalChange(docMgr.activeIndex) {
        shell.SetStatusLeft("Auto-save paused: " + docMgr.ExternalStateMessage(docMgr.activeIndex));
        return false;
    }
    NormalizeDocumentForSave(docMgr, engine, docMgr.activeIndex);
    if docMgr.SaveActive() {
        tabs.SetModified(docMgr.activeIndex, false);
        engine.ClearModified();
        shell.SetStatusLeft("Auto-saved: " + doc.fileName);
        return true;
    }
    return false;
}

func NormalizeDocumentForSave(docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine,
                              index: Integer) {
    if docMgr == null or index < 0 or index >= docMgr.GetCount() { return; }
    var doc = docMgr.documents.get(index);
    if doc.isReadOnlyPreview { return; }
    var normalized = ApplySaveTextRules(doc.content);
    if normalized != doc.content {
        doc.content = normalized;
        doc.isModified = true;
        if index == docMgr.activeIndex and engine != null and engine.editor != null {
            var cursorLine = engine.GetCursorLine();
            var cursorCol = engine.GetCursorCol();
            var scrollLine = engine.GetScrollLine();
            engine.SetText(normalized);
            if cursorLine > 0 and cursorCol > 0 {
                engine.editor.SetCursor(cursorLine - 1, cursorCol - 1);
            }
            if scrollLine > 1 {
                engine.editor.ScrollTopLine = scrollLine - 1;
            }
        }
    }
}

func ApplySaveTextRules(text: String) -> String {
    var result = text;
    var eol = "\n";
    if Str.IndexOf(text, "\r\n") != 0 { eol = "\r\n"; }

    if trimTrailingWhitespaceOnSave {
        var lines = Str.Split(result, "\n");
        result = "";
        var i = 0;
        while i < Seq.get_Count(lines) {
            var line = Obj.ToString(Seq.Get(lines, i));
            if Str.EndsWith(line, "\r") {
                line = Str.Left(line, Str.get_Length(line) - 1);
            }
            line = TrimLineRightWhitespace(line);
            if i > 0 { result = result + eol; }
            result = result + line;
            i = i + 1;
        }
    }

    if ensureFinalNewlineOnSave and Str.EndsWith(result, "\n") == false {
        result = result + eol;
    }
    return result;
}

func TrimLineRightWhitespace(line: String) -> String {
    var end = Str.get_Length(line);
    while end > 0 {
        var ch = Str.MidLen(line, end, 1);
        if ch != " " and ch != "\t" { break; }
        end = end - 1;
    }
    if end <= 0 { return ""; }
    return Str.Left(line, end);
}

/// @brief Open `path` (deduping if already open), wire up the tab,
///        breadcrumb, and status bar. Used by handleOpen and the file
///        tree click handler.
func OpenFileAtPath(shell: app_shell.AppShell,
                    docMgr: document_manager.DocumentManager,
                    engine: editor_engine.EditorEngine,
                    tabs: editor_tabs.EditorTabs,
                    path: String) {
    SaveEditorState(docMgr, engine);

    var prevCount = docMgr.GetCount();
    var openDoc = docMgr.OpenFile(path);

    if docMgr.GetCount() > prevCount {
        tabs.AddTab(openDoc.fileName, 1);
        tabs.SetTooltip(docMgr.activeIndex, openDoc.filePath);
    }
    tabs.SetActive(docMgr.activeIndex);
    engine.LoadDocument(openDoc);
    shell.SelectSurface(openDoc.kind);

    shell.SetBreadcrumbPath(openDoc.filePath);
    if openDoc.isReadOnlyPreview {
        shell.SetStatusLeft("Preview: " + openDoc.fileName);
        GUI.Toast.Info("Opened read-only preview");
    } else {
        shell.SetStatusLeft("Opened: " + openDoc.fileName);
    }
    shell.SetStatusRight(DocStatusLabel(openDoc));
}

func ConfirmCloseDocuments(shell: app_shell.AppShell,
                           docMgr: document_manager.DocumentManager,
                           engine: editor_engine.EditorEngine,
                           reason: String,
                           targetIndex: Integer) -> Boolean {
    if shell == null { return false; }
    SaveEditorState(docMgr, engine);
    var dirtyCount = 0;
    var names = "";
    var i = 0;
    while i < docMgr.GetCount() {
        if targetIndex < 0 or targetIndex == i {
            var doc = docMgr.documents.get(i);
            if doc.isModified {
                dirtyCount = dirtyCount + 1;
                if names == "" {
                    names = doc.fileName;
                } else if dirtyCount <= 5 {
                    names = names + "\n" + doc.fileName;
                }
            }
        }
        i = i + 1;
    }
    if dirtyCount == 0 { return true; }
    if confirmDirtyClose == false { return true; }

    var msg = names;
    if dirtyCount > 5 {
        msg = msg + "\n...and " + (dirtyCount - 5) + " more";
    }
    msg = msg + "\n\nSave changes before continuing?";
    var choice = DirtyCloseChoice("Unsaved Changes - " + reason, msg);
    if choice == CLOSE_CHOICE_CANCEL { return false; }
    if choice == CLOSE_CHOICE_DISCARD { return true; }
    return SaveDirtyDocumentsForClose(shell, docMgr, engine, targetIndex, -1);
}

/// @brief Confirm and optionally save dirty documents except one kept tab.
/// @details Used by Close Others so one cancellation cannot close a partial
///          subset of tabs. The confirmation covers the whole batch before any
///          document is removed.
func ConfirmCloseDocumentsExcept(shell: app_shell.AppShell,
                                 docMgr: document_manager.DocumentManager,
                                 engine: editor_engine.EditorEngine,
                                 reason: String,
                                 keepIndex: Integer) -> Boolean {
    if shell == null { return false; }
    SaveEditorState(docMgr, engine);
    var dirtyCount = 0;
    var names = "";
    var i = 0;
    while i < docMgr.GetCount() {
        if i != keepIndex {
            var doc = docMgr.documents.get(i);
            if doc.isModified {
                dirtyCount = dirtyCount + 1;
                if names == "" {
                    names = doc.fileName;
                } else if dirtyCount <= 5 {
                    names = names + "\n" + doc.fileName;
                }
            }
        }
        i = i + 1;
    }
    if dirtyCount == 0 { return true; }
    if confirmDirtyClose == false { return true; }
    if dirtyCount > 5 {
        names = names + "\n...and " + (dirtyCount - 5) + " more";
    }
    var choice = DirtyCloseChoice("Unsaved Changes - " + reason,
                                  names + "\n\nSave changes before continuing?");
    if choice == CLOSE_CHOICE_CANCEL { return false; }
    if choice == CLOSE_CHOICE_DISCARD { return true; }
    return SaveDirtyDocumentsForClose(shell, docMgr, engine, -1, keepIndex);
}

/// @brief Confirm and optionally save dirty open documents below a filesystem path.
/// @details Project tree deletion calls this before touching disk. Returning
///          false means the delete must be aborted because the user canceled,
///          a Save As dialog was canceled, or a save failed.
func ConfirmCloseDocumentsUnderPath(shell: app_shell.AppShell,
                                    docMgr: document_manager.DocumentManager,
                                    engine: editor_engine.EditorEngine,
                                    reason: String,
                                    path: String) -> Boolean {
    if shell == null or docMgr == null or path == "" { return false; }
    SaveEditorState(docMgr, engine);
    var dirtyCount = 0;
    var names = "";
    var i = 0;
    while i < docMgr.GetCount() {
        var doc = docMgr.documents.get(i);
        if DocumentIsUnderPath(doc, path) and doc.isModified {
            dirtyCount = dirtyCount + 1;
            if names == "" {
                names = doc.fileName;
            } else if dirtyCount <= 5 {
                names = names + "\n" + doc.fileName;
            }
        }
        i = i + 1;
    }
    if dirtyCount == 0 { return true; }
    if confirmDirtyClose == false { return true; }
    if dirtyCount > 5 {
        names = names + "\n...and " + (dirtyCount - 5) + " more";
    }
    var choice = DirtyCloseChoice("Unsaved Changes - " + reason,
                                  names + "\n\nSave changes before "
                                  + DirtyPathActionVerb(reason) + "?");
    if choice == CLOSE_CHOICE_CANCEL { return false; }
    if choice == CLOSE_CHOICE_DISCARD { return true; }
    return SaveDirtyDocumentsUnderPath(shell, docMgr, engine, path);
}

/// @brief Return the verb used in dirty-document prompts for path operations.
/// @param reason Operation name passed by the caller.
/// @return Lowercase gerund that fits "Save changes before ...?".
/// @details Rename and delete share the same dirty-document preflight helper,
///          but the prompt must describe the actual operation so users can make
///          the right save/discard/cancel decision.
func DirtyPathActionVerb(reason: String) -> String {
    if reason == "Move to Trash" { return "moving to trash"; }
    if reason == "Rename" { return "renaming"; }
    if reason == "Delete" { return "deleting"; }
    return "continuing";
}

/// @brief Show a Save / Discard / Cancel prompt for dirty-close flows.
/// @details The object-style MessageBox preserves exact custom button IDs, so
///          callers can branch without inferring intent from localized text.
func DirtyCloseChoice(title: String, msg: String) -> Integer {
    var box = GUI.MessageBox.NewQuestion(title, msg);
    if box == null {
        return CLOSE_CHOICE_CANCEL;
    }
    box.AddButton("Save", CLOSE_CHOICE_SAVE);
    box.AddButton("Discard", CLOSE_CHOICE_DISCARD);
    box.AddButton("Cancel", CLOSE_CHOICE_CANCEL);
    box.SetDefaultButton(CLOSE_CHOICE_SAVE);
    var choice = box.Show();
    box.Destroy();
    return choice;
}

/// @brief Save dirty documents targeted by a close operation.
/// @details Untitled files are prompted one by one. Existing files honor the
///          external-change overwrite prompt and use DocumentManager's atomic
///          existing-file save path.
func SaveDirtyDocumentsForClose(shell: app_shell.AppShell,
                                docMgr: document_manager.DocumentManager,
                                engine: editor_engine.EditorEngine,
                                targetIndex: Integer,
                                skipIndex: Integer) -> Boolean {
    var i = 0;
    while i < docMgr.GetCount() {
        if (targetIndex < 0 or targetIndex == i) and i != skipIndex {
            var doc = docMgr.documents.get(i);
            if doc.isModified {
                if doc.isReadOnlyPreview {
                    shell.SetStatusLeft("Cannot save read-only preview: " + doc.fileName);
                    return false;
                }
                if doc.isNew {
                    var savePath = FileDialog.Save(
                        "Save " + doc.fileName, "", file_utils.SaveDialogFilter(doc.kind, doc.language), doc.fileName);
                    if savePath == "" {
                        shell.SetStatusLeft("Close canceled");
                        return false;
                    }
                    NormalizeDocumentForSave(docMgr, engine, i);
                    if docMgr.SaveDocumentAs(i, savePath) == false {
                        shell.SetStatusLeft("Save failed: " + doc.fileName);
                        GUI.Toast.Error("Save failed");
                        return false;
                    }
                } else {
                    if confirmOverwriteExternal(shell, docMgr, i) == false {
                        return false;
                    }
                    NormalizeDocumentForSave(docMgr, engine, i);
                    if docMgr.SaveDocument(i) == false {
                        shell.SetStatusLeft("Save failed: " + doc.fileName);
                        GUI.Toast.Error("Save failed");
                        return false;
                    }
                }
                doc.isModified = false;
            }
        }
        i = i + 1;
    }
    return true;
}

/// @brief Save all dirty documents whose paths are equal to or below @p path.
/// @details This mirrors close-save behavior but selects documents by path so
///          project tree deletes can abort safely before removing files.
func SaveDirtyDocumentsUnderPath(shell: app_shell.AppShell,
                                 docMgr: document_manager.DocumentManager,
                                 engine: editor_engine.EditorEngine,
                                 path: String) -> Boolean {
    var i = 0;
    while i < docMgr.GetCount() {
        var doc = docMgr.documents.get(i);
        if DocumentIsUnderPath(doc, path) and doc.isModified {
            if doc.isReadOnlyPreview {
                shell.SetStatusLeft("Cannot save read-only preview: " + doc.fileName);
                return false;
            }
            if doc.isNew {
                var savePath = FileDialog.Save(
                    "Save " + doc.fileName, "", file_utils.SaveDialogFilter(doc.kind, doc.language), doc.fileName);
                if savePath == "" { return false; }
                NormalizeDocumentForSave(docMgr, engine, i);
                if docMgr.SaveDocumentAs(i, savePath) == false { return false; }
            } else {
                if confirmOverwriteExternal(shell, docMgr, i) == false { return false; }
                NormalizeDocumentForSave(docMgr, engine, i);
                if docMgr.SaveDocument(i) == false { return false; }
            }
            doc.isModified = false;
        }
        i = i + 1;
    }
    return true;
}

/// @brief Return true when a document path is the selected file or inside a directory.
func DocumentIsUnderPath(doc: document.Document, path: String) -> Boolean {
    if doc == null or path == "" or doc.filePath == "" { return false; }
    if doc.filePath == path { return true; }
    return Str.StartsWith(doc.filePath, path + Path.Sep());
}

func confirmOverwriteExternal(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              index: Integer) -> Boolean {
    var state = docMgr.ExternalState(index);
    if state == document.EXTERNAL_STATE_CLEAN {
        return true;
    }
    var doc = docMgr.documents.get(index);
    var title = "File Changed on Disk";
    var msg = doc.fileName + " changed on disk since it was opened or saved.\nOverwrite it?";
    if state == document.EXTERNAL_STATE_DELETED {
        title = "File Deleted on Disk";
        msg = doc.fileName + " was deleted on disk.\nRecreate it at the original path?";
    } else if state == document.EXTERNAL_STATE_RENAMED {
        title = "File Moved on Disk";
        msg = doc.fileName + " was renamed or moved on disk.\nRecreate it at the original path?";
    } else if state == document.EXTERNAL_STATE_MISSING {
        title = "File Missing on Disk";
        msg = doc.fileName + " is missing on disk.\nRecreate it at the original path?";
    }
    var confirmed = GUI.MessageBox.Confirm(
        title,
        msg);
    if confirmed == 0 {
        shell.SetStatusLeft("Save canceled: " + docMgr.ExternalStateMessage(index));
        return false;
    }
    return true;
}

/// @brief Flush editor state (cursor, scroll, text) into the active
///        Document. Called at the start of every command to keep the
///        document model in sync with what the user sees.
func SaveEditorState(docMgr: document_manager.DocumentManager,
                     engine: editor_engine.EditorEngine) {
    if docMgr == null or engine == null {
        return;
    }
    var doc = docMgr.GetActive();
    if doc != null {
        engine.SaveToDocument(doc);
    }
}

/// @brief Build the right-aligned status-bar label "Lang | EOL".
/// @details Detects EOL by searching for "\r\n"; presence => CRLF, else LF.
func DocStatusLabel(doc: document.Document) -> String {
    var lang = "Text";
    if doc.language == "zia"   { lang = "Zia"; }
    if doc.language == "basic" { lang = "Basic"; }
    if doc.language == "scene" { lang = "Scene"; }

    var eol = "LF";
    if Str.IndexOf(doc.content, "\r\n") != 0 { eol = "CRLF"; }

    if doc.isReadOnlyPreview {
        return lang + "  |  Read-only preview";
    }
    return lang + "  |  " + eol;
}
