module search_commands;

bind "../ui/app_shell";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../commands/file_commands";
bind "../core/document_manager";
bind "../services/file_utils";
bind "../services/locations";
bind "../services/search_matcher";
bind "../services/search_paths";
bind "../services/search_request";
bind "../editor/zia_query";

bind Viper.GUI;
bind ZiaCompletion = Viper.Zia.Completion;
bind IO = Viper.IO;
bind Dir = Viper.IO.Dir;
bind Path = Viper.IO.Path;
bind Str = Viper.String;
bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;
bind Map = Viper.Collections.Map;
bind Convert = Viper.Core.Convert;
bind FileIndex = Viper.Workspace.FileIndex;

// ============================================================================
// MODULE: search_commands
// PURPOSE: Project-wide text search (Ctrl+Shift+F). Scans selected text
//          file kinds under the project root, supports literal/regex, case,
//          whole-word, and path-filter options, and stores structured location
//          ids on output rows.
//
// WHERE-THIS-FITS: Wired into main.zia's command dispatcher. Only
//          enabled when a project is open (otherwise toasts a warning).
//
// KEY-DESIGN-CHOICES:
//   * GLOB-BASED FILE DISCOVERY. `Viper.IO.Glob.Files(root, "**/*.zia")`
//     walks the tree once. Two passes (zia then bas) is simpler than
//     extending Glob to handle multi-pattern queries.
//   * COOPERATIVE MATCHING. Search work remains file-sliced per frame; regex
//     matching is intentionally local to a single line and uses a compact
//     editor-search subset (`.`, `*`, `+`, `?`, `[]`, `^`, `$`, and escapes).
//   * RESULT ROWS CARRY DATA. Each output-panel item stores a LocationStore
//     id via `ItemSetData`, so clicking a result does not parse display text.
// ============================================================================

final SEARCH_FILES_PER_FRAME = 16;
final SEARCH_DISCOVERY_DIRS_PER_FRAME = 8;
final QUICK_OPEN_ID_PREFIX = "quickopen:";

class SearchController {
    expose Boolean active;
    expose Boolean canceled;
    expose String root;
    expose String query;
    expose String fileKinds;
    expose String ignorePatterns;
    expose String includeGlobs;
    expose String excludeGlobs;
    expose Boolean caseSensitive;
    expose Boolean wholeWord;
    expose Boolean regexMode;
    expose Integer fileIndex;
    expose Integer resultCount;
    expose Integer totalFiles;
    expose List files;
    expose Boolean discovering;
    expose List pendingDirs;
    expose Integer directoriesScanned;

    expose func init() {
        active = false;
        canceled = false;
        root = "";
        query = "";
        fileKinds = "";
        ignorePatterns = "";
        includeGlobs = "";
        excludeGlobs = "";
        caseSensitive = false;
        wholeWord = false;
        regexMode = false;
        fileIndex = 0;
        resultCount = 0;
        totalFiles = 0;
        files = new List();
        discovering = false;
        pendingDirs = new List();
        directoriesScanned = 0;
    }

    expose func Start(shell: app_shell.AppShell,
                      rootPath: String,
                      searchTitle: String,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine) -> Boolean {
        if active {
            var confirmed = GUI.MessageBox.Confirm(
                "Search Already Running",
                "Cancel the current search and start a new one?");
            if confirmed == 0 { return false; }
            Cancel(shell);
        }

        var requestedQuery = GUI.MessageBox.Prompt(searchTitle, "Search for:");
        if requestedQuery == "" { return false; }
        var requestedCase = GUI.MessageBox.Confirm(
            "Search Options",
            "Use case-sensitive matching?") != 0;
        var requestedWholeWord = GUI.MessageBox.Confirm(
            "Search Options",
            "Match whole words only?") != 0;
        var requestedRegex = GUI.MessageBox.Confirm(
            "Search Options",
            "Treat the search text as a regular expression?") != 0;
        var requestedKinds = GUI.MessageBox.Prompt(
            "Search File Kinds",
            "Comma-separated extensions to search.\nLeave blank for code, text, scene, and docs.");
        requestedKinds = search_request.NormalizeFileKinds(requestedKinds);
        var requestedInclude = GUI.MessageBox.Prompt(
            "Search Include Paths",
            "Comma-separated include globs. Leave blank for all matching files.");
        var requestedExclude = GUI.MessageBox.Prompt(
            "Search Exclude Paths",
            "Comma-separated exclude globs. Leave blank for project defaults.");

        file_commands.SaveEditorState(docMgr, engine);
        return StartDirectWithSearchMode(shell, rootPath, requestedQuery,
                                         requestedKinds, requestedCase, requestedWholeWord,
                                         requestedRegex, requestedInclude, requestedExclude);
    }

    expose func StartProject(shell: app_shell.AppShell,
                             projMgr: project_manager.ProjectManager,
                             searchTitle: String,
                             docMgr: document_manager.DocumentManager,
                             engine: editor_engine.EditorEngine) -> Boolean {
        if projMgr == null or projMgr.IsOpen() == false {
            return false;
        }
        projMgr.WarmFileCache(128);
        if projMgr.CachedFileCount() == 0 {
            GUI.Toast.Info(projMgr.FileCacheStatusText());
            return false;
        }
        return StartWithCachedFiles(shell, projMgr, projMgr.RootPath(), searchTitle, docMgr, engine);
    }

    expose func StartFolder(shell: app_shell.AppShell,
                            projMgr: project_manager.ProjectManager,
                            folderPath: String,
                            searchTitle: String,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine) -> Boolean {
        if folderPath == "" or Dir.Exists(folderPath) == false {
            return false;
        }
        if projMgr != null {
            projMgr.WarmFileCache(64);
        }
        if projMgr != null and projMgr.IsOpen() and
           projMgr.CachedFileCount() > 0 and IsWithinRoot(folderPath, projMgr.RootPath()) {
            return StartWithCachedFiles(shell, projMgr, folderPath, searchTitle, docMgr, engine);
        }
        return Start(shell, folderPath, searchTitle, docMgr, engine);
    }

    func StartWithCachedFiles(shell: app_shell.AppShell,
                              projMgr: project_manager.ProjectManager,
                              scopeRoot: String,
                              searchTitle: String,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine) -> Boolean {
        if active {
            var confirmed = GUI.MessageBox.Confirm(
                "Search Already Running",
                "Cancel the current search and start a new one?");
            if confirmed == 0 { return false; }
            Cancel(shell);
        }

        var requestedQuery = GUI.MessageBox.Prompt(searchTitle, "Search for:");
        if requestedQuery == "" { return false; }
        var requestedCase = GUI.MessageBox.Confirm(
            "Search Options",
            "Use case-sensitive matching?") != 0;
        var requestedWholeWord = GUI.MessageBox.Confirm(
            "Search Options",
            "Match whole words only?") != 0;
        var requestedRegex = GUI.MessageBox.Confirm(
            "Search Options",
            "Treat the search text as a regular expression?") != 0;
        var requestedKinds = GUI.MessageBox.Prompt(
            "Search File Kinds",
            "Comma-separated extensions to search.\nLeave blank for code, text, scene, and docs.");
        requestedKinds = search_request.NormalizeFileKinds(requestedKinds);
        var requestedInclude = GUI.MessageBox.Prompt(
            "Search Include Paths",
            "Comma-separated include globs. Leave blank for all matching files.");
        var requestedExclude = GUI.MessageBox.Prompt(
            "Search Exclude Paths",
            "Comma-separated exclude globs. Leave blank for project defaults.");

        file_commands.SaveEditorState(docMgr, engine);
        return StartCachedDirectWithSearchMode(shell, projMgr, scopeRoot, requestedQuery,
                                               requestedKinds, requestedCase, requestedWholeWord,
                                               requestedRegex, requestedInclude, requestedExclude);
    }

    expose func StartDirect(shell: app_shell.AppShell,
                            rootPath: String,
                            requestedQuery: String,
                            requestedKinds: String,
                            requestedCase: Boolean,
                            requestedWholeWord: Boolean) -> Boolean {
        return StartDirectWithOptions(shell, rootPath, requestedQuery,
                                      requestedKinds, requestedCase, requestedWholeWord,
                                      "", "");
    }

    expose func StartDirectWithOptions(shell: app_shell.AppShell,
                                       rootPath: String,
                                       requestedQuery: String,
                                       requestedKinds: String,
                                       requestedCase: Boolean,
                                       requestedWholeWord: Boolean,
                                       requestedIncludeGlobs: String,
                                       requestedExcludeGlobs: String) -> Boolean {
        if rootPath == "" or requestedQuery == "" { return false; }
        return StartDirectWithSearchMode(shell, rootPath, requestedQuery,
                                         requestedKinds, requestedCase, requestedWholeWord,
                                         false, requestedIncludeGlobs, requestedExcludeGlobs);
    }

    expose func StartDirectWithSearchMode(shell: app_shell.AppShell,
                                          rootPath: String,
                                          requestedQuery: String,
                                          requestedKinds: String,
                                          requestedCase: Boolean,
                                          requestedWholeWord: Boolean,
                                          requestedRegexMode: Boolean,
                                          requestedIncludeGlobs: String,
                                          requestedExcludeGlobs: String) -> Boolean {
        if rootPath == "" or requestedQuery == "" { return false; }
        if Dir.Exists(rootPath) == false { return false; }

        var request = search_request.Create(rootPath, requestedQuery, requestedKinds,
                                            requestedCase, requestedWholeWord,
                                            requestedRegexMode,
                                            requestedIncludeGlobs, requestedExcludeGlobs, "");
        ApplyRequest(request);
        files = new List();
        pendingDirs = new List();
        pendingDirs.Push(root);
        discovering = true;
        directoriesScanned = 0;
        totalFiles = 0;
        fileIndex = 0;
        resultCount = 0;
        canceled = false;
        active = true;

        shell.searchListBox.Clear();
        shell.ShowSearchPanel();
        shell.SetStatusLeft("Discovering files for '" + query + "'...");
        return true;
    }

    expose func StartCachedDirect(shell: app_shell.AppShell,
                                  projMgr: project_manager.ProjectManager,
                                  scopeRoot: String,
                                  requestedQuery: String,
                                  requestedKinds: String,
                                  requestedCase: Boolean,
                                  requestedWholeWord: Boolean) -> Boolean {
        return StartCachedDirectWithOptions(shell, projMgr, scopeRoot, requestedQuery,
                                            requestedKinds, requestedCase, requestedWholeWord,
                                            "", "");
    }

    expose func StartCachedDirectWithOptions(shell: app_shell.AppShell,
                                             projMgr: project_manager.ProjectManager,
                                             scopeRoot: String,
                                             requestedQuery: String,
                                             requestedKinds: String,
                                             requestedCase: Boolean,
                                             requestedWholeWord: Boolean,
                                             requestedIncludeGlobs: String,
                                             requestedExcludeGlobs: String) -> Boolean {
        if projMgr == null or scopeRoot == "" or requestedQuery == "" { return false; }
        return StartCachedDirectWithSearchMode(shell, projMgr, scopeRoot, requestedQuery,
                                               requestedKinds, requestedCase, requestedWholeWord,
                                               false, requestedIncludeGlobs, requestedExcludeGlobs);
    }

    expose func StartCachedDirectWithSearchMode(shell: app_shell.AppShell,
                                                projMgr: project_manager.ProjectManager,
                                                scopeRoot: String,
                                                requestedQuery: String,
                                                requestedKinds: String,
                                                requestedCase: Boolean,
                                                requestedWholeWord: Boolean,
                                                requestedRegexMode: Boolean,
                                                requestedIncludeGlobs: String,
                                                requestedExcludeGlobs: String) -> Boolean {
        if projMgr == null or scopeRoot == "" or requestedQuery == "" { return false; }
        if Dir.Exists(scopeRoot) == false { return false; }

        var request = search_request.Create(scopeRoot, requestedQuery, requestedKinds,
                                            requestedCase, requestedWholeWord,
                                            requestedRegexMode,
                                            requestedIncludeGlobs, requestedExcludeGlobs,
                                            projMgr.IgnorePatterns());
        ApplyRequest(request);
        files = BuildFileListFromCacheWithFilters(projMgr, scopeRoot, fileKinds, includeGlobs, excludeGlobs);
        totalFiles = files.count();
        pendingDirs = new List();
        discovering = false;
        directoriesScanned = 0;
        fileIndex = 0;
        resultCount = 0;
        canceled = false;
        active = true;

        shell.searchListBox.Clear();
        shell.ShowSearchPanel();
        shell.SetStatusLeft("Searching cached project files (" + totalFiles + ") for '" + query + "'...");
        return true;
    }

    /// @brief Copy normalized request fields into controller state for a new run.
    /// @details Startup paths differ only in file discovery: direct searches
    ///          discover files cooperatively, cached searches reuse ProjectManager
    ///          file cache. The request fields themselves should be applied once
    ///          through this helper so defaults and normalization cannot diverge.
    /// @param request Normalized search request from services/search_request.zia.
    hide func ApplyRequest(request: search_request.SearchRequest) {
        root = request.rootPath;
        query = request.query;
        fileKinds = request.fileKinds;
        ignorePatterns = request.ignorePatterns;
        includeGlobs = request.includeGlobs;
        excludeGlobs = request.excludeGlobs;
        caseSensitive = request.caseSensitive;
        wholeWord = request.wholeWord;
        regexMode = request.regexMode;
    }

    expose func Cancel(shell: app_shell.AppShell) {
        if active == false { return; }
        active = false;
        canceled = true;
        discovering = false;
        pendingDirs = new List();
        shell.SetStatusLeft("Search canceled after " + resultCount + " matches");
        if resultCount == 0 {
            shell.searchListBox.Clear();
            shell.AddToolInfoRow(shell.searchListBox, "search",
                                 "Search canceled before any matches were found");
            shell.ShowSearchPanel();
        }
    }

    expose func PumpDiscovery(maxDirs: Integer) -> Integer {
        if discovering == false { return 0; }
        var limit = maxDirs;
        if limit <= 0 { limit = SEARCH_DISCOVERY_DIRS_PER_FRAME; }

        var processed = 0;
        while pendingDirs.count() > 0 and processed < limit {
            var dirPath = Obj.ToString(pendingDirs.get(0));
            pendingDirs.removeAt(0);
            processed = processed + 1;
            directoriesScanned = directoriesScanned + 1;

            if Dir.Exists(dirPath) == false { continue; }

            for dirName in Dir.DirsSeq(dirPath) {
                var childDir = Path.Join(dirPath, dirName);
                if ShouldSearchIgnore(root, childDir, true, MergePatternLists(ignorePatterns, excludeGlobs)) == false {
                    pendingDirs.Push(childDir);
                }
            }

            for fileName in Dir.FilesSeq(dirPath) {
                var filePath = Path.Join(dirPath, fileName);
                if ShouldSearchIgnore(root, filePath, false, MergePatternLists(ignorePatterns, excludeGlobs)) == false
                   and SearchKindMatches(filePath, fileKinds)
                   and SearchPathAllowed(root, filePath, includeGlobs, excludeGlobs) {
                    files.Push(filePath);
                }
            }
        }

        totalFiles = files.count();
        if pendingDirs.count() == 0 {
            discovering = false;
        }
        return processed;
    }

    expose func Pump(shell: app_shell.AppShell,
                     docMgr: document_manager.DocumentManager,
                     locStore: locations.LocationStore) {
        if active == false { return; }

        PumpDiscovery(SEARCH_DISCOVERY_DIRS_PER_FRAME);
        totalFiles = files.count();

        var scanned = 0;
        while active and scanned < SEARCH_FILES_PER_FRAME and fileIndex < files.count() {
            var filePath = Obj.ToString(files.get(fileIndex));
            fileIndex = fileIndex + 1;
            scanned = scanned + 1;

            if IO.File.Exists(filePath) == false { continue; }
            resultCount = resultCount + searchOneFile(shell, filePath, query, caseSensitive, wholeWord,
                                                      regexMode, docMgr, locStore);
        }

        if discovering == false and fileIndex >= files.count() {
            active = false;
            if resultCount > 0 {
                shell.ShowSearchPanel();
                shell.SetStatusLeft("Found " + resultCount + " matches for '" + query + "'");
            } else {
                shell.searchListBox.Clear();
                shell.AddToolInfoRow(shell.searchListBox, "search",
                                     "No matches found for '" + query + "'");
                shell.ShowSearchPanel();
                GUI.Toast.Info("No matches found for '" + query + "'");
            }
        } else {
            if discovering {
                shell.SetStatusLeft("Discovering files: " + totalFiles + " queued, " + fileIndex + " searched...");
            } else {
                shell.SetStatusLeft("Searching " + fileIndex + "/" + totalFiles + " files...");
            }
        }
    }
}

func BuildFileListFromIndex(rootPath: String, fileKinds: String) -> List {
    var result = new List();
    var indexed = FileIndex.Enumerate(rootPath, fileKinds, "", false);
    var i = 0;
    while i < Seq.get_Length(indexed) {
        var entry = Seq.Get(indexed, i);
        var filePath = Map.GetStr(entry, "path");
        if filePath != "" {
            result.Push(filePath);
        }
        i = i + 1;
    }
    return result;
}

func BuildFileListFromCache(projMgr: project_manager.ProjectManager,
                            scopeRoot: String,
                            fileKinds: String) -> List {
    return BuildFileListFromCacheWithFilters(projMgr, scopeRoot, fileKinds, "", "");
}

func BuildFileListFromCacheWithFilters(projMgr: project_manager.ProjectManager,
                                       scopeRoot: String,
                                       fileKinds: String,
                                       includeGlobs: String,
                                       excludeGlobs: String) -> List {
    var result = new List();
    if projMgr == null { return result; }
    projMgr.WarmFileCache(128);
    var cachedCount = projMgr.CachedFileCount();
    var i = 0;
    while i < cachedCount {
        var filePath = projMgr.CachedFileAt(i);
        if IsWithinRoot(filePath, scopeRoot)
           and SearchKindMatches(filePath, fileKinds)
           and SearchPathAllowed(scopeRoot, filePath, includeGlobs, excludeGlobs) {
            result.Push(filePath);
        }
        i = i + 1;
    }
    return result;
}

func IsWithinRoot(filePath: String, rootPath: String) -> Boolean {
    if filePath == "" or rootPath == "" { return false; }
    if filePath == rootPath { return true; }
    var prefix = rootPath;
    if Str.EndsWith(prefix, Path.Sep()) == false {
        prefix = prefix + Path.Sep();
    }
    return Str.StartsWith(filePath, prefix);
}

func SearchKindMatches(filePath: String, fileKinds: String) -> Boolean {
    return search_paths.SearchKindMatches(filePath, fileKinds);
}

func ShouldSearchIgnore(rootPath: String,
                        fullPath: String,
                        isDir: Boolean,
                        ignorePatterns: String) -> Boolean {
    return search_paths.ShouldSearchIgnore(rootPath, fullPath, isDir, ignorePatterns);
}

func SearchPathAllowed(rootPath: String,
                       filePath: String,
                       includeGlobs: String,
                       excludeGlobs: String) -> Boolean {
    return search_paths.SearchPathAllowed(rootPath, filePath, includeGlobs, excludeGlobs);
}

func RelativeSearchPath(rootPath: String, filePath: String) -> String {
    return search_paths.RelativeSearchPath(rootPath, filePath);
}

func NormalizeSearchPath(path: String) -> String {
    return search_paths.NormalizeSearchPath(path);
}

func NormalizeSearchGlobList(globs: String) -> String {
    return search_paths.NormalizeSearchGlobList(globs);
}

func MergePatternLists(left: String, right: String) -> String {
    return search_paths.MergePatternLists(left, right);
}

func AnySearchGlobMatches(relativePath: String, globs: String) -> Boolean {
    return search_paths.AnySearchGlobMatches(relativePath, globs);
}

func SearchGlobMatches(relativePath: String, pattern: String) -> Boolean {
    return search_paths.SearchGlobMatches(relativePath, pattern);
}

/// @brief Prompt for a query, scan the project, populate the output panel.
func handleProjectSearch(shell: app_shell.AppShell,
                         projMgr: project_manager.ProjectManager,
                         docMgr: document_manager.DocumentManager,
                         engine: editor_engine.EditorEngine,
                         locStore: locations.LocationStore) {
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }

    RunSearch(shell, projMgr.RootPath(), "Search in Project", docMgr, engine, locStore);
}

func handleProjectSearchAsync(shell: app_shell.AppShell,
                              projMgr: project_manager.ProjectManager,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine,
                              locStore: locations.LocationStore,
                              searcher: SearchController) {
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }
    if searcher == null {
        RunSearch(shell, projMgr.RootPath(), "Search in Project", docMgr, engine, locStore);
        return;
    }
    searcher.StartProject(shell, projMgr, "Search in Project", docMgr, engine);
}

func handleProjectSearchInFolder(shell: app_shell.AppShell,
                                 folder: String,
                                 docMgr: document_manager.DocumentManager,
                                 engine: editor_engine.EditorEngine,
                                 locStore: locations.LocationStore) {
    if folder == "" or Dir.Exists(folder) == false {
        GUI.Toast.Warning("Choose a folder to search");
        return;
    }
    RunSearch(shell, folder, "Search in Folder", docMgr, engine, locStore);
}

func handleProjectSearchInFolderAsync(shell: app_shell.AppShell,
                                      projMgr: project_manager.ProjectManager,
                                      folder: String,
                                      docMgr: document_manager.DocumentManager,
                                      engine: editor_engine.EditorEngine,
                                      locStore: locations.LocationStore,
                                      searcher: SearchController) {
    if folder == "" or Dir.Exists(folder) == false {
        GUI.Toast.Warning("Choose a folder to search");
        return;
    }
    if searcher == null {
        RunSearch(shell, folder, "Search in Folder", docMgr, engine, locStore);
        return;
    }
    searcher.StartFolder(shell, projMgr, folder, "Search in Folder", docMgr, engine);
}

func handleQuickOpen(shell: app_shell.AppShell,
                     projMgr: project_manager.ProjectManager,
                     docMgr: document_manager.DocumentManager,
                     engine: editor_engine.EditorEngine,
                     tabs: editor_tabs.EditorTabs) {
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }
    var query = Str.Trim(GUI.MessageBox.Prompt("Quick Open", "File name or path:"));
    if query == "" { return; }

    var bestPath = "";
    var bestScore = 999;
    projMgr.WarmFileCache(256);
    var cachedCount = projMgr.CachedFileCount();
    var i = 0;
    while i < cachedCount {
        var filePath = projMgr.CachedFileAt(i);
        var score = QuickOpenScore(projMgr.RelativePath(filePath), query);
        if score >= 0 and score < bestScore {
            bestScore = score;
            bestPath = filePath;
        }
        i = i + 1;
    }

    if bestPath == "" and cachedCount == 0 {
        GUI.Toast.Info(projMgr.FileCacheStatusText());
        return;
    }

    if bestPath == "" {
        var suffix = "";
        if projMgr.fileCacheComplete == false {
            suffix = " (still indexing project files)";
        }
        GUI.Toast.Info("No project file matched '" + query + "'" + suffix);
        return;
    }

    file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, bestPath);
    shell.SetStatusLeft("Opened: " + projMgr.RelativePath(bestPath));
}

expose func ShowQuickOpenPalette(shell: app_shell.AppShell,
                                 projMgr: project_manager.ProjectManager) -> Boolean {
    if shell == null or shell.commandPalette == null { return false; }
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return false;
    }
    projMgr.WarmFileCache(256);
    var cachedCount = projMgr.CachedFileCount();
    if cachedCount == 0 {
        GUI.Toast.Info(projMgr.FileCacheStatusText());
        return false;
    }

    shell.commandPalette.Clear();
    shell.commandPalette.SetPlaceholder("Open file by name or path...");

    var i = 0;
    while i < cachedCount {
        var filePath = projMgr.CachedFileAt(i);
        shell.commandPalette.AddCommandWithShortcut(QuickOpenCommandId(filePath),
                                                    projMgr.RelativePath(filePath),
                                                    "Files",
                                                    "");
        i = i + 1;
    }

    shell.commandPalette.Show();
    if projMgr.fileCacheComplete {
        shell.SetStatusLeft("Quick Open: type a file name or path");
    } else {
        shell.SetStatusLeft("Quick Open: partial results while project files index");
    }
    return true;
}

expose func HandleQuickOpenPaletteSelection(shell: app_shell.AppShell,
                                            projMgr: project_manager.ProjectManager,
                                            docMgr: document_manager.DocumentManager,
                                            engine: editor_engine.EditorEngine,
                                            tabs: editor_tabs.EditorTabs,
                                            selected: String) -> Boolean {
    var path = QuickOpenPathFromCommandId(selected);
    if path == "" { return false; }
    file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, path);
    shell.SetStatusLeft("Opened: " + projMgr.RelativePath(path));
    return true;
}

expose func QuickOpenCommandId(path: String) -> String {
    return QUICK_OPEN_ID_PREFIX + path;
}

expose func QuickOpenPathFromCommandId(id: String) -> String {
    if Str.StartsWith(id, QUICK_OPEN_ID_PREFIX) == false { return ""; }
    var prefixLen = Str.get_Length(QUICK_OPEN_ID_PREFIX);
    return Str.MidLen(id, prefixLen + 1, Str.get_Length(id) - prefixLen);
}

func handleWorkspaceSymbols(shell: app_shell.AppShell,
                            projMgr: project_manager.ProjectManager,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            locStore: locations.LocationStore) {
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }

    var query = Str.Trim(GUI.MessageBox.Prompt("Workspace Symbols", "Symbol name:"));
    if query == "" { return; }

    file_commands.SaveEditorState(docMgr, engine);
    var count = CollectWorkspaceSymbols(shell, projMgr, docMgr, locStore, query);
    if count > 0 {
        shell.ShowSearchPanel();
        shell.SetStatusLeft("Found " + count + " workspace symbols for '" + query + "'");
    } else {
        shell.searchListBox.Clear();
        shell.AddToolInfoRow(shell.searchListBox, "symbol",
                             "No workspace symbols matched '" + query + "'");
        shell.ShowSearchPanel();
        GUI.Toast.Info("No workspace symbols matched '" + query + "'");
    }
}

func CollectWorkspaceSymbols(shell: app_shell.AppShell,
                             projMgr: project_manager.ProjectManager,
                             docMgr: document_manager.DocumentManager,
                             locStore: locations.LocationStore,
                             query: String) -> Integer {
    if shell == null or projMgr == null or locStore == null { return 0; }
    if projMgr.IsOpen() == false { return 0; }

    var needle = Str.ToLower(Str.Trim(query));
    if needle == "" { return 0; }

    shell.searchListBox.Clear();
    var resultCount = 0;
    var i = 0;
    while i < projMgr.CachedFileCount() {
        var filePath = projMgr.CachedFileAt(i);
        i = i + 1;
        if SearchKindMatches(filePath, ".zia") == false { continue; }

        var content = contentForPath(docMgr, filePath);
        if content == "" { continue; }

        var qsource = zia_query.WrapForQuery(content);
        var lineOff = zia_query.LineOffset(content);
        var raw = ZiaCompletion.SymbolsForFile(qsource, filePath);
        if raw == "" { continue; }

        var addedHeader = false;
        var rows = Str.Split(raw, "\n");
        var r = 0;
        while r < Seq.get_Length(rows) {
            var row = Obj.ToString(Seq.Get(rows, r));
            r = r + 1;
            if row == "" { continue; }

            var parts = Str.Split(row, "\t");
            if Seq.get_Length(parts) < 4 { continue; }

            var name = Obj.ToString(Seq.Get(parts, 0));
            var kind = Obj.ToString(Seq.Get(parts, 1));
            var typeText = Obj.ToString(Seq.Get(parts, 2));
            var lineText = Obj.ToString(Seq.Get(parts, 3));
            if lineText == "0" { continue; }

            var symbolLine = Convert.ToInt64(lineText) - lineOff;
            if symbolLine < 1 { continue; }
            if WorkspaceSymbolMatches(name, kind, filePath, needle) == false { continue; }

            if addedHeader == false {
                shell.AddToolGroupHeader(shell.searchListBox, Path.Name(filePath), filePath);
                addedHeader = true;
            }

            var detail = "";
            if typeText != "" { detail = " : " + typeText; }
            var item = shell.AddToolLocationRow(shell.searchListBox, kind, "symbol",
                                                "line " + symbolLine, typeText,
                                                name + detail, "");
            var locId = locStore.Add(filePath, symbolLine, 1,
                                     symbolLine, 1 + Str.get_Length(name),
                                     locations.KIND_SYMBOL, name);
            GUI.ListBox.ItemSetData(item, locId);
            resultCount = resultCount + 1;
        }
    }

    if resultCount > 0 {
        shell.ShowSearchPanel();
    }
    return resultCount;
}

func WorkspaceSymbolMatches(name: String,
                            kind: String,
                            filePath: String,
                            needle: String) -> Boolean {
    var lowerName = Str.ToLower(name);
    if Str.IndexOf(lowerName, needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(kind), needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(filePath), needle) != 0 { return true; }
    return false;
}

func RunSearch(shell: app_shell.AppShell,
               root: String,
               title: String,
               docMgr: document_manager.DocumentManager,
               engine: editor_engine.EditorEngine,
               locStore: locations.LocationStore) {
    var query = GUI.MessageBox.Prompt(title, "Search for:");
    if query == "" { return; }
    var caseSensitive = GUI.MessageBox.Confirm(
        "Search Options",
        "Use case-sensitive matching?") != 0;
    var wholeWord = GUI.MessageBox.Confirm(
        "Search Options",
        "Match whole words only?") != 0;
    var regexMode = GUI.MessageBox.Confirm(
        "Search Options",
        "Treat the search text as a regular expression?") != 0;
    var fileKinds = GUI.MessageBox.Prompt(
        "Search File Kinds",
        "Comma-separated extensions to search.\nLeave blank for code, text, scene, and docs.");
    if fileKinds == "" {
        fileKinds = ".zia,.bas,.vb,.json,.md,.scene,.level";
    } else {
        fileKinds = Str.Replace(fileKinds, " ", "");
    }
    var includeGlobs = GUI.MessageBox.Prompt(
        "Search Include Paths",
        "Comma-separated include globs. Leave blank for all matching files.");
    var excludeGlobs = GUI.MessageBox.Prompt(
        "Search Exclude Paths",
        "Comma-separated exclude globs. Leave blank for project defaults.");
    file_commands.SaveEditorState(docMgr, engine);

    includeGlobs = NormalizeSearchGlobList(includeGlobs);
    excludeGlobs = NormalizeSearchGlobList(excludeGlobs);
    var files = FileIndex.Enumerate(root, fileKinds, excludeGlobs, false);

    var resultCount = 0;
    shell.searchListBox.Clear();

    resultCount = resultCount + searchFiles(shell, root, files, query, caseSensitive, wholeWord, regexMode,
                                            includeGlobs, excludeGlobs, docMgr, locStore);

    if resultCount > 0 {
        shell.ShowSearchPanel();
        shell.SetStatusLeft("Found " + resultCount + " matches for '" + query + "'");
    } else {
        shell.searchListBox.Clear();
        shell.AddToolInfoRow(shell.searchListBox, "search",
                             "No matches found for '" + query + "'");
        shell.ShowSearchPanel();
        GUI.Toast.Info("No matches found for '" + query + "'");
    }
}

/// @brief Substring-search every file in `files` for `query`.
/// @return Match count (rows added to the output panel).
func searchFiles(shell: app_shell.AppShell,
                 rootPath: String,
                 files: Any,
                 query: String,
                 caseSensitive: Boolean,
                 wholeWord: Boolean,
                 regexMode: Boolean,
                 includeGlobs: String,
                 excludeGlobs: String,
                 docMgr: document_manager.DocumentManager,
                 locStore: locations.LocationStore) -> Integer {
    var count = 0;
    var fileIdx = 0;
    while fileIdx < Seq.get_Length(files) {
        var entry = Seq.Get(files, fileIdx);
        var filePath = Map.GetStr(entry, "path");
        fileIdx = fileIdx + 1;

        if IO.File.Exists(filePath) == false { continue; }
        if SearchPathAllowed(rootPath, filePath, includeGlobs, excludeGlobs) == false { continue; }
        count = count + searchOneFile(shell, filePath, query, caseSensitive, wholeWord,
                                      regexMode, docMgr, locStore);
    }
    return count;
}

func searchOneFile(shell: app_shell.AppShell,
                   filePath: String,
                   query: String,
                   caseSensitive: Boolean,
                   wholeWord: Boolean,
                   regexMode: Boolean,
                   docMgr: document_manager.DocumentManager,
                   locStore: locations.LocationStore) -> Integer {
    var count = 0;
    var content = contentForPath(docMgr, filePath);
    var contentLines = Str.Split(content, "\n");
    var lineNum = 0;
    var addedHeader = false;
    while lineNum < Seq.get_Length(contentLines) {
        var line = Obj.ToString(Seq.Get(contentLines, lineNum));
        lineNum = lineNum + 1;
        var match = FindLineMatch(line, query, caseSensitive, wholeWord, regexMode);
        if match.matched {
            if addedHeader == false {
                shell.AddToolGroupHeader(shell.searchListBox, Path.Name(filePath), filePath);
                addedHeader = true;
            }
            var resultText = Str.Trim(line);
            var item = shell.AddToolLocationRow(shell.searchListBox, "match", "text",
                                                "" + lineNum + ":" + match.startCol,
                                                "", resultText, "");
            var locId = locStore.Add(filePath, lineNum, match.startCol,
                                     lineNum, match.startCol + match.length,
                                     locations.KIND_SEARCH, Str.Trim(line));
            GUI.ListBox.ItemSetData(item, locId);
            count = count + 1;
        }
    }
    return count;
}

func QuickOpenScore(relativePath: String, query: String) -> Integer {
    var rel = Str.ToLower(relativePath);
    var needle = Str.ToLower(Str.Trim(query));
    if needle == "" { return -1; }
    if rel == needle { return 0; }

    var slash = Str.LastIndexOf(rel, "/");
    var name = rel;
    if slash != 0 {
        name = Str.Mid(rel, slash + 1);
    }
    if name == needle { return 1; }
    if Str.StartsWith(name, needle) { return 2; }
    if Str.StartsWith(rel, needle) { return 3; }
    if Str.IndexOf(rel, needle) != 0 { return 4; }
    return -1;
}

func contentForPath(docMgr: document_manager.DocumentManager, filePath: String) -> String {
    var idx = docMgr.FindByPath(filePath);
    if idx >= 0 {
        return docMgr.documents.get(idx).content;
    }
    return IO.File.ReadAllText(filePath);
}

