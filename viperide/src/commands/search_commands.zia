module search_commands;

bind "../ui/app_shell";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../commands/file_commands";
bind "../core/document_manager";
bind "../services/file_utils";
bind "../services/locations";

bind Viper.GUI;
bind IO = Viper.IO;
bind Dir = Viper.IO.Dir;
bind Str = Viper.String;
bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;
bind Map = Viper.Collections.Map;
bind FileIndex = Viper.Workspace.FileIndex;

// ============================================================================
// MODULE: search_commands
// PURPOSE: Project-wide text search (Ctrl+Shift+F). Scans selected text
//          file kinds under the project root, supports case and whole-word
//          options, and stores structured location ids on output rows.
//
// WHERE-THIS-FITS: Wired into main.zia's command dispatcher. Only
//          enabled when a project is open (otherwise toasts a warning).
//
// KEY-DESIGN-CHOICES:
//   * GLOB-BASED FILE DISCOVERY. `Viper.IO.Glob.Files(root, "**/*.zia")`
//     walks the tree once. Two passes (zia then bas) is simpler than
//     extending Glob to handle multi-pattern queries.
//   * SIMPLE MATCH MODES. No regex in Phase 0; the command flow exposes
//     case-sensitive and whole-word toggles without adding query syntax.
//   * RESULT ROWS CARRY DATA. Each output-panel item stores a LocationStore
//     id via `ItemSetData`, so clicking a result does not parse display text.
// ============================================================================

/// @brief Prompt for a query, scan the project, populate the output panel.
func handleProjectSearch(shell: app_shell.AppShell,
                         projMgr: project_manager.ProjectManager,
                         docMgr: document_manager.DocumentManager,
                         engine: editor_engine.EditorEngine,
                         locStore: locations.LocationStore) {
    if projMgr.project == null or projMgr.project.isOpen == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }

    RunSearch(shell, projMgr.project.rootPath, "Search in Project", docMgr, engine, locStore);
}

func handleProjectSearchInFolder(shell: app_shell.AppShell,
                                 folder: String,
                                 docMgr: document_manager.DocumentManager,
                                 engine: editor_engine.EditorEngine,
                                 locStore: locations.LocationStore) {
    if folder == "" or Dir.Exists(folder) == false {
        GUI.Toast.Warning("Choose a folder to search");
        return;
    }
    RunSearch(shell, folder, "Search in Folder", docMgr, engine, locStore);
}

func handleQuickOpen(shell: app_shell.AppShell,
                     projMgr: project_manager.ProjectManager,
                     docMgr: document_manager.DocumentManager,
                     engine: editor_engine.EditorEngine,
                     tabs: editor_tabs.EditorTabs) {
    if projMgr.project == null or projMgr.project.isOpen == false {
        GUI.Toast.Warning("Open a project folder first");
        return;
    }
    var query = Str.Trim(GUI.MessageBox.Prompt("Quick Open", "File name or path:"));
    if query == "" { return; }

    var files = FileIndex.Enumerate(projMgr.project.rootPath,
                                    ".zia,.bas,.vb,.json,.md,.scene,.level,.txt",
                                    "", false);
    var bestPath = "";
    var bestScore = 999;
    var i = 0;
    while i < Seq.get_Length(files) {
        var entry = Seq.Get(files, i);
        var filePath = Map.GetStr(entry, "path");
        var score = QuickOpenScore(projMgr.RelativePath(filePath), query);
        if score >= 0 and score < bestScore {
            bestScore = score;
            bestPath = filePath;
        }
        i = i + 1;
    }

    if bestPath == "" {
        GUI.Toast.Info("No project file matched '" + query + "'");
        return;
    }

    file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, bestPath);
    shell.SetStatusLeft("Opened: " + projMgr.RelativePath(bestPath));
}

func RunSearch(shell: app_shell.AppShell,
               root: String,
               title: String,
               docMgr: document_manager.DocumentManager,
               engine: editor_engine.EditorEngine,
               locStore: locations.LocationStore) {
    var query = GUI.MessageBox.Prompt(title, "Search for:");
    if query == "" { return; }
    var caseSensitive = GUI.MessageBox.Confirm(
        "Search Options",
        "Use case-sensitive matching?") != 0;
    var wholeWord = GUI.MessageBox.Confirm(
        "Search Options",
        "Match whole words only?") != 0;
    var fileKinds = GUI.MessageBox.Prompt(
        "Search File Kinds",
        "Comma-separated extensions to search.\nLeave blank for code, text, scene, and docs.");
    if fileKinds == "" {
        fileKinds = ".zia,.bas,.vb,.json,.md,.scene,.level";
    } else {
        fileKinds = Str.Replace(fileKinds, " ", "");
    }
    file_commands.SaveEditorState(docMgr, engine);

    var files = FileIndex.Enumerate(root, fileKinds, "", false);

    var resultCount = 0;
    shell.outputListBox.Clear();

    resultCount = resultCount + searchFiles(shell, files, query, caseSensitive, wholeWord, docMgr, locStore);

    if resultCount > 0 {
        shell.ShowOutputPanel();
        shell.SetStatusLeft("Found " + resultCount + " matches for '" + query + "'");
    } else {
        shell.HideOutputPanel();
        GUI.Toast.Info("No matches found for '" + query + "'");
    }
}

/// @brief Substring-search every file in `files` for `query`.
/// @return Match count (rows added to the output panel).
func searchFiles(shell: app_shell.AppShell,
                 files: Any,
                 query: String,
                 caseSensitive: Boolean,
                 wholeWord: Boolean,
                 docMgr: document_manager.DocumentManager,
                 locStore: locations.LocationStore) -> Integer {
    var count = 0;
    var fileIdx = 0;
    while fileIdx < Seq.get_Length(files) {
        var entry = Seq.Get(files, fileIdx);
        var filePath = Map.GetStr(entry, "path");
        fileIdx = fileIdx + 1;

        if IO.File.Exists(filePath) == false { continue; }
        var content = contentForPath(docMgr, filePath);

        // Search each line for the query
        var contentLines = Str.Split(content, "\n");
        var lineNum = 0;
        while lineNum < Seq.get_Length(contentLines) {
            var line = Obj.ToString(Seq.Get(contentLines, lineNum));
            lineNum = lineNum + 1;
            if LineMatches(line, query, caseSensitive, wholeWord) {
                var resultText = filePath + ":" + lineNum + ": " + Str.Trim(line);
                var item = shell.outputListBox.AddItem(resultText);
                var locId = locStore.Add(filePath, lineNum, MatchColumn(line, query, caseSensitive),
                                         lineNum, MatchColumn(line, query, caseSensitive) + Str.Length(query),
                                         locations.KIND_SEARCH, Str.Trim(line));
                GUI.ListBox.ItemSetData(item, locId);
                count = count + 1;
            }
        }
    }
    return count;
}

func QuickOpenScore(relativePath: String, query: String) -> Integer {
    var rel = Str.ToLower(relativePath);
    var needle = Str.ToLower(Str.Trim(query));
    if needle == "" { return -1; }
    if rel == needle { return 0; }

    var slash = Str.LastIndexOf(rel, "/");
    var name = rel;
    if slash != 0 {
        name = Str.Mid(rel, slash + 1);
    }
    if name == needle { return 1; }
    if Str.StartsWith(name, needle) { return 2; }
    if Str.StartsWith(rel, needle) { return 3; }
    if Str.IndexOf(rel, needle) != 0 { return 4; }
    return -1;
}

func contentForPath(docMgr: document_manager.DocumentManager, filePath: String) -> String {
    var idx = docMgr.FindByPath(filePath);
    if idx >= 0 {
        return docMgr.documents.get(idx).content;
    }
    return IO.File.ReadAllText(filePath);
}

func LineMatches(line: String,
                 query: String,
                 caseSensitive: Boolean,
                 wholeWord: Boolean) -> Boolean {
    var hay = line;
    var needle = query;
    if caseSensitive == false {
        hay = Str.ToLower(hay);
        needle = Str.ToLower(needle);
    }
    var idx = Str.IndexOf(hay, needle);
    while idx != 0 {
        if wholeWord == false or IsWholeWordMatch(hay, idx, Str.Length(needle)) {
            return true;
        }
        idx = Str.IndexOfFrom(hay, idx + 1, needle);
    }
    return false;
}

func MatchColumn(line: String, query: String, caseSensitive: Boolean) -> Integer {
    var hay = line;
    var needle = query;
    if caseSensitive == false {
        hay = Str.ToLower(hay);
        needle = Str.ToLower(needle);
    }
    var idx = Str.IndexOf(hay, needle);
    if idx <= 0 { return 1; }
    return idx;
}

func IsWholeWordMatch(text: String, startCol: Integer, len: Integer) -> Boolean {
    var beforeOk = true;
    var afterOk = true;
    if startCol > 1 {
        beforeOk = IsIdentifierChar(Str.MidLen(text, startCol - 1, 1)) == false;
    }
    var afterCol = startCol + len;
    if afterCol <= Str.Length(text) {
        afterOk = IsIdentifierChar(Str.MidLen(text, afterCol, 1)) == false;
    }
    return beforeOk and afterOk;
}

func IsIdentifierChar(ch: String) -> Boolean {
    if ch >= "a" and ch <= "z" { return true; }
    if ch >= "A" and ch <= "Z" { return true; }
    if ch >= "0" and ch <= "9" { return true; }
    if ch == "_" { return true; }
    return false;
}
