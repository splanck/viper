module command_registry;

bind "../editor/language_service";

bind Viper.GUI;
bind Str = Viper.String;

class CommandEntry {
    expose String id;
    expose String label;
    expose String description;
    expose String category;
    expose String shortcut;
    expose String capability;
    expose Boolean showInPalette;

    expose func init() {
        id = "";
        label = "";
        description = "";
        category = "";
        shortcut = "";
        capability = "";
        showInPalette = true;
    }
}

class CommandRegistry {
    expose List[CommandEntry] commands;

    expose func init() {
        commands = [];
        RegisterDefaults();
    }

    expose func Add(id: String,
                    label: String,
                    description: String,
                    shortcut: String,
                    capability: String,
                    showInPalette: Boolean) {
        var cmd = new CommandEntry();
        cmd.id = id;
        cmd.label = label;
        cmd.description = description;
        cmd.category = CommandCategory(id);
        cmd.shortcut = shortcut;
        cmd.capability = capability;
        cmd.showInPalette = showInPalette;
        commands.add(cmd);
    }

    expose func RegisterDefaults() {
        Add("new", "New File", "Create a new untitled file", "Ctrl+N", "", true);
        Add("open", "Open File...", "Open a file from disk", "Ctrl+O", "", true);
        Add("save", "Save", "Save the current file", "Ctrl+S", "", true);
        Add("saveall", "Save All", "Save all open files", "Ctrl+Shift+S", "", true);
        Add("close", "Close File", "Close the current tab", "Ctrl+W", "", true);
        Add("reload", "Reload File", "Reload file from disk", "Ctrl+Shift+R", "", true);
        Add("recentfiles", "Recent Files", "Show recently opened files", "Ctrl+K Ctrl+R", "", true);
        Add("reopenclosed", "Reopen Closed File", "Reopen the most recently closed named file", "Ctrl+Alt+T", "", true);
        Add("find", "Find / Replace", "Open the find bar", "Ctrl+F", "", true);
        Add("goto", "Go To Line", "Jump to a specific line number", "Ctrl+G", "", true);
        Add("build", "Build", "Compile the current file or project", "Ctrl+Shift+B", "", true);
        Add("buildrun", "Build and Run", "Build and run the current file or project", "F5", "", true);
        Add("run", "Run without Build", "Run without compiling first", "Ctrl+F5", "", true);
        Add("stopjob", "Stop Running Job", "Terminate the active build or run process", "Shift+F5", "", true);
        Add("debugstart", "Start Debugging", "Launch the active file in the debug protocol", "F6", "", true);
        Add("debugcontinue", "Continue Debugging", "Continue a paused debug session", "F7", "", true);
        Add("debugstepover", "Step Over", "Step over the current debug line", "F10", "", true);
        Add("debugpause", "Pause Debugging", "Pause the active debug session", "", "", true);
        Add("debugstop", "Stop Debugging", "Terminate the active debug session", "", "", true);
        Add("togglebreakpoint", "Toggle Breakpoint", "Set or clear a breakpoint at the cursor", "F9", "", true);
        Add("togglesidebar", "Toggle Sidebar", "Show or hide the file tree", "Ctrl+B", "", true);
        Add("statusbar", "Toggle Status Bar", "Show or hide the status bar", "", "", true);
        Add("zoomin", "Zoom In", "Increase editor font size", "Ctrl+=", "", true);
        Add("zoomout", "Zoom Out", "Decrease editor font size", "Ctrl+-", "", true);
        Add("zoomreset", "Reset Zoom", "Reset editor font size to default", "Ctrl+0", "", true);
        Add("toggletheme", "Toggle Theme", "Switch between dark and light theme", "Ctrl+Shift+T", "", true);
        Add("fullscreen", "Toggle Fullscreen", "Enter or exit fullscreen mode", "F11", "", true);
        Add("minimap", "Toggle Minimap", "Show or hide the minimap panel", "Ctrl+Shift+M", "", true);
        Add("settings", "Settings", "View and adjust IDE settings", "Ctrl+,", "", true);
        Add("keybindings", "Keyboard Shortcuts", "Show active keyboard shortcuts and conflicts", "Ctrl+K Ctrl+S", "", true);
        Add("copytoolrow", "Copy Tool Row", "Copy the selected row from the active tool panel", "Ctrl+Alt+Y", "", true);
        Add("copyoutputtext", "Copy Output Text", "Copy the full build output buffer", "Ctrl+Alt+Shift+Y", "", true);
        Add("clearoutput", "Clear Output", "Clear the build output panel", "Ctrl+Alt+L", "", true);
        Add("filteroutput", "Filter Output", "Filter build output rows by text", "Ctrl+Alt+F", "", true);
        Add("toggleoutputwrap", "Toggle Output Wrap", "Wrap long output rows into readable chunks", "Ctrl+Alt+W", "", true);
        Add("toggleoutputautoscroll", "Toggle Output Auto-Scroll", "Keep new output pinned or preserve the current view", "Ctrl+Alt+S", "", true);
        Add("treenewfile", "Explorer: New File", "Create a file in the selected project folder", "Ctrl+Alt+N", "", true);
        Add("treenewfolder", "Explorer: New Folder", "Create a folder in the selected project folder", "Ctrl+Alt+Shift+N", "", true);
        Add("treerename", "Explorer: Rename", "Rename the selected project tree item", "Ctrl+Alt+R", "", true);
        Add("treedelete", "Explorer: Delete", "Delete the selected project tree item", "Ctrl+Alt+D", "", true);
        Add("treerefresh", "Explorer: Refresh", "Refresh the project tree", "Ctrl+Alt+Shift+R", "", true);
        Add("quickopen", "Quick Open File", "Open a project file by name or path", "Ctrl+P", "", true);
        Add("undo", "Undo", "Undo last action", "Ctrl+Z", "", true);
        Add("redo", "Redo", "Redo last undone action", "Ctrl+Y", "", true);
        Add("cut", "Cut", "Cut selection", "Ctrl+X", "", false);
        Add("copy", "Copy", "Copy selection", "Ctrl+C", "", false);
        Add("paste", "Paste", "Paste clipboard", "Ctrl+V", "", false);
        Add("selectall", "Select All", "Select the full document", "Ctrl+A", "", true);
        Add("gotodef", "Go To Definition", "Jump to symbol definition", "F12", "definition", true);
        Add("findrefs", "Find References", "Find semantic references", "Shift+F12", "references", true);
        Add("incomingcalls", "Incoming Calls", "Show callers of the symbol at the cursor", "Ctrl+Alt+H", "references", true);
        Add("outgoingcalls", "Outgoing Calls", "Show calls made by the enclosing function", "Ctrl+Alt+Shift+H", "definition", true);
        Add("rename", "Rename Symbol", "Rename a semantic symbol", "F2", "rename", true);
        Add("nexterror", "Next Error", "Jump to next diagnostic", "F8", "diagnostics", true);
        Add("preverror", "Previous Error", "Jump to previous diagnostic", "Shift+F8", "diagnostics", true);
        Add("checknow", "Run Check Now", "Run diagnostics for the active file now", "Ctrl+Alt+C", "diagnostics", true);
        Add("searchproject", "Search in Project", "Find text across project files", "Ctrl+Shift+F", "", true);
        Add("workspacesymbols", "Workspace Symbols", "Find symbols across project files", "Ctrl+T", "symbols", true);
        Add("symboloutline", "Symbol Outline", "Toggle document symbol list", "Ctrl+Shift+O", "symbols", true);
        Add("completion_trigger", "Trigger Completion", "Show completion suggestions", "Ctrl+Space", "completion", false);
        Add("signature_trigger", "Trigger Signature Help", "Show signature help at the cursor", "Ctrl+Shift+Space", "signature", true);
        Add("signaturenextoverload", "Signature: Next Overload", "Show the next signature overload", "Ctrl+Alt+Down", "signature", true);
        Add("signatureprevoverload", "Signature: Previous Overload", "Show the previous signature overload", "Ctrl+Alt+Up", "signature", true);
        Add("addnextoccurrence", "Add Next Occurrence", "Add a cursor at the next matching word", "Ctrl+D", "", true);
        Add("skipoccurrence", "Skip Occurrence", "Move to the next matching word", "Ctrl+K Ctrl+D", "", true);
        Add("selectalloccurrences", "Select All Occurrences", "Select every matching word", "Ctrl+Shift+L", "", true);
        Add("clearcursors", "Clear Extra Cursors", "Remove secondary cursors", "Escape", "", true);
        Add("expandselection", "Expand Selection", "Grow selection from word to line to document", "Shift+Alt+Right", "", true);
        Add("shrinkselection", "Shrink Selection", "Shrink selection from document to line to word", "Shift+Alt+Left", "", true);
        Add("togglelinecomment", "Toggle Line Comment", "Comment or uncomment the active line", "Ctrl+/", "", true);
        Add("toggleblockcomment", "Toggle Block Comment", "Wrap or unwrap the selection in a block comment", "Shift+Alt+A", "", true);
        Add("duplicateline", "Duplicate Line", "Duplicate the active line", "Ctrl+Shift+D", "", true);
        Add("movelineup", "Move Line Up", "Move the active line above the previous line", "Alt+Up", "", true);
        Add("movelinedown", "Move Line Down", "Move the active line below the next line", "Alt+Down", "", true);
        Add("organizebinds", "Organize Binds", "Sort and deduplicate the leading Zia bind block", "Shift+Alt+O", "diagnostics", true);
        Add("suppressdiagnostic", "Suppress Warning", "Insert a Zia suppression comment for the warning at the cursor", "", "diagnostics", true);
        Add("applydiagnosticfix", "Apply Diagnostic Fix-It", "Apply the first language-proposed diagnostic fix at the cursor", "Ctrl+.", "diagnostics", true);
        Add("createmissingbind", "Create Missing Bind", "Add a safe runtime bind for an undefined Viper namespace alias", "", "diagnostics", true);
        Add("trimtrailingwhitespace", "Trim Trailing Whitespace", "Remove trailing spaces and tabs from the active document", "Shift+Alt+T", "", true);
        Add("formatdocument", "Format Document", "Format the active document when a formatter is available", "Shift+Alt+F", "", true);
        Add("formatselection", "Format Selection", "Format the selected text when a formatter is available", "", "", true);
    }

    expose func InstallShortcuts() {
        Shortcuts.Clear();
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.shortcut != "" {
                Shortcuts.Register(cmd.id, cmd.shortcut, cmd.label);
            }
            i = i + 1;
        }
    }

    expose func PopulatePalette(palette: GUI.CommandPalette,
                                service: language_service.LanguageService) {
        if palette == null { return; }
        palette.Clear();
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.showInPalette {
                if IsSupported(cmd, service) {
                    palette.AddCommandWithShortcut(cmd.id, cmd.label, cmd.category, cmd.shortcut);
                } else {
                    palette.AddCommandWithShortcut(cmd.id,
                                                   cmd.label + " (Unavailable)",
                                                   cmd.category,
                                                   cmd.shortcut);
                }
            }
            i = i + 1;
        }
    }

    expose func ApplyCapabilities(service: language_service.LanguageService) {
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.shortcut != "" {
                if IsSupported(cmd, service) {
                    Shortcuts.SetEnabled(cmd.id, 1);
                } else {
                    Shortcuts.SetEnabled(cmd.id, 0);
                }
            }
            i = i + 1;
        }
    }

    expose func NormalizeId(id: String) -> String {
        if id == "sidebar" { return "togglesidebar"; }
        return id;
    }

    expose func IsKnown(id: String) -> Boolean {
        var norm = NormalizeId(id);
        return Find(norm) != null;
    }

    expose func IsExecutable(id: String,
                             service: language_service.LanguageService) -> Boolean {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return false; }
        return IsSupported(cmd, service);
    }

    expose func DisabledReason(id: String,
                               service: language_service.LanguageService) -> String {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return "Command is not registered"; }
        if IsSupported(cmd, service) { return ""; }
        return DisabledReasonFor(cmd, service);
    }

    expose func Find(id: String) -> CommandEntry {
        var i = 0;
        while i < commands.count() {
            if commands.get(i).id == id { return commands.get(i); }
            i = i + 1;
        }
        return null;
    }

    expose func ShortcutConflictCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < commands.count() {
            var left = commands.get(i);
            if left.shortcut != "" {
                var j = i + 1;
                while j < commands.count() {
                    var right = commands.get(j);
                    if right.shortcut != "" and right.shortcut == left.shortcut {
                        count = count + 1;
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
        return count;
    }

    expose func ShortcutHasConflict(shortcut: String) -> Boolean {
        if shortcut == "" { return false; }
        var matches = 0;
        var i = 0;
        while i < commands.count() {
            if commands.get(i).shortcut == shortcut {
                matches = matches + 1;
            }
            i = i + 1;
        }
        return matches > 1;
    }

    expose func ShortcutConflictSummary() -> String {
        var summary = "";
        var i = 0;
        while i < commands.count() {
            var left = commands.get(i);
            if left.shortcut != "" {
                var j = i + 1;
                while j < commands.count() {
                    var right = commands.get(j);
                    if right.shortcut == left.shortcut {
                        if summary != "" { summary = summary + "\n"; }
                        summary = summary + left.shortcut + ": " + left.id + " / " + right.id;
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
        return summary;
    }

    expose func IsSupported(cmd: CommandEntry,
                            service: language_service.LanguageService) -> Boolean {
        if cmd.capability == "" { return true; }
        if service == null { return false; }
        if cmd.capability == "completion" { return service.canComplete; }
        if cmd.capability == "diagnostics" { return service.canDiagnose; }
        if cmd.capability == "definition" { return service.canGoToDefinition; }
        if cmd.capability == "references" { return service.canFindReferences; }
        if cmd.capability == "rename" { return service.canRename; }
        if cmd.capability == "signature" { return service.canSignatureHelp; }
        if cmd.capability == "symbols" { return service.canDocumentSymbols; }
        return true;
    }

    expose func DisabledReasonFor(cmd: CommandEntry,
                                  service: language_service.LanguageService) -> String {
        if cmd == null { return "Command is not registered"; }
        var language = "this file";
        if service != null and service.name != "" {
            language = Str.ToUpper(service.name);
        }
        return cmd.label + " is unavailable: " + language
               + " does not support " + CapabilityLabel(cmd.capability) + ".";
    }

    expose func CapabilityLabel(capability: String) -> String {
        if capability == "completion" { return "completion"; }
        if capability == "diagnostics" { return "diagnostics"; }
        if capability == "definition" { return "go to definition"; }
        if capability == "references" { return "references"; }
        if capability == "rename" { return "rename"; }
        if capability == "signature" { return "signature help"; }
        if capability == "symbols" { return "document symbols"; }
        return "this language feature";
    }

    expose func CommandCategory(id: String) -> String {
        if id == "new" or id == "open" or id == "save" or id == "saveall"
           or id == "close" or id == "reload" or id == "recentfiles"
           or id == "reopenclosed" {
            return "File";
        }
        if id == "find" or id == "searchproject" {
            return "Search";
        }
        if id == "quickopen" or id == "goto" or id == "gotodef"
           or id == "findrefs" or id == "incomingcalls" or id == "outgoingcalls"
           or id == "nexterror" or id == "preverror" or id == "workspacesymbols"
           or id == "symboloutline" or id == "signature_trigger"
           or id == "signaturenextoverload" or id == "signatureprevoverload" {
            return "Navigate";
        }
        if id == "rename" or id == "organizebinds" or id == "suppressdiagnostic"
           or id == "applydiagnosticfix" or id == "createmissingbind" {
            return "Refactor";
        }
        if id == "build" or id == "buildrun" or id == "run" or id == "stopjob" {
            return "Build";
        }
        if Str.StartsWith(id, "debug") or id == "togglebreakpoint" {
            return "Debug";
        }
        if id == "togglesidebar" or id == "statusbar" or id == "zoomin"
           or id == "zoomout" or id == "zoomreset" or id == "toggletheme"
           or id == "fullscreen" or id == "minimap" {
            return "View";
        }
        if id == "settings" or id == "keybindings" {
            return "Settings";
        }
        if id == "copytoolrow" or id == "copyoutputtext" or id == "clearoutput"
           or id == "filteroutput" or id == "toggleoutputwrap"
           or id == "toggleoutputautoscroll" {
            return "Output";
        }
        if Str.StartsWith(id, "tree") {
            return "Explorer";
        }
        if id == "undo" or id == "redo" or id == "cut" or id == "copy"
           or id == "paste" or id == "selectall" or id == "completion_trigger"
           or id == "addnextoccurrence" or id == "skipoccurrence"
           or id == "selectalloccurrences" or id == "clearcursors"
           or id == "expandselection" or id == "shrinkselection"
           or id == "togglelinecomment" or id == "toggleblockcomment"
           or id == "duplicateline" or id == "movelineup" or id == "movelinedown"
           or id == "trimtrailingwhitespace" or id == "formatdocument"
           or id == "formatselection" {
            return "Edit";
        }
        return "Command";
    }
}
