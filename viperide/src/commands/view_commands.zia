module view_commands;

bind "../ui/app_shell";
bind "../core/settings";
bind "../core/session";
bind "../editor/editor_engine";
bind "../editor/diagnostics";
bind "../commands/command_registry";

bind Viper.GUI;
bind Convert = Viper.Core.Convert;
bind Machine = Viper.System.Machine;
bind Path = Viper.IO.Path;
bind Str = Viper.String;
bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;

// ============================================================================
// MODULE: view_commands
// PURPOSE: View / appearance command handlers — toggle sidebar / status
//          bar / minimap / theme / fullscreen, zoom in/out/reset, and
//          the shared font / theme application helpers. Also owns the cross-platform
//          font-fallback chains.
//
// WHERE-THIS-FITS: Command handlers wired into main.zia's command
//          dispatcher. The font helpers (applyShellFont,
//          applyEditorFont) are also called once at startup so the
//          shell's chrome and editor pick up consistent fonts.
//
// KEY-DESIGN-CHOICES:
//   * OS-SPECIFIC FONT FALLBACKS. `Machine.Os` returns "macos" /
//     "windows" / "linux"; we try the platform-conventional UI font
//     first, then progressively more conservative fallbacks. Matches
//     real IDEs that "just work" on a fresh OS install.
//   * TWO FONT CHAINS. Shell chrome uses the proportional-UI chain
//     (SF / Helvetica, Segoe UI / Arial, DejaVu Sans); the editor uses
//     the monospace chain (SF Mono / Menlo / Monaco, Consolas /
//     Courier, DejaVu Sans Mono). Loaded independently because the
//     chrome-vs-code distinction matters for legibility.
//   * USER OVERRIDE. `appSettings.fontPath` short-circuits the editor
//     fallback chain so power users can supply their own .ttf/.ttc.
//     If the override fails to load, the user is toast-warned and we
//     fall back to the OS chain (so a typo doesn't leave the editor
//     unusable).
//   * CLAMP ON ZOOM. clampFontSize keeps font size in [6, 72]. Outside
//     that range the editor would be unreadable or rendered in a
//     single glyph.
// ============================================================================

/// @brief Clamp font size to the editor's usable range [12, 72].
func clampFontSize(size: Integer) -> Integer {
    if size < 12 { return 12; }
    if size > 72 { return 72; }
    return size;
}

/// @brief Base chrome font size (15pt) scaled by the current whole-UI zoom so the
///        menus, toolbar, and panels grow together with View > UI Zoom. The theme
///        typography and control metrics are scaled by the same factor in the GUI
///        runtime, so the chrome stays proportional.
func chromeFontSize(shell: app_shell.AppShell) -> Number {
    var zoom = shell.app.GetUiScale();
    if zoom <= 0.0 { zoom = 1.0; }
    return 15.0 * zoom;
}

/// @brief Set the shell's chrome font from the OS-conventional UI font.
/// @details Tries SFNS / HelveticaNeue / Helvetica on macOS, Segoe UI /
///          Arial on Windows, DejaVu Sans on Linux. Falls back to
///          `SetFontSize(15)` on the default if every load fails.
func applyShellFont(shell: app_shell.AppShell) {
    var font: GUI.Font = null;
    var os = Machine.Os;

    if os == "macos" {
        font = GUI.Font.Load("/System/Library/Fonts/SFNS.ttf");
        if font == null { font = GUI.Font.Load("/System/Library/Fonts/SFNSRounded.ttf"); }
        if font == null { font = GUI.Font.Load("/System/Library/Fonts/Geneva.ttf"); }
    } else if os == "windows" {
        font = GUI.Font.Load("C:\\Windows\\Fonts\\segoeui.ttf");
        if font == null { font = GUI.Font.Load("C:\\Windows\\Fonts\\tahoma.ttf"); }
        if font == null { font = GUI.Font.Load("C:\\Windows\\Fonts\\arial.ttf"); }
    } else {
        font = GUI.Font.Load("/usr/share/fonts/truetype/noto/NotoSans-Regular.ttf");
        if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"); }
        if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/liberation2/LiberationSans-Regular.ttf"); }
        if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/liberation/LiberationSans-Regular.ttf"); }
        if font == null { font = GUI.Font.Load("/usr/share/fonts/TTF/DejaVuSans.ttf"); }
    }

    var chromeSize = chromeFontSize(shell);
    if font != null {
        shell.app.SetFont(font, chromeSize);
        return;
    }

    shell.app.SetFontSize(chromeSize);
}

/// @brief Set the editor's monospace font from settings + OS fallback.
/// @details If `appSettings.fontPath` is set, tries that first (toasts
///          a warning if it fails). Otherwise walks the OS-conventional
///          monospace chain (SF Mono / Menlo / Monaco, Consolas /
///          Courier, DejaVu Sans Mono).
func applyEditorFont(engine: editor_engine.EditorEngine,
                     appSettings: settings.SettingsManager) {
    appSettings.fontSize = clampFontSize(appSettings.fontSize);

    var font: GUI.Font = null;
    if appSettings.fontPath != "" {
        font = GUI.Font.Load(appSettings.fontPath);
        if font == null {
            GUI.Toast.Warning("Could not load font: " + appSettings.fontPath);
            appSettings.fontPath = "";
        }
    }

    if font == null {
        var os = Machine.Os;
        if os == "macos" {
            font = GUI.Font.Load("/System/Library/Fonts/SFNSMono.ttf");
            if font == null { font = GUI.Font.Load("/System/Library/Fonts/Monaco.ttf"); }
        } else if os == "windows" {
            font = GUI.Font.Load("C:\\Windows\\Fonts\\CascadiaMono.ttf");
            if font == null { font = GUI.Font.Load("C:\\Windows\\Fonts\\consola.ttf"); }
            if font == null { font = GUI.Font.Load("C:\\Windows\\Fonts\\lucon.ttf"); }
        } else {
            font = GUI.Font.Load("/usr/share/fonts/truetype/noto/NotoSansMono-Regular.ttf");
            if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf"); }
            if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/liberation2/LiberationMono-Regular.ttf"); }
            if font == null { font = GUI.Font.Load("/usr/share/fonts/truetype/liberation/LiberationMono-Regular.ttf"); }
            if font == null { font = GUI.Font.Load("/usr/share/fonts/TTF/DejaVuSansMono.ttf"); }
        }
    }

    if font != null {
        engine.editor.SetFont(font, appSettings.fontSize);
        return;
    }

    engine.editor.SetFontSize(appSettings.fontSize);
}

/// @brief Apply all persisted appearance / behavior settings in one pass.
func applyPersistentSettings(shell: app_shell.AppShell,
                             engine: editor_engine.EditorEngine,
                             liveDiag: diagnostics.LiveDiagnostics,
                             appSettings: settings.SettingsManager) {
    appSettings.fontSize = clampFontSize(appSettings.fontSize);
    if appSettings.tabWidth < 2 { appSettings.tabWidth = 2; }
    if appSettings.tabWidth > 8 { appSettings.tabWidth = 8; }

    appSettings.ApplyTheme();
    applyEditorFont(engine, appSettings);
    engine.editor.SetTabSize(appSettings.tabWidth);
    if appSettings.insertSpaces {
        engine.editor.SetInsertSpaces(true);
    } else {
        engine.editor.SetInsertSpaces(false);
    }
    if appSettings.wordWrap {
        engine.editor.SetWordWrap(true);
    } else {
        engine.editor.SetWordWrap(false);
    }
    if appSettings.lineNumbers {
        engine.editor.SetShowLineNumbers(true);
    } else {
        engine.editor.SetShowLineNumbers(false);
    }

    if appSettings.codeFolding {
        engine.editor.SetShowFoldGutter(true);
        engine.editor.SetAutoFoldDetection(false);
    } else {
        engine.editor.SetShowFoldGutter(false);
        engine.editor.SetAutoFoldDetection(false);
        engine.editor.ClearFoldRegions();
    }

    liveDiag.enabled = appSettings.autoCheckOnSave;
    if appSettings.autoCheckOnSave {
        liveDiag.invalidate();
    } else {
        shell.ClearProblemsPanel();
        shell.minimap.ClearMarkers();
        engine.editor.ClearHighlights();
    }

    if appSettings.minimapVisible {
        shell.minimap.SetVisible(true);
    } else {
        shell.minimap.SetVisible(false);
    }
    if appSettings.statusBarVisible {
        shell.statusBar.SetVisible(true);
    } else {
        shell.statusBar.SetVisible(false);
    }
    shell.app.SetFullscreen(appSettings.fullscreen);

    applyUiZoom(shell, appSettings);
}

/// @brief Toggle the file-tree sidebar visibility.
func handleToggleSidebar(shell: app_shell.AppShell) {
    shell.ToggleSidebar();
}

/// @brief Toggle status bar visibility and persist the new state.
func handleToggleStatusBar(shell: app_shell.AppShell,
                           appSettings: settings.SettingsManager) {
    if shell.statusBar.IsVisible() {
        shell.statusBar.SetVisible(false);
        appSettings.statusBarVisible = false;
        shell.SetStatusLeft("Status bar hidden");
    } else {
        shell.statusBar.SetVisible(true);
        appSettings.statusBarVisible = true;
        shell.SetStatusLeft("Status bar shown");
    }
    appSettings.Save();
}

/// @brief Increase editor font size by 1pt; persist setting.
func handleZoomIn(shell: app_shell.AppShell,
                  engine: editor_engine.EditorEngine,
                  appSettings: settings.SettingsManager) {
    appSettings.fontSize = clampFontSize(appSettings.fontSize + 1);
    applyEditorFont(engine, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("Font size: " + appSettings.fontSize);
}

/// @brief Decrease editor font size by 1pt; persist setting.
func handleZoomOut(shell: app_shell.AppShell,
                   engine: editor_engine.EditorEngine,
                   appSettings: settings.SettingsManager) {
    appSettings.fontSize = clampFontSize(appSettings.fontSize - 1);
    applyEditorFont(engine, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("Font size: " + appSettings.fontSize);
}

/// @brief Reset editor font to DEFAULT_FONT_SIZE; persist setting.
func handleZoomReset(shell: app_shell.AppShell,
                     engine: editor_engine.EditorEngine,
                     appSettings: settings.SettingsManager) {
    appSettings.fontSize = settings.DEFAULT_FONT_SIZE;
    applyEditorFont(engine, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("Font size reset to " + settings.DEFAULT_FONT_SIZE);
}

/// @brief Clamp the whole-UI zoom percentage to the legible range [50, 300].
func clampUiZoom(percent: Integer) -> Integer {
    if percent < 50 { return 50; }
    if percent > 300 { return 300; }
    return percent;
}

/// @brief Apply the persisted whole-UI zoom to the GUI runtime and chrome font.
/// @details SetUiScale folds the zoom into the HiDPI scale so typography, spacing,
///          and control metrics all grow together; re-applying the shell font picks
///          up the matching chrome size.
func applyUiZoom(shell: app_shell.AppShell,
                 appSettings: settings.SettingsManager) {
    appSettings.uiZoomPercent = clampUiZoom(appSettings.uiZoomPercent);
    shell.app.SetUiScale(appSettings.uiZoomPercent / 100.0);
    applyShellFont(shell);
}

/// @brief Enlarge the whole interface by 10%; persist setting.
func handleUiZoomIn(shell: app_shell.AppShell,
                    appSettings: settings.SettingsManager) {
    appSettings.uiZoomPercent = clampUiZoom(appSettings.uiZoomPercent + 10);
    applyUiZoom(shell, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("UI zoom: " + appSettings.uiZoomPercent + "%");
}

/// @brief Shrink the whole interface by 10%; persist setting.
func handleUiZoomOut(shell: app_shell.AppShell,
                     appSettings: settings.SettingsManager) {
    appSettings.uiZoomPercent = clampUiZoom(appSettings.uiZoomPercent - 10);
    applyUiZoom(shell, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("UI zoom: " + appSettings.uiZoomPercent + "%");
}

/// @brief Reset the whole-UI zoom to 100%; persist setting.
func handleUiZoomReset(shell: app_shell.AppShell,
                       appSettings: settings.SettingsManager) {
    appSettings.uiZoomPercent = 100;
    applyUiZoom(shell, appSettings);
    appSettings.Save();
    shell.SetStatusLeft("UI zoom reset to 100%");
}

/// @brief Switch between dark and light themes, refresh appearance, and persist setting.
/// @details Theme changes affect long-lived widgets and standalone overlays.
///          Running the same appearance pass used at startup keeps font sizes,
///          editor chrome, minimap/status visibility, and theme-derived colors
///          synchronized after the toggle.
func handleToggleTheme(shell: app_shell.AppShell,
                       engine: editor_engine.EditorEngine,
                       liveDiag: diagnostics.LiveDiagnostics,
                       appSettings: settings.SettingsManager) {
    if appSettings.theme == "dark" {
        GUI.Theme.SetLight();
        appSettings.theme = "light";
        GUI.Toast.Info("Switched to light theme");
    } else {
        GUI.Theme.SetDark();
        appSettings.theme = "dark";
        GUI.Toast.Info("Switched to dark theme");
    }
    applyShellFont(shell);
    applyPersistentSettings(shell, engine, liveDiag, appSettings);
    appSettings.Save();
}

func handleKeybindings(shell: app_shell.AppShell,
                       registry: command_registry.CommandRegistry) {
    if shell == null or registry == null { return; }
    shell.BeginOutputRows();
    var conflictCount = registry.ShortcutConflictCount();
    if conflictCount == 0 {
        shell.AddOutputDisplayLine("Keyboard Shortcuts - no conflicts");
    } else {
        shell.AddOutputDisplayLine("Keyboard Shortcuts - " + conflictCount + " conflicts");
        var conflicts = Str.Split(registry.ShortcutConflictSummary(), "\n");
        var c = 0;
        while c < Seq.get_Count(conflicts) {
            shell.AddOutputDisplayLine("  conflict: " + Obj.ToString(Seq.Get(conflicts, c)));
            c = c + 1;
        }
    }

    var i = 0;
    while i < registry.commands.count() {
        var cmd = registry.commands.get(i);
        if cmd.shortcut != "" {
            var marker = " ";
            if registry.ShortcutHasConflict(cmd.shortcut) { marker = "!"; }
            shell.AddOutputDisplayLine(marker + " " + cmd.shortcut + "  " + cmd.label);
        }
        i = i + 1;
    }
    shell.ShowOutputPanel();
    shell.SetStatusLeft("Keyboard shortcuts");
}

func handleCopyToolSelection(shell: app_shell.AppShell) {
    if shell.CopySelectedToolRow() {
        GUI.Toast.Success("Copied selected rows");
        shell.SetStatusLeft("Copied selected tool rows");
    } else {
        GUI.Toast.Info("No tool row selected");
    }
}

func handleCopyOutputText(shell: app_shell.AppShell) {
    if shell.CopyOutputText() {
        GUI.Toast.Success("Copied output text");
        shell.SetStatusLeft("Copied full output");
    } else {
        GUI.Toast.Info("No output to copy");
    }
}

func handleClearOutput(shell: app_shell.AppShell) {
    shell.ClearOutputPanel();
    shell.SetStatusLeft("Output cleared");
}

func handleFilterOutput(shell: app_shell.AppShell) {
    var filter = GUI.MessageBox.Prompt("Filter Output", "Show output rows containing:");
    shell.SetOutputFilter(filter);
    if filter == "" {
        shell.SetStatusLeft("Output filter cleared");
    } else {
        shell.SetStatusLeft("Output filter: " + filter);
    }
}

func handleToggleOutputWrap(shell: app_shell.AppShell) {
    if shell.ToggleOutputWrap() {
        shell.SetStatusLeft("Output wrap enabled");
    } else {
        shell.SetStatusLeft("Output wrap disabled");
    }
}

func handleToggleOutputAutoScroll(shell: app_shell.AppShell) {
    if shell.ToggleOutputAutoScroll() {
        shell.SetStatusLeft("Output auto-scroll enabled");
    } else {
        shell.SetStatusLeft("Output auto-scroll locked");
    }
}

func handleRecentFiles(shell: app_shell.AppShell,
                       sessionMgr: session.SessionManager) {
    shell.BeginOutputRows();
    var count = sessionMgr.RecentFileCount();
    if count <= 0 {
        shell.AddOutputDisplayLine("Recent Files - none");
    } else {
        shell.AddOutputDisplayLine("Recent Files");
        var i = 0;
        while i < count {
            var path = sessionMgr.RecentFileAt(i);
            if path != "" {
                var item = shell.AddOutputDisplayLine("  " + Path.Name(path) + "  -  " + path);
                if item != null {
                    GUI.ListBox.ItemSetData(item, "file:" + path);
                }
            }
            i = i + 1;
        }
    }
    shell.ShowOutputPanel();
    shell.SetStatusLeft("Recent files");
}

/// @brief Toggle fullscreen window state and persist the new state.
func handleFullscreen(shell: app_shell.AppShell,
                      appSettings: settings.SettingsManager) {
    if shell.app.IsFullscreen() {
        shell.app.SetFullscreen(false);
        appSettings.fullscreen = false;
        shell.SetStatusLeft("Fullscreen disabled");
    } else {
        shell.app.SetFullscreen(true);
        appSettings.fullscreen = true;
        shell.SetStatusLeft("Fullscreen enabled");
    }
    appSettings.Save();
}

/// @brief Toggle minimap visibility; persist; return new visibility.
func handleToggleMinimap(shell: app_shell.AppShell,
                         appSettings: settings.SettingsManager) -> Boolean {
    var nowVisible = appSettings.minimapVisible == false;
    appSettings.minimapVisible = nowVisible;
    if nowVisible {
        shell.minimap.SetVisible(true);
    } else {
        shell.minimap.SetVisible(false);
    }
    appSettings.Save();
    return nowVisible;
}

/// @brief Show settings cheat sheet; prompt for new font size and path.
/// @details Three-panel UX: info dialog with current values + keyboard
///          shortcuts, then prompt for font size (validated 6..72), then
///          prompt for font path ("default" resets to OS fallback).
func handleSettings(shell: app_shell.AppShell,
                    engine: editor_engine.EditorEngine,
                    appSettings: settings.SettingsManager) {
    var fontPathDisplay = appSettings.fontPath;
    if fontPathDisplay == "" {
        fontPathDisplay = "(system default)";
    }

    var settingsInfo = "Editor settings\n\n";
    settingsInfo = settingsInfo + "Font size: " + appSettings.fontSize + " pt\n";
    settingsInfo = settingsInfo + "Font path: " + fontPathDisplay + "\n";
    settingsInfo = settingsInfo + "Theme: " + appSettings.theme + "\n";
    settingsInfo = settingsInfo + "Tab width: " + appSettings.tabWidth + "\n";
    settingsInfo = settingsInfo + "Code folding: " + appSettings.codeFolding + "\n";
    settingsInfo = settingsInfo + "Status bar: " + appSettings.statusBarVisible + "\n";
    settingsInfo = settingsInfo + "Fullscreen: " + appSettings.fullscreen + "\n";
    settingsInfo = settingsInfo + "Live diagnostics: " + appSettings.autoCheckOnSave + "\n";
    settingsInfo = settingsInfo + "\nQuick controls\n";
    settingsInfo = settingsInfo + "Ctrl+= / Ctrl+-  Zoom in or out\n";
    settingsInfo = settingsInfo + "Ctrl+0           Reset font size\n";
    settingsInfo = settingsInfo + "Ctrl+Shift+T     Toggle theme\n";
    settingsInfo = settingsInfo + "Ctrl+Shift+M     Toggle minimap\n";
    settingsInfo = settingsInfo + "F11              Toggle fullscreen\n";
    settingsInfo = settingsInfo + "F12              Go to definition\n";
    settingsInfo = settingsInfo + "F8 / Shift+F8    Next / previous error\n";
    settingsInfo = settingsInfo + "Ctrl+Shift+F     Search in project\n";
    settingsInfo = settingsInfo + "Ctrl+Shift+O     Symbol outline\n";
    settingsInfo = settingsInfo + "\nThe next two dialogs let you update the editor font size and optional font path.";
    GUI.MessageBox.Info("Settings", settingsInfo);

    var sizePrompt = "Current size: " + appSettings.fontSize + " pt\n\n";
    sizePrompt = sizePrompt + "Enter a font size from 6 to 72.\n";
    sizePrompt = sizePrompt + "Leave this blank to keep the current value.";
    var sizeText = GUI.MessageBox.Prompt("Editor Font Size", sizePrompt);
    if sizeText != "" {
        var requestedSize = Convert.ToInt64(sizeText);
        if requestedSize >= 6 and requestedSize <= 72 {
            appSettings.fontSize = requestedSize;
            applyEditorFont(engine, appSettings);
            appSettings.Save();
            shell.SetStatusLeft("Font size: " + appSettings.fontSize);
        } else {
            GUI.Toast.Warning("Font size must be between 6 and 72");
        }
    }

    var fontPrompt = "Current path: " + fontPathDisplay + "\n\n";
    fontPrompt = fontPrompt + "Enter a .ttf or .ttc file path.\n";
    fontPrompt = fontPrompt + "Enter default to go back to the system font.\n";
    fontPrompt = fontPrompt + "Leave this blank to keep the current path.";
    var fontText = GUI.MessageBox.Prompt("Editor Font Path", fontPrompt);
    if fontText == "default" {
        appSettings.fontPath = "";
        applyEditorFont(engine, appSettings);
        appSettings.Save();
        shell.SetStatusLeft("Using default editor font");
    } else if fontText != "" {
        appSettings.fontPath = fontText;
        applyEditorFont(engine, appSettings);
        appSettings.Save();
        shell.SetStatusLeft("Using custom editor font");
    }
}

/// @brief "About ViperIDE" message box.
func handleAbout() {
    GUI.MessageBox.Info("About ViperIDE",
        "ViperIDE\n\n"
        + "A lightweight IDE for Zia and Viper BASIC, built on the Viper Runtime.\n\n"
        + "Demo highlights\n"
        + "- Docked panels, toolbars, menus, and dialogs\n"
        + "- Code editor, project search, Zia diagnostics, and minimap\n"
        + "- Persistent editor settings for fonts, theme, tabs, and visibility");
}
