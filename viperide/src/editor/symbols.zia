module symbols;

bind "../editor/editor_engine";
bind "../editor/scheduler";
bind "../ui/app_shell";

bind ZiaCompletion = Viper.Zia.Completion;
bind BasicCompletion = Viper.Basic.Completion;
bind SemanticJob = Viper.Zia.SemanticJob;
bind "../editor/zia_query";
bind Viper.GUI;
bind Str = Viper.String;
bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;
bind Convert = Viper.Core.Convert;

final MAX_SEMANTIC_FOLD_LINES = 8000;
final MAX_SEMANTIC_FOLD_REGIONS = 200;

// ============================================================================
// MODULE: symbols
// PURPOSE: Document-symbol navigator. Lists every top-level symbol
//          (class / function / module-level value) of the active file
//          in a sidebar listbox. Clicking jumps to the symbol's line.
//
// WHERE-THIS-FITS: Editor controller invoked once per frame from
//          main.zia. Toggleable via the symbol-outline command. Queries
//          `Viper.Zia.Completion.SymbolsForFile` for the symbol list.
//
// KEY-DESIGN-CHOICES:
//   * REVISION + PATH CACHE. Like diagnostics, only re-queries when
//     either the editor content revision OR the active file path changes.
//     The full buffer is read only when the outline is visible and stale.
//   * RUNTIME-SYMBOL FILTER. The completion engine returns symbols from
//     dependent runtimes too (line == 0 marker). We skip those — the
//     outline should only list symbols defined IN the file the user is
//     editing.
//   * TOGGLE VISIBILITY + FORCE REFRESH. `toggle` flips visibility and
//     blanks the cache so the next update re-queries even if the
//     source matches what was cached when the panel was last hidden.
//   * NAVIGATION VIA NODE-DATA. We stash the symbol's line number on
//     each listbox item via `ItemSetData` / `ItemGetData`, so clicking
//     a row reads back the line and calls `engine.GoToLine`.
//
// HOW-TO-READ: init -> setup (creates listbox) -> setSourcePath ->
//   toggle (visibility) -> update (re-query and populate when source
//   changes) -> handleClicks (click-to-navigate).
// ============================================================================

/// @brief Sidebar listbox of the file's top-level symbols.
class SymbolOutline {
    expose GUI.ListBox symbolList;
    expose String lastSource;
    expose String sourcePath;
    expose String lastPath;
    expose Integer lastRevision;
    expose Boolean visible;
    expose Boolean enabled;
    expose Boolean isBasic;   // route to Viper.Basic.Completion (sync) instead of Zia
    expose scheduler.EditorScheduler workScheduler;
    expose Any pendingJob;
    expose Integer pendingRevision;
    expose String pendingPath;
    expose String pendingSource;
    expose Integer pendingLineOffset;
    expose Boolean semanticFoldingEnabled;
    expose String foldedPath;
    expose Integer foldedRevision;

    /// @brief Initialize hidden with empty caches.
    expose func init() {
        lastSource = "";
        sourcePath = "";
        lastPath = "";
        lastRevision = -1;
        visible = false;
        enabled = true;
        isBasic = false;
        workScheduler = null;
        pendingJob = null;
        pendingRevision = -1;
        pendingPath = "";
        pendingSource = "";
        pendingLineOffset = 0;
        semanticFoldingEnabled = false;
        foldedPath = "";
        foldedRevision = -1;
    }

    expose func SetScheduler(value: scheduler.EditorScheduler) {
        workScheduler = value;
    }

    /// @brief Construct the listbox inside `parent`. Hidden by default.
    expose func setup(parent: GUI.VBox) {
        symbolList = GUI.ListBox.New(parent);
        symbolList.SetSize(0, 200);
        symbolList.SetVisible(0);
    }

    /// @brief Set the active file's path; invalidates path cache so the
    ///        next `update` re-queries.
    expose func setSourcePath(path: String) {
        if path != sourcePath {
            sourcePath = path;
            lastPath = "";
            lastRevision = -1;
            CancelPendingJob();
        }
    }

    expose func setEnabled(value: Boolean) {
        if enabled == value {
            return;
        }
        enabled = value;
        if enabled == false {
            symbolList.SetVisible(0);
            visible = false;
            CancelPendingJob();
        }
    }

    expose func setSemanticFoldingEnabled(value: Boolean,
                                          engine: editor_engine.EditorEngine) {
        if semanticFoldingEnabled == value { return; }
        var oldValue = semanticFoldingEnabled;
        semanticFoldingEnabled = value;
        foldedPath = "";
        foldedRevision = -1;
        if engine != null and engine.editor != null {
            engine.editor.ClearFoldRegions();
        }
        if oldValue and semanticFoldingEnabled == false and visible == false {
            CancelPendingJob();
        }
    }

    /// @brief Toggle visibility. When showing, force a refresh so the
    ///        list reflects the current buffer.
    expose func toggle() {
        visible = visible == false;
        if visible {
            symbolList.SetVisible(1);
            lastSource = "";  // force refresh
            lastRevision = -1;
        } else {
            symbolList.SetVisible(0);
            if semanticFoldingEnabled == false {
                CancelPendingJob();
            }
        }
    }

    /// @brief Per-frame refresh. Re-queries `SymbolsForFile` when the
    ///        buffer revision or active path changes; otherwise no-op.
    expose func update(engine: editor_engine.EditorEngine) {
        if enabled == false { return; }
        if visible == false and semanticFoldingEnabled == false { return; }
        if engine == null or engine.editor == null { return; }

        var revision = engine.GetRevision();
        if pendingJob != null {
            if revision != pendingRevision or sourcePath != pendingPath {
                CancelPendingJob();
            } else {
                PollPendingJob(engine);
                return;
            }
        }

        if revision == lastRevision and sourcePath == lastPath {
            if semanticFoldingEnabled == false { return; }
            if revision == foldedRevision and sourcePath == foldedPath { return; }
        }

        if workScheduler != null {
            if workScheduler.IsQueued(scheduler.JOB_SYMBOLS, sourcePath, revision) == false {
                workScheduler.Queue(scheduler.JOB_SYMBOLS, sourcePath, revision, -1);
                return;
            }
            if workScheduler.IsDue(scheduler.JOB_SYMBOLS, sourcePath, revision) == false {
                return;
            }
            workScheduler.Complete(scheduler.JOB_SYMBOLS);
        }

        StartSymbolJob(engine, revision);
    }

    hide func StartSymbolJob(engine: editor_engine.EditorEngine, revision: Integer) {
        var source = engine.GetTextSnapshot();

        // BASIC: synchronous in-process symbols (raw source, no Zia module-wrap).
        if isBasic {
            CancelPendingJob();
            var braw = BasicCompletion.SymbolsForFile(source, sourcePath);
            ApplySymbols(engine, braw, 0, source, sourcePath, revision);
            return;
        }

        // Synthetic-module prefix for buffers lacking a `module` line; symbol
        // line numbers come back shifted and must be un-shifted below.
        var qsource = zia_query.WrapForQuery(source);
        var lineOff = zia_query.LineOffset(source);
        CancelPendingJob();
        var job = ZiaCompletion.BeginSymbolsForFile(qsource, sourcePath);
        if job != null {
            pendingJob = job;
            pendingRevision = revision;
            pendingPath = sourcePath;
            pendingSource = source;
            pendingLineOffset = lineOff;
            return;
        }

        var raw = ZiaCompletion.SymbolsForFile(qsource, sourcePath);
        ApplySymbols(engine, raw, lineOff, source, sourcePath, revision);
    }

    hide func PollPendingJob(engine: editor_engine.EditorEngine) -> Boolean {
        if pendingJob == null { return false; }
        if SemanticJob.IsDone(pendingJob) == false { return false; }

        var job = pendingJob;
        pendingJob = null;
        if SemanticJob.IsError(job) {
            return true;
        }
        if sourcePath != pendingPath or engine.GetRevision() != pendingRevision {
            return true;
        }
        ApplySymbols(engine, SemanticJob.Symbols(job), pendingLineOffset,
                     pendingSource, pendingPath, pendingRevision);
        return true;
    }

    hide func ApplySymbols(engine: editor_engine.EditorEngine,
                           raw: String,
                           lineOff: Integer,
                           source: String,
                           path: String,
                           revision: Integer) {
        lastSource = source;
        lastPath = path;
        lastRevision = revision;

        if semanticFoldingEnabled and engine != null {
            ApplySemanticFoldRegions(engine, raw, lineOff, source);
            foldedPath = path;
            foldedRevision = revision;
        }

        if visible == false { return; }

        symbolList.Clear();
        if raw == "" { return; }

        var lines = Str.Split(raw, "\n");
        var i = 0;
        while i < Seq.get_Length(lines) {
            var line = Obj.ToString(Seq.Get(lines, i));
            i = i + 1;
            if Str.Length(line) == 0 { continue; }

            var parts = Str.Split(line, "\t");
            if Seq.get_Length(parts) < 4 { continue; }

            var name = Obj.ToString(Seq.Get(parts, 0));
            var kind = Obj.ToString(Seq.Get(parts, 1));
            var symLine = Obj.ToString(Seq.Get(parts, 3));

            // Skip runtime symbols (line 0 = not from this file)
            if symLine == "0" { continue; }

            // Un-shift the synthetic-module prefix; drop anything that maps
            // onto (or above) the injected line.
            var symLineNum = Convert.ToInt(symLine) - lineOff;
            if symLineNum < 1 { continue; }

            var displayText = kind + "  " + name;
            var item = symbolList.AddItem(displayText);
            GUI.ListBox.ItemSetData(item, "" + symLineNum);
        }
    }

    /// @brief Per-frame click handler. If the user picked a row,
    ///        reads its line number from the item data and jumps the
    ///        editor caret/scroll there.
    expose func handleClicks(engine: editor_engine.EditorEngine) {
        if visible == false { return; }
        if symbolList.WasSelectionChanged() != 0 {
            var selItem = symbolList.Selected;
            if selItem != null {
                var lineStr = GUI.ListBox.ItemGetData(selItem);
                var lineNum = Convert.ToInt(lineStr);
                if lineNum > 0 {
                    engine.GoToLine(lineNum);
                }
            }
        }
    }

    hide func CancelPendingJob() {
        if pendingJob != null {
            SemanticJob.Cancel(pendingJob);
            pendingJob = null;
        }
    }
}

expose func ApplySemanticFoldRegions(engine: editor_engine.EditorEngine,
                                     raw: String,
                                     lineOff: Integer,
                                     source: String) -> Integer {
    if engine == null or engine.editor == null { return 0; }

    engine.editor.ClearFoldRegions();
    if raw == "" or source == "" { return 0; }

    var sourceLines = Str.Split(source, "\n");
    if Seq.get_Length(sourceLines) > MAX_SEMANTIC_FOLD_LINES {
        return 0;
    }

    var added = 0;
    var rows = Str.Split(raw, "\n");
    var i = 0;
    while i < Seq.get_Length(rows) and added < MAX_SEMANTIC_FOLD_REGIONS {
        var row = Obj.ToString(Seq.Get(rows, i));
        i = i + 1;
        if row == "" { continue; }

        var parts = Str.Split(row, "\t");
        if Seq.get_Length(parts) < 4 { continue; }

        var kind = Obj.ToString(Seq.Get(parts, 1));
        if kind != "function" and kind != "type" { continue; }

        var symLineText = Obj.ToString(Seq.Get(parts, 3));
        if symLineText == "0" { continue; }

        var startLine = Convert.ToInt(symLineText) - lineOff;
        if startLine < 1 { continue; }

        var endLine = SemanticFoldEndLineFromLines(sourceLines, startLine);
        if endLine > startLine {
            engine.editor.AddFoldRegion(startLine - 1, endLine - 1);
            added = added + 1;
        }
    }
    return added;
}

expose func SemanticFoldEndLine(source: String, startLine: Integer) -> Integer {
    var lines = Str.Split(source, "\n");
    return SemanticFoldEndLineFromLines(lines, startLine);
}

expose func SemanticFoldEndLineFromLines(lines: Any, startLine: Integer) -> Integer {
    var startIdx = startLine - 1;
    if startIdx < 0 or startIdx >= Seq.get_Length(lines) { return startLine; }

    var depth = 0;
    var seenOpen = false;
    var i = startIdx;
    while i < Seq.get_Length(lines) {
        var line = Obj.ToString(Seq.Get(lines, i));
        var pos = 1;
        while pos <= Str.Length(line) {
            var commentPos = Str.IndexOfFrom(line, pos, "//");
            var quotePos = Str.IndexOfFrom(line, pos, "\"");
            var openPos = Str.IndexOfFrom(line, pos, "{");
            var closePos = Str.IndexOfFrom(line, pos, "}");
            var nextPos = 0;
            if commentPos != 0 { nextPos = commentPos; }
            if quotePos != 0 and (nextPos == 0 or quotePos < nextPos) { nextPos = quotePos; }
            if openPos != 0 and (nextPos == 0 or openPos < nextPos) { nextPos = openPos; }
            if closePos != 0 and (nextPos == 0 or closePos < nextPos) { nextPos = closePos; }

            if nextPos == 0 {
                break;
            }
            if commentPos == nextPos {
                break;
            } else if quotePos == nextPos {
                var scan = quotePos + 1;
                var closed = false;
                while closed == false {
                    var endQuote = Str.IndexOfFrom(line, scan, "\"");
                    if endQuote == 0 {
                        pos = Str.Length(line) + 1;
                        closed = true;
                    } else if endQuote > 1 and Str.MidLen(line, endQuote - 1, 1) == "\\" {
                        scan = endQuote + 1;
                    } else {
                        pos = endQuote + 1;
                        closed = true;
                    }
                }
            } else if openPos == nextPos {
                depth = depth + 1;
                seenOpen = true;
                pos = openPos + 1;
            } else {
                if seenOpen {
                    depth = depth - 1;
                    if depth <= 0 {
                        return i + 1;
                    }
                }
                pos = closePos + 1;
            }
        }
        i = i + 1;
    }

    return startLine;
}
