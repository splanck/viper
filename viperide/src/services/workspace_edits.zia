module workspace_edits;

bind "../core/document_manager";
bind "../core/document";

bind WorkspaceEdit = Viper.Workspace.Edit;
bind File = Viper.IO.File;
bind Path = Viper.IO.Path;
bind Seq = Viper.Collections.Seq;
bind Map = Viper.Collections.Map;
bind Str = Viper.String;
bind Obj = Viper.Core.Object;

class ApplyResult {
    expose Boolean success;
    expose String message;
    expose Integer changedDocuments;

    expose func init() {
        success = false;
        message = "";
        changedDocuments = 0;
    }
}

func PreviewRenameEdits(edits: Any, maxRows: Integer) -> String {
    if edits == null {
        return "No edits returned.";
    }
    var count = Seq.get_Length(edits);
    var text = "Apply " + count + " rename edits?";
    var shown = 0;
    while shown < count and shown < maxRows {
        var edit = Seq.Get(edits, shown);
        text = text + "\n" +
               Map.GetStr(edit, "file") + ":" +
               Map.GetInt(edit, "startLine") + ":" +
               Map.GetInt(edit, "startColumn") +
               " -> " + Map.GetStr(edit, "newText");
        shown = shown + 1;
    }
    if count > maxRows {
        text = text + "\n... and " + (count - maxRows) + " more";
    }
    return text;
}

func ApplyRenameEdits(edits: Any,
                      docMgr: document_manager.DocumentManager) -> ApplyResult {
    var result = new ApplyResult();
    if edits == null {
        result.message = "No edits returned";
        return result;
    }

    var validation = ValidateRenameEdits(edits, docMgr);
    if validation != "" {
        result.message = validation;
        return result;
    }

    var closedEdits = Seq.New();
    var openPaths = Seq.New();
    var newContentByPath = Map.New();
    var i = 0;
    while i < Seq.get_Length(edits) {
        var edit = Seq.Get(edits, i);
        var path = Map.GetStr(edit, "file");
        var docIndex = docMgr.FindByPath(path);
        if docIndex >= 0 {
            if SeqContainsString(openPaths, path) == false {
                Seq.Push(openPaths, path);
                var openDoc = docMgr.documents.get(docIndex);
                Map.SetStr(newContentByPath, path, openDoc.content);
            }
        } else {
            if File.Exists(path) {
                Map.SetInt(edit, "expectedMtime", File.Modified(path));
            }
            Seq.Push(closedEdits, edit);
        }
        i = i + 1;
    }

    var j = Seq.get_Length(edits) - 1;
    while j >= 0 {
        var edit2 = Seq.Get(edits, j);
        var path2 = Map.GetStr(edit2, "file");
        var idx = docMgr.FindByPath(path2);
        if idx >= 0 {
            var current = Map.GetStr(newContentByPath, path2);
            Map.SetStr(newContentByPath, path2, ApplyEditToText(current, edit2));
        }
        j = j - 1;
    }

    if Seq.get_Length(closedEdits) > 0 {
        var editRoot = WorkspaceEditRoot(closedEdits);
        var diskValidation = WorkspaceEdit.ValidateInRoot(closedEdits, editRoot);
        if Map.GetBool(diskValidation, "success") == false {
            result.message = Map.GetStr(diskValidation, "diagnostics");
            if result.message == "" {
                result.message = "Workspace edit validation failed";
            }
            return result;
        }
        var diskResult = WorkspaceEdit.ApplyInRoot(closedEdits, editRoot);
        if Map.GetBool(diskResult, "success") == false {
            result.message = Map.GetStr(diskResult, "diagnostics");
            if result.message == "" {
                result.message = "Workspace edit failed";
            }
            return result;
        }
    }

    var p = 0;
    while p < Seq.get_Length(openPaths) {
        var openPath = Obj.ToString(Seq.Get(openPaths, p));
        var openIdx = docMgr.FindByPath(openPath);
        if openIdx >= 0 {
            var doc = docMgr.documents.get(openIdx);
            var newContent = Map.GetStr(newContentByPath, openPath);
            if newContent != doc.content {
                if openIdx != docMgr.activeIndex {
                    doc.pendingWorkspaceUndoContent = doc.content;
                    doc.pendingWorkspaceUndoLabel = "Rename";
                    doc.hasPendingWorkspaceUndo = true;
                }
                doc.content = newContent;
                doc.isModified = true;
                result.changedDocuments = result.changedDocuments + 1;
            }
        }
        p = p + 1;
    }

    result.success = true;
    result.message = "Applied edits";
    return result;
}

/// @brief Compute the narrowest existing directory that contains closed edits.
/// @details The runtime rooted workspace edit API requires a directory root.
///          Rename edits can span sibling folders, so this walks upward from the
///          first target's directory until every edit file is contained.
/// @param edits Sequence of workspace edit maps.
/// @return Absolute normalized directory path used as rooted validation/apply scope.
func WorkspaceEditRoot(edits: Any) -> String {
    if edits == null or Seq.get_Length(edits) == 0 {
        return Path.Abs(".");
    }
    var first = Seq.Get(edits, 0);
    var root = Path.Dir(Path.Norm(Path.Abs(Map.GetStr(first, "file"))));
    var i = 1;
    while i < Seq.get_Length(edits) {
        var edit = Seq.Get(edits, i);
        var editDir = Path.Dir(Path.Norm(Path.Abs(Map.GetStr(edit, "file"))));
        while root != "" and PathIsInRoot(root, editDir) == false {
            var parent = Path.Dir(root);
            if parent == "" or parent == root { break; }
            root = parent;
        }
        i = i + 1;
    }
    if root == "" { return Path.Abs("."); }
    return root;
}

/// @brief Return whether a path is equal to or nested under a root directory.
/// @param root Candidate root directory.
/// @param path Candidate child path.
/// @return True when @p path is exactly @p root or begins below it.
func PathIsInRoot(root: String,
                  path: String) -> Boolean {
    var nr = Path.Norm(Path.Abs(root));
    var np = Path.Norm(Path.Abs(path));
    if nr == np { return true; }
    if Str.EndsWith(nr, "/") or Str.EndsWith(nr, "\\") {
        return Str.StartsWith(np, nr);
    }
    return Str.StartsWith(np, nr + "/") or Str.StartsWith(np, nr + "\\");
}

func ApplyEditToDocument(doc: document.Document, edit: Any) -> Boolean {
    if CanApplyEditToText(doc.content, edit) == false {
        return false;
    }
    doc.content = ApplyEditToText(doc.content, edit);
    return true;
}

func ValidateRenameEdits(edits: Any,
                         docMgr: document_manager.DocumentManager) -> String {
    var i = 0;
    while i < Seq.get_Length(edits) {
        var edit = Seq.Get(edits, i);
        var path = Map.GetStr(edit, "file");
        if path == "" {
            return "Workspace edit has no file path";
        }
        var content = "";
        var docIndex = docMgr.FindByPath(path);
        if docIndex >= 0 {
            content = docMgr.documents.get(docIndex).content;
        } else {
            if File.Exists(path) == false {
                return "Workspace edit file not found: " + path;
            }
            content = File.ReadAllText(path);
        }
        if CanApplyEditToText(content, edit) == false {
            return "Invalid workspace edit range in " + path;
        }

        var j = i + 1;
        while j < Seq.get_Length(edits) {
            var other = Seq.Get(edits, j);
            if EditsOverlap(edit, other) {
                return RenameConflictMessage(edit, other);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return "";
}

func RenameConflictMessage(edit: Any,
                           other: Any) -> String {
    var path = Map.GetStr(edit, "file");
    var otherPath = Map.GetStr(other, "file");
    if path == "" { path = otherPath; }
    return "Overlapping workspace edits.\n"
           + "Rename was canceled before changing files.\n"
           + "File: " + path + "\n"
           + "First edit:  " + EditRange(edit) + " -> " + Map.GetStr(edit, "newText") + "\n"
           + "Second edit: " + EditRange(other) + " -> " + Map.GetStr(other, "newText");
}

func EditLocation(edit: Any) -> String {
    return Map.GetStr(edit, "file") + ":"
           + Map.GetInt(edit, "startLine") + ":" + Map.GetInt(edit, "startColumn")
           + "-" + Map.GetInt(edit, "endLine") + ":" + Map.GetInt(edit, "endColumn");
}

func EditRange(edit: Any) -> String {
    return Map.GetInt(edit, "startLine") + ":" + Map.GetInt(edit, "startColumn")
           + "-" + Map.GetInt(edit, "endLine") + ":" + Map.GetInt(edit, "endColumn");
}

func EditsOverlap(a: Any, b: Any) -> Boolean {
    if Map.GetStr(a, "file") != Map.GetStr(b, "file") {
        return false;
    }
    var aStartLine = Map.GetInt(a, "startLine");
    var aEndLine = Map.GetInt(a, "endLine");
    var bStartLine = Map.GetInt(b, "startLine");
    var bEndLine = Map.GetInt(b, "endLine");
    if aStartLine != aEndLine or bStartLine != bEndLine {
        return true;
    }
    if aStartLine != bStartLine {
        return false;
    }
    var aStart = Map.GetInt(a, "startColumn");
    var aEnd = Map.GetInt(a, "endColumn");
    var bStart = Map.GetInt(b, "startColumn");
    var bEnd = Map.GetInt(b, "endColumn");
    return aStart < bEnd and bStart < aEnd;
}

func CanApplyEditToText(content: String, edit: Any) -> Boolean {
    var startLine = Map.GetInt(edit, "startLine");
    var startCol = Map.GetInt(edit, "startColumn");
    var endLine = Map.GetInt(edit, "endLine");
    var endCol = Map.GetInt(edit, "endColumn");
    if startLine != endLine { return false; }
    if startLine < 1 or startCol < 1 or endCol < startCol { return false; }

    var lines = Str.Split(content, "\n");
    if startLine > Seq.get_Length(lines) { return false; }
    var line = Obj.ToString(Seq.Get(lines, startLine - 1));
    if startCol > Str.Length(line) + 1 { return false; }
    if endCol > Str.Length(line) + 1 { return false; }
    return true;
}

func ApplyEditToText(content: String, edit: Any) -> String {
    var startLine = Map.GetInt(edit, "startLine");
    var startCol = Map.GetInt(edit, "startColumn");
    var endCol = Map.GetInt(edit, "endColumn");
    var newText = Map.GetStr(edit, "newText");

    var lines = Str.Split(content, "\n");
    var line = Obj.ToString(Seq.Get(lines, startLine - 1));
    var prefix = "";
    if startCol > 1 {
        prefix = Str.Left(line, startCol - 1);
    }
    var suffix = "";
    if endCol <= Str.Length(line) {
        suffix = Str.Mid(line, endCol);
    }
    var replacement = prefix + newText + suffix;
    var rebuilt = "";
    var i = 0;
    while i < Seq.get_Length(lines) {
        if i > 0 {
            rebuilt = rebuilt + "\n";
        }
        if i == startLine - 1 {
            rebuilt = rebuilt + replacement;
        } else {
            rebuilt = rebuilt + Obj.ToString(Seq.Get(lines, i));
        }
        i = i + 1;
    }
    return rebuilt;
}

func SeqContainsString(items: Any, value: String) -> Boolean {
    var i = 0;
    while i < Seq.get_Length(items) {
        if Obj.ToString(Seq.Get(items, i)) == value {
            return true;
        }
        i = i + 1;
    }
    return false;
}
