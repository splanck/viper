module identifier_utils;

bind Str = Viper.String;

// ============================================================================
// MODULE: identifier_utils
// PURPOSE: Canonical identifier and keyword helpers for ViperIDE's Zia-aware
//          source transforms.
//
// WHERE-THIS-FITS: Leaf helper used by formatting, refactoring, completion
//          filtering, and command validation. It intentionally mirrors the
//          conservative ASCII identifier subset used by the current IDE helpers;
//          future Unicode identifier support should be added here first.
//
// KEY-DESIGN-CHOICES:
//   * CENTRAL KEYWORD TABLE. Refactors, rename prompts, and selection helpers
//     should agree on what names are invalid.
//   * BOUNDARY HELPERS. Search and multi-cursor commands need the same "whole
//     word" semantics as identifier-based refactors.
// ============================================================================

/// @brief Return true when a character may start a Zia identifier.
/// @param ch Single-character string.
/// @return True for ASCII letters and underscore.
expose func IsIdentStart(ch: String) -> Boolean {
    if ch >= "a" and ch <= "z" { return true; }
    if ch >= "A" and ch <= "Z" { return true; }
    if ch == "_" { return true; }
    return false;
}

/// @brief Return true when a character may continue a Zia identifier.
/// @param ch Single-character string.
/// @return True for identifier starts and ASCII digits.
expose func IsIdentPart(ch: String) -> Boolean {
    if IsIdentStart(ch) { return true; }
    if ch >= "0" and ch <= "9" { return true; }
    return false;
}

/// @brief Validate a candidate user-authored identifier.
/// @details Used before local refactors create new declarations. The check is
///          deliberately conservative: an empty string, keyword, leading digit,
///          or non-identifier character makes the name invalid.
/// @param name Candidate identifier.
/// @return True when the name is safe to emit into generated Zia source.
expose func IsValidIdentifier(name: String) -> Boolean {
    if Str.get_Length(name) == 0 { return false; }
    if IsKeyword(name) { return false; }
    var first = Str.MidLen(name, 1, 1);
    if IsIdentStart(first) == false { return false; }
    var i = 2;
    while i <= Str.get_Length(name) {
        if IsIdentPart(Str.MidLen(name, i, 1)) == false { return false; }
        i = i + 1;
    }
    return true;
}

/// @brief Return true when a match is bounded by non-identifier characters.
/// @param line Full source line containing the match.
/// @param startCol 1-based start column of the match.
/// @param len Length of the matched text.
/// @return True when the character before and after the match are not
///         identifier parts, or when the match touches the line edge.
expose func IsWordBoundaryMatch(line: String, startCol: Integer, len: Integer) -> Boolean {
    var beforeOk = true;
    var afterOk = true;
    if startCol > 1 {
        beforeOk = IsIdentPart(Str.MidLen(line, startCol - 1, 1)) == false;
    }
    var afterCol = startCol + len;
    if afterCol <= Str.get_Length(line) {
        afterOk = IsIdentPart(Str.MidLen(line, afterCol, 1)) == false;
    }
    return beforeOk and afterOk;
}

/// @brief Read an identifier starting at a 1-based character position.
/// @details The first character must be an identifier start. Reading stops at
///          the first non-identifier part.
/// @param text Source text to scan.
/// @param startPos 1-based character position where the identifier should begin.
/// @return Identifier text, or empty when no identifier starts at `startPos`.
expose func ReadIdentifierAt(text: String, startPos: Integer) -> String {
    var pos = startPos;
    var name = "";
    while pos <= Str.get_Length(text) {
        var ch = Str.MidLen(text, pos, 1);
        if name == "" {
            if IsIdentStart(ch) == false { return ""; }
        } else if IsIdentPart(ch) == false {
            break;
        }
        name = name + ch;
        pos = pos + 1;
    }
    return name;
}

/// @brief Return true for Zia reserved words known to the IDE transforms.
/// @details This table is intentionally explicit instead of data-driven so it
///          remains easy for new Zia developers to audit.
/// @param name Candidate identifier.
/// @return True when `name` is a reserved keyword.
expose func IsKeyword(name: String) -> Boolean {
    if name == "and" { return true; }
    if name == "bind" { return true; }
    if name == "break" { return true; }
    if name == "class" { return true; }
    if name == "continue" { return true; }
    if name == "else" { return true; }
    if name == "expose" { return true; }
    if name == "false" { return true; }
    if name == "final" { return true; }
    if name == "for" { return true; }
    if name == "func" { return true; }
    if name == "hide" { return true; }
    if name == "if" { return true; }
    if name == "in" { return true; }
    if name == "module" { return true; }
    if name == "new" { return true; }
    if name == "not" { return true; }
    if name == "null" { return true; }
    if name == "or" { return true; }
    if name == "return" { return true; }
    if name == "true" { return true; }
    if name == "var" { return true; }
    if name == "while" { return true; }
    return false;
}
