module formatters;

bind "../services/text_utils";
bind "source_scan";

bind Obj = Viper.Core.Object;
bind Seq = Viper.Collections.Seq;
bind Str = Viper.String;

// ============================================================================
// MODULE: formatters
// PURPOSE: Pure string-in/string-out formatters used by ViperIDE edit commands.
//
// WHERE-THIS-FITS: Refactorable source transforms below the GUI command layer.
//          Command handlers decide when to run these functions and how to show
//          status; this module only computes replacement text.
//
// KEY-DESIGN-CHOICES:
//   * CONSERVATIVE FORMATTING. The formatter adjusts indentation and trailing
//     whitespace only. It does not rewrite expressions, reorder statements, or
//     rely on compiler AST APIs.
//   * EOL PRESERVATION. Whole-document entry points preserve CRLF documents by
//     rebuilding with CRLF when the input contains CRLF.
//   * LANGUAGE ROUTING. `FormatDocumentText` and `FormatDocumentRangeText`
//     provide the small public surface command handlers need.
// ============================================================================

/// @brief Format a full document according to its IDE language tag.
/// @param language Document language (`zia`, `basic`, `text`, or `viper`).
/// @param source Full document text.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Formatted text, or empty when no formatter is available.
expose func FormatDocumentText(language: String,
                               source: String,
                               tabSize: Integer,
                               insertSpaces: Boolean) -> String {
    if language == "zia" {
        return FormatZiaText(source, tabSize, insertSpaces);
    }
    if language == "basic" {
        return FormatBasicText(source, tabSize, insertSpaces);
    }
    if language == "text" or language == "viper" {
        return TrimTrailingWhitespaceText(source);
    }
    return "";
}

/// @brief Format a document line range according to its IDE language tag.
/// @param language Document language (`zia`, `basic`, `text`, or `viper`).
/// @param source Full document text.
/// @param startLine 0-based inclusive range start.
/// @param endLine 0-based inclusive range end.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Formatted full document text, or empty when no formatter exists.
expose func FormatDocumentRangeText(language: String,
                                    source: String,
                                    startLine: Integer,
                                    endLine: Integer,
                                    tabSize: Integer,
                                    insertSpaces: Boolean) -> String {
    if language == "zia" {
        return FormatZiaRangeText(source, startLine, endLine, tabSize, insertSpaces);
    }
    if language == "basic" {
        return FormatBasicRangeText(source, startLine, endLine, tabSize, insertSpaces);
    }
    if language == "text" or language == "viper" {
        return TrimTrailingWhitespaceRangeText(source, startLine, endLine);
    }
    return "";
}

/// @brief Remove trailing spaces/tabs from every line.
/// @param source Full document text.
/// @return Document text with original newline style and no trailing whitespace.
expose func TrimTrailingWhitespaceText(source: String) -> String {
    if source == "" { return ""; }
    var eol = "\n";
    if Str.IndexOf(source, "\r\n") != 0 { eol = "\r\n"; }
    var lines = Str.Lines(source);
    var result = "";
    var i = 0;
    while i < Seq.get_Length(lines) {
        var line = Obj.ToString(Seq.Get(lines, i));
        line = text_utils.TrimLineRightWhitespace(line);
        if i > 0 { result = result + eol; }
        result = result + line;
        i = i + 1;
    }
    return result;
}

/// @brief Format a full Zia document.
/// @param source Full document text.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Re-indented Zia text.
expose func FormatZiaText(source: String,
                          tabSize: Integer,
                          insertSpaces: Boolean) -> String {
    var lines = Str.Lines(source);
    return FormatZiaRangeText(source, 0, Seq.get_Length(lines) - 1, tabSize, insertSpaces);
}

/// @brief Format a 0-based inclusive line range in a Zia document.
/// @details Brace indentation carries in from lines before the range, and
///          continuation indentation considers open `(`/`[` depth and leading
///          dot chains. Lines inside block comments are preserved verbatim.
/// @param source Full document text.
/// @param startLine 0-based inclusive range start.
/// @param endLine 0-based inclusive range end.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Full document text with only the requested range reformatted.
expose func FormatZiaRangeText(source: String,
                               startLine: Integer,
                               endLine: Integer,
                               tabSize: Integer,
                               insertSpaces: Boolean) -> String {
    var lines = Str.Lines(source);
    var count = Seq.get_Length(lines);
    if count == 0 { return source; }
    var rangeStart = startLine;
    var rangeEnd = endLine;
    if rangeStart < 0 { rangeStart = 0; }
    if rangeEnd >= count { rangeEnd = count - 1; }
    if rangeEnd < rangeStart { return source; }

    var indentLevel = ZiaIndentBeforeLine(lines, rangeStart);
    var commentDepth = source_scan.ZiaCommentDepthBeforeLine(lines, rangeStart);
    var parenDepth = source_scan.ZiaParenDepthBeforeLine(lines, rangeStart);
    var output = new List();
    var i = 0;
    while i < count {
        var line = Obj.ToString(Seq.Get(lines, i));
        if i >= rangeStart and i <= rangeEnd {
            if commentDepth > 0 {
                output.add(line);
            } else {
                var cont = source_scan.ZiaContinuationIndent(line, parenDepth);
                output.add(FormatZiaLine(line, indentLevel + cont, tabSize, insertSpaces));
            }
            indentLevel = indentLevel + source_scan.ZiaBraceDelta(line, commentDepth);
            if indentLevel < 0 { indentLevel = 0; }
            parenDepth = parenDepth + source_scan.ZiaParenDelta(line, commentDepth);
            if parenDepth < 0 { parenDepth = 0; }
            commentDepth = source_scan.ZiaCommentDepthAfter(line, commentDepth);
        } else {
            output.add(line);
        }
        i = i + 1;
    }

    var eol = "\n";
    if Str.IndexOf(source, "\r\n") != 0 { eol = "\r\n"; }
    return text_utils.JoinStringList(output, eol);
}

/// @brief Format a full Viper BASIC document.
/// @param source Full document text.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Re-indented BASIC text.
expose func FormatBasicText(source: String,
                            tabSize: Integer,
                            insertSpaces: Boolean) -> String {
    var lines = Str.Lines(source);
    return FormatBasicRangeText(source, 0, Seq.get_Length(lines) - 1, tabSize, insertSpaces);
}

/// @brief Format a 0-based inclusive line range in a BASIC document.
/// @details BASIC indentation is keyword-driven. Block openers increase the
///          next line's indent, closers decrease it, and `ELSE`/`ELSEIF` align
///          with their matching `IF` while preserving body indentation.
/// @param source Full document text.
/// @param startLine 0-based inclusive range start.
/// @param endLine 0-based inclusive range end.
/// @param tabSize Tab width used when spaces are requested.
/// @param insertSpaces True to indent with spaces, false to indent with tabs.
/// @return Full document text with only the requested range reformatted.
expose func FormatBasicRangeText(source: String,
                                 startLine: Integer,
                                 endLine: Integer,
                                 tabSize: Integer,
                                 insertSpaces: Boolean) -> String {
    var lines = Str.Lines(source);
    var count = Seq.get_Length(lines);
    if count == 0 { return source; }
    var rangeStart = startLine;
    var rangeEnd = endLine;
    if rangeStart < 0 { rangeStart = 0; }
    if rangeEnd >= count { rangeEnd = count - 1; }
    if rangeEnd < rangeStart { return source; }

    var indentLevel = BasicIndentBeforeLine(lines, rangeStart);
    var output = new List();
    var i = 0;
    while i < count {
        var line = Obj.ToString(Seq.Get(lines, i));
        if i >= rangeStart and i <= rangeEnd {
            output.add(FormatBasicLine(line, indentLevel, tabSize, insertSpaces));
            indentLevel = indentLevel + BasicLineDelta(line);
            if indentLevel < 0 { indentLevel = 0; }
        } else {
            output.add(line);
        }
        i = i + 1;
    }

    var eol = "\n";
    if Str.IndexOf(source, "\r\n") != 0 { eol = "\r\n"; }
    return text_utils.JoinStringList(output, eol);
}

/// @brief Remove trailing spaces and tabs from a bounded line range.
/// @param source Full document text.
/// @param startLine Zero-based first line to trim.
/// @param endLine Zero-based last line to trim.
/// @return Document text with only the requested range right-trimmed.
/// @details Carriage returns are preserved per line so CRLF documents remain
///          CRLF-compatible after the range edit.
func TrimTrailingWhitespaceRangeText(source: String,
                                     startLine: Integer,
                                     endLine: Integer) -> String {
    var lines = Str.Split(source, "\n");
    var count = Seq.get_Length(lines);
    if count == 0 { return source; }
    var rangeStart = startLine;
    var rangeEnd = endLine;
    if rangeStart < 0 { rangeStart = 0; }
    if rangeEnd >= count { rangeEnd = count - 1; }
    if rangeEnd < rangeStart { return source; }

    var output = new List();
    var i = 0;
    while i < count {
        var line = Obj.ToString(Seq.Get(lines, i));
        var hadCr = false;
        if Str.EndsWith(line, "\r") {
            hadCr = true;
            line = Str.Left(line, Str.get_Length(line) - 1);
        }
        if i >= rangeStart and i <= rangeEnd {
            line = text_utils.TrimLineRightWhitespace(line);
        }
        if hadCr { line = line + "\r"; }
        output.add(line);
        i = i + 1;
    }
    return text_utils.JoinStringList(output, "\n");
}

/// @brief Format one Zia line at a known indentation level.
/// @param line Raw line text without its newline.
/// @param indentLevel Structural indentation before this line.
/// @param tabSize Number of spaces used for one indentation level.
/// @param insertSpaces True to indent with spaces; false to indent with tabs.
/// @return Formatted line text.
func FormatZiaLine(line: String,
                   indentLevel: Integer,
                   tabSize: Integer,
                   insertSpaces: Boolean) -> String {
    var trimmed = Str.Trim(line);
    if trimmed == "" { return ""; }

    var outIndent = indentLevel - LeadingCloseBraceCount(trimmed);
    if outIndent < 0 { outIndent = 0; }
    return IndentText(outIndent, tabSize, insertSpaces) + trimmed;
}

/// @brief Compute structural Zia indentation before a target line.
/// @param lines Sequence of source lines.
/// @param targetLine Zero-based line index where formatting starts.
/// @return Brace-based indentation level before targetLine.
/// @details Block-comment depth is carried while scanning so braces inside
///          comments do not affect indentation.
func ZiaIndentBeforeLine(lines: Any,
                         targetLine: Integer) -> Integer {
    var indent = 0;
    var depth = 0;
    var i = 0;
    while i < targetLine and i < Seq.get_Length(lines) {
        var line = text_utils.StripTrailingCr(Obj.ToString(Seq.Get(lines, i)));
        indent = indent + source_scan.ZiaBraceDelta(line, depth);
        if indent < 0 { indent = 0; }
        depth = source_scan.ZiaCommentDepthAfter(line, depth);
        i = i + 1;
    }
    return indent;
}

/// @brief Count leading `}` braces that should outdent the current Zia line.
/// @param trimmed Line text with surrounding whitespace removed.
/// @return Number of leading close braces.
func LeadingCloseBraceCount(trimmed: String) -> Integer {
    var count = 0;
    var i = 1;
    while i <= Str.get_Length(trimmed) and Str.MidLen(trimmed, i, 1) == "}" {
        count = count + 1;
        i = i + 1;
    }
    return count;
}

/// @brief Format one BASIC line at a known indentation level.
/// @param line Raw line text without its newline.
/// @param indentLevel Structural indentation before this line.
/// @param tabSize Number of spaces used for one indentation level.
/// @param insertSpaces True to indent with spaces; false to indent with tabs.
/// @return Formatted line text.
func FormatBasicLine(line: String,
                     indentLevel: Integer,
                     tabSize: Integer,
                     insertSpaces: Boolean) -> String {
    var trimmed = Str.Trim(line);
    if trimmed == "" { return ""; }
    var outIndent = indentLevel - BasicLineDedent(trimmed);
    if outIndent < 0 { outIndent = 0; }
    return IndentText(outIndent, tabSize, insertSpaces) + trimmed;
}

/// @brief Compute BASIC indentation before a target line.
/// @param lines Sequence of source lines.
/// @param targetLine Zero-based line index where formatting starts.
/// @return Keyword-based indentation level before targetLine.
func BasicIndentBeforeLine(lines: Any,
                           targetLine: Integer) -> Integer {
    var indent = 0;
    var i = 0;
    while i < targetLine and i < Seq.get_Length(lines) {
        var line = text_utils.StripTrailingCr(Obj.ToString(Seq.Get(lines, i)));
        indent = indent + BasicLineDelta(line);
        if indent < 0 { indent = 0; }
        i = i + 1;
    }
    return indent;
}

/// @brief Return the first BASIC keyword/token on a trimmed line.
/// @param trimmed Line text with surrounding whitespace removed.
/// @return Uppercase first word, or empty when none exists.
func BasicFirstWord(trimmed: String) -> String {
    var n = Str.get_Length(trimmed);
    var i = 1;
    while i <= n and (Str.MidLen(trimmed, i, 1) == " " or Str.MidLen(trimmed, i, 1) == "\t") {
        i = i + 1;
    }
    var start = i;
    while i <= n and Str.MidLen(trimmed, i, 1) != " " and Str.MidLen(trimmed, i, 1) != "\t" {
        i = i + 1;
    }
    if i <= start { return ""; }
    return Str.ToUpper(Str.MidLen(trimmed, start, i - start));
}

/// @brief Return the second BASIC keyword/token on a trimmed line.
/// @param trimmed Line text with surrounding whitespace removed.
/// @return Uppercase second word, or empty when none exists.
func BasicSecondWord(trimmed: String) -> String {
    var n = Str.get_Length(trimmed);
    var i = 1;
    while i <= n and Str.MidLen(trimmed, i, 1) != " " and Str.MidLen(trimmed, i, 1) != "\t" {
        i = i + 1;
    }
    while i <= n and (Str.MidLen(trimmed, i, 1) == " " or Str.MidLen(trimmed, i, 1) == "\t") {
        i = i + 1;
    }
    var start = i;
    while i <= n and Str.MidLen(trimmed, i, 1) != " " and Str.MidLen(trimmed, i, 1) != "\t" {
        i = i + 1;
    }
    if i <= start { return ""; }
    return Str.ToUpper(Str.MidLen(trimmed, start, i - start));
}

/// @brief Strip a BASIC apostrophe comment while preserving string content.
/// @param line Source line to scan.
/// @return Code portion before the first comment apostrophe outside strings.
func BasicCodeOnly(line: String) -> String {
    var inString = false;
    var n = Str.get_Length(line);
    var i = 1;
    while i <= n {
        var ch = Str.MidLen(line, i, 1);
        if inString {
            if ch == "\"" { inString = false; }
        } else {
            if ch == "\"" {
                inString = true;
            } else if ch == "'" {
                return Str.Left(line, i - 1);
            }
        }
        i = i + 1;
    }
    return line;
}

/// @brief Return whether a BASIC line opens an IF block through THEN.
/// @param trimmed Line text with surrounding whitespace removed.
/// @return True when the code-only line ends with `THEN`.
func BasicEndsWithThen(trimmed: String) -> Boolean {
    var up = Str.ToUpper(Str.Trim(BasicCodeOnly(trimmed)));
    if up == "THEN" { return true; }
    return Str.EndsWith(up, " THEN");
}

/// @brief Return the indentation decrease that applies before a BASIC line.
/// @param trimmed Line text with surrounding whitespace removed.
/// @return Usually 0 or 1 indentation level.
func BasicLineDedent(trimmed: String) -> Integer {
    var w = BasicFirstWord(trimmed);
    if w == "NEXT" or w == "WEND" or w == "LOOP" or w == "ENDIF"
       or w == "ELSE" or w == "ELSEIF" {
        return 1;
    }
    if w == "END" {
        var s = BasicSecondWord(trimmed);
        if s == "IF" or s == "SUB" or s == "FUNCTION" or s == "SELECT"
           or s == "WHILE" or s == "TYPE" {
            return 1;
        }
    }
    return 0;
}

/// @brief Return the indentation delta contributed after a BASIC line.
/// @param line Raw BASIC line.
/// @return -1, 0, or 1 for the next line's indentation.
/// @details The formatter models common block keywords rather than attempting
///          full BASIC parsing; this keeps formatting predictable and cheap.
func BasicLineDelta(line: String) -> Integer {
    var trimmed = Str.Trim(line);
    if trimmed == "" { return 0; }
    var w = BasicFirstWord(trimmed);

    if w == "NEXT" or w == "WEND" or w == "LOOP" or w == "ENDIF" {
        return -1;
    }
    if w == "END" {
        var s = BasicSecondWord(trimmed);
        if s == "IF" or s == "SUB" or s == "FUNCTION" or s == "SELECT"
           or s == "WHILE" or s == "TYPE" {
            return -1;
        }
        return 0;
    }
    if w == "ELSE" or w == "ELSEIF" {
        return 0;
    }
    if w == "FOR" or w == "WHILE" or w == "DO" or w == "SUB"
       or w == "FUNCTION" or w == "SELECT" or w == "TYPE" {
        return 1;
    }
    if w == "IF" {
        if BasicEndsWithThen(trimmed) { return 1; }
        return 0;
    }
    return 0;
}

/// @brief Build the leading indentation string for a formatted line.
/// @param level Number of indentation levels.
/// @param tabSize Number of spaces in one indentation level.
/// @param insertSpaces True to emit spaces; false to emit tab characters.
/// @return Indentation prefix.
func IndentText(level: Integer,
                tabSize: Integer,
                insertSpaces: Boolean) -> String {
    if level <= 0 { return ""; }
    var width = tabSize;
    if width < 1 { width = 4; }

    var unit = "\t";
    if insertSpaces {
        unit = "";
        var s = 0;
        while s < width {
            unit = unit + " ";
            s = s + 1;
        }
    }

    var text = "";
    var i = 0;
    while i < level {
        text = text + unit;
        i = i + 1;
    }
    return text;
}
