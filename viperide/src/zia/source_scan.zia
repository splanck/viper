module source_scan;

bind "call_scan";
bind "delimiter_scan";
bind "function_scan";
bind "occurrence_scan";
bind "trivia_scan";

// ============================================================================
// MODULE: source_scan
// PURPOSE: Compatibility facade for lightweight Zia source-analysis helpers.
//
// WHERE-THIS-FITS: Older callers import source_scan directly. The actual
//          implementation now lives in focused modules:
//          function_scan, trivia_scan, call_scan, delimiter_scan, and
//          occurrence_scan. Keeping this facade preserves the public surface
//          while making each scanner easier to read and teach.
//
// TEACHING-NOTE: New code should import the focused module that owns the
//          concept it needs. Use this facade only when preserving an existing
//          dependency is more valuable than adding a new direct bind.
// ============================================================================

/// @brief Return one 1-based source line.
/// @param source Whole document text.
/// @param lineNumber 1-based line number.
/// @return The requested line or empty when out of range.
expose func SourceLine(source: String,
                       lineNumber: Integer) -> String {
    return function_scan.SourceLine(source, lineNumber);
}

/// @brief Find the nearest function declaration at or above a line.
/// @param source Whole Zia document.
/// @param lineNumber 1-based line near the cursor/selection.
/// @return 1-based start line of the enclosing function, or 0 when none exists.
expose func EnclosingZiaFunctionStartLine(source: String,
                                          lineNumber: Integer) -> Integer {
    return function_scan.EnclosingZiaFunctionStartLine(source, lineNumber);
}

/// @brief Find the enclosing function name for a source line.
/// @param source Whole Zia document.
/// @param lineNumber 1-based line inside or below a function declaration.
/// @return Function name, or empty when no enclosing function is found.
expose func EnclosingZiaFunctionName(source: String,
                                     lineNumber: Integer) -> String {
    return function_scan.EnclosingZiaFunctionName(source, lineNumber);
}

/// @brief Extract a function name from a declaration line.
/// @param line Source line to inspect.
/// @return Function name, or empty when the line is not a recognized declaration.
expose func ZiaFunctionNameFromLine(line: String) -> String {
    return function_scan.ZiaFunctionNameFromLine(line);
}

/// @brief Find the matching closing line for a function body.
/// @param source Whole Zia document.
/// @param startLine 1-based function declaration line.
/// @return 1-based line where the function body closes, or `startLine` when
///         no close can be found.
expose func ZiaFunctionEndLine(source: String,
                               startLine: Integer) -> Integer {
    return function_scan.ZiaFunctionEndLine(source, startLine);
}

/// @brief Collect simple call tokens in a line range.
/// @param source Whole Zia document.
/// @param startLine 1-based inclusive start line.
/// @param endLine 1-based inclusive end line.
/// @return Sequence of maps with `name`, `line`, and 0-based `column` fields.
expose func OutgoingZiaCallTokens(source: String,
                                  startLine: Integer,
                                  endLine: Integer) -> Any {
    return call_scan.OutgoingZiaCallTokens(source, startLine, endLine);
}

/// @brief Net brace delta for a line outside trivia.
/// @param line Source line.
/// @param commentDepth Open block-comment depth before this line.
/// @return Net brace delta visible to indentation/structure scanners.
expose func ZiaBraceDelta(line: String, commentDepth: Integer) -> Integer {
    return trivia_scan.ZiaBraceDelta(line, commentDepth);
}

/// @brief Open block-comment depth at the end of a line.
/// @param line Source line.
/// @param commentDepth Open block-comment depth before this line.
/// @return Block-comment depth after scanning the line.
expose func ZiaCommentDepthAfter(line: String, commentDepth: Integer) -> Integer {
    return trivia_scan.ZiaCommentDepthAfter(line, commentDepth);
}

/// @brief Open block-comment depth at the start of a target line.
/// @param lines Sequence returned by `Str.Split(source, "\n")`.
/// @param targetLine Zero-based target line index.
/// @return Block-comment depth before `targetLine`.
expose func ZiaCommentDepthBeforeLine(lines: Any,
                                      targetLine: Integer) -> Integer {
    return trivia_scan.ZiaCommentDepthBeforeLine(lines, targetLine);
}

/// @brief Net `(`/`[` nesting delta for a line outside trivia.
/// @param line Source line.
/// @param commentDepth Open block-comment depth before this line.
/// @return Net parenthesis/bracket depth change visible outside trivia.
expose func ZiaParenDelta(line: String, commentDepth: Integer) -> Integer {
    return trivia_scan.ZiaParenDelta(line, commentDepth);
}

/// @brief Open `(`/`[` depth at the start of a target line.
/// @param lines Sequence returned by `Str.Split(source, "\n")`.
/// @param targetLine Zero-based target line index.
/// @return Parenthesis/bracket depth before `targetLine`.
expose func ZiaParenDepthBeforeLine(lines: Any,
                                    targetLine: Integer) -> Integer {
    return trivia_scan.ZiaParenDepthBeforeLine(lines, targetLine);
}

/// @brief Extra continuation indent for a line.
/// @param line Source line.
/// @param parenDepthBefore Parenthesis/bracket depth before the line.
/// @return 1 for hanging continuation lines, else 0.
expose func ZiaContinuationIndent(line: String,
                                  parenDepthBefore: Integer) -> Integer {
    return trivia_scan.ZiaContinuationIndent(line, parenDepthBefore);
}

/// @brief Replace identifier occurrences outside strings and line comments.
/// @param line Source line.
/// @param name Identifier to replace.
/// @param replacement Replacement text.
/// @return Rebuilt line with matching identifier tokens replaced.
expose func ReplaceIdentifierOutsideTrivia(line: String,
                                           name: String,
                                           replacement: String) -> String {
    return trivia_scan.ReplaceIdentifierOutsideTrivia(line, name, replacement);
}

/// @brief Find the open inline delimiter enclosing a column.
/// @param line Source line.
/// @param startCol Zero-based column inside the expression.
/// @return Zero-based open delimiter column, or -1 when none is found.
expose func EnclosingInlineDelimiterOpenCol(line: String,
                                            startCol: Integer) -> Integer {
    return delimiter_scan.EnclosingInlineDelimiterOpenCol(line, startCol);
}

/// @brief Find the close delimiter matching an inline open delimiter.
/// @param line Source line.
/// @param openCol Zero-based column containing `(` or `[`.
/// @return Zero-based close delimiter column, or -1 when no match is found.
expose func MatchingInlineDelimiterCloseCol(line: String,
                                            openCol: Integer) -> Integer {
    return delimiter_scan.MatchingInlineDelimiterCloseCol(line, openCol);
}

/// @brief Find the open brace line enclosing a line.
/// @param source Whole Zia document.
/// @param lineIdx Zero-based line index near the cursor.
/// @return Zero-based line containing the open brace, or -1.
expose func EnclosingBraceOpenLine(source: String,
                                   lineIdx: Integer) -> Integer {
    return delimiter_scan.EnclosingBraceOpenLine(source, lineIdx);
}

/// @brief Find the close brace line matching an open brace line.
/// @param source Whole Zia document.
/// @param openLine Zero-based line containing an open brace.
/// @return Zero-based close brace line, or -1.
expose func MatchingBraceCloseLine(source: String,
                                   openLine: Integer) -> Integer {
    return delimiter_scan.MatchingBraceCloseLine(source, openLine);
}

/// @brief Return the first whole-word occurrence at or after a position.
/// @param source Whole document text.
/// @param word Identifier-like text to find.
/// @param startLine 1-based start line.
/// @param startCol 1-based start column for the first line.
/// @return `"line:column"` using 1-based coordinates, or empty when not found.
expose func FindNextOccurrence(source: String,
                               word: String,
                               startLine: Integer,
                               startCol: Integer) -> String {
    return occurrence_scan.FindNextOccurrence(source, word, startLine, startCol);
}

/// @brief Skip spaces and tabs from a 1-based position.
/// @param line Source line.
/// @param pos 1-based starting position.
/// @return First non-whitespace position, or one past end.
expose func SkipWhitespace(line: String,
                           pos: Integer) -> Integer {
    return trivia_scan.SkipWhitespace(line, pos);
}
