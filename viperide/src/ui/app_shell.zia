module app_shell;

bind "../commands/command_registry";
bind "../editor/language_service";
bind "../ui/status_bar_model";
bind "../ui/tool_panel_model";
bind "../ui/tool_panel_text";

bind Viper.GUI as GUI;
bind Viper.Collections.Seq as Seq;
bind Obj = Viper.Core.Object;
bind Str = Viper.String;

final TOOL_COLOR_ERROR = 14707829;   // 0xE06C75
final TOOL_COLOR_WARNING = 15911349; // 0xF2C76D
final TOOL_COLOR_INFO = 6662382;     // 0x65A5EE
final TOOL_COLOR_SUCCESS = 10264905; // 0x9CD67D
final TOOL_COLOR_MUTED = 10066329;   // 0x999999
final TOOL_KIND_COL = 10;
final TOOL_SOURCE_COL = 10;
final TOOL_LOCATION_COL = 24;
final TOOL_CODE_COL = 10;
final TOOL_ACTION_COL = 18;
final MAX_BUILD_OUTPUT_CACHE_CHARS = 250000;
final MAX_OUTPUT_ROW_COUNT = 5000;
final OUTPUT_CACHE_TRUNCATED_PREFIX = "[output truncated]\n";
final OUTPUT_ROWS_TRUNCATED_MARKER = "[older output rows hidden]";

// ============================================================================
// MODULE: app_shell
// PURPOSE: Top-level UI layout for ViperIDE. Owns the GUI.App window and
//          every widget that lives in the persistent chrome (menu bar,
//          toolbar, sidebar, tab bar, breadcrumb, find bar, editor row,
//          minimap, docked preferences panel, diagnostics panel, build-output
//          panel, status bar, context menu, command palette).
//
// WHERE-THIS-FITS: Constructed once by main.zia. The main loop polls
//          this shell each frame for input events; command handlers in
//          commands/* receive a reference to it so they can update any
//          surface.
//
// KEY-DESIGN-CHOICES:
//   * EVERY WIDGET IS expose. The main loop needs to poll menu items,
//     toolbar buttons, etc. for click events. Rather than hide the
//     widgets and expose a callback API, we expose the handles and let
//     the loop pull state. This trades encapsulation for testability —
//     the loop is one big readable dispatcher.
//   * VBox(menu / toolbar / split / status). Main vertical layout with
//     a SplitPane filling the middle. The SplitPane is horizontal (1)
//     with the sidebar on the left and the editor area on the right.
//   * WORKBENCH ROW IS HBOX. The editor area and the preferences side panel
//     sit beside each other, so Preferences resizes the editor instead of
//     floating over it. Inside the editor area, `editorRow` still holds the
//     editor + minimap.
//   * KEYBOARD SHORTCUTS WIRED INTO MENU ITEMS. Every menu item with a
//     shortcut calls `SetShortcut(...)` so the runtime can dispatch
//     accelerators to that menu item without the IDE needing to
//     intercept raw key events.
//   * THEME APPLIED IN BUILD. SetDark() is the default; settings.Load()
//     later flips to light if needed.
//
// HOW-TO-READ: Field declarations (a panorama of every widget) ->
//   init -> Build (the giant constructor — read top-to-bottom for the
//   layout) -> ShouldClose / Poll / Render / Destroy (lifecycle) ->
//   SetStatusLeft / SetStatusCenter / SetStatusRight / SetBreadcrumbPath
//   (status helpers) -> SetBuildOutput / ToggleSidebar / CenterAndSize.
// ============================================================================

/// @brief Owns the IDE's window and every persistent widget in it.
class AppShell {
    // Application
    expose GUI.App app;

    // Layout containers
    expose GUI.VBox mainVBox;
    expose GUI.SplitPane splitPane;
    expose GUI.HBox workbenchRow;
    expose GUI.VBox editorArea;
    expose GUI.HBox editorRow;         // horizontal: editor (flex) + minimap
    expose GUI.VBox preferencesPanel;  // right-side dock for Preferences

    // Menu bar + menus
    expose GUI.MenuBar menuBar;
    expose GUI.Menu fileMenu;
    expose GUI.Menu editMenu;
    expose GUI.Menu navigateMenu;
    expose GUI.Menu viewMenu;
    expose GUI.Menu helpMenu;

    // File menu items
    expose GUI.MenuItem miNew;
    expose GUI.MenuItem miOpen;
    expose GUI.MenuItem miOpenFolder;
    expose GUI.MenuItem miQuickOpen;
    expose GUI.MenuItem miSave;
    expose GUI.MenuItem miSaveAs;
    expose GUI.MenuItem miSaveAll;
    expose GUI.MenuItem miClose;
    expose GUI.MenuItem miReload;      // Reload File from disk
    expose GUI.MenuItem miRecentFiles;
    expose GUI.MenuItem miReopenClosed;
    expose GUI.MenuItem miExit;

    // Edit menu items
    expose GUI.MenuItem miUndo;
    expose GUI.MenuItem miRedo;
    expose GUI.MenuItem miCut;
    expose GUI.MenuItem miCopy;
    expose GUI.MenuItem miPaste;
    expose GUI.MenuItem miSelectAll;
    expose GUI.MenuItem miFind;
    expose GUI.MenuItem miSearchProject;
    expose GUI.MenuItem miGoToLine;

    // Navigate menu items
    expose GUI.MenuItem miGoToDefinition;
    expose GUI.MenuItem miFindReferences;
    expose GUI.MenuItem miIncomingCalls;
    expose GUI.MenuItem miOutgoingCalls;
    expose GUI.MenuItem miWorkspaceSymbols;
    expose GUI.MenuItem miSymbolOutline;
    expose GUI.MenuItem miNextError;
    expose GUI.MenuItem miPreviousError;
    expose GUI.MenuItem miSignatureHelp;
    expose GUI.MenuItem miRenameSymbol;
    expose GUI.MenuItem miPreferences;

    // View menu items
    expose GUI.MenuItem miToggleSidebar;
    expose GUI.MenuItem miToggleStatusBar;
    expose GUI.MenuItem miZoomIn;
    expose GUI.MenuItem miZoomOut;
    expose GUI.MenuItem miZoomReset;
    expose GUI.MenuItem miUiZoomIn;
    expose GUI.MenuItem miUiZoomOut;
    expose GUI.MenuItem miUiZoomReset;
    expose GUI.MenuItem miToggleTheme;
    expose GUI.MenuItem miFullscreen;
    expose GUI.MenuItem miToggleMinimap;
    expose GUI.MenuItem miTerminal;

    // Build menu
    expose GUI.Menu buildMenu;
    expose GUI.MenuItem miBuild;
    expose GUI.MenuItem miBuildAndRun;
    expose GUI.MenuItem miRun;
    expose GUI.MenuItem miStop;
    expose GUI.MenuItem miDebugStart;
    expose GUI.MenuItem miDebugContinue;
    expose GUI.MenuItem miDebugStepOver;
    expose GUI.MenuItem miDebugStepIn;
    expose GUI.MenuItem miDebugStepOut;
    expose GUI.MenuItem miDebugPause;
    expose GUI.MenuItem miDebugRestart;
    expose GUI.MenuItem miDebugStop;
    expose GUI.MenuItem miToggleBreakpoint;

    // Help menu
    expose GUI.MenuItem miKeyboardShortcuts;
    expose GUI.MenuItem miAbout;

    // Toolbar + items
    expose GUI.Toolbar toolbar;
    expose GUI.ToolbarItem tbNew;
    expose GUI.ToolbarItem tbOpen;
    expose GUI.ToolbarItem tbSave;
    expose GUI.ToolbarItem tbSaveAll;
    expose GUI.ToolbarItem tbBuild;
    expose GUI.ToolbarItem tbRun;
    expose GUI.ToolbarItem tbStop;
    expose GUI.ToolbarItem tbDebug;
    expose GUI.ToolbarItem tbDebugContinue;
    expose GUI.ToolbarItem tbDebugStep;
    expose GUI.ToolbarItem tbFind;

    // Tab bar
    expose GUI.TabBar tabBar;

    // Breadcrumb (file path, below tab bar)
    expose GUI.Breadcrumb breadcrumb;

    // Sidebar
    expose GUI.TreeView sidebarTree;

    // Activity bar (vertical view switcher, left edge) + swappable left view stack
    expose GUI.Toolbar activityBar;
    expose GUI.ToolbarItem abExplorer;
    expose GUI.ToolbarItem abSourceControl;
    expose GUI.VBox leftViewStack;
    expose GUI.VBox explorerView;
    expose GUI.VBox scmViewHost;

    // Find bar (hidden by default; shown by Ctrl+F)
    expose GUI.FindBar findBar;

    // Minimap (right of editor; bound to editor after engine.Setup in main.zia)
    expose GUI.Minimap minimap;

    // Diagnostics panel (below editor; populated after build)
    expose GUI.ListBox diagListBox;

    // Build output surfaces (OutputPane for raw streams, ListBox for row tools)
    expose GUI.OutputPane outputPane;
    expose GUI.ListBox outputListBox;
    expose GUI.VirtualList outputVirtualList;
    expose List outputRenderedItems;
    expose Integer outputRenderedRowCount;
    expose GUI.ListBox searchListBox;
    expose GUI.ListBox referencesListBox;
    expose GUI.ListBox debugListBox;
    expose GUI.ListBox variablesListBox; // debug: locals at the current stop
    expose GUI.ListBox callStackListBox; // debug: call frames at the current stop

    // Integrated terminal (Phase 5E): panel + interactive PTY output pane + controls.
    expose GUI.VBox terminalPanel;
    expose GUI.OutputPane terminalPane;
    expose GUI.Button terminalKill;
    expose GUI.Button terminalRestart;

    // Bottom tool surface tabs
    expose GUI.TabBar toolTabBar;
    expose GUI.Tab toolProblemsTab;
    expose GUI.Tab toolOutputTab;
    expose GUI.Tab toolSearchTab;
    expose GUI.Tab toolReferencesTab;
    expose GUI.Tab toolDebugTab;
    expose GUI.Tab toolTerminalTab;
    expose GUI.Tab toolVariablesTab;
    expose GUI.Tab toolCallStackTab;

    // Context menu for the file tree
    expose GUI.ContextMenu treeContextMenu;
    expose GUI.MenuItem ctxOpen;
    expose GUI.MenuItem ctxOpenText;
    expose GUI.MenuItem ctxReveal;
    expose GUI.MenuItem ctxCopyPath;
    expose GUI.MenuItem ctxCopyRelativePath;
    expose GUI.MenuItem ctxDuplicate;
    expose GUI.MenuItem ctxRename;
    expose GUI.MenuItem ctxDelete;
    expose GUI.MenuItem ctxNewFile;
    expose GUI.MenuItem ctxNewFolder;
    expose GUI.MenuItem ctxSearchFolder;
    expose GUI.MenuItem ctxRunFile;
    expose GUI.MenuItem ctxSetEntry;
    expose GUI.MenuItem ctxRefresh;

    // Editor context menu (right-click inside the code editor surface).
    expose GUI.ContextMenu editorContextMenu;
    expose GUI.MenuItem ecCut;
    expose GUI.MenuItem ecCopy;
    expose GUI.MenuItem ecPaste;
    expose GUI.MenuItem ecGotoDef;
    expose GUI.MenuItem ecFindRefs;
    expose GUI.MenuItem ecRename;
    expose GUI.MenuItem ecFormat;
    expose GUI.MenuItem ecToggleBreakpoint;
    expose GUI.MenuItem ecEvaluate;
    expose GUI.MenuItem ecPalette;

    // Tab context menu (right-click on the editor tab strip).
    expose GUI.ContextMenu tabContextMenu;
    expose GUI.MenuItem tcClose;
    expose GUI.MenuItem tcCloseOthers;
    expose GUI.MenuItem tcCloseAll;
    expose GUI.MenuItem tcCloseSaved;
    expose GUI.MenuItem tcCopyPath;
    expose GUI.MenuItem tcCopyRelativePath;
    expose GUI.MenuItem tcReveal;

    // Status bar + items
    expose GUI.StatusBar statusBar;
    expose GUI.StatusBarItem cursorItem;   // clickable Ln/Col display (center zone)
    expose GUI.StatusBarItem projectItem;  // right-zone project name
    expose GUI.StatusBarItem indexItem;    // right-zone workspace index state
    expose GUI.StatusBarItem languageItem; // right-zone active language service
    expose GUI.StatusBarItem jobItem;      // right-zone build/run job state
    expose GUI.StatusBarItem taskItem;     // right-zone background editor tasks
    expose GUI.StatusBarItem diagnosticsItem; // right-zone diagnostics summary

    // Command palette (Ctrl+Shift+P)
    expose GUI.CommandPalette commandPalette;

    // State
    expose Boolean sidebarVisible;
    expose Integer activeSurfaceKind;
    expose Integer activeDocumentSurfaceKind;
    expose Integer activeToolPanelKind;
    expose String contextPath;
    expose String contextDir;
    expose Integer tabContextIndex; // Tab the tab-context-menu acts on (-1 = active).
    expose String lastBuildOutput;
    expose String outputPartialLine;
    expose Any outputPartialItem;
    expose String outputFilterText;
    expose Boolean outputWrapLines;
    expose Boolean outputAutoScroll;
    expose Boolean outputPaneMode;
    expose Boolean problemsHaveDiagnostics;
    expose String lastDiagnosticsStatus;
    expose Integer lastDiagnosticsColor;
    expose String lastProjectStatus;
    expose String lastIndexStatus;
    expose String lastLanguageStatus;
    expose String lastBuildJobStatus;
    expose String lastTaskStatus;

    /// @brief Initialize with sidebar visible. Build() must be called next.
    expose func init() {
        sidebarVisible = true;
        activeSurfaceKind = 0;
        activeDocumentSurfaceKind = 0;
        activeToolPanelKind = tool_panel_model.PANEL_NONE;
        contextPath = "";
        contextDir = "";
        tabContextIndex = -1;
        lastBuildOutput = "";
        outputPartialLine = "";
        outputPartialItem = null;
        outputRenderedItems = new List();
        outputRenderedRowCount = 0;
        outputFilterText = "";
        outputWrapLines = false;
        outputAutoScroll = true;
        outputPaneMode = true;
        problemsHaveDiagnostics = false;
        lastDiagnosticsStatus = "Diagnostics: clean";
        lastDiagnosticsColor = TOOL_COLOR_SUCCESS;
        lastProjectStatus = "No project";
        lastIndexStatus = "Workspace index idle";
        lastLanguageStatus = "Lang: text";
        lastBuildJobStatus = "Job: idle";
        lastTaskStatus = "Tasks: idle";
    }

    /// @brief Construct the full IDE window and every chrome widget.
    /// @param title  Window title.
    /// @param width  Initial window width in logical pixels.
    /// @param height Initial window height in logical pixels.
    /// @details Read top-to-bottom — each section corresponds to one
    ///          band of the IDE chrome (menu bar, toolbar, split pane,
    ///          status bar, command palette).
    expose func Build(title: String, width: Integer, height: Integer) {
        // Create application window
        app = GUI.App.New(title, width, height);
        app.SetPreventClose(true);
        GUI.Theme.SetDark();

        // Main vertical layout (fills entire window)
        mainVBox = GUI.VBox.New();
        mainVBox.SetSpacing(0.0);
        mainVBox.SetPadding(0.0);
        mainVBox.SetFlex(1.0);
        var root: GUI.Widget = app.Root;
        root.AddChild(mainVBox);

        // ====================================================================
        // Menu Bar
        // ====================================================================
        menuBar = GUI.MenuBar.New(mainVBox);

        // File menu
        fileMenu = menuBar.AddMenu("File");
        miNew = fileMenu.AddItem("New File");
        miNew.SetShortcut("Ctrl+N");
        miOpen = fileMenu.AddItem("Open File...");
        miOpen.SetShortcut("Ctrl+O");
        miOpenFolder = fileMenu.AddItem("Open Folder...");
        miOpenFolder.SetShortcut("Ctrl+Alt+O");
        miQuickOpen = fileMenu.AddItem("Quick Open File");
        miQuickOpen.SetShortcut("Ctrl+P");
        fileMenu.AddSeparator();
        miSave = fileMenu.AddItem("Save");
        miSave.SetShortcut("Ctrl+S");
        miSaveAs = fileMenu.AddItem("Save As...");
        miSaveAs.SetShortcut("Ctrl+Shift+S");
        miSaveAll = fileMenu.AddItem("Save All");
        miSaveAll.SetShortcut("Ctrl+Alt+Shift+S");
        fileMenu.AddSeparator();
        miClose = fileMenu.AddItem("Close File");
        miClose.SetShortcut("Ctrl+W");
        miReload = fileMenu.AddItem("Reload File");
        miReload.SetShortcut("Ctrl+Shift+R");
        miRecentFiles = fileMenu.AddItem("Recent Files");
        miRecentFiles.SetShortcut("Ctrl+K Ctrl+R");
        miReopenClosed = fileMenu.AddItem("Reopen Closed File");
        miReopenClosed.SetShortcut("Ctrl+Alt+T");
        fileMenu.AddSeparator();
        miExit = fileMenu.AddItem("Exit");

        // Edit menu
        editMenu = menuBar.AddMenu("Edit");
        miUndo = editMenu.AddItem("Undo");
        miUndo.SetShortcut("Ctrl+Z");
        miRedo = editMenu.AddItem("Redo");
        miRedo.SetShortcut("Ctrl+Y");
        editMenu.AddSeparator();
        miCut = editMenu.AddItem("Cut");
        miCut.SetShortcut("Ctrl+X");
        miCopy = editMenu.AddItem("Copy");
        miCopy.SetShortcut("Ctrl+C");
        miPaste = editMenu.AddItem("Paste");
        miPaste.SetShortcut("Ctrl+V");
        editMenu.AddSeparator();
        miSelectAll = editMenu.AddItem("Select All");
        miSelectAll.SetShortcut("Ctrl+A");
        miFind = editMenu.AddItem("Find...");
        miFind.SetShortcut("Ctrl+F");
        miSearchProject = editMenu.AddItem("Search in Project");
        miSearchProject.SetShortcut("Ctrl+Shift+F");
        miGoToLine = editMenu.AddItem("Go To Line");
        miGoToLine.SetShortcut("Ctrl+G");
        miRenameSymbol = editMenu.AddItem("Rename Symbol");
        miRenameSymbol.SetShortcut("F2");
        editMenu.AddSeparator();
        miPreferences = editMenu.AddItem("Preferences...");
        miPreferences.SetShortcut("Ctrl+,");

        // Navigate menu
        navigateMenu = menuBar.AddMenu("Navigate");
        miGoToDefinition = navigateMenu.AddItem("Go To Definition");
        miGoToDefinition.SetShortcut("F12");
        miFindReferences = navigateMenu.AddItem("Find References");
        miFindReferences.SetShortcut("Shift+F12");
        navigateMenu.AddSeparator();
        miIncomingCalls = navigateMenu.AddItem("Incoming Calls");
        miIncomingCalls.SetShortcut("Ctrl+Alt+H");
        miOutgoingCalls = navigateMenu.AddItem("Outgoing Calls");
        miOutgoingCalls.SetShortcut("Ctrl+Alt+Shift+H");
        miWorkspaceSymbols = navigateMenu.AddItem("Workspace Symbols");
        miWorkspaceSymbols.SetShortcut("Ctrl+T");
        miSymbolOutline = navigateMenu.AddItem("Symbol Outline");
        miSymbolOutline.SetShortcut("Ctrl+Shift+O");
        navigateMenu.AddSeparator();
        miNextError = navigateMenu.AddItem("Next Error");
        miNextError.SetShortcut("F8");
        miPreviousError = navigateMenu.AddItem("Previous Error");
        miPreviousError.SetShortcut("Shift+F8");
        miSignatureHelp = navigateMenu.AddItem("Trigger Signature Help");
        miSignatureHelp.SetShortcut("Ctrl+Shift+Space");

        // View menu
        viewMenu = menuBar.AddMenu("View");
        miToggleSidebar = viewMenu.AddItem("Toggle Sidebar");
        miToggleSidebar.SetShortcut("Ctrl+B");
        miToggleStatusBar = viewMenu.AddItem("Toggle Status Bar");
        viewMenu.AddSeparator();
        miZoomIn = viewMenu.AddItem("Zoom In");
        miZoomIn.SetShortcut("Ctrl+=");
        miZoomOut = viewMenu.AddItem("Zoom Out");
        miZoomOut.SetShortcut("Ctrl+-");
        miZoomReset = viewMenu.AddItem("Reset Zoom");
        miZoomReset.SetShortcut("Ctrl+0");
        miUiZoomIn = viewMenu.AddItem("UI Zoom In");
        miUiZoomIn.SetShortcut("Ctrl+Shift+=");
        miUiZoomOut = viewMenu.AddItem("UI Zoom Out");
        miUiZoomOut.SetShortcut("Ctrl+Shift+-");
        miUiZoomReset = viewMenu.AddItem("Reset UI Zoom");
        miUiZoomReset.SetShortcut("Ctrl+Shift+0");
        viewMenu.AddSeparator();
        miToggleTheme = viewMenu.AddItem("Toggle Theme");
        miToggleTheme.SetShortcut("Ctrl+Shift+T");
        miFullscreen = viewMenu.AddItem("Toggle Fullscreen");
        miFullscreen.SetShortcut("F11");
        miToggleMinimap = viewMenu.AddItem("Toggle Minimap");
        miToggleMinimap.SetShortcut("Ctrl+Shift+M");
        viewMenu.AddSeparator();
        miTerminal = viewMenu.AddItem("Terminal");
        miTerminal.SetShortcut("Ctrl+`");

        // Build menu
        buildMenu = menuBar.AddMenu("Build");
        miBuild = buildMenu.AddItem("Build");
        miBuild.SetShortcut("Ctrl+Shift+B");
        miBuildAndRun = buildMenu.AddItem("Build and Run");
        miBuildAndRun.SetShortcut("F5");
        miRun = buildMenu.AddItem("Run without Build");
        miRun.SetShortcut("Ctrl+F5");
        miStop = buildMenu.AddItem("Stop");
        miStop.SetShortcut("Shift+F5");
        buildMenu.AddSeparator();
        miDebugStart = buildMenu.AddItem("Start Debugging");
        miDebugStart.SetShortcut("F6");
        miDebugContinue = buildMenu.AddItem("Continue Debugging");
        miDebugContinue.SetShortcut("F7");
        miDebugStepOver = buildMenu.AddItem("Step Over");
        miDebugStepOver.SetShortcut("F10");
        miDebugStepIn = buildMenu.AddItem("Step Into");
        miDebugStepIn.SetShortcut("Ctrl+F10");
        miDebugStepOut = buildMenu.AddItem("Step Out");
        miDebugStepOut.SetShortcut("Ctrl+Shift+F10");
        miDebugPause = buildMenu.AddItem("Pause Debugging");
        miDebugRestart = buildMenu.AddItem("Restart Debugging");
        miDebugRestart.SetShortcut("Ctrl+Shift+F5");
        miDebugStop = buildMenu.AddItem("Stop Debugging");
        miToggleBreakpoint = buildMenu.AddItem("Toggle Breakpoint");
        miToggleBreakpoint.SetShortcut("F9");

        // Help menu
        helpMenu = menuBar.AddMenu("Help");
        miKeyboardShortcuts = helpMenu.AddItem("Keyboard Shortcuts");
        miKeyboardShortcuts.SetShortcut("Ctrl+K Ctrl+S");
        miAbout = helpMenu.AddItem("About ViperIDE");

        // ====================================================================
        // Toolbar — BMP-only Unicode glyphs rendered as button text via the
        // system font. The runtime maps these codepoints to crisp vector icons,
        // giving the IDE consistent cross-platform toolbar art without shipping
        // external image assets.
        // NOTE: AddButton(icon, tooltip) treats arg 1 as a FILE PATH
        // (rt_gui_icon_from_path_cstr), so we pass "" for icon and put the
        // glyph in the text slot via AddButtonWithText. Standard system fonts
        // render every codepoint below — supplementary-plane emoji (U+1F000+)
        // would fall back to the missing-glyph "hamburger" .notdef on UI fonts
        // that lack color emoji support.
        // ====================================================================
        toolbar = GUI.Toolbar.New(mainVBox);
        tbNew     = toolbar.AddButtonWithText("", "+",  "New File (Ctrl+N)");
        tbOpen    = toolbar.AddButtonWithText("", "▤",  "Open File (Ctrl+O)");
        tbSave    = toolbar.AddButtonWithText("", "▼",  "Save File (Ctrl+S)");
        tbSaveAll = toolbar.AddButtonWithText("", "⇓",  "Save All Files (Ctrl+Alt+Shift+S)");
        toolbar.AddSeparator();
        tbBuild   = toolbar.AddButtonWithText("", "▣",  "Build (Ctrl+Shift+B)");
        tbRun     = toolbar.AddButtonWithText("", "▶",  "Build & Run (F5)");
        tbStop    = toolbar.AddButtonWithText("", "■",  "Stop Running Job (Shift+F5)");
        tbDebug   = toolbar.AddButtonWithText("", "◇",  "Start Debugging (F6)");
        tbDebugContinue = toolbar.AddButtonWithText("", "▷", "Continue Debugging (F7)");
        tbDebugStep = toolbar.AddButtonWithText("", "→", "Step Over (F10)");
        toolbar.AddSeparator();
        tbFind    = toolbar.AddButtonWithText("", "?",  "Find (Ctrl+F)");
        SetBuildJobActive(false, "");
        SetDebugSessionState(false, false, false);

        // ====================================================================
        // Workbench host: always-visible activity bar (left) + a resizable
        // SplitPane [ left view stack | editor area ]. The activity bar lives
        // OUTSIDE the SplitPane so dragging the splitter never shrinks it.
        // ====================================================================
        var workbenchHost: GUI.HBox = GUI.HBox.New();
        workbenchHost.SetSpacing(0.0);
        workbenchHost.SetPadding(0.0);
        workbenchHost.SetFlex(1.0);
        mainVBox.AddChild(workbenchHost);

        // Activity bar — vertical icon strip that switches the left view.
        activityBar = GUI.Toolbar.NewVertical(workbenchHost);
        abExplorer = activityBar.AddButtonWithText("", "▦", "Explorer");
        abSourceControl = activityBar.AddButtonWithText("", "⎇", "Source Control");

        splitPane = GUI.SplitPane.New(workbenchHost, 1);
        splitPane.SetFlex(1.0);
        splitPane.SetPosition(0.24);

        // Left panel — a swappable stack of views. The activity bar toggles
        // which child is visible; Explorer (the file tree) is the default.
        var leftPanel: GUI.Widget = splitPane.First;
        leftViewStack = GUI.VBox.New();
        leftViewStack.SetSpacing(0.0);
        leftViewStack.SetPadding(0.0);
        leftViewStack.SetFlex(1.0);
        leftPanel.AddChild(leftViewStack);

        explorerView = GUI.VBox.New();
        explorerView.SetSpacing(0.0);
        explorerView.SetPadding(0.0);
        explorerView.SetFlex(1.0);
        leftViewStack.AddChild(explorerView);
        sidebarTree = GUI.TreeView.New(explorerView);

        // Source Control view host (populated in sub-phase 5C); hidden until selected.
        scmViewHost = GUI.VBox.New();
        scmViewHost.SetSpacing(0.0);
        scmViewHost.SetPadding(0.0);
        scmViewHost.SetFlex(1.0);
        scmViewHost.SetVisible(false);
        leftViewStack.AddChild(scmViewHost);

        // Workbench — editor area plus the docked Preferences side panel.
        var rightPanel: GUI.Widget = splitPane.Second;
        workbenchRow = GUI.HBox.New();
        workbenchRow.SetSpacing(0.0);
        workbenchRow.SetPadding(0.0);
        workbenchRow.SetFlex(1.0);
        rightPanel.AddChild(workbenchRow);

        editorArea = GUI.VBox.New();
        editorArea.SetSpacing(0.0);
        editorArea.SetPadding(0.0);
        editorArea.SetFlex(1.0);
        workbenchRow.AddChild(editorArea);

        preferencesPanel = GUI.VBox.New();
        preferencesPanel.SetSpacing(0.0);
        preferencesPanel.SetPadding(0.0);
        preferencesPanel.SetSize(420, 0);
        preferencesPanel.SetVisible(false);
        workbenchRow.AddChild(preferencesPanel);

        // Tab bar inside editor area
        tabBar = GUI.TabBar.New(editorArea);

        // Breadcrumb (file path, shown below the tab bar)
        breadcrumb = GUI.Breadcrumb.New(editorArea);
        breadcrumb.SetSeparator(" / ");
        breadcrumb.SetMaxItems(6);
        breadcrumb.SetVisible(false);

        // Find bar inside editor area (hidden until Ctrl+F)
        findBar = GUI.FindBar.New(editorArea);
        findBar.SetVisible(false);

        // Editor row — HBox (editor left with flex, minimap right with fixed width).
        // The editor widget is added to editorRow by engine.Setup() in main.zia;
        // the minimap is added immediately after in main.zia.
        editorRow = GUI.HBox.New();
        editorRow.SetSpacing(0.0);
        editorRow.SetPadding(0.0);
        editorRow.SetFlex(1.0);
        editorArea.AddChild(editorRow);

        // Diagnostics panel (hidden until a build produces errors or warnings)
        toolTabBar = GUI.TabBar.New(editorArea);
        toolTabBar.SetAutoClose(false);
        toolProblemsTab = toolTabBar.AddTab("Problems", 0);
        toolOutputTab = toolTabBar.AddTab("Output", 0);
        toolSearchTab = toolTabBar.AddTab("Search", 0);
        toolReferencesTab = toolTabBar.AddTab("References", 0);
        toolVariablesTab = toolTabBar.AddTab("Variables", 0);
        toolCallStackTab = toolTabBar.AddTab("Call Stack", 0);
        toolDebugTab = toolTabBar.AddTab("Debug Console", 0);
        toolTerminalTab = toolTabBar.AddTab("Terminal", 0);
        toolTabBar.SetVisible(false);

        diagListBox = GUI.ListBox.New(editorArea);
        diagListBox.SetMultiSelect(true);
        diagListBox.SetVisible(false);
        diagListBox.SetSize(0, 120);

        // Build output panel (hidden until a build runs; shows raw compiler stdout/stderr)
        outputPane = GUI.OutputPane.New(editorArea);
        outputPane.SetMaxLines(10000);
        outputPane.SetAutoScroll(true);
        outputPane.SetVisible(false);
        outputPane.SetSize(0, 100);

        outputListBox = GUI.ListBox.New(editorArea);
        outputListBox.SetMultiSelect(true);
        outputListBox.SetVisible(false);
        outputListBox.SetSize(0, 100);
        outputVirtualList = GUI.VirtualList.New(0, 18, 100);

        searchListBox = GUI.ListBox.New(editorArea);
        searchListBox.SetMultiSelect(true);
        searchListBox.SetVisible(false);
        searchListBox.SetSize(0, 120);

        referencesListBox = GUI.ListBox.New(editorArea);
        referencesListBox.SetMultiSelect(true);
        referencesListBox.SetVisible(false);
        referencesListBox.SetSize(0, 120);

        debugListBox = GUI.ListBox.New(editorArea);
        debugListBox.SetMultiSelect(true);
        debugListBox.SetVisible(false);
        debugListBox.SetSize(0, 120);

        variablesListBox = GUI.ListBox.New(editorArea);
        variablesListBox.SetMultiSelect(true);
        variablesListBox.SetVisible(false);
        variablesListBox.SetSize(0, 120);

        callStackListBox = GUI.ListBox.New(editorArea);
        callStackListBox.SetMultiSelect(false);
        callStackListBox.SetVisible(false);
        callStackListBox.SetSize(0, 120);

        // Integrated terminal panel (Phase 5E): interactive PTY terminal. The
        // OutputPane runs in terminal mode — the user types directly into it; a
        // thin button row offers Stop/Restart.
        terminalPanel = GUI.VBox.New();
        terminalPanel.SetSpacing(0.0);
        terminalPanel.SetPadding(0.0);
        terminalPanel.SetSize(0, 220);
        terminalPanel.SetVisible(false);
        editorArea.AddChild(terminalPanel);
        terminalPane = GUI.OutputPane.New(terminalPanel);
        terminalPane.SetMaxLines(10000);
        terminalPane.SetAutoScroll(true);
        terminalPane.SetFlex(1.0);
        var terminalInputRow = GUI.HBox.New();
        terminalInputRow.SetSpacing(0.0);
        terminalInputRow.SetPadding(0.0);
        terminalPanel.AddChild(terminalInputRow);
        terminalKill = GUI.Button.New(terminalInputRow, "Stop");
        terminalRestart = GUI.Button.New(terminalInputRow, "Restart");

        // Context menu for the file tree (populated on right-click)
        treeContextMenu = GUI.ContextMenu.New();
        ctxOpen = treeContextMenu.AddItem("▷ Open");
        ctxOpenText = treeContextMenu.AddItem("T Open With Text Editor");
        treeContextMenu.AddSeparator();
        ctxReveal = treeContextMenu.AddItem("▣ Reveal in Finder");
        ctxCopyPath = treeContextMenu.AddItem("⧉ Copy Path");
        ctxCopyRelativePath = treeContextMenu.AddItem("⧉ Copy Relative Path");
        ctxDuplicate = treeContextMenu.AddItem("◇ Duplicate File...");
        treeContextMenu.AddSeparator();
        ctxRename = treeContextMenu.AddItem("✎ Rename");
        ctxRename.SetShortcut("Ctrl+Alt+R");
        ctxDelete = treeContextMenu.AddItem("× Delete");
        ctxDelete.SetShortcut("Ctrl+Alt+D");
        treeContextMenu.AddSeparator();
        ctxNewFile = treeContextMenu.AddItem("+ New File...");
        ctxNewFile.SetShortcut("Ctrl+Alt+N");
        ctxNewFolder = treeContextMenu.AddItem("▤ New Folder...");
        ctxNewFolder.SetShortcut("Ctrl+Alt+Shift+N");
        ctxSearchFolder = treeContextMenu.AddItem("? Search in Folder...");
        ctxRunFile = treeContextMenu.AddItem("▶ Run This File");
        ctxSetEntry = treeContextMenu.AddItem("◆ Set as Project Entry");
        treeContextMenu.AddSeparator();
        ctxRefresh = treeContextMenu.AddItem("↻ Refresh");
        ctxRefresh.SetShortcut("Ctrl+Alt+Shift+R");

        // Context menu for the code editor surface (populated on right-click).
        editorContextMenu = GUI.ContextMenu.New();
        ecCut = editorContextMenu.AddItem("✂ Cut");
        ecCut.SetShortcut("Ctrl+X");
        ecCopy = editorContextMenu.AddItem("⧉ Copy");
        ecCopy.SetShortcut("Ctrl+C");
        ecPaste = editorContextMenu.AddItem("▣ Paste");
        ecPaste.SetShortcut("Ctrl+V");
        editorContextMenu.AddSeparator();
        ecGotoDef = editorContextMenu.AddItem("→ Go to Definition");
        ecGotoDef.SetShortcut("F12");
        ecFindRefs = editorContextMenu.AddItem("? Find References");
        ecFindRefs.SetShortcut("Shift+F12");
        ecRename = editorContextMenu.AddItem("✎ Rename Symbol");
        ecRename.SetShortcut("F2");
        editorContextMenu.AddSeparator();
        ecFormat = editorContextMenu.AddItem("◇ Format Document");
        ecFormat.SetShortcut("Shift+Alt+F");
        ecToggleBreakpoint = editorContextMenu.AddItem("● Toggle Breakpoint");
        ecToggleBreakpoint.SetShortcut("F9");
        ecEvaluate = editorContextMenu.AddItem("▸ Evaluate at Cursor");
        editorContextMenu.AddSeparator();
        ecPalette = editorContextMenu.AddItem("◆ Command Palette...");
        ecPalette.SetShortcut("Ctrl+Shift+P");

        // Context menu for the editor tab strip (populated on right-click).
        tabContextMenu = GUI.ContextMenu.New();
        tcClose = tabContextMenu.AddItem("× Close");
        tcCloseOthers = tabContextMenu.AddItem("× Close Others");
        tcCloseAll = tabContextMenu.AddItem("× Close All");
        tcCloseSaved = tabContextMenu.AddItem("✓ Close Saved");
        tabContextMenu.AddSeparator();
        tcCopyPath = tabContextMenu.AddItem("⧉ Copy Path");
        tcCopyRelativePath = tabContextMenu.AddItem("⧉ Copy Relative Path");
        tcReveal = tabContextMenu.AddItem("▣ Reveal in Finder");

        // ====================================================================
        // Status Bar
        // ====================================================================
        statusBar = GUI.StatusBar.New(mainVBox);
        statusBar.SetLeftText("Ready");
        cursorItem = statusBar.AddText("Ln 1, Col 1", 1);   // zone 1 = center
        projectItem = statusBar.AddText("No project", 2);
        projectItem.SetTooltip("Active project");
        indexItem = statusBar.AddText("Workspace index idle", 2);
        indexItem.SetTooltip("Workspace index state");
        languageItem = statusBar.AddText("Lang: text", 2);
        languageItem.SetTooltip("Active language service");
        jobItem = statusBar.AddText("Job: idle", 2);
        jobItem.SetTooltip("Build/run job state");
        taskItem = statusBar.AddText("Tasks: idle", 2);
        taskItem.SetTooltip("Background editor tasks");
        diagnosticsItem = statusBar.AddText("Diagnostics: clean", 2);
        diagnosticsItem.SetTextColor(TOOL_COLOR_SUCCESS);
        diagnosticsItem.SetTooltip("Live diagnostics summary");
        statusBar.SetRightText("ViperIDE");

        // ====================================================================
        // Command Palette (application-level overlay, shown via Ctrl+Shift+P)
        // ====================================================================
        commandPalette = GUI.CommandPalette.New(app);
        commandPalette.SetPlaceholder("Type a command...");
    }

    /// @brief Apply command-catalog shortcuts to visible menu/context items.
    /// @details Build() creates menu items with sensible defaults so AppShell is
    ///          usable in isolation. After CommandRegistry loads the central
    ///          catalog, main.zia calls this method to make the catalog the
    ///          source of truth for user-visible shortcut labels.
    /// @param registry Runtime command registry populated from command_catalog.
    expose func ApplyCommandShortcuts(registry: command_registry.CommandRegistry) {
        if registry == null { return; }
        ApplyShortcut(miNew, "new", registry);
        ApplyShortcut(miOpen, "open", registry);
        ApplyShortcut(miOpenFolder, "openfolder", registry);
        ApplyShortcut(miQuickOpen, "quickopen", registry);
        ApplyShortcut(miSave, "save", registry);
        ApplyShortcut(miSaveAs, "saveas", registry);
        ApplyShortcut(miSaveAll, "saveall", registry);
        ApplyShortcut(miClose, "close", registry);
        ApplyShortcut(miReload, "reload", registry);
        ApplyShortcut(miRecentFiles, "recentfiles", registry);
        ApplyShortcut(miReopenClosed, "reopenclosed", registry);
        ApplyShortcut(miUndo, "undo", registry);
        ApplyShortcut(miRedo, "redo", registry);
        ApplyShortcut(miCut, "cut", registry);
        ApplyShortcut(miCopy, "copy", registry);
        ApplyShortcut(miPaste, "paste", registry);
        ApplyShortcut(miSelectAll, "selectall", registry);
        ApplyShortcut(miFind, "find", registry);
        ApplyShortcut(miSearchProject, "searchproject", registry);
        ApplyShortcut(miGoToLine, "goto", registry);
        ApplyShortcut(miRenameSymbol, "rename", registry);
        ApplyShortcut(miPreferences, "settings", registry);
        ApplyShortcut(miGoToDefinition, "gotodef", registry);
        ApplyShortcut(miFindReferences, "findrefs", registry);
        ApplyShortcut(miIncomingCalls, "incomingcalls", registry);
        ApplyShortcut(miOutgoingCalls, "outgoingcalls", registry);
        ApplyShortcut(miWorkspaceSymbols, "workspacesymbols", registry);
        ApplyShortcut(miSymbolOutline, "symboloutline", registry);
        ApplyShortcut(miNextError, "nexterror", registry);
        ApplyShortcut(miPreviousError, "preverror", registry);
        ApplyShortcut(miSignatureHelp, "signature_trigger", registry);
        ApplyShortcut(miToggleSidebar, "togglesidebar", registry);
        ApplyShortcut(miToggleStatusBar, "statusbar", registry);
        ApplyShortcut(miZoomIn, "zoomin", registry);
        ApplyShortcut(miZoomOut, "zoomout", registry);
        ApplyShortcut(miZoomReset, "zoomreset", registry);
        ApplyShortcut(miUiZoomIn, "uizoomin", registry);
        ApplyShortcut(miUiZoomOut, "uizoomout", registry);
        ApplyShortcut(miUiZoomReset, "uizoomreset", registry);
        ApplyShortcut(miToggleTheme, "toggletheme", registry);
        ApplyShortcut(miFullscreen, "fullscreen", registry);
        ApplyShortcut(miToggleMinimap, "minimap", registry);
        ApplyShortcut(miTerminal, "terminal", registry);
        ApplyShortcut(miBuild, "build", registry);
        ApplyShortcut(miBuildAndRun, "buildrun", registry);
        ApplyShortcut(miRun, "run", registry);
        ApplyShortcut(miStop, "stopjob", registry);
        ApplyShortcut(miDebugStart, "debugstart", registry);
