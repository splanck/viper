    /// @brief Apply one command shortcut to one menu item.
    /// @param item Menu or context-menu item that displays a shortcut label.
    /// @param commandId Command id in CommandRegistry.
    /// @param registry Runtime command registry to query.
    hide func ApplyShortcut(item: GUI.MenuItem,
                            commandId: String,
                            registry: command_registry.CommandRegistry) {
        if item == null or registry == null { return; }
        var shortcut = registry.ShortcutFor(commandId);
        if shortcut == "" { return; }
        item.SetShortcut(shortcut);
    }

    /// @brief True if the user requested window close (clicked the X).
    expose func ShouldClose() -> Boolean {
        return app.ShouldClose;
    }

    expose func WasCloseRequested() -> Boolean {
        return app.WasCloseRequested();
    }

    /// @brief Pump the event queue. Call once per frame before reading
    ///        widget state.
    expose func Poll() {
        app.Poll();
    }

    /// @brief Paint the current frame. Call once per frame after all
    ///        state mutations.
    expose func Render() {
        app.Render();
    }

    /// @brief Tear down the window. Triggered by the Exit command.
    expose func Destroy() {
        app.Destroy();
    }

    /// @brief Set the status bar's left text (status messages).
    expose func SetStatusLeft(text: String) {
        statusBar.SetLeftText(text);
    }

    /// @brief Set the status bar's center text (cursor position).
    expose func SetStatusCenter(text: String) {
        cursorItem.SetText(text);
    }

    /// @brief Set the status bar's right text (language / EOL indicator).
    expose func SetStatusRight(text: String) {
        statusBar.SetRightText(text);
    }

    expose func SetWorkspaceStatus(projectName: String,
                                   languageName: String) {
        var projectText = status_bar_model.ProjectStatusText(projectName);
        var languageText = status_bar_model.LanguageStatusText(languageName);
        if projectText == lastProjectStatus and languageText == lastLanguageStatus {
            return;
        }
        lastProjectStatus = projectText;
        lastLanguageStatus = languageText;
        if projectItem != null {
            projectItem.SetText(projectText);
            projectItem.SetTooltip(projectText);
        }
        if languageItem != null {
            languageItem.SetText(languageText);
            languageItem.SetTooltip(languageText);
        }
    }

    /// @brief Update the workspace-index status-bar item.
    /// @details Indexing can run for many frames on large projects. Keeping its
    ///          progress in a dedicated status item makes that background work
    ///          visible without overwriting command/status messages in the left
    ///          zone every frame.
    /// @param status Short index status text.
    expose func SetIndexStatus(status: String) {
        var text = status;
        text = status_bar_model.IndexStatusText(text);
        if text == lastIndexStatus { return; }
        lastIndexStatus = text;
        if indexItem != null {
            indexItem.SetText(text);
            indexItem.SetTooltip(text);
        }
    }

    expose func SetDiagnosticsSummary(errors: Integer,
                                      warnings: Integer,
                                      notes: Integer) {
        var text = FormatDiagnosticsSummary(errors, warnings, notes);
        var color = DiagnosticsSummaryColor(errors, warnings, notes);
        if text == lastDiagnosticsStatus and color == lastDiagnosticsColor {
            return;
        }
        lastDiagnosticsStatus = text;
        lastDiagnosticsColor = color;
        if diagnosticsItem != null {
            diagnosticsItem.SetText(text);
            diagnosticsItem.SetTextColor(color);
            diagnosticsItem.SetTooltip(text);
        }
    }

    expose func SetBuildJobActive(active: Boolean, name: String) {
        var enabled = true;
        var stopEnabled = false;
        var jobName = status_bar_model.JobDisplayName(name);
        if active {
            enabled = false;
            stopEnabled = true;
            lastBuildJobStatus = status_bar_model.BuildJobStatusText(true, jobName);
        } else {
            lastBuildJobStatus = status_bar_model.BuildJobStatusText(false, jobName);
        }

        SetToolbarItemState(tbBuild, enabled,
                            "Build (Ctrl+Shift+B)",
                            "Build disabled while " + jobName + " is running");
        SetToolbarItemState(tbRun, enabled,
                            "Build & Run (F5)",
                            "Run disabled while " + jobName + " is running");
        SetToolbarItemState(tbDebug, enabled,
                            "Start Debugging (F6)",
                            "Debug disabled while " + jobName + " is running");
        if tbStop != null {
            tbStop.SetEnabled(stopEnabled);
            if active {
                tbStop.SetTooltip("Stop " + jobName + " (Shift+F5)");
            } else {
                tbStop.SetTooltip("No running job");
            }
        }

        if miBuild != null { miBuild.SetEnabled(enabled); }
        if miBuildAndRun != null { miBuildAndRun.SetEnabled(enabled); }
        if miRun != null { miRun.SetEnabled(enabled); }
        if miDebugStart != null { miDebugStart.SetEnabled(enabled); }
        if miStop != null { miStop.SetEnabled(stopEnabled); }
        if jobItem != null {
            jobItem.SetText(lastBuildJobStatus);
            jobItem.SetTooltip(lastBuildJobStatus);
        }
    }

    /// @brief Update the background editor-task status item.
    /// @details The scheduler handles diagnostics, completion, hover, search,
    ///          symbols, and index sync. Keeping this state visible makes
    ///          background work diagnosable without mixing it with build/run
    ///          process status.
    /// @param status Short display text produced by editor/scheduler.zia.
    expose func SetSchedulerStatus(status: String) {
        var text = status;
        text = status_bar_model.TaskStatusText(text);
        if text == lastTaskStatus { return; }
        lastTaskStatus = text;
        if taskItem != null {
            taskItem.SetText(text);
            taskItem.SetTooltip(text);
        }
    }

    /// @brief Apply enabled state and matching hover text to one toolbar item.
    /// @details Toolbar tooltips are the primary affordance for compact icon
    ///          buttons. Keeping disabled-state reasons here prevents the app
    ///          from presenting inert icons with no explanation while preserving
    ///          the existing menu/shortcut command routing.
    /// @param item Toolbar item handle; NULL is ignored during partial setup.
    /// @param enabled Runtime GUI enabled flag.
    /// @param enabledTooltip Tooltip used when the item can be activated.
    /// @param disabledTooltip Tooltip used when the item is disabled.
    hide func SetToolbarItemState(item: GUI.ToolbarItem,
                                  enabled: Boolean,
                                  enabledTooltip: String,
                                  disabledTooltip: String) {
        if item == null { return; }
        item.SetEnabled(enabled);
        if enabled {
            item.SetTooltip(enabledTooltip);
        } else {
            item.SetTooltip(disabledTooltip);
        }
    }

    /// @brief Apply running/paused debug-session state to visible controls.
    /// @details Debug commands are always registered so shortcuts and palette
    ///          routing remain stable. This method only updates affordances:
    ///          start is disabled while a session is active, stepping is enabled
    ///          only while paused, and pause is enabled only while running.
    /// @param active True while a debug adapter session exists.
    /// @param stopped True while the debuggee is paused at a stop location.
    /// @param buildJobActive True while the build/run process controller is busy.
    expose func SetDebugSessionState(active: Boolean,
                                     stopped: Boolean,
                                     buildJobActive: Boolean) {
        var startEnabled = true;
        if active or buildJobActive {
            startEnabled = false;
        }
        var pausedEnabled = false;
        if active and stopped {
            pausedEnabled = true;
        }
        var runningEnabled = false;
        if active and stopped == false {
            runningEnabled = true;
        }
        var activeEnabled = false;
        if active {
            activeEnabled = true;
        }

        if active {
            SetToolbarItemState(tbBuild, false,
                                "Build (Ctrl+Shift+B)",
                                "Build disabled while debugging");
            SetToolbarItemState(tbRun, false,
                                "Build & Run (F5)",
                                "Run disabled while debugging");
            SetMenuEnabled(miBuild, false);
            SetMenuEnabled(miBuildAndRun, false);
            SetMenuEnabled(miRun, false);
        } else if buildJobActive == false {
            SetToolbarItemState(tbBuild, true,
                                "Build (Ctrl+Shift+B)",
                                "Build disabled while another job is running");
            SetToolbarItemState(tbRun, true,
                                "Build & Run (F5)",
                                "Run disabled while another job is running");
            SetMenuEnabled(miBuild, true);
            SetMenuEnabled(miBuildAndRun, true);
            SetMenuEnabled(miRun, true);
        }

        var startDisabled = "Debug disabled while another job is running";
        if active {
            startDisabled = "Debug session already running";
        }
        SetToolbarItemState(tbDebug, startEnabled,
                            "Start Debugging (F6)", startDisabled);
        SetToolbarItemState(tbDebugContinue, pausedEnabled,
                            "Continue Debugging (F7)",
                            "Continue is available while paused at a breakpoint");
        SetToolbarItemState(tbDebugStep, pausedEnabled,
                            "Step Over (F10)",
                            "Step is available while paused at a breakpoint");

        SetMenuEnabled(miDebugStart, startEnabled);
        SetMenuEnabled(miDebugContinue, pausedEnabled);
        SetMenuEnabled(miDebugStepOver, pausedEnabled);
        SetMenuEnabled(miDebugStepIn, pausedEnabled);
        SetMenuEnabled(miDebugStepOut, pausedEnabled);
        SetMenuEnabled(miDebugPause, runningEnabled);
        SetMenuEnabled(miDebugRestart, activeEnabled);
        SetMenuEnabled(miDebugStop, activeEnabled);
    }

    /// @brief Apply active-language capability state to menus and editor context actions.
    /// @details The command registry already disables shortcuts and filters command
    ///          palette execution. This UI pass keeps visible menu surfaces honest
    ///          by greying out semantic actions that the active language service
    ///          cannot currently satisfy, without unregistering or deleting them.
    /// @param service Capability record selected for the active document.
    expose func ApplyLanguageCommandState(service: language_service.LanguageService) {
        var canDefinition = false;
        var canReferences = false;
        var canRename = false;
        var canSymbols = false;
        var canSignature = false;
        if service != null {
            canDefinition = service.canGoToDefinition;
            canReferences = service.canFindReferences;
            canRename = service.canRename;
            canSymbols = service.canDocumentSymbols;
            canSignature = service.canSignatureHelp;
        }

        SetMenuEnabled(miGoToDefinition, canDefinition);
        SetMenuEnabled(miFindReferences, canReferences);
        SetMenuEnabled(miIncomingCalls, canReferences);
        SetMenuEnabled(miOutgoingCalls, canDefinition);
        SetMenuEnabled(miRenameSymbol, canRename);
        SetMenuEnabled(miWorkspaceSymbols, canSymbols);
        SetMenuEnabled(miSymbolOutline, canSymbols);
        SetMenuEnabled(miSignatureHelp, canSignature);

        SetMenuEnabled(ecGotoDef, canDefinition);
        SetMenuEnabled(ecFindRefs, canReferences);
        SetMenuEnabled(ecRename, canRename);
    }

    /// @brief Enable or disable one menu item when the handle exists.
    /// @param item Menu item handle that may be null during partial setup.
    /// @param enabled True to enable, false to grey the item out.
    hide func SetMenuEnabled(item: GUI.MenuItem, enabled: Boolean) {
        if item == null { return; }
        if enabled {
            item.SetEnabled(true);
        } else {
            item.SetEnabled(false);
        }
    }

    /// @brief Set the breadcrumb path; auto-hides when path is empty.
    expose func SetBreadcrumbPath(path: String) {
        if path == "" {
            breadcrumb.SetPath("", "/");
            breadcrumb.SetVisible(false);
            return;
        }
        breadcrumb.SetPath(path, "/");
        breadcrumb.SetVisible(true);
    }

    /// @brief Populate the build-output panel with one row per line of
    ///        compiler stdout/stderr. Empty string clears + hides.
    expose func SetBuildOutput(output: String) {
        if output == lastBuildOutput {
            return;
        }
        if output == "" {
            ClearOutputPanel();
            return;
        }

        if lastBuildOutput != "" and Str.EndsWith(lastBuildOutput, "\n")
           and Str.StartsWith(output, lastBuildOutput) {
            var delta = Str.Mid(output, Str.get_Length(lastBuildOutput) + 1);
            if UsesRawOutputPane() {
                AppendBuildOutput(delta);
            } else {
                RenderOutputRows(output);
                lastBuildOutput = output;
                ShowOutputPanel();
            }
            return;
        }

        lastBuildOutput = BoundOutputCache("", output);
        if UsesRawOutputPane() {
            RenderOutputPane(lastBuildOutput);
        } else {
            RenderOutputRows(lastBuildOutput);
        }
        ShowOutputPanel();
    }

    /// @brief Append incremental process output to the active output surface.
    /// @details The raw text pane is used when no filter or wrapping transform is
    ///          active. Otherwise output is split into rows while preserving a
    ///          partial trailing line until the next append supplies a newline.
    /// @param output Newly captured stdout/stderr text.
    expose func AppendBuildOutput(output: String) {
        if output == "" { return; }
        var previousLen = Str.get_Length(lastBuildOutput);
        lastBuildOutput = BoundOutputCache(lastBuildOutput, output);
        var trimmed = previousLen + Str.get_Length(output) > MAX_BUILD_OUTPUT_CACHE_CHARS;
        if UsesRawOutputPane() {
            UseOutputPane();
            if trimmed {
                RenderOutputPane(lastBuildOutput);
            } else {
                outputPane.Append(output);
            }
            ShowOutputPanel();
            return;
        }

        if outputPartialItem != null {
            outputListBox.RemoveItem(outputPartialItem);
            outputPartialItem = null;
        }

        var combined = outputPartialLine + output;
        outputPartialLine = "";

        var lines = Str.Split(combined, "\n");
        var n = Seq.get_Count(lines);
        var endsWithNewline = Str.EndsWith(combined, "\n");
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            var isLast = i == n - 1;
            if isLast and endsWithNewline == false {
                outputPartialLine = line;
                if line != "" {
                    outputPartialItem = AddOutputDisplayLine(line);
                }
            } else if line != "" {
                AddOutputDisplayLine(line);
            }
            i = i + 1;
        }

        if trimmed {
            RenderOutputRows(lastBuildOutput);
        }
        ShowOutputPanel();
    }

    /// @brief Append to the cached build output while preserving a bounded tail.
    /// @details The visible raw pane and row renderer both use this cache for
    ///          filtering, copying, and repainting. Bounding it keeps long-running
    ///          jobs from accumulating unbounded UI-side strings even when the
    ///          BuildSystem has already trimmed its own model.
    /// @param existing Current cached output.
    /// @param text New output text.
    /// @return Combined output, trimmed from the front when too large.
    hide func BoundOutputCache(existing: String,
                               text: String) -> String {
        var combined = existing + text;
        var textLen = Str.get_Length(text);
        if textLen >= MAX_BUILD_OUTPUT_CACHE_CHARS {
            return OUTPUT_CACHE_TRUNCATED_PREFIX
                + Str.Mid(text, textLen - MAX_BUILD_OUTPUT_CACHE_CHARS + 1);
        }
        var existingLen = Str.get_Length(existing);
        var keepExisting = MAX_BUILD_OUTPUT_CACHE_CHARS - textLen;
        if existingLen > keepExisting {
            return OUTPUT_CACHE_TRUNCATED_PREFIX
                + Str.Mid(existing, existingLen - keepExisting + 1) + text;
        }
        if Str.get_Length(combined) <= MAX_BUILD_OUTPUT_CACHE_CHARS {
            return combined;
        }
        return OUTPUT_CACHE_TRUNCATED_PREFIX
            + Str.Mid(combined, Str.get_Length(combined) - MAX_BUILD_OUTPUT_CACHE_CHARS + 1);
    }

    /// @brief Return whether build output can be rendered as raw appended text.
    /// @return True when no row-level filtering or wrapping is active.
    hide func UsesRawOutputPane() -> Boolean {
        return outputFilterText == "" and outputWrapLines == false;
    }

    /// @brief Render complete build output into the raw multiline text pane.
    /// @param output Complete captured build output text.
    hide func RenderOutputPane(output: String) {
        UseOutputPane();
        outputPane.Clear();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
        outputPane.Append(output);
    }

    /// @brief Render complete build output into the filterable row list.
    /// @param output Complete captured build output text.
    hide func RenderOutputRows(output: String) {
        UseOutputRows();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
        AddBuildOutputLines(output);
    }

    /// @brief Switch the output panel to the raw multiline text widget.
    hide func UseOutputPane() {
        outputPaneMode = true;
        outputListBox.SetVisible(false);
        if activeToolPanelKind == tool_panel_model.PANEL_OUTPUT {
            outputPane.SetVisible(true);
        }
    }

    /// @brief Switch the output panel to row-list mode.
    expose func UseOutputRows() {
        outputPaneMode = false;
        outputPane.SetVisible(false);
        if activeToolPanelKind == tool_panel_model.PANEL_OUTPUT {
            outputListBox.SetVisible(true);
        }
    }

    /// @brief Clear output rows and prepare for row-by-row population.
    expose func BeginOutputRows() {
        UseOutputRows();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
    }

    /// @brief Return whether either output surface currently contains content.
    /// @return True when raw text, rendered rows, or cached output text exist.
    hide func HasOutputContent() -> Boolean {
        if lastBuildOutput != "" { return true; }
        if outputPaneMode and outputPane.LineCount > 0 { return true; }
        if outputListBox.Count > 0 { return true; }
        return false;
    }

    expose func SetDebugOutput(output: String) {
        debugListBox.Clear();
        var text = output;
        if text == "" {
            AddToolInfoRow(debugListBox, "debug", "Debug console is idle");
            ShowDebugPanel();
            return;
        }
        var lines = Str.Split(text, "\n");
        var n = Seq.get_Count(lines);
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            if line != "" {
                var item = debugListBox.AddItem(line);
                ApplyDebugLineColor(item, line);
            }
            i = i + 1;
        }
        ShowDebugPanel();
    }

    /// @brief Apply semantic color to a debug-console row.
    /// @details Debug output combines adapter status, program stdout/stderr,
    ///          stop metadata, and termination messages. Coloring known line
    ///          classes improves scanability while leaving arbitrary program
    ///          output unchanged.
    /// @param item Debug ListBox item to color.
    /// @param line Text displayed in the row.
    hide func ApplyDebugLineColor(item: Any,
                                  line: String) {
        if item == null { return; }
        var lower = Str.ToLower(line);
        if Str.IndexOf(lower, "error") != 0
           or Str.IndexOf(lower, "failed") != 0
           or Str.IndexOf(lower, "trap") != 0
           or Str.IndexOf(lower, "not found") != 0 {
            GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_ERROR);
        } else if Str.IndexOf(lower, "warning") != 0
                  or Str.IndexOf(lower, "warn") != 0 {
            GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_WARNING);
        } else if Str.IndexOf(lower, "stopped") != 0
                  or Str.IndexOf(lower, "breakpoint") != 0 {
            GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_INFO);
        } else if Str.IndexOf(lower, "terminated") != 0
                  or Str.IndexOf(lower, "exited") != 0
                  or Str.IndexOf(lower, "exit") != 0 {
            GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_SUCCESS);
        } else if Str.StartsWith(lower, "[debug]") {
            GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_MUTED);
        }
    }

    func AddBuildOutputLines(output: String) {
        var lines = Str.Split(output, "\n");
        var n = Seq.get_Count(lines);
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            if line != "" {
                AddOutputDisplayLine(line);
            }
            i = i + 1;
        }
    }

    expose func SetOutputFilter(filter: String) {
        outputFilterText = Str.ToLower(Str.Trim(filter));
        if UsesRawOutputPane() {
            RenderOutputPane(lastBuildOutput);
            if lastBuildOutput != "" {
                ShowOutputPanel();
            } else {
                HideOutputPanel();
            }
            return;
        }
        RenderOutputRows(lastBuildOutput);
        if outputListBox.Count > 0 or outputFilterText != "" {
            ShowOutputPanel();
        } else {
            HideOutputPanel();
        }
    }

    expose func ToggleOutputWrap() -> Boolean {
        outputWrapLines = outputWrapLines == false;
        if UsesRawOutputPane() {
            RenderOutputPane(lastBuildOutput);
            if lastBuildOutput != "" {
                ShowOutputPanel();
            }
            return outputWrapLines;
        }
        RenderOutputRows(lastBuildOutput);
        if outputListBox.Count > 0 {
            ShowOutputPanel();
        }
        return outputWrapLines;
    }

    expose func SetOutputAutoScroll(enabled: Boolean) {
        outputAutoScroll = enabled;
        if enabled {
            outputPane.SetAutoScroll(true);
        } else {
            outputPane.SetAutoScroll(false);
        }
    }

    expose func ToggleOutputAutoScroll() -> Boolean {
        outputAutoScroll = outputAutoScroll == false;
        SetOutputAutoScroll(outputAutoScroll);
        return outputAutoScroll;
    }

    expose func ClearOutputPanel() {
        outputPane.Clear();
        outputPane.SetVisible(false);
        outputListBox.Clear();
        ResetOutputRows();
        outputListBox.SetVisible(false);
        lastBuildOutput = "";
        outputPartialLine = "";
        outputPartialItem = null;
        outputPaneMode = true;
        HideOutputPanel();
    }

    expose func CopyOutputText() -> Boolean {
        if lastBuildOutput == "" {
            return false;
        }
        GUI.ClipboardText.SetText(lastBuildOutput);
        return true;
    }

    expose func CopySelectedToolRow() -> Boolean {
        var selectedText = outputListBox.GetSelectedText();
        if activeToolPanelKind == tool_panel_model.PANEL_OUTPUT and outputPaneMode {
            selectedText = outputPane.GetSelection();
        }
        if activeToolPanelKind == tool_panel_model.PANEL_PROBLEMS { selectedText = diagListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_SEARCH { selectedText = searchListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_REFERENCES { selectedText = referencesListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_DEBUG { selectedText = debugListBox.GetSelectedText(); }
        if selectedText == "" { return false; }
        GUI.ClipboardText.SetText(selectedText);
        return true;
    }

    hide func AddOutputDisplayLine(line: String) -> Any {
        if outputFilterText != "" and Str.IndexOf(Str.ToLower(line), outputFilterText) == 0 {
            return null;
        }
        EnsureOutputRowCapacity();
        var wrapColumn = OutputWrapColumn();
        if outputWrapLines == false or Str.get_Length(line) <= wrapColumn {
            var item = outputListBox.AddItem(line);
            RegisterOutputRow(item, line);
            ApplyOutputLineColor(item, line);
            if outputAutoScroll {
                outputListBox.ScrollToBottom();
            }
            return item;
        }

        var first: Any = null;
        var start = 1;
        while start <= Str.get_Length(line) {
            var chunk = Str.MidLen(line, start, wrapColumn);
            var item = outputListBox.AddItem(chunk);
            RegisterOutputRow(item, chunk);
            ApplyOutputLineColor(item, line);
            if first == null { first = item; }
            if outputAutoScroll {
                outputListBox.ScrollToBottom();
            }
            start = start + wrapColumn;
        }
        return first;
    }

    /// @brief Keep the row-mode output surface bounded.
    /// @details ListBox rows are heavier than raw text appends. Older visible
    ///          rows are removed one at a time so selection, scroll position, and
    ///          the newest output remain stable. The full bounded text cache
    ///          remains available for copy/filter repaint.
    hide func EnsureOutputRowCapacity() {
        while outputRenderedItems.count() >= MAX_OUTPUT_ROW_COUNT {
            var oldest = outputRenderedItems.get(0);
            outputRenderedItems.removeAt(0);
            if oldest != null {
                outputListBox.RemoveItem(oldest);
            }
        }
        if outputVirtualList != null {
            outputVirtualList.SetCount(outputRenderedRowCount);
        }
    }

    /// @brief Reset row-mode bookkeeping after a full output repaint.
    /// @details The ListBox owns visible row widgets while outputRenderedItems
    ///          tracks those widgets in insertion order for bounded removal. The
    ///          virtual list stores stable ids for the complete rendered stream so
    ///          future UI work can realize only visible ranges without changing the
    ///          output data model again.
    hide func ResetOutputRows() {
        outputRenderedItems = new List();
        outputRenderedRowCount = 0;
        if outputVirtualList != null {
            outputVirtualList.SetCount(0);
        }
    }

    /// @brief Record a newly-created output row in the bounded row model.
    /// @param item ListBox row handle returned by AddItem.
    /// @param text Rendered row text, used only to derive a stable virtual-row id.
    hide func RegisterOutputRow(item: Any,
                                text: String) {
        if item == null { return; }
        outputRenderedRowCount = outputRenderedRowCount + 1;
        outputRenderedItems.add(item);
        if outputVirtualList != null {
            outputVirtualList.SetCount(outputRenderedRowCount);
            outputVirtualList.SetRowId(outputRenderedRowCount - 1,
                                       "out:" + outputRenderedRowCount + ":" + Str.get_Length(text));
        }
    }

    /// @brief Compute an approximate output wrap width for the current window.
    /// @details Output rows are still rendered through ListBox, so the IDE does
    ///          not have text-measurement per row here. This heuristic tracks the
    ///          current window width and clamps to readable bounds, avoiding the
    ///          old fixed 160-character behavior on small and wide layouts.
    /// @return Character count used for wrapped output chunks.
    hide func OutputWrapColumn() -> Integer {
        var col = 160;
        if app != null {
            col = app.GetWidth() / 8;
        }
        if col < 80 { col = 80; }
        if col > 220 { col = 220; }
        return col;
    }

    expose func ClearProblemsPanel() {
        diagListBox.Clear();
        problemsHaveDiagnostics = false;
        HideProblemsPanel();
    }

    expose func BeginProblems() {
        diagListBox.Clear();
        problemsHaveDiagnostics = false;
        var header = diagListBox.AddItem(PadToolColumn("TYPE", TOOL_KIND_COL)
                                         + "  " + PadToolColumn("SOURCE", TOOL_SOURCE_COL)
                                         + "  " + PadToolColumn("LOCATION", TOOL_LOCATION_COL)
                                         + "  " + PadToolColumn("CODE", TOOL_CODE_COL)
                                         + "  MESSAGE"
                                         + "  " + PadToolColumn("ACTION", TOOL_ACTION_COL));
        GUI.ListBox.ItemSetTextColor(header, TOOL_COLOR_MUTED);
    }

    expose func AddProblem(severity: String,
                           source: String,
                           filePath: String,
                           line: Integer,
                           column: Integer,
                           code: String,
                           message: String,
                           action: String) -> Any {
        problemsHaveDiagnostics = true;
        var displayCode = code;
        if displayCode == "" { displayCode = "-"; }
        var displayAction = action;
        if displayAction == "" or displayAction == "No quick fix" { displayAction = "-"; }
        var displaySource = source;
        if displaySource == "" { displaySource = "-"; }
        var location = filePath + ":" + line + ":" + column;
        var item = AddToolLocationRow(diagListBox, ProblemSeverityLabel(severity),
                                      displaySource, location, displayCode,
                                      message, displayAction);
        ApplyProblemSeverityColor(item, severity);
        return item;
    }

    expose func AddToolGroupHeader(listBox: GUI.ListBox,
                                   title: String,
                                   detail: String) -> Any {
        if listBox == null { return null; }
        var text = TrimToolText(title, 36);
        if detail != "" and detail != title {
            text = text + "  " + TrimToolText(detail, 96);
        }
        var item = listBox.AddItem(text);
        GUI.ListBox.ItemSetTextColor(item, TOOL_COLOR_MUTED);
        return item;
    }

    expose func AddToolLocationRow(listBox: GUI.ListBox,
                                   kind: String,
                                   source: String,
                                   location: String,
                                   code: String,
                                   preview: String,
                                   action: String) -> Any {
        if listBox == null { return null; }
        var displayKind = kind;
        if displayKind == "" { displayKind = "-"; }
        var displaySource = source;
        if displaySource == "" { displaySource = "-"; }
        var displayCode = code;
        if displayCode == "" { displayCode = "-"; }
        var text = PadToolColumn(displayKind, TOOL_KIND_COL)
                   + "  " + PadToolColumn(displaySource, TOOL_SOURCE_COL)
                   + "  " + PadToolColumn(location, TOOL_LOCATION_COL)
                   + "  " + PadToolColumn(displayCode, TOOL_CODE_COL)
                   + "  " + TrimToolText(preview, 96);
        if action != "" {
            text = text + "  " + PadToolColumn(action, TOOL_ACTION_COL);
        }
        return listBox.AddItem(text);
    }

    /// @brief Add a colorized informational row to any bottom tool ListBox.
    /// @details Tool panels use fixed columns for diagnostics, search results,
    ///          references, and debug messages. Empty/progress state rows should
    ///          use the same geometry as actionable rows so the panel does not
    ///          visually jump between states.
    /// @param listBox Destination tool ListBox.
    /// @param kind Short row kind such as INFO or OK.
    /// @param source Source column text such as search, debug, or build.
    /// @param message Human-readable row message.
    /// @param color Text color applied to the row.
    /// @return Newly-created ListBox item, or null if the list box is null.
    expose func AddToolStateRow(listBox: GUI.ListBox,
                                kind: String,
                                source: String,
                                message: String,
                                color: Integer) -> Any {
        var item = AddToolLocationRow(listBox, kind, source, "-", "-", message, "-");
        if item != null {
            GUI.ListBox.ItemSetTextColor(item, color);
        }
        return item;
    }

    /// @brief Add a muted informational state row to a tool panel.
    /// @param listBox Destination tool ListBox.
    /// @param source Source column text.
    /// @param message Human-readable state message.
    /// @return Newly-created ListBox item, or null if the list box is null.
    expose func AddToolInfoRow(listBox: GUI.ListBox,
                               source: String,
                               message: String) -> Any {
        return AddToolStateRow(listBox, "INFO", source, message, TOOL_COLOR_MUTED);
    }

    /// @brief Add a success state row to a tool panel.
    /// @param listBox Destination tool ListBox.
    /// @param source Source column text.
    /// @param message Human-readable state message.
    /// @return Newly-created ListBox item, or null if the list box is null.
    expose func AddToolSuccessRow(listBox: GUI.ListBox,
                                  source: String,
                                  message: String) -> Any {
        return AddToolStateRow(listBox, "OK", source, message, TOOL_COLOR_SUCCESS);
    }

    expose func ProblemSeverityLabel(severity: String) -> String {
        return tool_panel_text.ProblemSeverityLabel(severity);
    }

    expose func PadToolColumn(text: String, width: Integer) -> String {
        return tool_panel_text.PadToolColumn(text, width);
    }

    expose func TrimToolText(text: String, width: Integer) -> String {
        return tool_panel_text.TrimToolText(text, width);
    }

    expose func ApplyProblemSeverityColor(item: Any, severity: String) {
        if item == null { return; }
        GUI.ListBox.ItemSetTextColor(item, tool_panel_text.ProblemSeverityColor(severity));
    }

    expose func ApplyOutputLineColor(item: Any, line: String) {
        if item == null { return; }
        var color = tool_panel_text.OutputLineColor(line);
        if color != 0 {
            GUI.ListBox.ItemSetTextColor(item, color);
        }
    }

    expose func FormatDiagnosticsSummary(errors: Integer,
                                         warnings: Integer,
                                         notes: Integer) -> String {
        return tool_panel_text.FormatDiagnosticsSummary(errors, warnings, notes);
    }

    expose func DiagnosticsSummaryColor(errors: Integer,
                                        warnings: Integer,
                                        notes: Integer) -> Integer {
        return tool_panel_text.DiagnosticsSummaryColor(errors, warnings, notes);
    }

    expose func FormatLanguageName(languageName: String) -> String {
        return tool_panel_text.FormatLanguageName(languageName);
    }

    expose func FinishProblems(problemCount: Integer) {
        if problemCount > 0 {
            problemsHaveDiagnostics = true;
            ShowProblemsPanel();
        } else {
            problemsHaveDiagnostics = false;
            AddCleanProblemsRow();
            HideProblemsPanel();
        }
    }

    /// @brief Add a compact clean-state row to the Problems list.
    /// @details `BeginProblems` has already inserted the table header before this
    ///          method is called. Keeping a clean row in the list lets users
    ///          revisit the Problems tab and see when the latest check produced
    ///          no diagnostics, while `FinishProblems` can still hide the panel
    ///          so it does not consume vertical space after clean builds.
    hide func AddCleanProblemsRow() {
        AddToolSuccessRow(diagListBox, "build", "No diagnostics from the latest check");
    }

    /// @brief Hide every bottom tool panel surface. Each Show*Panel calls this
    ///        first, then reveals only its own — so adding a panel can never leave
    ///        two overlapping (the bug class the old per-function hide lists risked).
    hide func HideAllToolPanels() {
        diagListBox.SetVisible(false);
        outputPane.SetVisible(false);
        outputListBox.SetVisible(false);
        searchListBox.SetVisible(false);
        referencesListBox.SetVisible(false);
        debugListBox.SetVisible(false);
        variablesListBox.SetVisible(false);
        callStackListBox.SetVisible(false);
        terminalPanel.SetVisible(false);
    }

    expose func ShowProblemsPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolProblemsTab);
        activeToolPanelKind = tool_panel_model.PANEL_PROBLEMS;
        HideAllToolPanels();
        diagListBox.SetVisible(true);
    }

    expose func HideProblemsPanel() {
        diagListBox.SetVisible(false);
        ShowFallbackToolPanel();
    }

    expose func ShowOutputPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolOutputTab);
        activeToolPanelKind = tool_panel_model.PANEL_OUTPUT;
        HideAllToolPanels();
        if outputPaneMode {
            outputPane.SetVisible(true);
        } else {
            outputListBox.SetVisible(true);
        }
    }

    expose func HideOutputPanel() {
        outputPane.SetVisible(false);
        outputListBox.SetVisible(false);
        ShowFallbackToolPanel();
    }

    expose func ShowSearchPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolSearchTab);
        activeToolPanelKind = tool_panel_model.PANEL_SEARCH;
        HideAllToolPanels();
        searchListBox.SetVisible(true);
    }

    expose func HideSearchPanel() {
        searchListBox.SetVisible(false);
        ShowFallbackToolPanel();
    }

    expose func ShowReferencesPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolReferencesTab);
        activeToolPanelKind = tool_panel_model.PANEL_REFERENCES;
        HideAllToolPanels();
        referencesListBox.SetVisible(true);
    }

    expose func HideReferencesPanel() {
        referencesListBox.SetVisible(false);
        ShowFallbackToolPanel();
    }

    expose func ShowVariablesPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolVariablesTab);
        activeToolPanelKind = tool_panel_model.PANEL_VARIABLES;
        HideAllToolPanels();
        variablesListBox.SetVisible(true);
    }

    expose func ShowCallStackPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolCallStackTab);
        activeToolPanelKind = tool_panel_model.PANEL_CALL_STACK;
        HideAllToolPanels();
        callStackListBox.SetVisible(true);
    }

    expose func ShowDebugPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolDebugTab);
        activeToolPanelKind = tool_panel_model.PANEL_DEBUG;
        HideAllToolPanels();
        debugListBox.SetVisible(true);
    }

    expose func ShowTerminalPanel() {
        toolTabBar.SetVisible(true);
        toolTabBar.SetActive(toolTerminalTab);
        activeToolPanelKind = tool_panel_model.PANEL_TERMINAL;
        HideAllToolPanels();
        terminalPanel.SetVisible(true);
        if terminalPane != null { terminalPane.Focus(); }
    }

    /// @brief Hide the integrated terminal panel without destroying its session.
    /// @details This powers the command-palette/menu toggle behavior. The PTY
    ///          remains alive so long-running commands keep producing output and
    ///          can be resumed by showing the terminal again.
    expose func HideTerminalPanel() {
        terminalPanel.SetVisible(false);
        if activeToolPanelKind == tool_panel_model.PANEL_TERMINAL {
            ShowFallbackToolPanelWithoutTerminal();
        }
    }

    /// @brief Toggle the terminal panel's visible state.
    expose func ToggleTerminalPanel() {
        if terminalPanel != null and terminalPanel.IsVisible() {
            HideTerminalPanel();
        } else {
            ShowTerminalPanel();
        }
    }

    /// @brief Return true when the terminal panel container is visible.
    expose func IsTerminalPanelVisible() -> Boolean {
        return terminalPanel != null and terminalPanel.IsVisible();
    }

    expose func HideDebugPanel() {
        debugListBox.SetVisible(false);
        ShowFallbackToolPanel();
    }

    /// @brief Select the best remaining bottom tool panel after one is hidden.
    /// @details All Hide*Panel entry points converge here so the fallback order
    ///          and empty-state handling stay consistent. It preserves existing
    ///          content instead of deleting rows, and hides the tab strip only
    ///          when no tool panel has visible content left.
    hide func ShowFallbackToolPanel() {
        if HasOutputContent() {
            ShowOutputPanel();
        } else if HasActiveProblemsContent() {
            ShowProblemsPanel();
        } else if searchListBox.Count > 0 {
            ShowSearchPanel();
        } else if referencesListBox.Count > 0 {
            ShowReferencesPanel();
        } else if variablesListBox.Count > 0 {
            ShowVariablesPanel();
        } else if callStackListBox.Count > 0 {
            ShowCallStackPanel();
        } else if debugListBox.Count > 0 {
            ShowDebugPanel();
        } else {
            toolTabBar.SetVisible(false);
            activeToolPanelKind = tool_panel_model.PANEL_NONE;
        }
    }

    /// @brief Select the best remaining tool panel after hiding Terminal.
    /// @details Terminal is intentionally excluded so Toggle Terminal can close
    ///          the panel instead of immediately selecting it again as fallback.
    hide func ShowFallbackToolPanelWithoutTerminal() {
        if HasOutputContent() {
            ShowOutputPanel();
        } else if HasActiveProblemsContent() {
            ShowProblemsPanel();
        } else if searchListBox.Count > 0 {
            ShowSearchPanel();
        } else if referencesListBox.Count > 0 {
            ShowReferencesPanel();
        } else if variablesListBox.Count > 0 {
            ShowVariablesPanel();
        } else if callStackListBox.Count > 0 {
            ShowCallStackPanel();
        } else if debugListBox.Count > 0 {
            ShowDebugPanel();
        } else {
            toolTabBar.SetVisible(false);
            activeToolPanelKind = tool_panel_model.PANEL_NONE;
        }
    }

    /// @brief Return whether Problems should claim fallback tool-panel space.
    /// @details The Problems list can intentionally keep a clean-state row after
    ///          a successful check. Fallback selection should only auto-open the
    ///          panel for real diagnostics, while explicit tab selection can
    ///          still display the retained clean row.
    /// @return True when the Problems list contains active diagnostics.
    hide func HasActiveProblemsContent() -> Boolean {
        return problemsHaveDiagnostics and diagListBox.Count > 0;
    }

    expose func PumpToolTabs() {
        if toolTabBar == null { return; }
        if !toolTabBar.WasChanged() { return; }
        var idx = toolTabBar.GetActiveIndex();
        if idx == tool_panel_model.TAB_PROBLEMS {
            if diagListBox.Count > 0 { ShowProblemsPanel(); }
        } else if idx == tool_panel_model.TAB_OUTPUT {
            if HasOutputContent() { ShowOutputPanel(); }
        } else if idx == tool_panel_model.TAB_SEARCH {
            ShowSearchPanel();
        } else if idx == tool_panel_model.TAB_REFERENCES {
            ShowReferencesPanel();
        } else if idx == tool_panel_model.TAB_VARIABLES {
            ShowVariablesPanel();
        } else if idx == tool_panel_model.TAB_CALL_STACK {
            ShowCallStackPanel();
        } else if idx == tool_panel_model.TAB_DEBUG {
            ShowDebugPanel();
        } else if idx == tool_panel_model.TAB_TERMINAL {
            ShowTerminalPanel();
        } else {
            toolTabBar.SetActive(toolOutputTab);
            if HasOutputContent() {
                ShowOutputPanel();
            } else if HasActiveProblemsContent() {
                ShowProblemsPanel();
            } else if searchListBox.Count > 0 {
                ShowSearchPanel();
            } else if referencesListBox.Count > 0 {
                ShowReferencesPanel();
            } else if debugListBox.Count > 0 {
                ShowDebugPanel();
            }
        }
    }

    /// @brief Toggle the sidebar by collapsing the SplitPane to 0% width.
    expose func ToggleSidebar() {
        if sidebarVisible {
            sidebarVisible = false;
            splitPane.SetPosition(0.0);
        } else {
            sidebarVisible = true;
            splitPane.SetPosition(0.20);
        }
    }

    expose func SelectSurface(kind: Integer) {
        activeSurfaceKind = kind;
        activeDocumentSurfaceKind = kind;
        editorRow.SetVisible(true);
    }

    /// @brief Resize to scalePct% of the monitor and center on screen.
    /// @details Uses the runtime's monitor dimensions for the math —
    ///          works on any screen resolution including HiDPI.
    expose func CenterAndSize(scalePct: Integer) {
        var mw = app.GetMonitorWidth();
        var mh = app.GetMonitorHeight();
        if mw <= 0 { mw = 1440; }
        if mh <= 0 { mh = 900; }
        var w = (mw * scalePct) / 100;
        var h = (mh * scalePct) / 100;
        var edgeGap = 96;
        var maxW = 1540;
        var maxH = 980;
        if maxW > mw - edgeGap { maxW = mw - edgeGap; }
        if maxH > mh - edgeGap { maxH = mh - edgeGap; }
        if maxW > 0 and w > maxW { w = maxW; }
        if maxH > 0 and h > maxH { h = maxH; }
        if w > mw - 32 { w = mw - 32; }
        if h > mh - 32 { h = mh - 32; }
        if mw > 760 and w < 720 { w = 720; }
        if mh > 560 and h < 520 { h = 520; }
        if w < 1 { w = 1; }
        if h < 1 { h = 1; }
        app.SetWindowSize(w, h);
        app.SetPosition((mw - w) / 2, (mh - h) / 2);
    }
}
