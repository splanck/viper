module build_system;

bind "diagnostic";
bind "run_config";
bind Viper.String as Str;
bind Viper.Core.Convert as Convert;
bind Viper.Collections.Seq as Seq;
bind Viper.Collections.Map as Map;
bind Viper.Core.Object as Obj;
bind Viper.System.Process as Process;
bind Viper.System.Environment as Env;
bind Viper.System.Machine as Machine;
bind Viper.IO.Path as Path;
bind Viper.IO as IO;
bind Json = Viper.Text.Json;

// ============================================================================
// MODULE: build_system
// PURPOSE: Compile and run Zia/BASIC programs from the IDE.
//
// WHERE-THIS-FITS: Build and debug command handlers create jobs here; main.zia
//          pumps UpdateJob every frame and AppShell renders the streamed output.
//
// TEACHING-NOTE: Build/run processes are long-lived external state. Keep process
//          handles, output deltas, cancellation, elapsed time, and diagnostic
//          parsing together so command handlers remain thin request initiators.
//          Diagnostic format: "file.zia:line:col: error[code]: message".
// ============================================================================

final MAX_BUILD_OUTPUT_CHARS = 250000;
final MAX_BUILD_OUTPUT_DELTA_CHARS = 65536;

class BuildSystem {
    // Build state
    expose Boolean isBuilding;
    expose Boolean isRunning;
    expose Boolean lastBuildSuccess;

    // Build output
    expose String buildOutput;
    expose String outputDelta;
    expose String compilerPath;

    // Build timing ("1.2s" after last build)
    expose String lastBuildTime;
    expose Integer startMs;
    expose Integer exitCode;
    expose String activeAction;
    expose String activeName;
    expose run_config.RunConfig activeConfig;
    expose Process.Handle processHandle;

    // Parsed diagnostics
    expose List[diagnostic.Diagnostic] diagnostics;

    expose func init() {
        isBuilding = false;
        isRunning = false;
        lastBuildSuccess = false;
        buildOutput = "";
        outputDelta = "";
        compilerPath = "viper";
        lastBuildTime = "";
        startMs = 0;
        exitCode = -1;
        activeAction = "";
        activeName = "";
        activeConfig = null;
        processHandle = null;
        diagnostics = [];
    }

    expose func IsActive() -> Boolean {
        return isBuilding or isRunning;
    }

    expose func StartConfig(cfg: run_config.RunConfig) -> Boolean {
        if cfg == null { return false; }
        if IsActive() { return false; }

        activeConfig = cfg;
        activeAction = cfg.action;
        activeName = cfg.name;
        buildOutput = "";
        outputDelta = "";
        diagnostics = [];
        exitCode = -1;
        lastBuildSuccess = false;
        lastBuildTime = "";
        startMs = Viper.Time.GetTickCount();

        // The Process runtime spawns via execve(), which neither searches PATH nor
        // resolves a bare name against anything except the child's working directory
        // (the edited file's folder). Resolve an absolute path up front so a build
        // actually starts, and report a precise error instead of a silent exit 127.
        var resolved = ResolveCompiler(cfg.program);
        if resolved == "" {
            buildOutput = CompilerNotFoundMessage(cfg.program);
            Finish(-1);
            return false;
        }
        compilerPath = resolved;

        if cfg.action == run_config.ACTION_BUILD {
            isBuilding = true;
            isRunning = false;
        } else {
            isBuilding = false;
            isRunning = true;
        }

        processHandle = Process.StartWithEnv(resolved, cfg.args, cfg.workingDirectory, cfg.env);
        if processHandle == null or processHandle.IsValid() == false {
            buildOutput = "Could not start process: " + cfg.program;
            Finish(-1);
            return false;
        }
        return true;
    }

    // ----------------------------------------------------------------------
    // Compiler resolution
    // ----------------------------------------------------------------------

    /// @brief Resolve a runnable absolute path for the requested program.
    /// @details For the default "viper" compiler, searches an explicit override,
    ///          the IDE's own folder (installed layout), the developer build tree,
    ///          and finally PATH. Returns "" when nothing is found. Custom
    ///          project-supplied programs are resolved on their own merits and are
    ///          never silently replaced by viper.
    expose func ResolveCompiler(preferred: String) -> String {
        var name = preferred;
        if name == "" { name = "viper"; }

        if name != "viper" {
            return ResolveBinary(name);
        }

        var exe = ExeName();

        // 1. Explicit override wins. Absolutise it: execve resolves a relative
        //    path against the child's working directory (the edited file's folder),
        //    not the IDE's, so a relative override would point at the wrong place.
        var envBin = EnvValue("VIPER_BINARY");
        if envBin != "" and IO.File.Exists(envBin) {
            return Path.Abs(envBin);
        }

        // 2. Installed layout: viper ships next to the IDE binary.
        var exeDir = Path.ExeDir();
        if exeDir != "" {
            var colocated = Path.Join(exeDir, exe);
            if IO.File.Exists(colocated) {
                return colocated;
            }
            // 3. Developer build tree (viperide/bin -> build/src/tools/viper).
            var devA = Path.Norm(Path.Join(exeDir, Path.Join("../../build/src/tools/viper", exe)));
            if IO.File.Exists(devA) {
                return devA;
            }
            var devB = Path.Norm(Path.Join(exeDir, Path.Join("../build/src/tools/viper", exe)));
            if IO.File.Exists(devB) {
                return devB;
            }
        }

        // 4. Explicit build directory (honours the build scripts' VIPER_BUILD_DIR).
        var buildDir = EnvValue("VIPER_BUILD_DIR");
        if buildDir != "" {
            var fromBuild = Path.Norm(Path.Join(buildDir, Path.Join("src/tools/viper", exe)));
            if IO.File.Exists(fromBuild) {
                return fromBuild;
            }
        }

        // 5. Manual PATH scan (execve won't do it for us).
        return ResolveBinary(exe);
    }

    /// @brief Resolve a single binary name to an absolute path: an absolute path is
    ///        used as-is when it exists; a bare name is searched on PATH.
    func ResolveBinary(name: String) -> String {
        if name == "" { return ""; }
        if Path.IsAbs(name) {
            if IO.File.Exists(name) { return name; }
            return "";
        }
        var pathVar = EnvValue("PATH");
        if pathVar == "" { return ""; }
        var entries = Str.Split(pathVar, ListSep());
        var i = 0;
        while i < Seq.get_Length(entries) {
            var entry = Obj.ToString(Seq.Get(entries, i));
            if entry != "" {
                var cand = Path.Join(entry, name);
                if IO.File.Exists(cand) { return Path.Abs(cand); }
            }
            i = i + 1;
        }
        return "";
    }

    func EnvValue(key: String) -> String {
        if Env.HasVariable(key) == false { return ""; }
        return Env.GetVariable(key);
    }

    func ExeName() -> String {
        if Machine.OS == "windows" { return "viper.exe"; }
        return "viper";
    }

    func ListSep() -> String {
        if Machine.OS == "windows" { return ";"; }
        return ":";
    }

    func CompilerNotFoundMessage(requested: String) -> String {
        var name = requested;
        if name == "" { name = "viper"; }
        return "Could not find the '" + name + "' compiler.\n"
            + "Searched VIPER_BINARY, the IDE folder, the build tree, and PATH.\n"
            + "Fix: add viper to your PATH, or set VIPER_BINARY=/full/path/to/viper.";
    }

    expose func Update() -> Boolean {
        if processHandle == null { return false; }
        var out = processHandle.ReadStdout();
        var err = processHandle.ReadStderr();
        AppendOutput(out);
        AppendOutput(err);

        if processHandle.IsRunning() {
            return true;
        }
        out = processHandle.ReadStdout();
        err = processHandle.ReadStderr();
        AppendOutput(out);
        AppendOutput(err);
        Finish(processHandle.ExitCode());
        processHandle.Destroy();
        processHandle = null;
        return false;
    }

    expose func Stop() -> Boolean {
        if processHandle == null { return false; }
        var killed = processHandle.Kill();
        var out = processHandle.ReadStdout();
        var err = processHandle.ReadStderr();
        AppendOutput(out);
        AppendOutput(err);
        Finish(-1);
        processHandle.Destroy();
        processHandle = null;
        AppendOutput("\n[stopped]\n");
        return killed;
    }

    func AppendOutput(text: String) {
        if text == "" { return; }
        buildOutput = AppendBoundedOutput(buildOutput, text,
                                          "[output truncated]\n",
                                          MAX_BUILD_OUTPUT_CHARS);
        outputDelta = AppendBoundedOutput(outputDelta, text,
                                          "[output delta truncated]\n",
                                          MAX_BUILD_OUTPUT_DELTA_CHARS);
    }

    /// @brief Append text to a bounded output buffer.
    /// @details Build processes may emit large logs in a single frame. Keeping
    ///          both the durable output cache and the per-frame delta bounded
    ///          prevents repeated string growth from dominating the IDE loop.
    /// @param existing Current buffer content.
    /// @param text New text to append.
    /// @param prefix Visible marker inserted when older text is discarded.
    /// @param maxChars Maximum number of tail characters to keep after prefix.
    /// @return Combined output, trimmed from the front when necessary.
    func AppendBoundedOutput(existing: String,
                             text: String,
                             prefix: String,
                             maxChars: Integer) -> String {
        var combined = existing + text;
        if maxChars <= 0 {
            return combined;
        }
        var textLen = Str.Length(text);
        if textLen >= maxChars {
            return prefix + Str.Mid(text, textLen - maxChars + 1);
        }
        var existingLen = Str.Length(existing);
        var keepExisting = maxChars - textLen;
        if existingLen > keepExisting {
            return prefix + Str.Mid(existing, existingLen - keepExisting + 1) + text;
        }
        return combined;
    }

    func Finish(code: Integer) {
        exitCode = code;
        isBuilding = false;
        isRunning = false;
        lastBuildSuccess = code == 0;
        lastBuildTime = FormatDuration(Viper.Time.GetTickCount() - startMs);
        ParseBuildOutput();
    }

    /// @brief Format an elapsed millisecond count as a readable duration: "850ms"
    ///        under a second, "1.2s" at or above one second (rounded to a tenth).
    expose func FormatDuration(ms: Integer) -> String {
        var millis = ms;
        if millis < 0 { millis = 0; }
        if millis < 1000 { return "" + millis + "ms"; }
        var tenths = (millis + 50) / 100;
        var whole = tenths / 10;
        var frac = tenths - whole * 10;
        return "" + whole + "." + frac + "s";
    }

    // Parse build output for diagnostics (error/warning lines).
    // Populates `diagnostics` list. Success is determined by exit code in callers.
    func ParseBuildOutput() {
        diagnostics = [];
        if ParseJsonDiagnostics(buildOutput) {
            return;
        }
        var lines = Str.Split(buildOutput, "\n");
        var i = 0;
        while i < Seq.get_Length(lines) {
            var diag = ParseDiagnosticLine(Obj.ToString(Seq.Get(lines, i)));
            if diag != null {
                diagnostics.add(diag);
            }
            i = i + 1;
        }
    }

    /// @brief Parse `--diagnostic-format=json` output from the viper CLI.
    /// @details The CLI writes a compact object with a `diagnostics` array. This
    ///          parser accepts that object even when stdout/stderr wrappers add
    ///          text before or after it, and returns false so callers can fall
    ///          back to legacy text parsing when JSON is absent.
    /// @param text Complete captured build output.
    /// @return true when a JSON diagnostics object was found and consumed.
    func ParseJsonDiagnostics(text: String) -> Boolean {
        var start = Str.IndexOf(text, "{\"diagnostics\"");
        if start == 0 { return false; }
        var endPos = JsonObjectEnd(text, start);
        if endPos <= 0 { return false; }
        var jsonText = Str.MidLen(text, start, endPos - start + 1);
        if Json.IsValid(jsonText) == false { return false; }

        var root = Json.Parse(jsonText);
        var records = Map.Get(root, "diagnostics");
        if records == null { return false; }

        var i = 0;
        while i < Seq.get_Length(records) {
            var record = Seq.Get(records, i);
            var diag = DiagnosticFromJsonRecord(record);
            if diag != null {
                diagnostics.add(diag);
            }
            i = i + 1;
        }
        return true;
    }

    /// @brief Find the balanced end of a JSON object embedded in process output.
    /// @details Compiler diagnostics may be preceded or followed by human text,
    ///          and that trailing text can contain braces. This scanner respects
    ///          JSON strings and escapes so `ParseJsonDiagnostics` extracts the
    ///          first complete object instead of slicing to the last brace.
    /// @param text Complete captured process output.
    /// @param start One-based index of the opening `{`.
    /// @return One-based index of the matching `}`, or 0 when incomplete.
    func JsonObjectEnd(text: String, start: Integer) -> Integer {
        var depth = 0;
        var inString = false;
        var escaped = false;
        var pos = start;
        while pos <= Str.Length(text) {
            var ch = Str.MidLen(text, pos, 1);
            if inString {
                if escaped {
                    escaped = false;
                } else if ch == "\\" {
                    escaped = true;
                } else if ch == "\"" {
                    inString = false;
                }
            } else {
                if ch == "\"" {
                    inString = true;
                } else if ch == "{" {
                    depth = depth + 1;
                } else if ch == "}" {
                    depth = depth - 1;
                    if depth == 0 { return pos; }
                }
            }
            pos = pos + 1;
        }
        return 0;
    }

    /// @brief Convert one CLI JSON diagnostic record to the IDE diagnostic model.
    /// @details Prefer the primary location object, then fall back to the range
    ///          begin object because some diagnostics only have concrete ranges.
    func DiagnosticFromJsonRecord(record: Any) -> diagnostic.Diagnostic? {
        if record == null { return null; }
        var loc = Map.Get(record, "location");
        var range = Map.Get(record, "range");
        var path = "";
        var lineNo = 0;
        var colNo = 0;
        if loc != null {
            path = Map.GetStr(loc, "file");
            lineNo = Map.GetInt(loc, "line");
            colNo = Map.GetInt(loc, "column");
        }
        if path == "" or lineNo <= 0 or colNo <= 0 {
            if range != null {
                var begin = Map.Get(range, "begin");
                if begin != null {
                    path = Map.GetStr(begin, "file");
                    lineNo = Map.GetInt(begin, "line");
                    colNo = Map.GetInt(begin, "column");
                }
            }
        }
        if path == "" or lineNo <= 0 or colNo <= 0 { return null; }

        var diag = new diagnostic.Diagnostic();
        diag.filePath = path;
        diag.line = lineNo;
        diag.column = colNo;
        diag.endLine = lineNo;
        diag.endColumn = colNo + 1;
        if range != null {
            var endLoc = Map.Get(range, "end");
            if endLoc != null {
                var parsedEndLine = Map.GetInt(endLoc, "line");
                var parsedEndColumn = Map.GetInt(endLoc, "column");
                if parsedEndLine > 0 and parsedEndColumn > 0 {
                    diag.endLine = parsedEndLine;
                    diag.endColumn = parsedEndColumn;
                }
            }
        }
        var sev = Map.GetStr(record, "severity");
        diag.severity = diagnostic.SEV_ERROR;
        if sev == "warning" {
            diag.severity = diagnostic.SEV_WARNING;
        } else if sev == "note" or sev == "info" {
            diag.severity = diagnostic.SEV_INFO;
        }
        diag.code = Map.GetStr(record, "code");
        diag.message = Map.GetStr(record, "message");
        var notes = Map.Get(record, "notes");
        if notes != null {
            diag.noteCount = Seq.get_Length(notes);
            if diag.noteCount > 0 {
                diag.noteSummary = Map.GetStr(Seq.Get(notes, 0), "message");
            }
        }
        var fixits = Map.Get(record, "fixits");
        if fixits != null {
            diag.fixitCount = Seq.get_Length(fixits);
            if diag.fixitCount > 0 {
                diag.fixitMessage = Map.GetStr(Seq.Get(fixits, 0), "message");
                if diag.fixitMessage == "" {
                    diag.fixitMessage = Map.GetStr(Seq.Get(fixits, 0), "label");
                }
            }
        }
        return diag;
    }

    expose func ParseDiagnosticLine(line: String) -> diagnostic.Diagnostic? {
        var severity = "error";
        var sevPos = Str.IndexOf(line, ": error[");
        if sevPos == 0 {
            sevPos = Str.IndexOf(line, ": warning[");
            severity = "warning";
        }
        if sevPos == 0 { return null; }

        var before = Str.Left(line, sevPos - 1);
        var codeStart = sevPos + Str.Length(": " + severity + "[");
        var msgSep = Str.IndexOfFrom(line, codeStart, "]: ");
        if msgSep == 0 { return null; }
        var code = Str.MidLen(line, codeStart, msgSep - codeStart);
        var msg = Str.Mid(line, msgSep + 3);

        var colSep = Str.LastIndexOf(before, ":");
        if colSep <= 0 { return null; }
        var colText = Str.Mid(before, colSep + 1);
        var pathAndLine = Str.Left(before, colSep - 1);
        var lineSep = Str.LastIndexOf(pathAndLine, ":");
        if lineSep <= 0 { return null; }
        var lineText = Str.Mid(pathAndLine, lineSep + 1);
        var path = Str.Left(pathAndLine, lineSep - 1);
        var lineNo = Convert.ToInt(lineText);
        var colNo = Convert.ToInt(colText);
        if path == "" or lineNo <= 0 or colNo <= 0 { return null; }

        var diag = new diagnostic.Diagnostic();
        diag.filePath = path;
        diag.line = lineNo;
        diag.column = colNo;
        diag.endLine = lineNo;
        diag.endColumn = colNo + 1;
        diag.severity = diagnostic.SEV_ERROR;
        if severity == "warning" {
            diag.severity = diagnostic.SEV_WARNING;
        }
        diag.code = code;
        diag.message = msg;
        return diag;
    }

    // Get the number of errors.
    expose func GetErrorCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < diagnostics.count() {
            var diag = diagnostics.get(i);
            if diag.severity == 0 {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }

    // Get the number of warnings.
    expose func GetWarningCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < diagnostics.count() {
            var diag = diagnostics.get(i);
            if diag.severity == 1 {
                count = count + 1;
            }
            i = i + 1;
        }
        return count;
    }

    // Get the build output text.
    expose func GetOutput() -> String {
        return buildOutput;
    }

    expose func TakeOutputDelta() -> String {
        var delta = outputDelta;
        outputDelta = "";
        return delta;
    }

    // Get the elapsed time of the last build ("1.2s").
    expose func GetBuildTime() -> String {
        return lastBuildTime;
    }

    // Clear diagnostics.
    expose func ClearDiagnostics() {
        diagnostics = [];
    }
}
