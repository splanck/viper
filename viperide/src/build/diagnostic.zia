module diagnostic;

// ============================================================================
// MODULE: diagnostic
// PURPOSE: Shared compiler diagnostic record for build output and Problems.
//
// WHERE-THIS-FITS: BuildSystem and live diagnostics convert toolchain output
//          into this model before UI panels, status text, or navigation consume
//          it.
//
// TEACHING-NOTE: Diagnostics are data, not display strings. Keep severity, range,
//          code, notes, and fix-it metadata structured so UI surfaces can change
//          without losing navigation or actions.
// ============================================================================

final SEV_ERROR   = 0;
final SEV_WARNING = 1;
final SEV_INFO    = 2;

class Diagnostic {
    expose String filePath;
    expose Integer line;
    expose Integer column;
    expose Integer endLine;
    expose Integer endColumn;
    expose Integer severity;   // SEV_ERROR, SEV_WARNING, or SEV_INFO
    expose String message;
    expose String code;
    expose String noteSummary;
    expose Integer noteCount;
    expose String fixitMessage;
    expose Integer fixitCount;

    expose func init() {
        filePath = "";
        line = 0;
        column = 0;
        endLine = 0;
        endColumn = 0;
        severity = SEV_ERROR;
        message = "";
        code = "";
        noteSummary = "";
        noteCount = 0;
        fixitMessage = "";
        fixitCount = 0;
    }
}
