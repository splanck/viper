module run_config;

bind "../core/document";
bind "../core/project_manager";
bind "../services/file_utils";

bind Seq = Viper.Collections.Seq;
bind Obj = Viper.Core.Object;
bind Path = Viper.IO.Path;
bind Str = Viper.String;

final ACTION_BUILD = "build";
final ACTION_RUN = "run";
final KIND_CURRENT_FILE = "current-file";
final KIND_PROJECT_ENTRY = "project-entry";
final KIND_CUSTOM = "custom";

class RunConfig {
    expose String name;
    expose String action;
    expose String kind;
    expose String program;
    expose Any args;
    expose String workingDirectory;
    expose Any env;
    expose String problemMatcher;
    expose String targetPath;

    expose func init() {
        name = "";
        action = ACTION_RUN;
        kind = KIND_CURRENT_FILE;
        program = "viper";
        args = Seq.New();
        workingDirectory = "";
        env = null;
        problemMatcher = "viper";
        targetPath = "";
    }
}

func ForDocument(action: String,
                 doc: document.Document,
                 projMgr: project_manager.ProjectManager) -> RunConfig {
    var cfg = new RunConfig();
    cfg.action = action;
    if action == ACTION_BUILD {
        cfg.name = "Build";
    } else {
        cfg.name = "Run";
    }

    var root = "";
    var lang = "";
    if doc != null {
        lang = doc.language;
    }
    if projMgr != null and projMgr.project != null and projMgr.project.isOpen {
        root = projMgr.project.rootPath;
        lang = projMgr.project.lang;
        cfg.kind = KIND_PROJECT_ENTRY;
        cfg.targetPath = root;
        cfg.workingDirectory = root;
        cfg.problemMatcher = "viper";
        ApplyProjectOverrides(cfg, projMgr);
    } else if doc != null {
        cfg.kind = KIND_CURRENT_FILE;
        cfg.targetPath = doc.filePath;
        cfg.workingDirectory = Path.Dir(doc.filePath);
    }

    if cfg.program == "" { cfg.program = "viper"; }
    if Seq.get_Length(cfg.args) == 0 {
        if action == ACTION_BUILD {
            Seq.Push(cfg.args, "build");
        } else {
            Seq.Push(cfg.args, "run");
        }
        if cfg.program == "viper" {
            Seq.Push(cfg.args, "--diagnostic-format=json");
        }
        Seq.Push(cfg.args, cfg.targetPath);
    }
    if lang == "basic" and cfg.kind == KIND_CURRENT_FILE and cfg.program == "viper" {
        // viper run/build handles BASIC directly; keep this branch explicit so
        // project configs can override BASIC without changing call sites.
    }
    return cfg;
}

func ApplyProjectOverrides(cfg: RunConfig,
                           projMgr: project_manager.ProjectManager) {
    if projMgr == null or projMgr.project == null { return; }
    var proj = projMgr.project;
    if proj.problemMatcher != "" {
        cfg.problemMatcher = proj.problemMatcher;
    }
    if proj.workingDirectory != "" {
        cfg.workingDirectory = Path.Join(proj.rootPath, proj.workingDirectory);
    }
    if cfg.action == ACTION_BUILD {
        if proj.buildProgram != "" { cfg.program = proj.buildProgram; }
        if proj.buildArgs != "" {
            cfg.args = SplitArgsWithTarget(proj.buildArgs, cfg.targetPath);
            cfg.kind = KIND_CUSTOM;
        }
    } else {
        if proj.runProgram != "" { cfg.program = proj.runProgram; }
        if proj.runArgs != "" {
            cfg.args = SplitArgsWithTarget(proj.runArgs, cfg.targetPath);
            cfg.kind = KIND_CUSTOM;
        }
    }
}

func SplitArgsWithTarget(text: String, targetPath: String) -> Any {
    var items = SplitArgs(text);
    var out = Seq.New();
    var i = 0;
    while i < Seq.get_Length(items) {
        var item = Obj.ToString(Seq.Get(items, i));
        if item == "{target}" {
            item = targetPath;
        }
        Seq.Push(out, item);
        i = i + 1;
    }
    return out;
}

/// @brief Split a project run/build argument string into an argv sequence.
/// @details Supports whitespace-delimited tokens, single and double quoted
///          spans, and backslash escapes inside or outside quotes. This keeps
///          project manifests compatible with paths containing spaces without
///          invoking a shell or doing platform-specific command parsing.
/// @param text User-authored argument string from viper.project.
/// @return Seq of argv tokens with quotes removed and escapes resolved.
func SplitArgs(text: String) -> Any {
    var items = Seq.New();
    var token = "";
    var quote = "";
    var escaping = false;
    var i = 1;
    while i <= Str.get_Length(text) {
        var ch = Str.MidLen(text, i, 1);
        if escaping {
            token = token + ch;
            escaping = false;
        } else if ch == "\\" {
            escaping = true;
        } else if ch == "\"" or ch == "'" {
            if quote == "" {
                quote = ch;
            } else if quote == ch {
                quote = "";
            } else {
                token = token + ch;
            }
        } else if (ch == " " or ch == "\t") and quote == "" {
            if token != "" {
                Seq.Push(items, token);
                token = "";
            }
        } else {
            token = token + ch;
        }
        i = i + 1;
    }
    if escaping {
        token = token + "\\";
    }
    if token != "" {
        Seq.Push(items, token);
    }
    return items;
}
