// test_math_extra.zia — Quat, Scanner, CompiledPattern
module TestMathExtra;

bind Viper.Terminal;

func start() {
    var q = Viper.Math.Quat.Identity();
    SayNum(q.W);

    var sc = new Viper.Text.Scanner("hello world");
    Say(sc.ReadIdent());

    var pat = new Viper.Text.CompiledPattern("[0-9]+");
    var matches = pat.FindAll("a1b22c333");
    SayInt(matches.Length);

    Say("done");
}
