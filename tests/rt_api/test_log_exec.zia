// test_log_exec.zia — Log, Exec, NumberFormat
module TestLogExec;

bind Viper.Terminal;
bind Viper.Diagnostics.Log;
bind Viper.System.Exec;
bind Viper.Text.Fmt;

func start() {
    SayInt(Viper.Diagnostics.Log.LevelDebug);
    SayInt(Viper.Diagnostics.Log.LevelInfo);
    SayInt(Viper.Diagnostics.Log.LevelWarn);
    SayInt(Viper.Diagnostics.Log.LevelError);
    SayInt(Viper.Diagnostics.Log.LevelOff);
    SayInt(Viper.Diagnostics.Log.Level);
    SayBool(Viper.Diagnostics.Log.Enabled(Viper.Diagnostics.Log.LevelDebug));
    Viper.Diagnostics.Log.Info("test info message");
    Viper.Diagnostics.Log.Warn("test warn message");
    Viper.Diagnostics.Log.Error("test error message");

    Say(ShellCapture("echo hello"));

    Say(Viper.Text.Fmt.Size(1048576));
    Say(Viper.Text.Fmt.Ordinal(1));
    Say(Viper.Text.Fmt.Ordinal(2));
    Say(Viper.Text.Fmt.Ordinal(3));
    Say(Viper.Text.Fmt.Ordinal(11));
    Say(Viper.Text.Fmt.IntPad(42, 5, " "));
    Say(Viper.Text.Fmt.NumPct(0.756, 1));
    Say(Viper.Text.Fmt.IntGrouped(1234567, ","));
    Say(Viper.Text.Fmt.ToWords(42));
    Say(Viper.Text.Fmt.NumFixed(3.14159, 2));
    Say(Viper.Text.Fmt.Currency(1234.56, 2, "$"));

    Say("done");
}
