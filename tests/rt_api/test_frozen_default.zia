// test_frozen_default.zia — FrozenSet, FrozenMap, DefaultMap
module TestFrozenDefault;

bind Viper.Terminal;

func start() {
    var dm = Viper.Collections.DefaultMap.New(Viper.Core.Box.Str("N/A"));
    SayInt(dm.Count);
    dm.Set("name", "viper");
    dm.Set("lang", "zia");
    SayInt(dm.Count);
    SayBool(dm.Has("name"));
    SayBool(dm.Has("missing"));
    dm.Remove("lang");
    SayInt(dm.Count);
    dm.Clear();
    SayInt(dm.Count);

    var emptySet = Viper.Collections.FrozenSet.Empty();
    SayInt(emptySet.Count);

    var emptyMap = Viper.Collections.FrozenMap.Empty();
    SayInt(emptyMap.Count);

    Say("done");
}
