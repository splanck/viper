module TestViperIdePrimitives;

bind Viper.Terminal;

func start() {
    SayBool(Viper.Workspace.FileIndex.ShouldIgnore(".", "build/generated.zia", "build/"));

    var manifest = Viper.Project.Manifest.ParseText(
        "project Demo\nlang zia\nentry src/main.zia\nasset-root assets\ndefault-scene scenes/level.json\n");
    SayBool(manifest.GetBool("valid"));
    Say(manifest.GetStr("defaultScene"));

    var scene = Viper.Game.Scene.New(2, 2, 16, 16);
    var layer = scene.AddLayer("fg");
    scene.SetTile(layer, 1, 1, 7);
    scene.SetLayerAsset(layer, "tiles.png");
    SayInt(scene.GetTile(layer, 1, 1));
    SayInt(scene.AssetPaths().Length);

    var fuzzy = Viper.Text.FuzzyMatch.Match("VS", "ViperScene.zia");
    SayBool(fuzzy.GetBool("matched"));
    SayInt(fuzzy.GetInt("score"));

    var harness = Viper.GUI.TestHarness.New();
    harness.RegisterWidget("editor", "CodeEditor", "Editor", 0, 0, 320, 200);
    harness.SendMouse("down", 10, 10, 1);
    Say(harness.GetFocus());
    var snapshot = harness.CaptureRegion(0, 0, 32, 32);
    SayBool(Viper.GUI.TestHarness.AssertNonBlank(snapshot));

    var list = Viper.GUI.VirtualList.New(1000, 20, 100);
    list.SetRowId(42, "target");
    list.SelectId("target");
    SayInt(list.GetSelectedIndex());

    Say("done");
}
