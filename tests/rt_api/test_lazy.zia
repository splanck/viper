// test_lazy.zia — Lazy, LazySeq
module TestLazy;

bind Viper.Terminal;
bind Viper.Lazy;
bind Viper.LazySeq;

func start() {
    var lazy = Viper.Lazy.OfI64(42);
    SayInt(Viper.Lazy.GetI64(lazy));

    var seq = Viper.LazySeq.Range(1, 5, 1);
    var out = Viper.LazySeq.ToSeqN(seq, 3);
    SayInt(out.Length);

    Say("done");
}
