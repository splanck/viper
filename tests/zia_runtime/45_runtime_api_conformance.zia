module RuntimeTest45;

bind "./_support";
bind Viper.Text.Json;
bind Viper.Text.Fmt;
bind Viper.Math.Easing;
bind Viper.Collections.Map;

// EXPECT_OUT: RESULT: ok

func testCanonicalRuntimeSurface() {
    assertEqStr(Viper.Text.Fmt.Int(42), "42", "fmt_int");
    assertTrue(Viper.String.Has(Viper.Text.Fmt.Num(1.5), "1.5"), "fmt_num");

    var seq = new Viper.Collections.Seq();
    assertEqInt(seq.Count, 0, "seq_new_count");
    seq.Push("x");
    assertEqStr(Viper.Collections.Seq.GetStr(seq, 0), "x", "seq_new_sized_set");

    var list = Viper.Collections.List.New();
    assertEqInt(Viper.Collections.List.get_Count(list), 0, "list_count");
}

func testCollectionSnapshots() {
    var map = new Viper.Collections.Map();
    map.SetStr("name", "zia");
    map.SetInt("version", 1);
    assertEqInt(map.Keys().Count, 2, "map_keys_count");
    assertEqInt(map.Values().Count, 2, "map_values_count");
}

func testConstructorsAndRandom() {
    var ring = new Viper.Collections.Ring();
    assertGtInt(ring.Cap, 0, "ring_default_ctor");

    var a = new Viper.Math.Random(123);
    var b = new Viper.Math.Random(123);
    assertEqInt(a.NextInt(1000), b.NextInt(1000), "random_same_seed_first");
    assertEqInt(a.NextInt(1000), b.NextInt(1000), "random_same_seed_second");
    assertInRange(a.NextDouble(), 0.0, 1.0, "random_next_double");
    var ranged = a.Range(10, 20);
    assertGteInt(ranged, 10, "random_range_min");
    assertLteInt(ranged, 20, "random_range_max");
}

func testJsonMachineVecAndEasing() {
    var obj = NewObject();
    Viper.Collections.Map.SetStr(obj, "name", "zia");
    Viper.Collections.Map.SetInt(obj, "version", 1);
    Viper.Collections.Map.SetBool(obj, "ready", true);
    assertEqStr(Viper.Collections.Map.GetStr(obj, "name"), "zia", "json_get_str");
    assertEqInt(Viper.Collections.Map.GetInt(obj, "version"), 1, "json_get_int");
    assertTrue(Viper.Collections.Map.GetBool(obj, "ready"), "json_get_bool");
    assertTrue(Viper.Collections.Map.Has(obj, "name"), "json_has");
    assertTrue(Viper.String.Has(Viper.Text.Json.Format(obj), "zia"), "json_format");

    assertNotEmpty(Viper.System.Machine.get_Os(), "environment_platform");
    assertNotEmpty(Viper.System.Machine.get_Arch(), "machine_arch");
    assertGtInt(Viper.System.Machine.get_PageSize(), 0, "machine_page_size");
    assertGtInt(Viper.System.Machine.get_PointerSize(), 0, "machine_pointer_size");

    var v = new Viper.Math.Vec2(3.0, 4.0);
    assertApprox(v.Length(), 5.0, 0.0001, "vec2_length");
    assertApprox(Viper.Math.Vec2.Dist(new Viper.Math.Vec2(0.0, 0.0), v), 5.0, 0.0001, "vec2_distance");
    assertApprox(Viper.Math.Easing.InQuad(0.5), 0.25, 0.0001, "easing_in_quad");
}

func start() {
    testCanonicalRuntimeSurface();
    testCollectionSnapshots();
    testConstructorsAndRandom();
    testJsonMachineVecAndEasing();
    report();
}
