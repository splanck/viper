module RuntimeTest17;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// EXPECT_ARGS: gamma delta

func start() {    var argc = Viper.System.Environment.GetArgumentCount();
    assertTrue(argc >= 1, "argc");
    if (argc >= 3) {
        assertEqStr(Viper.System.Environment.GetArgument(1), "gamma", "arg1");
        assertEqStr(Viper.System.Environment.GetArgument(2), "delta", "arg2");
    }
    var cmd = Viper.System.Environment.GetCommandLine();
    assertNotEmpty(cmd, "cmd");

    Viper.Time.Clock.Sleep(1);
    Viper.Time.Clock.Sleep(1);

    report();
}
