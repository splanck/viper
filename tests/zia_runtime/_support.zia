module Support;

var failures: Integer = 0;

func fail(msg: String) {    failures = failures + 1;
    Viper.Terminal.Say("FAIL: " + msg);
}

func assertTrue(cond: Boolean, msg: String) {    if (!cond) {
        fail(msg);
    }
}

func assertEqInt(actual: Integer, expected: Integer, msg: String) {    if (actual != expected) {
        fail(msg + " (got " + toString(actual) + ", want " + toString(expected) + ")");
    }
}

func assertGtInt(actual: Integer, expected: Integer, msg: String) {    if (actual <= expected) {
        fail(msg + " (got " + toString(actual) + ", want > " + toString(expected) + ")");
    }
}

func assertGteInt(actual: Integer, expected: Integer, msg: String) {    if (actual < expected) {
        fail(msg + " (got " + toString(actual) + ", want >= " + toString(expected) + ")");
    }
}

func assertLteInt(actual: Integer, expected: Integer, msg: String) {    if (actual > expected) {
        fail(msg + " (got " + toString(actual) + ", want <= " + toString(expected) + ")");
    }
}

func assertEqStr(actual: String, expected: String, msg: String) {    if (actual != expected) {
        fail(msg + " (got \"" + actual + "\", want \"" + expected + "\")");
    }
}

func assertApprox(actual: Number, expected: Number, eps: Number, msg: String) {    if (Viper.Math.Abs(actual - expected) > eps) {
        fail(msg + " (got " + toString(actual) + ", want " + toString(expected) + ")");
    }
}

func assertInRange(actual: Number, min: Number, max: Number, msg: String) {    if (actual < min || actual > max) {
        fail(msg + " (got " + toString(actual) + ", want range [" + toString(min) + ", " + toString(max) + "])");
    }
}

func assertNotEmpty(actual: String, msg: String) {    if (actual == "") {
        fail(msg);
    }
}

func report() {    if (failures == 0) {
        Viper.Terminal.Say("RESULT: ok");
    } else {
        Viper.Terminal.Say("RESULT: fail " + toString(failures));
    }
}
