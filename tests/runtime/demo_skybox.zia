// Demo: Skybox — colored cube map background with orbiting camera
module DemoSkybox;

bind Viper.Terminal;
bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Input;

func start() {
    var canvas = Canvas3D.New("Skybox Demo", 640, 480);

    // Create 6 colored face textures for the cube map
    // Each face is a solid color so we can verify orientation
    var size = 64;
    var face_px = new Viper.Graphics.Pixels(size, size); // +X = red
    var face_nx = new Viper.Graphics.Pixels(size, size); // -X = cyan
    var face_py = new Viper.Graphics.Pixels(size, size); // +Y = green
    var face_ny = new Viper.Graphics.Pixels(size, size); // -Y = magenta
    var face_pz = new Viper.Graphics.Pixels(size, size); // +Z = blue
    var face_nz = new Viper.Graphics.Pixels(size, size); // -Z = yellow

    // Fill each face with its color (Pixels format: 0xRRGGBBAA)
    var x = 0;
    while (x < size) {
        var y = 0;
        while (y < size) {
            Viper.Graphics.Pixels.Set(face_px, x, y, 0xCC333300 + 0xFF);
            Viper.Graphics.Pixels.Set(face_nx, x, y, 0x33CCCC00 + 0xFF);
            Viper.Graphics.Pixels.Set(face_py, x, y, 0x33CC3300 + 0xFF);
            Viper.Graphics.Pixels.Set(face_ny, x, y, 0xCC33CC00 + 0xFF);
            Viper.Graphics.Pixels.Set(face_pz, x, y, 0x3333CC00 + 0xFF);
            Viper.Graphics.Pixels.Set(face_nz, x, y, 0xCCCC3300 + 0xFF);
            y = y + 1;
        }
        x = x + 1;
    }

    var skybox = CubeMap3D.New(face_px, face_nx, face_py, face_ny, face_pz, face_nz);
    Canvas3D.SetSkybox(canvas, skybox);

    var cam = Camera3D.New(60.0, 640.0 / 480.0, 0.1, 100.0);

    // A few objects in the scene
    var sphere = Mesh3D.NewSphere(0.8, 16);
    var floor = Mesh3D.NewPlane(6.0, 6.0);

    var sphere_mat = Material3D.NewColor(0.9, 0.9, 0.9);
    Material3D.SetShininess(sphere_mat, 128.0);
    var floor_mat = Material3D.NewColor(0.4, 0.4, 0.45);

    var sun_dir = new Vec3(-0.5, -1.0, -0.3);
    var sun = Light3D.NewDirectional(sun_dir, 1.0, 0.95, 0.9);
    Canvas3D.SetLight(canvas, 0, sun);
    Canvas3D.SetAmbient(canvas, 0.15, 0.15, 0.2);

    var floor_xform = Mat4.Translate(0.0, -1.0, 0.0);
    var angle = 0.0;

    while (Canvas3D.get_ShouldClose(canvas) == 0) {
        Canvas3D.Poll(canvas);

        var target = new Vec3(0.0, 0.0, 0.0);
        Camera3D.Orbit(cam, target, 5.0, angle * 20.0, 10.0);

        Canvas3D.Clear(canvas, 0.0, 0.0, 0.0);
        Canvas3D.Begin(canvas, cam);
        Canvas3D.DrawMesh(canvas, sphere, Mat4.Identity(), sphere_mat);
        Canvas3D.DrawMesh(canvas, floor, floor_xform, floor_mat);
        Canvas3D.End(canvas);
        Canvas3D.Flip(canvas);

        angle = angle + 0.01;
    }
}
