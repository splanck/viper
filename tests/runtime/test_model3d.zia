module TestSceneAsset;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func start() {
    var path = "tests/runtime/_tmp_scene_asset_surface.vscn";
    var scene = SceneGraph.New();
    var parent = SceneNode.New();
    var child = SceneNode.New();
    var mesh = Mesh3D.NewBox(1.0, 2.0, 3.0);
    var mat = Material3D.NewColor(0.2, 0.4, 0.8);

    SceneNode.set_Name(parent, "parent");
    SceneNode.set_Name(child, "child");
    SceneNode.SetPosition(parent, 1.0, 2.0, 3.0);
    SceneNode.SetPosition(child, 0.0, 5.0, 0.0);
    SceneNode.set_Mesh(parent, mesh);
    SceneNode.set_Material(parent, mat);
    SceneNode.set_Mesh(child, mesh);
    SceneNode.set_Material(child, mat);
    SceneNode.AddChild(parent, child);
    SceneGraph.Add(scene, parent);

    if (SceneGraph.Save(scene, path) != 1) {
        Say("FAIL: SceneGraph.Save should create the fixture asset");
        return;
    }

    var model = SceneAsset.Load(path);
    if (model == null) {
        Say("FAIL: SceneAsset.Load should load saved .vscn assets");
        return;
    }

    if (SceneAsset.get_MeshCount(model) != 1 || SceneAsset.get_MaterialCount(model) != 1 ||
        SceneAsset.get_NodeCount(model) != 2) {
        Say("FAIL: SceneAsset should expose deduplicated scene assets and node counts");
        return;
    }

    var templateChild = SceneAsset.FindNode(model, "child");
    if (templateChild == null) {
        Say("FAIL: SceneAsset.FindNode should find imported template nodes");
        return;
    }

    var instRoot = SceneAsset.Instantiate(model);
    if (instRoot == null || SceneNode.get_ChildCount(instRoot) != 1) {
        Say("FAIL: SceneAsset.Instantiate should clone the template subtree");
        return;
    }

    var instChild = SceneNode.Find(instRoot, "child");
    if (instChild == null) {
        Say("FAIL: instantiated subtree should preserve child names");
        return;
    }

    SceneNode.SetPosition(instChild, 9.0, 9.0, 9.0);
    if (Vec3.get_Y(SceneNode.get_Position(instChild)) != 9.0) {
        Say("FAIL: instantiated nodes should be writable");
        return;
    }
    if (Vec3.get_Y(SceneNode.get_Position(templateChild)) != 5.0) {
        Say("FAIL: mutating an instance should not change the template node");
        return;
    }

    var instScene = SceneAsset.InstantiateScene(model);
    if (instScene == null || SceneGraph.get_NodeCount(instScene) != 3) {
        Say("FAIL: InstantiateScene should create a new SceneGraph with imported nodes");
        return;
    }
    if (SceneGraph.Find(instScene, "child") == null) {
        Say("FAIL: InstantiateScene should preserve searchable node names");
        return;
    }

    Say("PASS");
}
