module TestMaterial3DPBR;

bind Viper.Graphics3D;
bind Viper.Terminal;

func start() {
    var path = "tests/runtime/_tmp_material3d_pbr.vscn";
    var scene = SceneGraph.New();
    var node = SceneNode.New();
    var mesh = Mesh3D.NewBox(1.0, 1.0, 1.0);
    var mat = Material3D.NewPBR(0.6, 0.4, 0.2);

    mat.Metallic = 0.7;
    mat.Roughness = 0.3;
    mat.AO = 0.85;
    mat.EmissiveIntensity = 1.5;
    mat.NormalScale = 0.55;
    mat.Alpha = 0.6;
    mat.AlphaMode = 2;
    mat.DoubleSided = true;

    var inst = Material3D.MakeInstance(mat);
    inst.Roughness = 0.9;
    inst.DoubleSided = false;
    if (mat.Roughness < 0.29 || mat.Roughness > 0.31) {
        Say("FAIL: MakeInstance should keep scalar overrides independent");
        return;
    }
    if (mat.DoubleSided != true) {
        Say("FAIL: MakeInstance should not mutate the source material");
        return;
    }

    var clone = Material3D.Clone(mat);
    if (clone.Metallic < 0.69 || clone.Metallic > 0.71) {
        Say("FAIL: Clone should preserve metallic");
        return;
    }
    if (clone.AlphaMode != 2) {
        Say("FAIL: Clone should preserve alpha mode");
        return;
    }

    node.Mesh = mesh;
    node.Material = mat;
    SceneGraph.Add(scene, node);
    if (SceneGraph.Save(scene, path) != 1) {
        Say("FAIL: SceneGraph.Save should create the PBR fixture asset");
        return;
    }

    var model = SceneAsset.Load(path);
    if (model == null) {
        Say("FAIL: SceneAsset.Load should read the saved PBR fixture");
        return;
    }
    if (SceneAsset.get_MaterialCount(model) != 1) {
        Say("FAIL: SceneAsset should preserve one shared material");
        return;
    }

    var loaded = SceneAsset.GetMaterial(model, 0);
    if (loaded == null) {
        Say("FAIL: SceneAsset.GetMaterial should return the saved PBR material");
        return;
    }
    if (Material3D.get_Metallic(loaded) < 0.69 || Material3D.get_Metallic(loaded) > 0.71) {
        Say("FAIL: Metallic should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_Roughness(loaded) < 0.29 || Material3D.get_Roughness(loaded) > 0.31) {
        Say("FAIL: Roughness should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_AO(loaded) < 0.84 || Material3D.get_AO(loaded) > 0.86) {
        Say("FAIL: AO should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_EmissiveIntensity(loaded) < 1.49 ||
        Material3D.get_EmissiveIntensity(loaded) > 1.51) {
        Say("FAIL: EmissiveIntensity should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_NormalScale(loaded) < 0.54 || Material3D.get_NormalScale(loaded) > 0.56) {
        Say("FAIL: NormalScale should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_AlphaMode(loaded) != 2) {
        Say("FAIL: AlphaMode should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }
    if (Material3D.get_DoubleSided(loaded) != true) {
        Say("FAIL: DoubleSided should round-trip through SceneGraph.Save/SceneAsset.Load");
        return;
    }

    Say("PASS");
}
