// Demo: Multi-object scene with orbiting camera, OBJ model, wireframe toggle
module DemoCanvas3D;

bind Viper.Terminal;
bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Input;

func start() {
    var canvas = Canvas3D.New("Viper 3D Engine", 800, 600);
    var cam = Camera3D.New(60.0, 800.0 / 600.0, 0.1, 100.0);

    // Meshes
    var cube = Mesh3D.FromOBJ("tests/runtime/test_cube.obj");
    var sphere = Mesh3D.NewSphere(0.5, 20);
    var floor = Mesh3D.NewPlane(12.0, 12.0);
    var cylinder = Mesh3D.NewCylinder(0.3, 2.0, 12);

    // Materials
    var blue_mat = Material3D.NewColor(0.2, 0.4, 0.9);
    Material3D.SetShininess(blue_mat, 64.0);

    var gold_mat = Material3D.NewColor(0.95, 0.8, 0.2);
    Material3D.SetShininess(gold_mat, 128.0);

    var red_mat = Material3D.NewColor(0.9, 0.15, 0.15);
    Material3D.SetShininess(red_mat, 32.0);

    var green_mat = Material3D.NewColor(0.15, 0.6, 0.15);
    Material3D.SetShininess(green_mat, 16.0);

    var floor_mat = Material3D.NewColor(0.35, 0.35, 0.4);
    Material3D.SetShininess(floor_mat, 4.0);

    // Lights
    var sun_dir = new Vec3(-0.6, -1.0, -0.4);
    var sun = Light3D.NewDirectional(sun_dir, 1.0, 0.95, 0.85);

    var point_pos = new Vec3(3.0, 3.0, 3.0);
    var point = Light3D.NewPoint(point_pos, 0.8, 0.4, 0.1, 0.2);

    Canvas3D.SetLight(canvas, 0, sun);
    Canvas3D.SetLight(canvas, 1, point);
    Canvas3D.SetAmbient(canvas, 0.12, 0.12, 0.18);

    var floor_xform = Mat4.Translate(0.0, -1.5, 0.0);
    var time = 0.0;

    while (Canvas3D.get_ShouldClose(canvas) == 0) {
        Canvas3D.Poll(canvas);
        Canvas3D.Clear(canvas, 0.04, 0.04, 0.08);

        // Orbit camera
        var target = new Vec3(0.0, 0.0, 0.0);
        Camera3D.Orbit(cam, target, 7.0, time * 15.0, 20.0);

        // Rotating cube (center)
        var cube_rot = Mat4.RotateY(time * 0.5);
        var cube_tilt = Mat4.RotateX(time * 0.3);
        var cube_xform = Mat4.Mul(cube_rot, cube_tilt);

        // Orbiting spheres
        var s1x = 2.5 * Cos(time * 1.5);
        var s1z = 2.5 * Sin(time * 1.5);
        var s1_xform = Mat4.Translate(s1x, 0.0, s1z);

        var s2x = 2.5 * Cos(time * 1.5 + 2.094);
        var s2z = 2.5 * Sin(time * 1.5 + 2.094);
        var s2_xform = Mat4.Translate(s2x, 0.0, s2z);

        var s3x = 2.5 * Cos(time * 1.5 + 4.189);
        var s3z = 2.5 * Sin(time * 1.5 + 4.189);
        var s3_xform = Mat4.Translate(s3x, 0.0, s3z);

        // Pillars
        var p1_xform = Mat4.Translate(-3.0, -0.5, -3.0);
        var p2_xform = Mat4.Translate(3.0, -0.5, -3.0);
        var p3_xform = Mat4.Translate(-3.0, -0.5, 3.0);
        var p4_xform = Mat4.Translate(3.0, -0.5, 3.0);

        Canvas3D.Begin(canvas, cam);

        // Floor
        Canvas3D.DrawMesh(canvas, floor, floor_xform, floor_mat);

        // Central rotating cube
        Canvas3D.DrawMesh(canvas, cube, cube_xform, blue_mat);

        // Orbiting spheres
        Canvas3D.DrawMesh(canvas, sphere, s1_xform, gold_mat);
        Canvas3D.DrawMesh(canvas, sphere, s2_xform, red_mat);
        Canvas3D.DrawMesh(canvas, sphere, s3_xform, green_mat);

        // Corner pillars
        Canvas3D.DrawMesh(canvas, cylinder, p1_xform, floor_mat);
        Canvas3D.DrawMesh(canvas, cylinder, p2_xform, floor_mat);
        Canvas3D.DrawMesh(canvas, cylinder, p3_xform, floor_mat);
        Canvas3D.DrawMesh(canvas, cylinder, p4_xform, floor_mat);

        Canvas3D.End(canvas);
        Canvas3D.Flip(canvas);

        time = time + 0.016;
    }
}
