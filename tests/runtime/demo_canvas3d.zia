// Demo: Multi-object scene with orbiting camera, OBJ model, wireframe toggle
module DemoCanvas3D;

bind Viper.Terminal;

func start() {
    var canvas = Viper.Graphics3D.Canvas3D.New("Viper 3D Engine", 800, 600);
    var cam = Viper.Graphics3D.Camera3D.New(60.0, 800.0 / 600.0, 0.1, 100.0);

    // Meshes
    var cube = Viper.Graphics3D.Mesh3D.FromOBJ("tests/runtime/test_cube.obj");
    var sphere = Viper.Graphics3D.Mesh3D.NewSphere(0.5, 20);
    var floor = Viper.Graphics3D.Mesh3D.NewPlane(12.0, 12.0);
    var cylinder = Viper.Graphics3D.Mesh3D.NewCylinder(0.3, 2.0, 12);

    // Materials
    var blue_mat = Viper.Graphics3D.Material3D.NewColor(0.2, 0.4, 0.9);
    Viper.Graphics3D.Material3D.SetShininess(blue_mat, 64.0);

    var gold_mat = Viper.Graphics3D.Material3D.NewColor(0.95, 0.8, 0.2);
    Viper.Graphics3D.Material3D.SetShininess(gold_mat, 128.0);

    var red_mat = Viper.Graphics3D.Material3D.NewColor(0.9, 0.15, 0.15);
    Viper.Graphics3D.Material3D.SetShininess(red_mat, 32.0);

    var green_mat = Viper.Graphics3D.Material3D.NewColor(0.15, 0.6, 0.15);
    Viper.Graphics3D.Material3D.SetShininess(green_mat, 16.0);

    var floor_mat = Viper.Graphics3D.Material3D.NewColor(0.35, 0.35, 0.4);
    Viper.Graphics3D.Material3D.SetShininess(floor_mat, 4.0);

    // Lights
    var sun_dir = new Viper.Math.Vec3(-0.6, -1.0, -0.4);
    var sun = Viper.Graphics3D.Light3D.NewDirectional(sun_dir, 1.0, 0.95, 0.85);

    var point_pos = new Viper.Math.Vec3(3.0, 3.0, 3.0);
    var point = Viper.Graphics3D.Light3D.NewPoint(point_pos, 0.8, 0.4, 0.1, 0.2);

    Viper.Graphics3D.Canvas3D.SetLight(canvas, 0, sun);
    Viper.Graphics3D.Canvas3D.SetLight(canvas, 1, point);
    Viper.Graphics3D.Canvas3D.SetAmbient(canvas, 0.12, 0.12, 0.18);

    var floor_xform = Viper.Math.Mat4.Translate(0.0, -1.5, 0.0);
    var time = 0.0;

    while (Viper.Graphics3D.Canvas3D.get_ShouldClose(canvas) == 0) {
        Viper.Graphics3D.Canvas3D.Poll(canvas);
        Viper.Graphics3D.Canvas3D.Clear(canvas, 0.04, 0.04, 0.08);

        // Orbit camera
        var target = new Viper.Math.Vec3(0.0, 0.0, 0.0);
        Viper.Graphics3D.Camera3D.Orbit(cam, target, 7.0, time * 15.0, 20.0);

        // Rotating cube (center)
        var cube_rot = Viper.Math.Mat4.RotateY(time * 0.5);
        var cube_tilt = Viper.Math.Mat4.RotateX(time * 0.3);
        var cube_xform = Viper.Math.Mat4.Mul(cube_rot, cube_tilt);

        // Orbiting spheres
        var s1x = 2.5 * Viper.Math.Cos(time * 1.5);
        var s1z = 2.5 * Viper.Math.Sin(time * 1.5);
        var s1_xform = Viper.Math.Mat4.Translate(s1x, 0.0, s1z);

        var s2x = 2.5 * Viper.Math.Cos(time * 1.5 + 2.094);
        var s2z = 2.5 * Viper.Math.Sin(time * 1.5 + 2.094);
        var s2_xform = Viper.Math.Mat4.Translate(s2x, 0.0, s2z);

        var s3x = 2.5 * Viper.Math.Cos(time * 1.5 + 4.189);
        var s3z = 2.5 * Viper.Math.Sin(time * 1.5 + 4.189);
        var s3_xform = Viper.Math.Mat4.Translate(s3x, 0.0, s3z);

        // Pillars
        var p1_xform = Viper.Math.Mat4.Translate(-3.0, -0.5, -3.0);
        var p2_xform = Viper.Math.Mat4.Translate(3.0, -0.5, -3.0);
        var p3_xform = Viper.Math.Mat4.Translate(-3.0, -0.5, 3.0);
        var p4_xform = Viper.Math.Mat4.Translate(3.0, -0.5, 3.0);

        Viper.Graphics3D.Canvas3D.Begin(canvas, cam);

        // Floor
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, floor, floor_xform, floor_mat);

        // Central rotating cube
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, cube, cube_xform, blue_mat);

        // Orbiting spheres
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, sphere, s1_xform, gold_mat);
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, sphere, s2_xform, red_mat);
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, sphere, s3_xform, green_mat);

        // Corner pillars
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, cylinder, p1_xform, floor_mat);
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, cylinder, p2_xform, floor_mat);
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, cylinder, p3_xform, floor_mat);
        Viper.Graphics3D.Canvas3D.DrawMesh(canvas, cylinder, p4_xform, floor_mat);

        Viper.Graphics3D.Canvas3D.End(canvas);
        Viper.Graphics3D.Canvas3D.Flip(canvas);

        time = time + 0.016;
    }
}
