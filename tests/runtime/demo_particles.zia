// Demo: 3D particle system — fountain effect with gravity and fade-out.
module DemoParticles;

bind Viper.Terminal;
bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Input;

func start() {
    var canvas = Canvas3D.New("Particle System", 800, 600);
    var cam = Camera3D.New(60.0, 800.0 / 600.0, 0.1, 100.0);
    var floor_mesh = Mesh3D.NewPlane(12.0, 12.0);
    var floor_mat = Material3D.NewColor(0.15, 0.15, 0.2);

    // Fountain particle system
    var fountain = Particles3D.New(500);
    Particles3D.SetPosition(fountain, 0.0, -0.5, 0.0);
    Particles3D.SetDirection(fountain, 0.0, 1.0, 0.0, 0.4);
    Particles3D.SetSpeed(fountain, 3.0, 6.0);
    Particles3D.SetLifetime(fountain, 1.0, 2.5);
    Particles3D.SetSize(fountain, 0.15, 0.03);
    Particles3D.SetGravity(fountain, 0.0, -4.0, 0.0);
    Particles3D.SetColor(fountain, 0x4488FF, 0x1122AA);
    Particles3D.SetAlpha(fountain, 0.9, 0.0);
    Particles3D.SetRate(fountain, 80.0);
    Particles3D.Start(fountain);

    // Fire particle system (additive blending)
    var fire = Particles3D.New(300);
    Particles3D.SetPosition(fire, 2.0, -0.5, 0.0);
    Particles3D.SetDirection(fire, 0.0, 1.0, 0.0, 0.3);
    Particles3D.SetSpeed(fire, 1.0, 2.5);
    Particles3D.SetLifetime(fire, 0.3, 0.8);
    Particles3D.SetSize(fire, 0.3, 0.05);
    Particles3D.SetGravity(fire, 0.0, 1.0, 0.0);
    Particles3D.SetColor(fire, 0xFFAA22, 0xFF2200);
    Particles3D.SetAlpha(fire, 1.0, 0.0);
    Particles3D.SetRate(fire, 120.0);
    Particles3D.Start(fire);

    // Lighting
    var sun_dir = new Vec3(-0.5, -1.0, -0.3);
    var sun = Light3D.NewDirectional(sun_dir, 1.0, 0.95, 0.9);
    Canvas3D.SetLight(canvas, 0, sun);
    Canvas3D.SetAmbient(canvas, 0.1, 0.1, 0.15);

    var time = 0.0;

    while (Canvas3D.get_ShouldClose(canvas) == 0) {
        Canvas3D.Poll(canvas);
        Canvas3D.Clear(canvas, 0.02, 0.02, 0.05);

        var target = new Vec3(1.0, 0.5, 0.0);
        Camera3D.Orbit(cam, target, 8.0, time * 10.0, 20.0);

        // Update particles
        Particles3D.Update(fountain, 0.016);
        Particles3D.Update(fire, 0.016);

        Canvas3D.Begin(canvas, cam);

        // Floor
        var floor_xform = Mat4.Translate(0.0, -1.0, 0.0);
        Canvas3D.DrawMesh(canvas, floor_mesh, floor_xform, floor_mat);

        // Draw particles (between Begin/End for proper transparency sorting)
        Particles3D.Draw(fountain, canvas, cam);
        Particles3D.Draw(fire, canvas, cam);

        Canvas3D.End(canvas);
        Canvas3D.Flip(canvas);

        time = time + 0.016;
    }
}
