module test_game3d_double_despawn_reject;

bind Viper.Game3D as Game3D;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    Game3D.Diagnostics.Reset();
    var world = Game3D.World3D.New("Game3D Double Despawn Noop", 32, 24);
    var entity = Game3D.Entity3D.New();
    Game3D.World3D.spawn(world, entity);
    Game3D.World3D.despawn(world, entity);
    Game3D.World3D.despawn(world, entity);
    if (Game3D.Diagnostics.get_StaleEntityCalls() != 1) {
        fail("second despawn should be one counted stale no-op");
        return;
    }
    Terminal.Say("PASS double despawn no-op");
}
