module test_game3d_world_probe;

bind Viper.Game3D as Game3D;
bind Viper.Graphics as Graphics;
bind Viper.Graphics3D as G3D;
bind Viper.Math as Math;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) {
        d = 0.0 - d;
    }
    return d <= eps;
}

func start() {
    var world = Game3D.World3D.New("Game3D World Probe", 64, 48);
    if (world == null) {
        fail("World3D.New returned null");
        return;
    }
    if (world.Canvas == null ||
        world.Camera == null ||
        world.Scene == null ||
        world.Physics == null ||
        world.Input == null ||
        world.Audio == null ||
        world.Effects == null) {
        fail("World3D.New did not create the expected runtime components");
        return;
    }

    var mask = Game3D.LayerMask.Of(Game3D.Layers.get_World());
    mask.Include(Game3D.Layers.get_Player());
    if (mask.Includes(Game3D.Layers.get_Player()) == false) {
        fail("LayerMask include/includes failed");
        return;
    }

    var mesh = G3D.Mesh3D.NewBox(1.0, 1.0, 1.0);
    var mat = G3D.Material3D.NewColor(0.2, 0.7, 0.9);
    var player = Game3D.Entity3D.Of(mesh, mat);
    player.SetName("Player");
    player.SetPosition(0.0, 0.0, 0.0);
    player.SetLayer(Game3D.Layers.get_Player());
    player.SetCollisionMask(mask);
    world.Spawn(player);

    if (player.IsSpawned() == false) {
        fail("World3D.spawn did not mark the entity spawned");
        return;
    }
    if (world.FindEntity("Player") == null) {
        fail("World3D.findEntity did not find the spawned entity");
        return;
    }
    if (world.FindNode("Player") == null) {
        fail("World3D.findNode did not find the entity node");
        return;
    }

    var rawRoot = G3D.SceneNode.New();
    var rawChild = G3D.SceneNode.New();
    rawRoot.Name = "ImportedRoot";
    rawChild.Name = "ImportedChild";
    G3D.SceneNode.AddChild(rawRoot, rawChild);
    var imported = Game3D.Entity3D.FromNode(rawRoot);
    if (imported == null || imported.IsGroup() == false) {
        fail("Entity3D.FromNode did not wrap a raw SceneNode subtree");
        return;
    }
    world.Spawn(imported);
    if (world.FindEntity("ImportedRoot") == null ||
        world.FindNode("ImportedChild") == null) {
        fail("World3D did not index a FromNode imported subtree");
        return;
    }

    world.SetAmbient(0.18, 0.20, 0.24);
    world.SetQuality(Game3D.QualityLevel.get_Balanced());
    world.LookAt(new Math.Vec3(0.0, 0.0, 0.0));
    world.OnResize(64, 48);
    var canvas = world.Canvas;
    G3D.Canvas3D.SetInputSource(canvas, 1);
    G3D.Canvas3D.SetClockSource(canvas, 1);
    G3D.Canvas3D.SetSyntheticDeltaTimeSec(canvas, 0.020);
    if (world.Tick() == false ||
        world.Frame != 1 ||
        near(world.Dt, 0.020, 0.0001) == false) {
        fail("World3D.tick did not advance synthetic timing");
        return;
    }
    world.StepSimulation(0.0);
    if (world.Frame != 2 ||
        near(world.Dt, 1.0 / 60.0, 0.0001) == false) {
        fail("World3D.stepSimulation did not clamp and advance frame timing");
        return;
    }
    world.BeginFrame();
    world.DrawScene();
    world.DrawEffects();
    world.EndScene();
    var snap = world.CaptureFinalFrame();
    if (snap == null) {
        fail("World3D.captureFinalFrame returned null");
        return;
    }
    if (Graphics.Pixels.get_Width(snap) != 64 || Graphics.Pixels.get_Height(snap) != 48) {
        fail("World3D.captureFinalFrame returned the wrong size");
        return;
    }
    world.Present();

    world.Despawn(imported);
    if (world.FindNode("ImportedChild") != null) {
        fail("World3D.despawn did not detach the FromNode subtree");
        return;
    }
    world.Despawn(player);
    if (player.IsSpawned()) {
        fail("World3D.despawn did not clear spawned state");
        return;
    }
    world.Destroy();
    if (world.IsDestroyed() == false) {
        fail("World3D.destroy did not mark the world destroyed");
        return;
    }

    Terminal.Say("PASS");
}
