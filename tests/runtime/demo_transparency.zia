// Demo: Alpha blending — transparent glass panels over a lit scene
module DemoTransparency;

bind Viper.Terminal;
bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Input;

func start() {
    var canvas = Canvas3D.New("Transparency Demo", 640, 480);
    var cam = Camera3D.New(60.0, 640.0 / 480.0, 0.1, 100.0);

    var sphere = Mesh3D.NewSphere(0.6, 16);
    var floor = Mesh3D.NewPlane(10.0, 10.0);
    var box = Mesh3D.NewBox(1.0, 1.0, 1.0);

    // Build glass panel (vertical quad)
    var panel = Mesh3D.New();
    Mesh3D.AddVertex(panel, -1.0, -1.0, 0.0, 0, 0, 1, 0, 1);
    Mesh3D.AddVertex(panel,  1.0, -1.0, 0.0, 0, 0, 1, 1, 1);
    Mesh3D.AddVertex(panel,  1.0,  1.0, 0.0, 0, 0, 1, 1, 0);
    Mesh3D.AddVertex(panel, -1.0,  1.0, 0.0, 0, 0, 1, 0, 0);
    Mesh3D.AddTriangle(panel, 0, 1, 2);
    Mesh3D.AddTriangle(panel, 0, 2, 3);

    // Opaque materials
    var floor_mat = Material3D.NewColor(0.3, 0.3, 0.35);
    var sphere_mat = Material3D.NewColor(0.9, 0.2, 0.15);
    Material3D.SetShininess(sphere_mat, 64.0);
    var box_mat = Material3D.NewColor(0.2, 0.5, 0.9);

    // Transparent materials (glass panels)
    var red_glass = Material3D.NewColor(1.0, 0.2, 0.2);
    Material3D.set_Alpha(red_glass, 0.35);

    var green_glass = Material3D.NewColor(0.2, 1.0, 0.3);
    Material3D.set_Alpha(green_glass, 0.35);

    var blue_glass = Material3D.NewColor(0.3, 0.4, 1.0);
    Material3D.set_Alpha(blue_glass, 0.35);

    // Light
    var sun_dir = new Vec3(-0.5, -1.0, -0.3);
    var sun = Light3D.NewDirectional(sun_dir, 1.0, 0.95, 0.9);
    Canvas3D.SetLight(canvas, 0, sun);
    Canvas3D.SetAmbient(canvas, 0.12, 0.12, 0.18);

    var floor_xform = Mat4.Translate(0.0, -1.0, 0.0);
    var angle = 0.0;

    while (Canvas3D.get_ShouldClose(canvas) == 0) {
        Canvas3D.Poll(canvas);

        var target = new Vec3(0.0, 0.5, 0.0);
        Camera3D.Orbit(cam, target, 7.0, angle * 20.0, 15.0);

        Canvas3D.Clear(canvas, 0.05, 0.05, 0.1);
        Canvas3D.Begin(canvas, cam);

        // Opaque objects (rendered first automatically)
        Canvas3D.DrawMesh(canvas, floor, floor_xform, floor_mat);
        Canvas3D.DrawMesh(canvas, sphere,
            Mat4.Translate(0.0, 0.0, 0.0), sphere_mat);
        Canvas3D.DrawMesh(canvas, box,
            Mat4.Mul(Mat4.Translate(-2.0, 0.0, 0.0),
                                Mat4.RotateY(angle * 0.5)), box_mat);

        // Transparent panels — disable backface culling so they're visible from both sides
        Canvas3D.SetBackfaceCull(canvas, false);
        Canvas3D.DrawMesh(canvas, panel,
            Mat4.Translate(-1.5, 0.5, 1.0), red_glass);
        Canvas3D.DrawMesh(canvas, panel,
            Mat4.Translate(0.0, 0.5, 1.5), green_glass);
        Canvas3D.DrawMesh(canvas, panel,
            Mat4.Translate(1.5, 0.5, 1.0), blue_glass);

        Canvas3D.SetBackfaceCull(canvas, true);

        Canvas3D.End(canvas);
        Canvas3D.Flip(canvas);

        angle = angle + 0.01;
    }
}
