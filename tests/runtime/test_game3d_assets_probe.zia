module test_game3d_assets_probe;

bind Viper.Game3D as Game3D;
bind Viper.Graphics3D as G3D;
bind Viper.Terminal as Terminal;
bind Viper.Threads.Thread as Thread;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    var path = "tests/runtime/assets/gltf/load_asset_triangle.gltf";
    Game3D.Assets3D.ClearCache();

    var entity = Game3D.Assets3D.LoadEntity(path);
    if (entity == null || Game3D.Entity3D.isGroup(entity) == false ||
        G3D.SceneNode.get_ChildCount(Game3D.Entity3D.get_node(entity)) != 1) {
        fail("LoadEntity did not return an imported group entity");
        return;
    }

    var assetEntity = Game3D.Assets3D.LoadEntityAsset(path);
    if (assetEntity == null ||
        G3D.SceneNode.get_ChildCount(Game3D.Entity3D.get_node(assetEntity)) != 1) {
        fail("LoadEntityAsset did not instantiate through asset resolver");
        return;
    }
    Game3D.Entity3D.setName(assetEntity, "AssetProbeImport");
    var world = Game3D.World3D.New("Game3D Asset Lifetime Probe", 64, 48);
    var i = 0;
    while (i < 4) {
        var loopEntity = Game3D.Assets3D.LoadEntityAsset(path);
        if (loopEntity == null ||
            G3D.SceneNode.get_ChildCount(Game3D.Entity3D.get_node(loopEntity)) != 1) {
            fail("LoadEntityAsset did not create a fresh asset group");
            return;
        }
        Game3D.Entity3D.setName(loopEntity, "AssetProbeImport");
        Game3D.World3D.spawn(world, loopEntity);
        if (Game3D.World3D.get_entityCount(world) != 1 ||
            Game3D.World3D.findEntity(world, "AssetProbeImport") == null) {
            fail("imported asset group did not spawn/index cleanly");
            return;
        }
        Game3D.World3D.despawn(world, loopEntity);
        if (Game3D.World3D.get_entityCount(world) != 0 ||
            Game3D.World3D.findEntity(world, "AssetProbeImport") != null) {
            fail("imported asset group despawn leaked world registry state");
            return;
        }
        i = i + 1;
    }
    Game3D.World3D.destroy(world);

    var tpl1 = Game3D.Assets3D.LoadTemplate(path);
    var tpl2 = Game3D.Assets3D.LoadTemplate(path);
    if (tpl1 == null || tpl2 == null) {
        fail("LoadTemplate did not return cached templates");
        return;
    }
    if (G3D.SceneAsset.get_MeshCount(Game3D.SceneTemplate.get_model(tpl1)) != 1 ||
        G3D.SceneAsset.get_MeshCount(Game3D.SceneTemplate.get_model(tpl2)) != 1) {
        fail("SceneTemplate lost mesh data");
        return;
    }

    var inst = Game3D.SceneTemplate.instantiate(tpl1);
    if (inst == null || Game3D.Entity3D.isGroup(inst) == false ||
        G3D.SceneNode.get_ChildCount(Game3D.Entity3D.get_node(inst)) != 1) {
        fail("SceneTemplate.instantiate did not clone the model subtree");
        return;
    }

    var assetTpl = Game3D.Assets3D.LoadTemplateAsset(path);
    if (assetTpl == null || Game3D.SceneTemplate.get_isAsset(assetTpl) == false) {
        fail("LoadTemplateAsset did not record asset path");
        return;
    }

    var missing = Game3D.Assets3D.LoadTemplateAssetAsync("viper/missing/co3_missing.gltf");
    if (missing == null) {
        fail("missing package asset did not return a diagnostic handle");
        return;
    }
    var missingReady = Game3D.AssetHandle3D.get_ready(missing);
    var wait = 0;
    while (missingReady == false && wait < 40) {
        Thread.Sleep(5);
        missingReady = Game3D.AssetHandle3D.get_ready(missing);
        wait = wait + 1;
    }
    if (missingReady == false ||
        Game3D.AssetHandle3D.get_error(missing) != "failed to load model asset" ||
        Game3D.AssetHandle3D.getTemplate(missing) != null) {
        fail("missing package asset did not produce a terminal diagnostic handle");
        return;
    }

    Game3D.Assets3D.Preload(path);
    Game3D.Assets3D.ClearCache();
    var tpl3 = Game3D.Assets3D.LoadTemplate(path);
    if (tpl3 == null) {
        fail("LoadTemplate failed after ClearCache");
        return;
    }
    Game3D.Assets3D.ClearCache();
    Terminal.Say("PASS");
}
