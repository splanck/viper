module TestNavAgent3D;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func start() {
    var mesh = Mesh3D.NewPlane(20.0, 20.0);
    var nav = NavMesh3D.Build(mesh, 0.4, 1.8);

    var scene = Scene3D.New();
    var parent = SceneNode3D.New();
    var child = SceneNode3D.New();
    SceneNode3D.SetPosition(parent, 2.0, 0.0, 1.0);
    SceneNode3D.AddChild(parent, child);
    Scene3D.Add(scene, parent);

    var agent = NavAgent3D.New(nav, 0.4, 1.8);
    NavAgent3D.BindNode(agent, child);
    NavAgent3D.set_DesiredSpeed(agent, 6.0);
    NavAgent3D.set_StoppingDistance(agent, 0.2);
    NavAgent3D.Warp(agent, Vec3.New(0.0, 0.0, 0.0));
    NavAgent3D.SetTarget(agent, Vec3.New(4.0, 0.0, 4.0));

    var i = 0;
    while (i < 80) {
        NavAgent3D.Update(agent, 0.05);
        i = i + 1;
    }

    var worldPos = Mat4.TransformPoint(SceneNode3D.get_WorldMatrix(child), Vec3.Zero());
    if (Vec3.get_X(worldPos) < 3.65 || Vec3.get_X(worldPos) > 4.35 || Vec3.get_Z(worldPos) < 3.65 ||
        Vec3.get_Z(worldPos) > 4.35) {
        Say("FAIL: NavAgent3D should drive a bound SceneNode3D to the target in world space");
        return;
    }
    if (NavAgent3D.get_HasPath(agent) != false) {
        Say("FAIL: NavAgent3D should clear HasPath after reaching the target");
        return;
    }
    if (NavAgent3D.get_RemainingDistance(agent) < -0.3 || NavAgent3D.get_RemainingDistance(agent) > 0.3) {
        Say("FAIL: NavAgent3D should reduce RemainingDistance near zero on arrival");
        return;
    }

    var world = Physics3DWorld.New(0.0, -9.8, 0.0);
    var character = Character3D.New(0.4, 1.8, 80.0);
    Character3D.set_World(character, world);
    NavAgent3D.BindCharacter(agent, character);
    NavAgent3D.SetTarget(agent, Vec3.New(3.0, 0.0, 0.0));

    i = 0;
    while (i < 20) {
        NavAgent3D.Update(agent, 0.1);
        i = i + 1;
    }

    var charPos = Character3D.get_Position(character);
    if (Vec3.get_X(charPos) <= 1.5) {
        Say("FAIL: NavAgent3D should advance a bound Character3D");
        return;
    }

    NavAgent3D.SetTarget(agent, Vec3.New(5.0, 0.0, 0.0));
    NavAgent3D.Update(agent, 0.1);
    NavAgent3D.Warp(agent, Vec3.New(-3.0, 0.0, 0.0));

    var agentPos = NavAgent3D.get_Position(agent);
    var vel = NavAgent3D.get_Velocity(agent);
    if (Vec3.get_X(agentPos) < -3.2 || Vec3.get_X(agentPos) > -2.8) {
        Say("FAIL: NavAgent3D.Warp should move the agent immediately");
        return;
    }
    if (Vec3.get_X(vel) < -0.001 || Vec3.get_X(vel) > 0.001) {
        Say("FAIL: NavAgent3D.Warp should clear the old velocity");
        return;
    }
    if (NavAgent3D.get_HasPath(agent) != true) {
        Say("FAIL: NavAgent3D.Warp should rebuild the path when a target is still active");
        return;
    }

    Say("RESULT: ok");
}
