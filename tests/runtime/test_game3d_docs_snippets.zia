module test_game3d_docs_snippets;

bind Viper.Game3D as Game3D;
bind Viper.Graphics.Pixels as Pixels;
bind Viper.Graphics3D;
bind Viper.Math as Math;
bind Viper.Sound as Sound;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) { d = 0.0 - d; }
    return d <= eps;
}

func probeFrameHelperSnippet() -> Boolean {
    var world = Game3D.World3D.New("Docs runFramesOnly Snippet", 48, 32);
    world.RunFramesOnly(2, 0.025);
    var ok = world.Frame == 2 &&
             near(world.Elapsed, 0.050, 0.0001);
    world.Destroy();
    if (ok == false) {
        fail("runFramesOnly docs snippet failed");
    }
    return ok;
}

func start() {
    if (probeFrameHelperSnippet() == false) {
        return;
    }

    var world = Game3D.World3D.New("Game3D Docs Snippets", 96, 64);
    world.OnResize(96, 64);
    var canvas = world.Canvas;
    Canvas3D.SetDTMax(canvas, 50);

    Game3D.Quality.Apply(world, Game3D.QualityLevel.get_Balanced());
    Game3D.Lighting.Studio(world);
    Game3D.PostFX.Crisp(world);
    var env: Game3D.EnvHandle = Game3D.Environment3D.Outdoor(world);
    env.WithFog(12.0, 48.0);

    var ground: Game3D.Entity3D = Game3D.Prefab.Ground(18.0, Game3D.Materials.Rubber(0.28, 0.38, 0.24));
    ground.AttachBody(Game3D.BodyDef.StaticPlane(18.0));
    world.Spawn(ground);

    var ball: Game3D.Entity3D = Game3D.Prefab.Sphere(0.35, 18, Game3D.Materials.Plastic(0.90, 0.20, 0.16));
    ball.Name = "DocsBall";
    ball.SetPosition(0.0, 1.2, 0.0);
    var body = Game3D.BodyDef.Sphere(0.35, 1.0);
    body.Restitution = 0.25;
    body.WithMask(Game3D.LayerMask.Of(Game3D.Layers.get_World()));
    ball.AttachBody(body);
    world.Spawn(ball);

    var imported: Game3D.Entity3D = Game3D.Assets3D.LoadEntityAsset("examples/3d/game3d_starter/assets/models/triangle.gltf");
    if (imported == null) {
        fail("Assets3D docs snippet failed");
        return;
    }
    imported.Name = "DocsAsset";
    imported.SetPosition(1.1, 0.08, -1.2);
    world.Spawn(imported);

    var audio = world.Audio;
    audio.SetAttenuation(1.0, 10.0);
    var tone = Sound.Synth.Tone(330, 60, 0);
    if (tone != null) {
        audio.PlayAt(tone, Math.Vec3.New(0.0, 0.8, 0.0));
        audio.PlayAttached(tone, ball);
        audio.Play2D(tone);
    }

    ball.ApplyImpulse(0.0, -0.2, 0.0);
    world.RunFramesOnly(12, 1.0 / 60.0);
    if (world.CollisionEventCount(Game3D.CollisionPhase.get_Enter()) > 0) {
        var evt = world.CollisionEvent(Game3D.CollisionPhase.get_Enter(), 0);
        Game3D.Effects3D.Dust(world, evt.Point());
        Game3D.Effects3D.ImpactDecal(world, evt.Point(),
                                     evt.Normal());
    } else {
        Game3D.Effects3D.Smoke(world, Math.Vec3.New(0.0, 0.5, 0.0));
    }

    world.BeginFrame();
    world.DrawScene();
    world.DrawEffects();
    world.EndScene();
    Canvas3D.BeginOverlay(canvas);
    Canvas3D.DrawRect2D(canvas, 8, 8, 72, 3, 0x00E8FF);
    Canvas3D.DrawText2D(canvas, 14, 22, "DOCS", 0xFFFFFF);
    Canvas3D.EndOverlay(canvas);

    var snap = world.CaptureFinalFrame();
    if (snap == null || Pixels.get_Width(snap) != 96 || Pixels.get_Height(snap) != 64) {
        fail("manual frame docs snippet failed");
        return;
    }

    world.Destroy();
    Terminal.Say("PASS");
}
