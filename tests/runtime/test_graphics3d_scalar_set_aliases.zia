//
// File: tests/runtime/test_graphics3d_scalar_set_aliases.zia
// Purpose: Regression coverage for Graphics3D scalar property setter aliases.
//
//===----------------------------------------------------------------------===//

module TestGraphics3DScalarSetAliases;

bind Viper.Graphics3D;
bind Viper.Terminal;

/// @brief Exercise advertised static `Set*` method aliases for scalar Graphics3D properties.
/// @details The runtime class catalog exposes instance-style methods such as
/// `Material3D.SetRoughness(value)`, while Zia static calls use ABI-shaped functions such as
/// `Material3D.SetRoughness(material, value)`. This test verifies both the compiler binding and
/// runtime dispatch for the static call spelling.
func start() {
    var mat = Material3D.NewPBR(0.4, 0.5, 0.6);

    Material3D.SetMetallic(mat, 0.72);
    Material3D.SetRoughness(mat, 0.31);
    Material3D.SetAO(mat, 0.83);
    Material3D.SetEmissiveIntensity(mat, 1.45);
    Material3D.SetNormalScale(mat, 0.62);
    Material3D.SetReflectivity(mat, 0.27);

    if (Material3D.get_Metallic(mat) < 0.71 || Material3D.get_Metallic(mat) > 0.73) {
        Say("FAIL: SetMetallic alias should update Metallic");
        return;
    }
    if (Material3D.get_Roughness(mat) < 0.30 || Material3D.get_Roughness(mat) > 0.32) {
        Say("FAIL: SetRoughness alias should update Roughness");
        return;
    }
    if (Material3D.get_AO(mat) < 0.82 || Material3D.get_AO(mat) > 0.84) {
        Say("FAIL: SetAO alias should update AO");
        return;
    }
    if (Material3D.get_EmissiveIntensity(mat) < 1.44 ||
        Material3D.get_EmissiveIntensity(mat) > 1.46) {
        Say("FAIL: SetEmissiveIntensity alias should update EmissiveIntensity");
        return;
    }
    if (Material3D.get_NormalScale(mat) < 0.61 || Material3D.get_NormalScale(mat) > 0.63) {
        Say("FAIL: SetNormalScale alias should update NormalScale");
        return;
    }
    if (Material3D.get_Reflectivity(mat) < 0.26 || Material3D.get_Reflectivity(mat) > 0.28) {
        Say("FAIL: SetReflectivity alias should update Reflectivity");
        return;
    }

    var light = Light3D.NewAmbient(0.1, 0.2, 0.3);
    Light3D.SetEnabled(light, false);
    Light3D.SetCastsShadows(light, true);

    if (Light3D.get_Enabled(light) != false) {
        Say("FAIL: SetEnabled alias should update Enabled");
        return;
    }
    if (Light3D.get_CastsShadows(light) != true) {
        Say("FAIL: SetCastsShadows alias should update CastsShadows");
        return;
    }

    Say("PASS");
}
