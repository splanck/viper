module TestPhysics3DQueries;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func start() {
    var world = Physics3DWorld.New(0.0, 0.0, 0.0);
    var nearBox = Physics3DBody.NewAABB(0.5, 0.5, 0.5, 0.0);
    var farBox = Physics3DBody.NewAABB(0.5, 0.5, 0.5, 0.0);
    Physics3DBody.SetPosition(nearBox, 4.0, 0.0, 0.0);
    Physics3DBody.SetPosition(farBox, 7.0, 0.0, 0.0);
    Physics3DBody.set_CollisionLayer(nearBox, 1);
    Physics3DBody.set_CollisionLayer(farBox, 2);
    Physics3DWorld.Add(world, nearBox);
    Physics3DWorld.Add(world, farBox);

    var origin = Vec3.New(0.0, 0.0, 0.0);
    var dir = Vec3.New(1.0, 0.0, 0.0);
    var delta = Vec3.New(5.0, 0.0, 0.0);
    var hit = Physics3DWorld.Raycast(world, origin, dir, 20.0, 3);
    if (PhysicsHit3D.get_Body(hit) != nearBox) {
        Say("FAIL: raycast should return the nearest body");
        return;
    }

    var hits = Physics3DWorld.RaycastAll(world, origin, dir, 20.0, 3);
    if (PhysicsHitList3D.get_Count(hits) != 2) {
        Say("FAIL: RaycastAll should return two hits");
        return;
    }
    var hit0 = PhysicsHitList3D.Get(hits, 0);
    var hit1 = PhysicsHitList3D.Get(hits, 1);
    if (PhysicsHit3D.get_Distance(hit0) >= PhysicsHit3D.get_Distance(hit1)) {
        Say("FAIL: RaycastAll hits should be sorted by distance");
        return;
    }

    var overlap = Physics3DWorld.OverlapSphere(world, Vec3.New(4.0, 0.0, 0.0), 1.0, 1);
    if (PhysicsHitList3D.get_Count(overlap) != 1) {
        Say("FAIL: OverlapSphere should honor the mask");
        return;
    }
    if (PhysicsHit3D.get_Body(PhysicsHitList3D.Get(overlap, 0)) != nearBox) {
        Say("FAIL: OverlapSphere returned the wrong body");
        return;
    }

    var overlapAabb = Physics3DWorld.OverlapAABB(
        world,
        Vec3.New(6.0, -1.0, -1.0),
        Vec3.New(8.0, 1.0, 1.0),
        2
    );
    if (PhysicsHitList3D.get_Count(overlapAabb) != 1) {
        Say("FAIL: OverlapAABB should honor the mask");
        return;
    }
    if (PhysicsHit3D.get_Body(PhysicsHitList3D.Get(overlapAabb, 0)) != farBox) {
        Say("FAIL: OverlapAABB returned the wrong body");
        return;
    }

    var sweepWorld = Physics3DWorld.New(0.0, 0.0, 0.0);
    var wall = Physics3DBody.NewAABB(1.0, 1.0, 1.0, 0.0);
    Physics3DBody.SetPosition(wall, 0.0, 0.0, 0.0);
    Physics3DWorld.Add(sweepWorld, wall);
    var sweepHit = Physics3DWorld.SweepSphere(
        sweepWorld,
        Vec3.New(0.25, 0.0, 0.0),
        0.5,
        delta,
        1
    );
    if (PhysicsHit3D.get_StartedPenetrating(sweepHit) == 0) {
        Say("FAIL: SweepSphere should report initial penetration");
        return;
    }

    var capsuleHit = Physics3DWorld.SweepCapsule(
        sweepWorld,
        Vec3.New(-3.0, -0.5, 0.0),
        Vec3.New(-3.0, 0.5, 0.0),
        0.5,
        Vec3.New(4.5, 0.0, 0.0),
        1
    );
    if (PhysicsHit3D.get_Distance(capsuleHit) <= 0.0) {
        Say("FAIL: SweepCapsule should find a forward hit");
        return;
    }

    Say("PASS");
}
