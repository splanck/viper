module test_game3d_collision_probe;

bind Viper.Game3D as Game3D;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    var world = Game3D.World3D.New("Game3D Collision Probe", 80, 60);
    Game3D.World3D.setGravity(world, 0.0, 0.0, 0.0);

    var a = Game3D.Entity3D.New();
    Game3D.Entity3D.setName(a, "A");
    Game3D.Entity3D.attachBody(a, Game3D.BodyDef.StaticBox(1.0, 1.0, 1.0));
    Game3D.World3D.spawn(world, a);

    var b = Game3D.Entity3D.New();
    Game3D.Entity3D.setName(b, "B");
    var bDef = Game3D.BodyDef.Box(1.0, 1.0, 1.0, 1.0);
    Game3D.BodyDef.withMask(bDef, Game3D.LayerMask.Of(Game3D.Layers.get_World()));
    Game3D.Entity3D.attachBody(b, bDef);
    Game3D.Entity3D.setPosition(b, 0.5, 0.0, 0.0);
    Game3D.World3D.spawn(world, b);

    Game3D.World3D.stepSimulation(world, 0.016);
    if (Game3D.World3D.collisionEventCount(world, Game3D.CollisionPhase.get_Enter()) <= 0) {
        fail("no enter event");
        return;
    }
    var evt = Game3D.World3D.collisionEvent(world, Game3D.CollisionPhase.get_Enter(), 0);
    if (evt == null ||
        Game3D.Collision3DEvent.get_phase(evt) != Game3D.CollisionPhase.get_Enter()) {
        fail("enter event phase missing");
        return;
    }
    if (Game3D.Collision3DEvent.get_a(evt) == null ||
        Game3D.Collision3DEvent.get_b(evt) == null ||
        Game3D.Collision3DEvent.get_raw(evt) == null) {
        fail("event missing entity/raw handles");
        return;
    }
    if (Game3D.Collision3DEvent.other(evt, a) != b) {
        fail("event.other did not resolve opposite entity");
        return;
    }
    if (Game3D.Collision3DEvent.point(evt) == null ||
        Game3D.Collision3DEvent.normal(evt) == null) {
        fail("event point/normal missing");
        return;
    }

    Game3D.World3D.stepSimulation(world, 0.016);
    if (Game3D.World3D.collisionEventCount(world, Game3D.CollisionPhase.get_Stay()) <= 0) {
        fail("no stay event");
        return;
    }

    Game3D.Entity3D.setPosition(b, 5.0, 0.0, 0.0);
    Game3D.World3D.stepSimulation(world, 0.016);
    if (Game3D.World3D.collisionEventCount(world, Game3D.CollisionPhase.get_Exit()) <= 0) {
        fail("no exit event");
        return;
    }

    Game3D.World3D.destroy(world);

    var triggerWorld = Game3D.World3D.New("Game3D Trigger Probe", 80, 60);
    Game3D.World3D.setGravity(triggerWorld, 0.0, 0.0, 0.0);

    var trigger = Game3D.Entity3D.New();
    var triggerDef = Game3D.BodyDef.StaticBox(1.0, 1.0, 1.0);
    Game3D.BodyDef.withLayer(triggerDef, Game3D.Layers.get_Trigger());
    Game3D.BodyDef.asTrigger(triggerDef);
    Game3D.Entity3D.attachBody(trigger, triggerDef);
    Game3D.World3D.spawn(triggerWorld, trigger);

    var body = Game3D.Entity3D.New();
    var bodyDef = Game3D.BodyDef.Sphere(0.5, 1.0);
    var triggerMask = Game3D.LayerMask.Of(Game3D.Layers.get_World());
    Game3D.LayerMask.include(triggerMask, Game3D.Layers.get_Trigger());
    Game3D.BodyDef.withMask(bodyDef, triggerMask);
    Game3D.Entity3D.attachBody(body, bodyDef);
    Game3D.World3D.spawn(triggerWorld, body);

    Game3D.World3D.stepSimulation(triggerWorld, 0.016);
    var triggerEvt = Game3D.World3D.collisionEvent(triggerWorld, Game3D.CollisionPhase.get_Enter(), 0);
    if (triggerEvt == null || Game3D.Collision3DEvent.get_isTrigger(triggerEvt) == false) {
        fail("trigger event missing");
        return;
    }

    Game3D.World3D.destroy(triggerWorld);
    Terminal.Say("PASS");
}
