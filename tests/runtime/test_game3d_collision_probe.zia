module test_game3d_collision_probe;

bind Viper.Game3D as Game3D;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    var world = Game3D.World3D.New("Game3D Collision Probe", 80, 60);
    world.SetGravity(0.0, 0.0, 0.0);

    var a = Game3D.Entity3D.New();
    a.Name = "A";
    a.AttachBody(Game3D.BodyDef.StaticBox(1.0, 1.0, 1.0));
    world.Spawn(a);

    var b = Game3D.Entity3D.New();
    b.Name = "B";
    var bDef = Game3D.BodyDef.Box(1.0, 1.0, 1.0, 1.0);
    bDef.WithMask(Game3D.LayerMask.Of(Game3D.Layers.get_World()));
    bDef.WithSync(Game3D.SyncMode.get_BodyFromNode());
    b.AttachBody(bDef);
    b.SetPosition(0.5, 0.0, 0.0);
    world.Spawn(b);

    world.StepSimulation(0.016);
    if (world.CollisionEventCount(Game3D.CollisionPhase.get_Enter()) <= 0) {
        fail("no enter event");
        return;
    }
    var evt = world.CollisionEvent(Game3D.CollisionPhase.get_Enter(), 0);
    if (evt == null ||
        evt.Phase != Game3D.CollisionPhase.get_Enter()) {
        fail("enter event phase missing");
        return;
    }
    if (evt.EntityA == null ||
        evt.EntityB == null ||
        evt.Raw == null) {
        fail("event missing entity/raw handles");
        return;
    }
    if (evt.Other(a) != b) {
        fail("event.other did not resolve opposite entity");
        return;
    }
    if (evt.Point() == null ||
        evt.Normal() == null) {
        fail("event point/normal missing");
        return;
    }

    world.StepSimulation(0.016);
    if (world.CollisionEventCount(Game3D.CollisionPhase.get_Stay()) <= 0) {
        fail("no stay event");
        return;
    }

    b.SetPosition(5.0, 0.0, 0.0);
    world.StepSimulation(0.016);
    if (world.CollisionEventCount(Game3D.CollisionPhase.get_Exit()) <= 0) {
        fail("no exit event");
        return;
    }

    world.Destroy();

    var triggerWorld = Game3D.World3D.New("Game3D Trigger Probe", 80, 60);
    triggerWorld.SetGravity(0.0, 0.0, 0.0);

    var trigger = Game3D.Entity3D.New();
    var triggerDef = Game3D.BodyDef.StaticBox(1.0, 1.0, 1.0);
    triggerDef.WithLayer(Game3D.Layers.get_Trigger());
    triggerDef.AsTrigger();
    trigger.AttachBody(triggerDef);
    triggerWorld.Spawn(trigger);

    var body = Game3D.Entity3D.New();
    var bodyDef = Game3D.BodyDef.Sphere(0.5, 1.0);
    var triggerMask = Game3D.LayerMask.Of(Game3D.Layers.get_World());
    triggerMask.Include(Game3D.Layers.get_Trigger());
    bodyDef.WithMask(triggerMask);
    body.AttachBody(bodyDef);
    triggerWorld.Spawn(body);

    triggerWorld.StepSimulation(0.016);
    var triggerEvt = triggerWorld.CollisionEvent(Game3D.CollisionPhase.get_Enter(), 0);
    if (triggerEvt == null || triggerEvt.IsTrigger == false) {
        fail("trigger event missing");
        return;
    }

    triggerWorld.Destroy();
    Terminal.Say("PASS");
}
