module test_game3d_camera_controllers_probe;

bind Viper.Game3D as Game3D;
bind Viper.Graphics3D as G3D;
bind Viper.Math as Math;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) { d = 0.0 - d; }
    return d <= eps;
}

func start() {
    var world = Game3D.World3D.New("Game3D Camera Controllers Probe", 64, 48);
    var canvas = Game3D.World3D.get_canvas(world);
    var camera = Game3D.World3D.get_camera(world);

    var freeFly = Game3D.FreeFlyController.New(world);
    Game3D.FreeFlyController.set_speed(freeFly, 10.0);
    Game3D.FreeFlyController.set_lookSensitivity(freeFly, 0.10);
    Game3D.World3D.setCameraController(world, freeFly);

    var before = G3D.Camera3D.get_Position(camera);
    G3D.Canvas3D.PushSyntheticKey(canvas, Game3D.Keys.get_W(), true);
    G3D.Canvas3D.PushSyntheticMouse(canvas, 12.0, -4.0, 0, 0.0);
    Game3D.World3D.runFramesOnly(world, 1, 0.1);
    var after = G3D.Camera3D.get_Position(camera);
    if (Math.Vec3.get_Z(after) >= Math.Vec3.get_Z(before) - 0.05) {
        fail("FreeFlyController did not move camera from synthetic W input");
        return;
    }
    G3D.Canvas3D.ClearSyntheticInput(canvas);

    var orbitTarget = new Math.Vec3(0.0, 1.0, 0.0);
    var orbit = Game3D.OrbitController.New(world, orbitTarget);
    Game3D.World3D.setCameraController(world, orbit);
    G3D.Canvas3D.PushSyntheticMouse(canvas, 20.0, -8.0, 1, 1.0);
    Game3D.World3D.runFramesOnly(world, 1, 0.1);
    if (Game3D.OrbitController.get_yaw(orbit) <= 0.0 ||
        Game3D.OrbitController.get_distance(orbit) >= 6.0) {
        fail("OrbitController did not consume mouse drag and wheel input");
        return;
    }
    G3D.Canvas3D.ClearSyntheticInput(canvas);

    var target = Game3D.Entity3D.New();
    Game3D.Entity3D.setPosition(target, 4.0, 0.5, -2.0);
    Game3D.World3D.spawn(world, target);
    var follow = Game3D.FollowController.New(world, target, new Math.Vec3(0.0, 2.0, 5.0));
    Game3D.FollowController.set_damping(follow, 0.0);
    Game3D.World3D.setCameraController(world, follow);
    Game3D.World3D.runFramesOnly(world, 1, 0.1);

    var followPos = G3D.Camera3D.get_Position(camera);
    if (near(Math.Vec3.get_X(followPos), 4.0, 0.0001) == false ||
        near(Math.Vec3.get_Y(followPos), 2.5, 0.0001) == false ||
        near(Math.Vec3.get_Z(followPos), 3.0, 0.0001) == false) {
        fail("FollowController did not track target plus offset in lateUpdate");
        return;
    }

    Game3D.Entity3D.setPosition(target, 6.0, 0.5, -3.0);
    Game3D.World3D.stepSimulation(world, 0.1);
    followPos = G3D.Camera3D.get_Position(camera);
    if (near(Math.Vec3.get_X(followPos), 6.0, 0.0001) == false ||
        near(Math.Vec3.get_Z(followPos), 2.0, 0.0001) == false) {
        fail("FollowController did not track post-physics target pose");
        return;
    }

    Game3D.World3D.destroy(world);
    Terminal.Say("PASS");
}
