module test_game3d_destroyed_entity_reject;

bind Viper.Game3D as Game3D;

func start() {
    var world = Game3D.World3D.New("Game3D Destroyed Entity Reject", 32, 24);
    var entity = Game3D.Entity3D.New();
    Game3D.World3D.spawn(world, entity);
    Game3D.World3D.destroy(world);
    Game3D.Entity3D.position(entity);
}
