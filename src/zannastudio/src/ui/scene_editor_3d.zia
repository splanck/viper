//
// File: zannastudio/src/ui/scene_editor_3d.zia
// Purpose: Visual hierarchy, transform/material inspector, additive importer,
//          and directly manipulable wireframe viewport for VSCN.
// Key invariants:
//   - The live SceneGraph is serialized back to Document.content after every
//     accepted edit; a failed serialization rolls the graph back.
//   - One complete gizmo drag creates one local-transform history snapshot.
//   - Compact windows show viewport or inspector at full width, never two slivers.
//   - Compact wrapped toolbars reserve every row so actions remain reachable.
//   - VSCN parsing and serialization use unique bounded staging files because
//     the runtime deliberately exposes file-oriented asset APIs.
//   - Hierarchy traversal and preview work are capped for hostile assets.
//   - Group inspector, reparent, and selection commands are transactional;
//     hierarchy cycles are rejected before mutation and inspector inputs never
//     inherit viewport shortcuts.
// Ownership/Lifetime:
//   - Main owns one controller; WorkbenchShell owns its persistent host widgets.
//   - Staging files are deleted before every load/commit operation returns.
// Links: zannastudio/src/core/document.zia,
//        zannastudio/src/ui/scene_clipboard.zia,
//        zannastudio/src/ui/scene_hierarchy_3d.zia,
//        zannastudio/src/ui/scene_material_3d.zia,
//        zannastudio/src/ui/scene_material_inspector_3d.zia,
//        zannastudio/src/ui/scene_transform_3d.zia,
//        docs/graphics3d-guide.md,
//        docs/adr/0156-listbox-selected-row-data.md
//
//===----------------------------------------------------------------------===//

module scene_editor_3d;

// ============================================================================
// MODULE: scene_editor_3d
// PURPOSE: Present one VSCN document as a responsive hierarchy, wireframe
//          viewport, transform toolbar, and numeric inspector.
//
// WHERE-THIS-FITS: Main pumps this controller only for the active 3D scene.
//          SceneGraph is transient; Document.content remains the canonical
//          save, session, and recovery payload.
//
// TEACHING-NOTE: A drag mutates the live node for visual feedback but
//          serializes once on release. Escape restores copied scalar origins,
//          so cancelation never requires a partial document rewrite.
// ============================================================================

bind "../core/document";
bind "../core/project_manager";
bind "../services/file_utils";
bind "../services/safe_io";
bind "scene_asset_browser";
bind "scene_clipboard";
bind "scene_hierarchy_3d";
bind "scene_selection";
bind "scene_material_inspector_3d";
bind "scene_material_3d";
bind "scene_transform_3d";

