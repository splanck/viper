    /// @brief Borrow Studio's multi-root project index for non-modal assets.
    expose func SetWorkspaceContext(
        nextProjectManager: project_manager.ProjectManager) {
        projectManager = nextProjectManager;
        ReloadComponentSchema();
    }

    /// @brief Reload project component templates for the active document root.
    expose func ReloadComponentSchema() {
        var rootPath = ComponentSchemaRoot();
        componentSchemaPath =
            scene_component_schema.PathForRoot(rootPath);
        if componentPalette != null and componentPalette.group != null
           and componentAuthoring != null {
            componentAuthoring.Load(
                componentSchemaPath,
                scene_component_schema.TARGET_3D_NODE,
                componentPalette);
            componentSchema = componentAuthoring.schema;
            RefreshComponentPalette();
        } else {
            componentSchema =
                scene_component_schema.LoadPath(componentSchemaPath);
        }
    }

    /// @brief Keep multi-root schema ownership aligned with document ownership.
    hide func EnsureComponentSchema(force: Boolean) {
        var nextPath = scene_component_schema.PathForRoot(
            ComponentSchemaRoot());
        if force or nextPath != componentSchemaPath {
            ReloadComponentSchema();
        }
    }

    /// @brief Resolve the unambiguous workspace root for the current scene.
    hide func ComponentSchemaRoot() -> String {
        if projectManager == null { return ""; }
        if currentDoc != null and currentDoc.filePath != "" {
            var owner =
                projectManager.WorkspaceRootPathForPath(currentDoc.filePath);
            if owner != "" { return owner; }
        }
        if projectManager.RootCount() == 1 {
            return projectManager.RootPathAt(0);
        }
        return "";
    }

    /// @brief Pump the active document and return true when VSCN content changed.
    expose func Pump(activeDoc: document.Document) -> Boolean {
        if activeDoc == null or activeDoc.kind != file_utils.DOC_KIND_SCENE_3D {
            return false;
        }
        if activeDoc != currentDoc or activeDoc.content != currentSerialized {
            Activate(activeDoc);
        }
        EnsureComponentSchema(false);
        if activeDoc == currentDoc and activeDoc.isModified == false
           and activeDoc.content == currentSerialized {
            cleanSerialized = currentSerialized;
        }

        RefreshResponsiveLayout();
        if inspectorButton.WasClicked() { ToggleInspectorPane(); }

        var changed = false;
        if newSceneButton.WasClicked() {
            scene = SceneGraph.New();
            loadError = "";
            selectedIndex = -1;
            selectedIndices = [];
            selectedNodeMetadata = -1;
            metadataOwnerIndex = -1;
            viewTargetX = 0.0;
            viewTargetY = 0.0;
            viewTargetZ = 0.0;
            SetEditorControlsEnabled(true);
            RefreshHierarchy(null);
            changed = CommitScene("Created empty 3D scene") or changed;
        }
        if importAssetButton.WasClicked() {
            changed = ImportAsset() or changed;
        }
        var projectImportPath = importAssetBrowser.Pump(
            projectManager, currentDoc != null);
        if projectImportPath != "" {
            changed = ImportAssetPath(projectImportPath) or changed;
        }
        var projectMapPath = materialInspector.assetBrowser.Pump(
            projectManager,
            scene != null and SelectedNode() != null
            and selectedIndices.count() > 0);
        if projectMapPath != "" {
            changed = ApplySelectedMaterialMapPath(
                materialInspector.mapSlot.Selected,
                projectMapPath) or changed;
        }
        UpdateViewportSize();
        if viewportModeButton.WasClicked() {
            var nextViewportMode = VIEWPORT_MODE_WIREFRAME;
            if viewportMode == VIEWPORT_MODE_WIREFRAME {
                nextViewportMode = VIEWPORT_MODE_SHADED;
            }
            SetViewportMode(nextViewportMode);
        }
        if moveToolButton.WasClicked() { SetGizmoMode(GIZMO_MODE_MOVE); }
        if rotateToolButton.WasClicked() { SetGizmoMode(GIZMO_MODE_ROTATE); }
        if scaleToolButton.WasClicked() { SetGizmoMode(GIZMO_MODE_SCALE); }
        if transformSpaceButton.WasClicked() {
            var nextSpace = scene_transform_3d.TRANSFORM_SPACE_WORLD;
            if gizmoTransformSpace
               == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                nextSpace = scene_transform_3d.TRANSFORM_SPACE_LOCAL;
            }
            SetGizmoTransformSpace(nextSpace);
        }
        var nextSnapRevision = snapTransformCheck.GetRevision();
        if nextSnapRevision != snapTransformRevision {
            snapTransformRevision = nextSnapRevision;
            SetGizmoSnapEnabled(snapTransformCheck.IsChecked());
        }
        if scene == null {
            if renderDirty { RenderViewport(); }
            ApplyPendingWorkspaceScroll();
            ApplyInspectorLayout();
            CaptureWorkspaceState();
            return changed;
        }

        PumpHierarchySearchControls();
        if addEmptyButton.WasClicked() {
            changed = AddPrimitive(PRIMITIVE_EMPTY, false) or changed;
        }
        if addChildButton.WasClicked() {
            changed = AddPrimitive(PRIMITIVE_EMPTY, true) or changed;
        }
        if addBoxButton.WasClicked() {
            changed = AddPrimitive(PRIMITIVE_BOX, false) or changed;
        }
        if addSphereButton.WasClicked() {
            changed = AddPrimitive(PRIMITIVE_SPHERE, false) or changed;
        }
        if addPlaneButton.WasClicked() {
            changed = AddPrimitive(PRIMITIVE_PLANE, false) or changed;
        }
        if addLightButton.WasClicked() {
            changed = AddLightNode(
                "Point Light " + scene.NodeCount, -1) >= 0 or changed;
        }
        if duplicateNodeButton.WasClicked() {
            changed = DuplicateSelectedNodes() > 0 or changed;
        }
        if deleteNodeButton.WasClicked() {
            changed = DeleteSelectedNodes() or changed;
        }
        if hierarchyTree.WasSelectionChanged() {
            var primaryRow = hierarchyTree.GetSelected();
            selectedIndex = -1;
            if primaryRow != null {
                selectedIndex = Parse.IntOr(
                    GUI.TreeView.Node.GetData(primaryRow), -1);
            }
            selectedIndices = scene_selection.FromData(
                hierarchyTree.GetSelectedData(),
                flatNodes.count(),
                selectedIndex);
            if selectedIndex < 0 and selectedIndices.count() > 0 {
                selectedIndex = selectedIndices.get(0);
            }
            RefreshSelectedFields();
            SetEditorControlsEnabled(scene != null);
            renderDirty = true;
        }
        if hierarchyTree.WasDropReceived() {
            var sourceIndex = Parse.IntOr(
                hierarchyTree.GetDropSourceData(), -1);
            var targetIndex = Parse.IntOr(
                hierarchyTree.GetDropTargetData(), -1);
            var dropPosition = hierarchyTree.GetDropPosition();
            hierarchyTree.ClearDrop();
            changed = ApplyHierarchyDrop(
                sourceIndex, targetIndex, dropPosition) or changed;
        }
        var metadataNode = SelectedNode();
        metadataInspector.Pump(metadataNode);
        selectedNodeMetadata = metadataInspector.selectedProperty;
        if metadataInspector.TakeSetRequested()
           and selectedIndices.count() == 1 {
            changed = SetNodeMetadata(
                selectedIndex,
                metadataInspector.SelectedKey(),
                metadataInspector.keyInput.Text,
                metadataInspector.SelectedKind(),
                metadataInspector.valueInput.Text) or changed;
        }
        if metadataInspector.TakeRemoveRequested()
           and selectedIndices.count() == 1 {
            changed = RemoveNodeMetadata(
                selectedIndex,
                metadataInspector.SelectedKey()) or changed;
        }
        changed = PumpComponentControls() or changed;
        if parentDropdown.WasChanged() {
            UpdateParentControlAvailability();
        }
        if preserveWorldReparentCheck.WasChanged() {
            UpdateParentControlAvailability();
        }
        if reparentButton.WasClicked() {
            changed = ReparentSelectedNodes(
                SelectedParentTargetIndex()) or changed;
        }
        if moveSiblingEarlierButton.WasClicked() {
            changed = MoveSelectedSiblings(-1) or changed;
        }
        if moveSiblingLaterButton.WasClicked() {
            changed = MoveSelectedSiblings(1) or changed;
        }
        if applyTransformButton.WasClicked() {
            if selectedIndices.count() > 1 {
                changed = ApplySelectedTransformDeltas(
                    positionX.Value, positionY.Value, positionZ.Value,
                    rotationX.Value, rotationY.Value, rotationZ.Value,
                    scaleX.Value, scaleY.Value, scaleZ.Value) or changed;
            } else if selectedIndices.count() == 1 {
                changed = ApplySelectedNode() or changed;
            }
        }
        if nameInput.WasSubmitted() and selectedIndices.count() == 1 {
            changed = ApplySelectedNode() or changed;
        }
        if lightInspector.typeDropdown.WasChanged() {
            lightInspector.UpdateTypeControls();
        }
        if lightInspector.applyButton.WasClicked()
           and selectedIndices.count() == 1 {
            changed = ApplySelectedLightFromControls() or changed;
        }
        if lightInspector.removeButton.WasClicked()
           and selectedIndices.count() == 1 {
            changed = RemoveNodeLight(selectedIndex) or changed;
        }
        materialInspector.PumpDraftIntent();
        if materialInspector.applyButton.WasClicked()
           and selectedIndices.count() > 0 {
            changed = ApplySelectedMaterialFromControls() or changed;
        }
        if materialInspector.removeButton.WasClicked()
           and selectedIndices.count() > 0 {
            changed = RemoveSelectedMaterials() or changed;
        }
        if materialInspector.mapSlot.WasChanged() {
            materialInspector.RefreshMapSummarySelection(
                SelectedMaterialNodes());
            UpdateMaterialControls(true);
        }
        if materialInspector.chooseMapButton.WasClicked()
           and selectedIndices.count() > 0 {
            changed = ChooseMaterialMap() or changed;
        }
        if materialInspector.clearMapButton.WasClicked()
           and selectedIndices.count() > 0 {
            changed = ClearSelectedMaterialMap(
                materialInspector.mapSlot.Selected) or changed;
        }
        var nextVisibleRevision = visibleCheck.GetRevision();
        if nextVisibleRevision != visibleRevision {
            visibleRevision = nextVisibleRevision;
            if selectedIndices.count() > 0
               and visibleCheck.IsIndeterminate() == false {
                changed = ApplySelectedVisibility(
                    visibleCheck.IsChecked()) or changed;
            }
        }

        if orbitLeftButton.WasClicked() {
            viewYawDegrees = NormalizeYawDegrees(viewYawDegrees - 15);
            renderDirty = true;
        }
        if orbitRightButton.WasClicked() {
            viewYawDegrees = NormalizeYawDegrees(viewYawDegrees + 15);
            renderDirty = true;
        }
        if orbitUpButton.WasClicked() {
            viewPitchDegrees = ClampInt3D(viewPitchDegrees + 10, -80, 80);
            renderDirty = true;
        }
        if orbitDownButton.WasClicked() {
            viewPitchDegrees = ClampInt3D(viewPitchDegrees - 10, -80, 80);
            renderDirty = true;
        }
        if zoomOutButton.WasClicked() {
            viewScale = ClampInt3D(viewScale - 4, 4, 120);
            renderDirty = true;
        }
        if zoomInButton.WasClicked() {
            viewScale = ClampInt3D(viewScale + 4, 4, 120);
            renderDirty = true;
        }
        if frameButton.WasClicked() {
            FrameAll();
            renderDirty = true;
        }
        if frameSelectedButton.WasClicked() {
            FrameSelected();
            renderDirty = true;
        }

        changed = PumpViewportNavigation() or changed;
        if renderDirty { RenderViewport(); }
        ApplyPendingWorkspaceScroll();
        // Document activation and undo can restore the persisted divider
        // fraction during this pump. Reassert the responsive one-pane policy
        // before capturing state so compact mode cannot silently reopen both
        // panes for one or more frames.
        ApplyInspectorLayout();
        CaptureWorkspaceState();
        return changed;
    }

    /// @brief Load one document transactionally through the runtime VSCN loader.
    expose func Activate(doc: document.Document) {
        LoadDocumentModel(doc, false);
    }

    /// @brief Return whether a committed VSCN edit can be undone.
    expose func CanUndo() -> Boolean {
        return undoStack.count() > 0;
    }

    /// @brief Return whether an undone VSCN edit can be redone.
    expose func CanRedo() -> Boolean {
        return redoStack.count() > 0;
    }

    /// @brief Restore the preceding canonical VSCN snapshot.
    expose func Undo() -> Boolean {
        if currentDoc == null or undoStack.count() == 0 { return false; }
        var index = undoStack.count() - 1;
        var target = undoStack.get(index);
        undoStack.removeAt(index);
        PushHistory(redoStack, currentSerialized);
        currentDoc.content = target;
        currentDoc.isModified = target != cleanSerialized;
        revision = revision + 1;
        LoadDocumentModel(currentDoc, true);
        toolbarStatus.SetText("Undid 3D scene edit");
        return true;
    }

    /// @brief Reapply the next canonical VSCN snapshot.
    expose func Redo() -> Boolean {
        if currentDoc == null or redoStack.count() == 0 { return false; }
        var index = redoStack.count() - 1;
        var target = redoStack.get(index);
        redoStack.removeAt(index);
        PushHistory(undoStack, currentSerialized);
        currentDoc.content = target;
        currentDoc.isModified = target != cleanSerialized;
        revision = revision + 1;
        LoadDocumentModel(currentDoc, true);
        toolbarStatus.SetText("Redid 3D scene edit");
        return true;
    }

    /// @brief Load one document model with optional undo-history retention.
    hide func LoadDocumentModel(doc: document.Document,
                                preserveHistory: Boolean) {
        var switchingDocument = currentDoc != doc;
        lastViewportClickNode = -1;
        lastViewportClickMs = 0;
        if currentDoc != null { CaptureWorkspaceState(); }
        if preserveHistory == false {
            var savedState = doc.scene3DWorkspace;
            var canRestoreHistory = switchingDocument
                and savedState != null
                and savedState.historyContent == doc.content;
            if canRestoreHistory {
                undoStack = savedState.undoStack;
                redoStack = savedState.redoStack;
                cleanSerialized = savedState.cleanSerialized;
            } else {
                undoStack = [];
                redoStack = [];
                if doc.isModified == false { cleanSerialized = doc.content; }
                else { cleanSerialized = ""; }
            }
        }
        currentDoc = doc;
        currentSerialized = doc.content;
        EnsureComponentSchema(false);
        RestoreWorkspaceState(doc);
        gizmoHoverAxis = GIZMO_AXIS_NONE;
        ResetGizmoDrag(true);
        loadError = "";
        scene = LoadGraphFromContent(doc.content);
        if scene == null {
            SetEditorControlsEnabled(false);
            toolbarStatus.SetText("Scene needs repair");
            detailLabel.SetText("The VSCN asset could not be loaded. The original "
                                + "document is preserved.\n\n" + loadError);
        } else {
            SetEditorControlsEnabled(true);
            toolbarStatus.SetText("3D scene ready");
            detailLabel.SetText("");
        }
        RefreshHierarchy(null);
        renderDirty = true;
    }

    /// @brief Snapshot live hierarchy, camera, inspector, and undo state.
    hide func CaptureWorkspaceState() {
        if currentDoc == null or currentDoc.scene3DWorkspace == null { return; }
        var state = currentDoc.scene3DWorkspace;
        state.initialized = true;
        state.selectedIndex = selectedIndex;
        state.selectedIndices = selectedIndices;
        state.selectedNodeMetadata = selectedNodeMetadata;
        state.transformMode = gizmoMode;
        state.transformSpace = gizmoTransformSpace;
        state.transformSnapEnabled = gizmoSnapEnabled;
        state.viewYawDegrees = NormalizeYawDegrees(viewYawDegrees);
        state.viewPitchDegrees = ClampInt3D(viewPitchDegrees, -80, 80);
        state.viewScale = ClampInt3D(viewScale, 4, 120);
        state.viewportMode = ClampInt3D(
            viewportMode, VIEWPORT_MODE_SHADED, VIEWPORT_MODE_WIREFRAME);
        state.viewTargetX = ClampNumber3D(
            viewTargetX, -1000000.0, 1000000.0);
        state.viewTargetY = ClampNumber3D(
            viewTargetY, -1000000.0, 1000000.0);
        state.viewTargetZ = ClampNumber3D(
            viewTargetZ, -1000000.0, 1000000.0);
        if bodySplit != null {
            state.splitPosition = ClampNumber3D(
                bodySplit.GetPosition(), 0.20, 0.85);
        }
        if inspectorScroll != null {
            state.inspectorScrollY = ClampNumber3D(
                LogicalScrollY(inspectorScroll), 0.0, 1000000.0);
        }
        state.inspectorRequestedVisible = inspectorRequestedVisible;
        state.compactInspectorShown = compactInspectorShown;
        state.undoStack = undoStack;
        state.redoStack = redoStack;
        state.cleanSerialized = cleanSerialized;
        state.historyContent = currentSerialized;
    }

    /// @brief Restore a document's validated hierarchy, camera, and inspector.
    hide func RestoreWorkspaceState(doc: document.Document) {
        var state = doc.scene3DWorkspace;
        if state == null or state.initialized == false {
            selectedIndex = -1;
            selectedIndices = [];
            selectedNodeMetadata = -1;
            metadataOwnerIndex = -1;
            gizmoMode = GIZMO_MODE_MOVE;
            gizmoTransformSpace =
                scene_transform_3d.TRANSFORM_SPACE_LOCAL;
            gizmoSnapEnabled = false;
            viewYawDegrees = 35;
            viewPitchDegrees = -25;
            viewScale = 28;
            viewportMode = VIEWPORT_MODE_SHADED;
            viewTargetX = 0.0;
            viewTargetY = 0.0;
            viewTargetZ = 0.0;
            if bodySplit != null { bodySplit.SetPosition(0.65); }
            pendingInspectorScrollY = 0.0;
            inspectorRequestedVisible = true;
            compactInspectorShown = false;
            restoreInspectorScrollPending = true;
            SyncGizmoModeControls();
            UpdateViewportModeControls();
            return;
        }

        selectedIndex = ClampInt3D(
            state.selectedIndex, -1, MAX_EDITOR_NODES - 1);
        selectedIndices = state.selectedIndices;
        selectedNodeMetadata = ClampInt3D(
            state.selectedNodeMetadata, -1, 255);
        metadataOwnerIndex = selectedIndex;
        gizmoMode = ClampInt3D(
            state.transformMode, GIZMO_MODE_MOVE, GIZMO_MODE_SCALE);
        gizmoTransformSpace = ClampInt3D(
            state.transformSpace,
            scene_transform_3d.TRANSFORM_SPACE_LOCAL,
            scene_transform_3d.TRANSFORM_SPACE_WORLD);
        gizmoSnapEnabled = state.transformSnapEnabled;
        viewYawDegrees = NormalizeYawDegrees(
            ClampInt3D(state.viewYawDegrees, -36000, 36000));
        viewPitchDegrees = ClampInt3D(state.viewPitchDegrees, -80, 80);
        viewScale = ClampInt3D(state.viewScale, 4, 120);
        viewportMode = ClampInt3D(
            state.viewportMode,
            VIEWPORT_MODE_SHADED, VIEWPORT_MODE_WIREFRAME);
        viewTargetX = ClampNumber3D(
            state.viewTargetX, -1000000.0, 1000000.0);
        viewTargetY = ClampNumber3D(
            state.viewTargetY, -1000000.0, 1000000.0);
        viewTargetZ = ClampNumber3D(
            state.viewTargetZ, -1000000.0, 1000000.0);
        if bodySplit != null {
            bodySplit.SetPosition(ClampNumber3D(
                state.splitPosition, 0.20, 0.85));
        }
        pendingInspectorScrollY = ClampNumber3D(
            state.inspectorScrollY, 0.0, 1000000.0);
        inspectorRequestedVisible = state.inspectorRequestedVisible;
        compactInspectorShown = state.compactInspectorShown;
        restoreInspectorScrollPending = true;
        SyncGizmoModeControls();
        UpdateViewportModeControls();
    }

    /// @brief Toggle the inspector without making either compact pane unusable.
    expose func ToggleInspectorPane() {
        if compactLayout {
            compactInspectorShown = !compactInspectorShown;
        } else {
            inspectorRequestedVisible = !inspectorRequestedVisible;
        }
        ApplyInspectorLayout();
        CaptureWorkspaceState();
    }

    /// @brief Reconcile wrapping chrome and master/detail layout after resize.
    expose func RefreshResponsiveLayout() {
        if root == null or bodySplit == null { return; }
        var width = root.GetLogicalWidth();
        if guiApp != null {
            var scale = guiApp.GetEffectiveScale();
            if scale <= 0.0 { scale = 1.0; }
            var viewportWidth = guiApp.GetWidth() / scale;
            if viewportWidth > 0.0
               and (width <= 0.0 or viewportWidth < width) {
                width = viewportWidth;
            }
        }
        if width <= 0.0 { return; }
        var nextCompact = UsesCompactLayout(width);
        if nextCompact != compactLayout {
            compactLayout = nextCompact;
            ApplyResponsiveChrome();
            renderDirty = true;
        }
        ApplyInspectorLayout();
    }

    /// @brief Keep all scene creation and navigation actions reachable.
    hide func ApplyResponsiveChrome() {
        if compactLayout {
            // Flex measurement cannot infer wrapped cross-axis height before
            // its parent assigns a width. Reserve the three creation rows and
            // four denser view rows required at defensive compact widths.
            toolbar.SetPreferredSize(0.0, 96.0);
            viewToolbar.SetPreferredSize(0.0, 132.0);
            newSceneButton.SetText("New");
            importAssetButton.SetText("Import...");
            addEmptyButton.SetText("+ Node");
            moveToolButton.SetText("M");
            rotateToolButton.SetText("R");
            scaleToolButton.SetText("S");
            orbitLeftButton.SetText("←");
            orbitRightButton.SetText("→");
            orbitUpButton.SetText("↑");
            orbitDownButton.SetText("↓");
            frameButton.SetText("All");
            frameSelectedButton.SetText("Selected");
            toolbarStatus.SetVisible(false);
            viewStatusLabel.SetVisible(false);
        } else {
            toolbar.SetPreferredSize(0.0, 0.0);
            viewToolbar.SetPreferredSize(0.0, 0.0);
            newSceneButton.SetText("New");
            importAssetButton.SetText("Import Asset...");
            addEmptyButton.SetText("+ Empty");
            moveToolButton.SetText("Move");
            rotateToolButton.SetText("Rotate");
            scaleToolButton.SetText("Scale");
            orbitLeftButton.SetText("Yaw -");
            orbitRightButton.SetText("Yaw +");
            orbitUpButton.SetText("Pitch +");
            orbitDownButton.SetText("Pitch -");
            frameButton.SetText("Frame all");
            frameSelectedButton.SetText("Frame selected");
            toolbarStatus.SetVisible(true);
            viewStatusLabel.SetVisible(true);
        }
        UpdateGizmoModeControls();
        UpdateInspectorButton();
    }

    /// @brief Apply wide split or compact one-pane-at-a-time presentation.
    hide func ApplyInspectorLayout() {
        if bodySplit == null { return; }
        var desiredSide = 0;
        if compactLayout {
            desiredSide = 2;
            if compactInspectorShown { desiredSide = 1; }
        } else if !inspectorRequestedVisible {
            desiredSide = 2;
        }

        var currentSide = bodySplit.GetCollapsedSide();
        if desiredSide == 1 {
            bodySplit.CollapseFirst();
        } else if desiredSide == 2 {
            bodySplit.CollapseSecond();
        } else {
            bodySplit.Restore();
        }
        if currentSide != desiredSide {
            renderDirty = true;
        }
        UpdateInspectorButton();
    }

    /// @brief Describe the destination of the inspector toggle.
    hide func UpdateInspectorButton() {
        if inspectorButton == null { return; }
        if compactLayout {
            if compactInspectorShown {
                inspectorButton.SetText("Viewport");
                inspectorButton.SetTooltip("Return to the full-width 3D viewport");
                inspectorButton.SetStyle(1);
            } else {
                inspectorButton.SetText("Inspector");
                inspectorButton.SetTooltip("Show the node inspector at full width");
                inspectorButton.SetStyle(2);
            }
        } else if inspectorRequestedVisible {
            inspectorButton.SetText("Hide Inspector");
            inspectorButton.SetTooltip(
                "Hide the node inspector and give the viewport the full width");
            inspectorButton.SetStyle(2);
        } else {
            inspectorButton.SetText("Show Inspector");
            inspectorButton.SetTooltip("Restore the node inspector");
            inspectorButton.SetStyle(1);
        }
    }

    /// @brief Apply deferred inspector scroll after hierarchy layout is known.
    hide func ApplyPendingWorkspaceScroll() {
        if restoreInspectorScrollPending == false { return; }
        if inspectorScroll != null {
            SetLogicalScroll(
                inspectorScroll, 0.0, pendingInspectorScrollY);
        }
        restoreInspectorScrollPending = false;
    }

    /// @brief Select truthful shaded meshes or authored mesh wireframes.
    /// @details This is per-document presentation state. It never mutates the
    ///          live SceneGraph, canonical VSCN bytes, or edit history.
    expose func SetViewportMode(nextMode: Integer) {
        if (nextMode != VIEWPORT_MODE_SHADED
            and nextMode != VIEWPORT_MODE_WIREFRAME)
           or nextMode == viewportMode {
            return;
        }
        viewportMode = nextMode;
        UpdateViewportModeControls();
        toolbarStatus.SetText(
            ViewportModeLabel(viewportMode) + " viewport selected");
        renderDirty = true;
        CaptureWorkspaceState();
    }

    /// @brief Return the concise user-facing viewport mode label.
    hide func ViewportModeLabel(mode: Integer) -> String {
        if mode == VIEWPORT_MODE_WIREFRAME { return "Wireframe"; }
        return "Shaded";
    }

    /// @brief Keep the mode button, tooltip, and accessibility state truthful.
    hide func UpdateViewportModeControls() {
        if viewportModeButton == null { return; }
        var label = ViewportModeLabel(viewportMode);
        viewportModeButton.SetText(label);
        viewportModeButton.SetStyle(
            viewportMode == VIEWPORT_MODE_SHADED ? 1 : 0);
        viewportModeButton.SetAccessibleName(
            "3D viewport mode: " + label);
        if viewportMode == VIEWPORT_MODE_WIREFRAME {
            viewportModeButton.SetTooltip(
                "Show authored triangle edges; click for shaded PBR materials");
            viewportModeButton.SetAccessibleDescription(
                "Authored meshes render as triangle wireframes. "
                + "Activate for shaded PBR materials.");
        } else {
            viewportModeButton.SetTooltip(
                "Show authored PBR materials; click for triangle wireframes");
            viewportModeButton.SetAccessibleDescription(
                "Authored meshes render with their PBR materials. "
                + "Activate for triangle wireframes.");
        }
    }

    /// @brief Select one viewport transform tool without mutating scene data.
    expose func SetGizmoMode(nextMode: Integer) {
        if scene_transform_3d.IsValidMode(nextMode) == false
           or nextMode == gizmoMode {
            return;
        }
        if gizmoDragAxis != GIZMO_AXIS_NONE { CancelGizmoDrag(); }
        gizmoMode = nextMode;
        gizmoHoverAxis = GIZMO_AXIS_NONE;
        UpdateGizmoModeControls();
        toolbarStatus.SetText(
            scene_transform_3d.ModeLabel(gizmoMode) + " tool selected");
        renderDirty = true;
        CaptureWorkspaceState();
    }

    /// @brief Select parent-relative local axes or absolute world axes.
    expose func SetGizmoTransformSpace(nextSpace: Integer) {
        if scene_transform_3d.IsValidSpace(nextSpace) == false
           or nextSpace == gizmoTransformSpace {
            return;
        }
        if gizmoDragAxis != GIZMO_AXIS_NONE { CancelGizmoDrag(); }
        gizmoTransformSpace = nextSpace;
        gizmoHoverAxis = GIZMO_AXIS_NONE;
        UpdateGizmoModeControls();
        toolbarStatus.SetText(
            scene_transform_3d.SpaceLabel(gizmoTransformSpace)
            + " transform axes selected");
        renderDirty = true;
        CaptureWorkspaceState();
    }

    /// @brief Toggle mode-aware snapping and keep the native checkbox in sync.
    expose func SetGizmoSnapEnabled(enabled: Boolean) {
        if enabled == gizmoSnapEnabled
           and snapTransformCheck != null
           and snapTransformCheck.IsChecked() == enabled {
            return;
        }
        gizmoSnapEnabled = enabled;
        SyncGizmoModeControls();
        renderDirty = true;
        CaptureWorkspaceState();
    }

    /// @brief Reconcile persisted gizmo fields with their native widgets.
    hide func SyncGizmoModeControls() {
        if snapTransformCheck == null { return; }
        snapTransformCheck.SetChecked(gizmoSnapEnabled);
        snapTransformRevision = snapTransformCheck.GetRevision();
        UpdateGizmoModeControls();
    }

    /// @brief Present an unambiguous active transform mode and snap precision.
    hide func UpdateGizmoModeControls() {
        if moveToolButton == null { return; }
        moveToolButton.SetStyle(0);
        rotateToolButton.SetStyle(0);
        scaleToolButton.SetStyle(0);
        if gizmoMode == GIZMO_MODE_ROTATE {
            rotateToolButton.SetStyle(1);
        } else if gizmoMode == GIZMO_MODE_SCALE {
            scaleToolButton.SetStyle(1);
        } else {
            moveToolButton.SetStyle(1);
        }
        if transformSpaceButton != null {
            var spaceLabel =
                scene_transform_3d.SpaceLabel(gizmoTransformSpace);
            transformSpaceButton.SetText(spaceLabel);
            transformSpaceButton.SetStyle(
                gizmoTransformSpace
                    == scene_transform_3d.TRANSFORM_SPACE_WORLD
                ? 1 : 0);
            transformSpaceButton.SetTooltip(
                spaceLabel
                + " axes. Click to switch coordinate space. "
                + "Impossible parent-relative TRS conversions are rejected.");
        }
        var snapState = "off";
        if gizmoSnapEnabled {
            snapState = scene_transform_3d.SnapDescription(gizmoMode);
        }
        snapTransformCheck.SetTooltip(
            scene_transform_3d.ModeLabel(gizmoMode)
            + " snap: " + snapState);
        if viewportImage != null {
            var handleHint = "colored axes";
            if gizmoMode == GIZMO_MODE_MOVE {
                handleHint = "colored axes or XY/XZ/YZ plane squares";
            } else if gizmoMode == GIZMO_MODE_ROTATE {
                handleHint = "X/Y/Z rotation rings";
            } else if gizmoMode == GIZMO_MODE_SCALE {
                handleHint = "boxed axes or XY/XZ/YZ crossed scale squares";
            }
            viewportImage.SetTooltip(
                "Drag " + handleHint + " to "
                + Str.ToLower(scene_transform_3d.ModeLabel(gizmoMode))
                + " in "
                + Str.ToLower(
                    scene_transform_3d.SpaceLabel(gizmoTransformSpace))
                + " space. Click meshes to select; Shift adds and Ctrl/Cmd "
                + "toggles. Middle/right-drag to orbit, or add Shift to pan. "
                + "Use the wheel to zoom.");
        }
    }

    /// @brief Return the monotonic accepted-edit revision.
    expose func GetRevision() -> Integer {
        return revision;
    }

    /// @brief Add a named empty node through the normal committed edit path.
    /// @return New flattened node index, or -1 on failure.
    expose func AddEmptyNode(name: String,
                             parentIndex: Integer) -> Integer {
        if scene == null { return -1; }
        var parent: SceneNode = null;
        if parentIndex >= 0 and parentIndex < flatNodes.count() {
            parent = flatNodes.get(parentIndex);
        }
        var node = SceneNode.New();
        var nodeName = Str.Trim(name);
        if nodeName == "" { nodeName = "Node " + scene.NodeCount; }
        node.Name = nodeName;
        if parent != null {
            parent.AddChild(node);
        } else {
            scene.Add(node);
        }
        if CommitScene("Added " + nodeName) == false { return -1; }
        RefreshHierarchy(node);
        return selectedIndex;
    }

    /// @brief Create one named point-light node through canonical VSCN history.
    /// @details The light is staged before hierarchy mutation. A valid parent
    ///          index creates a light child; -1 creates a top-level node.
    expose func AddLightNode(name: String,
                             parentIndex: Integer) -> Integer {
        if scene == null { return -1; }
        var state = new scene_light_3d.LightState3D();
        var light = scene_light_3d.BuildLight(state);
        if light == null {
            toolbarStatus.SetText("Light creation failed");
            detailLabel.SetText(
                "Studio could not allocate the Point light component.");
            GUI.Toast.Error("3D light creation failed");
            return -1;
        }
        var parent: SceneNode = null;
        if parentIndex >= 0 and parentIndex < flatNodes.count() {
            parent = flatNodes.get(parentIndex);
        }
        var node = SceneNode.New();
        if node == null {
            toolbarStatus.SetText("Light creation failed");
            detailLabel.SetText("Studio could not allocate a scene node.");
            GUI.Toast.Error("3D light creation failed");
            return -1;
        }
        var nodeName = Str.Trim(name);
        if nodeName == "" { nodeName = "Point Light " + scene.NodeCount; }
        node.Name = nodeName;
        node.Light = light;
        if parent != null {
            parent.AddChild(node);
        } else {
            scene.Add(node);
        }
        if CommitScene("Added " + nodeName) == false { return -1; }
        RefreshHierarchy(node);
        detailLabel.SetText(
            "Created a Point light. Use the Light component inspector "
            + "to change its type and local emission fields.");
        return selectedIndex;
    }

    /// @brief Create, rename, or update one typed node metadata value.
    expose func SetNodeMetadata(nodeIndex: Integer,
                                previousKey: String,
                                key: String,
                                kind: String,
                                value: String) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        var nextKey = Str.Trim(key);
        if nextKey == "" {
            detailLabel.SetText("Node metadata key cannot be empty.");
            return false;
        }
        if previousKey != "" and node.MetadataHas(previousKey) == false {
            detailLabel.SetText(
                "The selected node metadata value no longer exists.");
            return false;
        }
        if previousKey != nextKey and node.MetadataHas(nextKey) {
            detailLabel.SetText(
                "Node metadata \"" + nextKey + "\" already exists.");
            return false;
        }

        var intValue = 0;
        var floatValue = 0.0;
        var boolValue = false;
        if kind == "int" {
            var parsedInt = Parse.TryInt(Str.Trim(value));
            if parsedInt.IsNone {
                detailLabel.SetText("Enter a valid whole number.");
                return false;
            }
            intValue = parsedInt.UnwrapI64();
        } else if kind == "float" {
            var parsedFloat = Parse.TryDouble(Str.Trim(value));
            if parsedFloat.IsNone {
                detailLabel.SetText("Enter a valid finite number.");
                return false;
            }
            floatValue = parsedFloat.UnwrapF64();
        } else if kind == "bool" {
            var parsedBool = Parse.TryBool(Str.Trim(value));
            if parsedBool.IsNone {
                detailLabel.SetText(
                    "Enter true/false, yes/no, on/off, or 1/0.");
                return false;
            }
            boolValue = parsedBool.UnwrapI1();
        } else if kind != "string" and kind != "null" {
            detailLabel.SetText("Choose a supported node metadata type.");
            return false;
        }

        if previousKey == nextKey
           and NodeMetadataMatches(
               node, nextKey, kind, value,
               intValue, floatValue, boolValue) {
            detailLabel.SetText("Node metadata is already up to date.");
            return false;
        }

        var applied = false;
        if kind == "string" {
            applied = node.MetadataSetString(nextKey, value);
        } else if kind == "int" {
            applied = node.MetadataSetInt(nextKey, intValue);
        } else if kind == "float" {
            applied = node.MetadataSetFloat(nextKey, floatValue);
        } else if kind == "bool" {
            applied = node.MetadataSetBool(nextKey, boolValue);
        } else {
            applied = node.MetadataSetNull(nextKey);
        }
        if applied == false
           or NodeMetadataMatches(
               node, nextKey, kind, value,
               intValue, floatValue, boolValue) == false {
            RestoreNodeMetadataEdit(
                nodeIndex,
                "The metadata value was rejected. Keys are limited to "
                + "128 bytes, nodes to 256 values, and strings to 64 KiB.");
            return false;
        }
        if previousKey != "" and previousKey != nextKey
           and node.MetadataRemove(previousKey) == false {
            RestoreNodeMetadataEdit(
                nodeIndex,
                "Studio could not complete the metadata rename.");
            return false;
        }
        if CommitScene("Updated node metadata " + nextKey) == false {
            RestoreNodeMetadataEdit(
                nodeIndex,
                "The node metadata update could not be committed.");
            return false;
        }

        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        metadataOwnerIndex = nodeIndex;
        detailLabel.SetText("");
        RefreshMetadataFields(node);
        metadataInspector.SelectByKey(node, nextKey);
        selectedNodeMetadata = metadataInspector.selectedProperty;
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Remove one typed node metadata value through canonical history.
    expose func RemoveNodeMetadata(nodeIndex: Integer,
                                   key: String) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        var nextKey = Str.Trim(key);
        if nextKey == "" or node.MetadataHas(nextKey) == false {
            return false;
        }
        if node.MetadataRemove(nextKey) == false {
            detailLabel.SetText("The node rejected the metadata removal.");
            return false;
        }
        if CommitScene("Removed node metadata " + nextKey) == false {
            RestoreNodeMetadataEdit(
                nodeIndex,
                "The node metadata removal could not be committed.");
            return false;
        }
        selectedNodeMetadata = -1;
        metadataOwnerIndex = nodeIndex;
        detailLabel.SetText("");
        RefreshMetadataFields(node);
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Add every missing field from one project component transactionally.
    /// @details Existing same-kind values are preserved. Any type conflict,
    ///          rejected runtime write, or failed VSCN commit restores the
    ///          complete canonical document.
    expose func ApplySelectedComponent(
        component: scene_component_schema.SceneComponentDefinition)
        -> Boolean {
        if scene == null or component == null
           or component.SupportsTarget(
               scene_component_schema.TARGET_3D_NODE) == false {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 {
            detailLabel.SetText(
                "Select one or more nodes before adding a component.");
            return false;
        }

        var missing = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node = flatNodes.get(selectedIndices.get(selectionIndex));
            var fieldIndex = 0;
            while fieldIndex < component.fields.count() {
                var field = component.fields.get(fieldIndex);
                if node.MetadataHas(field.key) {
                    if node.MetadataKind(field.key) != field.kind {
                        detailLabel.SetText(
                            "Component \"" + component.label
                            + "\" conflicts with metadata \"" + field.key
                            + "\". No nodes were changed.");
                        RefreshComponentPalette();
                        return false;
                    }
                } else {
                    missing = missing + 1;
                }
                fieldIndex = fieldIndex + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if missing == 0 {
            detailLabel.SetText(
                "Component \"" + component.label
                + "\" is already complete on the selection.");
            RefreshComponentPalette();
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node = flatNodes.get(selectedIndices.get(selectionIndex));
            var fieldIndex = 0;
            while fieldIndex < component.fields.count() {
                var field = component.fields.get(fieldIndex);
                if node.MetadataHas(field.key) == false
                   and WriteNodeComponentField(node, field) == false {
                    RestoreNodeComponentEdit(
                        previousSelection,
                        previousPrimary,
                        "Component \"" + component.label
                        + "\" was rejected. No nodes were changed.");
                    return false;
                }
                fieldIndex = fieldIndex + 1;
            }
            selectionIndex = selectionIndex + 1;
        }

        if CommitScene(
               "Added " + component.label + " to "
               + selectedIndices.count() + " node(s)") == false {
            RestoreNodeComponentEdit(
                previousSelection,
                previousPrimary,
                "The component could not be committed. No nodes were changed.");
            return false;
        }
        selectedNodeMetadata = -1;
        metadataOwnerIndex = selectedIndex;
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        detailLabel.SetText(
            "Added " + missing + " missing field(s) from "
            + component.label + ".");
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Copy one schema field into the single-node raw metadata editor.
    expose func EditSelectedComponentField() -> Boolean {
        if scene == null or componentPalette == null { return false; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var field = componentPalette.SelectedField();
        if field == null or selectedIndices.count() != 1 {
            return false;
        }
        var node = SelectedNode();
        if node == null
           or metadataInspector.SetDraft(
               node, field.key, field.kind, field.defaultText) == false {
            return false;
        }
        selectedNodeMetadata = metadataInspector.selectedProperty;
        detailLabel.SetText(
            "Editing " + field.label
            + " in the raw typed-metadata controls.");
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Write and verify one already-validated schema default.
    hide func WriteNodeComponentField(
        node: SceneNode,
        field: scene_component_schema.SceneComponentField) -> Boolean {
        var intValue = 0;
        var floatValue = 0.0;
        var boolValue = false;
        var applied = false;
        if field.kind == "string" {
            applied =
                node.MetadataSetString(field.key, field.defaultText);
        } else if field.kind == "int" {
            var parsedInt = Parse.TryInt(field.defaultText);
            if parsedInt.IsNone { return false; }
            intValue = parsedInt.UnwrapI64();
            applied = node.MetadataSetInt(field.key, intValue);
        } else if field.kind == "float" {
            var parsedFloat = Parse.TryDouble(field.defaultText);
            if parsedFloat.IsNone { return false; }
            floatValue = parsedFloat.UnwrapF64();
            applied = node.MetadataSetFloat(field.key, floatValue);
        } else if field.kind == "bool" {
            var parsedBool = Parse.TryBool(field.defaultText);
            if parsedBool.IsNone { return false; }
            boolValue = parsedBool.UnwrapI1();
            applied = node.MetadataSetBool(field.key, boolValue);
        } else if field.kind == "null" {
            applied = node.MetadataSetNull(field.key);
        } else {
            return false;
        }
        return applied and NodeMetadataMatches(
            node,
            field.key,
            field.kind,
            field.defaultText,
            intValue,
            floatValue,
            boolValue);
    }

    /// @brief Reload the canonical document after a partial component write.
    hide func RestoreNodeComponentEdit(
        previousSelection: List[Integer],
        previousPrimary: Integer,
        message: String) {
        var doc = currentDoc;
        if doc != null { LoadDocumentModel(doc, true); }
        SelectSceneNodes(previousSelection, previousPrimary);
        detailLabel.SetText(message + " The document was restored.");
        toolbarStatus.SetText("Component edit rolled back");
        RefreshComponentPalette();
    }

    /// @brief Verify one just-written value without scalar string coercion.
    hide func NodeMetadataMatches(node: SceneNode,
                                  key: String,
                                  kind: String,
                                  stringValue: String,
                                  intValue: Integer,
                                  floatValue: Number,
                                  boolValue: Boolean) -> Boolean {
        if node == null or node.MetadataHas(key) == false
           or node.MetadataKind(key) != kind {
            return false;
        }
        if kind == "string" {
            return node.MetadataGetString(key, "") == stringValue;
        }
        if kind == "int" {
            return node.MetadataGetInt(key, 0) == intValue;
        }
        if kind == "float" {
            var delta = node.MetadataGetFloat(key, 0.0) - floatValue;
            if delta < 0.0 { delta = 0.0 - delta; }
            return delta < 0.000000000001;
        }
        if kind == "bool" {
            return node.MetadataGetBool(key, false) == boolValue;
        }
        return kind == "null";
    }

    /// @brief Reload canonical VSCN after any partial metadata transaction.
    hide func RestoreNodeMetadataEdit(nodeIndex: Integer,
                                      message: String) {
        var doc = currentDoc;
        if doc != null { LoadDocumentModel(doc, true); }
        if nodeIndex >= 0 and nodeIndex < flatNodes.count() {
            SelectIndex(nodeIndex);
        }
        detailLabel.SetText(message + " The document was restored.");
        toolbarStatus.SetText("Metadata edit rolled back");
    }

    /// @brief Update one node's local transform and commit it.
    expose func SetNodeTransform(nodeIndex: Integer,
                                 px: Number,
                                 py: Number,
                                 pz: Number,
                                 sx: Number,
                                 sy: Number,
                                 sz: Number) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        node.SetPosition(px, py, pz);
        node.SetScale(sx, sy, sz);
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        if CommitScene("Updated node transform") == false { return false; }
        positionX.SetValue(px);
        positionY.SetValue(py);
        positionZ.SetValue(pz);
        scaleX.SetValue(sx);
        scaleY.SetValue(sy);
        scaleZ.SetValue(sz);
        return true;
    }

    /// @brief Update one node's local Euler rotation in editor-friendly degrees.
    expose func SetNodeEulerRotation(nodeIndex: Integer,
                                     xDegrees: Number,
                                     yDegrees: Number,
                                     zDegrees: Number) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        node.Rotation = Quat.FromEuler(xDegrees * DEG_TO_RAD,
                                       yDegrees * DEG_TO_RAD,
                                       zDegrees * DEG_TO_RAD).Normalize();
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        if CommitScene("Updated node rotation") == false { return false; }
        rotationX.SetValue(xDegrees);
        rotationY.SetValue(yDegrees);
        rotationZ.SetValue(zDegrees);
        return true;
    }

    /// @brief Translate one node along a displayed local gizmo axis and commit.
    /// @details This is the deterministic command path behind direct viewport
    ///          manipulation. The projected handle reflects parent rotation and
    ///          scale while the edit remains an inspector-compatible local value.
    expose func TranslateNodeAlongGizmoAxis(nodeIndex: Integer,
                                            axis: Integer,
                                            amount: Number) -> Boolean {
        return TransformNodeAlongGizmoAxis(
            nodeIndex, GIZMO_MODE_MOVE, axis, amount, false);
    }

    /// @brief Apply one deterministic Move, Rotate, or Scale axis edit.
    /// @details This is the probeable command boundary behind live gizmo drags.
    ///          The amount is expressed in units, degrees, or scale depending
    ///          on mode; optional snapping quantizes the resulting value.
    expose func TransformNodeAlongGizmoAxis(nodeIndex: Integer,
                                            transformMode: Integer,
                                            axis: Integer,
                                            amount: Number,
                                            snapEnabled: Boolean) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count()
           or scene_transform_3d.IsValidMode(transformMode) == false
           or (axis != GIZMO_AXIS_X and axis != GIZMO_AXIS_Y
               and axis != GIZMO_AXIS_Z)
           or (amount > -0.0000001 and amount < 0.0000001) {
            return false;
        }
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            selectedIndex = nodeIndex;
            selectedIndices = scene_selection.Single(
                nodeIndex, flatNodes.count());
            return TransformSelectedAlongWorldGizmoAxis(
                transformMode, axis, amount, snapEnabled);
        }
        var node = flatNodes.get(nodeIndex);
        var sourceX = 0.0;
        var sourceY = 0.0;
        var sourceZ = 0.0;
        if transformMode == GIZMO_MODE_ROTATE {
            var rotation = node.Rotation;
            var euler = QuaternionToEulerDegrees(rotation);
            sourceX = euler.X;
            sourceY = euler.Y;
            sourceZ = euler.Z;
        } else if transformMode == GIZMO_MODE_SCALE {
            var scale = node.Scale;
            sourceX = scale.X;
            sourceY = scale.Y;
            sourceZ = scale.Z;
        } else {
            var position = node.Position;
            sourceX = position.X;
            sourceY = position.Y;
            sourceZ = position.Z;
        }
        var sourceValue = sourceZ;
        if axis == GIZMO_AXIS_X { sourceValue = sourceX; }
        else if axis == GIZMO_AXIS_Y { sourceValue = sourceY; }
        var targetValue = scene_transform_3d.AxisTarget(
            transformMode, sourceValue, amount, snapEnabled);
        if scene_transform_3d.NearlyEqual(sourceValue, targetValue) {
            return false;
        }
        var targetX = sourceX;
        var targetY = sourceY;
        var targetZ = sourceZ;
        if axis == GIZMO_AXIS_X { targetX = targetValue; }
        else if axis == GIZMO_AXIS_Y { targetY = targetValue; }
        else { targetZ = targetValue; }
        if transformMode == GIZMO_MODE_ROTATE {
            return SetNodeEulerRotation(
                nodeIndex, targetX, targetY, targetZ);
        }
        if transformMode == GIZMO_MODE_SCALE {
            var localPosition = node.Position;
            return SetNodeTransform(
                nodeIndex,
                localPosition.X, localPosition.Y, localPosition.Z,
                targetX, targetY, targetZ);
        }
        var localScale = node.Scale;
        return SetNodeTransform(
            nodeIndex, targetX, targetY, targetZ,
            localScale.X, localScale.Y, localScale.Z);
    }

    /// @brief Apply one axis amount to every selected local transform.
    /// @details The complete group is serialized once so undo restores every
    ///          member together. Rotate and scale use each node's local origin.
    expose func TransformSelectedAlongGizmoAxis(
        transformMode: Integer,
        axis: Integer,
        amount: Number,
        snapEnabled: Boolean) -> Boolean {
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            return TransformSelectedAlongWorldGizmoAxis(
                transformMode, axis, amount, snapEnabled);
        }
        if scene == null
           or scene_transform_3d.IsValidMode(transformMode) == false
           or (axis != GIZMO_AXIS_X and axis != GIZMO_AXIS_Y
               and axis != GIZMO_AXIS_Z)
           or (amount > -0.0000001 and amount < 0.0000001) {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }
        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var changed = false;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var nodeIndex = selectedIndices.get(selectionIndex);
            var node = flatNodes.get(nodeIndex);
            var sourceX = 0.0;
            var sourceY = 0.0;
            var sourceZ = 0.0;
            if transformMode == GIZMO_MODE_ROTATE {
                var euler = QuaternionToEulerDegrees(node.Rotation);
                sourceX = euler.X;
                sourceY = euler.Y;
                sourceZ = euler.Z;
            } else if transformMode == GIZMO_MODE_SCALE {
                var scale = node.Scale;
                sourceX = scale.X;
                sourceY = scale.Y;
                sourceZ = scale.Z;
            } else {
                var position = node.Position;
                sourceX = position.X;
                sourceY = position.Y;
                sourceZ = position.Z;
            }
            var sourceValue = sourceZ;
            if axis == GIZMO_AXIS_X { sourceValue = sourceX; }
            else if axis == GIZMO_AXIS_Y { sourceValue = sourceY; }
            var targetValue = scene_transform_3d.AxisTarget(
                transformMode, sourceValue, amount, snapEnabled);
            if scene_transform_3d.NearlyEqual(
                   sourceValue, targetValue) == false {
                if axis == GIZMO_AXIS_X { sourceX = targetValue; }
                else if axis == GIZMO_AXIS_Y { sourceY = targetValue; }
                else { sourceZ = targetValue; }
                ApplyNodeTransformValues(
                    node, transformMode, sourceX, sourceY, sourceZ);
                changed = true;
            }
            selectionIndex = selectionIndex + 1;
        }
        if changed == false { return false; }
        if CommitScene(
               scene_transform_3d.ModeHistoryVerb(transformMode)
               + " " + selectedIndices.count() + " selected node(s)") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected transforms could not be committed.");
            return false;
        }
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        renderDirty = true;
        return true;
    }

    /// @brief Translate every selected node along two axes of one gizmo plane.
    /// @details Compatibility wrapper for deterministic Move-plane probes.
    expose func TranslateSelectedInGizmoPlane(
        plane: Integer,
        amountA: Number,
        amountB: Number,
        snapEnabled: Boolean) -> Boolean {
        return TransformSelectedInGizmoPlane(
            GIZMO_MODE_MOVE, plane, amountA, amountB, snapEnabled);
    }

    /// @brief Scale every selected node along two axes of one gizmo plane.
    /// @details The primary selection defines snapping and therefore the shared
    ///          additive group delta. World edits use exact matrix assignment
    ///          in hierarchy order and reject the complete group on shear.
    expose func ScaleSelectedInGizmoPlane(
        plane: Integer,
        amountA: Number,
        amountB: Number,
        snapEnabled: Boolean) -> Boolean {
        return TransformSelectedInGizmoPlane(
            GIZMO_MODE_SCALE, plane, amountA, amountB, snapEnabled);
    }

    /// @brief Apply one two-axis Move or Scale command to the selected group.
    /// @details Local edits use parent-relative fields. World edits use exact
    ///          runtime matrix assignment in hierarchy order. Either path
    ///          commits one canonical history snapshot or restores every node.
    hide func TransformSelectedInGizmoPlane(
        transformMode: Integer,
        plane: Integer,
        amountA: Number,
        amountB: Number,
        snapEnabled: Boolean) -> Boolean {
        if scene == null
           or (transformMode != GIZMO_MODE_MOVE
               and transformMode != GIZMO_MODE_SCALE)
           or IsGizmoPlane(plane) == false
           or (scene_transform_3d.NearlyEqual(amountA, 0.0)
               and scene_transform_3d.NearlyEqual(amountB, 0.0)) {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            return TransformSelectedInWorldGizmoPlane(
                transformMode, plane, amountA, amountB, snapEnabled);
        }

        var primary = SelectedNode();
        if primary == null { return false; }
        var axisA = GizmoPlaneAxisA(plane);
        var axisB = GizmoPlaneAxisB(plane);
        var primaryValues = primary.Position;
        if transformMode == GIZMO_MODE_SCALE {
            primaryValues = primary.Scale;
        }
        var sourceA = GizmoAxisValue(primaryValues, axisA);
        var sourceB = GizmoAxisValue(primaryValues, axisB);
        var targetA = scene_transform_3d.AxisTarget(
            transformMode, sourceA, amountA, snapEnabled);
        var targetB = scene_transform_3d.AxisTarget(
            transformMode, sourceB, amountB, snapEnabled);
        var deltaA = targetA - sourceA;
        var deltaB = targetB - sourceB;
        if scene_transform_3d.NearlyEqual(deltaA, 0.0)
           and scene_transform_3d.NearlyEqual(deltaB, 0.0) {
            return false;
        }

        var deltaX = 0.0;
        var deltaY = 0.0;
        var deltaZ = 0.0;
        if axisA == GIZMO_AXIS_X { deltaX = deltaA; }
        else if axisA == GIZMO_AXIS_Y { deltaY = deltaA; }
        else { deltaZ = deltaA; }
        if axisB == GIZMO_AXIS_X { deltaX = deltaB; }
        else if axisB == GIZMO_AXIS_Y { deltaY = deltaB; }
        else { deltaZ = deltaB; }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node = flatNodes.get(
                selectedIndices.get(selectionIndex));
            var values = node.Position;
            if transformMode == GIZMO_MODE_SCALE {
                values = node.Scale;
            }
            var valueX = values.X + deltaX;
            var valueY = values.Y + deltaY;
            var valueZ = values.Z + deltaZ;
            if transformMode == GIZMO_MODE_SCALE {
                if axisA == GIZMO_AXIS_X
                   or axisB == GIZMO_AXIS_X {
                    valueX = scene_transform_3d.UsableScale(
                        valueX, values.X);
                }
                if axisA == GIZMO_AXIS_Y
                   or axisB == GIZMO_AXIS_Y {
                    valueY = scene_transform_3d.UsableScale(
                        valueY, values.Y);
                }
                if axisA == GIZMO_AXIS_Z
                   or axisB == GIZMO_AXIS_Z {
                    valueZ = scene_transform_3d.UsableScale(
                        valueZ, values.Z);
                }
            }
            ApplyNodeTransformValues(
                node, transformMode, valueX, valueY, valueZ);
            selectionIndex = selectionIndex + 1;
        }
        if CommitScene(
               scene_transform_3d.ModeHistoryVerb(transformMode)
               + " " + selectedIndices.count()
               + " selected node(s) in "
               + GizmoAxisLabel(plane) + " plane") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected plane transform could not be committed.");
            return false;
        }
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        renderDirty = true;
        return true;
    }

    /// @brief Apply one exact absolute-world plane transform to a group.
    hide func TransformSelectedInWorldGizmoPlane(
        transformMode: Integer,
        plane: Integer,
        amountA: Number,
        amountB: Number,
        snapEnabled: Boolean) -> Boolean {
        var worldIndices = HierarchyOrderedSelection(selectedIndices);
        var primary = SelectedNode();
        if worldIndices.count() == 0 or primary == null { return false; }

        var axisA = GizmoPlaneAxisA(plane);
        var axisB = GizmoPlaneAxisB(plane);
        var primaryValues = primary.WorldPosition;
        if transformMode == GIZMO_MODE_SCALE {
            primaryValues = primary.WorldScale;
        }
        var sourceA = GizmoAxisValue(primaryValues, axisA);
        var sourceB = GizmoAxisValue(primaryValues, axisB);
        var targetA = scene_transform_3d.AxisTarget(
            transformMode, sourceA, amountA, snapEnabled);
        var targetB = scene_transform_3d.AxisTarget(
            transformMode, sourceB, amountB, snapEnabled);
        var deltaA = targetA - sourceA;
        var deltaB = targetB - sourceB;
        if scene_transform_3d.NearlyEqual(deltaA, 0.0)
           and scene_transform_3d.NearlyEqual(deltaB, 0.0) {
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var startPositions: List[Vec3] = [];
        var startRotations: List[Quat] = [];
        var startScales: List[Vec3] = [];
        var startWorldMatrices: List[Mat4] = [];
        var startWorldPositions: List[Vec3] = [];
        var startWorldScales: List[Vec3] = [];
        var selectionIndex = 0;
        while selectionIndex < worldIndices.count() {
            var node = flatNodes.get(worldIndices.get(selectionIndex));
            startPositions.add(node.Position);
            startRotations.add(node.Rotation);
            startScales.add(node.Scale);
            startWorldMatrices.add(node.WorldMatrix);
            startWorldPositions.add(node.WorldPosition);
            startWorldScales.add(node.WorldScale);
            selectionIndex = selectionIndex + 1;
        }

        var accepted = true;
        selectionIndex = 0;
        while selectionIndex < worldIndices.count() and accepted {
            var desired = WorldPlaneTargetMatrix(
                startWorldMatrices.get(selectionIndex),
                startWorldPositions.get(selectionIndex),
                startWorldScales.get(selectionIndex),
                transformMode,
                axisA,
                axisB,
                deltaA,
                deltaB);
            if desired == null
               or flatNodes.get(worldIndices.get(selectionIndex))
                      .TrySetWorldMatrix(desired) == false {
                accepted = false;
            }
            selectionIndex = selectionIndex + 1;
        }
        if accepted == false {
            RestoreLocalTransforms(
                worldIndices,
                startPositions,
                startRotations,
                startScales);
            detailLabel.SetText(
                "The world-space plane transform would require a singular, "
                + "degenerate, or sheared local transform. No nodes changed.");
            toolbarStatus.SetText("World plane transform rejected");
            RefreshSelectedFields();
            renderDirty = true;
            return false;
        }
        if CommitScene(
               scene_transform_3d.ModeHistoryVerb(transformMode)
               + " " + selectedIndices.count()
               + " selected node(s) in world "
               + GizmoAxisLabel(plane) + " plane") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The world-space plane transform could not be committed.");
            return false;
        }
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        renderDirty = true;
        return true;
    }

    /// @brief Apply one absolute-world axis amount to every selected node.
    /// @details Each member uses its own pivot and captured world matrix. The
    ///          runtime proves the resulting parent-relative TRS exactly; one
    ///          rejection restores every captured local transform before return.
    hide func TransformSelectedAlongWorldGizmoAxis(
        transformMode: Integer,
        axis: Integer,
        amount: Number,
        snapEnabled: Boolean) -> Boolean {
        if scene == null
           or scene_transform_3d.IsValidMode(transformMode) == false
           or (axis != GIZMO_AXIS_X and axis != GIZMO_AXIS_Y
               and axis != GIZMO_AXIS_Z)
           or (amount > -0.0000001 and amount < 0.0000001) {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var worldIndices = HierarchyOrderedSelection(selectedIndices);
        if worldIndices.count() == 0 { return false; }

        var primary = SelectedNode();
        if primary == null { return false; }
        var primaryPosition = primary.WorldPosition;
        var primaryScale = primary.WorldScale;
        var sourceValue = WorldAxisSourceValue(
            transformMode, axis, primaryPosition, primaryScale);
        var targetValue = scene_transform_3d.AxisTarget(
            transformMode, sourceValue, amount, snapEnabled);
        var delta = targetValue - sourceValue;
        if scene_transform_3d.NearlyEqual(delta, 0.0) {
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var startPositions: List[Vec3] = [];
        var startRotations: List[Quat] = [];
        var startScales: List[Vec3] = [];
        var startWorldMatrices: List[Mat4] = [];
        var startWorldPositions: List[Vec3] = [];
        var startWorldScales: List[Vec3] = [];
        var selectionIndex = 0;
        while selectionIndex < worldIndices.count() {
            var node = flatNodes.get(
                worldIndices.get(selectionIndex));
            startPositions.add(node.Position);
            startRotations.add(node.Rotation);
            startScales.add(node.Scale);
            startWorldMatrices.add(node.WorldMatrix);
            startWorldPositions.add(node.WorldPosition);
            startWorldScales.add(node.WorldScale);
            selectionIndex = selectionIndex + 1;
        }

        var accepted = true;
        selectionIndex = 0;
        while selectionIndex < worldIndices.count() and accepted {
            var desired = WorldAxisTargetMatrix(
                startWorldMatrices.get(selectionIndex),
                startWorldPositions.get(selectionIndex),
                startWorldScales.get(selectionIndex),
                transformMode,
                axis,
                delta);
            if desired == null
               or flatNodes.get(
                      worldIndices.get(selectionIndex))
                      .TrySetWorldMatrix(desired) == false {
                accepted = false;
            }
            selectionIndex = selectionIndex + 1;
        }
        if accepted == false {
            RestoreLocalTransforms(
                worldIndices,
                startPositions,
                startRotations,
                startScales);
            detailLabel.SetText(
                "The world-space transform would require a singular, "
                + "degenerate, or sheared local transform. No nodes changed.");
            toolbarStatus.SetText("World transform rejected");
            RefreshSelectedFields();
            renderDirty = true;
            return false;
        }

        if CommitScene(
               scene_transform_3d.ModeHistoryVerb(transformMode)
               + " " + selectedIndices.count()
               + " selected node(s) in world space") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The world-space transform could not be committed.");
            return false;
        }
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        renderDirty = true;
        return true;
    }

    /// @brief Return selected flattened indices in parent-before-child order.
    /// @details The visible hierarchy is a bounded preorder flattening. Rebuild
    ///          from that model order instead of trusting caller/restore order,
    ///          so a selected ancestor's world delta cannot affect a descendant
    ///          after the descendant has already reached its requested matrix.
    hide func HierarchyOrderedSelection(
        indices: List[Integer]) -> List[Integer] {
        var ordered: List[Integer] = [];
        var flatIndex = 0;
        while flatIndex < flatNodes.count() {
            if scene_selection.Contains(indices, flatIndex) {
                ordered.add(flatIndex);
            }
            flatIndex = flatIndex + 1;
        }
        return ordered;
    }

    /// @brief Resolve the snapped axis source used by one world-space action.
    hide func WorldAxisSourceValue(transformMode: Integer,
                                   axis: Integer,
                                   worldPosition: Vec3,
                                   worldScale: Vec3) -> Number {
        if transformMode == GIZMO_MODE_ROTATE { return 0.0; }
        var source = 0.0;
        if transformMode == GIZMO_MODE_SCALE {
            if worldScale == null { return 1.0; }
            source = worldScale.Z;
            if axis == GIZMO_AXIS_X { source = worldScale.X; }
            else if axis == GIZMO_AXIS_Y { source = worldScale.Y; }
            return source;
        }
        if worldPosition == null { return 0.0; }
        source = worldPosition.Z;
        if axis == GIZMO_AXIS_X { source = worldPosition.X; }
        else if axis == GIZMO_AXIS_Y { source = worldPosition.Y; }
        return source;
    }

    /// @brief Build one world-axis delta around the node's captured pivot.
    hide func WorldAxisTargetMatrix(startWorld: Mat4,
                                    pivot: Vec3,
                                    worldScale: Vec3,
                                    transformMode: Integer,
                                    axis: Integer,
                                    delta: Number) -> Mat4 {
        if startWorld == null or pivot == null { return null; }
        if transformMode == GIZMO_MODE_MOVE {
            var dx = 0.0;
            var dy = 0.0;
            var dz = 0.0;
            if axis == GIZMO_AXIS_X { dx = delta; }
            else if axis == GIZMO_AXIS_Y { dy = delta; }
            else { dz = delta; }
            return Mat4.Mul(Mat4.Translate(dx, dy, dz), startWorld);
        }

        var deltaTransform: Mat4 = null;
        if transformMode == GIZMO_MODE_ROTATE {
            var radians = delta * DEG_TO_RAD;
            if axis == GIZMO_AXIS_X {
                deltaTransform = Mat4.RotateX(radians);
            } else if axis == GIZMO_AXIS_Y {
                deltaTransform = Mat4.RotateY(radians);
            } else {
                deltaTransform = Mat4.RotateZ(radians);
            }
        } else if transformMode == GIZMO_MODE_SCALE {
            if worldScale == null { return null; }
            var sourceScale = worldScale.Z;
            if axis == GIZMO_AXIS_X { sourceScale = worldScale.X; }
            else if axis == GIZMO_AXIS_Y { sourceScale = worldScale.Y; }
            if sourceScale > -0.000001 and sourceScale < 0.000001 {
                return null;
            }
            var targetScale = scene_transform_3d.UsableScale(
                sourceScale + delta, sourceScale);
            var factor = targetScale / sourceScale;
            var factorX = 1.0;
            var factorY = 1.0;
            var factorZ = 1.0;
            if axis == GIZMO_AXIS_X { factorX = factor; }
            else if axis == GIZMO_AXIS_Y { factorY = factor; }
            else { factorZ = factor; }
            deltaTransform = Mat4.Scale(factorX, factorY, factorZ);
        }
        if deltaTransform == null { return null; }
        return Mat4.Mul(
            Mat4.Translate(pivot.X, pivot.Y, pivot.Z),
            Mat4.Mul(
                deltaTransform,
                Mat4.Mul(
                    Mat4.Translate(
                        0.0 - pivot.X,
                        0.0 - pivot.Y,
                        0.0 - pivot.Z),
                    startWorld)));
    }

    /// @brief Build one world-plane Move or Scale delta around a node pivot.
    /// @details Two-axis scale factors are derived from the captured absolute
    ///          scale. TrySetWorldMatrix remains the authority for whether the
    ///          resulting parent-relative transform is an exact TRS.
    hide func WorldPlaneTargetMatrix(
        startWorld: Mat4,
        pivot: Vec3,
        worldScale: Vec3,
        transformMode: Integer,
        axisA: Integer,
        axisB: Integer,
        deltaA: Number,
        deltaB: Number) -> Mat4 {
        if startWorld == null or pivot == null { return null; }
        if transformMode == GIZMO_MODE_MOVE {
            var dx = 0.0;
            var dy = 0.0;
            var dz = 0.0;
            if axisA == GIZMO_AXIS_X { dx = deltaA; }
            else if axisA == GIZMO_AXIS_Y { dy = deltaA; }
            else { dz = deltaA; }
            if axisB == GIZMO_AXIS_X { dx = deltaB; }
            else if axisB == GIZMO_AXIS_Y { dy = deltaB; }
            else { dz = deltaB; }
            return Mat4.Mul(Mat4.Translate(dx, dy, dz), startWorld);
        }
        if transformMode != GIZMO_MODE_SCALE or worldScale == null {
            return null;
        }

        var sourceA = GizmoAxisValue(worldScale, axisA);
        var sourceB = GizmoAxisValue(worldScale, axisB);
        if (sourceA > -0.000001 and sourceA < 0.000001)
           or (sourceB > -0.000001 and sourceB < 0.000001) {
            return null;
        }
        var factorA = scene_transform_3d.UsableScale(
            sourceA + deltaA, sourceA) / sourceA;
        var factorB = scene_transform_3d.UsableScale(
            sourceB + deltaB, sourceB) / sourceB;
        var factorX = 1.0;
        var factorY = 1.0;
        var factorZ = 1.0;
        if axisA == GIZMO_AXIS_X { factorX = factorA; }
        else if axisA == GIZMO_AXIS_Y { factorY = factorA; }
        else { factorZ = factorA; }
        if axisB == GIZMO_AXIS_X { factorX = factorB; }
        else if axisB == GIZMO_AXIS_Y { factorY = factorB; }
        else { factorZ = factorB; }
        var deltaTransform = Mat4.Scale(factorX, factorY, factorZ);
        return Mat4.Mul(
            Mat4.Translate(pivot.X, pivot.Y, pivot.Z),
            Mat4.Mul(
                deltaTransform,
                Mat4.Mul(
                    Mat4.Translate(
                        0.0 - pivot.X,
                        0.0 - pivot.Y,
                        0.0 - pivot.Z),
                    startWorld)));
    }

    /// @brief Restore complete local TRS snapshots after a rejected group edit.
    hide func RestoreLocalTransforms(indices: List[Integer],
                                     positions: List[Vec3],
                                     rotations: List[Quat],
                                     scales: List[Vec3]) {
        var index = 0;
        while index < indices.count()
              and index < positions.count()
              and index < rotations.count()
              and index < scales.count() {
            var nodeIndex = indices.get(index);
            if nodeIndex >= 0 and nodeIndex < flatNodes.count() {
                var node = flatNodes.get(nodeIndex);
                var position = positions.get(index);
                var scale = scales.get(index);
                node.SetPosition(position.X, position.Y, position.Z);
                node.Rotation = rotations.get(index);
                node.SetScale(scale.X, scale.Y, scale.Z);
            }
            index = index + 1;
        }
    }

    /// @brief Apply explicit relative inspector values to every selected node.
    /// @details Position and Euler values are added to each local transform;
    ///          scale values multiply each local scale. The batch commits once
    ///          and reloads the prior canonical graph on any commit failure.
    expose func ApplySelectedTransformDeltas(
        positionDeltaX: Number,
        positionDeltaY: Number,
        positionDeltaZ: Number,
        rotationDeltaX: Number,
        rotationDeltaY: Number,
        rotationDeltaZ: Number,
        scaleFactorX: Number,
        scaleFactorY: Number,
        scaleFactorZ: Number) -> Boolean {
        if scene == null { return false; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() < 2 { return false; }
        var positionChanged =
            scene_transform_3d.NearlyEqual(positionDeltaX, 0.0) == false
            or scene_transform_3d.NearlyEqual(positionDeltaY, 0.0) == false
            or scene_transform_3d.NearlyEqual(positionDeltaZ, 0.0) == false;
        var rotationChanged =
            scene_transform_3d.NearlyEqual(rotationDeltaX, 0.0) == false
            or scene_transform_3d.NearlyEqual(rotationDeltaY, 0.0) == false
            or scene_transform_3d.NearlyEqual(rotationDeltaZ, 0.0) == false;
        var scaleChanged =
            scene_transform_3d.NearlyEqual(scaleFactorX, 1.0) == false
            or scene_transform_3d.NearlyEqual(scaleFactorY, 1.0) == false
            or scene_transform_3d.NearlyEqual(scaleFactorZ, 1.0) == false;
        if positionChanged == false
           and rotationChanged == false and scaleChanged == false {
            detailLabel.SetText("The batch transform is already neutral.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node = flatNodes.get(selectedIndices.get(selectionIndex));
            var position = node.Position;
            node.SetPosition(
                position.X + positionDeltaX,
                position.Y + positionDeltaY,
                position.Z + positionDeltaZ);
            var euler = QuaternionToEulerDegrees(node.Rotation);
            node.Rotation = Quat.FromEuler(
                (euler.X + rotationDeltaX) * DEG_TO_RAD,
                (euler.Y + rotationDeltaY) * DEG_TO_RAD,
                (euler.Z + rotationDeltaZ) * DEG_TO_RAD).Normalize();
            var scale = node.Scale;
            node.SetScale(
                scale.X * scaleFactorX,
                scale.Y * scaleFactorY,
                scale.Z * scaleFactorZ);
            selectionIndex = selectionIndex + 1;
        }
        var count = selectedIndices.count();
        if CommitScene(
               "Applied transform deltas to " + count + " selected nodes")
           == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The batch transform could not be committed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshSelectedFields();
        SetEditorControlsEnabled(true);
        renderDirty = true;
        return true;
    }

    /// @brief Replace one node light with an independent all-field value.
    /// @details No live light mutates before staging completes. Imported or
    ///          shared component aliases therefore cannot observe this edit.
    expose func ApplyNodeLight(
        nodeIndex: Integer,
        state: scene_light_3d.LightState3D) -> Boolean {
        if scene == null or state == null
           or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        var next = scene_light_3d.BuildLight(state);
        if next == null {
            toolbarStatus.SetText("Light edit failed");
            detailLabel.SetText(
                "Studio could not construct an independent light value.");
            GUI.Toast.Error("3D light edit failed");
            return false;
        }
        if scene_light_3d.Equivalent(node.Light, next) {
            detailLabel.SetText("The node light is already up to date.");
            return false;
        }
        node.Light = next;
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        var typeName = scene_light_3d.TypeName(next.Type);
        if CommitScene(
               "Updated " + typeName + " light on "
               + NodeDisplayName(node)) == false {
            return false;
        }
        RefreshHierarchy(node);
        detailLabel.SetText(
            typeName
            + " light updated as one independent, undoable component.");
        return true;
    }

    /// @brief Apply the current light inspector draft to its one selected node.
    expose func ApplySelectedLightFromControls() -> Boolean {
        if lightInspector == null or selectedIndices.count() != 1 {
            return false;
        }
        return ApplyNodeLight(
            selectedIndex, lightInspector.BuildState());
    }

    /// @brief Remove one node light as a canonical history transaction.
    expose func RemoveNodeLight(nodeIndex: Integer) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        if node.Light == null {
            detailLabel.SetText("The selected node has no light component.");
            return false;
        }
        node.Light = null;
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        if CommitScene(
               "Removed light from " + NodeDisplayName(node)) == false {
            return false;
        }
        RefreshHierarchy(node);
        detailLabel.SetText(
            "Removed the light component; the scene node was preserved.");
        return true;
    }

    /// @brief Apply one copy-on-edit PBR material component transaction.
    /// @details Existing material state is cloned before visible fields change,
    ///          preserving shared siblings and unexposed texture/custom slots.
    expose func ApplyNodeMaterial(nodeIndex: Integer,
                                  red: Number,
                                  green: Number,
                                  blue: Number,
                                  alpha: Number,
                                  metallic: Number,
                                  roughness: Number,
                                  ambientOcclusion: Number,
                                  alphaMode: Integer,
                                  doubleSided: Boolean,
                                  unlit: Boolean) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        var current = node.Material;
        if scene_material_3d.Matches(
               current, red, green, blue, alpha, metallic, roughness,
               ambientOcclusion, alphaMode, doubleSided, unlit) {
            return false;
        }
        var next = scene_material_3d.MakeUnique(
            current, red, green, blue, alpha, metallic, roughness,
            ambientOcclusion, alphaMode, doubleSided, unlit);
        if next == null {
            toolbarStatus.SetText("Material edit failed");
            detailLabel.SetText(
                "Studio could not allocate a node-local material copy.");
            GUI.Toast.Error("3D material edit failed");
            return false;
        }
        node.Material = next;
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        if CommitScene("Updated material on " + NodeDisplayName(node)) == false {
            return false;
        }
        RefreshMaterialFields(node);
        return true;
    }

    /// @brief Apply one sparse PBR patch to the complete node selection.
    /// @details Materials are cloned before any live node changes. Selected
    ///          nodes that share one source material reuse one patched clone,
    ///          while unselected users retain the original. Any allocation or
    ///          serialization failure restores canonical bytes and selection.
    expose func ApplySelectedMaterialPatch(
        patch: scene_material_3d.MaterialPatch3D) -> Boolean {
        if scene == null or patch == null or patch.HasFields() == false {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }

        var currentMaterials: List[Material3D] = [];
        var nextMaterials: List[Material3D] = [];
        var changedCount = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node =
                flatNodes.get(selectedIndices.get(selectionIndex));
            var current = node.Material;
            currentMaterials.add(current);
            if scene_material_3d.MatchesPatch(current, patch) {
                nextMaterials.add(current);
            } else {
                var next: Material3D = null;
                var prior = 0;
                while prior < currentMaterials.count() - 1
                      and next == null {
                    if currentMaterials.get(prior) == current
                       and nextMaterials.get(prior) != current {
                        next = nextMaterials.get(prior);
                    }
                    prior = prior + 1;
                }
                if next == null {
                    next = scene_material_3d.ApplyPatchUnique(
                        current, patch);
                }
                if next == null {
                    toolbarStatus.SetText("Material batch failed");
                    detailLabel.SetText(
                        "Studio could not allocate every material copy. "
                        + "No selected nodes were changed.");
                    GUI.Toast.Error("3D material batch failed");
                    return false;
                }
                nextMaterials.add(next);
                changedCount = changedCount + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if changedCount == 0 { return false; }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            flatNodes.get(
                selectedIndices.get(selectionIndex)).Material =
                nextMaterials.get(selectionIndex);
            selectionIndex = selectionIndex + 1;
        }
        if CommitScene(
               "Updated material fields on " + changedCount
               + " selected node(s)") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The material batch could not be committed.");
            return false;
        }
        RefreshMaterialFields(SelectedNode());
        UpdateMaterialControls(true);
        detailLabel.SetText(
            "Material fields updated on " + changedCount
            + " selected node(s); unresolved mixed fields were preserved.");
        renderDirty = true;
        return true;
    }

    /// @brief Remove one selected material component as a history transaction.
    expose func RemoveNodeMaterial(nodeIndex: Integer) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        if node.Material == null { return false; }
        node.Material = null;
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        if CommitScene("Removed material from " + NodeDisplayName(node)) == false {
            return false;
        }
        RefreshMaterialFields(node);
        return true;
    }

    /// @brief Remove materials from every selected node in one transaction.
    expose func RemoveSelectedMaterials() -> Boolean {
        if scene == null { return false; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }
        var materialCount = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            if flatNodes.get(
                   selectedIndices.get(selectionIndex)).Material != null {
                materialCount = materialCount + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if materialCount == 0 { return false; }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            flatNodes.get(
                selectedIndices.get(selectionIndex)).Material = null;
            selectionIndex = selectionIndex + 1;
        }
        if CommitScene(
               "Removed material from " + materialCount
               + " selected node(s)") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The material removal batch could not be committed.");
            return false;
        }
        RefreshMaterialFields(SelectedNode());
        UpdateMaterialControls(true);
        detailLabel.SetText(
            "Removed " + materialCount
            + " material component(s) in one scene edit.");
        renderDirty = true;
        return true;
    }

    /// @brief Load and embed one texture map as a node-local material edit.
    expose func ApplyMaterialMapPath(nodeIndex: Integer,
                                     slot: Integer,
                                     path: String) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count()
           or scene_material_3d.IsMapSlot(slot) == false
           or Str.Trim(path) == "" {
            return false;
        }
        var texture = LoadMaterialMapPath(path);
        if texture == null { return false; }
        return AssignMaterialMap(nodeIndex, slot, texture);
    }

    /// @brief Load one map once and assign it across the current selection.
    expose func ApplySelectedMaterialMapPath(slot: Integer,
                                             path: String) -> Boolean {
        if scene == null
           or scene_material_3d.IsMapSlot(slot) == false
           or Str.Trim(path) == "" {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }
        var texture = LoadMaterialMapPath(path);
        if texture == null { return false; }
        return AssignSelectedMaterialMap(slot, texture);
    }

    /// @brief Decode one bounded material map with actionable diagnostics.
    hide func LoadMaterialMapPath(path: String) -> Any {
        var sourceBytes = safe_io.SizeBytes(path);
        if sourceBytes < 0 or sourceBytes > MAX_TEXTURE_SOURCE_BYTES {
            toolbarStatus.SetText("Texture map not loaded");
            detailLabel.SetText(
                "Choose a readable texture no larger than 16 MB.");
            GUI.Toast.Error("3D texture map could not be read");
            return null;
        }
        var texture = scene_material_3d.LoadTexturePath(path);
        if texture == null {
            toolbarStatus.SetText("Texture map not loaded");
            detailLabel.SetText(
                "Studio could not decode " + Path.Name(path)
                + ". Use PNG, JPEG, BMP, GIF, or a valid KTX2 asset; "
                + "raster maps may contain at most 16,777,216 pixels.");
            GUI.Toast.Error("Unsupported or invalid 3D texture map");
            return null;
        }
        return texture;
    }

    /// @brief Clear one editable map slot as a single history transaction.
    expose func ClearMaterialMap(nodeIndex: Integer,
                                 slot: Integer) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count()
           or scene_material_3d.IsMapSlot(slot) == false {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        if scene_material_3d.HasMap(node.Material, slot) == false {
            return false;
        }
        return AssignMaterialMap(nodeIndex, slot, null);
    }

    /// @brief Clear one map slot everywhere it is present in the selection.
    expose func ClearSelectedMaterialMap(slot: Integer) -> Boolean {
        if scene == null
           or scene_material_3d.IsMapSlot(slot) == false {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var index = 0;
        while index < selectedIndices.count() {
            var material =
                flatNodes.get(selectedIndices.get(index)).Material;
            if scene_material_3d.HasMap(material, slot) {
                return AssignSelectedMaterialMap(slot, null);
            }
            index = index + 1;
        }
        return false;
    }

    /// @brief Import one supported asset path into the active VSCN document.
    expose func ImportAssetPath(path: String) -> Boolean {
        if path == "" or currentDoc == null { return false; }
        var imported = SceneAsset.LoadResult(path);
        if imported == null or imported.IsOk == false {
            var message = "Unsupported or invalid 3D asset";
            if imported != null { message = imported.UnwrapErrStr(); }
            detailLabel.SetText("3D import failed:\n" + message);
            toolbarStatus.SetText("Import failed");
            GUI.Toast.Error("3D import failed: " + message);
            return false;
        }
        var asset = imported.Unwrap() as SceneAsset;
        var importedScene = asset.InstantiateScene() as SceneGraph;
        if importedScene == null {
            detailLabel.SetText("3D import failed: the asset has no scene hierarchy.");
            toolbarStatus.SetText("Import failed");
            GUI.Toast.Error("3D import failed: no scene hierarchy");
            return false;
        }

        var importedCount = importedScene.NodeCount - 1;
        var firstImported: SceneNode = null;
        if importedCount > 0 {
            firstImported = importedScene.Root.GetChild(0);
        }
        if scene == null {
            scene = importedScene;
        } else if importedCount > 0 {
            var importedRoot = importedScene.Root;
            while importedRoot.ChildCount > 0 {
                var importedNode = importedRoot.GetChild(0);
                importedRoot.RemoveChild(importedNode);
                if scene.TryAdd(importedNode) == false {
                    var failedDoc = currentDoc;
                    if failedDoc != null { LoadDocumentModel(failedDoc, true); }
                    detailLabel.SetText(
                        "3D import failed while merging the asset hierarchy. "
                        + "The document was restored.");
                    toolbarStatus.SetText("Import rolled back");
                    GUI.Toast.Error("3D asset merge failed");
                    return false;
                }
            }
        }
        loadError = "";
        selectedIndex = -1;
        selectedIndices = [];
        SetEditorControlsEnabled(true);
        if importedCount == 0 and scene != importedScene {
            detailLabel.SetText("The selected asset contains no scene nodes.");
            toolbarStatus.SetText("Nothing to import");
            return false;
        }
        RefreshHierarchy(firstImported);
        FrameAll();
        return CommitScene(
            "Imported " + importedCount + " node(s) from " + Path.Name(path));
    }

    hide func AddTransformSpinner(parent: GUI.HBox,
                                  label: String,
                                  value: Number) -> GUI.Spinner {
        GUI.Label.New(parent, label);
        var spinner = GUI.Spinner.New(parent);
        spinner.SetRange(-1000000.0, 1000000.0);
        spinner.SetStep(0.1);
        spinner.SetDecimals(3);
        spinner.SetValue(value);
        spinner.SetPreferredSize(72.0, 0.0);
        return spinner;
    }

    hide func AddRotationSpinner(parent: GUI.HBox,
                                 label: String) -> GUI.Spinner {
        GUI.Label.New(parent, label);
        var spinner = GUI.Spinner.New(parent);
        spinner.SetRange(-36000.0, 36000.0);
        spinner.SetStep(1.0);
        spinner.SetDecimals(2);
        spinner.SetValue(0.0);
        spinner.SetPreferredSize(76.0, 0.0);
        return spinner;
    }

    hide func LoadGraphFromContent(content: String) -> SceneGraph {
        var tempPath = TempFile.PathWithExt("zannastudio_scene3d_load_", ".vscn");
        if tempPath == "" or safe_io.WriteAllText(tempPath, content) == false {
            loadError = "Studio could not stage the scene for validation.";
            if tempPath != "" { safe_io.DeleteFile(tempPath); }
            return null;
        }
        var loaded = SceneAsset.LoadResult(tempPath);
        safe_io.DeleteFile(tempPath);
        if loaded == null or loaded.IsOk == false {
            loadError = "Invalid or unsupported VSCN data.";
            if loaded != null { loadError = loaded.UnwrapErrStr(); }
            return null;
        }
        var asset = loaded.Unwrap() as SceneAsset;
        var graph = asset.InstantiateScene() as SceneGraph;
        if graph == null {
            loadError = "The VSCN asset contains no instantiable scene.";
        }
        return graph;
    }

    hide func ImportAsset() -> Boolean {
        var baseDir = "";
        if currentDoc != null and currentDoc.filePath != "" {
            baseDir = Path.Directory(currentDoc.filePath);
        }
        var path = GUI.FileDialog.Open(
            "Import 3D Asset", baseDir, "*.vscn;*.gltf;*.glb;*.fbx;*.obj;*.stl");
        if path == "" { return false; }
        return ImportAssetPath(path);
    }

    hide func CommitScene(message: String) -> Boolean {
        if scene == null or currentDoc == null { return false; }
        var tempPath = TempFile.PathWithExt("zannastudio_scene3d_save_", ".vscn");
        if tempPath == "" or scene.Save(tempPath) == 0 {
            if tempPath != "" { safe_io.DeleteFile(tempPath); }
            RollBackFailedCommit("The 3D scene could not be serialized.");
            return false;
        }
        var readResult = safe_io.ReadAllTextBounded(tempPath, MAX_SCENE_BYTES);
        safe_io.DeleteFile(tempPath);
        if readResult.ok == false or readResult.text == "" {
            RollBackFailedCommit(
                "The serialized 3D scene exceeded Studio's 64 MB editing limit.");
            return false;
        }
        if readResult.text == currentSerialized { return false; }
        PushHistory(undoStack, currentSerialized);
        redoStack = [];
        currentSerialized = readResult.text;
        currentDoc.content = readResult.text;
        currentDoc.isModified = currentSerialized != cleanSerialized;
        revision = revision + 1;
        renderDirty = true;
        toolbarStatus.SetText(message);
        detailLabel.SetText("");
        return true;
    }

    /// @brief Append one bounded canonical VSCN history snapshot.
    hide func PushHistory(stack: List[String], content: String) {
        if content == "" { return; }
        stack.add(content);
        if stack.count() > MAX_3D_SCENE_HISTORY { stack.removeAt(0); }
    }

    hide func RollBackFailedCommit(message: String) {
        var doc = currentDoc;
        if doc != null { LoadDocumentModel(doc, true); }
        detailLabel.SetText(message + " The last edit was rolled back.");
        toolbarStatus.SetText("Edit rolled back");
        GUI.Toast.Error("3D scene edit rolled back");
    }

    hide func AddPrimitive(kind: Integer, asChild: Boolean) -> Boolean {
        if scene == null { return false; }
        var node = SceneNode.New();
        var name = "Empty " + scene.NodeCount;
        if kind == PRIMITIVE_BOX {
            name = "Box " + scene.NodeCount;
            node.Mesh = Mesh3D.Box(1.0, 1.0, 1.0);
            node.Material = Material3D.FromColor(0.30, 0.62, 0.92);
        } else if kind == PRIMITIVE_SPHERE {
            name = "Sphere " + scene.NodeCount;
            node.Mesh = Mesh3D.Sphere(0.5, 16);
            node.Material = Material3D.FromColor(0.92, 0.52, 0.26);
        } else if kind == PRIMITIVE_PLANE {
            name = "Plane " + scene.NodeCount;
            node.Mesh = Mesh3D.Plane(4.0, 4.0);
            node.Material = Material3D.FromColor(0.42, 0.70, 0.42);
        }
        node.Name = name;
        var parent = SelectedNode();
        if asChild and parent != null {
            parent.AddChild(node);
        } else {
            scene.Add(node);
        }
        if CommitScene("Added " + name) == false { return false; }
        RefreshHierarchy(node);
        return true;
    }

    hide func FindNodeIndex(nodes: List[SceneNode],
                            needle: SceneNode) -> Integer {
        var index = 0;
        while index < nodes.count() {
            if nodes.get(index) == needle { return index; }
            index = index + 1;
        }
        return -1;
    }

    /// @brief Return selected roots in an arbitrary flattened source graph.
    hide func TopLevelIndicesFor(nodes: List[SceneNode],
                                 indices: List[Integer],
                                 primary: Integer) -> List[Integer] {
        var roots: List[Integer] = [];
        var normalized = scene_selection.Normalize(
            indices, nodes.count(), primary);
        var selectionIndex = 0;
        while selectionIndex < normalized.count() {
            var candidate = normalized.get(selectionIndex);
            var parent = nodes.get(candidate).Parent;
            var hasSelectedAncestor = false;
            while parent != null and hasSelectedAncestor == false {
                var parentIndex = FindNodeIndex(nodes, parent);
                if parentIndex >= 0
                   and scene_selection.Contains(
                       normalized, parentIndex) {
                    hasSelectedAncestor = true;
                }
                parent = parent.Parent;
            }
            if hasSelectedAncestor == false { roots.add(candidate); }
            selectionIndex = selectionIndex + 1;
        }
        return roots;
    }

    /// @brief Return selected hierarchy roots, excluding selected descendants.
    hide func TopLevelSelectedIndices() -> List[Integer] {
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        return TopLevelIndicesFor(
            flatNodes, selectedIndices, selectedIndex);
    }

    /// @brief Return live handles for the top-level roots of current selection.
    hide func TopLevelSelectedNodes() -> List[SceneNode] {
        var nodes: List[SceneNode] = [];
        var indices = TopLevelSelectedIndices();
        var index = 0;
        while index < indices.count() {
            nodes.add(flatNodes.get(indices.get(index)));
            index = index + 1;
        }
        return nodes;
    }

    /// @brief Return the maximum child-edge depth beneath one live node.
    hide func SubtreeRelativeDepth(node: SceneNode) -> Integer {
        if node == null { return 0; }
        var maximum = 0;
        var child = 0;
        while child < node.ChildCount {
            var depth = 1 + SubtreeRelativeDepth(node.GetChild(child));
            if depth > maximum { maximum = depth; }
            if maximum >= MAX_HIERARCHY_DEPTH { return maximum; }
            child = child + 1;
        }
        return maximum;
    }

    /// @brief Return whether all moved subtrees remain visible within the cap.
    hide func ParentTargetFits(targetIndex: Integer,
                               roots: List[SceneNode]) -> Boolean {
        var rootDepth = 0;
        if targetIndex >= 0 {
            if targetIndex >= flatDepths.count() { return false; }
            rootDepth = flatDepths.get(targetIndex) + 1;
        }
        var index = 0;
        while index < roots.count() {
            if rootDepth + SubtreeRelativeDepth(roots.get(index))
               > MAX_HIERARCHY_DEPTH {
                return false;
            }
            index = index + 1;
        }
        return true;
    }

    /// @brief Move selected hierarchy roots beneath one existing target.
    /// @param targetIndex Flattened target index, or -1 for the scene root.
    /// @details World transforms are preserved by default through the runtime's
    ///          exact TRS conversion; the inspector can explicitly preserve
    ///          local transforms instead. Cycles, excessive depth, lossy world
    ///          conversion, unchanged parents, and invalid targets are
    ///          byte/history no-ops.
    ///          The complete operation serializes once and selection is remapped
    ///          by live node identity after preorder changes.
    expose func ReparentSelectedNodes(targetIndex: Integer) -> Boolean {
        if scene == null or (targetIndex < -1)
           or targetIndex >= flatNodes.count() {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var roots = TopLevelSelectedNodes();
        if roots.count() == 0 { return false; }

        var target = scene.Root;
        if targetIndex >= 0 { target = flatNodes.get(targetIndex); }
        if scene_hierarchy_3d.TargetAllowed(target, roots) == false {
            detailLabel.SetText(
                "A node cannot be reparented to itself or one of its descendants.");
            return false;
        }
        if ParentTargetFits(targetIndex, roots) == false {
            detailLabel.SetText(
                "That parent would exceed Studio's hierarchy depth limit.");
            return false;
        }
        if scene_hierarchy_3d.AllAlreadyParented(roots, target) {
            detailLabel.SetText(
                "The selected hierarchy roots already use that parent.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectedNodes: List[SceneNode] = [];
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            selectedNodes.add(
                flatNodes.get(selectedIndices.get(selectionIndex)));
            selectionIndex = selectionIndex + 1;
        }
        var primaryNode = SelectedNode();
        var preserveWorld = preserveWorldReparentCheck != null
            and preserveWorldReparentCheck.IsChecked();

        var rootIndex = 0;
        while rootIndex < roots.count() {
            var node = roots.get(rootIndex);
            var attached = false;
            if preserveWorld {
                attached = target.TryAddChildPreserveWorld(node);
            } else {
                attached = target.TryAddChild(node);
            }
            if attached == false {
                var failure =
                    "Studio could not attach every selected hierarchy root. "
                    + "The document was restored.";
                if preserveWorld {
                    failure =
                        "Keeping the complete world transform would require "
                        + "a singular, sheared, or otherwise lossy local "
                        + "transform. The document was restored.";
                }
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    failure);
                return false;
            }
            rootIndex = rootIndex + 1;
        }

        // Resolve every identity before accepting serialized bytes. If the
        // resulting preorder cannot represent the complete prior selection,
        // currentDoc still contains the old canonical graph and rollback is
        // exact.
        var destinationNodes = FlattenGraph(scene);
        var nextSelection: List[Integer] = [];
        selectionIndex = 0;
        while selectionIndex < selectedNodes.count() {
            var mapped = FindNodeIndex(
                destinationNodes, selectedNodes.get(selectionIndex));
            if mapped >= 0 { nextSelection.add(mapped); }
            selectionIndex = selectionIndex + 1;
        }
        var nextPrimary = FindNodeIndex(destinationNodes, primaryNode);
        if nextSelection.count() != selectedNodes.count()
           or nextPrimary < 0 {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not retain the reparented selection.");
            return false;
        }

        var targetName = "scene root";
        if targetIndex >= 0 { targetName = NodeDisplayName(target); }
        var transformMode = " while preserving local transforms";
        if preserveWorld {
            transformMode = " while preserving world transforms";
        }
        if CommitScene(
               "Reparented " + roots.count() + " hierarchy root(s) to "
               + targetName + transformMode) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected hierarchy could not be reparented.");
            return false;
        }

        RefreshHierarchy(null);
        SelectSceneNodes(nextSelection, nextPrimary);
        if preserveWorld {
            detailLabel.SetText(
                "World transforms were preserved while changing parent.");
        } else {
            detailLabel.SetText(
                "Local transforms were preserved while changing parent.");
        }
        return true;
    }

    /// @brief Apply one latched TreeView row drop through canonical history.
    /// @details Dragging an unselected source first makes it the sole
    ///          selection. INTO uses the established transactional reparent
    ///          path; BEFORE/AFTER also establish exact sibling order.
    expose func ApplyHierarchyDrop(sourceIndex: Integer,
                                   targetIndex: Integer,
                                   position: Integer) -> Boolean {
        if scene == null
           or sourceIndex < 0 or sourceIndex >= flatNodes.count()
           or targetIndex < 0 or targetIndex >= flatNodes.count()
           or position < 0 or position > 2 {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if scene_selection.Contains(selectedIndices, sourceIndex) == false {
            SelectIndex(sourceIndex);
        }
        if position == 1 {
            return ReparentSelectedNodes(targetIndex);
        }
        return MoveSelectedBeside(
            targetIndex, position == 2);
    }

    /// @brief Return whether one direct-child sequence is already exact.
    hide func ChildOrderMatches(parent: SceneNode,
                                desired: List[SceneNode]) -> Boolean {
        if parent == null or parent.ChildCount != desired.count() {
            return false;
        }
        var index = 0;
        while index < desired.count() {
            if parent.GetChild(index) != desired.get(index) {
                return false;
            }
            index = index + 1;
        }
        return true;
    }

    /// @brief Reparent selected roots beside a target and establish row order.
    /// @details Attachment, exact preserve-world conversion, stable ordering,
    ///          serialization, selection remapping, and rollback form one edit.
    hide func MoveSelectedBeside(targetIndex: Integer,
                                 after: Boolean) -> Boolean {
        if scene == null
           or targetIndex < 0 or targetIndex >= flatNodes.count() {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var roots = TopLevelSelectedNodes();
        if roots.count() == 0 { return false; }

        var target = flatNodes.get(targetIndex);
        if scene_hierarchy_3d.TargetAllowed(target, roots) == false {
            detailLabel.SetText(
                "Drop beside a node outside the selected subtrees.");
            return false;
        }
        var destinationParent = target.Parent;
        if destinationParent == null {
            detailLabel.SetText("The drop target has no editable parent.");
            return false;
        }
        var destinationParentIndex =
            FindNodeIndex(flatNodes, destinationParent);
        if ParentTargetFits(destinationParentIndex, roots) == false {
            detailLabel.SetText(
                "That row drop would exceed Studio's hierarchy depth limit.");
            return false;
        }

        // Normalize moved roots to the scene's current structural preorder,
        // independent of the order in which callers supplied selected indices.
        var orderedRoots: List[SceneNode] = [];
        var flatIndex = 0;
        while flatIndex < flatNodes.count() {
            var candidate = flatNodes.get(flatIndex);
            if FindNodeIndex(roots, candidate) >= 0 {
                orderedRoots.add(candidate);
            }
            flatIndex = flatIndex + 1;
        }
        if orderedRoots.count() != roots.count() { return false; }

        // Compute the complete destination order before changing hierarchy.
        // Selected roots already under the destination are removed first, then
        // the whole ordered block is inserted around the target.
        var desired: List[SceneNode] = [];
        var inserted = false;
        var childIndex = 0;
        while childIndex < destinationParent.ChildCount {
            var child = destinationParent.GetChild(childIndex);
            if FindNodeIndex(orderedRoots, child) < 0 {
                if child == target and after == false {
                    var rootIndex = 0;
                    while rootIndex < orderedRoots.count() {
                        desired.add(orderedRoots.get(rootIndex));
                        rootIndex = rootIndex + 1;
                    }
                }
                desired.add(child);
                if child == target and after {
                    var rootIndex = 0;
                    while rootIndex < orderedRoots.count() {
                        desired.add(orderedRoots.get(rootIndex));
                        rootIndex = rootIndex + 1;
                    }
                }
                if child == target { inserted = true; }
            }
            childIndex = childIndex + 1;
        }
        if inserted == false {
            detailLabel.SetText("The row drop target is no longer attached.");
            return false;
        }

        var allAlreadyDirect = true;
        var rootIndex = 0;
        while rootIndex < orderedRoots.count() {
            if orderedRoots.get(rootIndex).Parent != destinationParent {
                allAlreadyDirect = false;
            }
            rootIndex = rootIndex + 1;
        }
        if allAlreadyDirect and ChildOrderMatches(destinationParent, desired) {
            detailLabel.SetText(
                "The selected hierarchy roots already use that row position.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectedNodes: List[SceneNode] = [];
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            selectedNodes.add(
                flatNodes.get(selectedIndices.get(selectionIndex)));
            selectionIndex = selectionIndex + 1;
        }
        var primaryNode = SelectedNode();
        var preserveWorld = preserveWorldReparentCheck != null
            and preserveWorldReparentCheck.IsChecked();

        rootIndex = 0;
        while rootIndex < orderedRoots.count() {
            var node = orderedRoots.get(rootIndex);
            if node.Parent != destinationParent {
                var attached = false;
                if preserveWorld {
                    attached =
                        destinationParent.TryAddChildPreserveWorld(node);
                } else {
                    attached = destinationParent.TryAddChild(node);
                }
                if attached == false {
                    RollBackGroupEdit(
                        previousSelection, previousPrimary,
                        "Studio could not attach every dragged hierarchy "
                        + "root without a lossy transform.");
                    return false;
                }
            }
            rootIndex = rootIndex + 1;
        }

        if destinationParent.ChildCount != desired.count() {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The destination hierarchy changed during the row drop.");
            return false;
        }
        childIndex = 0;
        while childIndex < desired.count() {
            var desiredChild = desired.get(childIndex);
            if destinationParent.GetChild(childIndex) != desiredChild
               and destinationParent.TryMoveChild(
                       desiredChild, childIndex) == false {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "Studio could not establish the complete dropped row order.");
                return false;
            }
            childIndex = childIndex + 1;
        }
        if ChildOrderMatches(destinationParent, desired) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not verify the complete dropped row order.");
            return false;
        }

        var destinationNodes = FlattenGraph(scene);
        var nextSelection: List[Integer] = [];
        selectionIndex = 0;
        while selectionIndex < selectedNodes.count() {
            var mapped = FindNodeIndex(
                destinationNodes, selectedNodes.get(selectionIndex));
            if mapped >= 0 { nextSelection.add(mapped); }
            selectionIndex = selectionIndex + 1;
        }
        var nextPrimary = FindNodeIndex(destinationNodes, primaryNode);
        if nextSelection.count() != selectedNodes.count()
           or nextPrimary < 0 {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not retain the dropped hierarchy selection.");
            return false;
        }

        var placement = "before";
        if after { placement = "after"; }
        if CommitScene(
               "Moved " + orderedRoots.count() + " hierarchy root(s) "
               + placement + " " + NodeDisplayName(target)) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The dropped hierarchy could not be committed.");
            return false;
        }
        RefreshHierarchy(null);
        SelectSceneNodes(nextSelection, nextPrimary);
        detailLabel.SetText(
            "Hierarchy row order changed as one undoable edit.");
        return true;
    }

    /// @brief Return a selected contiguous block of children in sibling order.
    /// @details Empty means the selection is empty, mixed-parent, contains
    ///          ancestor/descendant rows, or has an unselected sibling gap.
    hide func SelectedSiblingBlock() -> List[SceneNode] {
        var block: List[SceneNode] = [];
        if scene == null { return block; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return block; }

        var selectedNodes: List[SceneNode] = [];
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            selectedNodes.add(
                flatNodes.get(selectedIndices.get(selectionIndex)));
            selectionIndex = selectionIndex + 1;
        }
        var parent = selectedNodes.get(0).Parent;
        if parent == null { return block; }
        selectionIndex = 1;
        while selectionIndex < selectedNodes.count() {
            if selectedNodes.get(selectionIndex).Parent != parent {
                return [];
            }
            selectionIndex = selectionIndex + 1;
        }

        var started = false;
        var ended = false;
        var childIndex = 0;
        while childIndex < parent.ChildCount {
            var child = parent.GetChild(childIndex);
            var selected = FindNodeIndex(selectedNodes, child) >= 0;
            if selected {
                if ended { return []; }
                block.add(child);
                started = true;
            } else if started {
                ended = true;
            }
            childIndex = childIndex + 1;
        }
        if block.count() != selectedNodes.count() { return []; }
        return block;
    }

    /// @brief Find one direct child index without exposing native child storage.
    hide func DirectChildIndex(parent: SceneNode,
                               child: SceneNode) -> Integer {
        if parent == null or child == null { return -1; }
        var index = 0;
        while index < parent.ChildCount {
            if parent.GetChild(index) == child { return index; }
            index = index + 1;
        }
        return -1;
    }

    /// @brief Move one contiguous selected sibling block by one position.
    /// @param direction -1 for earlier or 1 for later.
    /// @details The runtime operation is allocation-free, but Studio still
    ///          treats the complete block as one canonical history transaction
    ///          and reloads the old document after any rejected partial move.
    expose func MoveSelectedSiblings(direction: Integer) -> Boolean {
        if direction != -1 and direction != 1 { return false; }
        var block = SelectedSiblingBlock();
        if block.count() == 0 {
            detailLabel.SetText(
                "Select one contiguous group of nodes with the same parent.");
            return false;
        }
        var parent = block.get(0).Parent;
        var first = DirectChildIndex(parent, block.get(0));
        if first < 0 { return false; }
        var last = first + block.count() - 1;
        if (direction < 0 and first == 0)
           or (direction > 0 and last + 1 >= parent.ChildCount) {
            detailLabel.SetText(
                "The selected sibling block is already at that boundary.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectedNodes: List[SceneNode] = [];
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            selectedNodes.add(
                flatNodes.get(selectedIndices.get(selectionIndex)));
            selectionIndex = selectionIndex + 1;
        }
        var primaryNode = SelectedNode();

        if direction < 0 {
            var blockIndex = 0;
            while blockIndex < block.count() {
                if parent.TryMoveChild(
                       block.get(blockIndex),
                       first - 1 + blockIndex) == false {
                    RollBackGroupEdit(
                        previousSelection, previousPrimary,
                        "Studio could not move the complete sibling block.");
                    return false;
                }
                blockIndex = blockIndex + 1;
            }
        } else {
            var blockIndex = block.count() - 1;
            while blockIndex >= 0 {
                if parent.TryMoveChild(
                       block.get(blockIndex),
                       first + blockIndex + 1) == false {
                    RollBackGroupEdit(
                        previousSelection, previousPrimary,
                        "Studio could not move the complete sibling block.");
                    return false;
                }
                blockIndex = blockIndex - 1;
            }
        }

        var destinationNodes = FlattenGraph(scene);
        var nextSelection: List[Integer] = [];
        selectionIndex = 0;
        while selectionIndex < selectedNodes.count() {
            var mapped = FindNodeIndex(
                destinationNodes, selectedNodes.get(selectionIndex));
            if mapped >= 0 { nextSelection.add(mapped); }
            selectionIndex = selectionIndex + 1;
        }
        var nextPrimary = FindNodeIndex(destinationNodes, primaryNode);
        if nextSelection.count() != selectedNodes.count()
           or nextPrimary < 0 {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not retain the reordered selection.");
            return false;
        }

        var directionName = "earlier";
        if direction > 0 { directionName = "later"; }
        if CommitScene(
               "Moved " + block.count() + " sibling node(s) "
               + directionName) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected sibling block could not be reordered.");
            return false;
        }
        RefreshHierarchy(null);
        SelectSceneNodes(nextSelection, nextPrimary);
        detailLabel.SetText(
            "Sibling order changed without changing parent or local transforms.");
        return true;
    }

    /// @brief Remove selected hierarchy roots as one safe history transaction.
    expose func DeleteSelectedNodes() -> Boolean {
        if scene == null { return false; }
        var roots = TopLevelSelectedIndices();
        if roots.count() == 0 { return false; }
        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var firstRemoved = flatNodes.count();
        var index = roots.count() - 1;
        while index >= 0 {
            var nodeIndex = roots.get(index);
            if nodeIndex < firstRemoved { firstRemoved = nodeIndex; }
            scene.Remove(flatNodes.get(nodeIndex));
            index = index - 1;
        }
        selectedIndex = firstRemoved;
        selectedIndices = scene_selection.Single(
            selectedIndex, scene.NodeCount - 1);
        var message = "Deleted " + previousSelection.count()
            + " selected node(s)";
        if CommitScene(message) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected nodes could not be deleted.");
            return false;
        }
        RefreshHierarchy(null);
        return true;
    }

    /// @brief Flatten one cloned graph in the same pre-order as the inspector.
    hide func FlattenGraph(graph: SceneGraph) -> List[SceneNode] {
        var nodes: List[SceneNode] = [];
        if graph == null { return nodes; }
        var root = graph.Root;
        var child = 0;
        while child < root.ChildCount and nodes.count() < MAX_EDITOR_NODES {
            AppendFlattenedClone(root.GetChild(child), nodes);
            child = child + 1;
        }
        return nodes;
    }

    hide func AppendFlattenedClone(node: SceneNode,
                                   nodes: List[SceneNode]) {
        if node == null or nodes.count() >= MAX_EDITOR_NODES { return; }
        nodes.add(node);
        var child = 0;
        while child < node.ChildCount and nodes.count() < MAX_EDITOR_NODES {
            AppendFlattenedClone(node.GetChild(child), nodes);
            child = child + 1;
        }
    }

    /// @brief Return a useful scene-unique name for one duplicated root.
    hide func UniqueDuplicateNodeName(source: SceneNode) -> String {
        var stem = NodeDisplayName(source) + " Copy";
        if scene.Find(stem).IsNone { return stem; }
        var suffix = 2;
        while suffix <= flatNodes.count() + 2 {
            var candidate = stem + " " + suffix;
            if scene.Find(candidate).IsNone { return candidate; }
            suffix = suffix + 1;
        }
        return stem + " " + (flatNodes.count() + 3);
    }

    /// @brief Reload canonical content after a partially applied group action.
    hide func RollBackGroupEdit(previousSelection: List[Integer],
                                previousPrimary: Integer,
                                message: String) {
        var doc = currentDoc;
        if doc != null { LoadDocumentModel(doc, true); }
        SelectSceneNodes(previousSelection, previousPrimary);
        toolbarStatus.SetText("Group edit rolled back");
        detailLabel.SetText(message);
    }

    /// @brief Duplicate selected hierarchy roots from a canonical full clone.
    /// @return Number of selected nodes represented in the duplicate selection.
    expose func DuplicateSelectedNodes() -> Integer {
        if scene == null or currentSerialized == "" { return 0; }
        var roots = TopLevelSelectedIndices();
        if roots.count() == 0 { return 0; }
        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var cloneGraph = LoadGraphFromContent(currentSerialized);
        var cloneNodes = FlattenGraph(cloneGraph);
        if cloneGraph == null or cloneNodes.count() != flatNodes.count() {
            detailLabel.SetText(
                "Studio could not build a complete hierarchy clone. "
                + "No nodes were changed.");
            return 0;
        }

        var duplicateSelectionNodes: List[SceneNode] = [];
        var selectionIndex = 0;
        while selectionIndex < previousSelection.count() {
            duplicateSelectionNodes.add(
                cloneNodes.get(previousSelection.get(selectionIndex)));
            selectionIndex = selectionIndex + 1;
        }
        var primaryClone: SceneNode = null;
        if previousPrimary >= 0 and previousPrimary < cloneNodes.count() {
            primaryClone = cloneNodes.get(previousPrimary);
        }

        var rootIndex = 0;
        while rootIndex < roots.count() {
            var sourceIndex = roots.get(rootIndex);
            var source = flatNodes.get(sourceIndex);
            var clone = cloneNodes.get(sourceIndex);
            var cloneParent = clone.Parent;
            var destinationParent = source.Parent;
            if cloneParent == null or destinationParent == null {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "The duplicate hierarchy had no valid parent.");
                return 0;
            }
            cloneParent.RemoveChild(clone);
            clone.Name = UniqueDuplicateNodeName(source);
            var position = clone.Position;
            clone.SetPosition(position.X + 1.0, position.Y, position.Z);
            if destinationParent.TryAddChild(clone) == false {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "Studio could not attach every duplicated subtree. "
                    + "The document was restored.");
                return 0;
            }
            rootIndex = rootIndex + 1;
        }
        if scene.NodeCount - 1 > MAX_EDITOR_NODES {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Duplicating this selection would exceed Studio's "
                + MAX_EDITOR_NODES + "-node editing limit.");
            return 0;
        }

        var message = "Duplicated " + roots.count()
            + " selected hierarchy root(s)";
        if CommitScene(message) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected hierarchy could not be duplicated.");
            return 0;
        }
        RefreshHierarchy(null);
        var duplicateIndices: List[Integer] = [];
        var duplicatePrimary = -1;
        selectionIndex = 0;
        while selectionIndex < duplicateSelectionNodes.count() {
            var duplicateIndex =
                FindFlatIndex(duplicateSelectionNodes.get(selectionIndex));
            if duplicateIndex >= 0 { duplicateIndices.add(duplicateIndex); }
            selectionIndex = selectionIndex + 1;
        }
        if primaryClone != null {
            duplicatePrimary = FindFlatIndex(primaryClone);
        }
        if duplicatePrimary < 0 and duplicateIndices.count() > 0 {
            duplicatePrimary = duplicateIndices.get(0);
        }
        SelectSceneNodes(duplicateIndices, duplicatePrimary);
        return duplicateIndices.count();
    }

    hide func ApplySelectedNode() -> Boolean {
        var node = SelectedNode();
        if node == null { return false; }
        var nextName = Str.Trim(nameInput.Text);
        if nextName == "" { nextName = "Node"; }
        node.Name = nextName;
        node.Visible = visibleCheck.IsChecked();
        node.SetPosition(positionX.Value, positionY.Value, positionZ.Value);
        node.Rotation = Quat.FromEuler(rotationX.Value * DEG_TO_RAD,
                                       rotationY.Value * DEG_TO_RAD,
                                       rotationZ.Value * DEG_TO_RAD).Normalize();
        node.SetScale(scaleX.Value, scaleY.Value, scaleZ.Value);
        if CommitScene("Updated " + nextName) == false { return false; }
        RefreshHierarchy(node);
        return true;
    }

    /// @brief Set visibility across the complete normalized node selection.
    /// @details Mixed state is presentation-only. A determined checkbox value
    ///          changes every selected node, verifies the live graph, and
    ///          creates one canonical VSCN history entry. No-op and failed
    ///          commits retain content, selection, and history.
    hide func ApplySelectedVisibility(nextVisible: Boolean) -> Boolean {
        if scene == null { return false; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }

        var needsChange = false;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            if flatNodes.get(
                   selectedIndices.get(selectionIndex)).Visible
               != nextVisible {
                needsChange = true;
            }
            selectionIndex = selectionIndex + 1;
        }
        if needsChange == false {
            detailLabel.SetText(
                "Every selected node already has that visibility.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var node =
                flatNodes.get(selectedIndices.get(selectionIndex));
            node.Visible = nextVisible;
            if node.Visible != nextVisible {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "Studio could not update every selected node's visibility.");
                return false;
            }
            selectionIndex = selectionIndex + 1;
        }

        var stateName = "visible";
        if nextVisible == false { stateName = "hidden"; }
        if CommitScene(
               "Set " + selectedIndices.count() + " node(s) "
               + stateName) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The selected nodes' visibility could not be committed.");
            return false;
        }
        RefreshHierarchy(null);
        SelectSceneNodes(previousSelection, previousPrimary);
        detailLabel.SetText(
            "Visibility updated for the complete selection.");
        return true;
    }

    /// @brief Commit every determined material control for the selection.
    expose func ApplySelectedMaterialFromControls() -> Boolean {
        if materialInspector == null or materialInspector.colorPicker == null {
            return false;
        }
        materialInspector.PumpDraftIntent();
        return ApplySelectedMaterialPatch(
            materialInspector.BuildPatch());
    }

    /// @brief Open the native picker for the currently selected texture slot.
    hide func ChooseMaterialMap() -> Boolean {
        var node = SelectedNode();
        if node == null { return false; }
        var baseDir = "";
        if currentDoc != null and currentDoc.filePath != "" {
            baseDir = Path.Directory(currentDoc.filePath);
        }
        var slot = materialInspector.mapSlot.Selected;
        var path = GUI.FileDialog.Open(
            "Choose " + scene_material_3d.MapSlotName(slot) + " Map",
            baseDir,
            "*.png;*.jpg;*.jpeg;*.bmp;*.gif;*.ktx2");
        if path == "" { return false; }
        return ApplySelectedMaterialMapPath(slot, path);
    }

    /// @brief Assign or clear one map across the complete node selection.
    /// @details All required material clones are staged before nodes mutate.
    ///          Equal source-material identities reuse one staged clone, so a
    ///          selected sharing group remains shared without affecting any
    ///          unselected node that owns the original material.
    expose func AssignSelectedMaterialMap(slot: Integer,
                                          texture: Any) -> Boolean {
        if scene == null
           or scene_material_3d.IsMapSlot(slot) == false {
            return false;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }

        var currentMaterials: List[Material3D] = [];
        var nextMaterials: List[Material3D] = [];
        var changedCount = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            var current = flatNodes.get(
                selectedIndices.get(selectionIndex)).Material;
            currentMaterials.add(current);
            var shouldChange = texture != null
                or scene_material_3d.HasMap(current, slot);
            if shouldChange == false {
                nextMaterials.add(current);
            } else {
                var next: Material3D = null;
                var prior = 0;
                while prior < currentMaterials.count() - 1
                      and next == null {
                    if currentMaterials.get(prior) == current
                       and nextMaterials.get(prior) != current {
                        next = nextMaterials.get(prior);
                    }
                    prior = prior + 1;
                }
                if next == null {
                    next = scene_material_3d.WithMap(
                        current, slot, texture);
                }
                if next == null {
                    toolbarStatus.SetText("Texture map batch failed");
                    detailLabel.SetText(
                        "Studio could not allocate every material map copy. "
                        + "No selected nodes were changed.");
                    GUI.Toast.Error("3D texture map batch failed");
                    return false;
                }
                nextMaterials.add(next);
                changedCount = changedCount + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if changedCount == 0 { return false; }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        selectionIndex = 0;
        while selectionIndex < selectedIndices.count() {
            flatNodes.get(
                selectedIndices.get(selectionIndex)).Material =
                nextMaterials.get(selectionIndex);
            selectionIndex = selectionIndex + 1;
        }
        var action = "Embedded ";
        if texture == null { action = "Cleared "; }
        if CommitScene(
               action + scene_material_3d.MapSlotName(slot)
               + " map on " + changedCount + " selected node(s)") == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The texture map batch could not be committed.");
            return false;
        }
        RefreshMaterialFields(SelectedNode());
        UpdateMaterialControls(true);
        detailLabel.SetText(
            action + scene_material_3d.MapSlotName(slot)
            + " map on " + changedCount + " selected node(s).");
        renderDirty = true;
        return true;
    }

    /// @brief Assign a loaded object to one cloned material map slot.
    hide func AssignMaterialMap(nodeIndex: Integer,
                                slot: Integer,
                                texture: Any) -> Boolean {
        if scene == null or nodeIndex < 0 or nodeIndex >= flatNodes.count()
           or scene_material_3d.IsMapSlot(slot) == false {
            return false;
        }
        var node = flatNodes.get(nodeIndex);
        var next = scene_material_3d.WithMap(node.Material, slot, texture);
        if next == null {
            toolbarStatus.SetText("Texture map edit failed");
            detailLabel.SetText(
                "Studio could not create a node-local material copy.");
            GUI.Toast.Error("3D texture map edit failed");
            return false;
        }
        node.Material = next;
        selectedIndex = nodeIndex;
        selectedIndices = scene_selection.Single(
            nodeIndex, flatNodes.count());
        var action = "Embedded ";
        if texture == null { action = "Cleared "; }
        if CommitScene(
               action + scene_material_3d.MapSlotName(slot)
               + " map on " + NodeDisplayName(node)) == false {
            return false;
        }
        RefreshMaterialFields(node);
        return true;
    }

    hide func SetEditorControlsEnabled(enabled: Boolean) {
        if addEmptyButton == null { return; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var hasSelection = enabled and selectedIndex >= 0
            and selectedIndex < flatNodes.count()
            and selectedIndices.count() > 0;
        var hasSingle = hasSelection and selectedIndices.count() == 1;
        addEmptyButton.SetEnabled(enabled);
        addChildButton.SetEnabled(hasSingle);
        addBoxButton.SetEnabled(enabled);
        addSphereButton.SetEnabled(enabled);
        addPlaneButton.SetEnabled(enabled);
        addLightButton.SetEnabled(enabled);
        duplicateNodeButton.SetEnabled(hasSelection);
        moveToolButton.SetEnabled(hasSelection);
        rotateToolButton.SetEnabled(hasSelection);
        scaleToolButton.SetEnabled(hasSelection);
        snapTransformCheck.SetEnabled(hasSelection);
        deleteNodeButton.SetEnabled(hasSelection);
        frameSelectedButton.SetEnabled(hasSelection);
        hierarchySearchInput.SetEnabled(enabled);
        hierarchyTree.SetEnabled(enabled);
        parentDropdown.SetEnabled(hasSelection);
        reparentButton.SetEnabled(hasSelection);
        preserveWorldReparentCheck.SetEnabled(hasSelection);
        moveSiblingEarlierButton.SetEnabled(false);
        moveSiblingLaterButton.SetEnabled(false);
        nameInput.SetEnabled(hasSingle);
        visibleCheck.SetEnabled(hasSelection);
        positionX.SetEnabled(hasSelection);
        positionY.SetEnabled(hasSelection);
        positionZ.SetEnabled(hasSelection);
        rotationX.SetEnabled(hasSelection);
        rotationY.SetEnabled(hasSelection);
        rotationZ.SetEnabled(hasSelection);
        scaleX.SetEnabled(hasSelection);
        scaleY.SetEnabled(hasSelection);
        scaleZ.SetEnabled(hasSelection);
        applyTransformButton.SetEnabled(hasSelection);
        duplicateNodeButton.SetText("Duplicate");
        deleteNodeButton.SetText("Delete");
        applyTransformButton.SetText("Apply node properties");
        applyTransformButton.SetTooltip(
            "Set the selected node's name, visibility, and local transform");
        UpdateHierarchySearchControls();
        if selectedIndices.count() > 1 {
            duplicateNodeButton.SetText(
                "Duplicate (" + selectedIndices.count() + ")");
            deleteNodeButton.SetText(
                "Delete (" + selectedIndices.count() + ")");
            applyTransformButton.SetText(
                "Apply deltas to " + selectedIndices.count());
            applyTransformButton.SetTooltip(
                "Add position/rotation and multiply scale for every "
                + "selected node as one undoable edit");
        }
        UpdateParentControlAvailability();
        UpdateSiblingControlAvailability();
        metadataInspector.SetEnabled(hasSingle);
        UpdateLightControls(enabled);
        UpdateMaterialControls(enabled);
    }

    /// @brief Refresh typed metadata without rebuilding hierarchy identity.
    hide func RefreshMetadataFields(node: SceneNode) {
        if metadataInspector == null { return; }
        if selectedIndex != metadataOwnerIndex {
            selectedNodeMetadata = -1;
            metadataOwnerIndex = selectedIndex;
        }
        var enabled = scene != null and node != null
            and selectedIndices.count() == 1;
        metadataInspector.Refresh(
            node, enabled, selectedNodeMetadata);
        selectedNodeMetadata = metadataInspector.selectedProperty;
    }

    /// @brief Refresh complete node-light controls without changing history.
    hide func RefreshLightFields(node: SceneNode) {
        if lightInspector == null { return; }
        lightInspector.Refresh(
            node,
            selectedIndices.count(),
            scene != null);
    }

    /// @brief Keep light actions truthful for single-node authoring.
    hide func UpdateLightControls(editorEnabled: Boolean) {
        if lightInspector == null { return; }
        var node = SelectedNode();
        var hasLight = node != null and node.Light != null;
        lightInspector.UpdateControls(
            editorEnabled, hasLight, selectedIndices.count());
    }

    /// @brief Summarize selected-node coverage for the active component.
    hide func RefreshComponentPalette() {
        if componentPalette == null or componentPalette.group == null {
            return;
        }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var component = componentPalette.SelectedComponent();
        var enabled = scene != null and selectedIndices.count() > 0
            and component != null;
        var present = 0;
        var missing = 0;
        var conflicts = 0;
        if enabled {
            var selectionIndex = 0;
            while selectionIndex < selectedIndices.count() {
                var node =
                    flatNodes.get(selectedIndices.get(selectionIndex));
                var fieldIndex = 0;
                while fieldIndex < component.fields.count() {
                    var field = component.fields.get(fieldIndex);
                    if node.MetadataHas(field.key) == false {
                        missing = missing + 1;
                    } else if node.MetadataKind(field.key) == field.kind {
                        present = present + 1;
                    } else {
                        conflicts = conflicts + 1;
                    }
                    fieldIndex = fieldIndex + 1;
                }
                selectionIndex = selectionIndex + 1;
            }
        }
        componentPalette.SetContext(
            enabled, present, missing, conflicts);
        componentPalette.SetEditEnabled(
            enabled and selectedIndices.count() == 1);
    }

    /// @brief Route project component-picker intent into editor transactions.
    hide func PumpComponentControls() -> Boolean {
        if componentPalette == null or componentPalette.group == null {
            return false;
        }
        if componentPalette.Pump() { RefreshComponentPalette(); }
        var schemaChanged = componentAuthoring.PollExternalChanges(
            1000, componentPalette);
        var schemaAuthored =
            componentAuthoring.Pump(componentPalette);
        if schemaChanged or schemaAuthored
           or componentAuthoring.handled {
            componentSchema = componentAuthoring.schema;
            RefreshComponentPalette();
            if componentAuthoring.message != "" {
                detailLabel.SetText(componentAuthoring.message);
            }
        }
        if componentPalette.TakeEditFieldRequested() {
            EditSelectedComponentField();
        }
        if componentPalette.TakeApplyRequested() {
            return ApplySelectedComponent(
                componentPalette.SelectedComponent());
        }
        return false;
    }

    /// @brief Update material fields without rebuilding hierarchy/node identity.
    hide func RefreshMaterialFields(node: SceneNode) {
        if materialInspector == null { return; }
        var primary = SelectedNode();
        if primary == null and node != null { primary = node; }
        var material: Material3D = null;
        if primary != null { material = primary.Material; }
        materialInspector.RefreshSelection(
            SelectedMaterialNodes(),
            primary,
            MaterialUsageCount(material),
            scene != null);
    }

    /// @brief Keep material actions truthful for selection and sharing state.
    hide func UpdateMaterialControls(editorEnabled: Boolean) {
        if materialInspector == null { return; }
        var node = SelectedNode();
        var material: Material3D = null;
        if node != null { material = node.Material; }
        materialInspector.UpdateSelectionControls(
            editorEnabled,
            SelectedMaterialNodes(),
            MaterialUsageCount(material));
    }

    /// @brief Return normalized live material owners for current selection.
    hide func SelectedMaterialNodes() -> List[SceneNode] {
        var nodes: List[SceneNode] = [];
        var normalized = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        var index = 0;
        while index < normalized.count() {
            nodes.add(flatNodes.get(normalized.get(index)));
            index = index + 1;
        }
        return nodes;
    }

    /// @brief Count selected-scene nodes sharing one material identity.
    hide func MaterialUsageCount(material: Material3D) -> Integer {
        if material == null { return 0; }
        var count = 0;
        var index = 0;
        while index < flatNodes.count() {
            if flatNodes.get(index).Material == material { count = count + 1; }
            index = index + 1;
        }
        return count;
    }

    /// @brief Count node-attached lights represented by the bounded editor tree.
    hide func AuthoredLightCount() -> Integer {
        var count = 0;
        var index = 0;
        while index < flatNodes.count() {
            if flatNodes.get(index).Light != null { count = count + 1; }
            index = index + 1;
        }
        return count;
    }

    /// @brief Return a non-empty node name for status messages.
    hide func NodeDisplayName(node: SceneNode) -> String {
        if node == null { return "node"; }
        var name = Str.Trim(node.Name);
        if name == "" { return "unnamed node"; }
        return name;
    }

    hide func SelectedNode() -> SceneNode {
        if selectedIndex < 0 or selectedIndex >= flatNodes.count() { return null; }
        return flatNodes.get(selectedIndex);
    }

    hide func SelectIndex(index: Integer) {
        if index < 0 or index >= flatNodes.count() {
            selectedIndex = -1;
            selectedIndices = [];
        } else {
            selectedIndex = index;
            selectedIndices = scene_selection.Single(
                index, flatNodes.count());
        }
        RevealHierarchyTreeSelection();
        RefreshSelectedFields();
        SetEditorControlsEnabled(scene != null);
        renderDirty = true;
    }

    /// @brief Select validated hierarchy rows with one explicit primary node.
    expose func SelectSceneNodes(indices: List[Integer],
                                 primary: Integer) -> Boolean {
        selectedIndices = scene_selection.Normalize(
            indices, flatNodes.count(), primary);
        selectedIndex = primary;
        if selectedIndex < 0 or selectedIndex >= flatNodes.count() {
            selectedIndex = -1;
            if selectedIndices.count() > 0 {
                selectedIndex = selectedIndices.get(0);
            }
        }
        RevealHierarchyTreeSelection();
        RefreshSelectedFields();
        SetEditorControlsEnabled(scene != null);
        renderDirty = true;
        CaptureWorkspaceState();
        return selectedIndices.count() > 0;
    }

    /// @brief Reveal and focus the hierarchy Find field without editing VSCN.
    /// @return True when a loaded scene owns a usable search field.
    expose func FocusHierarchySearch() -> Boolean {
        if scene == null or hierarchySearchInput == null { return false; }
        if compactLayout {
            compactInspectorShown = true;
        } else {
            inspectorRequestedVisible = true;
        }
        ApplyInspectorLayout();
        if inspectorScroll != null {
            inspectorScroll.ScrollTo(hierarchySearchInput);
        }
        hierarchySearchInput.Focus();
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Select and reveal one bounded node-name hierarchy match.
    /// @param query Case-insensitive node-name fragment.
    /// @param direction Negative for previous; zero or positive for next.
    /// @return True when a matching represented row was selected.
    expose func FindHierarchy(query: String,
                              direction: Integer) -> Boolean {
        if scene == null or hierarchySearchInput == null { return false; }
        var normalized = scene_hierarchy_search.Normalize(query);
        var resetCursor = normalized != hierarchySearchQuery;
        if hierarchySearchInput.Text != query {
            hierarchySearchInput.SetText(query);
        }
        RefreshHierarchySearch(resetCursor);
        return NavigateHierarchySearch(direction);
    }

    /// @brief Rebuild match indices from represented bounded rows only.
    hide func RefreshHierarchySearch(resetCursor: Boolean) {
        if hierarchySearchInput == null { return; }
        hierarchySearchQuery = scene_hierarchy_search.Normalize(
            hierarchySearchInput.Text);
        hierarchySearchMatches = [];
        if scene != null and hierarchySearchQuery != "" {
            var index = 0;
            while index < flatNodes.count()
                  and index < hierarchyTreeNodes.count() {
                if hierarchyTreeNodes.get(index) != null
                   and scene_hierarchy_search.MatchesNormalized(
                       hierarchySearchQuery,
                       flatNodes.get(index).Name,
                       "") {
                    hierarchySearchMatches.add(index);
                }
                index = index + 1;
            }
        }

        hierarchySearchCursor = -1;
        if resetCursor == false {
            var match = 0;
            while match < hierarchySearchMatches.count() {
                if hierarchySearchMatches.get(match) == selectedIndex {
                    hierarchySearchCursor = match;
                    break;
                }
                match = match + 1;
            }
        }
        UpdateHierarchySearchControls();
    }

    /// @brief Apply one previous/next hierarchy jump without scene mutation.
    hide func NavigateHierarchySearch(direction: Integer) -> Boolean {
        hierarchySearchCursor = scene_hierarchy_search.NextCursor(
            hierarchySearchMatches.count(),
            hierarchySearchCursor,
            direction);
        if hierarchySearchCursor < 0
           or hierarchySearchCursor >= hierarchySearchMatches.count() {
            UpdateHierarchySearchControls();
            return false;
        }
        var target = hierarchySearchMatches.get(hierarchySearchCursor);
        var selection = scene_selection.Single(
            target, flatNodes.count());
        var selected = SelectSceneNodes(selection, target);
        UpdateHierarchySearchControls();
        return selected;
    }

    /// @brief Pump search text and navigation controls without VSCN history.
    hide func PumpHierarchySearchControls() {
        if hierarchySearchInput == null { return; }
        var query = scene_hierarchy_search.Normalize(
            hierarchySearchInput.Text);
        if query != hierarchySearchQuery {
            RefreshHierarchySearch(true);
        }
        var direction = 0;
        var requested = false;
        if hierarchySearchPreviousButton.WasClicked() {
            direction = -1;
            requested = true;
        }
        if hierarchySearchNextButton.WasClicked()
           or hierarchySearchInput.WasSubmitted() {
            direction = 1;
            requested = true;
        }
        if requested { NavigateHierarchySearch(direction); }
    }

    /// @brief Reflect query, match cursor, and safety bounds in compact UI.
    hide func UpdateHierarchySearchControls() {
        if hierarchySearchInput == null { return; }
        var available = scene != null;
        hierarchySearchInput.SetEnabled(available);
        var canNavigate =
            available and hierarchySearchMatches.count() > 0;
        hierarchySearchPreviousButton.SetEnabled(canNavigate);
        hierarchySearchNextButton.SetEnabled(canNavigate);

        var suffix = "";
        if hierarchyClipped {
            suffix = " within the bounded visible hierarchy";
        }
        if hierarchySearchQuery == "" {
            hierarchySearchStatus.SetText(
                "Find by node name" + suffix);
        } else if hierarchySearchMatches.count() == 0 {
            hierarchySearchStatus.SetText(
                "No matching nodes" + suffix);
        } else if hierarchySearchCursor < 0 {
            hierarchySearchStatus.SetText(
                hierarchySearchMatches.count()
                + " matching node(s)" + suffix
                + "; press Enter to jump");
        } else {
            hierarchySearchStatus.SetText(
                "Match " + (hierarchySearchCursor + 1)
                + " of " + hierarchySearchMatches.count()
                + suffix);
        }
    }

    /// @brief Return whether at least one valid hierarchy node is selected.
    expose func HasSceneNodeSelection() -> Boolean {
        var normalized = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        return scene != null and normalized.count() > 0;
    }

    /// @brief Return whether Select All has a hierarchy target.
    expose func CanSelectAllSceneNodes() -> Boolean {
        return scene != null and flatNodes.count() > 0;
    }

    /// @brief Return whether the text clipboard may contain pasteable data.
    /// @details Explicit paste performs typed envelope and VSCN validation;
    ///          per-frame menu state only asks the cheap native HasText query.
    expose func CanPasteSceneNodes() -> Boolean {
        return scene != null and GUI.ClipboardText.HasText();
    }

    /// @brief Select every editable hierarchy row without changing history.
    expose func SelectAllSceneNodes() -> Boolean {
        if CanSelectAllSceneNodes() == false { return false; }
        var all: List[Integer] = [];
        var index = 0;
        while index < flatNodes.count() {
            all.add(index);
            index = index + 1;
        }
        var primary = selectedIndex;
        if primary < 0 or primary >= flatNodes.count() { primary = 0; }
        if SelectSceneNodes(all, primary) == false { return false; }
        toolbarStatus.SetText(
            "Selected all " + selectedIndices.count() + " scene nodes");
        detailLabel.SetText("");
        return true;
    }

    /// @brief Copy selected hierarchy identities with canonical VSCN content.
    expose func CopySelectedNodes() -> Boolean {
        if scene == null or currentSerialized == "" { return false; }
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return false; }
        if selectedIndex < 0
           or scene_selection.Contains(selectedIndices, selectedIndex) == false {
            selectedIndex = selectedIndices.get(0);
        }
        var encoded = scene_clipboard.Encode(
            "3d", selectedIndices, selectedIndex, currentSerialized);
        if encoded == "" {
            toolbarStatus.SetText("Scene nodes not copied");
            detailLabel.SetText(
                "The selected hierarchy exceeds Studio's scene clipboard limit.");
            return false;
        }
        GUI.ClipboardText.SetText(encoded);
        toolbarStatus.SetText(
            "Copied " + selectedIndices.count() + " scene node(s)");
        detailLabel.SetText("");
        return true;
    }

    /// @brief Copy and remove selected hierarchy roots as one undoable edit.
    expose func CutSelectedNodes() -> Boolean {
        var count = selectedIndices.count();
        if CopySelectedNodes() == false { return false; }
        if DeleteSelectedNodes() == false {
            detailLabel.SetText(
                "The nodes were copied, but Studio could not remove them.");
            return false;
        }
        toolbarStatus.SetText("Cut " + count + " scene node(s)");
        return true;
    }

    /// @brief Paste selected VSCN subtrees as siblings of the primary node.
    /// @details A source graph is instantiated from the clipboard's canonical
    ///          VSCN. Selected descendants remain attached to selected roots,
    ///          and any attachment/serialization failure restores the complete
    ///          destination document and its prior selection.
    expose func PasteSceneNodesFromClipboard() -> Boolean {
        if scene == null or currentDoc == null { return false; }
        var payload = scene_clipboard.Decode(GUI.ClipboardText.GetText());
        if payload.valid == false {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(payload.error);
            return false;
        }
        if payload.kind != "3d" {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard contains 2D objects. Paste them into a 2D scene.");
            return false;
        }

        var sourceGraph = LoadGraphFromContent(payload.content);
        var sourceNodes = FlattenGraph(sourceGraph);
        if sourceGraph == null
           or sourceGraph.NodeCount - 1 != sourceNodes.count()
           or sourceNodes.count() > MAX_EDITOR_NODES {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard contains invalid, incomplete, or oversized VSCN data.");
            return false;
        }
        var sourceSelection = scene_selection.Normalize(
            payload.indices, sourceNodes.count(), payload.primary);
        if sourceSelection.count() != payload.indices.count()
           or payload.primary < 0
           or payload.primary >= sourceNodes.count() {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard node identities no longer match its VSCN data.");
            return false;
        }
        var sourceRoots = TopLevelIndicesFor(
            sourceNodes, sourceSelection, payload.primary);
        if sourceRoots.count() == 0 {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText("Clipboard contains no pasteable hierarchy roots.");
            return false;
        }

        var previousSelection = selectedIndices;
        var previousPrimary = selectedIndex;
        var selectionNodes: List[SceneNode] = [];
        var index = 0;
        while index < sourceSelection.count() {
            selectionNodes.add(
                sourceNodes.get(sourceSelection.get(index)));
            index = index + 1;
        }
        var primaryNode = sourceNodes.get(payload.primary);
        var destinationParent = scene.Root;
        if selectedIndex >= 0 and selectedIndex < flatNodes.count()
           and flatNodes.get(selectedIndex).Parent != null {
            destinationParent = flatNodes.get(selectedIndex).Parent;
        }

        index = 0;
        while index < sourceRoots.count() {
            var rootIndex = sourceRoots.get(index);
            var rootNode = sourceNodes.get(rootIndex);
            var sourceParent = rootNode.Parent;
            if sourceParent == null {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "Clipboard hierarchy had no valid parent.");
                return false;
            }
            sourceParent.RemoveChild(rootNode);
            rootNode.Name = UniqueDuplicateNodeName(rootNode);
            var position = rootNode.Position;
            rootNode.SetPosition(
                position.X + 1.0, position.Y, position.Z);
            if destinationParent.TryAddChild(rootNode) == false {
                RollBackGroupEdit(
                    previousSelection, previousPrimary,
                    "Studio could not attach every pasted subtree. "
                    + "The document was restored.");
                return false;
            }
            index = index + 1;
        }
        if scene.NodeCount - 1 > MAX_EDITOR_NODES {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Pasting this hierarchy would exceed Studio's "
                + MAX_EDITOR_NODES + "-node editing limit.");
            return false;
        }

        // Resolve selection identities before serialization. The canonical
        // VSCN is reloaded below so the active edit graph is independent from
        // the temporary clipboard graph and its retained shared resources.
        var destinationNodes = FlattenGraph(scene);
        var pastedIndices: List[Integer] = [];
        index = 0;
        while index < selectionNodes.count() {
            var pastedIndex = FindNodeIndex(
                destinationNodes, selectionNodes.get(index));
            if pastedIndex >= 0 { pastedIndices.add(pastedIndex); }
            index = index + 1;
        }
        var pastedPrimary = FindNodeIndex(
            destinationNodes, primaryNode);
        if pastedPrimary < 0 and pastedIndices.count() > 0 {
            pastedPrimary = pastedIndices.get(0);
        }
        if pastedIndices.count() != selectionNodes.count()
           or pastedPrimary < 0 {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not retain the pasted hierarchy selection.");
            return false;
        }

        var message = "Pasted " + sourceRoots.count()
            + " hierarchy root(s)";
        if CommitScene(message) == false {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The pasted hierarchy could not be committed.");
            return false;
        }
        var acceptedDoc = currentDoc;
        if acceptedDoc == null {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "The pasted hierarchy lost its destination document.");
            return false;
        }
        LoadDocumentModel(acceptedDoc, true);
        if scene == null {
            RollBackGroupEdit(
                previousSelection, previousPrimary,
                "Studio could not reload the accepted pasted hierarchy.");
            return false;
        }
        SelectSceneNodes(pastedIndices, pastedPrimary);
        detailLabel.SetText("");
        return pastedIndices.count() > 0;
    }

    /// @brief Expand every retained ancestor and scroll the primary into view.
    hide func RevealHierarchyTreeSelection() {
        if hierarchyTree == null { return; }
        if selectedIndex >= 0 and selectedIndex < flatNodes.count() {
            var parent = flatNodes.get(selectedIndex).Parent;
            var steps = 0;
            while parent != null and steps <= flatNodes.count() {
                if scene != null and parent == scene.Root { break; }
                var parentIndex = FindNodeIndex(flatNodes, parent);
                if parentIndex < 0
                   or parentIndex >= hierarchyTreeNodes.count() {
                    break;
                }
                hierarchyTree.Expand(
                    hierarchyTreeNodes.get(parentIndex));
                parent = parent.Parent;
                steps = steps + 1;
            }
        }
        RestoreHierarchyTreeSelection();
        if selectedIndex >= 0
           and selectedIndex < hierarchyTreeNodes.count()
           and hierarchyTreeNodes.get(selectedIndex) != null {
            hierarchyTree.ScrollTo(
                hierarchyTreeNodes.get(selectedIndex));
        }
    }

    /// @brief Restore all retained hierarchy rows while keeping one primary.
    hide func RestoreHierarchyTreeSelection() {
        if hierarchyTree == null { return; }
        hierarchyTree.Select(null);
        var index = 0;
        while index < selectedIndices.count() {
            var selected = selectedIndices.get(index);
            if selected != selectedIndex
               and selected >= 0
               and selected < hierarchyTreeNodes.count() {
                hierarchyTree.Select(hierarchyTreeNodes.get(selected));
            }
            index = index + 1;
        }
        if selectedIndex >= 0
           and selectedIndex < hierarchyTreeNodes.count() {
            hierarchyTree.Select(hierarchyTreeNodes.get(selectedIndex));
        }
    }

    /// @brief Resolve the current dropdown row to its flattened target identity.
    hide func SelectedParentTargetIndex() -> Integer {
        if parentDropdown == null
           or parentDropdown.Selected < 0
           or parentDropdown.Selected >= parentTargetIndices.count() {
            return PARENT_TARGET_MIXED;
        }
        return parentTargetIndices.get(parentDropdown.Selected);
    }

    /// @brief Select one currently offered parent target by stable node index.
    /// @details This mirrors a dropdown choice for command/probe callers without
    ///          synthesizing native pointer input. It never changes scene data.
    expose func SelectParentTarget(targetIndex: Integer) -> Boolean {
        if parentDropdown == null { return false; }
        var option = 0;
        while option < parentTargetIndices.count() {
            if parentTargetIndices.get(option) == targetIndex {
                parentDropdown.SetSelected(option);
                UpdateParentControlAvailability();
                return true;
            }
            option = option + 1;
        }
        return false;
    }

    /// @brief Resolve -1/root or one current flattened hierarchy target.
    hide func ParentTargetNode(targetIndex: Integer) -> SceneNode {
        if scene == null { return null; }
        if targetIndex == -1 { return scene.Root; }
        if targetIndex >= 0 and targetIndex < flatNodes.count() {
            return flatNodes.get(targetIndex);
        }
        return null;
    }

    /// @brief Rebuild cycle-safe parent choices from stable live node handles.
    hide func RefreshParentTargets() {
        if parentDropdown == null or reparentButton == null { return; }
        parentDropdown.Clear();
        parentTargetIndices = [];
        if scene == null or selectedIndices.count() == 0 {
            parentDropdown.SetPlaceholder("Select a node");
            parentDropdown.SetEnabled(false);
            reparentButton.SetEnabled(false);
            preserveWorldReparentCheck.SetEnabled(false);
            reparentButton.SetText("Reparent");
            return;
        }

        var roots = TopLevelSelectedNodes();
        if roots.count() == 0 {
            parentDropdown.SetPlaceholder("Select a node");
            parentDropdown.SetEnabled(false);
            reparentButton.SetEnabled(false);
            preserveWorldReparentCheck.SetEnabled(false);
            return;
        }
        var commonParent = scene_hierarchy_3d.CommonParent(roots);
        var mixedParents = commonParent == null and roots.count() > 1;
        var selectedOption = -1;
        if mixedParents {
            parentDropdown.AddItem("Multiple parents — choose target");
            parentTargetIndices.add(PARENT_TARGET_MIXED);
            selectedOption = 0;
        }

        if scene_hierarchy_3d.TargetAllowed(scene.Root, roots)
           and ParentTargetFits(-1, roots) {
            var option = parentDropdown.AddItem("Scene root");
            parentTargetIndices.add(-1);
            if mixedParents == false
               and (commonParent == scene.Root or commonParent == null) {
                selectedOption = option;
            }
        }

        var candidateIndex = 0;
        while candidateIndex < flatNodes.count() {
            var candidate = flatNodes.get(candidateIndex);
            if scene_hierarchy_3d.TargetAllowed(candidate, roots)
               and ParentTargetFits(candidateIndex, roots) {
                var prefix = "";
                var depth = flatDepths.get(candidateIndex);
                var indent = 0;
                while indent < depth and indent < 16 {
                    prefix = prefix + "  ";
                    indent = indent + 1;
                }
                var option = parentDropdown.AddItem(
                    prefix + NodeDisplayName(candidate));
                parentTargetIndices.add(candidateIndex);
                if mixedParents == false and commonParent == candidate {
                    selectedOption = option;
                }
            }
            candidateIndex = candidateIndex + 1;
        }

        if selectedOption < 0 and parentTargetIndices.count() > 0 {
            selectedOption = 0;
        }
        if selectedOption >= 0 { parentDropdown.SetSelected(selectedOption); }
        parentDropdown.SetPlaceholder("Choose parent");
        UpdateParentControlAvailability();
    }

    /// @brief Enable Reparent only for a valid, changed, depth-safe target.
    hide func UpdateParentControlAvailability() {
        if parentDropdown == null or reparentButton == null { return; }
        var roots = TopLevelSelectedNodes();
        var targetIndex = SelectedParentTargetIndex();
        var target = ParentTargetNode(targetIndex);
        var available = roots.count() > 0
            and target != null
            and scene_hierarchy_3d.TargetAllowed(target, roots)
            and ParentTargetFits(targetIndex, roots)
            and scene_hierarchy_3d.AllAlreadyParented(roots, target) == false;
        parentDropdown.SetEnabled(roots.count() > 0
                                  and parentTargetIndices.count() > 0);
        preserveWorldReparentCheck.SetEnabled(roots.count() > 0);
        reparentButton.SetEnabled(available);
        reparentButton.SetText("Reparent");
        if roots.count() > 1 {
            reparentButton.SetText("Reparent (" + roots.count() + ")");
        }
        var transformMode = "local transforms stay unchanged";
        if preserveWorldReparentCheck.IsChecked() {
            transformMode =
                "world transforms stay unchanged; lossy conversions are rejected";
        }
        reparentButton.SetTooltip(
            "Move " + roots.count() + " selected hierarchy root(s) beneath "
            + "the chosen parent; " + transformMode);
    }

    /// @brief Enable ordering only for a movable contiguous sibling block.
    hide func UpdateSiblingControlAvailability() {
        if moveSiblingEarlierButton == null
           or moveSiblingLaterButton == null {
            return;
        }
        var block = SelectedSiblingBlock();
        var canMoveEarlier = false;
        var canMoveLater = false;
        if block.count() > 0 {
            var parent = block.get(0).Parent;
            var first = DirectChildIndex(parent, block.get(0));
            if first >= 0 {
                canMoveEarlier = first > 0;
                canMoveLater =
                    first + block.count() < parent.ChildCount;
            }
        }
        moveSiblingEarlierButton.SetEnabled(canMoveEarlier);
        moveSiblingLaterButton.SetEnabled(canMoveLater);
        var count = block.count();
        moveSiblingEarlierButton.SetTooltip(
            "Move " + count
            + " contiguous sibling node(s) one position earlier");
        moveSiblingLaterButton.SetTooltip(
            "Move " + count
            + " contiguous sibling node(s) one position later");
    }

    hide func RefreshSelectedFields() {
        var node = SelectedNode();
        RefreshParentTargets();
        UpdateSiblingControlAvailability();
        RefreshComponentPalette();
        if node == null {
            nameInput.SetText("");
            visibleCheck.SetIndeterminate(false);
            visibleCheck.SetChecked(false);
            visibleRevision = visibleCheck.GetRevision();
            positionX.SetValue(0.0);
            positionY.SetValue(0.0);
            positionZ.SetValue(0.0);
            rotationX.SetValue(0.0);
            rotationY.SetValue(0.0);
            rotationZ.SetValue(0.0);
            scaleX.SetValue(1.0);
            scaleY.SetValue(1.0);
            scaleZ.SetValue(1.0);
            selectionInfo.SetText("No node selected");
            RefreshMetadataFields(null);
            RefreshLightFields(null);
            RefreshMaterialFields(null);
            return;
        }
        if selectedIndices.count() > 1 {
            nameInput.SetText("");
            nameInput.SetPlaceholder(
                selectedIndices.count() + " nodes selected");
            var allVisible = true;
            var allHidden = true;
            var visibilityIndex = 0;
            while visibilityIndex < selectedIndices.count() {
                if flatNodes.get(
                       selectedIndices.get(visibilityIndex)).Visible {
                    allHidden = false;
                } else {
                    allVisible = false;
                }
                visibilityIndex = visibilityIndex + 1;
            }
            if allVisible {
                visibleCheck.SetChecked(true);
            } else if allHidden {
                visibleCheck.SetChecked(false);
            } else {
                visibleCheck.SetIndeterminate(true);
            }
            visibleCheck.SetTooltip(
                "Set visibility for all "
                + selectedIndices.count() + " selected nodes");
            visibleRevision = visibleCheck.GetRevision();
            positionX.SetValue(0.0);
            positionY.SetValue(0.0);
            positionZ.SetValue(0.0);
            rotationX.SetValue(0.0);
            rotationY.SetValue(0.0);
            rotationZ.SetValue(0.0);
            scaleX.SetValue(1.0);
            scaleY.SetValue(1.0);
            scaleZ.SetValue(1.0);
            selectionInfo.SetText(
                selectedIndices.count() + " nodes selected  |  primary "
                + NodeDisplayName(node)
                + "  |  inspector adds position/rotation and multiplies "
                + "scale for the group");
            RefreshMetadataFields(node);
            RefreshLightFields(node);
            RefreshMaterialFields(null);
            return;
        }
        nameInput.SetPlaceholder("Node name");
        nameInput.SetText(node.Name);
        visibleCheck.SetChecked(node.Visible);
        visibleCheck.SetTooltip("Set this node's visibility");
        visibleRevision = visibleCheck.GetRevision();
        var position = node.Position;
        positionX.SetValue(position.X);
        positionY.SetValue(position.Y);
        positionZ.SetValue(position.Z);
        var rotation = node.Rotation;
        var euler = QuaternionToEulerDegrees(rotation);
        rotationX.SetValue(euler.X);
        rotationY.SetValue(euler.Y);
        rotationZ.SetValue(euler.Z);
        var scale = node.Scale;
        scaleX.SetValue(scale.X);
        scaleY.SetValue(scale.Y);
        scaleZ.SetValue(scale.Z);
        var kind = "empty";
        if node.Mesh != null { kind = "mesh"; }
        var materialState = "no material";
        if node.Material != null { materialState = "material"; }
        var lightState = "no light";
        if node.Light != null {
            lightState =
                scene_light_3d.TypeName(node.Light.Type) + " light";
        }
        selectionInfo.SetText(
            kind + " node  |  children " + node.ChildCount
            + "  |  " + lightState
            + "  |  " + materialState + "  |  local transform");
        RefreshMetadataFields(node);
        RefreshLightFields(node);
        RefreshMaterialFields(node);
    }

    hide func QuaternionToEulerDegrees(rotation: Quat) -> Vec3 {
        if rotation == null { return Vec3.New(0.0, 0.0, 0.0); }
        var x = rotation.X;
        var y = rotation.Y;
        var z = rotation.Z;
        var w = rotation.W;
        var pitch = Math.Atan2(
            2.0 * (w * x + y * z),
            1.0 - 2.0 * (x * x + y * y));
        var yaw = Math.Asin(Math.Clamp(
            2.0 * (w * y - z * x), -1.0, 1.0));
        var roll = Math.Atan2(
            2.0 * (w * z + x * y),
            1.0 - 2.0 * (y * y + z * z));
        return Vec3.New(
            pitch * RAD_TO_DEG,
            yaw * RAD_TO_DEG,
            roll * RAD_TO_DEG);
    }

    hide func RefreshHierarchy(preferred: SceneNode) {
        CaptureHierarchyExpansion();
        flatNodes = [];
        flatDepths = [];
        flatPaths = [];
        hierarchyTreeNodes = [];
        hierarchyTree.Clear();
        hierarchyTree.PruneRetiredNodes();
        hierarchyClipped = false;
        hierarchyPreferredNode = preferred;
        if scene != null {
            var sceneRoot = scene.Root;
            var child = 0;
            while child < sceneRoot.ChildCount
                  and flatNodes.count() < MAX_EDITOR_NODES {
                AppendHierarchy(
                    sceneRoot.GetChild(child), 0, "" + child, null);
                child = child + 1;
            }
            if child < sceneRoot.ChildCount { hierarchyClipped = true; }
            hierarchySceneRoot = sceneRoot;
        } else {
            hierarchySceneRoot = null;
        }
        hierarchyDocument = currentDoc;

        var i = 0;
        var preferredIndex = -1;
        while i < flatNodes.count() {
            var node = flatNodes.get(i);
            if preferred != null and node == preferred { preferredIndex = i; }
            i = i + 1;
        }
        if preferredIndex >= 0 {
            selectedIndex = preferredIndex;
            selectedIndices = scene_selection.Single(
                preferredIndex, flatNodes.count());
        } else if selectedIndex >= flatNodes.count() {
            selectedIndex = -1;
            selectedIndices = [];
        } else {
            selectedIndices = scene_selection.Normalize(
                selectedIndices, flatNodes.count(), selectedIndex);
            if selectedIndex < 0 and selectedIndices.count() > 0 {
                selectedIndex = selectedIndices.get(0);
            }
        }
        RevealHierarchyTreeSelection();
        RefreshHierarchySearch(false);
        hierarchyPreferredNode = null;
        hierarchyExpandedNodes = [];
        hierarchyExpandedPaths = [];
        RefreshSelectedFields();
        SetEditorControlsEnabled(scene != null);
        renderDirty = true;
    }

    /// @brief Snapshot expanded identities before rebuilding retained rows.
    /// @details Live graph refreshes match node identity, while canonical
    ///          reloads fall back to structural paths. First presentation
    ///          expands the complete bounded hierarchy for discoverability.
    hide func CaptureHierarchyExpansion() {
        hierarchyExpandedNodes = [];
        hierarchyExpandedPaths = [];
        var sameDocument =
            currentDoc != null and hierarchyDocument == currentDoc;
        hierarchyPreserveExpansionByIdentity =
            sameDocument and scene != null and hierarchySceneRoot != null
            and hierarchySceneRoot == scene.Root;
        hierarchyExpandByDefault =
            hierarchyTreeNodes.count() == 0 or sameDocument == false;
        if sameDocument == false { return; }
        var index = 0;
        while index < hierarchyTreeNodes.count()
              and index < flatNodes.count()
              and index < flatPaths.count() {
            var treeNode = hierarchyTreeNodes.get(index);
            if treeNode != null
               and GUI.TreeView.Node.IsExpanded(treeNode) {
                hierarchyExpandedNodes.add(flatNodes.get(index));
                hierarchyExpandedPaths.add(flatPaths.get(index));
            }
            index = index + 1;
        }
    }

    /// @brief Return whether one node is the candidate or its ancestor.
    hide func HierarchyContains(node: SceneNode,
                                candidate: SceneNode) -> Boolean {
        if node == null or candidate == null { return false; }
        var current = candidate;
        while current != null {
            if current == node { return true; }
            current = current.Parent;
        }
        return false;
    }

    hide func ExpandedPathContains(path: String) -> Boolean {
        var index = 0;
        while index < hierarchyExpandedPaths.count() {
            if hierarchyExpandedPaths.get(index) == path { return true; }
            index = index + 1;
        }
        return false;
    }

    /// @brief Decide expansion without confusing reordered live nodes by path.
    hide func ShouldExpandHierarchyNode(node: SceneNode,
                                        path: String) -> Boolean {
        if node == null or node.ChildCount == 0 { return false; }
        if hierarchyPreferredNode != null
           and HierarchyContains(node, hierarchyPreferredNode) {
            return true;
        }
        if hierarchyExpandByDefault { return true; }
        if hierarchyPreserveExpansionByIdentity {
            return FindNodeIndex(hierarchyExpandedNodes, node) >= 0;
        }
        return ExpandedPathContains(path);
    }

    /// @brief Append one true retained parent/child row and its bounded subtree.
    hide func AppendHierarchy(node: SceneNode,
                              depth: Integer,
                              path: String,
                              parentTreeNode: Any) {
        if node == null { return; }
        if flatNodes.count() >= MAX_EDITOR_NODES
           or depth > MAX_HIERARCHY_DEPTH {
            hierarchyClipped = true;
            return;
        }
        var visibleMarker = "○ ";
        if node.Visible { visibleMarker = "● "; }
        var componentMarker = "";
        if node.Mesh != null { componentMarker = " [mesh]"; }
        if node.Material != null {
            componentMarker = componentMarker + " [mat]";
        }
        if node.Light != null {
            componentMarker = componentMarker + " [light]";
        }
        var name = node.Name;
        if name == "" { name = "(unnamed)"; }
        var treeNode = hierarchyTree.AddNode(
            parentTreeNode,
            visibleMarker + name + componentMarker);
        if treeNode == null {
            hierarchyClipped = true;
            return;
        }
        GUI.TreeView.Node.SetData(treeNode, "" + flatNodes.count());
        GUI.TreeView.Node.SetStableId(treeNode, path);
        var icon = "◇";
        if node.Mesh != null { icon = "◆"; }
        else if node.Light != null { icon = "✦"; }
        GUI.TreeView.Node.SetIcon(treeNode, icon);
        flatNodes.add(node);
        flatDepths.add(depth);
        flatPaths.add(path);
        hierarchyTreeNodes.add(treeNode);
        var child = 0;
        while child < node.ChildCount
              and flatNodes.count() < MAX_EDITOR_NODES {
            AppendHierarchy(
                node.GetChild(child),
                depth + 1,
                path + "/" + child,
                treeNode);
            child = child + 1;
        }
        if child < node.ChildCount { hierarchyClipped = true; }
        if ShouldExpandHierarchyNode(node, path) {
            hierarchyTree.Expand(treeNode);
        }
    }

    hide func FrameAll() {
        if flatNodes.count() == 0 {
            viewScale = 28;
            viewTargetX = 0.0;
            viewTargetY = 0.0;
            viewTargetZ = 0.0;
            return;
        }
        var first = flatNodes.get(0).WorldPosition;
        var minimumX = first.X;
        var minimumY = first.Y;
        var minimumZ = first.Z;
        var maximumX = first.X;
        var maximumY = first.Y;
        var maximumZ = first.Z;
        var i = 0;
        while i < flatNodes.count() {
            var p = flatNodes.get(i).WorldPosition;
            if p.X < minimumX { minimumX = p.X; }
            if p.Y < minimumY { minimumY = p.Y; }
            if p.Z < minimumZ { minimumZ = p.Z; }
            if p.X > maximumX { maximumX = p.X; }
            if p.Y > maximumY { maximumY = p.Y; }
            if p.Z > maximumZ { maximumZ = p.Z; }
            i = i + 1;
        }
        viewTargetX = (minimumX + maximumX) * 0.5;
        viewTargetY = (minimumY + maximumY) * 0.5;
        viewTargetZ = (minimumZ + maximumZ) * 0.5;

        var furthest = 1.0;
        i = 0;
        while i < flatNodes.count() {
            var p = flatNodes.get(i).WorldPosition;
            var dx = p.X - viewTargetX;
            var dy = p.Y - viewTargetY;
            var dz = p.Z - viewTargetZ;
            var distance = Math.Sqrt(dx * dx + dy * dy + dz * dz);
            if distance > furthest { furthest = distance; }
            i = i + 1;
        }
        var available = renderedViewportWidth;
        if renderedViewportHeight < available {
            available = renderedViewportHeight;
        }
        viewScale = ClampInt3D(Convert.NumToInt(
            (available * 0.38) / furthest), 4, 120);
    }

    hide func FrameSelected() {
        selectedIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if selectedIndices.count() == 0 { return; }
        var first = flatNodes.get(selectedIndices.get(0)).WorldPosition;
        var minimumX = first.X;
        var minimumY = first.Y;
        var minimumZ = first.Z;
        var maximumX = first.X;
        var maximumY = first.Y;
        var maximumZ = first.Z;
        var index = 1;
        while index < selectedIndices.count() {
            var world = flatNodes.get(
                selectedIndices.get(index)).WorldPosition;
            if world.X < minimumX { minimumX = world.X; }
            if world.Y < minimumY { minimumY = world.Y; }
            if world.Z < minimumZ { minimumZ = world.Z; }
            if world.X > maximumX { maximumX = world.X; }
            if world.Y > maximumY { maximumY = world.Y; }
            if world.Z > maximumZ { maximumZ = world.Z; }
            index = index + 1;
        }
        viewTargetX = (minimumX + maximumX) * 0.5;
        viewTargetY = (minimumY + maximumY) * 0.5;
        viewTargetZ = (minimumZ + maximumZ) * 0.5;

        var furthest = 1.0;
        index = 0;
        while index < selectedIndices.count() {
            var world = flatNodes.get(
                selectedIndices.get(index)).WorldPosition;
            var dx = world.X - viewTargetX;
            var dy = world.Y - viewTargetY;
            var dz = world.Z - viewTargetZ;
            var distance = Math.Sqrt(dx * dx + dy * dy + dz * dz);
            if distance > furthest { furthest = distance; }
            index = index + 1;
        }
        var available = renderedViewportWidth;
        if renderedViewportHeight < available {
            available = renderedViewportHeight;
        }
        viewScale = ClampInt3D(Convert.NumToInt(
            (available * 0.38) / furthest), 4, 120);
        if selectedIndices.count() == 1 and viewScale < 48 {
            viewScale = 48;
        }
    }

    hide func UpdateViewportSize() {
        if viewportScroll == null { return; }
        var width = Convert.NumToInt(
            viewportScroll.GetLogicalWidth() - 2.0);
        var height = Convert.NumToInt(
            viewportScroll.GetLogicalHeight() - 2.0);
        if width <= 0 { width = DEFAULT_VIEWPORT_WIDTH; }
        if height <= 0 { height = DEFAULT_VIEWPORT_HEIGHT; }
        width = ClampInt3D(
            width, MIN_VIEWPORT_WIDTH, MAX_VIEWPORT_WIDTH);
        height = ClampInt3D(
            height, MIN_VIEWPORT_HEIGHT, MAX_VIEWPORT_HEIGHT);
        if width != renderedViewportWidth
           or height != renderedViewportHeight {
            renderedViewportWidth = width;
            renderedViewportHeight = height;
            renderDirty = true;
        }
    }

    hide func Project(x: Number, y: Number, z: Number) -> ProjectedPoint {
        var yaw = viewYawDegrees * DEG_TO_RAD;
        var pitch = viewPitchDegrees * DEG_TO_RAD;
        var cosYaw = Math.Cos(yaw);
        var sinYaw = Math.Sin(yaw);
        var cosPitch = Math.Cos(pitch);
        var sinPitch = Math.Sin(pitch);
        var relativeX = x - viewTargetX;
        var relativeY = y - viewTargetY;
        var relativeZ = z - viewTargetZ;
        var rotatedX = relativeX * cosYaw - relativeZ * sinYaw;
        var rotatedZ = relativeX * sinYaw + relativeZ * cosYaw;
        var rotatedY = relativeY * cosPitch - rotatedZ * sinPitch;
        var projected = new ProjectedPoint();
        projected.x = Convert.NumToInt(
            renderedViewportWidth / 2.0 + rotatedX * viewScale);
        projected.y = Convert.NumToInt(
            renderedViewportHeight / 2.0 - rotatedY * viewScale);
        return projected;
    }

    /// @brief Return whether either side-specific Shift key is held.
    hide func ViewportShiftDown() -> Boolean {
        return Input.Keyboard.IsDown(Input.Key.LeftShift)
            or Input.Keyboard.IsDown(Input.Key.RightShift);
    }

    /// @brief Return whether the conventional Control/Command key is held.
    hide func ViewportPrimaryModifierDown() -> Boolean {
        return Input.Keyboard.IsDown(Input.Key.LeftControl)
            or Input.Keyboard.IsDown(Input.Key.RightControl)
            or Input.Keyboard.IsDown(Input.Key.LeftSuper)
            or Input.Keyboard.IsDown(Input.Key.RightSuper);
    }

    /// @brief Move the camera target in its exact screen-plane basis.
    /// @details Positive deltas move rendered content with the pointer. This
    ///          updates workspace state only and never commits VSCN content.
    expose func PanViewportByPixels(deltaX: Number,
                                    deltaY: Number) -> Boolean {
        var stationaryX = deltaX > -0.000001 and deltaX < 0.000001;
        var stationaryY = deltaY > -0.000001 and deltaY < 0.000001;
        if (stationaryX and stationaryY) or viewScale <= 0 {
            return false;
        }
        var yaw = viewYawDegrees * DEG_TO_RAD;
        var pitch = viewPitchDegrees * DEG_TO_RAD;
        var cosYaw = Math.Cos(yaw);
        var sinYaw = Math.Sin(yaw);
        var cosPitch = Math.Cos(pitch);
        var sinPitch = Math.Sin(pitch);
        var rightAmount = (0.0 - deltaX) / viewScale;
        var upAmount = deltaY / viewScale;
        viewTargetX = ClampNumber3D(
            viewTargetX
                + cosYaw * rightAmount
                - sinYaw * sinPitch * upAmount,
            -1000000.0, 1000000.0);
        viewTargetY = ClampNumber3D(
            viewTargetY + cosPitch * upAmount,
            -1000000.0, 1000000.0);
        viewTargetZ = ClampNumber3D(
            viewTargetZ
                - sinYaw * rightAmount
                - cosYaw * sinPitch * upAmount,
            -1000000.0, 1000000.0);
        renderDirty = true;
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Find the nearest bounded origin marker at one viewport point.
    hide func ViewportMarkerAt(mouseX: Integer,
                               mouseY: Integer) -> Integer {
        var best = -1;
        var bestDistance = 196;
        var index = 0;
        while index < projectedX.count()
              and index < projectedY.count()
              and index < flatNodes.count() {
            var dx = projectedX.get(index) - mouseX;
            var dy = projectedY.get(index) - mouseY;
            var distance = dx * dx + dy * dy;
            if distance < bestDistance {
                bestDistance = distance;
                best = index;
            }
            index = index + 1;
        }
        return best;
    }

    /// @brief Resolve one viewport point through visible mesh bounds then markers.
    /// @return Flattened node index, or -1 for empty viewport space.
    expose func ViewportNodeAt(mouseX: Integer,
                               mouseY: Integer) -> Integer {
        if scene == null
           or mouseX < 0 or mouseX >= renderedViewportWidth
           or mouseY < 0 or mouseY >= renderedViewportHeight {
            return -1;
        }
        if ConfigureViewportCamera() {
            var origin = viewportRenderCamera.ScreenToRayOrigin(
                mouseX, mouseY,
                renderedViewportWidth, renderedViewportHeight) as Vec3;
            var direction = viewportRenderCamera.ScreenToRay(
                mouseX, mouseY,
                renderedViewportWidth, renderedViewportHeight) as Vec3;
            var hit = scene.RaycastNodes(
                origin, direction, viewportRenderCamera.FarPlane)
                as SceneNode;
            var hitIndex = FindFlatIndex(hit);
            if hitIndex >= 0 { return hitIndex; }
        }
        return ViewportMarkerAt(mouseX, mouseY);
    }

    /// @brief Apply replace, additive, toggle, or blank viewport selection.
    /// @return True only when presentation selection state changed.
    expose func ApplyViewportSelection(nodeIndex: Integer,
                                       additive: Boolean,
                                       toggle: Boolean) -> Boolean {
        var current = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if nodeIndex < 0 or nodeIndex >= flatNodes.count() {
            if additive or toggle or current.count() == 0 {
                return false;
            }
            SelectSceneNodes([], -1);
            return true;
        }

        var next: List[Integer] = [];
        var nextPrimary = nodeIndex;
        if toggle {
            var removing = scene_selection.Contains(current, nodeIndex);
            var index = 0;
            while index < current.count() {
                var candidate = current.get(index);
                if removing == false or candidate != nodeIndex {
                    next.add(candidate);
                }
                index = index + 1;
            }
            if removing == false { next.add(nodeIndex); }
            if removing {
                if next.count() == 0 {
                    nextPrimary = -1;
                } else if selectedIndex != nodeIndex
                          and scene_selection.Contains(
                              next, selectedIndex) {
                    nextPrimary = selectedIndex;
                } else {
                    nextPrimary = next.get(next.count() - 1);
                }
            }
        } else if additive {
            next = current;
            if scene_selection.Contains(next, nodeIndex) == false {
                next.add(nodeIndex);
            }
        } else {
            next.add(nodeIndex);
        }

        var changed = nextPrimary != selectedIndex
            or next.count() != current.count();
        if changed == false {
            var compareIndex = 0;
            while compareIndex < next.count() and changed == false {
                if next.get(compareIndex) != current.get(compareIndex) {
                    changed = true;
                }
                compareIndex = compareIndex + 1;
            }
        }
        if changed == false { return false; }
        SelectSceneNodes(next, nextPrimary);
        return true;
    }

    /// @brief Recognize only two nearby clicks on the same viewport node.
    /// @details The global mouse double-click flag has no widget or position
    ///          identity, so it cannot safely distinguish toolbar clicks.
    hide func RegisterViewportClick(nodeIndex: Integer,
                                    mouseX: Integer,
                                    mouseY: Integer) -> Boolean {
        var now = Zanna.Time.Clock.NowMs();
        var elapsed = now - lastViewportClickMs;
        var dx = mouseX - lastViewportClickX;
        var dy = mouseY - lastViewportClickY;
        var isDouble = nodeIndex >= 0
            and nodeIndex == lastViewportClickNode
            and elapsed >= 0
            and elapsed <= VIEWPORT_DOUBLE_CLICK_MS
            and dx * dx + dy * dy
                <= VIEWPORT_DOUBLE_CLICK_RADIUS_SQUARED;
        lastViewportClickNode = nodeIndex;
        lastViewportClickX = mouseX;
        lastViewportClickY = mouseY;
        lastViewportClickMs = now;
        return isDouble;
    }

    /// @brief Pump viewport selection, orbit/pan, zoom, and transform gizmos.
    /// @return True only when a complete gizmo drag committed document content.
    hide func PumpViewportNavigation() -> Boolean {
        if gizmoDragAxis != GIZMO_AXIS_NONE {
            if Input.Keyboard.WasPressed(Input.Key.Escape) {
                CancelGizmoDrag();
                return false;
            }
            if !Input.Mouse.IsDown(Input.Mouse.ButtonLeft) {
                return FinishGizmoDrag();
            }
            ApplyGizmoMouseDelta();
            return false;
        }
        PumpGizmoShortcuts();
        if viewportImage == null or viewportImage.IsHovered() == false {
            if gizmoHoverAxis != GIZMO_AXIS_NONE {
                gizmoHoverAxis = GIZMO_AXIS_NONE;
                renderDirty = true;
            }
            return false;
        }
        var wheel = Input.Mouse.WheelYFloat();
        if wheel > 0.0 {
            viewScale = ClampInt3D(viewScale + 4, 4, 120);
            renderDirty = true;
        } else if wheel < 0.0 {
            viewScale = ClampInt3D(viewScale - 4, 4, 120);
            renderDirty = true;
        }
        if Input.Mouse.WasPressed(Input.Mouse.ButtonMiddle)
           or Input.Mouse.WasPressed(Input.Mouse.ButtonRight) {
            FocusActiveGizmoButton();
        }
        if Input.Mouse.IsDown(Input.Mouse.ButtonMiddle)
           or Input.Mouse.IsDown(Input.Mouse.ButtonRight) {
            var deltaX = Convert.NumToInt(
                PhysicalPointerToUi(Input.Mouse.DeltaX()));
            var deltaY = Convert.NumToInt(
                PhysicalPointerToUi(Input.Mouse.DeltaY()));
            if deltaX != 0 or deltaY != 0 {
                if ViewportShiftDown() {
                    PanViewportByPixels(deltaX, deltaY);
                } else {
                    viewYawDegrees = NormalizeYawDegrees(
                        viewYawDegrees + deltaX);
                    viewPitchDegrees = ClampInt3D(
                        viewPitchDegrees - deltaY, -80, 80);
                    renderDirty = true;
                }
            }
            return false;
        }
        var mouseX = Convert.NumToInt(
            PhysicalPointerToUi(Input.Mouse.X())
            - viewportImage.GetScreenX());
        var mouseY = Convert.NumToInt(
            PhysicalPointerToUi(Input.Mouse.Y())
            - viewportImage.GetScreenY());
        var hoveredAxis = GizmoHandleAtViewportPoint(mouseX, mouseY);
        if hoveredAxis != gizmoHoverAxis {
            gizmoHoverAxis = hoveredAxis;
            renderDirty = true;
        }
        if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
            FocusActiveGizmoButton();
        }
        if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft)
           and hoveredAxis != GIZMO_AXIS_NONE {
            BeginGizmoDrag(hoveredAxis);
            return false;
        }
        if Input.Mouse.WasClicked(Input.Mouse.ButtonLeft) == false {
            return false;
        }
        var best = ViewportNodeAt(mouseX, mouseY);
        var doubleClick = RegisterViewportClick(best, mouseX, mouseY);
        ApplyViewportSelection(
            best,
            ViewportShiftDown(),
            ViewportPrimaryModifierDown());
        if best >= 0
           and doubleClick
           and scene_selection.Contains(selectedIndices, best) {
            FrameSelected();
            renderDirty = true;
        }
        return false;
    }

    /// @brief Apply conventional transform shortcuts only while viewport owns focus.
    hide func PumpGizmoShortcuts() {
        if GizmoControlsOwnFocus() == false {
            return;
        }
        if Input.Keyboard.WasPressed(Input.Key.W) {
            SetGizmoMode(GIZMO_MODE_MOVE);
        } else if Input.Keyboard.WasPressed(Input.Key.E) {
            SetGizmoMode(GIZMO_MODE_ROTATE);
        } else if Input.Keyboard.WasPressed(Input.Key.R) {
            SetGizmoMode(GIZMO_MODE_SCALE);
        }
    }

    /// @brief Use the active focusable tool button as the viewport key proxy.
    hide func FocusActiveGizmoButton() {
        if gizmoMode == GIZMO_MODE_ROTATE {
            rotateToolButton.Focus();
        } else if gizmoMode == GIZMO_MODE_SCALE {
            scaleToolButton.Focus();
        } else {
            moveToolButton.Focus();
        }
    }

    /// @brief Return whether W/E/R belong to this scene viewport this frame.
    hide func GizmoControlsOwnFocus() -> Boolean {
        return (moveToolButton != null and moveToolButton.IsFocused())
            or (rotateToolButton != null and rotateToolButton.IsFocused())
            or (scaleToolButton != null and scaleToolButton.IsFocused())
            or (transformSpaceButton != null
                and transformSpaceButton.IsFocused());
    }

    /// @brief Return whether duplicate/delete keys belong to the scene surface.
    /// @details Text, numeric, color, and material inputs remain outside this
    ///          focus set even while their node stays selected.
    expose func SceneSelectionCommandsOwnFocus() -> Boolean {
        return (hierarchyTree != null and hierarchyTree.IsFocused())
            or GizmoControlsOwnFocus()
            or (duplicateNodeButton != null
                and duplicateNodeButton.IsFocused())
            or (deleteNodeButton != null and deleteNodeButton.IsFocused())
            or (frameSelectedButton != null
                and frameSelectedButton.IsFocused());
    }

    /// @brief Return the transform handle at one viewport-local coordinate.
    /// @details Exposed so display probes use the exact rounded geometry that
    ///          production input and rendering share.
    expose func GizmoHandleAtViewportPoint(mouseX: Integer,
                                           mouseY: Integer) -> Integer {
        var node = SelectedNode();
        if node == null { return GIZMO_AXIS_NONE; }
        var world = node.WorldPosition;
        var origin = Project(world.X, world.Y, world.Z);
        var xEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_X);
        var yEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_Y);
        var zEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_Z);
        if gizmoMode == GIZMO_MODE_ROTATE {
            return ClosestGizmoRotationRing(
                mouseX, mouseY, origin.x, origin.y,
                xEnd.x, xEnd.y, yEnd.x, yEnd.y, zEnd.x, zEnd.y,
                GIZMO_RING_PICK_RADIUS);
        }
        if gizmoMode == GIZMO_MODE_MOVE
           or gizmoMode == GIZMO_MODE_SCALE {
            var plane = ClosestGizmoPlane(
                mouseX, mouseY, origin.x, origin.y,
                xEnd.x, xEnd.y, yEnd.x, yEnd.y, zEnd.x, zEnd.y);
            if plane != GIZMO_AXIS_NONE { return plane; }
        }
        return ClosestGizmoAxis(
            mouseX, mouseY, origin.x, origin.y,
            xEnd.x, xEnd.y, yEnd.x, yEnd.y, zEnd.x, zEnd.y,
            GIZMO_PICK_RADIUS);
    }

    /// @brief Return the currently hovered axis or plane handle.
    expose func HoveredGizmoHandle() -> Integer {
        return gizmoHoverAxis;
    }

    /// @brief Return the active gesture amount for deterministic input probes.
    expose func GizmoDragAccumulatedAmount() -> Number {
        return gizmoDragAccumulated;
    }

    /// @brief Return the selected node's rounded projected axis endpoint.
    /// @details Display probes use this instead of duplicating camera math.
    expose func SelectedGizmoAxisEndpoint(
        axis: Integer) -> ProjectedPoint {
        if IsGizmoAxis(axis) == false {
            return new ProjectedPoint();
        }
        return GizmoAxisEndpoint(SelectedNode(), axis);
    }

    /// @brief Return one rounded point on the selected projected rotation ring.
    /// @details Probes and production drawing share this exact right-handed
    ///          ellipse parameterization instead of duplicating camera math.
    expose func SelectedGizmoRotationRingPoint(
        axis: Integer,
        degrees: Number) -> ProjectedPoint {
        return GizmoRotationRingPoint(
            SelectedNode(), axis, degrees);
    }

    /// @brief Project one angular coordinate on a node's rotation ellipse.
    hide func GizmoRotationRingPoint(node: SceneNode,
                                     axis: Integer,
                                     degrees: Number) -> ProjectedPoint {
        var point = new ProjectedPoint();
        if node == null or IsGizmoAxis(axis) == false { return point; }
        var world = node.WorldPosition;
        var origin = Project(world.X, world.Y, world.Z);
        var axisA = GizmoAxisEndpoint(node, GizmoRingAxisA(axis));
        var axisB = GizmoAxisEndpoint(node, GizmoRingAxisB(axis));
        var radians = degrees * DEG_TO_RAD;
        point.x = origin.x + Convert.NumToInt(
            (axisA.x - origin.x) * Math.Cos(radians)
            + (axisB.x - origin.x) * Math.Sin(radians));
        point.y = origin.y + Convert.NumToInt(
            (axisA.y - origin.y) * Math.Cos(radians)
            + (axisB.y - origin.y) * Math.Sin(radians));
        return point;
    }

    /// @brief Decode one viewport point against a node's projected ring basis.
    hide func GizmoRotationRingAngle(
        node: SceneNode,
        axis: Integer,
        pointerX: Number,
        pointerY: Number) -> scene_transform_3d.RingAngleResult {
        if node == null or IsGizmoAxis(axis) == false {
            return new scene_transform_3d.RingAngleResult();
        }
        var world = node.WorldPosition;
        var origin = Project(world.X, world.Y, world.Z);
        var axisA = GizmoAxisEndpoint(node, GizmoRingAxisA(axis));
        var axisB = GizmoAxisEndpoint(node, GizmoRingAxisB(axis));
        return scene_transform_3d.RotationRingAngle(
            pointerX, pointerY, origin.x, origin.y,
            axisA.x, axisA.y, axisB.x, axisB.y);
    }

    /// @brief Project one parent-aware local transform handle.
    hide func GizmoAxisEndpoint(node: SceneNode,
                                axis: Integer) -> ProjectedPoint {
        if node == null { return new ProjectedPoint(); }
        var world = node.WorldPosition;
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            var worldLength = GizmoWorldLength();
            var worldX = world.X;
            var worldY = world.Y;
            var worldZ = world.Z;
            if axis == GIZMO_AXIS_X { worldX = worldX + worldLength; }
            else if axis == GIZMO_AXIS_Y {
                worldY = worldY + worldLength;
            } else {
                worldZ = worldZ + worldLength;
            }
            return Project(worldX, worldY, worldZ);
        }
        var localLength = GizmoLocalLength(node, axis);
        var deltaX = 0.0;
        var deltaY = 0.0;
        var deltaZ = 0.0;
        if axis == GIZMO_AXIS_X { deltaX = localLength; }
        else if axis == GIZMO_AXIS_Y { deltaY = localLength; }
        else { deltaZ = localLength; }

        var parent = node.Parent;
        if parent != null {
            var parentScale = parent.WorldScale;
            deltaX = deltaX * parentScale.X;
            deltaY = deltaY * parentScale.Y;
            deltaZ = deltaZ * parentScale.Z;
            var rotation = parent.WorldRotation;
            var crossX = 2.0
                * (rotation.Y * deltaZ - rotation.Z * deltaY);
            var crossY = 2.0
                * (rotation.Z * deltaX - rotation.X * deltaZ);
            var crossZ = 2.0
                * (rotation.X * deltaY - rotation.Y * deltaX);
            var rotatedX = deltaX + rotation.W * crossX
                + rotation.Y * crossZ - rotation.Z * crossY;
            var rotatedY = deltaY + rotation.W * crossY
                + rotation.Z * crossX - rotation.X * crossZ;
            var rotatedZ = deltaZ + rotation.W * crossZ
                + rotation.X * crossY - rotation.Y * crossX;
            deltaX = rotatedX;
            deltaY = rotatedY;
            deltaZ = rotatedZ;
        }
        return Project(
            world.X + deltaX, world.Y + deltaY, world.Z + deltaZ);
    }

    /// @brief Local distance that produces a stable world-space handle length.
    hide func GizmoLocalLength(node: SceneNode,
                               axis: Integer) -> Number {
        var worldLength = GizmoWorldLength();
        if node == null or node.Parent == null { return worldLength; }
        var scale = node.Parent.WorldScale;
        var axisScale = scale.Z;
        if axis == GIZMO_AXIS_X { axisScale = scale.X; }
        else if axis == GIZMO_AXIS_Y { axisScale = scale.Y; }
        if axisScale < 0.0 { axisScale = 0.0 - axisScale; }
        if axisScale < 0.0001 { axisScale = 0.0001; }
        return worldLength / axisScale;
    }

    /// @brief World distance that keeps every absolute-axis handle pixel-stable.
    hide func GizmoWorldLength() -> Number {
        if viewScale > 0 { return GIZMO_PIXEL_LENGTH / viewScale; }
        return 1.0;
    }

    /// @brief Scene-unit amount represented by the currently displayed handle.
    hide func GizmoDragLength(node: SceneNode,
                              axis: Integer) -> Number {
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            return GizmoWorldLength();
        }
        return GizmoLocalLength(node, axis);
    }

    /// @brief Start one captured transactional transform gesture.
    hide func BeginGizmoDrag(axis: Integer) {
        var node = SelectedNode();
        if node == null
           or (IsGizmoAxis(axis) == false
               and ((gizmoMode != GIZMO_MODE_MOVE
                     and gizmoMode != GIZMO_MODE_SCALE)
                    or IsGizmoPlane(axis) == false)) {
            return;
        }
        var sourceX = 0.0;
        var sourceY = 0.0;
        var sourceZ = 0.0;
        if gizmoMode == GIZMO_MODE_ROTATE {
            var rotation = node.Rotation;
            var euler = QuaternionToEulerDegrees(rotation);
            sourceX = euler.X;
            sourceY = euler.Y;
            sourceZ = euler.Z;
        } else if gizmoMode == GIZMO_MODE_SCALE {
            var scale = node.Scale;
            sourceX = scale.X;
            sourceY = scale.Y;
            sourceZ = scale.Z;
        } else {
            var position = node.Position;
            sourceX = position.X;
            sourceY = position.Y;
            sourceZ = position.Z;
        }
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            if gizmoMode == GIZMO_MODE_ROTATE {
                sourceX = 0.0;
                sourceY = 0.0;
                sourceZ = 0.0;
            } else if gizmoMode == GIZMO_MODE_SCALE {
                var worldScale = node.WorldScale;
                sourceX = worldScale.X;
                sourceY = worldScale.Y;
                sourceZ = worldScale.Z;
            } else {
                var worldPosition = node.WorldPosition;
                sourceX = worldPosition.X;
                sourceY = worldPosition.Y;
                sourceZ = worldPosition.Z;
            }
        }
        var initialRingAngle = 0.0;
        var initialRingValid = false;
        if gizmoMode == GIZMO_MODE_ROTATE {
            var pointerX =
                PhysicalPointerToUi(Input.Mouse.X())
                - viewportImage.GetScreenX();
            var pointerY =
                PhysicalPointerToUi(Input.Mouse.Y())
                - viewportImage.GetScreenY();
            var decodedRing = GizmoRotationRingAngle(
                node, axis, pointerX, pointerY);
            if decodedRing.valid == false { return; }
            initialRingAngle = decodedRing.degrees;
            initialRingValid = true;
        }
        gizmoDragAxis = axis;
        gizmoDragChanged = false;
        gizmoDragAccumulated = 0.0;
        gizmoDragAccumulatedB = 0.0;
        gizmoDragPreviousRingAngle = initialRingAngle;
        gizmoDragRingAngleValid = initialRingValid;
        gizmoDragStartX = sourceX;
        gizmoDragStartY = sourceY;
        gizmoDragStartZ = sourceZ;
        gizmoDragIndices = scene_selection.Normalize(
            selectedIndices, flatNodes.count(), selectedIndex);
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            gizmoDragIndices =
                HierarchyOrderedSelection(gizmoDragIndices);
        }
        gizmoDragStartXs = [];
        gizmoDragStartYs = [];
        gizmoDragStartZs = [];
        gizmoDragStartPositions = [];
        gizmoDragStartRotations = [];
        gizmoDragStartScales = [];
        gizmoDragStartWorldMatrices = [];
        gizmoDragStartWorldPositions = [];
        gizmoDragStartWorldScales = [];
        var selectionIndex = 0;
        while selectionIndex < gizmoDragIndices.count() {
            var selectedNode = flatNodes.get(
                gizmoDragIndices.get(selectionIndex));
            gizmoDragStartPositions.add(selectedNode.Position);
            gizmoDragStartRotations.add(selectedNode.Rotation);
            gizmoDragStartScales.add(selectedNode.Scale);
            if gizmoTransformSpace
               == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                gizmoDragStartWorldMatrices.add(
                    selectedNode.WorldMatrix);
                gizmoDragStartWorldPositions.add(
                    selectedNode.WorldPosition);
                gizmoDragStartWorldScales.add(
                    selectedNode.WorldScale);
            }
            var startX = 0.0;
            var startY = 0.0;
            var startZ = 0.0;
            if gizmoMode == GIZMO_MODE_ROTATE {
                var selectedEuler =
                    QuaternionToEulerDegrees(selectedNode.Rotation);
                startX = selectedEuler.X;
                startY = selectedEuler.Y;
                startZ = selectedEuler.Z;
            } else if gizmoMode == GIZMO_MODE_SCALE {
                var selectedScale = selectedNode.Scale;
                startX = selectedScale.X;
                startY = selectedScale.Y;
                startZ = selectedScale.Z;
            } else {
                var selectedPosition = selectedNode.Position;
                startX = selectedPosition.X;
                startY = selectedPosition.Y;
                startZ = selectedPosition.Z;
            }
            gizmoDragStartXs.add(startX);
            gizmoDragStartYs.add(startY);
            gizmoDragStartZs.add(startZ);
            selectionIndex = selectionIndex + 1;
        }
        Input.Mouse.Capture();
        toolbarStatus.SetText(
            scene_transform_3d.ModeAction(gizmoMode)
            + " " + gizmoDragIndices.count()
            + " selected node(s) on "
            + scene_transform_3d.SpaceLabel(gizmoTransformSpace)
            + " " + GizmoHandleLabel(axis)
            + GizmoSnapStatus());
        renderDirty = true;
    }

    /// @brief Apply one frame of pointer motion from the gesture origin.
    hide func ApplyGizmoMouseDelta() {
        var node = SelectedNode();
        if node == null {
            ResetGizmoDrag(true);
            return;
        }
        var deltaX = PhysicalPointerToUi(Input.Mouse.DeltaX());
        var deltaY = PhysicalPointerToUi(Input.Mouse.DeltaY());
        if deltaX == 0 and deltaY == 0 { return; }

        var world = node.WorldPosition;
        var origin = Project(world.X, world.Y, world.Z);
        if gizmoMode == GIZMO_MODE_ROTATE
           and IsGizmoAxis(gizmoDragAxis) {
            var pointerX =
                PhysicalPointerToUi(Input.Mouse.X())
                - viewportImage.GetScreenX();
            var pointerY =
                PhysicalPointerToUi(Input.Mouse.Y())
                - viewportImage.GetScreenY();
            var decodedRing = GizmoRotationRingAngle(
                node, gizmoDragAxis, pointerX, pointerY);
            if decodedRing.valid == false {
                gizmoDragRingAngleValid = false;
                return;
            }
            if gizmoDragRingAngleValid == false {
                gizmoDragPreviousRingAngle = decodedRing.degrees;
                gizmoDragRingAngleValid = true;
                return;
            }
            var amount = scene_transform_3d.SignedAngleDelta(
                gizmoDragPreviousRingAngle, decodedRing.degrees);
            gizmoDragPreviousRingAngle = decodedRing.degrees;
            if scene_transform_3d.NearlyEqual(amount, 0.0) {
                return;
            }
            gizmoDragAccumulated = gizmoDragAccumulated + amount;

            var sourceValue = gizmoDragStartZ;
            if gizmoDragAxis == GIZMO_AXIS_X {
                sourceValue = gizmoDragStartX;
            } else if gizmoDragAxis == GIZMO_AXIS_Y {
                sourceValue = gizmoDragStartY;
            }
            var targetValue = scene_transform_3d.AxisTarget(
                GIZMO_MODE_ROTATE,
                sourceValue,
                gizmoDragAccumulated,
                gizmoSnapEnabled);
            if gizmoTransformSpace
               == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                var applied =
                    ApplyLiveWorldGizmoTarget(targetValue);
                gizmoDragChanged = applied
                    and scene_transform_3d.NearlyEqual(
                        sourceValue, targetValue) == false;
            } else {
                ApplyLiveGizmoTarget(node, targetValue);
                gizmoDragChanged =
                    scene_transform_3d.NearlyEqual(
                        sourceValue, targetValue) == false;
            }
            renderDirty = true;
            return;
        }
        if IsGizmoPlane(gizmoDragAxis) {
            var axisA = GizmoPlaneAxisA(gizmoDragAxis);
            var axisB = GizmoPlaneAxisB(gizmoDragAxis);
            var endpointA = GizmoAxisEndpoint(node, axisA);
            var endpointB = GizmoAxisEndpoint(node, axisB);
            var planeDrag = scene_transform_3d.PlanarDragAmounts(
                gizmoMode, deltaX, deltaY,
                endpointA.x - origin.x,
                endpointA.y - origin.y,
                endpointB.x - origin.x,
                endpointB.y - origin.y,
                GizmoDragLength(node, axisA),
                GizmoDragLength(node, axisB));
            if planeDrag.valid == false
               or (scene_transform_3d.NearlyEqual(
                       planeDrag.amountA, 0.0)
                   and scene_transform_3d.NearlyEqual(
                       planeDrag.amountB, 0.0)) {
                return;
            }
            gizmoDragAccumulated =
                gizmoDragAccumulated + planeDrag.amountA;
            gizmoDragAccumulatedB =
                gizmoDragAccumulatedB + planeDrag.amountB;

            var sourceA = gizmoDragStartZ;
            if axisA == GIZMO_AXIS_X { sourceA = gizmoDragStartX; }
            else if axisA == GIZMO_AXIS_Y {
                sourceA = gizmoDragStartY;
            }
            var sourceB = gizmoDragStartZ;
            if axisB == GIZMO_AXIS_X { sourceB = gizmoDragStartX; }
            else if axisB == GIZMO_AXIS_Y {
                sourceB = gizmoDragStartY;
            }
            var targetA = scene_transform_3d.AxisTarget(
                gizmoMode, sourceA, gizmoDragAccumulated,
                gizmoSnapEnabled);
            var targetB = scene_transform_3d.AxisTarget(
                gizmoMode, sourceB, gizmoDragAccumulatedB,
                gizmoSnapEnabled);
            if gizmoTransformSpace
               == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                var applied = ApplyLiveWorldGizmoPlaneTarget(
                    targetA, targetB);
                gizmoDragChanged = applied
                    and (scene_transform_3d.NearlyEqual(
                             sourceA, targetA) == false
                         or scene_transform_3d.NearlyEqual(
                                sourceB, targetB) == false);
            } else {
                ApplyLiveGizmoPlaneTarget(targetA, targetB);
                gizmoDragChanged =
                    scene_transform_3d.NearlyEqual(
                        sourceA, targetA) == false
                    or scene_transform_3d.NearlyEqual(
                           sourceB, targetB) == false;
            }
            renderDirty = true;
            return;
        }
        var endpoint = GizmoAxisEndpoint(node, gizmoDragAxis);
        var axisX = endpoint.x - origin.x;
        var axisY = endpoint.y - origin.y;
        var amount = scene_transform_3d.AxisDragAmount(
            gizmoMode, deltaX, deltaY, axisX, axisY,
            GizmoDragLength(node, gizmoDragAxis));
        if amount > -0.0000001 and amount < 0.0000001 { return; }
        gizmoDragAccumulated = gizmoDragAccumulated + amount;

        var sourceValue = gizmoDragStartZ;
        if gizmoDragAxis == GIZMO_AXIS_X { sourceValue = gizmoDragStartX; }
        else if gizmoDragAxis == GIZMO_AXIS_Y {
            sourceValue = gizmoDragStartY;
        }
        var targetValue = scene_transform_3d.AxisTarget(
            gizmoMode, sourceValue, gizmoDragAccumulated,
            gizmoSnapEnabled);
        if gizmoTransformSpace
           == scene_transform_3d.TRANSFORM_SPACE_WORLD {
            var applied = ApplyLiveWorldGizmoTarget(targetValue);
            gizmoDragChanged = applied
                and scene_transform_3d.NearlyEqual(
                    sourceValue, targetValue) == false;
        } else {
            ApplyLiveGizmoTarget(node, targetValue);
            gizmoDragChanged =
                scene_transform_3d.NearlyEqual(
                    sourceValue, targetValue) == false;
        }
        renderDirty = true;
    }

    /// @brief Commit one complete axis drag as a single undoable edit.
    hide func FinishGizmoDrag() -> Boolean {
        var changed = gizmoDragChanged;
        var node = SelectedNode();
        var completedMode = gizmoMode;
        var transformedCount = gizmoDragIndices.count();
        ResetGizmoDrag(true);
        renderDirty = true;
        if changed == false or node == null { return false; }
        if CommitScene(
               scene_transform_3d.ModeHistoryVerb(completedMode)
               + " " + transformedCount + " selected node(s)") {
            return true;
        }
        return false;
    }

    /// @brief Restore the drag origin and leave document/history untouched.
    hide func CancelGizmoDrag() {
        if gizmoDragAxis != GIZMO_AXIS_NONE {
            if gizmoTransformSpace
               == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                RestoreLocalTransforms(
                    gizmoDragIndices,
                    gizmoDragStartPositions,
                    gizmoDragStartRotations,
                    gizmoDragStartScales);
            } else {
                var selectionIndex = 0;
                while selectionIndex < gizmoDragIndices.count()
                      and selectionIndex < gizmoDragStartXs.count()
                      and selectionIndex < gizmoDragStartYs.count()
                      and selectionIndex < gizmoDragStartZs.count() {
                    var nodeIndex = gizmoDragIndices.get(selectionIndex);
                    if nodeIndex >= 0 and nodeIndex < flatNodes.count() {
                        ApplyNodeTransformValues(
                            flatNodes.get(nodeIndex),
                            gizmoMode,
                            gizmoDragStartXs.get(selectionIndex),
                            gizmoDragStartYs.get(selectionIndex),
                            gizmoDragStartZs.get(selectionIndex));
                    }
                    selectionIndex = selectionIndex + 1;
                }
            }
            var node = SelectedNode();
            if node != null {
                if gizmoTransformSpace
                   == scene_transform_3d.TRANSFORM_SPACE_WORLD {
                    RefreshSelectedFields();
                } else if gizmoMode == GIZMO_MODE_ROTATE {
                    rotationX.SetValue(gizmoDragStartX);
                    rotationY.SetValue(gizmoDragStartY);
                    rotationZ.SetValue(gizmoDragStartZ);
                } else if gizmoMode == GIZMO_MODE_SCALE {
                    scaleX.SetValue(gizmoDragStartX);
                    scaleY.SetValue(gizmoDragStartY);
                    scaleZ.SetValue(gizmoDragStartZ);
                } else {
                    positionX.SetValue(gizmoDragStartX);
                    positionY.SetValue(gizmoDragStartY);
                    positionZ.SetValue(gizmoDragStartZ);
                }
            }
        }
        ResetGizmoDrag(true);
        toolbarStatus.SetText("Transform canceled");
        renderDirty = true;
    }

    /// @brief Apply one live world-plane target from immutable gesture origins.
    /// @return True when every selected node accepted the exact transform.
    hide func ApplyLiveWorldGizmoPlaneTarget(
        targetA: Number,
        targetB: Number) -> Boolean {
        var axisA = GizmoPlaneAxisA(gizmoDragAxis);
        var axisB = GizmoPlaneAxisB(gizmoDragAxis);
        var sourceA = gizmoDragStartZ;
        if axisA == GIZMO_AXIS_X { sourceA = gizmoDragStartX; }
        else if axisA == GIZMO_AXIS_Y { sourceA = gizmoDragStartY; }
        var sourceB = gizmoDragStartZ;
        if axisB == GIZMO_AXIS_X { sourceB = gizmoDragStartX; }
        else if axisB == GIZMO_AXIS_Y { sourceB = gizmoDragStartY; }
        var deltaA = targetA - sourceA;
        var deltaB = targetB - sourceB;

        RestoreLocalTransforms(
            gizmoDragIndices,
            gizmoDragStartPositions,
            gizmoDragStartRotations,
            gizmoDragStartScales);
        var accepted = true;
        var selectionIndex = 0;
        while selectionIndex < gizmoDragIndices.count() and accepted
              and selectionIndex < gizmoDragStartWorldMatrices.count()
              and selectionIndex < gizmoDragStartWorldPositions.count()
              and selectionIndex < gizmoDragStartWorldScales.count() {
            var desired = WorldPlaneTargetMatrix(
                gizmoDragStartWorldMatrices.get(selectionIndex),
                gizmoDragStartWorldPositions.get(selectionIndex),
                gizmoDragStartWorldScales.get(selectionIndex),
                gizmoMode,
                axisA,
                axisB,
                deltaA,
                deltaB);
            var nodeIndex = gizmoDragIndices.get(selectionIndex);
            if desired == null
               or nodeIndex < 0 or nodeIndex >= flatNodes.count()
               or flatNodes.get(nodeIndex)
                      .TrySetWorldMatrix(desired) == false {
                accepted = false;
            }
            selectionIndex = selectionIndex + 1;
        }
        if accepted == false
           or selectionIndex != gizmoDragIndices.count() {
            RestoreLocalTransforms(
                gizmoDragIndices,
                gizmoDragStartPositions,
                gizmoDragStartRotations,
                gizmoDragStartScales);
            detailLabel.SetText(
                "This world-space plane drag would require a singular, "
                + "degenerate, or sheared local transform. The gesture remains "
                + "uncommitted.");
            toolbarStatus.SetText("World plane transform rejected");
            RefreshSelectedFields();
            return false;
        }
        RefreshSelectedFields();
        return true;
    }

    /// @brief Apply one local Move/Scale plane target before release history.
    hide func ApplyLiveGizmoPlaneTarget(
        targetA: Number,
        targetB: Number) {
        var axisA = GizmoPlaneAxisA(gizmoDragAxis);
        var axisB = GizmoPlaneAxisB(gizmoDragAxis);
        var sourceA = gizmoDragStartZ;
        if axisA == GIZMO_AXIS_X { sourceA = gizmoDragStartX; }
        else if axisA == GIZMO_AXIS_Y { sourceA = gizmoDragStartY; }
        var sourceB = gizmoDragStartZ;
        if axisB == GIZMO_AXIS_X { sourceB = gizmoDragStartX; }
        else if axisB == GIZMO_AXIS_Y { sourceB = gizmoDragStartY; }
        var deltaA = targetA - sourceA;
        var deltaB = targetB - sourceB;
        var deltaX = 0.0;
        var deltaY = 0.0;
        var deltaZ = 0.0;
        if axisA == GIZMO_AXIS_X { deltaX = deltaA; }
        else if axisA == GIZMO_AXIS_Y { deltaY = deltaA; }
        else { deltaZ = deltaA; }
        if axisB == GIZMO_AXIS_X { deltaX = deltaB; }
        else if axisB == GIZMO_AXIS_Y { deltaY = deltaB; }
        else { deltaZ = deltaB; }

        var selectionIndex = 0;
        while selectionIndex < gizmoDragIndices.count()
              and selectionIndex < gizmoDragStartXs.count()
              and selectionIndex < gizmoDragStartYs.count()
              and selectionIndex < gizmoDragStartZs.count() {
            var nodeIndex = gizmoDragIndices.get(selectionIndex);
            if nodeIndex >= 0 and nodeIndex < flatNodes.count() {
                var startX = gizmoDragStartXs.get(selectionIndex);
                var startY = gizmoDragStartYs.get(selectionIndex);
                var startZ = gizmoDragStartZs.get(selectionIndex);
                var targetX = startX + deltaX;
                var targetY = startY + deltaY;
                var targetZ = startZ + deltaZ;
                if gizmoMode == GIZMO_MODE_SCALE {
                    if axisA == GIZMO_AXIS_X
                       or axisB == GIZMO_AXIS_X {
                        targetX = scene_transform_3d.UsableScale(
                            targetX, startX);
                    }
                    if axisA == GIZMO_AXIS_Y
                       or axisB == GIZMO_AXIS_Y {
                        targetY = scene_transform_3d.UsableScale(
                            targetY, startY);
                    }
                    if axisA == GIZMO_AXIS_Z
                       or axisB == GIZMO_AXIS_Z {
                        targetZ = scene_transform_3d.UsableScale(
                            targetZ, startZ);
                    }
                }
                ApplyNodeTransformValues(
                    flatNodes.get(nodeIndex),
                    gizmoMode,
                    targetX,
                    targetY,
                    targetZ);
            }
            selectionIndex = selectionIndex + 1;
        }
        var primaryX = gizmoDragStartX + deltaX;
        var primaryY = gizmoDragStartY + deltaY;
        var primaryZ = gizmoDragStartZ + deltaZ;
        if gizmoMode == GIZMO_MODE_SCALE {
            if axisA == GIZMO_AXIS_X
               or axisB == GIZMO_AXIS_X {
                primaryX = scene_transform_3d.UsableScale(
                    primaryX, gizmoDragStartX);
            }
            if axisA == GIZMO_AXIS_Y
               or axisB == GIZMO_AXIS_Y {
                primaryY = scene_transform_3d.UsableScale(
                    primaryY, gizmoDragStartY);
            }
            if axisA == GIZMO_AXIS_Z
               or axisB == GIZMO_AXIS_Z {
                primaryZ = scene_transform_3d.UsableScale(
                    primaryZ, gizmoDragStartZ);
            }
            scaleX.SetValue(primaryX);
            scaleY.SetValue(primaryY);
            scaleZ.SetValue(primaryZ);
        } else {
            positionX.SetValue(primaryX);
            positionY.SetValue(primaryY);
            positionZ.SetValue(primaryZ);
        }
    }

    /// @brief Apply one live world-space target from immutable gesture origins.
    /// @return True when every selected node accepted the exact conversion.
    hide func ApplyLiveWorldGizmoTarget(targetValue: Number) -> Boolean {
        var sourceValue = gizmoDragStartZ;
        if gizmoDragAxis == GIZMO_AXIS_X {
            sourceValue = gizmoDragStartX;
        } else if gizmoDragAxis == GIZMO_AXIS_Y {
            sourceValue = gizmoDragStartY;
        }
        var delta = targetValue - sourceValue;
        RestoreLocalTransforms(
            gizmoDragIndices,
            gizmoDragStartPositions,
            gizmoDragStartRotations,
            gizmoDragStartScales);

        var accepted = true;
        var selectionIndex = 0;
        while selectionIndex < gizmoDragIndices.count() and accepted
              and selectionIndex < gizmoDragStartWorldMatrices.count()
              and selectionIndex < gizmoDragStartWorldPositions.count()
              and selectionIndex < gizmoDragStartWorldScales.count() {
            var desired = WorldAxisTargetMatrix(
                gizmoDragStartWorldMatrices.get(selectionIndex),
                gizmoDragStartWorldPositions.get(selectionIndex),
                gizmoDragStartWorldScales.get(selectionIndex),
                gizmoMode,
                gizmoDragAxis,
                delta);
            var nodeIndex = gizmoDragIndices.get(selectionIndex);
            if desired == null
               or nodeIndex < 0 or nodeIndex >= flatNodes.count()
               or flatNodes.get(nodeIndex)
                      .TrySetWorldMatrix(desired) == false {
                accepted = false;
            }
            selectionIndex = selectionIndex + 1;
        }
        if accepted == false
           or selectionIndex != gizmoDragIndices.count() {
            RestoreLocalTransforms(
                gizmoDragIndices,
                gizmoDragStartPositions,
                gizmoDragStartRotations,
                gizmoDragStartScales);
            detailLabel.SetText(
                "This world-space drag would require local shear or a "
                + "singular transform. The gesture remains uncommitted.");
            toolbarStatus.SetText("World transform rejected");
            RefreshSelectedFields();
            return false;
        }
        RefreshSelectedFields();
        return true;
    }

    /// @brief Apply one snapped target while deferring serialization to release.
    hide func ApplyLiveGizmoTarget(node: SceneNode,
                                   targetValue: Number) {
        if node == null { return; }
        var primarySource = gizmoDragStartZ;
        if gizmoDragAxis == GIZMO_AXIS_X {
            primarySource = gizmoDragStartX;
        } else if gizmoDragAxis == GIZMO_AXIS_Y {
            primarySource = gizmoDragStartY;
        }
        var delta = targetValue - primarySource;
        var selectionIndex = 0;
        while selectionIndex < gizmoDragIndices.count()
              and selectionIndex < gizmoDragStartXs.count()
              and selectionIndex < gizmoDragStartYs.count()
              and selectionIndex < gizmoDragStartZs.count() {
            var targetX = gizmoDragStartXs.get(selectionIndex);
            var targetY = gizmoDragStartYs.get(selectionIndex);
            var targetZ = gizmoDragStartZs.get(selectionIndex);
            if gizmoDragAxis == GIZMO_AXIS_X {
                targetX = targetX + delta;
            } else if gizmoDragAxis == GIZMO_AXIS_Y {
                targetY = targetY + delta;
            } else {
                targetZ = targetZ + delta;
            }
            if gizmoMode == GIZMO_MODE_SCALE {
                if gizmoDragAxis == GIZMO_AXIS_X {
                    targetX = scene_transform_3d.UsableScale(
                        targetX, gizmoDragStartXs.get(selectionIndex));
                } else if gizmoDragAxis == GIZMO_AXIS_Y {
                    targetY = scene_transform_3d.UsableScale(
                        targetY, gizmoDragStartYs.get(selectionIndex));
                } else {
                    targetZ = scene_transform_3d.UsableScale(
                        targetZ, gizmoDragStartZs.get(selectionIndex));
                }
            }
            var nodeIndex = gizmoDragIndices.get(selectionIndex);
            if nodeIndex >= 0 and nodeIndex < flatNodes.count() {
                ApplyNodeTransformValues(
                    flatNodes.get(nodeIndex),
                    gizmoMode,
                    targetX,
                    targetY,
                    targetZ);
            }
            selectionIndex = selectionIndex + 1;
        }
        var primaryX = gizmoDragStartX;
        var primaryY = gizmoDragStartY;
        var primaryZ = gizmoDragStartZ;
        if gizmoDragAxis == GIZMO_AXIS_X { primaryX = targetValue; }
        else if gizmoDragAxis == GIZMO_AXIS_Y { primaryY = targetValue; }
        else { primaryZ = targetValue; }
        if gizmoMode == GIZMO_MODE_ROTATE {
            rotationX.SetValue(primaryX);
            rotationY.SetValue(primaryY);
            rotationZ.SetValue(primaryZ);
        } else if gizmoMode == GIZMO_MODE_SCALE {
            scaleX.SetValue(primaryX);
            scaleY.SetValue(primaryY);
            scaleZ.SetValue(primaryZ);
        } else {
            positionX.SetValue(primaryX);
            positionY.SetValue(primaryY);
            positionZ.SetValue(primaryZ);
        }
    }

    /// @brief Apply three local transform components without serializing.
    hide func ApplyNodeTransformValues(node: SceneNode,
                                       transformMode: Integer,
                                       x: Number,
                                       y: Number,
                                       z: Number) {
        if node == null { return; }
        if transformMode == GIZMO_MODE_ROTATE {
            node.Rotation = Quat.FromEuler(
                x * DEG_TO_RAD,
                y * DEG_TO_RAD,
                z * DEG_TO_RAD).Normalize();
        } else if transformMode == GIZMO_MODE_SCALE {
            node.SetScale(x, y, z);
        } else {
            node.SetPosition(x, y, z);
        }
    }

    /// @brief Clear gesture-only state and release pointer capture if owned.
    hide func ResetGizmoDrag(releaseCapture: Boolean) {
        var wasDragging = gizmoDragAxis != GIZMO_AXIS_NONE;
        gizmoDragAxis = GIZMO_AXIS_NONE;
        gizmoDragChanged = false;
        gizmoDragAccumulated = 0.0;
        gizmoDragAccumulatedB = 0.0;
        gizmoDragPreviousRingAngle = 0.0;
        gizmoDragRingAngleValid = false;
        gizmoDragStartX = 0.0;
        gizmoDragStartY = 0.0;
        gizmoDragStartZ = 0.0;
        gizmoDragIndices = [];
        gizmoDragStartXs = [];
        gizmoDragStartYs = [];
        gizmoDragStartZs = [];
        gizmoDragStartPositions = [];
        gizmoDragStartRotations = [];
        gizmoDragStartScales = [];
        gizmoDragStartWorldMatrices = [];
        gizmoDragStartWorldPositions = [];
        gizmoDragStartWorldScales = [];
        if releaseCapture and wasDragging and Input.Mouse.IsCaptured() {
            Input.Mouse.Release();
        }
    }

    /// @brief Return the app's logical-to-framebuffer scale for legacy pixel APIs.
    hide func EffectiveUiScale() -> Number {
        if guiApp == null { return 1.0; }
        var scale = guiApp.GetEffectiveScale();
        if scale <= 0.0 { return 1.0; }
        return scale;
    }

    /// @brief Convert a GUI-app pointer coordinate into effective UI units.
    hide func PhysicalPointerToUi(value: Number) -> Number {
        return value / EffectiveUiScale();
    }

    /// @brief Read a legacy framebuffer scroll offset as logical UI units.
    hide func LogicalScrollY(scroll: GUI.ScrollView) -> Number {
        if scroll == null { return 0.0; }
        return scroll.GetScrollY() / EffectiveUiScale();
    }

    /// @brief Apply logical offsets through ScrollView's framebuffer-pixel API.
    hide func SetLogicalScroll(scroll: GUI.ScrollView,
                               x: Number,
                               y: Number) {
        if scroll == null { return; }
        var scale = EffectiveUiScale();
        scroll.SetScroll(x * scale, y * scale);
    }

    /// @brief Apply logical content dimensions through the legacy pixel API.
    hide func SetLogicalContentSize(scroll: GUI.ScrollView,
                                    width: Number,
                                    height: Number) {
        if scroll == null { return; }
        var scale = EffectiveUiScale();
        scroll.SetContentSize(width * scale, height * scale);
    }

    hide func GizmoAxisLabel(axis: Integer) -> String {
        if axis == GIZMO_PLANE_XY { return "XY"; }
        if axis == GIZMO_PLANE_XZ { return "XZ"; }
        if axis == GIZMO_PLANE_YZ { return "YZ"; }
        if axis == GIZMO_AXIS_X { return "X"; }
        if axis == GIZMO_AXIS_Y { return "Y"; }
        return "Z";
    }

    /// @brief Describe an axis or plane without relying on color alone.
    hide func GizmoHandleLabel(handle: Integer) -> String {
        if IsGizmoPlane(handle) {
            if gizmoMode == GIZMO_MODE_SCALE {
                return GizmoAxisLabel(handle) + " scale plane";
            }
            return GizmoAxisLabel(handle) + " move plane";
        }
        if gizmoMode == GIZMO_MODE_ROTATE {
            return GizmoAxisLabel(handle) + " rotation ring";
        }
        return GizmoAxisLabel(handle) + " axis";
    }

    hide func GizmoSnapStatus() -> String {
        if gizmoSnapEnabled == false { return ""; }
        return "  |  snap "
            + scene_transform_3d.SnapDescription(gizmoMode);
    }

    /// @brief Return camera distance, far plane, and orthographic half-height.
    /// @details Only nodes whose projected origins are near the viewport affect
    ///          the depth range. This keeps nearby geometry precise in large
    ///          worlds while retaining enough margin for visible mesh extents.
    hide func ViewportCameraRange() -> Vec3 {
        var halfHeight =
            renderedViewportHeight / (2.0 * viewScale);
        var depthMargin = halfHeight * 2.0 + 10.0;
        var maxTowardEye = 0.0;
        var minTowardEye = 0.0;
        var yaw = viewYawDegrees * DEG_TO_RAD;
        var pitch = viewPitchDegrees * DEG_TO_RAD;
        var sinYaw = Math.Sin(yaw);
        var cosYaw = Math.Cos(yaw);
        var sinPitch = Math.Sin(pitch);
        var cosPitch = Math.Cos(pitch);
        var i = 0;
        while i < flatNodes.count() {
            var world = flatNodes.get(i).WorldPosition;
            var point = Project(world.X, world.Y, world.Z);
            if point.x >= 0 - renderedViewportWidth
               and point.x <= renderedViewportWidth * 2
               and point.y >= 0 - renderedViewportHeight
               and point.y <= renderedViewportHeight * 2 {
                var dx = world.X - viewTargetX;
                var dy = world.Y - viewTargetY;
                var dz = world.Z - viewTargetZ;
                var rotatedZ = dx * sinYaw + dz * cosYaw;
                var towardEye =
                    rotatedZ * cosPitch + dy * sinPitch;
                if towardEye > maxTowardEye {
                    maxTowardEye = towardEye;
                }
                if towardEye < minTowardEye {
                    minTowardEye = towardEye;
                }
            }
            i = i + 1;
        }
        var distance = maxTowardEye + depthMargin;
        if distance < VIEWPORT_CAMERA_MIN_DISTANCE {
            distance = VIEWPORT_CAMERA_MIN_DISTANCE;
        }
        var farPlane = distance - minTowardEye + depthMargin;
        if farPlane < distance + depthMargin {
            farPlane = distance + depthMargin;
        }
        return Vec3.New(distance, farPlane, halfHeight);
    }

    /// @brief Retain one correctly sized windowless renderer and camera.
    hide func EnsureViewportRenderer() -> Boolean {
        if renderedViewportWidth <= 0 or renderedViewportHeight <= 0 {
            return false;
        }
        if viewportRenderTarget != null
           and viewportRenderCanvas != null
           and viewportRenderCamera != null
           and viewportRenderTarget.Width == renderedViewportWidth
           and viewportRenderTarget.Height == renderedViewportHeight {
            return true;
        }

        var target = RenderTarget3D.New(
            renderedViewportWidth, renderedViewportHeight);
        if target == null { return false; }
        var canvas = Canvas3D.NewOffscreen(target);
        if canvas == null { return false; }
        var aspect =
            renderedViewportWidth / (renderedViewportHeight / 1.0);
        var halfHeight =
            renderedViewportHeight / (2.0 * viewScale);
        var camera = Camera3D.NewOrtho(
            halfHeight, aspect,
            VIEWPORT_CAMERA_NEAR,
            VIEWPORT_CAMERA_MIN_DISTANCE * 4.0);
        if camera == null { return false; }
        canvas.SetDefaultLighting();

        viewportRenderTarget = target;
        viewportRenderCanvas = canvas;
        viewportRenderCamera = camera;
        return true;
    }

    /// @brief Keep the retained orthographic camera exact for draw and pick.
    hide func ConfigureViewportCamera() -> Boolean {
        if scene == null or EnsureViewportRenderer() == false {
            return false;
        }
        var cameraRange = ViewportCameraRange();
        viewportRenderCamera.OrthoSize = cameraRange.Z;
        viewportRenderCamera.NearPlane = VIEWPORT_CAMERA_NEAR;
        viewportRenderCamera.FarPlane = cameraRange.Y;
        viewportRenderCamera.Orbit(
            Vec3.New(viewTargetX, viewTargetY, viewTargetZ),
            cameraRange.X,
            viewYawDegrees,
            viewPitchDegrees);
        return true;
    }

    /// @brief Rasterize authored meshes and materials into the embedded image.
    hide func RenderAuthoredViewport() -> Boolean {
        if ConfigureViewportCamera() == false { return false; }
        viewportRenderCanvas.Wireframe =
            viewportMode == VIEWPORT_MODE_WIREFRAME;
        viewportRenderCanvas.Clear(
            VIEWPORT_CLEAR_RED,
            VIEWPORT_CLEAR_GREEN,
            VIEWPORT_CLEAR_BLUE);
        scene.Draw(viewportRenderCanvas, viewportRenderCamera);
        var rendered = viewportRenderTarget.AsPixels();
        if rendered == null { return false; }
        viewportPixels = rendered;
        return true;
    }

    /// @brief Draw authored geometry plus deterministic editor overlays.
    hide func RenderViewport() {
        renderDirty = false;
        viewYawDegrees = NormalizeYawDegrees(viewYawDegrees);
        viewPitchDegrees = ClampInt3D(viewPitchDegrees, -80, 80);
        viewScale = ClampInt3D(viewScale, 4, 120);
        viewportPixels = null;
        viewportRenderFallback = false;
        if scene != null and RenderAuthoredViewport() == false {
            viewportRenderFallback = true;
        }
        if viewportPixels == null {
            viewportPixels = Pixels.New(
                renderedViewportWidth, renderedViewportHeight);
            viewportPixels.FillColor(Color.RGB(22, 26, 34));
        }
        projectedX = [];
        projectedY = [];

        var gridColor = Color.RGB(47, 55, 67);
        var axisX = Color.RGB(170, 70, 70);
        var axisZ = Color.RGB(70, 110, 180);
        var gridCenterX = Convert.NumToInt(viewTargetX);
        var gridCenterZ = Convert.NumToInt(viewTargetZ);
        var line = -10;
        while line <= 10 {
            var worldX = gridCenterX + line;
            var worldZ = gridCenterZ + line;
            var a = Project(worldX, 0.0, gridCenterZ - 10);
            var b = Project(worldX, 0.0, gridCenterZ + 10);
            var c = Project(gridCenterX - 10, 0.0, worldZ);
            var d = Project(gridCenterX + 10, 0.0, worldZ);
            var colorA = gridColor;
            var colorB = gridColor;
            if worldX == 0 { colorA = axisZ; }
            if worldZ == 0 { colorB = axisX; }
            viewportPixels.DrawLine(a.x, a.y, b.x, b.y, colorA);
            viewportPixels.DrawLine(c.x, c.y, d.x, d.y, colorB);
            line = line + 1;
        }

        if scene == null {
            var messageY = renderedViewportHeight / 2 - 12;
            viewportPixels.DrawTextCentered(
                messageY, "Unable to display this 3D scene",
                Color.RGB(230, 115, 115));
            viewportPixels.DrawTextCentered(
                messageY + 22, "Repair the VSCN or create a new scene",
                Color.RGB(180, 188, 202));
        } else {
            var i = 0;
            while i < flatNodes.count() {
                var node = flatNodes.get(i);
                var world = node.WorldPosition;
                var point = Project(world.X, world.Y, world.Z);
                var pickPoint = point;
                if node.Light != null and node.Mesh == null {
                    var lightWorld =
                        LightWorldPosition(node, node.Light);
                    pickPoint = Project(
                        lightWorld.X, lightWorld.Y, lightWorld.Z);
                }
                projectedX.add(pickPoint.x);
                projectedY.add(pickPoint.y);

                var parent = node.Parent;
                var parentIndex = FindFlatIndex(parent);
                if parentIndex >= 0 {
                    var parentWorld = parent.WorldPosition;
                    var parentPoint = Project(
                        parentWorld.X, parentWorld.Y, parentWorld.Z);
                    viewportPixels.DrawLine(
                        parentPoint.x, parentPoint.y, point.x, point.y,
                        Color.RGB(86, 96, 112));
                }

                var markerColor = Color.RGB(150, 165, 188);
                if node.Mesh != null {
                    markerColor = Color.RGB(91, 180, 235);
                } else if node.Light != null {
                    markerColor = Color.RGB(255, 190, 74);
                }
                if node.Visible == false {
                    markerColor = Color.RGB(92, 98, 108);
                }
                if scene_selection.Contains(selectedIndices, i) {
                    markerColor = Color.RGB(104, 220, 255);
                }
                if i == selectedIndex {
                    markerColor = Color.RGB(255, 195, 78);
                    var xEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_X);
                    var yEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_Y);
                    var zEnd = GizmoAxisEndpoint(node, GIZMO_AXIS_Z);
                    var selectedXColor = axisX;
                    var selectedYColor = Color.RGB(80, 190, 105);
                    var selectedZColor = axisZ;
                    if gizmoHoverAxis == GIZMO_AXIS_X
                       or gizmoDragAxis == GIZMO_AXIS_X {
                        selectedXColor = Color.RGB(255, 105, 105);
                    }
                    if gizmoHoverAxis == GIZMO_AXIS_Y
                       or gizmoDragAxis == GIZMO_AXIS_Y {
                        selectedYColor = Color.RGB(115, 240, 140);
                    }
                    if gizmoHoverAxis == GIZMO_AXIS_Z
                       or gizmoDragAxis == GIZMO_AXIS_Z {
                        selectedZColor = Color.RGB(105, 165, 255);
                    }
                    if gizmoMode == GIZMO_MODE_ROTATE {
                        DrawGizmoRotationRing(
                            point, yEnd, zEnd, selectedXColor);
                        DrawGizmoRotationRing(
                            point, zEnd, xEnd, selectedYColor);
                        DrawGizmoRotationRing(
                            point, xEnd, yEnd, selectedZColor);
                    } else {
                        if gizmoMode == GIZMO_MODE_MOVE
                           or gizmoMode == GIZMO_MODE_SCALE {
                            var xyFill = Color.RGB(84, 78, 38);
                            var xyOutline = Color.RGB(176, 158, 68);
                            var xzFill = Color.RGB(82, 48, 72);
                            var xzOutline = Color.RGB(184, 92, 154);
                            var yzFill = Color.RGB(36, 80, 82);
                            var yzOutline = Color.RGB(72, 174, 178);
                            if gizmoHoverAxis == GIZMO_PLANE_XY
                               or gizmoDragAxis == GIZMO_PLANE_XY {
                                xyFill = Color.RGB(154, 132, 44);
                                xyOutline = Color.RGB(255, 222, 96);
                            }
                            if gizmoHoverAxis == GIZMO_PLANE_XZ
                               or gizmoDragAxis == GIZMO_PLANE_XZ {
                                xzFill = Color.RGB(148, 66, 122);
                                xzOutline = Color.RGB(255, 132, 218);
                            }
                            if gizmoHoverAxis == GIZMO_PLANE_YZ
                               or gizmoDragAxis == GIZMO_PLANE_YZ {
                                yzFill = Color.RGB(44, 142, 146);
                                yzOutline = Color.RGB(104, 238, 242);
                            }
                            var crossed =
                                gizmoMode == GIZMO_MODE_SCALE;
                            DrawGizmoPlane(
                                point, xEnd, yEnd,
                                xyFill, xyOutline, crossed);
                            DrawGizmoPlane(
                                point, xEnd, zEnd,
                                xzFill, xzOutline, crossed);
                            DrawGizmoPlane(
                                point, yEnd, zEnd,
                                yzFill, yzOutline, crossed);
                        }
                        viewportPixels.DrawLine(
                            point.x, point.y,
                            xEnd.x, xEnd.y, selectedXColor);
                        viewportPixels.DrawLine(
                            point.x, point.y,
                            yEnd.x, yEnd.y, selectedYColor);
                        viewportPixels.DrawLine(
                            point.x, point.y,
                            zEnd.x, zEnd.y, selectedZColor);
                        DrawGizmoHandle(xEnd, selectedXColor);
                        DrawGizmoHandle(yEnd, selectedYColor);
                        DrawGizmoHandle(zEnd, selectedZColor);
                    }
                }
                if node.Mesh != null {
                    viewportPixels.DrawFrame(
                        point.x - 6, point.y - 6, 13, 13, markerColor);
                } else {
                    viewportPixels.DrawDisc(point.x, point.y, 4, markerColor);
                }
                if node.Light != null {
                    DrawLightOverlay(
                        node, node.Light, i == selectedIndex);
                }
                i = i + 1;
            }
        }

        viewportImage.SetPixels(
            viewportPixels, renderedViewportWidth, renderedViewportHeight);
        viewportImage.SetSize(renderedViewportWidth, renderedViewportHeight);
        SetLogicalContentSize(
            viewportScroll,
            renderedViewportWidth, renderedViewportHeight);
        var clipped = "";
        if hierarchyClipped { clipped = "  |  hierarchy preview clipped"; }
        var count = 0;
        if scene != null { count = scene.NodeCount - 1; }
        var lightCount = AuthoredLightCount();
        var interaction = "";
        if gizmoDragAxis != GIZMO_AXIS_NONE {
            interaction = "  |  "
                + Str.ToLower(scene_transform_3d.ModeAction(gizmoMode))
                + " " + GizmoHandleLabel(gizmoDragAxis);
        } else if gizmoHoverAxis != GIZMO_AXIS_NONE {
            interaction = "  |  " + GizmoHandleLabel(gizmoHoverAxis);
        }
        var snapStatus = "";
        if gizmoSnapEnabled {
            snapStatus = " snap "
                + scene_transform_3d.SnapDescription(gizmoMode);
        }
        var renderStatus = ViewportModeLabel(viewportMode);
        if viewportRenderFallback {
            renderStatus = renderStatus + " fallback";
        }
        viewStatusLabel.SetText(
            count + " nodes  |  view " + viewYawDegrees
            + "/" + viewPitchDegrees + "  |  " + viewScale + " px/u"
            + "  |  " + lightCount + " light(s)"
            + "  |  " + renderStatus
            + "  |  " + scene_transform_3d.ModeLabel(gizmoMode)
            + snapStatus
            + clipped + interaction);
        viewportImage.SetAccessibleDescription(
            count + " scene nodes and " + lightCount
            + " authored lights in " + renderStatus
            + " mode at " + viewScale + " pixels per world unit. "
            + "Click visible meshes to select; Shift adds and Control or "
            + "Command toggles. Middle or right drag orbits; add Shift to pan.");
    }

    /// @brief Draw a mode-specific endpoint so tools are distinguishable.
    hide func DrawGizmoHandle(point: ProjectedPoint,
                              color: Integer) {
        if gizmoMode == GIZMO_MODE_SCALE {
            viewportPixels.DrawFrame(
                point.x - 4, point.y - 4, 9, 9, color);
            return;
        }
        viewportPixels.DrawDisc(point.x, point.y, 3, color);
    }

    /// @brief Resolve the authored light-local offset through node world space.
    hide func LightWorldPosition(node: SceneNode,
                                 light: Light3D) -> Vec3 {
        if node == null { return Vec3.New(0.0, 0.0, 0.0); }
        if light == null
           or scene_light_3d.HasPosition(light.Type) == false {
            return node.WorldPosition;
        }
        return Mat4.TransformPoint(node.WorldMatrix, light.Position) as Vec3;
    }

    /// @brief Resolve and normalize one light-local direction in world space.
    hide func LightWorldDirection(node: SceneNode,
                                  light: Light3D) -> Vec3 {
        if node == null or light == null {
            return Vec3.New(0.0, -1.0, 0.0);
        }
        var transformed = Mat4.TransformVector(
            node.WorldMatrix, light.Direction) as Vec3;
        if transformed == null {
            return Vec3.New(0.0, -1.0, 0.0);
        }
        var length = Math.Sqrt(
            transformed.X * transformed.X
            + transformed.Y * transformed.Y
            + transformed.Z * transformed.Z);
        if length <= 0.000001 {
            return Vec3.New(0.0, -1.0, 0.0);
        }
        return Vec3.New(
            transformed.X / length,
            transformed.Y / length,
            transformed.Z / length);
    }

    /// @brief Draw a pickable light glyph plus applicable direction and range.
    /// @details The retained overlay makes meshless lighting nodes visible
    ///          without replacing the live SceneGraph shading underneath it.
    hide func DrawLightOverlay(node: SceneNode,
                               light: Light3D,
                               selected: Boolean) {
        if node == null or light == null or viewportPixels == null { return; }
        var world = LightWorldPosition(node, light);
        var center = Project(world.X, world.Y, world.Z);
        var nodeWorld = node.WorldPosition;
        var nodePoint = Project(
            nodeWorld.X, nodeWorld.Y, nodeWorld.Z);
        var color = scene_light_3d.PackedRgb(light);
        if color == 0 { color = Color.RGB(118, 100, 54); }
        if light.IsEnabled == false {
            color = Color.RGB(106, 108, 114);
        }
        if center.x != nodePoint.x or center.y != nodePoint.y {
            viewportPixels.DrawLine(
                nodePoint.x, nodePoint.y,
                center.x, center.y,
                Color.RGB(132, 112, 66));
        }
        viewportPixels.DrawLine(
            center.x - 7, center.y,
            center.x + 7, center.y, color);
        viewportPixels.DrawLine(
            center.x, center.y - 7,
            center.x, center.y + 7, color);
        viewportPixels.DrawDisc(center.x, center.y, 4, color);
        var outline = Color.RGB(255, 220, 136);
        if selected { outline = Color.RGB(255, 195, 78); }
        viewportPixels.DrawFrame(
            center.x - 6, center.y - 6, 13, 13, outline);

        if scene_light_3d.HasDirection(light.Type) {
            var direction = LightWorldDirection(node, light);
            var endpoint = Project(
                world.X + direction.X * 1.5,
                world.Y + direction.Y * 1.5,
                world.Z + direction.Z * 1.5);
            viewportPixels.DrawLine(
                center.x, center.y,
                endpoint.x, endpoint.y, color);
            viewportPixels.DrawDisc(
                endpoint.x, endpoint.y, 2, color);
        }
        if selected and scene_light_3d.HasRange(light.Type) {
            var rangePixels = Convert.NumToInt(light.Range * viewScale);
            if rangePixels < 8 { rangePixels = 8; }
            if rangePixels > 90 { rangePixels = 90; }
            viewportPixels.DrawFrame(
                center.x - rangePixels,
                center.y - rangePixels,
                rangePixels * 2 + 1,
                rangePixels * 2 + 1,
                Color.RGB(156, 128, 62));
        }
    }

    /// @brief Interpolate one corner of a projected plane handle.
    hide func GizmoPlanePoint(origin: ProjectedPoint,
                              axisA: ProjectedPoint,
                              axisB: ProjectedPoint,
                              fractionA: Number,
                              fractionB: Number) -> ProjectedPoint {
        var point = new ProjectedPoint();
        point.x = origin.x + Convert.NumToInt(
            (axisA.x - origin.x) * fractionA
            + (axisB.x - origin.x) * fractionB);
        point.y = origin.y + Convert.NumToInt(
            (axisA.y - origin.y) * fractionA
            + (axisB.y - origin.y) * fractionB);
        return point;
    }

    /// @brief Draw the same conditioned 32-segment ellipse used for picking.
    hide func DrawGizmoRotationRing(origin: ProjectedPoint,
                                    axisA: ProjectedPoint,
                                    axisB: ProjectedPoint,
                                    color: Integer) {
        var vectorAX = axisA.x - origin.x;
        var vectorAY = axisA.y - origin.y;
        var vectorBX = axisB.x - origin.x;
        var vectorBY = axisB.y - origin.y;
        if scene_transform_3d.PlaneProjectionIsUsable(
               vectorAX, vectorAY, vectorBX, vectorBY) == false {
            return;
        }
        var previous = GizmoPlanePoint(
            origin, axisA, axisB, 1.0, 0.0);
        var segment = 1;
        while segment <= GIZMO_RING_SEGMENTS {
            var angle = segment * GIZMO_RING_STEP_RADIANS;
            var current = GizmoPlanePoint(
                origin, axisA, axisB,
                Math.Cos(angle), Math.Sin(angle));
            viewportPixels.DrawLine(
                previous.x, previous.y,
                current.x, current.y, color);
            previous = current;
            segment = segment + 1;
        }
    }

    /// @brief Draw one filled, outlined plane only when projection is stable.
    hide func DrawGizmoPlane(origin: ProjectedPoint,
                             axisA: ProjectedPoint,
                             axisB: ProjectedPoint,
                             fillColor: Integer,
                             outlineColor: Integer,
                             crossed: Boolean) {
        var vectorAX = axisA.x - origin.x;
        var vectorAY = axisA.y - origin.y;
        var vectorBX = axisB.x - origin.x;
        var vectorBY = axisB.y - origin.y;
        if scene_transform_3d.PlaneProjectionIsUsable(
               vectorAX, vectorAY, vectorBX, vectorBY) == false {
            return;
        }
        var cornerAA = GizmoPlanePoint(
            origin, axisA, axisB,
            GIZMO_PLANE_INNER_FRACTION,
            GIZMO_PLANE_INNER_FRACTION);
        var cornerBA = GizmoPlanePoint(
            origin, axisA, axisB,
            GIZMO_PLANE_OUTER_FRACTION,
            GIZMO_PLANE_INNER_FRACTION);
        var cornerBB = GizmoPlanePoint(
            origin, axisA, axisB,
            GIZMO_PLANE_OUTER_FRACTION,
            GIZMO_PLANE_OUTER_FRACTION);
        var cornerAB = GizmoPlanePoint(
            origin, axisA, axisB,
            GIZMO_PLANE_INNER_FRACTION,
            GIZMO_PLANE_OUTER_FRACTION);
        viewportPixels.DrawTriangle(
            cornerAA.x, cornerAA.y,
            cornerBA.x, cornerBA.y,
            cornerBB.x, cornerBB.y,
            fillColor);
        viewportPixels.DrawTriangle(
            cornerAA.x, cornerAA.y,
            cornerBB.x, cornerBB.y,
            cornerAB.x, cornerAB.y,
            fillColor);
        viewportPixels.DrawLine(
            cornerAA.x, cornerAA.y, cornerBA.x, cornerBA.y,
            outlineColor);
        viewportPixels.DrawLine(
            cornerBA.x, cornerBA.y, cornerBB.x, cornerBB.y,
            outlineColor);
        viewportPixels.DrawLine(
            cornerBB.x, cornerBB.y, cornerAB.x, cornerAB.y,
            outlineColor);
        viewportPixels.DrawLine(
            cornerAB.x, cornerAB.y, cornerAA.x, cornerAA.y,
            outlineColor);
        if crossed {
            viewportPixels.DrawLine(
                cornerAA.x, cornerAA.y, cornerBB.x, cornerBB.y,
                outlineColor);
            viewportPixels.DrawLine(
                cornerBA.x, cornerBA.y, cornerAB.x, cornerAB.y,
                outlineColor);
        }
    }

    hide func FindFlatIndex(node: SceneNode) -> Integer {
        if node == null { return -1; }
        var i = 0;
        while i < flatNodes.count() {
            if flatNodes.get(i) == node { return i; }
            i = i + 1;
        }
        return -1;
    }
}

/// @brief Clamp one integer without platform-specific math helpers.
func ClampInt3D(value: Integer,
                minimum: Integer,
                maximum: Integer) -> Integer {
    if value < minimum { return minimum; }
    if value > maximum { return maximum; }
    return value;
}
