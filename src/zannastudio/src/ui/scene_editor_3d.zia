        snapTransformCheck.SetTooltip(
            "Quantize the resulting transform using the current tool's step");
        snapTransformCheck.SetChecked(false);
        snapTransformRevision = snapTransformCheck.GetRevision();
        UpdateGizmoModeControls();
        orbitLeftButton = GUI.Button.New(viewToolbar, "Yaw -");
        orbitLeftButton.SetTooltip("Orbit the view left");
        orbitRightButton = GUI.Button.New(viewToolbar, "Yaw +");
        orbitRightButton.SetTooltip("Orbit the view right");
        orbitUpButton = GUI.Button.New(viewToolbar, "Pitch +");
        orbitUpButton.SetTooltip("Orbit the view upward");
        orbitDownButton = GUI.Button.New(viewToolbar, "Pitch -");
        orbitDownButton.SetTooltip("Orbit the view downward");
