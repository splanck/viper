    /// @brief Build the editor into WorkbenchShell.scene3DHost.
    expose func Setup(host: GUI.VBox, app: GUI.App) {
        guiApp = app;
        root = GUI.VBox.New();
        root.SetSpacing(0.0);
        root.SetPadding(0.0);
        root.SetFlex(1.0);
        root.SetName("scene-editor-3d");
        root.SetAccessibleName("3D scene editor");
        host.AddChild(root);

        toolbar = GUI.Flex.New();
        toolbar.SetDirection(GUI.FlexDirection.Row);
        toolbar.SetWrap(GUI.FlexWrap.Wrap);
        toolbar.SetAlign(GUI.Align.Center);
        toolbar.SetGap(4.0);
        toolbar.SetPadding(4.0);
        root.AddChild(toolbar);
        newSceneButton = GUI.Button.New(toolbar, "New");
        newSceneButton.SetTooltip("Replace this document with an empty 3D scene");
        importAssetButton = GUI.Button.New(toolbar, "Import Asset...");
        importAssetButton.SetTooltip(
            "Import VSCN, glTF, GLB, FBX, OBJ, or STL into this scene document");
        addEmptyButton = GUI.Button.New(toolbar, "+ Empty");
        addChildButton = GUI.Button.New(toolbar, "+ Child");
        addBoxButton = GUI.Button.New(toolbar, "+ Box");
        addSphereButton = GUI.Button.New(toolbar, "+ Sphere");
        addPlaneButton = GUI.Button.New(toolbar, "+ Plane");
        addLightButton = GUI.Button.New(toolbar, "+ Light");
        addLightButton.SetTooltip(
            "Create a top-level Point light node in one undoable edit");
        duplicateNodeButton = GUI.Button.New(toolbar, "Duplicate");
        duplicateNodeButton.SetTooltip(
            "Duplicate selected hierarchy roots with their complete subtrees");
        deleteNodeButton = GUI.Button.New(toolbar, "Delete");
        toolbarStatus = GUI.Label.New(toolbar, "Open or create a 3D scene");
        toolbarStatus.SetFlex(1.0);
        toolbarStatus.SetPreferredSize(180.0, 0.0);

        viewToolbar = GUI.Flex.New();
        viewToolbar.SetDirection(GUI.FlexDirection.Row);
        viewToolbar.SetWrap(GUI.FlexWrap.Wrap);
        viewToolbar.SetAlign(GUI.Align.Center);
        viewToolbar.SetGap(4.0);
        viewToolbar.SetPadding(4.0);
        root.AddChild(viewToolbar);
        GUI.Label.New(viewToolbar, "View");
        viewportModeButton = GUI.Button.New(viewToolbar, "Shaded");
        UpdateViewportModeControls();
        inspectorButton = GUI.Button.New(viewToolbar, "Hide Inspector");
        inspectorButton.SetStyle(2);
        inspectorButton.SetTooltip(
            "Hide the node inspector and give the viewport the full width");
        GUI.Label.New(viewToolbar, "Transform");
        moveToolButton = GUI.Button.New(viewToolbar, "Move");
        moveToolButton.SetTooltip(
            "Move the selected node along one axis (W in viewport)");
        rotateToolButton = GUI.Button.New(viewToolbar, "Rotate");
        rotateToolButton.SetTooltip(
            "Rotate the selected node around one axis (E in viewport)");
        scaleToolButton = GUI.Button.New(viewToolbar, "Scale");
        scaleToolButton.SetTooltip(
            "Scale the selected node along one axis (R in viewport)");
        transformSpaceButton = GUI.Button.New(viewToolbar, "Local");
