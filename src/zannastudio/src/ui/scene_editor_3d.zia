        selectionInfo = GUI.Label.New(inspector, "No node selected");
        selectionInfo.SetWordWrap(true);
        detailLabel = GUI.Label.New(inspector, "");
        detailLabel.SetWordWrap(true);
        SetEditorControlsEnabled(false);
