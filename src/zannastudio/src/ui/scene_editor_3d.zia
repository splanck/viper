        addChildButton = GUI.Button.New(toolbar, "+ Child");
        addBoxButton = GUI.Button.New(toolbar, "+ Box");
        addSphereButton = GUI.Button.New(toolbar, "+ Sphere");
        addPlaneButton = GUI.Button.New(toolbar, "+ Plane");
