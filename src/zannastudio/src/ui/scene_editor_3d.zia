            + "to reorder or reparent one undoable selection.");
        var parentRow = GUI.HBox.New();
        parentRow.SetSpacing(4.0);
        inspector.AddChild(parentRow);
        GUI.Label.New(parentRow, "Parent");
        parentDropdown = GUI.Dropdown.New(parentRow);
        parentDropdown.SetFlex(1.0);
        parentDropdown.SetAccessibleName("Selected node parent target");
        parentDropdown.SetTooltip(
            "Choose a hierarchy parent and whether to preserve the world transform");
        reparentButton = GUI.Button.New(parentRow, "Reparent");
        reparentButton.SetTooltip(
            "Move selected hierarchy roots beneath this parent as one undoable edit");
        preserveWorldReparentCheck =
            GUI.Checkbox.New(inspector, "Keep world transform");
        preserveWorldReparentCheck.SetAccessibleName(
            "Preserve world transform while reparenting");
        preserveWorldReparentCheck.SetTooltip(
            "Derive new local transforms so nodes and descendants stay in place; "
            + "reject conversions that would require shear");
        preserveWorldReparentCheck.SetChecked(true);
        var siblingOrderRow = GUI.HBox.New();
        siblingOrderRow.SetSpacing(4.0);
        inspector.AddChild(siblingOrderRow);
        GUI.Label.New(siblingOrderRow, "Sibling order");
        moveSiblingEarlierButton =
            GUI.Button.New(siblingOrderRow, "Earlier");
        moveSiblingEarlierButton.SetAccessibleName(
            "Move selected 3D scene nodes earlier");
        moveSiblingEarlierButton.SetTooltip(
            "Move one contiguous sibling selection one position earlier");
        moveSiblingLaterButton =
            GUI.Button.New(siblingOrderRow, "Later");
        moveSiblingLaterButton.SetAccessibleName(
            "Move selected 3D scene nodes later");
        moveSiblingLaterButton.SetTooltip(
            "Move one contiguous sibling selection one position later");
        var importGroup = GUI.GroupBox.New(inspector, "Project 3D imports");
        importAssetBrowser.Setup(
            importGroup,
            "Import Project 3D Asset...",
            ".vscn,.gltf,.glb,.fbx,.obj,.stl",
            "Import Asset");
        GUI.Label.New(inspector, "Name");
        nameInput = GUI.TextInput.New(inspector);
        nameInput.SetPlaceholder("Node name");
        visibleCheck = GUI.Checkbox.New(inspector, "Visible");

        GUI.Label.New(inspector, "Position");
        var positionRow = GUI.HBox.New();
        positionRow.SetSpacing(4.0);
        inspector.AddChild(positionRow);
        positionX = AddTransformSpinner(positionRow, "X", 0.0);
        positionY = AddTransformSpinner(positionRow, "Y", 0.0);
        positionZ = AddTransformSpinner(positionRow, "Z", 0.0);

        GUI.Label.New(inspector, "Rotation (degrees)");
        var rotationRow = GUI.HBox.New();
        rotationRow.SetSpacing(4.0);
        inspector.AddChild(rotationRow);
        rotationX = AddRotationSpinner(rotationRow, "X");
        rotationY = AddRotationSpinner(rotationRow, "Y");
        rotationZ = AddRotationSpinner(rotationRow, "Z");

        GUI.Label.New(inspector, "Scale");
        var scaleRow = GUI.HBox.New();
        scaleRow.SetSpacing(4.0);
        inspector.AddChild(scaleRow);
        scaleX = AddTransformSpinner(scaleRow, "X", 1.0);
        scaleY = AddTransformSpinner(scaleRow, "Y", 1.0);
        scaleZ = AddTransformSpinner(scaleRow, "Z", 1.0);
        applyTransformButton = GUI.Button.New(inspector, "Apply node properties");
        applyTransformButton.SetTooltip(
