        frameSelectedButton = GUI.Button.New(viewToolbar, "Frame selected");
        frameSelectedButton.SetTooltip(
            "Center and frame the selected node in the viewport");
        viewStatusLabel = GUI.Label.New(viewToolbar, "");
        viewStatusLabel.SetFlex(1.0);
        viewStatusLabel.SetPreferredSize(220.0, 0.0);

        bodySplit = GUI.SplitPane.New(root, 1);
        bodySplit.SetFlex(1.0);
        bodySplit.SetPosition(0.65);
        bodySplit.SetMinFirst(320.0);
        bodySplit.SetMinSecond(320.0);

        viewportScroll = GUI.ScrollView.New(bodySplit.First);
        viewportScroll.SetFlex(1.0);
        viewportImage = GUI.Image.New(viewportScroll);
        viewportImage.SetScaleMode(0);
