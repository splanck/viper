final DEFAULT_VIEWPORT_WIDTH: Integer = 800;
final DEFAULT_VIEWPORT_HEIGHT: Integer = 520;
final MIN_VIEWPORT_WIDTH: Integer = 320;
final MIN_VIEWPORT_HEIGHT: Integer = 240;
final MAX_VIEWPORT_WIDTH: Integer = 1600;
final MAX_VIEWPORT_HEIGHT: Integer = 1000;
final MAX_SCENE_BYTES: Integer = 64000000;
final MAX_TEXTURE_SOURCE_BYTES: Integer = 16000000;
final MAX_EDITOR_NODES: Integer = 1024;
final MAX_HIERARCHY_DEPTH: Integer = 256;
final MAX_3D_SCENE_HISTORY: Integer = 100;
final DEG_TO_RAD: Number = 0.017453292519943295;
final RAD_TO_DEG: Number = 57.29577951308232;
final GIZMO_PIXEL_LENGTH: Number = 36.0;
final GIZMO_PICK_RADIUS: Number = 7.0;
final GIZMO_RING_PICK_RADIUS: Number = 6.0;
final GIZMO_RING_SEGMENTS: Integer = 32;
final GIZMO_RING_STEP_RADIANS: Number = 0.19634954084936207;
final GIZMO_RING_INVALID_DISTANCE: Number = 1000000000.0;
final GIZMO_PLANE_INNER_FRACTION: Number = 0.25;
final GIZMO_PLANE_OUTER_FRACTION: Number = 0.55;
final COMPACT_SCENE_3D_WIDTH: Number = 700.0;
final VIEWPORT_CLEAR_RED: Number = 0.08627450980392157;
final VIEWPORT_CLEAR_GREEN: Number = 0.10196078431372549;
final VIEWPORT_CLEAR_BLUE: Number = 0.13333333333333333;
final VIEWPORT_CAMERA_NEAR: Number = 0.1;
final VIEWPORT_CAMERA_MIN_DISTANCE: Number = 100.0;
final VIEWPORT_DOUBLE_CLICK_MS: Integer = 400;
final VIEWPORT_DOUBLE_CLICK_RADIUS_SQUARED: Integer = 64;

final VIEWPORT_MODE_SHADED: Integer = 0;
final VIEWPORT_MODE_WIREFRAME: Integer = 1;

final GIZMO_AXIS_NONE: Integer = -1;
final GIZMO_AXIS_X: Integer = 0;
final GIZMO_AXIS_Y: Integer = 1;
final GIZMO_AXIS_Z: Integer = 2;
final GIZMO_PLANE_XY: Integer = 3;
final GIZMO_PLANE_XZ: Integer = 4;
final GIZMO_PLANE_YZ: Integer = 5;

final GIZMO_MODE_MOVE: Integer = scene_transform_3d.TRANSFORM_MOVE;
final GIZMO_MODE_ROTATE: Integer = scene_transform_3d.TRANSFORM_ROTATE;
final GIZMO_MODE_SCALE: Integer = scene_transform_3d.TRANSFORM_SCALE;

final PRIMITIVE_EMPTY: Integer = 0;
final PRIMITIVE_BOX: Integer = 1;
final PRIMITIVE_SPHERE: Integer = 2;
final PRIMITIVE_PLANE: Integer = 3;
final PARENT_TARGET_MIXED: Integer = -2;

/// @brief Return whether a handle names one single-axis transform.
func IsGizmoAxis(handle: Integer) -> Boolean {
    return handle == GIZMO_AXIS_X
        or handle == GIZMO_AXIS_Y
        or handle == GIZMO_AXIS_Z;
}

/// @brief Return whether a handle names one two-axis transform plane.
func IsGizmoPlane(handle: Integer) -> Boolean {
    return handle == GIZMO_PLANE_XY
        or handle == GIZMO_PLANE_XZ
        or handle == GIZMO_PLANE_YZ;
}

/// @brief Return the first conventional axis in one plane handle.
func GizmoPlaneAxisA(plane: Integer) -> Integer {
    if plane == GIZMO_PLANE_YZ { return GIZMO_AXIS_Y; }
    return GIZMO_AXIS_X;
}

/// @brief Return the second conventional axis in one plane handle.
func GizmoPlaneAxisB(plane: Integer) -> Integer {
    if plane == GIZMO_PLANE_XY { return GIZMO_AXIS_Y; }
    return GIZMO_AXIS_Z;
}

/// @brief Return the first oriented basis axis for one rotation ring.
/// @details The ordered pairs follow positive right-handed rotation:
///          X rotates Y toward Z, Y rotates Z toward X, Z rotates X toward Y.
func GizmoRingAxisA(axis: Integer) -> Integer {
    if axis == GIZMO_AXIS_X { return GIZMO_AXIS_Y; }
    if axis == GIZMO_AXIS_Y { return GIZMO_AXIS_Z; }
    return GIZMO_AXIS_X;
}

/// @brief Return the second oriented basis axis for one rotation ring.
func GizmoRingAxisB(axis: Integer) -> Integer {
    if axis == GIZMO_AXIS_X { return GIZMO_AXIS_Z; }
    if axis == GIZMO_AXIS_Y { return GIZMO_AXIS_X; }
    return GIZMO_AXIS_Y;
}

/// @brief Read one Cartesian component from a runtime vector.
func GizmoAxisValue(value: Vec3,
                    axis: Integer) -> Number {
    if value == null { return 0.0; }
    if axis == GIZMO_AXIS_X { return value.X; }
    if axis == GIZMO_AXIS_Y { return value.Y; }
    return value.Z;
}

/// @brief Clamp one Number used by persisted scene workspace geometry.
func ClampNumber3D(value: Number, minimum: Number, maximum: Number) -> Number {
    if value < minimum { return minimum; }
    if value > maximum { return maximum; }
    return value;
}

/// @brief Keep long orbit sessions numerically stable and easy to persist.
func NormalizeYawDegrees(value: Integer) -> Integer {
    var normalized = value;
    while normalized > 180 { normalized = normalized - 360; }
    while normalized < -180 { normalized = normalized + 360; }
    return normalized;
}

/// @brief Squared pointer distance to a finite projected line segment.
/// @details Pure geometry keeps gizmo hit testing deterministic and probeable.
expose func DistanceSquaredToSegment(pointerX: Number,
                                     pointerY: Number,
                                     startX: Number,
                                     startY: Number,
                                     endX: Number,
                                     endY: Number) -> Number {
    var segmentX = endX - startX;
    var segmentY = endY - startY;
    var lengthSquared = segmentX * segmentX + segmentY * segmentY;
    if lengthSquared <= 0.000001 {
        var pointX = pointerX - startX;
        var pointY = pointerY - startY;
        return pointX * pointX + pointY * pointY;
    }
    var projection = ((pointerX - startX) * segmentX
                      + (pointerY - startY) * segmentY)
        / lengthSquared;
    if projection < 0.0 { projection = 0.0; }
    if projection > 1.0 { projection = 1.0; }
    var nearestX = startX + projection * segmentX;
    var nearestY = startY + projection * segmentY;
    var deltaX = pointerX - nearestX;
    var deltaY = pointerY - nearestY;
    return deltaX * deltaX + deltaY * deltaY;
}

/// @brief Pick the nearest projected translation axis within a pixel radius.
expose func ClosestGizmoAxis(pointerX: Number,
                             pointerY: Number,
                             originX: Number,
                             originY: Number,
                             axisXX: Number,
                             axisXY: Number,
                             axisYX: Number,
                             axisYY: Number,
                             axisZX: Number,
                             axisZY: Number,
                             radius: Number) -> Integer {
    var threshold = radius * radius;
    var centerX = pointerX - originX;
    var centerY = pointerY - originY;
    if centerX * centerX + centerY * centerY <= threshold {
        return GIZMO_AXIS_NONE;
    }
    var bestDistance = threshold;
    var best = GIZMO_AXIS_NONE;
    var distance = DistanceSquaredToSegment(
        pointerX, pointerY, originX, originY, axisXX, axisXY);
    if distance <= bestDistance {
        bestDistance = distance;
        best = GIZMO_AXIS_X;
    }
    distance = DistanceSquaredToSegment(
        pointerX, pointerY, originX, originY, axisYX, axisYY);
    if distance < bestDistance {
        bestDistance = distance;
        best = GIZMO_AXIS_Y;
    }
    distance = DistanceSquaredToSegment(
        pointerX, pointerY, originX, originY, axisZX, axisZY);
    if distance < bestDistance {
        best = GIZMO_AXIS_Z;
    }
    return best;
}

/// @brief Return whether a pointer lies inside one projected plane handle.
func GizmoPlaneContains(pointerX: Number,
                        pointerY: Number,
                        originX: Number,
                        originY: Number,
                        axisAX: Number,
                        axisAY: Number,
                        axisBX: Number,
                        axisBY: Number) -> Boolean {
    var vectorAX = axisAX - originX;
    var vectorAY = axisAY - originY;
    var vectorBX = axisBX - originX;
    var vectorBY = axisBY - originY;
    if scene_transform_3d.PlaneProjectionIsUsable(
           vectorAX, vectorAY, vectorBX, vectorBY) == false {
        return false;
    }
    var relativeX = pointerX - originX;
    var relativeY = pointerY - originY;
    var determinant =
        vectorAX * vectorBY - vectorAY * vectorBX;
    var fractionA =
        (relativeX * vectorBY - relativeY * vectorBX) / determinant;
    var fractionB =
        (vectorAX * relativeY - vectorAY * relativeX) / determinant;
    return fractionA >= GIZMO_PLANE_INNER_FRACTION
        and fractionA <= GIZMO_PLANE_OUTER_FRACTION
        and fractionB >= GIZMO_PLANE_INNER_FRACTION
        and fractionB <= GIZMO_PLANE_OUTER_FRACTION;
}

/// @brief Squared projected area used to prefer the most face-on overlap.
func GizmoPlaneAreaSquared(originX: Number,
                           originY: Number,
                           axisAX: Number,
                           axisAY: Number,
                           axisBX: Number,
                           axisBY: Number) -> Number {
    var vectorAX = axisAX - originX;
    var vectorAY = axisAY - originY;
    var vectorBX = axisBX - originX;
    var vectorBY = axisBY - originY;
    var determinant =
        vectorAX * vectorBY - vectorAY * vectorBX;
    return determinant * determinant;
}

/// @brief Pick the most face-on projected XY, XZ, or YZ transform plane.
/// @details Axis-line picking runs only after this function so an intentional
///          click inside a visible plane cannot be stolen by its border axes.
expose func ClosestGizmoPlane(pointerX: Number,
                              pointerY: Number,
                              originX: Number,
                              originY: Number,
                              axisXX: Number,
                              axisXY: Number,
                              axisYX: Number,
                              axisYY: Number,
                              axisZX: Number,
                              axisZY: Number) -> Integer {
    var best = GIZMO_AXIS_NONE;
    var bestArea = 0.0;
    if GizmoPlaneContains(
           pointerX, pointerY, originX, originY,
           axisXX, axisXY, axisYX, axisYY) {
        best = GIZMO_PLANE_XY;
        bestArea = GizmoPlaneAreaSquared(
            originX, originY, axisXX, axisXY, axisYX, axisYY);
    }
    if GizmoPlaneContains(
           pointerX, pointerY, originX, originY,
           axisXX, axisXY, axisZX, axisZY) {
        var area = GizmoPlaneAreaSquared(
            originX, originY, axisXX, axisXY, axisZX, axisZY);
        if area > bestArea {
            best = GIZMO_PLANE_XZ;
            bestArea = area;
        }
    }
    if GizmoPlaneContains(
           pointerX, pointerY, originX, originY,
           axisYX, axisYY, axisZX, axisZY) {
        var area = GizmoPlaneAreaSquared(
            originX, originY, axisYX, axisYY, axisZX, axisZY);
        if area > bestArea {
            best = GIZMO_PLANE_YZ;
        }
    }
    return best;
}

/// @brief Squared pointer distance to a sampled projected rotation ellipse.
/// @details Sampling the same 32-segment ellipse used for drawing keeps hit
///          testing stable without assuming that the projection is circular.
func DistanceSquaredToGizmoRotationRing(
    pointerX: Number,
    pointerY: Number,
    originX: Number,
    originY: Number,
    axisAX: Number,
    axisAY: Number,
    axisBX: Number,
    axisBY: Number) -> Number {
    var vectorAX = axisAX - originX;
    var vectorAY = axisAY - originY;
    var vectorBX = axisBX - originX;
    var vectorBY = axisBY - originY;
    if scene_transform_3d.PlaneProjectionIsUsable(
           vectorAX, vectorAY, vectorBX, vectorBY) == false {
        return GIZMO_RING_INVALID_DISTANCE;
    }
    var previousX = originX + vectorAX;
    var previousY = originY + vectorAY;
    var best = GIZMO_RING_INVALID_DISTANCE;
    var segment = 1;
    while segment <= GIZMO_RING_SEGMENTS {
        var angle = segment * GIZMO_RING_STEP_RADIANS;
        var cosine = Math.Cos(angle);
        var sine = Math.Sin(angle);
        var currentX =
            originX + vectorAX * cosine + vectorBX * sine;
        var currentY =
            originY + vectorAY * cosine + vectorBY * sine;
        var distance = DistanceSquaredToSegment(
            pointerX, pointerY,
            previousX, previousY, currentX, currentY);
        if distance < best { best = distance; }
        previousX = currentX;
        previousY = currentY;
        segment = segment + 1;
    }
    return best;
}

/// @brief Pick the nearest stable projected X, Y, or Z rotation ring.
/// @details Ring planes use the right-handed basis order shared by angular
///          decoding. Exact ties remain deterministic in X/Y/Z order.
expose func ClosestGizmoRotationRing(
    pointerX: Number,
    pointerY: Number,
    originX: Number,
    originY: Number,
    axisXX: Number,
    axisXY: Number,
    axisYX: Number,
    axisYY: Number,
    axisZX: Number,
    axisZY: Number,
    radius: Number) -> Integer {
    var threshold = radius * radius;
    var bestDistance = threshold;
    var best = GIZMO_AXIS_NONE;
    var distance = DistanceSquaredToGizmoRotationRing(
        pointerX, pointerY, originX, originY,
        axisYX, axisYY, axisZX, axisZY);
    if distance <= bestDistance {
        bestDistance = distance;
        best = GIZMO_AXIS_X;
    }
    distance = DistanceSquaredToGizmoRotationRing(
        pointerX, pointerY, originX, originY,
        axisZX, axisZY, axisXX, axisXY);
    if distance < bestDistance {
        bestDistance = distance;
        best = GIZMO_AXIS_Y;
    }
    distance = DistanceSquaredToGizmoRotationRing(
        pointerX, pointerY, originX, originY,
        axisXX, axisXY, axisYX, axisYY);
    if distance < bestDistance {
        best = GIZMO_AXIS_Z;
    }
    return best;
}

/// @brief Return whether a 3D scene width needs master/detail presentation.
expose func UsesCompactLayout(width: Number) -> Boolean {
    return width > 0.0 and width <= COMPACT_SCENE_3D_WIDTH;
}

/// @brief One projected viewport coordinate.
class ProjectedPoint {
    expose Integer x;
    expose Integer y;

    expose func init() {
        x = 0;
        y = 0;
    }
}

