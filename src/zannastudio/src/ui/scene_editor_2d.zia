bind Input = Zanna.Input;
bind Convert = Zanna.Core.Convert;
bind Parse = Zanna.Core.Parse;
bind Fmt = Zanna.Text.Fmt;
bind Seq = Zanna.Collections.Seq;
bind Path = Zanna.IO.Path;
bind Str = Zanna.String;

// ============================================================================
// MODULE: scene_editor_2d
// PURPOSE: Coordinate the document-backed 2D scene surface, gestures, asset
//          intent, and one-step canonical history transactions.
//
// WHERE-THIS-FITS: SceneDocument owns serialized scene truth; tileset leaf
//          modules own bounded image decoding and palette presentation.
//
// TEACHING-NOTE: Preview pixels are disposable external state. Only an accepted
//          authored path or scene edit may change Document.content.
// ============================================================================

final MODE_SELECT: Integer = 0;
final MODE_PAINT: Integer = 1;
final MODE_ERASE: Integer = 2;
final MODE_OBJECT: Integer = 3;

final DEFAULT_SCENE_WIDTH: Integer = 32;
final DEFAULT_SCENE_HEIGHT: Integer = 18;
final DEFAULT_TILE_SIZE: Integer = 32;
final BASE_DISPLAY_CELL: Integer = 16;
final MIN_ZOOM_PERCENT: Integer = 25;
final MAX_ZOOM_PERCENT: Integer = 1600;
final MAX_RENDER_DIMENSION: Integer = 2048;
final MAX_RENDER_CELLS_PER_AXIS: Integer = 256;
final MAX_2D_SCENE_HISTORY: Integer = 100;
final MAX_INSPECTOR_PROPERTIES: Integer = 512;
final COMPACT_SCENE_2D_WIDTH: Number = 640.0;

final PROPERTY_TYPE_STRING: Integer = 0;
final PROPERTY_TYPE_INT: Integer = 1;
final PROPERTY_TYPE_FLOAT: Integer = 2;
final PROPERTY_TYPE_BOOL: Integer = 3;
final PROPERTY_TYPE_NULL: Integer = 4;

final ARRANGE_ALIGN_X: Integer = scene_layout_2d.LAYOUT_ALIGN_X;
final ARRANGE_ALIGN_Y: Integer = scene_layout_2d.LAYOUT_ALIGN_Y;
final ARRANGE_DISTRIBUTE_X: Integer =
    scene_layout_2d.LAYOUT_DISTRIBUTE_X;
final ARRANGE_DISTRIBUTE_Y: Integer =
    scene_layout_2d.LAYOUT_DISTRIBUTE_Y;

/// @brief Deterministic preview color for a nonzero tile id.
func TilePreviewColor(tile: Integer, layer: Integer) -> Integer {
    var r = 56 + (tile * 53 + layer * 19) % 168;
    var g = 56 + (tile * 97 + layer * 31) % 168;
    var b = 56 + (tile * 151 + layer * 47) % 168;
    return Color.RGB(r, g, b);
}

/// @brief Clamp one integer without depending on platform math adapters.
func ClampInt(value: Integer, minimum: Integer, maximum: Integer) -> Integer {
    if value < minimum { return minimum; }
    if value > maximum { return maximum; }
    return value;
}

/// @brief Clamp one Number used by persisted workspace geometry.
func ClampNumber2D(value: Number, minimum: Number, maximum: Number) -> Number {
    if value < minimum { return minimum; }
    if value > maximum { return maximum; }
    return value;
}

func AbsInt2D(value: Integer) -> Integer {
    if value < 0 { return 0 - value; }
    return value;
}

/// @brief Compute a bounded whole-percent zoom that fits a tile scene.
/// @details Kept pure so compact-window and tiny-scene behavior can be probed
///          without constructing a native GUI.
expose func FitZoomPercent(sceneWidth: Integer,
                           sceneHeight: Integer,
                           viewportWidth: Integer,
                           viewportHeight: Integer) -> Integer {
    if sceneWidth <= 0 or sceneHeight <= 0
       or viewportWidth <= 0 or viewportHeight <= 0 {
        return 100;
    }
    var cellX = viewportWidth / sceneWidth;
    var cellY = viewportHeight / sceneHeight;
    var cell = cellX;
    if cellY < cell { cell = cellY; }
    if cell < 1 { cell = 1; }
    return ClampInt(cell * 100 / BASE_DISPLAY_CELL,
                    MIN_ZOOM_PERCENT,
                    MAX_ZOOM_PERCENT);
}

/// @brief Return whether a 2D scene width needs master/detail presentation.
expose func UsesCompactLayout(width: Number) -> Boolean {
    return width > 0.0 and width <= COMPACT_SCENE_2D_WIDTH;
}

