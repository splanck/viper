    /// @brief Borrow Studio's multi-root project index for non-modal assets.
    expose func SetWorkspaceContext(
        nextProjectManager: project_manager.ProjectManager) {
        projectManager = nextProjectManager;
        ReloadComponentSchema();
    }

    /// @brief Reload project component templates for the active document root.
    expose func ReloadComponentSchema() {
        var rootPath = ComponentSchemaRoot();
        componentSchemaPath =
            scene_component_schema.PathForRoot(rootPath);
        if componentPalette != null and componentPalette.group != null
           and componentAuthoring != null {
            componentAuthoring.Load(
                componentSchemaPath,
                scene_component_schema.TARGET_2D_OBJECT,
                componentPalette);
            componentSchema = componentAuthoring.schema;
            RefreshComponentPalette();
        } else {
            componentSchema =
                scene_component_schema.LoadPath(componentSchemaPath);
        }
    }

    /// @brief Keep multi-root schema ownership aligned with document ownership.
    hide func EnsureComponentSchema(force: Boolean) {
        var nextPath = scene_component_schema.PathForRoot(
            ComponentSchemaRoot());
        if force or nextPath != componentSchemaPath {
            ReloadComponentSchema();
        }
    }

    /// @brief Resolve the unambiguous workspace root for the current scene.
    hide func ComponentSchemaRoot() -> String {
        if projectManager == null { return ""; }
        if currentDoc != null and currentDoc.filePath != "" {
            var owner =
                projectManager.WorkspaceRootPathForPath(currentDoc.filePath);
            if owner != "" { return owner; }
        }
        if projectManager.RootCount() == 1 {
            return projectManager.RootPathAt(0);
        }
        return "";
    }

    /// @brief Pump one active document and return true when scene JSON changed.
    expose func Pump(activeDoc: document.Document) -> Boolean {
        if activeDoc == null or activeDoc.kind != file_utils.DOC_KIND_SCENE_2D {
            return false;
        }
        if activeDoc != currentDoc or activeDoc.content != currentSerialized {
            Activate(activeDoc);
        }
        EnsureComponentSchema(false);
        if activeDoc == currentDoc and activeDoc.isModified == false
           and activeDoc.content == currentSerialized {
            cleanSerialized = currentSerialized;
        }

        RefreshResponsiveLayout();
        if inspectorButton.WasClicked() { ToggleInspectorPane(); }

        var changed = false;
        if newSceneButton.WasClicked() {
            changed = ReplaceScene(
                Convert.NumToInt(sceneWidthSpinner.Value),
                Convert.NumToInt(sceneHeightSpinner.Value),
                Convert.NumToInt(sceneTileSizeSpinner.Value));
        }
        if importButton.WasClicked() {
            changed = ImportTiled() or changed;
        }
        var projectImportPath = tiledAssetBrowser.Pump(
            projectManager, currentDoc != null);
        if projectImportPath != "" {
            changed = ImportTiledPath(projectImportPath) or changed;
        }
        var canChooseLayerAsset = scene != null
            and activeLayer >= 0 and activeLayer < scene.LayerCount();
        var projectLayerAssetPath = tilesetInspector.assetBrowser.Pump(
            projectManager, canChooseLayerAsset);
        if projectLayerAssetPath != "" {
            changed = ApplyLayerAssetPath(
                activeLayer,
                PortableLayerAssetPath(projectLayerAssetPath)) or changed;
        }
        if scene == null {
            if renderDirty { RenderScene(); }
            ApplyPendingWorkspaceScroll();
            CaptureWorkspaceState();
            return changed;
        }
        if currentDoc != null
           and currentDoc.filePath != tilesetDocumentPath {
            ReloadTilesets();
            RefreshTilesetPalette();
        }
        PollTilesetExternalChanges(250);

        UpdateCanvasViewportSize();
        if selectButton.WasClicked() { SetMode(MODE_SELECT); }
        if paintButton.WasClicked() { SetMode(MODE_PAINT); }
        if eraseButton.WasClicked() { SetMode(MODE_ERASE); }
        if rectangleButton.WasClicked() { SetMode(MODE_RECTANGLE); }
        if fillButton.WasClicked() { SetMode(MODE_FILL); }
        if pickerButton.WasClicked() { SetMode(MODE_PICKER); }
        if objectButton.WasClicked() { SetMode(MODE_OBJECT); }
        if zoomOutButton.WasClicked() {
            zoomPercent = ClampInt(zoomPercent - 25,
                                   MIN_ZOOM_PERCENT,
                                   MAX_ZOOM_PERCENT);
            renderDirty = true;
        }
        if zoomInButton.WasClicked() {
            zoomPercent = ClampInt(zoomPercent + 25,
                                   MIN_ZOOM_PERCENT,
                                   MAX_ZOOM_PERCENT);
            renderDirty = true;
        }
        if fitButton.WasClicked() {
            fitPending = false;
            if FitScene() { renderDirty = true; }
        }
        if fitPending and FitScene() {
            fitPending = false;
            renderDirty = true;
        }
        if tileSpinner.WasChanged() { RefreshTilesetPalette(); }

        changed = PumpScenePropertyControls() or changed;
        changed = PumpLayerControls() or changed;
        changed = PumpObjectControls() or changed;
        changed = PumpComponentControls() or changed;
        PumpTilesetPalette();
        changed = PumpCanvas() or changed;
        changed = PumpCanvasKeyboard() or changed;

        if renderDirty { RenderScene(); }
        ApplyPendingWorkspaceScroll();
        CaptureWorkspaceState();
        return changed;
    }

    /// @brief Parse and display one document without mutating invalid input.
    expose func Activate(doc: document.Document) {
        LoadDocumentModel(doc, false);
    }

    /// @brief Return whether a visual scene edit can be undone.
    expose func CanUndo() -> Boolean {
        return undoStack.count() > 0;
    }

    /// @brief Return whether an undone visual scene edit can be redone.
    expose func CanRedo() -> Boolean {
        return redoStack.count() > 0;
    }

    /// @brief Restore the preceding canonical scene snapshot.
    expose func Undo() -> Boolean {
        if currentDoc == null or undoStack.count() == 0 { return false; }
        var index = undoStack.count() - 1;
        var target = undoStack.get(index);
        undoStack.removeAt(index);
        PushHistory(redoStack, currentSerialized);
        currentDoc.content = target;
        currentDoc.isModified = target != cleanSerialized;
        revision = revision + 1;
        LoadDocumentModel(currentDoc, true);
        toolbarStatus.SetText("Undid 2D scene edit");
        return true;
    }

    /// @brief Reapply the next canonical scene snapshot.
    expose func Redo() -> Boolean {
        if currentDoc == null or redoStack.count() == 0 { return false; }
        var index = redoStack.count() - 1;
        var target = redoStack.get(index);
        redoStack.removeAt(index);
        PushHistory(undoStack, currentSerialized);
        currentDoc.content = target;
        currentDoc.isModified = target != cleanSerialized;
        revision = revision + 1;
        LoadDocumentModel(currentDoc, true);
        toolbarStatus.SetText("Redid 2D scene edit");
        return true;
    }

    /// @brief Parse and display one document with optional history retention.
    hide func LoadDocumentModel(doc: document.Document,
                                preserveHistory: Boolean) {
        if paintStrokeActive { CancelPaintStroke(); }
        if tileRectangleActive { CancelTileRectangle(); }
        if canvasMarqueeActive { CancelCanvasMarquee(); }
        var switchingDocument = currentDoc != doc;
        if currentDoc != null { CaptureWorkspaceState(); }
        if preserveHistory == false {
            var savedState = doc.scene2DWorkspace;
            var canRestoreHistory = switchingDocument
                and savedState != null
                and savedState.historyContent == doc.content;
            if canRestoreHistory {
                undoStack = savedState.undoStack;
                redoStack = savedState.redoStack;
                cleanSerialized = savedState.cleanSerialized;
            } else {
                undoStack = [];
                redoStack = [];
                if doc.isModified == false { cleanSerialized = doc.content; }
                else { cleanSerialized = ""; }
            }
        }
        currentDoc = doc;
        currentSerialized = doc.content;
        EnsureComponentSchema(false);
        loadError = "";
        RestoreWorkspaceState(doc);
        ResetCanvasMarquee(true);
        ResetTileRectangle(true);
        lastPaintX = -1;
        lastPaintY = -1;
        paintStrokeActive = false;
        paintStrokeChanged = false;
        paintStrokeSnapshot = "";
        objectDragActive = false;
        objectDragChanged = false;
        objectDragSnapshot = "";
        objectDragIndex = -1;

        var parsed = SceneDocument.LoadJsonResult(doc.content);
        if parsed.IsOk {
            scene = parsed.Unwrap() as SceneDocument;
            SetEditorControlsEnabled(true);
            detailLabel.SetText("");
            toolbarStatus.SetText("2D scene ready");
        } else {
            scene = null;
            loadError = parsed.UnwrapErrStr();
            SetEditorControlsEnabled(false);
            toolbarStatus.SetText("Scene needs repair");
            detailLabel.SetText("Scene could not be parsed. The original JSON "
                                + "is preserved.\n\n" + loadError);
        }
        ReloadTilesets();
        RefreshInspector();
        RefreshSceneSetupFields();
        RefreshTilesetPalette();
        renderDirty = true;
    }

    /// @brief Snapshot live canvas, inspector, and process-local history state.
    hide func CaptureWorkspaceState() {
        if currentDoc == null or currentDoc.scene2DWorkspace == null { return; }
        var state = currentDoc.scene2DWorkspace;
        state.initialized = true;
        state.mode = ClampInt(mode, MODE_SELECT, MODE_PICKER);
        state.zoomPercent = ClampInt(
            zoomPercent, MIN_ZOOM_PERCENT, MAX_ZOOM_PERCENT);
        state.activeLayer = activeLayer;
        state.selectedObject = selectedObject;
        state.selectedObjects = selectedObjects;
        state.selectedObjectProperty = selectedObjectProperty;
        state.selectedSceneProperty = selectedSceneProperty;
        state.selectedCellX = selectedCellX;
        state.selectedCellY = selectedCellY;
        var tileId = 1;
        if tileSpinner != null {
            tileId = ClampInt(
                Convert.NumToInt(tileSpinner.Value), 0, 1000000);
        }
        state.tileId = tileId;
        if bodySplit != null {
            state.splitPosition = ClampNumber2D(
                bodySplit.GetPosition(), 0.20, 0.85);
        }
        if canvasScroll != null {
            state.canvasScrollX = ClampNumber2D(
                LogicalScrollX(canvasScroll), 0.0, 1000000.0);
            state.canvasScrollY = ClampNumber2D(
                LogicalScrollY(canvasScroll), 0.0, 1000000.0);
        }
        if inspectorScroll != null {
            state.inspectorScrollY = ClampNumber2D(
                LogicalScrollY(inspectorScroll), 0.0, 1000000.0);
        }
        state.inspectorRequestedVisible = inspectorRequestedVisible;
        state.compactInspectorShown = compactInspectorShown;
        state.undoStack = undoStack;
        state.redoStack = redoStack;
        state.cleanSerialized = cleanSerialized;
        state.historyContent = currentSerialized;
    }

    /// @brief Restore a document's validated canvas and inspector workspace.
    hide func RestoreWorkspaceState(doc: document.Document) {
        var state = doc.scene2DWorkspace;
        if state == null or state.initialized == false {
            mode = MODE_SELECT;
            zoomPercent = 100;
            activeLayer = 0;
            selectedObject = -1;
            selectedObjects = [];
            selectedObjectProperty = -1;
            selectedSceneProperty = -1;
            selectedCellX = -1;
            selectedCellY = -1;
            if tileSpinner != null { tileSpinner.SetValue(1.0); }
            if bodySplit != null { bodySplit.SetPosition(0.68); }
            pendingCanvasScrollX = 0.0;
            pendingCanvasScrollY = 0.0;
            pendingInspectorScrollY = 0.0;
            inspectorRequestedVisible = true;
            compactInspectorShown = false;
            restoreScrollPending = true;
            fitPending = true;
            UpdateModeButtons();
            return;
        }

        mode = ClampInt(state.mode, MODE_SELECT, MODE_PICKER);
        zoomPercent = ClampInt(
            state.zoomPercent, MIN_ZOOM_PERCENT, MAX_ZOOM_PERCENT);
        activeLayer = ClampInt(state.activeLayer, 0, 1023);
        selectedObject = ClampInt(state.selectedObject, -1, 1000000);
        selectedObjects = state.selectedObjects;
        selectedObjectProperty = ClampInt(
            state.selectedObjectProperty, -1, MAX_INSPECTOR_PROPERTIES - 1);
        selectedSceneProperty = ClampInt(
            state.selectedSceneProperty, -1, MAX_INSPECTOR_PROPERTIES - 1);
        selectedCellX = ClampInt(
            state.selectedCellX, -1, MAX_RENDER_CELLS_PER_AXIS - 1);
        selectedCellY = ClampInt(
            state.selectedCellY, -1, MAX_RENDER_CELLS_PER_AXIS - 1);
        if tileSpinner != null {
            tileSpinner.SetValue(ClampInt(state.tileId, 0, 1000000));
        }
        if bodySplit != null {
            bodySplit.SetPosition(ClampNumber2D(
                state.splitPosition, 0.20, 0.85));
        }
        pendingCanvasScrollX = ClampNumber2D(
            state.canvasScrollX, 0.0, 1000000.0);
        pendingCanvasScrollY = ClampNumber2D(
            state.canvasScrollY, 0.0, 1000000.0);
        pendingInspectorScrollY = ClampNumber2D(
            state.inspectorScrollY, 0.0, 1000000.0);
        inspectorRequestedVisible = state.inspectorRequestedVisible;
        compactInspectorShown = state.compactInspectorShown;
        restoreScrollPending = true;
        fitPending = false;
        UpdateModeButtons();
    }

    /// @brief Toggle the inspector without making either compact pane unusable.
    expose func ToggleInspectorPane() {
        if compactLayout {
            compactInspectorShown = !compactInspectorShown;
        } else {
            inspectorRequestedVisible = !inspectorRequestedVisible;
        }
        ApplyInspectorLayout();
        CaptureWorkspaceState();
    }

    /// @brief Reconcile wrapping chrome and master/detail layout after resize.
    expose func RefreshResponsiveLayout() {
        if root == null or bodySplit == null { return; }
        var width = root.GetLogicalWidth();
        if width <= 0.0 { return; }
        var nextCompact = UsesCompactLayout(width);
        if nextCompact != compactLayout {
            compactLayout = nextCompact;
            ApplyResponsiveChrome();
            renderDirty = true;
        }
        ApplyInspectorLayout();
    }

    /// @brief Keep essential scene actions reachable when toolbar rows wrap.
    hide func ApplyResponsiveChrome() {
        if compactLayout {
            // Flex measurement cannot infer wrapped cross-axis height before
            // its parent assigns a width. Reserve both compact action rows so
            // the inspector toggle remains inside the view toolbar.
            toolbar.SetPreferredSize(0.0, 64.0);
            viewToolbar.SetPreferredSize(0.0, 64.0);
            newSceneButton.SetText("New");
            importButton.SetText("Import...");
            toolbarStatus.SetVisible(false);
            viewStatusLabel.SetVisible(false);
        } else {
            toolbar.SetPreferredSize(0.0, 0.0);
            viewToolbar.SetPreferredSize(0.0, 0.0);
            newSceneButton.SetText("New Scene");
            importButton.SetText("Import Tiled...");
            toolbarStatus.SetVisible(true);
            viewStatusLabel.SetVisible(true);
        }
        UpdateInspectorButton();
    }

    /// @brief Apply wide split or compact one-pane-at-a-time presentation.
    hide func ApplyInspectorLayout() {
        if bodySplit == null { return; }
        var desiredSide = 0;
        if compactLayout {
            desiredSide = 2;
            if compactInspectorShown { desiredSide = 1; }
        } else if !inspectorRequestedVisible {
            desiredSide = 2;
        }

        if bodySplit.GetCollapsedSide() != desiredSide {
            if desiredSide == 1 { bodySplit.CollapseFirst(); }
            else if desiredSide == 2 { bodySplit.CollapseSecond(); }
            else { bodySplit.Restore(); }
            renderDirty = true;
        }
        UpdateInspectorButton();
    }

    /// @brief Describe the destination of the inspector toggle.
    hide func UpdateInspectorButton() {
        if inspectorButton == null { return; }
        if compactLayout {
            if compactInspectorShown {
                inspectorButton.SetText("Canvas");
                inspectorButton.SetTooltip("Return to the full-width scene canvas");
                inspectorButton.SetStyle(1);
            } else {
                inspectorButton.SetText("Inspector");
                inspectorButton.SetTooltip("Show the scene inspector at full width");
                inspectorButton.SetStyle(2);
            }
        } else if inspectorRequestedVisible {
            inspectorButton.SetText("Hide Inspector");
            inspectorButton.SetTooltip(
                "Hide the scene inspector and give the canvas the full width");
            inspectorButton.SetStyle(2);
        } else {
            inspectorButton.SetText("Show Inspector");
            inspectorButton.SetTooltip("Restore the scene inspector");
            inspectorButton.SetStyle(1);
        }
    }

    /// @brief Apply deferred scroll state after the canvas content size is known.
    hide func ApplyPendingWorkspaceScroll() {
        if restoreScrollPending == false { return; }
        if canvasScroll != null {
            SetLogicalScroll(
                canvasScroll,
                pendingCanvasScrollX, pendingCanvasScrollY);
        }
        if inspectorScroll != null {
            SetLogicalScroll(
                inspectorScroll, 0.0, pendingInspectorScrollY);
        }
        restoreScrollPending = false;
    }

    /// @brief Return the editor's monotonically increasing content revision.
    expose func GetRevision() -> Integer {
        return revision;
    }

    /// @brief Create a canonical default scene JSON for New Scene commands.
    expose func DefaultSceneJson() -> String {
        var fresh = SceneDocument.New(DEFAULT_SCENE_WIDTH,
                                      DEFAULT_SCENE_HEIGHT,
                                      DEFAULT_TILE_SIZE,
                                      DEFAULT_TILE_SIZE);
        return fresh.ToJson();
    }

    /// @brief Set one tile through the same transactional path as canvas paint.
    /// @return True only when a valid cell changed.
    expose func SetSceneTile(layer: Integer,
                             x: Integer,
                             y: Integer,
                             tile: Integer) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount()
           or x < 0 or y < 0 or x >= scene.Width or y >= scene.Height {
            return false;
        }
        var nextTile = tile;
        if nextTile < 0 { nextTile = 0; }
        if scene.GetTile(layer, x, y) == nextTile { return false; }
        scene.SetTile(layer, x, y, nextTile);
        activeLayer = layer;
        selectedCellX = x;
        selectedCellY = y;
        return CommitScene("Tile " + x + ", " + y + " updated");
    }

    /// @brief Paint an inclusive raster line as one undoable document edit.
    /// @details This is the deterministic command path used to regression-test
    ///          gap-free drag strokes without relying on native pointer timing.
    expose func PaintTileLine(layer: Integer,
                              startX: Integer,
                              startY: Integer,
                              endX: Integer,
                              endY: Integer,
                              tile: Integer) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount()
           or startX < 0 or startY < 0 or endX < 0 or endY < 0
           or startX >= scene.Width or endX >= scene.Width
           or startY >= scene.Height or endY >= scene.Height {
            return false;
        }
        var nextTile = tile;
        if nextTile < 0 { nextTile = 0; }
        var snapshot = currentSerialized;
        if ApplyTileLineUncommitted(
               layer, startX, startY, endX, endY, nextTile) == false {
            return false;
        }
        activeLayer = layer;
        selectedCellX = endX;
        selectedCellY = endY;
        if CommitScene("Painted tile stroke") { return true; }
        RestoreSceneSnapshot(snapshot);
        detailLabel.SetText("The tile stroke could not be committed.");
        return false;
    }

    /// @brief Fill one inclusive forward or reverse cell rectangle atomically.
    /// @return True only when at least one canonical tile changed and committed.
    expose func ApplyTileRectangle(layer: Integer,
                                   startX: Integer,
                                   startY: Integer,
                                   endX: Integer,
                                   endY: Integer,
                                   tile: Integer) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount()
           or startX < 0 or startY < 0 or endX < 0 or endY < 0
           or startX >= scene.Width or endX >= scene.Width
           or startY >= scene.Height or endY >= scene.Height {
            return false;
        }
        var minimumX = startX;
        var maximumX = endX;
        if maximumX < minimumX {
            minimumX = endX;
            maximumX = startX;
        }
        var minimumY = startY;
        var maximumY = endY;
        if maximumY < minimumY {
            minimumY = endY;
            maximumY = startY;
        }
        var nextTile = tile;
        if nextTile < 0 { nextTile = 0; }

        var changedCells = 0;
        var y = minimumY;
        while y <= maximumY {
            var x = minimumX;
            while x <= maximumX {
                if scene.GetTile(layer, x, y) != nextTile {
                    changedCells = changedCells + 1;
                }
                x = x + 1;
            }
            y = y + 1;
        }
        activeLayer = layer;
        selectedCellX = endX;
        selectedCellY = endY;
        renderDirty = true;
        if changedCells == 0 {
            toolbarStatus.SetText("Rectangle already matches the selected tile");
            return false;
        }

        var snapshot = currentSerialized;
        scene.FillTiles(
            layer,
            minimumX,
            minimumY,
            maximumX - minimumX + 1,
            maximumY - minimumY + 1,
            nextTile);
        if CommitScene(
               "Filled " + changedCells + " rectangle tile(s)") {
            detailLabel.SetText("");
            return true;
        }
        RestoreSceneSnapshot(snapshot);
        detailLabel.SetText("The tile rectangle could not be committed.");
        return false;
    }

    /// @brief Replace one four-connected active-layer tile region atomically.
    /// @return Exact changed-cell count, or zero for invalid/no-op/failure.
    expose func FloodFillSceneTile(layer: Integer,
                                   x: Integer,
                                   y: Integer,
                                   tile: Integer) -> Integer {
        if scene == null or layer < 0 or layer >= scene.LayerCount()
           or x < 0 or y < 0 or x >= scene.Width or y >= scene.Height {
            return 0;
        }
        var nextTile = tile;
        if nextTile < 0 { nextTile = 0; }
        activeLayer = layer;
        selectedCellX = x;
        selectedCellY = y;
        renderDirty = true;
        if scene.GetTile(layer, x, y) == nextTile {
            toolbarStatus.SetText("Fill region already matches the selected tile");
            return 0;
        }

        var snapshot = currentSerialized;
        var changedCells = scene.FloodFill(layer, x, y, nextTile);
        if changedCells <= 0 {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText("The contiguous tile fill was rejected.");
            return 0;
        }
        if CommitScene(
               "Filled " + changedCells + " connected tile(s)") {
            detailLabel.SetText("");
            return changedCells;
        }
        RestoreSceneSnapshot(snapshot);
        detailLabel.SetText("The contiguous tile fill could not be committed.");
        return 0;
    }

    /// @brief Sample one active-layer cell into the tile field and enter Paint.
    /// @return Authored tile ID, or -1 for invalid input.
    expose func PickSceneTile(layer: Integer,
                              x: Integer,
                              y: Integer) -> Integer {
        if scene == null or tileSpinner == null
           or layer < 0 or layer >= scene.LayerCount()
           or x < 0 or y < 0 or x >= scene.Width or y >= scene.Height {
            return -1;
        }
        var tile = scene.GetTile(layer, x, y);
        activeLayer = layer;
        selectedCellX = x;
        selectedCellY = y;
        tileSpinner.SetValue(ClampInt(tile, 0, 1000000));
        SetMode(MODE_PAINT);
        RefreshTilesetPalette();
        renderDirty = true;
        toolbarStatus.SetText(
            "Picked tile " + tile + " from " + x + ", " + y);
        detailLabel.SetText("");
        return tile;
    }

    /// @brief Add one scene object and commit its canonical JSON immediately.
    /// @return New object index, or -1 when the model rejects the object.
    expose func AddSceneObject(typeName: String,
                               objectId: String,
                               x: Integer,
                               y: Integer) -> Integer {
        return AddSceneObjectAtParent(-1, typeName, objectId, x, y);
    }

    /// @brief Add one object beneath an existing parent in one transaction.
    /// @details The hierarchy link is established before serialization, so
    ///          Undo never exposes an intermediate root object.
    expose func AddSceneChildObject(parentIndex: Integer,
                                    typeName: String,
                                    objectId: String,
                                    x: Integer,
                                    y: Integer) -> Integer {
        return AddSceneObjectAtParent(
            parentIndex, typeName, objectId, x, y);
    }

    /// @brief Shared root/child creation path with exact selection rollback.
    hide func AddSceneObjectAtParent(parentIndex: Integer,
                                     typeName: String,
                                     objectId: String,
                                     x: Integer,
                                     y: Integer) -> Integer {
        if scene == null { return -1; }
        if parentIndex < -1 or parentIndex >= scene.ObjectCount() {
            detailLabel.SetText("Choose an attached parent object.");
            return -1;
        }
        if parentIndex >= 0
           and ObjectHierarchyDepth(parentIndex)
               >= MAX_OBJECT_HIERARCHY_DEPTH {
            detailLabel.SetText(
                "A child there would exceed Studio's hierarchy depth limit.");
            return -1;
        }
        var nextType = Str.Trim(typeName);
        var nextId = Str.Trim(objectId);
        if nextType == "" {
            detailLabel.SetText("Object type cannot be empty.");
            return -1;
        }
        if nextId == "" {
            detailLabel.SetText("Object ID cannot be empty.");
            return -1;
        }
        if ObjectIdExists(nextId, -1) {
            detailLabel.SetText("Object ID \"" + nextId + "\" is already in use.");
            return -1;
        }
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var previousProperty = selectedObjectProperty;
        var objectIndex = scene.AddObject(nextType, nextId, x, y);
        if objectIndex < 0 { return -1; }
        if parentIndex >= 0
           and scene.TrySetObjectParent(
                   objectIndex, parentIndex) == false {
            scene.RemoveObject(objectIndex);
            detailLabel.SetText(
                "The scene model rejected the new child hierarchy link.");
            return -1;
        }
        selectedObject = objectIndex;
        selectedObjects = scene_selection.Single(
            objectIndex, scene.ObjectCount());
        var action = "Added object " + nextId;
        if parentIndex >= 0 { action = "Added child object " + nextId; }
        if CommitScene(action) == false {
            scene.RemoveObject(objectIndex);
            selectedObject = previousPrimary;
            selectedObjects = previousSelection;
            selectedObjectProperty = previousProperty;
            detailLabel.SetText("The object could not be committed to the document.");
            RefreshInspector();
            return -1;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return objectIndex;
    }

    /// @brief Apply reserved metadata and position as one undoable inspector edit.
    expose func UpdateSceneObject(index: Integer,
                                  typeName: String,
                                  objectId: String,
                                  x: Integer,
                                  y: Integer) -> Boolean {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return false;
        }
        var nextType = Str.Trim(typeName);
        var nextId = Str.Trim(objectId);
        if nextType == "" {
            detailLabel.SetText("Object type cannot be empty.");
            return false;
        }
        if nextId == "" {
            detailLabel.SetText("Object ID cannot be empty.");
            return false;
        }
        if ObjectIdExists(nextId, index) {
            detailLabel.SetText("Object ID \"" + nextId + "\" is already in use.");
            return false;
        }

        var previousType = scene.ObjectType(index);
        var previousId = scene.ObjectId(index);
        var previousX = scene.ObjectX(index);
        var previousY = scene.ObjectY(index);
        if previousType == nextType and previousId == nextId
           and previousX == x and previousY == y {
            detailLabel.SetText("Object is already up to date.");
            return false;
        }

        scene.SetObjectMetadata(index, nextType, nextId);
        scene.SetObjectPosition(index, x, y);
        if scene.ObjectType(index) != nextType or scene.ObjectId(index) != nextId {
            scene.SetObjectMetadata(index, previousType, previousId);
            scene.SetObjectPosition(index, previousX, previousY);
            detailLabel.SetText("Object metadata was rejected by the scene model.");
            return false;
        }
        selectedObject = index;
        selectedObjects = scene_selection.Single(
            index, scene.ObjectCount());
        if CommitScene("Updated object " + nextId) == false {
            scene.SetObjectMetadata(index, previousType, previousId);
            scene.SetObjectPosition(index, previousX, previousY);
            detailLabel.SetText("The object update could not be committed.");
            RefreshInspector();
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Duplicate one object without flattening its typed property map.
    /// @return New object index, or -1 when the model rejects the operation.
    expose func DuplicateSceneObject(index: Integer) -> Integer {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return -1;
        }
        var nextId = UniqueObjectId(scene.ObjectId(index) + "-copy");
        var duplicate = scene.DuplicateObject(index, nextId);
        if duplicate < 0 {
            detailLabel.SetText("The scene could not duplicate this object.");
            return -1;
        }
        scene.SetObjectPosition(
            duplicate,
            scene.ObjectX(index) + scene.TileWidth,
            scene.ObjectY(index) + scene.TileHeight);
        selectedObject = duplicate;
        selectedObjects = scene_selection.Single(
            duplicate, scene.ObjectCount());
        if CommitScene("Duplicated object as " + nextId) == false {
            scene.RemoveObject(duplicate);
            selectedObject = index;
            selectedObjects = scene_selection.Single(
                index, scene.ObjectCount());
            detailLabel.SetText("The duplicate could not be committed.");
            RefreshInspector();
            return -1;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return duplicate;
    }

    /// @brief Select validated object rows with one explicit primary object.
    expose func SelectSceneObjects(indices: List[Integer],
                                   primary: Integer) -> Boolean {
        if scene == null { return false; }
        selectedObjects = scene_selection.Normalize(
            indices, scene.ObjectCount(), primary);
        selectedObject = primary;
        if selectedObject < 0 or selectedObject >= scene.ObjectCount() {
            selectedObject = -1;
            if selectedObjects.count() > 0 {
                selectedObject = selectedObjects.get(0);
            }
        }
        selectedObjectProperty = -1;
        if objectTree != null {
            ExpandObjectTreeAncestors(selectedObject);
            RestoreObjectTreeSelection();
            if selectedObject >= 0
               and selectedObject < objectTreeNodes.count()
               and objectTreeNodes.get(selectedObject) != null {
                objectTree.ScrollTo(objectTreeNodes.get(selectedObject));
            }
        }
        RefreshObjectFields();
        renderDirty = true;
        CaptureWorkspaceState();
        return selectedObjects.count() > 0;
    }

    /// @brief Apply one canvas point hit with conventional modifier semantics.
    /// @details An unmodified hit on an already-selected object preserves the
    ///          complete group so the same press can begin a group drag.
    ///          Selection is workspace-only and never commits scene history.
    /// @return True only when selection or primary identity changed.
    expose func ApplyCanvasPointSelection(objectIndex: Integer,
                                          additive: Boolean,
                                          toggle: Boolean) -> Boolean {
        if scene == null { return false; }
        var current = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if objectIndex < 0 or objectIndex >= scene.ObjectCount() {
            if additive or toggle or current.count() == 0 {
                return false;
            }
            SelectSceneObjects([], -1);
            return true;
        }

        var next: List[Integer] = [];
        var nextPrimary = objectIndex;
        if toggle {
            var removing =
                scene_selection.Contains(current, objectIndex);
            var index = 0;
            while index < current.count() {
                var candidate = current.get(index);
                if removing == false or candidate != objectIndex {
                    next.add(candidate);
                }
                index = index + 1;
            }
            if removing == false { next.add(objectIndex); }
            if removing {
                if next.count() == 0 {
                    nextPrimary = -1;
                } else if selectedObject != objectIndex
                          and scene_selection.Contains(
                              next, selectedObject) {
                    nextPrimary = selectedObject;
                } else {
                    nextPrimary = next.get(next.count() - 1);
                }
            }
        } else if additive {
            next = current;
            if scene_selection.Contains(next, objectIndex) == false {
                next.add(objectIndex);
            }
        } else if scene_selection.Contains(current, objectIndex) {
            next = current;
        } else {
            next.add(objectIndex);
        }

        if nextPrimary == selectedObject
           and IntegerListsEqual(next, current) {
            return false;
        }
        SelectSceneObjects(next, nextPrimary);
        return true;
    }

    /// @brief Return authored objects whose point occupies an inclusive cell box.
    /// @details Results follow canonical object draw order, so the final item
    ///          is the same topmost identity a point hit would prefer.
    expose func CanvasObjectsInCellRect(startX: Integer,
                                        startY: Integer,
                                        endX: Integer,
                                        endY: Integer)
        -> List[Integer] {
        var hits: List[Integer] = [];
        if scene == null or scene.TileWidth <= 0 or scene.TileHeight <= 0 {
            return hits;
        }
        var minimumX = startX;
        var maximumX = endX;
        if maximumX < minimumX {
            minimumX = endX;
            maximumX = startX;
        }
        var minimumY = startY;
        var maximumY = endY;
        if maximumY < minimumY {
            minimumY = endY;
            maximumY = startY;
        }
        var index = 0;
        while index < scene.ObjectCount() {
            var cellX = scene.ObjectX(index) / scene.TileWidth;
            var cellY = scene.ObjectY(index) / scene.TileHeight;
            if cellX >= minimumX and cellX <= maximumX
               and cellY >= minimumY and cellY <= maximumY {
                hits.add(index);
            }
            index = index + 1;
        }
        return hits;
    }

    /// @brief Apply one completed inclusive canvas marquee against selection.
    /// @return True only when selection or primary identity changed.
    expose func ApplyCanvasMarqueeSelection(startX: Integer,
                                            startY: Integer,
                                            endX: Integer,
                                            endY: Integer,
                                            additive: Boolean,
                                            toggle: Boolean) -> Boolean {
        if scene == null { return false; }
        var current = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var hits = CanvasObjectsInCellRect(
            startX, startY, endX, endY);
        if hits.count() == 0 and (additive or toggle) {
            return false;
        }

        var next: List[Integer] = [];
        var nextPrimary = selectedObject;
        if toggle {
            var currentIndex = 0;
            while currentIndex < current.count() {
                var candidate = current.get(currentIndex);
                if scene_selection.Contains(hits, candidate) == false {
                    next.add(candidate);
                }
                currentIndex = currentIndex + 1;
            }
            var lastAdded = -1;
            var hitIndex = 0;
            while hitIndex < hits.count() {
                var hit = hits.get(hitIndex);
                if scene_selection.Contains(current, hit) == false {
                    next.add(hit);
                    lastAdded = hit;
                }
                hitIndex = hitIndex + 1;
            }
            if lastAdded >= 0 {
                nextPrimary = lastAdded;
            } else if scene_selection.Contains(next, selectedObject) {
                nextPrimary = selectedObject;
            } else if next.count() > 0 {
                nextPrimary = next.get(next.count() - 1);
            } else {
                nextPrimary = -1;
            }
        } else if additive {
            next = current;
            var hitIndex = 0;
            while hitIndex < hits.count() {
                var hit = hits.get(hitIndex);
                if scene_selection.Contains(next, hit) == false {
                    next.add(hit);
                }
                hitIndex = hitIndex + 1;
            }
            if hits.count() > 0 {
                nextPrimary = hits.get(hits.count() - 1);
            }
        } else {
            next = hits;
            nextPrimary = -1;
            if hits.count() > 0 {
                nextPrimary = hits.get(hits.count() - 1);
            }
        }

        if nextPrimary == selectedObject
           and IntegerListsEqual(next, current) {
            return false;
        }
        SelectSceneObjects(next, nextPrimary);
        return true;
    }

    /// @brief Reveal and focus the hierarchy Find field without editing scene data.
    /// @return True when a loaded scene owns a usable search field.
    expose func FocusHierarchySearch() -> Boolean {
        if scene == null or hierarchySearchInput == null { return false; }
        if compactLayout {
            compactInspectorShown = true;
        } else {
            inspectorRequestedVisible = true;
        }
        ApplyInspectorLayout();
        if inspectorScroll != null {
            inspectorScroll.ScrollTo(hierarchySearchInput);
        }
        hierarchySearchInput.Focus();
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Select and reveal one bounded id/type hierarchy match.
    /// @param query Case-insensitive object id or type fragment.
    /// @param direction Negative for previous; zero or positive for next.
    /// @return True when a matching represented row was selected.
    expose func FindHierarchy(query: String,
                              direction: Integer) -> Boolean {
        if scene == null or hierarchySearchInput == null { return false; }
        var normalized = scene_hierarchy_search.Normalize(query);
        var resetCursor = normalized != hierarchySearchQuery;
        if hierarchySearchInput.Text != query {
            hierarchySearchInput.SetText(query);
        }
        RefreshHierarchySearch(resetCursor);
        return NavigateHierarchySearch(direction);
    }

    /// @brief Rebuild match indices from represented rows only.
    /// @details Canonical objects hidden by hierarchy safety bounds remain
    ///          untouched and are never offered as an impossible-to-reveal hit.
    hide func RefreshHierarchySearch(resetCursor: Boolean) {
        if hierarchySearchInput == null { return; }
        hierarchySearchQuery = scene_hierarchy_search.Normalize(
            hierarchySearchInput.Text);
        hierarchySearchMatches = [];
        if scene != null and hierarchySearchQuery != "" {
            var index = 0;
            while index < scene.ObjectCount()
                  and index < objectTreeNodes.count() {
                if objectTreeNodes.get(index) != null
                   and scene_hierarchy_search.MatchesNormalized(
                       hierarchySearchQuery,
                       scene.ObjectId(index),
                       scene.ObjectType(index)) {
                    hierarchySearchMatches.add(index);
                }
                index = index + 1;
            }
        }

        hierarchySearchCursor = -1;
        if resetCursor == false {
            var match = 0;
            while match < hierarchySearchMatches.count() {
                if hierarchySearchMatches.get(match) == selectedObject {
                    hierarchySearchCursor = match;
                    break;
                }
                match = match + 1;
            }
        }
        UpdateHierarchySearchControls();
    }

    /// @brief Apply one previous/next hierarchy jump without scene mutation.
    hide func NavigateHierarchySearch(direction: Integer) -> Boolean {
        hierarchySearchCursor = scene_hierarchy_search.NextCursor(
            hierarchySearchMatches.count(),
            hierarchySearchCursor,
            direction);
        if hierarchySearchCursor < 0
           or hierarchySearchCursor >= hierarchySearchMatches.count() {
            UpdateHierarchySearchControls();
            return false;
        }
        var target = hierarchySearchMatches.get(hierarchySearchCursor);
        var selection = scene_selection.Single(
            target, scene.ObjectCount());
        var selected = SelectSceneObjects(selection, target);
        UpdateHierarchySearchControls();
        return selected;
    }

    /// @brief Pump search text and navigation controls without scene history.
    hide func PumpHierarchySearchControls() {
        if hierarchySearchInput == null { return; }
        var query = scene_hierarchy_search.Normalize(
            hierarchySearchInput.Text);
        if query != hierarchySearchQuery {
            RefreshHierarchySearch(true);
        }
        var direction = 0;
        var requested = false;
        if hierarchySearchPreviousButton.WasClicked() {
            direction = -1;
            requested = true;
        }
        if hierarchySearchNextButton.WasClicked()
           or hierarchySearchInput.WasSubmitted() {
            direction = 1;
            requested = true;
        }
        if requested { NavigateHierarchySearch(direction); }
    }

    /// @brief Reflect query, match cursor, and safety bounds in compact UI.
    hide func UpdateHierarchySearchControls() {
        if hierarchySearchInput == null { return; }
        var available = editorControlsEnabled and scene != null;
        hierarchySearchInput.SetEnabled(available);
        var canNavigate =
            available and hierarchySearchMatches.count() > 0;
        hierarchySearchPreviousButton.SetEnabled(canNavigate);
        hierarchySearchNextButton.SetEnabled(canNavigate);

        var suffix = "";
        if objectHierarchyClipped {
            suffix = " within the bounded visible hierarchy";
        }
        if hierarchySearchQuery == "" {
            hierarchySearchStatus.SetText(
                "Find by object id or type" + suffix);
        } else if hierarchySearchMatches.count() == 0 {
            hierarchySearchStatus.SetText(
                "No matching objects" + suffix);
        } else if hierarchySearchCursor < 0 {
            hierarchySearchStatus.SetText(
                hierarchySearchMatches.count()
                + " matching object(s)" + suffix
                + "; press Enter to jump");
        } else {
            hierarchySearchStatus.SetText(
                "Match " + (hierarchySearchCursor + 1)
                + " of " + hierarchySearchMatches.count()
                + suffix);
        }
    }

    /// @brief Return whether at least one valid object is selected.
    expose func HasSceneObjectSelection() -> Boolean {
        if scene == null { return false; }
        var normalized = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        return normalized.count() > 0;
    }

    /// @brief Return whether Select All has an object target.
    expose func CanSelectAllSceneObjects() -> Boolean {
        return scene != null and scene.ObjectCount() > 0;
    }

    /// @brief Return whether the text clipboard may contain pasteable data.
    /// @details Kind and payload validation happen only on explicit paste so
    ///          Studio does not copy a potentially large native clipboard every
    ///          render frame merely to update menu chrome.
    expose func CanPasteSceneObjects() -> Boolean {
        return scene != null and GUI.ClipboardText.HasText();
    }

    /// @brief Select every authored object without changing scene history.
    expose func SelectAllSceneObjects() -> Boolean {
        if CanSelectAllSceneObjects() == false { return false; }
        var all: List[Integer] = [];
        var index = 0;
        while index < scene.ObjectCount() {
            all.add(index);
            index = index + 1;
        }
        var primary = selectedObject;
        if primary < 0 or primary >= scene.ObjectCount() { primary = 0; }
        if SelectSceneObjects(all, primary) == false { return false; }
        toolbarStatus.SetText(
            "Selected all " + selectedObjects.count() + " scene objects");
        detailLabel.SetText("");
        return true;
    }

    /// @brief Copy selected objects as canonical typed scene data.
    expose func CopySelectedSceneObjects() -> Boolean {
        if scene == null or currentSerialized == "" { return false; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if selectedObjects.count() == 0 { return false; }
        if selectedObject < 0
           or scene_selection.Contains(selectedObjects, selectedObject) == false {
            selectedObject = selectedObjects.get(0);
        }
        var encoded = scene_clipboard.Encode(
            "2d", selectedObjects, selectedObject, currentSerialized);
        if encoded == "" {
            toolbarStatus.SetText("Scene objects not copied");
            detailLabel.SetText(
                "The selected objects exceed Studio's scene clipboard limit.");
            return false;
        }
        GUI.ClipboardText.SetText(encoded);
        toolbarStatus.SetText(
            "Copied " + selectedObjects.count() + " scene object(s)");
        detailLabel.SetText("");
        return true;
    }

    /// @brief Copy and remove selected objects as one undoable edit.
    expose func CutSelectedSceneObjects() -> Boolean {
        var count = selectedObjects.count();
        if CopySelectedSceneObjects() == false { return false; }
        if RemoveSelectedSceneObjects() == false {
            detailLabel.SetText(
                "The objects were copied, but Studio could not remove them.");
            return false;
        }
        toolbarStatus.SetText("Cut " + count + " scene object(s)");
        return true;
    }

    /// @brief Paste typed 2D objects into this scene as one history action.
    /// @details Source metadata and custom null/bool/int/float/string values are
    ///          reconstructed through SceneDocument's typed APIs. Any rejected
    ///          object restores the exact pre-paste canonical snapshot.
    expose func PasteSceneObjectsFromClipboard() -> Boolean {
        if scene == null or currentDoc == null { return false; }
        var payload = scene_clipboard.Decode(GUI.ClipboardText.GetText());
        if payload.valid == false {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(payload.error);
            return false;
        }
        if payload.kind != "2d" {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard contains 3D nodes. Paste them into a 3D scene.");
            return false;
        }
        var parsed = SceneDocument.LoadJsonResult(payload.content);
        if parsed.IsOk == false {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard contains invalid or unsupported 2D scene data.");
            return false;
        }
        var source = parsed.Unwrap() as SceneDocument;
        var sourceSelection = scene_selection.Normalize(
            payload.indices, source.ObjectCount(), payload.primary);
        if sourceSelection.count() != payload.indices.count()
           or payload.primary < 0
           or payload.primary >= source.ObjectCount() {
            toolbarStatus.SetText("Nothing pasted");
            detailLabel.SetText(
                "Clipboard object identities no longer match its scene data.");
            return false;
        }

        var snapshot = currentSerialized;
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var pasted: List[Integer] = [];
        var pastedPrimary = -1;
        var index = 0;
        while index < sourceSelection.count() {
            var sourceIndex = sourceSelection.get(index);
            var destination = CopyObjectFromScene(source, sourceIndex);
            if destination < 0 {
                RestoreSceneSnapshot(snapshot);
                selectedObjects = previousSelection;
                selectedObject = previousPrimary;
                RefreshInspector();
                toolbarStatus.SetText("Paste rolled back");
                detailLabel.SetText(
                    "Studio could not reconstruct every copied object. "
                    + "No scene data was changed.");
                return false;
            }
            pasted.add(destination);
            if sourceIndex == payload.primary { pastedPrimary = destination; }
            index = index + 1;
        }
        index = 0;
        while index < sourceSelection.count() {
            var sourceParent =
                source.ObjectParent(sourceSelection.get(index));
            var parentSelectionIndex =
                IntegerIndexOf(sourceSelection, sourceParent);
            if parentSelectionIndex >= 0
               and scene.TrySetObjectParent(
                      pasted.get(index),
                      pasted.get(parentSelectionIndex)) == false {
                RestoreSceneSnapshot(snapshot);
                selectedObjects = previousSelection;
                selectedObject = previousPrimary;
                RefreshInspector();
                toolbarStatus.SetText("Paste rolled back");
                detailLabel.SetText(
                    "Studio could not restore the copied object hierarchy. "
                    + "No scene data was changed.");
                return false;
            }
            index = index + 1;
        }
        if pastedPrimary < 0 and pasted.count() > 0 {
            pastedPrimary = pasted.get(0);
        }
        selectedObjects = pasted;
        selectedObject = pastedPrimary;
        selectedObjectProperty = -1;
        var message = "Pasted " + pasted.count() + " scene objects";
        if pasted.count() == 1 { message = "Pasted scene object"; }
        if pasted.count() == 0 or CommitScene(message) == false {
            RestoreSceneSnapshot(snapshot);
            selectedObjects = previousSelection;
            selectedObject = previousPrimary;
            RefreshInspector();
            toolbarStatus.SetText("Paste rolled back");
            detailLabel.SetText(
                "The pasted objects could not be committed. "
                + "No scene data was changed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        CaptureWorkspaceState();
        return true;
    }

    /// @brief Reconstruct one object from another loaded scene.
    hide func CopyObjectFromScene(source: SceneDocument,
                                  sourceIndex: Integer) -> Integer {
        if scene == null or source == null
           or sourceIndex < 0 or sourceIndex >= source.ObjectCount() {
            return -1;
        }
        var nextId = UniqueObjectId(
            source.ObjectId(sourceIndex) + "-copy");
        var destination = scene.AddObject(
            source.ObjectType(sourceIndex),
            nextId,
            source.ObjectX(sourceIndex) + scene.TileWidth,
            source.ObjectY(sourceIndex) + scene.TileHeight);
        if destination < 0 { return -1; }

        var keys = source.ObjectKeys(sourceIndex);
        var keyIndex = 0;
        while keyIndex < Seq.get_Count(keys) {
            var key = Seq.GetStr(keys, keyIndex);
            var kind = source.ObjectPropertyKind(sourceIndex, key);
            if kind == "string" {
                scene.ObjectSetStr(
                    destination, key,
                    source.ObjectGetStr(sourceIndex, key, ""));
            } else if kind == "int" {
                scene.ObjectSetInt(
                    destination, key,
                    source.ObjectGetInt(sourceIndex, key, 0));
            } else if kind == "float" {
                scene.ObjectSetFloat(
                    destination, key,
                    source.ObjectGetFloat(sourceIndex, key, 0.0));
            } else if kind == "bool" {
                scene.ObjectSetBool(
                    destination, key,
                    source.ObjectGetBool(sourceIndex, key, false));
            } else if kind == "null" {
                scene.ObjectSetNull(destination, key);
            } else {
                scene.RemoveObject(destination);
                return -1;
            }
            if scene.ObjectHas(destination, key) == false
               or scene.ObjectPropertyKind(destination, key) != kind {
                scene.RemoveObject(destination);
                return -1;
            }
            keyIndex = keyIndex + 1;
        }
        return destination;
    }

    /// @brief Duplicate every selected object as one lossless history action.
    /// @return Number of duplicated objects, or zero when the action fails.
    expose func DuplicateSelectedSceneObjects() -> Integer {
        if scene == null { return 0; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if selectedObjects.count() == 0 { return 0; }

        var snapshot = currentSerialized;
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var sourceIndices = selectedObjects;
        var sourceParents: List[Integer] = [];
        var duplicateIds: List[String] = [];
        var sourceIndex = 0;
        while sourceIndex < sourceIndices.count() {
            sourceParents.add(
                scene.ObjectParent(sourceIndices.get(sourceIndex)));
            duplicateIds.add("");
            sourceIndex = sourceIndex + 1;
        }
        var primaryDuplicateId = "";
        var source = scene.ObjectCount() - 1;
        while source >= 0 {
            if scene_selection.Contains(selectedObjects, source) {
                var selectionPosition =
                    IntegerIndexOf(sourceIndices, source);
                var nextId = UniqueObjectId(
                    scene.ObjectId(source) + "-copy");
                var duplicate = scene.DuplicateObject(source, nextId);
                if duplicate < 0 {
                    selectedObjects = previousSelection;
                    selectedObject = previousPrimary;
                    RestoreSceneSnapshot(snapshot);
                    detailLabel.SetText(
                        "The selected objects could not all be duplicated. "
                        + "No objects were changed.");
                    return 0;
                }
                scene.SetObjectPosition(
                    duplicate,
                    scene.ObjectX(source) + scene.TileWidth,
                    scene.ObjectY(source) + scene.TileHeight);
                if selectionPosition >= 0 {
                    duplicateIds.set(selectionPosition, nextId);
                }
                if source == previousPrimary {
                    primaryDuplicateId = nextId;
                }
            }
            source = source - 1;
        }

        sourceIndex = 0;
        while sourceIndex < sourceIndices.count() {
            var parentPosition = IntegerIndexOf(
                sourceIndices, sourceParents.get(sourceIndex));
            if parentPosition >= 0 {
                var duplicateIndex =
                    ObjectIndexWithId(duplicateIds.get(sourceIndex));
                var duplicateParent = ObjectIndexWithId(
                    duplicateIds.get(parentPosition));
                if duplicateIndex < 0 or duplicateParent < 0
                   or scene.TrySetObjectParent(
                          duplicateIndex, duplicateParent) == false {
                    selectedObjects = previousSelection;
                    selectedObject = previousPrimary;
                    RestoreSceneSnapshot(snapshot);
                    detailLabel.SetText(
                        "The selected hierarchy could not be duplicated. "
                        + "No objects were changed.");
                    return 0;
                }
            }
            sourceIndex = sourceIndex + 1;
        }

        var duplicates: List[Integer] = [];
        var nextPrimary = -1;
        var objectIndex = 0;
        while objectIndex < scene.ObjectCount() {
            var candidateId = scene.ObjectId(objectIndex);
            var idIndex = 0;
            while idIndex < duplicateIds.count() {
                if candidateId == duplicateIds.get(idIndex) {
                    duplicates.add(objectIndex);
                    if candidateId == primaryDuplicateId {
                        nextPrimary = objectIndex;
                    }
                    break;
                }
                idIndex = idIndex + 1;
            }
            objectIndex = objectIndex + 1;
        }
        if nextPrimary < 0 and duplicates.count() > 0 {
            nextPrimary = duplicates.get(0);
        }
        selectedObjects = duplicates;
        selectedObject = nextPrimary;
        selectedObjectProperty = -1;
        var count = duplicates.count();
        var message = "Duplicated " + count + " objects";
        if count == 1 { message = "Duplicated scene object"; }
        if count == 0 or CommitScene(message) == false {
            selectedObjects = previousSelection;
            selectedObject = previousPrimary;
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The selected objects could not be committed.");
            return 0;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return count;
    }

    /// @brief Remove every selected object in one descending-index transaction.
    expose func RemoveSelectedSceneObjects() -> Boolean {
        if scene == null { return false; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var count = selectedObjects.count();
        if count == 0 { return false; }

        var snapshot = currentSerialized;
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var firstRemoved = scene.ObjectCount();
        var index = scene.ObjectCount() - 1;
        while index >= 0 {
            if scene_selection.Contains(selectedObjects, index) {
                if index < firstRemoved { firstRemoved = index; }
                scene.RemoveObject(index);
            }
            index = index - 1;
        }

        var remaining = scene.ObjectCount();
        selectedObject = firstRemoved;
        if selectedObject >= remaining { selectedObject = remaining - 1; }
        selectedObjects = scene_selection.Single(selectedObject, remaining);
        selectedObjectProperty = -1;
        var message = "Removed " + count + " objects";
        if count == 1 { message = "Removed object"; }
        if CommitScene(message) == false {
            selectedObjects = previousSelection;
            selectedObject = previousPrimary;
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The selected objects could not be removed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Translate every selected object by one pixel delta and commit once.
    expose func TranslateSelectedSceneObjects(deltaX: Integer,
                                              deltaY: Integer) -> Boolean {
        if scene == null or (deltaX == 0 and deltaY == 0) {
            return false;
        }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if selectedObjects.count() == 0 { return false; }
        var snapshot = currentSerialized;
        if TranslateSelectedObjectsUncommitted(deltaX, deltaY) == false {
            return false;
        }
        var count = selectedObjects.count();
        var message = "Moved " + count + " objects";
        if count == 1 { message = "Moved scene object"; }
        if CommitScene(message) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The selected object move could not be committed.");
            return false;
        }
        RefreshInspector();
        return true;
    }

    /// @brief Apply one group delta without creating an intermediate history row.
    hide func TranslateSelectedObjectsUncommitted(deltaX: Integer,
                                                  deltaY: Integer) -> Boolean {
        if scene == null or (deltaX == 0 and deltaY == 0) {
            return false;
        }
        var changed = false;
        var selectionIndex = 0;
        while selectionIndex < selectedObjects.count() {
            var objectIndex = selectedObjects.get(selectionIndex);
            if objectIndex >= 0 and objectIndex < scene.ObjectCount() {
                scene.SetObjectPosition(
                    objectIndex,
                    scene.ObjectX(objectIndex) + deltaX,
                    scene.ObjectY(objectIndex) + deltaY);
                changed = true;
            }
            selectionIndex = selectionIndex + 1;
        }
        if changed { renderDirty = true; }
        return changed;
    }

    /// @brief Align or distribute the selected authored point positions once.
    /// @details Align uses selectedObject as the explicit anchor. Distribution
    ///          leaves both extrema fixed and deterministically rounds every
    ///          intermediate integer position. Rejected/no-op layouts do not
    ///          create history.
    expose func ArrangeSelectedSceneObjects(operation: Integer) -> Boolean {
        if scene == null or scene_layout_2d.IsOperation(operation) == false {
            return false;
        }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var minimum = scene_layout_2d.MinimumSelection(operation);
        if selectedObjects.count() < minimum
           or selectedObject < 0
           or selectedObject >= scene.ObjectCount() {
            detailLabel.SetText(
                scene_layout_2d.OperationLabel(operation)
                + " needs at least " + minimum + " selected objects.");
            return false;
        }

        var snapshot = currentSerialized;
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var useX = scene_layout_2d.UsesX(operation);
        var changed = false;
        if scene_layout_2d.IsDistribution(operation) {
            var ordered = scene_layout_2d.OrderedIndices(
                scene, selectedObjects, useX);
            if ordered.count() < minimum { return false; }
            var minimumCoordinate = scene_layout_2d.Coordinate(
                scene, ordered.get(0), useX);
            var maximumCoordinate = scene_layout_2d.Coordinate(
                scene, ordered.get(ordered.count() - 1), useX);
            var position = 0;
            while position < ordered.count() {
                var objectIndex = ordered.get(position);
                var target = scene_layout_2d.DistributedCoordinate(
                    minimumCoordinate,
                    maximumCoordinate,
                    position,
                    ordered.count());
                var current = scene_layout_2d.Coordinate(
                    scene, objectIndex, useX);
                if current != target {
                    if useX {
                        scene.SetObjectPosition(
                            objectIndex, target, scene.ObjectY(objectIndex));
                    } else {
                        scene.SetObjectPosition(
                            objectIndex, scene.ObjectX(objectIndex), target);
                    }
                    changed = true;
                }
                position = position + 1;
            }
        } else {
            var anchor = scene_layout_2d.Coordinate(
                scene, selectedObject, useX);
            var selectionIndex = 0;
            while selectionIndex < selectedObjects.count() {
                var objectIndex = selectedObjects.get(selectionIndex);
                var current = scene_layout_2d.Coordinate(
                    scene, objectIndex, useX);
                if current != anchor {
                    if useX {
                        scene.SetObjectPosition(
                            objectIndex, anchor, scene.ObjectY(objectIndex));
                    } else {
                        scene.SetObjectPosition(
                            objectIndex, scene.ObjectX(objectIndex), anchor);
                    }
                    changed = true;
                }
                selectionIndex = selectionIndex + 1;
            }
        }

        if changed == false {
            detailLabel.SetText(
                "The selection already satisfies "
                + scene_layout_2d.OperationLabel(operation) + ".");
            return false;
        }
        var message = scene_layout_2d.OperationLabel(operation)
            + " (" + selectedObjects.count() + " objects)";
        if CommitScene(message) == false {
            selectedObjects = previousSelection;
            selectedObject = previousPrimary;
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The selected object layout could not be committed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Move one object to an explicit draw-order index.
    expose func MoveSceneObject(index: Integer, target: Integer) -> Boolean {
        if scene == null or index < 0 or target < 0
           or index >= scene.ObjectCount() or target >= scene.ObjectCount()
           or index == target {
            return false;
        }
        scene.MoveObject(index, target);
        selectedObject = target;
        selectedObjects = scene_selection.Single(
            target, scene.ObjectCount());
        if CommitScene("Changed object draw order") == false {
            scene.MoveObject(target, index);
            selectedObject = index;
            selectedObjects = scene_selection.Single(
                index, scene.ObjectCount());
            detailLabel.SetText("The object order change could not be committed.");
            RefreshInspector();
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    hide func IntegerIndexOf(values: List[Integer],
                             value: Integer) -> Integer {
        var index = 0;
        while index < values.count() {
            if values.get(index) == value { return index; }
            index = index + 1;
        }
        return -1;
    }

    hide func IntegerListsEqual(left: List[Integer],
                                right: List[Integer]) -> Boolean {
        if left.count() != right.count() { return false; }
        var index = 0;
        while index < left.count() {
            if left.get(index) != right.get(index) { return false; }
            index = index + 1;
        }
        return true;
    }

    hide func SnapshotObjectParents() -> List[Integer] {
        var parents: List[Integer] = [];
        if scene == null { return parents; }
        var index = 0;
        while index < scene.ObjectCount() {
            parents.add(scene.ObjectParent(index));
            index = index + 1;
        }
        return parents;
    }

    /// @brief Classify every identity by the selected root that contains it.
    /// @details Memoized parent walks keep hierarchy edits linear even near the
    ///          SceneDocument object limit.
    hide func SelectedRootOwners(parents: List[Integer],
                                 roots: List[Integer])
        -> List[Integer] {
        var owners: List[Integer] = [];
        var index = 0;
        while index < parents.count() {
            owners.add(-2);
            index = index + 1;
        }
        index = 0;
        while index < roots.count() {
            var rootIdentity = roots.get(index);
            if rootIdentity >= 0 and rootIdentity < owners.count() {
                owners.set(rootIdentity, rootIdentity);
            }
            index = index + 1;
        }

        var start = 0;
        while start < parents.count() {
            if owners.get(start) == -2 {
                var path: List[Integer] = [];
                var current = start;
                var steps = 0;
                while current >= 0 and current < parents.count()
                      and owners.get(current) == -2
                      and steps <= parents.count() {
                    path.add(current);
                    current = parents.get(current);
                    steps = steps + 1;
                }
                var owner = -1;
                if current >= 0 and current < owners.count() {
                    owner = owners.get(current);
                }
                var pathIndex = path.count() - 1;
                while pathIndex >= 0 {
                    owners.set(path.get(pathIndex), owner);
                    pathIndex = pathIndex - 1;
                }
            }
            start = start + 1;
        }
        return owners;
    }

    /// @brief Compute every absolute depth with memoized parent walks.
    hide func IdentityDepths(parents: List[Integer]) -> List[Integer] {
        var depths: List[Integer] = [];
        var index = 0;
        while index < parents.count() {
            var depth = -1;
            if parents.get(index) < 0 { depth = 0; }
            depths.add(depth);
            index = index + 1;
        }
        var start = 0;
        while start < parents.count() {
            if depths.get(start) < 0 {
                var path: List[Integer] = [];
                var current = start;
                var steps = 0;
                while current >= 0 and current < parents.count()
                      and depths.get(current) < 0
                      and steps <= parents.count() {
                    path.add(current);
                    current = parents.get(current);
                    steps = steps + 1;
                }
                var depth = -1;
                if current >= 0 and current < depths.count() {
                    depth = depths.get(current);
                }
                var pathIndex = path.count() - 1;
                while pathIndex >= 0 {
                    depth = depth + 1;
                    depths.set(path.get(pathIndex), depth);
                    pathIndex = pathIndex - 1;
                }
            }
            start = start + 1;
        }
        return depths;
    }

    /// @brief Normalize selected hierarchy roots into current draw order.
    hide func TopLevelSelectedObjectRoots(
        parents: List[Integer]) -> List[Integer] {
        var roots: List[Integer] = [];
        var candidate = 0;
        while candidate < parents.count() {
            if scene_selection.Contains(selectedObjects, candidate) {
                var nested = false;
                var ancestor = parents.get(candidate);
                var steps = 0;
                while ancestor >= 0 and steps <= parents.count() {
                    if scene_selection.Contains(
                           selectedObjects, ancestor) {
                        nested = true;
                        break;
                    }
                    ancestor = parents.get(ancestor);
                    steps = steps + 1;
                }
                if nested == false { roots.add(candidate); }
            }
            candidate = candidate + 1;
        }
        return roots;
    }

    hide func MovingObjectIdentities(owners: List[Integer])
        -> List[Integer] {
        var moving: List[Integer] = [];
        var candidate = 0;
        while candidate < owners.count() {
            if owners.get(candidate) >= 0 { moving.add(candidate); }
            candidate = candidate + 1;
        }
        return moving;
    }

    hide func ObjectDropFitsDepth(destinationParent: Integer,
                                  parents: List[Integer],
                                  owners: List[Integer]) -> Boolean {
        var depths = IdentityDepths(parents);
        return ObjectDropFitsKnownDepths(
            destinationParent, depths, owners);
    }

    /// @brief Check a target using one shared depth snapshot.
    /// @details Parent-picker refresh calls this for many candidates and must
    ///          not repeat a complete hierarchy walk for every dropdown row.
    hide func ObjectDropFitsKnownDepths(
        destinationParent: Integer,
        depths: List[Integer],
        owners: List[Integer]) -> Boolean {
        var rootDepth = 0;
        if destinationParent >= 0 {
            rootDepth = depths.get(destinationParent) + 1;
        }
        var identity = 0;
        while identity < owners.count() {
            var owner = owners.get(identity);
            if owner >= 0
               and rootDepth + depths.get(identity) - depths.get(owner)
                  > MAX_OBJECT_HIERARCHY_DEPTH {
                return false;
            }
            identity = identity + 1;
        }
        return true;
    }

    /// @brief Move selected top-level subtrees beneath one explicit parent.
    /// @param targetParent Object index, or -1 for the scene root.
    /// @details This is the keyboard-accessible counterpart to an INTO row
    ///          drop. Reparenting to the scene root appends after the last
    ///          remaining root. Absolute object coordinates are unchanged.
    expose func ReparentSelectedSceneObjects(
        targetParent: Integer) -> Boolean {
        if scene == null or targetParent < -1
           or targetParent >= scene.ObjectCount() {
            return false;
        }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var parents = SnapshotObjectParents();
        var roots = TopLevelSelectedObjectRoots(parents);
        if roots.count() == 0 { return false; }
        var owners = SelectedRootOwners(parents, roots);
        var moving = MovingObjectIdentities(owners);
        if targetParent >= 0
           and scene_selection.Contains(moving, targetParent) {
            detailLabel.SetText(
                "An object cannot be parented to itself or one of its descendants.");
            return false;
        }
        if ObjectDropFitsDepth(
               targetParent, parents, owners) == false {
            detailLabel.SetText(
                "That parent would exceed Studio's hierarchy depth limit.");
            return false;
        }

        var alreadyParented = true;
        var rootIndex = 0;
        while rootIndex < roots.count() {
            if parents.get(roots.get(rootIndex)) != targetParent {
                alreadyParented = false;
            }
            rootIndex = rootIndex + 1;
        }
        if alreadyParented {
            detailLabel.SetText(
                "The selected object subtrees already use that parent.");
            return false;
        }

        var source = roots.get(0);
        if targetParent >= 0 {
            return ApplyObjectHierarchyDrop(source, targetParent, 1);
        }

        var lastRemainingRoot = -1;
        var candidate = 0;
        while candidate < parents.count() {
            if parents.get(candidate) < 0
               and scene_selection.Contains(moving, candidate) == false {
                lastRemainingRoot = candidate;
            }
            candidate = candidate + 1;
        }
        if lastRemainingRoot < 0 {
            detailLabel.SetText(
                "Studio could not find an attached scene-root destination.");
            return false;
        }
        var changed =
            ApplyObjectHierarchyDrop(source, lastRemainingRoot, 2);
        if changed {
            toolbarStatus.SetText(
                "Reparented " + roots.count()
                + " object subtree(s) to scene root");
        }
        return changed;
    }

    /// @brief Apply one retained TreeView row drop as a canonical transaction.
    /// @details Selected top-level roots carry their complete subtrees.
    ///          BEFORE/AFTER use the target's parent; INTO appends beneath the
    ///          target. Every identity and parent index is remapped exactly.
    expose func ApplyObjectHierarchyDrop(sourceIndex: Integer,
                                         targetIndex: Integer,
                                         position: Integer) -> Boolean {
        if scene == null or currentDoc == null
           or sourceIndex < 0 or sourceIndex >= scene.ObjectCount()
           or targetIndex < 0 or targetIndex >= scene.ObjectCount()
           or position < 0 or position > 2 {
            return false;
        }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if scene_selection.Contains(selectedObjects, sourceIndex) == false {
            var sourceOnly = scene_selection.Single(
                sourceIndex, scene.ObjectCount());
            SelectSceneObjects(sourceOnly, sourceIndex);
        }

        var parents = SnapshotObjectParents();
        var roots = TopLevelSelectedObjectRoots(parents);
        var owners = SelectedRootOwners(parents, roots);
        var moving = MovingObjectIdentities(owners);
        if roots.count() == 0
           or scene_selection.Contains(moving, targetIndex) {
            detailLabel.SetText(
                "Drop onto a row outside the selected object subtrees.");
            return false;
        }

        var destinationParent = parents.get(targetIndex);
        if position == 1 {
            destinationParent = targetIndex;
        }
        if ObjectDropFitsDepth(
               destinationParent, parents, owners) == false {
            detailLabel.SetText(
                "That row drop would exceed Studio's hierarchy depth limit.");
            return false;
        }

        var remaining: List[Integer] = [];
        var identityOrder: List[Integer] = [];
        var identity = 0;
        while identity < parents.count() {
            identityOrder.add(identity);
            if scene_selection.Contains(moving, identity) == false {
                remaining.add(identity);
            }
            identity = identity + 1;
        }

        var insertion = -1;
        if position == 0 {
            insertion = IntegerIndexOf(remaining, targetIndex);
        } else {
            var targetRoots: List[Integer] = [];
            targetRoots.add(targetIndex);
            var targetOwners =
                SelectedRootOwners(parents, targetRoots);
            var remainingIndex = 0;
            while remainingIndex < remaining.count() {
                if targetOwners.get(
                       remaining.get(remainingIndex)) == targetIndex {
                    insertion = remainingIndex + 1;
                }
                remainingIndex = remainingIndex + 1;
            }
        }
        if insertion < 0 or insertion > remaining.count() {
            detailLabel.SetText(
                "The hierarchy drop target is no longer attached.");
            return false;
        }

        var desired = remaining;
        var movingIndex = 0;
        while movingIndex < moving.count() {
            desired.insert(
                insertion + movingIndex, moving.get(movingIndex));
            movingIndex = movingIndex + 1;
        }

        var parentAlreadyExact = true;
        var rootIndex = 0;
        while rootIndex < roots.count() {
            if parents.get(roots.get(rootIndex)) != destinationParent {
                parentAlreadyExact = false;
            }
            rootIndex = rootIndex + 1;
        }
        if parentAlreadyExact
           and IntegerListsEqual(identityOrder, desired) {
            detailLabel.SetText(
                "The selected object subtrees already use that row position.");
            return false;
        }

        var snapshot = currentSerialized;
        var previousSelection = selectedObjects;
        var previousPrimary = selectedObject;
        var currentOrder = identityOrder;
        var destination = 0;
        while destination < desired.count() {
            var desiredIdentity = desired.get(destination);
            var current = IntegerIndexOf(
                currentOrder, desiredIdentity);
            if current < 0 {
                RestoreSceneSnapshot(snapshot);
                selectedObjects = previousSelection;
                selectedObject = previousPrimary;
                RefreshInspector();
                detailLabel.SetText(
                    "Studio lost an object identity while reordering.");
                return false;
            }
            if current != destination {
                scene.MoveObject(current, destination);
                currentOrder.removeAt(current);
                currentOrder.insert(destination, desiredIdentity);
            }
            destination = destination + 1;
        }

        var destinationParentIndex = -1;
        if destinationParent >= 0 {
            destinationParentIndex =
                IntegerIndexOf(desired, destinationParent);
        }
        rootIndex = 0;
        while rootIndex < roots.count() {
            var nextRoot = IntegerIndexOf(
                desired, roots.get(rootIndex));
            if nextRoot < 0
               or scene.TrySetObjectParent(
                      nextRoot, destinationParentIndex) == false {
                RestoreSceneSnapshot(snapshot);
                selectedObjects = previousSelection;
                selectedObject = previousPrimary;
                RefreshInspector();
                detailLabel.SetText(
                    "The scene model rejected the hierarchy change.");
                return false;
            }
            rootIndex = rootIndex + 1;
        }

        var nextSelection: List[Integer] = [];
        var selectionIndex = 0;
        while selectionIndex < previousSelection.count() {
            var mapped = IntegerIndexOf(
                desired, previousSelection.get(selectionIndex));
            if mapped >= 0 { nextSelection.add(mapped); }
            selectionIndex = selectionIndex + 1;
        }
        var nextPrimary = IntegerIndexOf(desired, previousPrimary);
        if nextPrimary < 0 and nextSelection.count() > 0 {
            nextPrimary = nextSelection.get(0);
        }
        selectedObjects = nextSelection;
        selectedObject = nextPrimary;
        selectedObjectProperty = -1;

        var action = "Moved " + roots.count()
            + " object subtree(s)";
        if position == 1 {
            action = "Reparented " + roots.count()
                + " object subtree(s)";
        }
        if CommitScene(action) == false {
            RestoreSceneSnapshot(snapshot);
            selectedObjects = previousSelection;
            selectedObject = previousPrimary;
            RefreshInspector();
            detailLabel.SetText(
                "The hierarchy edit could not be committed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        CaptureWorkspaceState();
        return true;
    }

    hide func PreviousObjectSibling(index: Integer) -> Integer {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return -1;
        }
        var parent = scene.ObjectParent(index);
        var sibling = -1;
        var candidate = 0;
        while candidate < index {
            if scene.ObjectParent(candidate) == parent {
                sibling = candidate;
            }
            candidate = candidate + 1;
        }
        return sibling;
    }

    hide func NextObjectSibling(index: Integer) -> Integer {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return -1;
        }
        var parent = scene.ObjectParent(index);
        var candidate = index + 1;
        while candidate < scene.ObjectCount() {
            if scene.ObjectParent(candidate) == parent { return candidate; }
            candidate = candidate + 1;
        }
        return -1;
    }

    /// @brief Create, rename, or update one typed scene property transactionally.
    expose func SetSceneProperty(previousKey: String,
                                 key: String,
                                 kind: String,
                                 value: String) -> Boolean {
        if scene == null { return false; }
        var nextKey = Str.Trim(key);
        if nextKey == "" {
            detailLabel.SetText("Scene property key cannot be empty.");
            return false;
        }
        if previousKey != "" and scene.Has(previousKey) == false {
            detailLabel.SetText(
                "The selected scene property no longer exists.");
            return false;
        }
        if previousKey != nextKey and scene.Has(nextKey) {
            detailLabel.SetText(
                "Scene property \"" + nextKey + "\" already exists.");
            return false;
        }

        var snapshot = scene.ToJson();
        var intValue = 0;
        var floatValue = 0.0;
        var boolValue = false;
        if kind == "string" {
            scene.SetStr(nextKey, value);
        } else if kind == "int" {
            var parsedInt = Parse.TryInt(Str.Trim(value));
            if parsedInt.IsNone {
                detailLabel.SetText("Enter a valid whole number.");
                return false;
            }
            intValue = parsedInt.UnwrapI64();
            scene.SetInt(nextKey, intValue);
        } else if kind == "float" {
            var parsedFloat = Parse.TryDouble(Str.Trim(value));
            if parsedFloat.IsNone {
                detailLabel.SetText("Enter a valid finite number.");
                return false;
            }
            floatValue = parsedFloat.UnwrapF64();
            scene.SetFloat(nextKey, floatValue);
        } else if kind == "bool" {
            var parsedBool = Parse.TryBool(Str.Trim(value));
            if parsedBool.IsNone {
                detailLabel.SetText(
                    "Enter true/false, yes/no, on/off, or 1/0.");
                return false;
            }
            boolValue = parsedBool.UnwrapI1();
            scene.SetBool(nextKey, boolValue);
        } else if kind == "null" {
            scene.SetNull(nextKey);
        } else {
            detailLabel.SetText("Choose a supported scene property type.");
            return false;
        }

        if ScenePropertyMatches(
               nextKey, kind, value, intValue, floatValue, boolValue) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The scene property was rejected. Keys are limited to "
                + "128 bytes and string values to 64 KiB.");
            return false;
        }
        if previousKey != "" and previousKey != nextKey {
            scene.Remove(previousKey);
        }
        if scene.ToJson() == snapshot {
            detailLabel.SetText("Scene property is already up to date.");
            return false;
        }
        if CommitScene("Updated scene property " + nextKey) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The scene property update could not be committed.");
            return false;
        }

        detailLabel.SetText("");
        RefreshInspector();
        sceneProperties.SelectByKey(scene, nextKey);
        selectedSceneProperty = sceneProperties.selectedProperty;
        return true;
    }

    /// @brief Remove one typed scene property through canonical history.
    expose func RemoveSceneProperty(key: String) -> Boolean {
        if scene == null { return false; }
        var nextKey = Str.Trim(key);
        if nextKey == "" or scene.Has(nextKey) == false { return false; }
        var snapshot = scene.ToJson();
        scene.Remove(nextKey);
        if scene.Has(nextKey) {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The scene model rejected the property removal.");
            return false;
        }
        if CommitScene("Removed scene property " + nextKey) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The scene property removal could not be committed.");
            return false;
        }
        detailLabel.SetText("");
        selectedSceneProperty = -1;
        RefreshInspector();
        return true;
    }

    /// @brief Verify one just-written scene property without string coercion.
    hide func ScenePropertyMatches(key: String,
                                   kind: String,
                                   stringValue: String,
                                   intValue: Integer,
                                   floatValue: Number,
                                   boolValue: Boolean) -> Boolean {
        if scene.Has(key) == false or scene.PropertyKind(key) != kind {
            return false;
        }
        if kind == "string" {
            return scene.GetStr(key, "") == stringValue;
        }
        if kind == "int" { return scene.GetInt(key, 0) == intValue; }
        if kind == "float" {
            var delta = scene.GetFloat(key, 0.0) - floatValue;
            if delta < 0.0 { delta = 0.0 - delta; }
            return delta < 0.000000000001;
        }
        if kind == "bool" {
            return scene.GetBool(key, false) == boolValue;
        }
        return kind == "null";
    }

    /// @brief Create, rename, or update one typed object property transactionally.
    expose func SetSceneObjectProperty(index: Integer,
                                       previousKey: String,
                                       key: String,
                                       kind: String,
                                       value: String) -> Boolean {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return false;
        }
        var nextKey = Str.Trim(key);
        if nextKey == "" {
            detailLabel.SetText("Property key cannot be empty.");
            return false;
        }
        if previousKey != nextKey and scene.ObjectHas(index, nextKey) {
            detailLabel.SetText(
                "Property \"" + nextKey + "\" already exists on this object.");
            return false;
        }

        var snapshot = scene.ToJson();
        var applied = false;
        if kind == "string" {
            scene.ObjectSetStr(index, nextKey, value);
            applied = scene.ObjectGetStr(index, nextKey, "") == value;
        } else if kind == "int" {
            var parsedInt = Parse.TryInt(Str.Trim(value));
            if parsedInt.IsNone {
                detailLabel.SetText("Enter a valid whole number.");
                return false;
            }
            var intValue = parsedInt.UnwrapI64();
            scene.ObjectSetInt(index, nextKey, intValue);
            applied = scene.ObjectGetInt(index, nextKey, 0) == intValue;
        } else if kind == "float" {
            var parsedFloat = Parse.TryDouble(Str.Trim(value));
            if parsedFloat.IsNone {
                detailLabel.SetText("Enter a valid finite number.");
                return false;
            }
            var floatValue = parsedFloat.UnwrapF64();
            scene.ObjectSetFloat(index, nextKey, floatValue);
            var floatDelta =
                scene.ObjectGetFloat(index, nextKey, 0.0) - floatValue;
            if floatDelta < 0.0 { floatDelta = 0.0 - floatDelta; }
            applied = floatDelta < 0.000000000001;
        } else if kind == "bool" {
            var parsedBool = Parse.TryBool(Str.Trim(value));
            if parsedBool.IsNone {
                detailLabel.SetText(
                    "Enter true/false, yes/no, on/off, or 1/0.");
                return false;
            }
            var boolValue = parsedBool.UnwrapI1();
            scene.ObjectSetBool(index, nextKey, boolValue);
            applied = scene.ObjectGetBool(index, nextKey, false) == boolValue;
        } else if kind == "null" {
            scene.ObjectSetNull(index, nextKey);
            applied = scene.ObjectPropertyKind(index, nextKey) == "null";
        } else {
            detailLabel.SetText("Choose a supported property type.");
            return false;
        }

        if applied == false or scene.ObjectHas(index, nextKey) == false
           or scene.ObjectPropertyKind(index, nextKey) != kind {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The property was rejected. Keys are limited to 128 bytes and "
                + "string values to 64 KiB.");
            return false;
        }
        if previousKey != "" and previousKey != nextKey {
            scene.ObjectRemove(index, previousKey);
        }
        if scene.ToJson() == snapshot {
            detailLabel.SetText("Property is already up to date.");
            return false;
        }
        selectedObject = index;
        selectedObjects = scene_selection.Single(
            index, scene.ObjectCount());
        if CommitScene("Updated property " + nextKey) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText("The property update could not be committed.");
            return false;
        }

        selectedObjectProperty = -1;
        detailLabel.SetText("");
        RefreshInspector();
        SelectObjectPropertyByKey(nextKey);
        return true;
    }

    /// @brief Remove one typed object property through the shared history path.
    expose func RemoveSceneObjectProperty(index: Integer,
                                          key: String) -> Boolean {
        if scene == null or index < 0 or index >= scene.ObjectCount()
           or scene.ObjectHas(index, key) == false {
            return false;
        }
        var snapshot = scene.ToJson();
        scene.ObjectRemove(index, key);
        if scene.ObjectHas(index, key) {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText("The scene model rejected the property removal.");
            return false;
        }
        selectedObject = index;
        selectedObjects = scene_selection.Single(
            index, scene.ObjectCount());
        selectedObjectProperty = -1;
        if CommitScene("Removed property " + key) == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText("The property removal could not be committed.");
            return false;
        }
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Set one typed property across the complete object selection.
    /// @details The value is parsed once, every selected object is verified,
    ///          and one canonical history snapshot covers the entire batch.
    expose func SetSelectedSceneObjectProperty(key: String,
                                               kind: String,
                                               value: String) -> Boolean {
        if scene == null { return false; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var count = selectedObjects.count();
        if count == 0 { return false; }
        var nextKey = Str.Trim(key);
        if nextKey == "" {
            detailLabel.SetText("Property key cannot be empty.");
            return false;
        }

        var intValue = 0;
        var floatValue = 0.0;
        var boolValue = false;
        if kind == "int" {
            var parsedInt = Parse.TryInt(Str.Trim(value));
            if parsedInt.IsNone {
                detailLabel.SetText("Enter a valid whole number.");
                return false;
            }
            intValue = parsedInt.UnwrapI64();
        } else if kind == "float" {
            var parsedFloat = Parse.TryDouble(Str.Trim(value));
            if parsedFloat.IsNone {
                detailLabel.SetText("Enter a valid finite number.");
                return false;
            }
            floatValue = parsedFloat.UnwrapF64();
        } else if kind == "bool" {
            var parsedBool = Parse.TryBool(Str.Trim(value));
            if parsedBool.IsNone {
                detailLabel.SetText(
                    "Enter true/false, yes/no, on/off, or 1/0.");
                return false;
            }
            boolValue = parsedBool.UnwrapI1();
        } else if kind != "string" and kind != "null" {
            detailLabel.SetText("Choose a supported property type.");
            return false;
        }

        var snapshot = scene.ToJson();
        var selectionIndex = 0;
        while selectionIndex < count {
            var objectIndex = selectedObjects.get(selectionIndex);
            if kind == "string" {
                scene.ObjectSetStr(objectIndex, nextKey, value);
            } else if kind == "int" {
                scene.ObjectSetInt(objectIndex, nextKey, intValue);
            } else if kind == "float" {
                scene.ObjectSetFloat(objectIndex, nextKey, floatValue);
            } else if kind == "bool" {
                scene.ObjectSetBool(objectIndex, nextKey, boolValue);
            } else {
                scene.ObjectSetNull(objectIndex, nextKey);
            }
            if BatchPropertyMatches(
                   objectIndex, nextKey, kind, value,
                   intValue, floatValue, boolValue) == false {
                RestoreSceneSnapshot(snapshot);
                detailLabel.SetText(
                    "The batch property was rejected. Keys are limited to "
                    + "128 bytes and string values to 64 KiB. "
                    + "No objects were changed.");
                return false;
            }
            selectionIndex = selectionIndex + 1;
        }
        if scene.ToJson() == snapshot {
            detailLabel.SetText(
                "Property is already up to date on every selected object.");
            return false;
        }
        if CommitScene(
               "Set " + nextKey + " on " + count + " objects") == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The batch property could not be committed. "
                + "No objects were changed.");
            return false;
        }
        selectedObjectProperty = -1;
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Remove one property from every selected object in one history row.
    expose func RemoveSelectedSceneObjectProperty(key: String) -> Boolean {
        if scene == null { return false; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var nextKey = Str.Trim(key);
        if selectedObjects.count() == 0 or nextKey == "" {
            detailLabel.SetText("Enter a property key to remove.");
            return false;
        }
        var snapshot = scene.ToJson();
        var removed = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedObjects.count() {
            var objectIndex = selectedObjects.get(selectionIndex);
            if scene.ObjectHas(objectIndex, nextKey) {
                scene.ObjectRemove(objectIndex, nextKey);
                if scene.ObjectHas(objectIndex, nextKey) {
                    RestoreSceneSnapshot(snapshot);
                    detailLabel.SetText(
                        "The batch property removal was rejected. "
                        + "No objects were changed.");
                    return false;
                }
                removed = removed + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if removed == 0 {
            detailLabel.SetText(
                "None of the selected objects has property \""
                + nextKey + "\".");
            return false;
        }
        if CommitScene(
               "Removed " + nextKey + " from " + removed + " objects")
           == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The batch property removal could not be committed. "
                + "No objects were changed.");
            return false;
        }
        selectedObjectProperty = -1;
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Add every missing field from one project component transactionally.
    /// @details Existing same-kind values are preserved. Any type conflict or
    ///          rejected write restores the complete scene before returning.
    expose func ApplySelectedComponent(
        component: scene_component_schema.SceneComponentDefinition)
        -> Boolean {
        if scene == null or component == null
           or component.SupportsTarget(
               scene_component_schema.TARGET_2D_OBJECT) == false {
            return false;
        }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        if selectedObjects.count() == 0 {
            detailLabel.SetText(
                "Select one or more objects before adding a component.");
            return false;
        }

        var missing = 0;
        var selectionIndex = 0;
        while selectionIndex < selectedObjects.count() {
            var objectIndex = selectedObjects.get(selectionIndex);
            var fieldIndex = 0;
            while fieldIndex < component.fields.count() {
                var field = component.fields.get(fieldIndex);
                if scene.ObjectHas(objectIndex, field.key) {
                    if scene.ObjectPropertyKind(objectIndex, field.key)
                       != field.kind {
                        detailLabel.SetText(
                            "Component \"" + component.label
                            + "\" conflicts with property \"" + field.key
                            + "\". No objects were changed.");
                        RefreshComponentPalette();
                        return false;
                    }
                } else {
                    missing = missing + 1;
                }
                fieldIndex = fieldIndex + 1;
            }
            selectionIndex = selectionIndex + 1;
        }
        if missing == 0 {
            detailLabel.SetText(
                "Component \"" + component.label
                + "\" is already complete on the selection.");
            RefreshComponentPalette();
            return false;
        }

        var snapshot = scene.ToJson();
        selectionIndex = 0;
        while selectionIndex < selectedObjects.count() {
            var objectIndex = selectedObjects.get(selectionIndex);
            var fieldIndex = 0;
            while fieldIndex < component.fields.count() {
                var field = component.fields.get(fieldIndex);
                if scene.ObjectHas(objectIndex, field.key) == false
                   and WriteObjectComponentField(objectIndex, field) == false {
                    RestoreSceneSnapshot(snapshot);
                    detailLabel.SetText(
                        "Component \"" + component.label
                        + "\" was rejected. No objects were changed.");
                    RefreshComponentPalette();
                    return false;
                }
                fieldIndex = fieldIndex + 1;
            }
            selectionIndex = selectionIndex + 1;
        }

        if CommitScene(
               "Added " + component.label + " to "
               + selectedObjects.count() + " object(s)") == false {
            RestoreSceneSnapshot(snapshot);
            detailLabel.SetText(
                "The component could not be committed. No objects were changed.");
            RefreshComponentPalette();
            return false;
        }
        selectedObjectProperty = -1;
        detailLabel.SetText(
            "Added " + missing + " missing field(s) from "
            + component.label + ".");
        RefreshInspector();
        return true;
    }

    /// @brief Write one already-validated schema default and verify exact kind.
    hide func WriteObjectComponentField(
        index: Integer,
        field: scene_component_schema.SceneComponentField) -> Boolean {
        var intValue = 0;
        var floatValue = 0.0;
        var boolValue = false;
        if field.kind == "string" {
            scene.ObjectSetStr(index, field.key, field.defaultText);
        } else if field.kind == "int" {
            var parsedInt = Parse.TryInt(field.defaultText);
            if parsedInt.IsNone { return false; }
            intValue = parsedInt.UnwrapI64();
            scene.ObjectSetInt(index, field.key, intValue);
        } else if field.kind == "float" {
            var parsedFloat = Parse.TryDouble(field.defaultText);
            if parsedFloat.IsNone { return false; }
            floatValue = parsedFloat.UnwrapF64();
            scene.ObjectSetFloat(index, field.key, floatValue);
        } else if field.kind == "bool" {
            var parsedBool = Parse.TryBool(field.defaultText);
            if parsedBool.IsNone { return false; }
            boolValue = parsedBool.UnwrapI1();
            scene.ObjectSetBool(index, field.key, boolValue);
        } else if field.kind == "null" {
            scene.ObjectSetNull(index, field.key);
        } else {
            return false;
        }
        return BatchPropertyMatches(
            index,
            field.key,
            field.kind,
            field.defaultText,
            intValue,
            floatValue,
            boolValue);
    }

    /// @brief Verify one just-written typed property without string coercion.
    hide func BatchPropertyMatches(index: Integer,
                                   key: String,
                                   kind: String,
                                   stringValue: String,
                                   intValue: Integer,
                                   floatValue: Number,
                                   boolValue: Boolean) -> Boolean {
        if scene.ObjectHas(index, key) == false
           or scene.ObjectPropertyKind(index, key) != kind {
            return false;
        }
        if kind == "string" {
            return scene.ObjectGetStr(index, key, "") == stringValue;
        }
        if kind == "int" {
            return scene.ObjectGetInt(index, key, 0) == intValue;
        }
        if kind == "float" {
            var delta =
                scene.ObjectGetFloat(index, key, 0.0) - floatValue;
            if delta < 0.0 { delta = 0.0 - delta; }
            return delta < 0.000000000001;
        }
        if kind == "bool" {
            return scene.ObjectGetBool(index, key, false) == boolValue;
        }
        return kind == "null";
    }

    /// @brief Replace the document with a bounded, undoable empty scene.
    expose func ReplaceScene(width: Integer,
                             height: Integer,
                             tileSize: Integer) -> Boolean {
        var nextWidth = ClampInt(width, 1, MAX_RENDER_CELLS_PER_AXIS);
        var nextHeight = ClampInt(height, 1, MAX_RENDER_CELLS_PER_AXIS);
        var nextTileSize = ClampInt(tileSize, 1, 512);
        scene = SceneDocument.New(nextWidth, nextHeight,
                                  nextTileSize, nextTileSize);
        if scene == null { return false; }
        loadError = "";
        activeLayer = 0;
        selectedObject = -1;
        selectedObjects = [];
        selectedObjectProperty = -1;
        selectedCellX = -1;
        selectedCellY = -1;
        SetEditorControlsEnabled(true);
        fitPending = true;
        var changed = CommitScene(
            "Created " + nextWidth + "x" + nextHeight + " scene");
        ReloadTilesets();
        detailLabel.SetText("");
        RefreshInspector();
        RefreshSceneSetupFields();
        return changed;
    }

    /// @brief Rename one scene layer through the canonical history path.
    expose func RenameSceneLayer(layer: Integer,
                                 name: String) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount() {
            return false;
        }
        var nextName = Str.Trim(name);
        if nextName == "" or scene.LayerName(layer) == nextName {
            return false;
        }
        scene.SetLayerName(layer, nextName);
        if scene.LayerName(layer) != nextName {
            detailLabel.SetText(
                "Layer names must fit the scene format's 31-byte limit.");
            return false;
        }
        activeLayer = layer;
        var changed = CommitScene("Renamed layer to " + nextName);
        detailLabel.SetText("");
        RefreshInspector();
        return changed;
    }

    /// @brief Validate and persist one external layer tileset reference.
    /// @details Empty paths clear the reference. Accepted changes create one
    ///          canonical history entry; invalid images leave JSON untouched.
    expose func ApplyLayerAssetPath(layer: Integer,
                                    assetPath: String) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount() {
            return false;
        }
        var nextPath = Str.Trim(assetPath);
        var previousPath = scene.LayerAsset(layer);
        if nextPath == previousPath { return false; }

        if nextPath != "" {
            var docPath = "";
            if currentDoc != null { docPath = currentDoc.filePath; }
            var candidate = tilesets.ValidateCandidateForLayer(
                layer, nextPath, docPath,
                scene.TileWidth, scene.TileHeight);
            if candidate.error != "" {
                toolbarStatus.SetText("Layer image not loaded");
                tilesetInspector.status.SetText(candidate.error);
                detailLabel.SetText(
                    "The layer image was not changed.\n\n" + candidate.error);
                GUI.Toast.Error("2D tileset image could not be loaded");
                return false;
            }
        }

        scene.SetLayerAsset(layer, nextPath);
        if scene.LayerAsset(layer) != nextPath {
            detailLabel.SetText("The scene model rejected the layer image path.");
            return false;
        }
        activeLayer = layer;
        var action = "Updated layer image";
        if nextPath == "" { action = "Cleared layer image"; }
        if CommitScene(action) == false {
            scene.SetLayerAsset(layer, previousPath);
            detailLabel.SetText("The layer image change could not be committed.");
            return false;
        }
        ReloadTilesets();
        detailLabel.SetText("");
        RefreshInspector();
        return true;
    }

    /// @brief Reload external layer pixels without changing scene history.
    expose func ReloadTilesetPreviews() {
        ReloadTilesets();
        RefreshTilesetPalette();
        var entry = tilesets.Entry(activeLayer);
        if entry != null and entry.error != "" {
            toolbarStatus.SetText("Layer image reload failed");
            detailLabel.SetText(entry.error);
        } else {
            toolbarStatus.SetText("Reloaded layer image previews");
            detailLabel.SetText("");
        }
    }

    /// @brief Quietly refresh externally changed layer images without history.
    /// @return True when metadata changed and the bounded preview was reloaded.
    expose func PollTilesetExternalChanges(intervalMs: Integer) -> Boolean {
        if scene == null or tilesets == null
           or tilesets.PollExternalChanges(intervalMs) == false {
            return false;
        }
        ReloadTilesets();
        RefreshTilesetPalette();
        var entry = tilesets.Entry(activeLayer);
        if entry != null and entry.error != "" {
            toolbarStatus.SetText("Layer image changed externally");
            detailLabel.SetText(entry.error);
        } else {
            toolbarStatus.SetText(
                "Layer image refreshed after external change");
            detailLabel.SetText("");
        }
        return true;
    }

    /// @brief Select one visible palette frame and enter Paint mode.
    expose func SelectPaletteTile(tileId: Integer) -> Boolean {
        if scene == null or tileId <= 0
           or tileId > tilesets.TileCount(activeLayer) {
            return false;
        }
        tileSpinner.SetValue(tileId);
        SetMode(MODE_PAINT);
        RefreshTilesetPalette();
        toolbarStatus.SetText("Selected tile " + tileId + " for painting");
        return true;
    }

    /// @brief Import one Tiled path transactionally without opening a dialog.
    /// @return True only when import and serialization both succeed.
    expose func ImportTiledPath(path: String) -> Boolean {
        if path == "" { return false; }
        var imported = SceneDocument.ImportTiledResult(path);
        if imported.IsOk == false {
            var message = imported.UnwrapErrStr();
            detailLabel.SetText("Tiled import failed:\n" + message);
            toolbarStatus.SetText("Import failed");
            GUI.Toast.Error("Tiled import failed: " + message);
            return false;
        }
        scene = imported.Unwrap() as SceneDocument;
        loadError = "";
        activeLayer = 0;
        selectedObject = -1;
        selectedObjects = [];
        selectedObjectProperty = -1;
        selectedCellX = -1;
        selectedCellY = -1;
        SetEditorControlsEnabled(true);
        fitPending = true;
        var changed = CommitScene("Imported " + Path.Name(path));
        ReloadTilesets();
        RefreshInspector();
        RefreshSceneSetupFields();
        return changed;
    }

    /// @brief Import a user-selected Tiled file transactionally.
    hide func ImportTiled() -> Boolean {
        var baseDir = "";
        if currentDoc != null and currentDoc.filePath != "" {
            baseDir = Path.Directory(currentDoc.filePath);
        }
        var path = GUI.FileDialog.Open(
            "Import Tiled Map", baseDir, "*.tmj;*.json;*.tmx");
        if path == "" { return false; }
        return ImportTiledPath(path);
    }

    /// @brief Serialize one accepted edit into the shared Document model.
    hide func CommitScene(message: String) -> Boolean {
        if scene == null or currentDoc == null { return false; }
        var serialized = scene.ToJson();
        if serialized == "" {
            detailLabel.SetText("Scene serialization failed; no document data changed.");
            return false;
        }
        if serialized == currentSerialized { return false; }
        PushHistory(undoStack, currentSerialized);
        redoStack = [];
        currentSerialized = serialized;
        currentDoc.content = serialized;
        currentDoc.isModified = serialized != cleanSerialized;
        revision = revision + 1;
        renderDirty = true;
        toolbarStatus.SetText(message);
        return true;
    }

    /// @brief Append one bounded canonical history snapshot.
    hide func PushHistory(stack: List[String], content: String) {
        if content == "" { return; }
        stack.add(content);
        if stack.count() > MAX_2D_SCENE_HISTORY { stack.removeAt(0); }
    }

    hide func SetMode(nextMode: Integer) {
        var normalizedMode = nextMode;
        if nextMode < MODE_SELECT or nextMode > MODE_PICKER {
            normalizedMode = MODE_SELECT;
        }
        if paintStrokeActive and normalizedMode != mode {
            CancelPaintStroke();
        }
        if tileRectangleActive and normalizedMode != MODE_RECTANGLE {
            CancelTileRectangle();
        }
        if canvasMarqueeActive and normalizedMode != MODE_SELECT {
            CancelCanvasMarquee();
        }
        mode = normalizedMode;
        lastPaintX = -1;
        lastPaintY = -1;
        UpdateModeButtons();
    }

    hide func UpdateModeButtons() {
        if selectButton == null { return; }
        selectButton.SetEnabled(editorControlsEnabled);
        paintButton.SetEnabled(editorControlsEnabled);
        eraseButton.SetEnabled(editorControlsEnabled);
        rectangleButton.SetEnabled(editorControlsEnabled);
        fillButton.SetEnabled(editorControlsEnabled);
        pickerButton.SetEnabled(editorControlsEnabled);
        objectButton.SetEnabled(editorControlsEnabled);
        selectButton.SetStyle(0);
        paintButton.SetStyle(0);
        eraseButton.SetStyle(0);
        rectangleButton.SetStyle(0);
        fillButton.SetStyle(0);
        pickerButton.SetStyle(0);
        objectButton.SetStyle(0);
        if mode == MODE_PAINT {
            paintButton.SetStyle(1);
        } else if mode == MODE_ERASE {
            eraseButton.SetStyle(1);
        } else if mode == MODE_RECTANGLE {
            rectangleButton.SetStyle(1);
        } else if mode == MODE_FILL {
            fillButton.SetStyle(1);
        } else if mode == MODE_PICKER {
            pickerButton.SetStyle(1);
        } else if mode == MODE_OBJECT {
            objectButton.SetStyle(1);
        } else {
            selectButton.SetStyle(1);
        }
    }

    hide func SetEditorControlsEnabled(enabled: Boolean) {
        if selectButton == null { return; }
        editorControlsEnabled = enabled;
        UpdateModeButtons();
        tileSpinner.SetEnabled(enabled);
        zoomOutButton.SetEnabled(enabled);
        zoomInButton.SetEnabled(enabled);
        fitButton.SetEnabled(enabled);
        addLayerButton.SetEnabled(enabled);
        removeLayerButton.SetEnabled(enabled);
        layerUpButton.SetEnabled(enabled);
        layerDownButton.SetEnabled(enabled);
        layerVisibleCheck.SetEnabled(enabled);
        layerNameInput.SetEnabled(enabled);
        layerAssetInput.SetEnabled(enabled);
        chooseLayerAssetButton.SetEnabled(enabled);
        sceneProperties.SetEnabled(enabled);
        tilesetInspector.SetEnabled(enabled);
        hierarchySearchInput.SetEnabled(enabled);
        objectTree.SetEnabled(enabled);
        addObjectButton.SetEnabled(enabled);
        addChildObjectButton.SetEnabled(enabled);
        applyObjectButton.SetEnabled(enabled);
        removeObjectButton.SetEnabled(enabled);
        objectParentDropdown.SetEnabled(enabled);
        reparentObjectButton.SetEnabled(enabled);
        duplicateObjectButton.SetEnabled(enabled);
        objectUpButton.SetEnabled(enabled);
        objectDownButton.SetEnabled(enabled);
        objectArrangeDropdown.SetEnabled(enabled);
        arrangeObjectButton.SetEnabled(enabled);
        objectPropertyList.SetEnabled(enabled);
        objectPropertyKeyInput.SetEnabled(enabled);
        objectPropertyTypeDropdown.SetEnabled(enabled);
        objectPropertyValueInput.SetEnabled(enabled);
        newObjectPropertyButton.SetEnabled(enabled);
        setObjectPropertyButton.SetEnabled(enabled);
        removeObjectPropertyButton.SetEnabled(enabled);
        objectTypeInput.SetEnabled(enabled);
        objectIdInput.SetEnabled(enabled);
        objectXSpinner.SetEnabled(enabled);
        objectYSpinner.SetEnabled(enabled);
        UpdateHierarchySearchControls();
    }

    /// @brief Rebuild bounded inspector rows from the active model.
    hide func RefreshInspector() {
        layerList.Clear();
        sceneProperties.Refresh(
            scene, editorControlsEnabled, selectedSceneProperty);
        selectedSceneProperty = sceneProperties.selectedProperty;
        if scene == null {
            selectedObject = -1;
            selectedObjects = [];
            selectedObjectProperty = -1;
            selectedSceneProperty = -1;
            RefreshObjectTree();
            RefreshObjectFields();
            sceneInfoLabel.SetText("Invalid 2D scene");
            toolbarStatus.SetText("Scene JSON needs attention");
            return;
        }

        sceneInfoLabel.SetText(
            scene.Width + " x " + scene.Height
            + " tiles  |  tile " + scene.TileWidth + " x " + scene.TileHeight
            + "  |  " + scene.LayerCount() + " layer(s)"
            + "  |  " + scene.ObjectCount() + " object(s)");

        var layerCount = scene.LayerCount();
        if activeLayer < 0 or activeLayer >= layerCount { activeLayer = 0; }
        var i = 0;
        while i < layerCount {
            var marker = "[ ] ";
            if scene.LayerVisible(i) { marker = "[x] "; }
            layerList.AddItem(marker + scene.LayerName(i));
            i = i + 1;
        }
        if layerCount > 0 { layerList.SelectIndex(activeLayer); }
        RefreshLayerFields();

        RefreshObjectTree();
        RefreshObjectFields();
    }

    hide func StringListContains(values: List[String],
                                 value: String) -> Boolean {
        var index = 0;
        while index < values.count() {
            if values.get(index) == value { return true; }
            index = index + 1;
        }
        return false;
    }

    /// @brief Snapshot expansion before replacing retained object rows.
    hide func CaptureObjectTreeExpansion() {
        objectExpandedIds = [];
        objectExpandedPaths = [];
        var sameDocument =
            currentDoc != null and objectTreeDocument == currentDoc;
        objectTreeExpandByDefault =
            objectTreeNodes.count() == 0 or sameDocument == false;
        if sameDocument == false { return; }
        var index = 0;
        while index < objectTreeNodes.count()
              and index < objectTreeIds.count()
              and index < objectTreePaths.count() {
            var treeNode = objectTreeNodes.get(index);
            if treeNode != null
               and GUI.TreeView.Node.IsExpanded(treeNode) {
                var objectId = objectTreeIds.get(index);
                if objectId != "" { objectExpandedIds.add(objectId); }
                objectExpandedPaths.add(objectTreePaths.get(index));
            }
            index = index + 1;
        }
    }

    /// @brief Return a bounded structural depth, with roots at depth zero.
    hide func ObjectHierarchyDepth(index: Integer) -> Integer {
        if scene == null or index < 0 or index >= scene.ObjectCount() {
            return MAX_OBJECT_HIERARCHY_DEPTH + 1;
        }
        var depth = 0;
        var current = index;
        var steps = 0;
        while current >= 0 and steps <= MAX_OBJECT_HIERARCHY_DEPTH {
            var parent = scene.ObjectParent(current);
            if parent < 0 { return depth; }
            depth = depth + 1;
            steps = steps + 1;
            current = parent;
        }
        return MAX_OBJECT_HIERARCHY_DEPTH + 1;
    }

    /// @brief Return whether ancestor contains candidate in the live hierarchy.
    hide func ObjectHierarchyContains(ancestor: Integer,
                                      candidate: Integer) -> Boolean {
        if scene == null or ancestor < 0 or candidate < 0
           or ancestor >= scene.ObjectCount()
           or candidate >= scene.ObjectCount() {
            return false;
        }
        var current = candidate;
        var steps = 0;
        while current >= 0 and steps <= scene.ObjectCount() {
            if current == ancestor { return true; }
            current = scene.ObjectParent(current);
            steps = steps + 1;
        }
        return false;
    }

    hide func ShouldExpandObjectNode(index: Integer,
                                     objectId: String,
                                     path: String) -> Boolean {
        var selectionIndex = 0;
        while selectionIndex < selectedObjects.count() {
            if ObjectHierarchyContains(
                   index, selectedObjects.get(selectionIndex)) {
                return true;
            }
            selectionIndex = selectionIndex + 1;
        }
        if objectTreeExpandByDefault { return true; }
        if objectId != ""
           and StringListContains(objectExpandedIds, objectId) {
            return true;
        }
        return StringListContains(objectExpandedPaths, path);
    }

    /// @brief Rebuild a bounded retained parent/child presentation.
    /// @details Depth and row limits protect the UI while preserving every
    ///          object in canonical scene data.
    hide func RefreshObjectTree() {
        if objectTree == null { return; }
        CaptureObjectTreeExpansion();
        objectTreeNodes = [];
        objectTreeIds = [];
        objectTreePaths = [];
        objectHierarchyClipped = false;
        objectTree.Clear();
        objectTree.PruneRetiredNodes();

        if scene == null {
            objectHierarchyStatus.SetText("");
            objectTreeDocument = currentDoc;
            RefreshHierarchySearch(false);
            return;
        }

        var objectCount = scene.ObjectCount();
        if selectedObject >= objectCount { selectedObject = -1; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, objectCount, selectedObject);
        if selectedObject < 0 and selectedObjects.count() > 0 {
            selectedObject = selectedObjects.get(0);
        }

        var visibleCount = objectCount;
        if visibleCount > MAX_OBJECT_TREE_ROWS {
            visibleCount = MAX_OBJECT_TREE_ROWS;
            objectHierarchyClipped = true;
        }
        var depths: List[Integer] = [];
        var hasChildren: List[Boolean] = [];
        var index = 0;
        while index < visibleCount {
            objectTreeNodes.add(null);
            objectTreeIds.add(scene.ObjectId(index));
            objectTreePaths.add("");
            depths.add(ObjectHierarchyDepth(index));
            hasChildren.add(false);
            index = index + 1;
        }
        index = 0;
        while index < objectCount {
            var parent = scene.ObjectParent(index);
            if parent >= 0 and parent < visibleCount {
                hasChildren.set(parent, true);
            }
            index = index + 1;
        }

        var rowCount = 0;
        var depth = 0;
        while depth <= MAX_OBJECT_HIERARCHY_DEPTH
              and rowCount < MAX_OBJECT_TREE_ROWS {
            index = 0;
            while index < visibleCount
                  and rowCount < MAX_OBJECT_TREE_ROWS {
                if depths.get(index) == depth {
                    var parentIndex = scene.ObjectParent(index);
                    var parentTreeNode: Any = null;
                    var path = Fmt.Int(index);
                    var canAppend = parentIndex < 0;
                    if parentIndex >= 0 and parentIndex < visibleCount
                       and objectTreeNodes.get(parentIndex) != null {
                        parentTreeNode = objectTreeNodes.get(parentIndex);
                        path = objectTreePaths.get(parentIndex)
                            + "/" + Fmt.Int(index);
                        canAppend = true;
                    }
                    if canAppend {
                        var objectId = scene.ObjectId(index);
                        var displayId = objectId;
                        if displayId == "" { displayId = "(unnamed)"; }
                        var treeNode = objectTree.AddNode(
                            parentTreeNode,
                            displayId + "  :  " + scene.ObjectType(index)
                            + "  @ " + scene.ObjectX(index)
                            + ", " + scene.ObjectY(index));
                        if treeNode == null {
                            objectHierarchyClipped = true;
                        } else {
                            GUI.TreeView.Node.SetData(
                                treeNode, Fmt.Int(index));
                            GUI.TreeView.Node.SetStableId(
                                treeNode, objectId + "|" + path);
                            objectTreeNodes.set(index, treeNode);
                            objectTreePaths.set(index, path);
                            rowCount = rowCount + 1;
                        }
                    } else {
                        objectHierarchyClipped = true;
                    }
                } else if depths.get(index)
                          > MAX_OBJECT_HIERARCHY_DEPTH {
                    objectHierarchyClipped = true;
                }
                index = index + 1;
            }
            depth = depth + 1;
        }

        index = 0;
        while index < visibleCount {
            var node = objectTreeNodes.get(index);
            if node != null {
                var icon = "◇";
                if hasChildren.get(index) { icon = "◆"; }
                GUI.TreeView.Node.SetIcon(node, icon);
                if hasChildren.get(index)
                   and ShouldExpandObjectNode(
                       index,
                       objectTreeIds.get(index),
                       objectTreePaths.get(index)) {
                    objectTree.Expand(node);
                }
            }
            index = index + 1;
        }

        if rowCount < objectCount { objectHierarchyClipped = true; }
        if objectHierarchyClipped {
            objectHierarchyStatus.SetText(
                "Hierarchy view is bounded to "
                + MAX_OBJECT_TREE_ROWS + " rows and depth "
                + MAX_OBJECT_HIERARCHY_DEPTH
                + "; hidden objects remain preserved in the scene.");
        } else {
            objectHierarchyStatus.SetText("");
        }
        objectTreeDocument = currentDoc;
        RestoreObjectTreeSelection();
        RefreshHierarchySearch(false);
        objectExpandedIds = [];
        objectExpandedPaths = [];
    }

    /// @brief Route scene-wide metadata drafts into canonical transactions.
    hide func PumpScenePropertyControls() -> Boolean {
        if scene == null { return false; }
        sceneProperties.Pump(scene);
        selectedSceneProperty = sceneProperties.selectedProperty;
        var setRequested = sceneProperties.TakeSetRequested();
        var removeRequested = sceneProperties.TakeRemoveRequested();
        var changed = false;
        if setRequested {
            changed = SetSceneProperty(
                sceneProperties.SelectedKey(),
                sceneProperties.keyInput.Text,
                sceneProperties.SelectedKind(),
                sceneProperties.valueInput.Text);
        }
        if removeRequested {
            changed = RemoveSceneProperty(
                sceneProperties.SelectedKey()) or changed;
        }
        return changed;
    }

    /// @brief Reveal the retained ancestors of one programmatic selection.
    hide func ExpandObjectTreeAncestors(index: Integer) {
        if scene == null or objectTree == null
           or index < 0 or index >= scene.ObjectCount() {
            return;
        }
        var parent = scene.ObjectParent(index);
        var steps = 0;
        while parent >= 0 and steps <= scene.ObjectCount() {
            if parent < objectTreeNodes.count()
               and objectTreeNodes.get(parent) != null {
                objectTree.Expand(objectTreeNodes.get(parent));
            }
            parent = scene.ObjectParent(parent);
            steps = steps + 1;
        }
    }

    /// @brief Restore every validated hierarchy row while keeping one primary.
    hide func RestoreObjectTreeSelection() {
        if objectTree == null { return; }
        objectTree.Select(null);
        var index = 0;
        while index < selectedObjects.count() {
            var selected = selectedObjects.get(index);
            if selected != selectedObject
               and selected >= 0 and selected < objectTreeNodes.count()
               and objectTreeNodes.get(selected) != null {
                objectTree.Select(objectTreeNodes.get(selected));
            }
            index = index + 1;
        }
        if selectedObject >= 0
           and selectedObject < objectTreeNodes.count()
           and objectTreeNodes.get(selectedObject) != null {
            objectTree.Select(objectTreeNodes.get(selectedObject));
        }
    }

    /// @brief Resolve the selected dropdown row to one object parent identity.
    hide func SelectedObjectParentTargetIndex() -> Integer {
        if objectParentDropdown == null
           or objectParentDropdown.Selected < 0
           or objectParentDropdown.Selected
              >= objectParentTargetIndices.count() {
            return OBJECT_PARENT_TARGET_MIXED;
        }
        return objectParentTargetIndices.get(
            objectParentDropdown.Selected);
    }

    /// @brief Select one currently offered parent without changing scene data.
    /// @details Probe and command callers use this instead of synthesizing a
    ///          platform-specific native dropdown click.
    expose func SelectObjectParentTarget(
        targetIndex: Integer) -> Boolean {
        if objectParentDropdown == null { return false; }
        var option = 0;
        while option < objectParentTargetIndices.count() {
            if objectParentTargetIndices.get(option) == targetIndex {
                objectParentDropdown.SetSelected(option);
                UpdateObjectParentControlAvailability();
                return true;
            }
            option = option + 1;
        }
        return false;
    }

    /// @brief Rebuild bounded, cycle-safe parent choices for the selection.
    hide func RefreshObjectParentTargets() {
        if objectParentDropdown == null
           or reparentObjectButton == null {
            return;
        }
        objectParentDropdown.Clear();
        objectParentTargetIndices = [];
        if scene == null or selectedObjects.count() == 0 {
            objectParentDropdown.SetPlaceholder("Select an object");
            objectParentDropdown.SetEnabled(false);
            reparentObjectButton.SetEnabled(false);
            reparentObjectButton.SetText("Reparent");
            return;
        }

        var parents = SnapshotObjectParents();
        var roots = TopLevelSelectedObjectRoots(parents);
        if roots.count() == 0 {
            objectParentDropdown.SetPlaceholder("Select an object");
            objectParentDropdown.SetEnabled(false);
            reparentObjectButton.SetEnabled(false);
            return;
        }
        var owners = SelectedRootOwners(parents, roots);
        var depths = IdentityDepths(parents);
        var commonParent = parents.get(roots.get(0));
        var mixedParents = false;
        var rootIndex = 1;
        while rootIndex < roots.count() {
            if parents.get(roots.get(rootIndex)) != commonParent {
                mixedParents = true;
            }
            rootIndex = rootIndex + 1;
        }

        var selectedOption = -1;
        if mixedParents {
            selectedOption = objectParentDropdown.AddItem(
                "Multiple parents — choose target");
            objectParentTargetIndices.add(
                OBJECT_PARENT_TARGET_MIXED);
        }
        if ObjectDropFitsKnownDepths(-1, depths, owners) {
            var rootOption =
                objectParentDropdown.AddItem("Scene root");
            objectParentTargetIndices.add(-1);
            if mixedParents == false and commonParent < 0 {
                selectedOption = rootOption;
            }
        }

        var candidateLimit = scene.ObjectCount();
        if candidateLimit > MAX_OBJECT_TREE_ROWS {
            candidateLimit = MAX_OBJECT_TREE_ROWS;
        }
        var candidate = 0;
        while candidate < candidateLimit {
            if owners.get(candidate) < 0
               and ObjectDropFitsKnownDepths(
                       candidate, depths, owners) {
                var prefix = "";
                var depth = ObjectHierarchyDepth(candidate);
                var indent = 0;
                while indent < depth and indent < 16 {
                    prefix = prefix + "  ";
                    indent = indent + 1;
                }
                var displayId = scene.ObjectId(candidate);
                if displayId == "" { displayId = "(unnamed)"; }
                var option = objectParentDropdown.AddItem(
                    prefix + displayId + " : "
                    + scene.ObjectType(candidate));
                objectParentTargetIndices.add(candidate);
                if mixedParents == false
                   and commonParent == candidate {
                    selectedOption = option;
                }
            }
            candidate = candidate + 1;
        }

        if selectedOption < 0
           and objectParentTargetIndices.count() > 0 {
            selectedOption = 0;
        }
        if selectedOption >= 0 {
            objectParentDropdown.SetSelected(selectedOption);
        }
        var placeholder = "Choose parent";
        if scene.ObjectCount() > candidateLimit {
            placeholder = "Choose parent (bounded hierarchy view)";
        }
        objectParentDropdown.SetPlaceholder(placeholder);
        UpdateObjectParentControlAvailability();
    }

    /// @brief Enable explicit reparenting only for a changed valid target.
    hide func UpdateObjectParentControlAvailability() {
        if objectParentDropdown == null
           or reparentObjectButton == null {
            return;
        }
        var available = false;
        var rootCount = 0;
        if scene != null and selectedObjects.count() > 0 {
            var parents = SnapshotObjectParents();
            var roots = TopLevelSelectedObjectRoots(parents);
            rootCount = roots.count();
            var owners = SelectedRootOwners(parents, roots);
            var depths = IdentityDepths(parents);
            var target = SelectedObjectParentTargetIndex();
            var targetValid = target == -1
                or (target >= 0 and target < scene.ObjectCount());
            var targetOutsideSelection = target < 0
                or owners.get(target) < 0;
            var alreadyParented = roots.count() > 0;
            var rootIndex = 0;
            while rootIndex < roots.count() {
                if parents.get(roots.get(rootIndex)) != target {
                    alreadyParented = false;
                }
                rootIndex = rootIndex + 1;
            }
            available = roots.count() > 0
                and targetValid
                and targetOutsideSelection
                and ObjectDropFitsKnownDepths(
                        target, depths, owners)
                and alreadyParented == false;
        }
        objectParentDropdown.SetEnabled(
            rootCount > 0 and objectParentTargetIndices.count() > 0);
        reparentObjectButton.SetEnabled(available);
        reparentObjectButton.SetText("Reparent");
        if rootCount > 1 {
            reparentObjectButton.SetText(
                "Reparent (" + rootCount + ")");
        }
        reparentObjectButton.SetTooltip(
            "Move " + rootCount
            + " selected top-level subtree(s) beneath the chosen parent; "
            + "absolute positions stay unchanged");
    }

    hide func RefreshLayerFields() {
        if scene == null or activeLayer < 0
           or activeLayer >= scene.LayerCount() {
            layerVisibleCheck.SetChecked(false);
            layerVisibleRevision = layerVisibleCheck.GetRevision();
            layerNameInput.SetText("");
            layerAssetInput.SetText("");
            RefreshTilesetPalette();
            return;
        }
        layerVisibleCheck.SetChecked(scene.LayerVisible(activeLayer));
        layerVisibleRevision = layerVisibleCheck.GetRevision();
        layerNameInput.SetText(scene.LayerName(activeLayer));
        layerAssetInput.SetText(scene.LayerAsset(activeLayer));
        RefreshTilesetPalette();
    }

    /// @brief Reload bounded image previews after scene/path/asset changes.
    hide func ReloadTilesets() {
        if tilesets == null { return; }
        var docPath = "";
        if currentDoc != null { docPath = currentDoc.filePath; }
        tilesets.Reload(scene, docPath);
        tilesetDocumentPath = docPath;
        renderDirty = true;
    }

    /// @brief Refresh the active layer's scrollable visual tile chooser.
    hide func RefreshTilesetPalette() {
        if tilesetInspector == null or tileSpinner == null { return; }
        tilesetInspector.Refresh(
            tilesets,
            activeLayer,
            Convert.NumToInt(tileSpinner.Value));
    }

    /// @brief Route a palette click into the same tile selection as the spinner.
    hide func PumpTilesetPalette() {
        if tilesetInspector == null { return; }
        var tileId =
            tilesetInspector.TakeSelectedTile(tilesets, activeLayer);
        if tileId > 0 { SelectPaletteTile(tileId); }
    }

    hide func RefreshObjectFields() {
        var objectCount = 0;
        if scene != null { objectCount = scene.ObjectCount(); }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, objectCount, selectedObject);
        var hasSelection = scene != null and selectedObject >= 0
            and selectedObject < objectCount
            and selectedObjects.count() > 0;
        var hasSingle = hasSelection and selectedObjects.count() == 1;
        addChildObjectButton.SetEnabled(hasSingle);
        applyObjectButton.SetEnabled(hasSingle);
        removeObjectButton.SetEnabled(hasSelection);
        duplicateObjectButton.SetEnabled(hasSelection);
        objectUpButton.SetEnabled(
            hasSingle and PreviousObjectSibling(selectedObject) >= 0);
        objectDownButton.SetEnabled(
            hasSingle and NextObjectSibling(selectedObject) >= 0);
        objectTypeInput.SetEnabled(hasSingle);
        objectIdInput.SetEnabled(hasSingle);
        objectXSpinner.SetEnabled(hasSingle);
        objectYSpinner.SetEnabled(hasSingle);
        RefreshObjectParentTargets();
        RefreshObjectArrangeControls(hasSelection);
        removeObjectButton.SetText("Remove");
        duplicateObjectButton.SetText("Duplicate");
        objectTypeInput.SetPlaceholder("Object type");
        objectIdInput.SetPlaceholder("Object id");
        if hasSingle == false {
            objectTypeInput.SetText("");
            objectIdInput.SetText("");
            objectXSpinner.SetValue(0.0);
            objectYSpinner.SetValue(0.0);
            selectedObjectProperty = -1;
            if hasSelection {
                removeObjectButton.SetText(
                    "Remove (" + selectedObjects.count() + ")");
                duplicateObjectButton.SetText(
                    "Duplicate (" + selectedObjects.count() + ")");
                objectTypeInput.SetPlaceholder(
                    selectedObjects.count() + " objects selected");
                objectIdInput.SetPlaceholder(
                    "Single-object fields disabled for group selection");
            }
            RefreshObjectProperties();
            RefreshComponentPalette();
            return;
        }
        objectTypeInput.SetText(scene.ObjectType(selectedObject));
        objectIdInput.SetText(scene.ObjectId(selectedObject));
        objectXSpinner.SetValue(scene.ObjectX(selectedObject));
        objectYSpinner.SetValue(scene.ObjectY(selectedObject));
        RefreshObjectProperties();
        RefreshComponentPalette();
    }

    /// @brief Summarize selected-object coverage for the active component.
    hide func RefreshComponentPalette() {
        if componentPalette == null or componentPalette.group == null {
            return;
        }
        var objectCount = 0;
        if scene != null { objectCount = scene.ObjectCount(); }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, objectCount, selectedObject);
        var component = componentPalette.SelectedComponent();
        var enabled = scene != null and selectedObjects.count() > 0
            and component != null;
        var present = 0;
        var missing = 0;
        var conflicts = 0;
        if enabled {
            var selectionIndex = 0;
            while selectionIndex < selectedObjects.count() {
                var objectIndex = selectedObjects.get(selectionIndex);
                var fieldIndex = 0;
                while fieldIndex < component.fields.count() {
                    var field = component.fields.get(fieldIndex);
                    if scene.ObjectHas(objectIndex, field.key) == false {
                        missing = missing + 1;
                    } else if scene.ObjectPropertyKind(
                                  objectIndex, field.key) == field.kind {
                        present = present + 1;
                    } else {
                        conflicts = conflicts + 1;
                    }
                    fieldIndex = fieldIndex + 1;
                }
                selectionIndex = selectionIndex + 1;
            }
        }
        componentPalette.SetContext(
            enabled, present, missing, conflicts);
    }

    /// @brief Copy one schema field into the raw typed-property controls.
    /// @details A matching single-object value is retained for editing;
    ///          otherwise the schema default becomes the draft.
    expose func EditSelectedComponentField() -> Boolean {
        if scene == null or componentPalette == null { return false; }
        selectedObjects = scene_selection.Normalize(
            selectedObjects, scene.ObjectCount(), selectedObject);
        var field = componentPalette.SelectedField();
        if field == null or selectedObjects.count() == 0 { return false; }

        var value = field.defaultText;
        selectedObjectProperty = -1;
        objectPropertyList.SelectIndex(-1);
        if selectedObjects.count() == 1 and selectedObject >= 0
           and selectedObject < scene.ObjectCount()
           and scene.ObjectHas(selectedObject, field.key) {
            var index = 0;
            while index < objectPropertyKeys.count() {
                if objectPropertyKeys.get(index) == field.key {
                    selectedObjectProperty = index;
                    objectPropertyList.SelectIndex(index);
                    break;
                }
                index = index + 1;
            }
            if scene.ObjectPropertyKind(selectedObject, field.key)
               == field.kind {
                value = PropertyValueText(
                    selectedObject, field.key, field.kind);
            }
        }

        objectPropertyKeyInput.SetText(field.key);
        SelectPropertyType(field.kind);
        objectPropertyValueInput.SetText(value);
        UpdatePropertyValueControl();
        if field.kind == "null" {
            objectPropertyKeyInput.Focus();
        } else {
            objectPropertyValueInput.Focus();
        }
        detailLabel.SetText(
            "Editing " + field.label
            + " in the raw typed-property controls.");
        return true;
    }

    /// @brief Keep multi-object layout affordances selection-count truthful.
    hide func RefreshObjectArrangeControls(hasSelection: Boolean) {
        if objectArrangeDropdown == null or arrangeObjectButton == null {
            return;
        }
        var operation = objectArrangeDropdown.Selected;
        var minimum = scene_layout_2d.MinimumSelection(operation);
        var available = hasSelection
            and selectedObjects.count() >= minimum;
        objectArrangeDropdown.SetEnabled(
            hasSelection and selectedObjects.count() >= 2);
        arrangeObjectButton.SetEnabled(available);
        arrangeObjectButton.SetText("Arrange");
        if available {
            arrangeObjectButton.SetText(
                "Arrange (" + selectedObjects.count() + ")");
        }
        arrangeObjectButton.SetTooltip(
            scene_layout_2d.OperationLabel(operation)
            + " as one undoable selection edit; needs "
            + minimum + " selected objects");
    }

    hide func RefreshObjectProperties() {
        objectPropertyList.Clear();
        objectPropertyKeys = [];
        var hasSelection = scene != null and selectedObject >= 0
            and selectedObject < scene.ObjectCount()
            and selectedObjects.count() > 0;
        var hasObject = hasSelection and selectedObjects.count() == 1;
        var hasBatch = hasSelection and selectedObjects.count() > 1;
        objectPropertyList.SetEnabled(hasObject);
        newObjectPropertyButton.SetEnabled(hasSelection);
        setObjectPropertyButton.SetEnabled(hasSelection);
        objectPropertyKeyInput.SetEnabled(hasSelection);
        objectPropertyTypeDropdown.SetEnabled(hasSelection);
        if hasBatch {
            objectPropertyList.AddItem(
                "Batch edit " + selectedObjects.count()
                + " selected objects");
            selectedObjectProperty = -1;
            RefreshObjectPropertyFields();
            return;
        }
        if hasObject == false {
            selectedObjectProperty = -1;
            RefreshObjectPropertyFields();
            return;
        }

        var keys = scene.ObjectKeys(selectedObject);
        var total = Seq.get_Count(keys);
        var visible = total;
        if visible > MAX_INSPECTOR_PROPERTIES {
            visible = MAX_INSPECTOR_PROPERTIES;
        }
        var index = 0;
        while index < visible {
            var key = Seq.GetStr(keys, index);
            var kind = scene.ObjectPropertyKind(selectedObject, key);
            objectPropertyKeys.add(key);
            objectPropertyList.AddItem(
                key + "  [" + kind + "] = "
                + PropertyPreview(PropertyValueText(
                    selectedObject, key, kind), kind));
            index = index + 1;
        }
        if total > visible {
            objectPropertyList.AddItem(
                "… " + (total - visible) + " more properties not shown");
        }
        if selectedObjectProperty >= objectPropertyKeys.count() {
            selectedObjectProperty = -1;
        }
        if selectedObjectProperty >= 0 {
            objectPropertyList.SelectIndex(selectedObjectProperty);
        }
        RefreshObjectPropertyFields();
    }

    hide func RefreshObjectPropertyFields() {
        var hasSelection = scene != null and selectedObject >= 0
            and selectedObject < scene.ObjectCount()
            and selectedObjects.count() > 0;
        var hasObject = hasSelection and selectedObjects.count() == 1;
        var hasBatch = hasSelection and selectedObjects.count() > 1;
        var hasProperty = hasObject and selectedObjectProperty >= 0
            and selectedObjectProperty < objectPropertyKeys.count();
        removeObjectPropertyButton.SetText("Remove");
        setObjectPropertyButton.SetText("Set");
        removeObjectPropertyButton.SetEnabled(hasProperty or hasBatch);
        objectPropertyKeyInput.SetEnabled(hasSelection);
        objectPropertyTypeDropdown.SetEnabled(hasSelection);
        setObjectPropertyButton.SetEnabled(hasSelection);
        if hasBatch {
            var count = selectedObjects.count();
            setObjectPropertyButton.SetText("Set on " + count);
            removeObjectPropertyButton.SetText("Remove from " + count);
            objectPropertyKeyInput.SetText("");
            objectPropertyKeyInput.SetPlaceholder(
                "Property key for " + count + " objects");
            objectPropertyTypeDropdown.SetSelected(PROPERTY_TYPE_STRING);
            objectPropertyValueInput.SetText("");
            objectPropertyValueInput.SetPlaceholder("Shared property value");
            objectPropertyValueInput.SetEnabled(true);
            return;
        }
        objectPropertyKeyInput.SetPlaceholder("Property key");
        if hasProperty == false {
            objectPropertyKeyInput.SetText("");
            objectPropertyTypeDropdown.SetSelected(PROPERTY_TYPE_STRING);
            objectPropertyValueInput.SetText("");
            objectPropertyValueInput.SetPlaceholder("Property value");
            objectPropertyValueInput.SetEnabled(hasSelection);
            return;
        }

        var key = objectPropertyKeys.get(selectedObjectProperty);
        var kind = scene.ObjectPropertyKind(selectedObject, key);
        objectPropertyKeyInput.SetText(key);
        SelectPropertyType(kind);
        objectPropertyValueInput.SetText(
            PropertyValueText(selectedObject, key, kind));
        UpdatePropertyValueControl();
    }

    hide func PropertyValueText(index: Integer,
                                key: String,
                                kind: String) -> String {
        if kind == "string" { return scene.ObjectGetStr(index, key, ""); }
        if kind == "int" {
            return Fmt.Int(scene.ObjectGetInt(index, key, 0));
        }
        if kind == "float" {
            return Fmt.Num(scene.ObjectGetFloat(index, key, 0.0));
        }
        if kind == "bool" {
            return Fmt.Bool(scene.ObjectGetBool(index, key, false));
        }
        if kind == "null" { return ""; }
        return "";
    }

    hide func PropertyPreview(value: String, kind: String) -> String {
        if kind == "null" { return "null"; }
        var preview = Str.Replace(
            Str.Replace(value, "\r", "\\r"), "\n", "\\n");
        if Str.get_Length(preview) > 72 {
            preview = Str.Left(preview, 69) + "...";
        }
        if kind == "string" { return "\"" + preview + "\""; }
        return preview;
    }

    hide func PropertyKindFromDropdown() -> String {
        if objectPropertyTypeDropdown.Selected == PROPERTY_TYPE_INT {
            return "int";
        }
        if objectPropertyTypeDropdown.Selected == PROPERTY_TYPE_FLOAT {
            return "float";
        }
        if objectPropertyTypeDropdown.Selected == PROPERTY_TYPE_BOOL {
            return "bool";
        }
        if objectPropertyTypeDropdown.Selected == PROPERTY_TYPE_NULL {
            return "null";
        }
        return "string";
    }

    hide func SelectPropertyType(kind: String) {
        var selected = PROPERTY_TYPE_STRING;
        if kind == "int" { selected = PROPERTY_TYPE_INT; }
        if kind == "float" { selected = PROPERTY_TYPE_FLOAT; }
        if kind == "bool" { selected = PROPERTY_TYPE_BOOL; }
        if kind == "null" { selected = PROPERTY_TYPE_NULL; }
        objectPropertyTypeDropdown.SetSelected(selected);
    }

    hide func UpdatePropertyValueControl() {
        var isNull = PropertyKindFromDropdown() == "null";
        objectPropertyValueInput.SetEnabled(isNull == false);
        if isNull {
            objectPropertyValueInput.SetText("");
            objectPropertyValueInput.SetPlaceholder("Null has no value");
        } else {
            objectPropertyValueInput.SetPlaceholder("Property value");
        }
    }

    hide func SelectObjectPropertyByKey(key: String) {
        var index = 0;
        while index < objectPropertyKeys.count() {
            if objectPropertyKeys.get(index) == key {
                selectedObjectProperty = index;
                objectPropertyList.SelectIndex(index);
                RefreshObjectPropertyFields();
                return;
            }
            index = index + 1;
        }
        selectedObjectProperty = -1;
        RefreshObjectPropertyFields();
    }

    hide func RestoreSceneSnapshot(snapshot: String) {
        var restored = SceneDocument.LoadJsonResult(snapshot);
        if restored.IsOk {
            scene = restored.Unwrap() as SceneDocument;
            renderDirty = true;
            RefreshInspector();
        }
    }

    hide func PumpLayerControls() -> Boolean {
        if scene == null { return false; }
        var changed = false;
        if layerList.WasSelectionChanged() {
            var selected = layerList.SelectedIndex;
            if selected >= 0 and selected < scene.LayerCount() {
                activeLayer = selected;
                RefreshLayerFields();
                renderDirty = true;
            }
        }
        if addLayerButton.WasClicked() {
            var added = scene.AddLayer("Layer " + (scene.LayerCount() + 1));
            if added >= 0 {
                activeLayer = added;
                changed = CommitScene("Added layer");
                ReloadTilesets();
                RefreshInspector();
            }
        }
        if removeLayerButton.WasClicked() {
            var before = scene.LayerCount();
            scene.RemoveLayer(activeLayer);
            if scene.LayerCount() != before {
                if activeLayer >= scene.LayerCount() {
                    activeLayer = scene.LayerCount() - 1;
                }
                changed = CommitScene("Removed layer") or changed;
                ReloadTilesets();
                RefreshInspector();
            }
        }
        if layerUpButton.WasClicked() and activeLayer > 0 {
            scene.MoveLayer(activeLayer, activeLayer - 1);
            activeLayer = activeLayer - 1;
            changed = CommitScene("Moved layer up") or changed;
            ReloadTilesets();
            RefreshInspector();
        }
        if layerDownButton.WasClicked()
           and activeLayer + 1 < scene.LayerCount() {
            scene.MoveLayer(activeLayer, activeLayer + 1);
            activeLayer = activeLayer + 1;
            changed = CommitScene("Moved layer down") or changed;
            ReloadTilesets();
            RefreshInspector();
        }
        if layerNameInput.WasSubmitted() {
            changed = RenameSceneLayer(
                activeLayer, layerNameInput.Text) or changed;
        }
        var nextVisibleRevision = layerVisibleCheck.GetRevision();
        if nextVisibleRevision != layerVisibleRevision {
            layerVisibleRevision = nextVisibleRevision;
            scene.SetLayerVisible(activeLayer, layerVisibleCheck.IsChecked());
            changed = CommitScene("Updated layer visibility") or changed;
            RefreshInspector();
        }
        if chooseLayerAssetButton.WasClicked() {
            var baseDir = "";
            if currentDoc != null and currentDoc.filePath != "" {
                baseDir = Path.Directory(currentDoc.filePath);
            }
            var assetPath = GUI.FileDialog.Open(
                "Choose Layer Image", baseDir, "*.png;*.jpg;*.jpeg;*.bmp;*.gif");
            if assetPath != "" {
                changed = ApplyLayerAssetPath(
                    activeLayer, PortableLayerAssetPath(assetPath)) or changed;
            }
        }
        if layerAssetInput.WasSubmitted() {
            changed = ApplyLayerAssetPath(
                activeLayer, layerAssetInput.Text) or changed;
        }
        if tilesetInspector.TakeReloadRequested() {
            ReloadTilesetPreviews();
        }
        if tilesetInspector.TakeClearRequested() {
            changed = ApplyLayerAssetPath(activeLayer, "") or changed;
        }
        return changed;
    }

    /// @brief Prefer scene-relative authored paths for saved scene documents.
    hide func PortableLayerAssetPath(assetPath: String) -> String {
        var documentPath = "";
        if currentDoc != null { documentPath = currentDoc.filePath; }
        return scene_asset_browser.PortableReferencePath(
            assetPath, documentPath);
    }

    /// @brief Configure one integer spinner used for new-scene dimensions.
    hide func ConfigureSceneSpinner(spinner: GUI.Spinner,
                                    value: Integer,
                                    maximum: Integer) {
        spinner.SetRange(1.0, maximum);
        spinner.SetStep(1.0);
        spinner.SetDecimals(0);
        spinner.SetValue(value);
        spinner.SetPreferredSize(68.0, 0.0);
    }

    /// @brief Reflect the loaded scene in the new-scene setup controls.
    hide func RefreshSceneSetupFields() {
        if scene == null or sceneWidthSpinner == null { return; }
        sceneWidthSpinner.SetValue(scene.Width);
        sceneHeightSpinner.SetValue(scene.Height);
        sceneTileSizeSpinner.SetValue(scene.TileWidth);
    }

    hide func PumpObjectControls() -> Boolean {
        if scene == null { return false; }
        PumpHierarchySearchControls();
        var changed = false;
        if objectTree.WasSelectionChanged() {
            var primaryRow = objectTree.GetSelected();
            selectedObject = -1;
            if primaryRow != null {
                selectedObject = Parse.IntOr(
                    GUI.TreeView.Node.GetData(primaryRow), -1);
            }
            selectedObjects = scene_selection.FromData(
                objectTree.GetSelectedData(),
                scene.ObjectCount(),
                selectedObject);
            if selectedObject < 0 and selectedObjects.count() > 0 {
                selectedObject = selectedObjects.get(0);
            }
            selectedObjectProperty = -1;
            RefreshObjectFields();
            renderDirty = true;
        }
        if objectTree.WasDropReceived() {
            var sourceIndex = Parse.IntOr(
                objectTree.GetDropSourceData(), -1);
            var targetIndex = Parse.IntOr(
                objectTree.GetDropTargetData(), -1);
            var dropPosition = objectTree.GetDropPosition();
            objectTree.ClearDrop();
            changed = ApplyObjectHierarchyDrop(
                sourceIndex, targetIndex, dropPosition) or changed;
        }
        if objectParentDropdown.WasChanged() {
            UpdateObjectParentControlAvailability();
        }
        if reparentObjectButton.WasClicked() {
            changed = ReparentSelectedSceneObjects(
                SelectedObjectParentTargetIndex()) or changed;
        }
        if addObjectButton.WasClicked() {
            var x = 0;
            var y = 0;
            if selectedCellX >= 0 {
                x = selectedCellX * scene.TileWidth;
                y = selectedCellY * scene.TileHeight;
            }
            var objectIndex = AddSceneObject(
                "entity",
                UniqueObjectId("object-" + (scene.ObjectCount() + 1)),
                x,
                y);
            if objectIndex >= 0 { changed = true; }
        }
        if addChildObjectButton.WasClicked()
           and selectedObjects.count() == 1
           and selectedObject >= 0
           and selectedObject < scene.ObjectCount() {
            var childParent = selectedObject;
            var childX = scene.ObjectX(childParent);
            var childY = scene.ObjectY(childParent);
            if selectedCellX >= 0 and selectedCellY >= 0 {
                childX = selectedCellX * scene.TileWidth;
                childY = selectedCellY * scene.TileHeight;
            }
            var childIndex = AddSceneChildObject(
                childParent,
                "entity",
                UniqueObjectId(
                    "object-" + (scene.ObjectCount() + 1)),
                childX,
                childY);
            if childIndex >= 0 { changed = true; }
        }
        var applyRequested = applyObjectButton.WasClicked();
        if objectTypeInput.WasSubmitted() { applyRequested = true; }
        if objectIdInput.WasSubmitted() { applyRequested = true; }
        if applyRequested and selectedObjects.count() == 1
           and selectedObject >= 0
           and selectedObject < scene.ObjectCount() {
            changed = UpdateSceneObject(
                selectedObject,
                objectTypeInput.Text,
                objectIdInput.Text,
                Convert.NumToInt(objectXSpinner.Value),
                Convert.NumToInt(objectYSpinner.Value)) or changed;
        }
        if duplicateObjectButton.WasClicked() and selectedObject >= 0 {
            if DuplicateSelectedSceneObjects() > 0 { changed = true; }
        }
        if objectArrangeDropdown.WasChanged() {
            RefreshObjectArrangeControls(selectedObjects.count() > 0);
        }
        if arrangeObjectButton.WasClicked() {
            changed = ArrangeSelectedSceneObjects(
                objectArrangeDropdown.Selected) or changed;
        }
        if objectUpButton.WasClicked()
           and selectedObjects.count() == 1 {
            var previousSibling =
                PreviousObjectSibling(selectedObject);
            if previousSibling >= 0 {
                changed = ApplyObjectHierarchyDrop(
                    selectedObject,
                    previousSibling,
                    0) or changed;
            }
        }
        if objectDownButton.WasClicked()
           and selectedObjects.count() == 1 {
            var nextSibling = NextObjectSibling(selectedObject);
            if nextSibling >= 0 {
                changed = ApplyObjectHierarchyDrop(
                    selectedObject,
                    nextSibling,
                    2) or changed;
            }
        }
        if removeObjectButton.WasClicked() and selectedObject >= 0 {
            changed = RemoveSelectedSceneObjects() or changed;
        }
        if objectPropertyList.WasSelectionChanged() {
            var propertyIndex = objectPropertyList.SelectedIndex;
            if propertyIndex >= 0
               and propertyIndex < objectPropertyKeys.count() {
                selectedObjectProperty = propertyIndex;
            } else {
                selectedObjectProperty = -1;
            }
            RefreshObjectPropertyFields();
        }
        if newObjectPropertyButton.WasClicked() {
            selectedObjectProperty = -1;
            objectPropertyList.SelectIndex(-1);
            RefreshObjectPropertyFields();
            objectPropertyKeyInput.Focus();
        }
        if objectPropertyTypeDropdown.WasChanged() {
            UpdatePropertyValueControl();
        }
        var setPropertyRequested = setObjectPropertyButton.WasClicked();
        if objectPropertyKeyInput.WasSubmitted() {
            setPropertyRequested = true;
        }
        if objectPropertyValueInput.WasSubmitted() {
            setPropertyRequested = true;
        }
        if setPropertyRequested and selectedObjects.count() > 1 {
            changed = SetSelectedSceneObjectProperty(
                objectPropertyKeyInput.Text,
                PropertyKindFromDropdown(),
                objectPropertyValueInput.Text) or changed;
        } else if setPropertyRequested and selectedObjects.count() == 1
                  and selectedObject >= 0 {
            var previousKey = "";
            if selectedObjectProperty >= 0
               and selectedObjectProperty < objectPropertyKeys.count() {
                previousKey = objectPropertyKeys.get(selectedObjectProperty);
            }
            changed = SetSceneObjectProperty(
                selectedObject,
                previousKey,
                objectPropertyKeyInput.Text,
                PropertyKindFromDropdown(),
                objectPropertyValueInput.Text) or changed;
        }
        if removeObjectPropertyButton.WasClicked()
           and selectedObjects.count() > 1 {
            changed = RemoveSelectedSceneObjectProperty(
                objectPropertyKeyInput.Text) or changed;
        } else if removeObjectPropertyButton.WasClicked()
                  and selectedObjects.count() == 1
                  and selectedObject >= 0
                  and selectedObjectProperty >= 0
                  and selectedObjectProperty < objectPropertyKeys.count() {
            changed = RemoveSceneObjectProperty(
                selectedObject,
                objectPropertyKeys.get(selectedObjectProperty)) or changed;
        }
        return changed;
    }

    /// @brief Route project component-picker intent into editor transactions.
    hide func PumpComponentControls() -> Boolean {
        if componentPalette == null or componentPalette.group == null {
            return false;
        }
        if componentPalette.Pump() { RefreshComponentPalette(); }
        var schemaChanged = componentAuthoring.PollExternalChanges(
            1000, componentPalette);
        var schemaAuthored =
            componentAuthoring.Pump(componentPalette);
        if schemaChanged or schemaAuthored
           or componentAuthoring.handled {
            componentSchema = componentAuthoring.schema;
            RefreshComponentPalette();
            if componentAuthoring.message != "" {
                detailLabel.SetText(componentAuthoring.message);
            }
        }
        if componentPalette.TakeEditFieldRequested() {
            EditSelectedComponentField();
        }
        if componentPalette.TakeApplyRequested() {
            return ApplySelectedComponent(
                componentPalette.SelectedComponent());
        }
        return false;
    }

    hide func ObjectIdExists(objectId: String, exceptIndex: Integer) -> Boolean {
        if scene == null { return false; }
        var index = 0;
        while index < scene.ObjectCount() {
            if index != exceptIndex and scene.ObjectId(index) == objectId {
                return true;
            }
            index = index + 1;
        }
        return false;
    }

    hide func ObjectIndexWithId(objectId: String) -> Integer {
        if scene == null or objectId == "" { return -1; }
        var index = 0;
        while index < scene.ObjectCount() {
            if scene.ObjectId(index) == objectId { return index; }
            index = index + 1;
        }
        return -1;
    }

    hide func UniqueObjectId(base: String) -> String {
        var stem = Str.Trim(base);
        if stem == "" { stem = "object"; }
        if ObjectIdExists(stem, -1) == false { return stem; }
        var suffix = 2;
        while suffix <= scene.ObjectCount() + 2 {
            var candidate = stem + "-" + suffix;
            if ObjectIdExists(candidate, -1) == false { return candidate; }
            suffix = suffix + 1;
        }
        return stem + "-" + (scene.ObjectCount() + 3);
    }

    /// @brief Return whether either side-specific Shift key is held.
    hide func CanvasShiftDown() -> Boolean {
        return Input.Keyboard.IsDown(Input.Key.LeftShift)
            or Input.Keyboard.IsDown(Input.Key.RightShift);
    }

    /// @brief Return whether conventional Control/Command selection is held.
    hide func CanvasPrimaryModifierDown() -> Boolean {
        return Input.Keyboard.IsDown(Input.Key.LeftControl)
            or Input.Keyboard.IsDown(Input.Key.RightControl)
            or Input.Keyboard.IsDown(Input.Key.LeftSuper)
            or Input.Keyboard.IsDown(Input.Key.RightSuper);
    }

    /// @brief Begin one blank-space marquee without changing selection yet.
    hide func BeginCanvasMarquee(cellX: Integer,
                                 cellY: Integer,
                                 additive: Boolean,
                                 toggle: Boolean) {
        canvasMarqueeActive = true;
        canvasMarqueeStartX = cellX;
        canvasMarqueeStartY = cellY;
        canvasMarqueeCurrentX = cellX;
        canvasMarqueeCurrentY = cellY;
        canvasMarqueeAdditive = additive;
        canvasMarqueeToggle = toggle;
        if Input.Mouse.IsCaptured() == false {
            Input.Mouse.Capture();
        }
        renderDirty = true;
        // Keep this transient status short enough to remain on one toolbar
        // line. Reflowing the retained layout after pointer capture moves the
        // canvas underneath the physical pointer and corrupts the drag cell.
        toolbarStatus.SetText("Box select; Escape cancels");
    }

    /// @brief Clear transient marquee state and optionally release its capture.
    hide func ResetCanvasMarquee(releaseCapture: Boolean) {
        var wasActive = canvasMarqueeActive;
        canvasMarqueeActive = false;
        canvasMarqueeStartX = -1;
        canvasMarqueeStartY = -1;
        canvasMarqueeCurrentX = -1;
        canvasMarqueeCurrentY = -1;
        canvasMarqueeAdditive = false;
        canvasMarqueeToggle = false;
        if releaseCapture and wasActive and Input.Mouse.IsCaptured() {
            Input.Mouse.Release();
        }
        if wasActive { renderDirty = true; }
    }

    /// @brief Cancel one active marquee and preserve its prior selection.
    hide func CancelCanvasMarquee() {
        if canvasMarqueeActive == false { return; }
        ResetCanvasMarquee(true);
        toolbarStatus.SetText("Box selection canceled");
    }

    /// @brief Apply one marquee exactly once when the left button is released.
    hide func FinishCanvasMarquee() {
        if canvasMarqueeActive == false { return; }
        var startX = canvasMarqueeStartX;
        var startY = canvasMarqueeStartY;
        var endX = canvasMarqueeCurrentX;
        var endY = canvasMarqueeCurrentY;
        var additive = canvasMarqueeAdditive;
        var toggle = canvasMarqueeToggle;
        ResetCanvasMarquee(true);
        var changed = ApplyCanvasMarqueeSelection(
            startX, startY, endX, endY, additive, toggle);
        if selectedObjects.count() == 0 {
            toolbarStatus.SetText("No canvas objects selected");
        } else if changed {
            toolbarStatus.SetText(
                "Selected " + selectedObjects.count()
                + " canvas object(s)");
        } else {
            toolbarStatus.SetText(
                "Canvas selection unchanged ("
                + selectedObjects.count() + " object(s))");
        }
    }

    /// @brief Begin a non-destructive inclusive tile-rectangle preview.
    hide func BeginTileRectangle(cellX: Integer,
                                 cellY: Integer) {
        tileRectangleActive = true;
        tileRectangleStartX = cellX;
        tileRectangleStartY = cellY;
        tileRectangleCurrentX = cellX;
        tileRectangleCurrentY = cellY;
        tileRectangleTile =
            ClampInt(Convert.NumToInt(tileSpinner.Value), 0, 1000000);
        if Input.Mouse.IsCaptured() == false {
            Input.Mouse.Capture();
        }
        renderDirty = true;
        toolbarStatus.SetText(
            "Drag a tile rectangle; release applies and Escape cancels");
    }

    /// @brief Clear transient rectangle state and optionally release capture.
    hide func ResetTileRectangle(releaseCapture: Boolean) {
        var wasActive = tileRectangleActive;
        tileRectangleActive = false;
        tileRectangleStartX = -1;
        tileRectangleStartY = -1;
        tileRectangleCurrentX = -1;
        tileRectangleCurrentY = -1;
        tileRectangleTile = 0;
        if releaseCapture and wasActive and Input.Mouse.IsCaptured() {
            Input.Mouse.Release();
        }
        if wasActive { renderDirty = true; }
    }

    /// @brief Clamp a captured rectangle pointer to the rendered scene edge.
    hide func UpdateTileRectanglePointer() {
        if tileRectangleActive == false or canvasImage == null
           or displayCellSize <= 0
           or renderedColumns <= 0 or renderedRows <= 0 {
            return;
        }
        var relativeX = PhysicalPointerToUi(Input.Mouse.X())
            - canvasImage.GetScreenX();
        var relativeY = PhysicalPointerToUi(Input.Mouse.Y())
            - canvasImage.GetScreenY();
        var cellX = 0;
        var cellY = 0;
        if relativeX > 0.0 {
            cellX = Convert.NumToInt(relativeX) / displayCellSize;
        }
        if relativeY > 0.0 {
            cellY = Convert.NumToInt(relativeY) / displayCellSize;
        }
        cellX = ClampInt(cellX, 0, renderedColumns - 1);
        cellY = ClampInt(cellY, 0, renderedRows - 1);
        if tileRectangleCurrentX != cellX
           or tileRectangleCurrentY != cellY {
            tileRectangleCurrentX = cellX;
            tileRectangleCurrentY = cellY;
            selectedCellX = cellX;
            selectedCellY = cellY;
            renderDirty = true;
        }
    }

    /// @brief Cancel an active tile rectangle without canonical mutation.
    hide func CancelTileRectangle() {
        if tileRectangleActive == false { return; }
        ResetTileRectangle(true);
        toolbarStatus.SetText("Tile rectangle canceled");
    }

    /// @brief Apply one captured tile rectangle exactly once on release.
    hide func FinishTileRectangle() -> Boolean {
        if tileRectangleActive == false { return false; }
        var startX = tileRectangleStartX;
        var startY = tileRectangleStartY;
        var endX = tileRectangleCurrentX;
        var endY = tileRectangleCurrentY;
        var tile = tileRectangleTile;
        ResetTileRectangle(true);
        return ApplyTileRectangle(
            activeLayer, startX, startY, endX, endY, tile);
    }

    /// @brief Reset one freehand stroke and optionally release its capture.
    hide func ResetPaintStroke(releaseCapture: Boolean) {
        var wasActive = paintStrokeActive;
        paintStrokeActive = false;
        paintStrokeChanged = false;
        paintStrokeSnapshot = "";
        lastPaintX = -1;
        lastPaintY = -1;
        if releaseCapture and wasActive and Input.Mouse.IsCaptured() {
            Input.Mouse.Release();
        }
    }

    /// @brief Restore the pre-stroke snapshot and create no history.
    hide func CancelPaintStroke() {
        if paintStrokeActive == false { return; }
        var snapshot = paintStrokeSnapshot;
        var changed = paintStrokeChanged;
        ResetPaintStroke(true);
        if changed and snapshot != "" {
            RestoreSceneSnapshot(snapshot);
        }
        toolbarStatus.SetText("Tile stroke canceled");
    }

    /// @brief Apply the current mouse tool to one bounded scene cell.
    hide func PumpCanvas() -> Boolean {
        if canvasMarqueeActive {
            if Input.Keyboard.WasPressed(Input.Key.Escape) {
                CancelCanvasMarquee();
                return false;
            }
            if !Input.Mouse.IsDown(Input.Mouse.ButtonLeft) {
                FinishCanvasMarquee();
                return false;
            }
        }
        if tileRectangleActive {
            if Input.Keyboard.WasPressed(Input.Key.Escape) {
                CancelTileRectangle();
                return false;
            }
            UpdateTileRectanglePointer();
            if !Input.Mouse.IsDown(Input.Mouse.ButtonLeft) {
                return FinishTileRectangle();
            }
            return false;
        }
        if paintStrokeActive {
            if Input.Keyboard.WasPressed(Input.Key.Escape) {
                CancelPaintStroke();
                return false;
            }
            if !Input.Mouse.IsDown(Input.Mouse.ButtonLeft) {
                return FinishPaintStroke();
            }
        }
        if objectDragActive
           and !Input.Mouse.IsDown(Input.Mouse.ButtonLeft) {
            return FinishObjectDrag();
        }
        if scene == null or canvasImage == null {
            return false;
        }
        if canvasImage.IsHovered() == false { return false; }
        if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft)
           or Input.Mouse.WasPressed(Input.Mouse.ButtonMiddle) {
            FocusActiveModeButton();
        }

        if Input.Mouse.IsDown(Input.Mouse.ButtonMiddle) {
            var panX = PhysicalPointerToUi(Input.Mouse.DeltaX());
            var panY = PhysicalPointerToUi(Input.Mouse.DeltaY());
            if panX != 0 or panY != 0 {
                SetLogicalScroll(
                    canvasScroll,
                    LogicalScrollX(canvasScroll) - panX,
                    LogicalScrollY(canvasScroll) - panY);
            }
            return false;
        }

        var wheel = Input.Mouse.WheelYFloat();
        if wheel > 0.0 {
            zoomPercent = ClampInt(zoomPercent + 25,
                                   MIN_ZOOM_PERCENT,
                                   MAX_ZOOM_PERCENT);
            fitPending = false;
            renderDirty = true;
        } else if wheel < 0.0 {
            zoomPercent = ClampInt(zoomPercent - 25,
                                   MIN_ZOOM_PERCENT,
                                   MAX_ZOOM_PERCENT);
            fitPending = false;
            renderDirty = true;
        }

        var relativeX = PhysicalPointerToUi(Input.Mouse.X())
            - canvasImage.GetScreenX();
        var relativeY = PhysicalPointerToUi(Input.Mouse.Y())
            - canvasImage.GetScreenY();
        if displayCellSize <= 0 { return false; }
        var cellX = Convert.NumToInt(relativeX) / displayCellSize;
        var cellY = Convert.NumToInt(relativeY) / displayCellSize;
        if cellX < 0 or cellY < 0
           or cellX >= renderedColumns or cellY >= renderedRows {
            return false;
        }

        if selectedCellX != cellX or selectedCellY != cellY {
            renderDirty = true;
        }
        selectedCellX = cellX;
        selectedCellY = cellY;
        if canvasMarqueeActive {
            if canvasMarqueeCurrentX != cellX
               or canvasMarqueeCurrentY != cellY {
                canvasMarqueeCurrentX = cellX;
                canvasMarqueeCurrentY = cellY;
                renderDirty = true;
            }
            return false;
        }
        if mode == MODE_PAINT or mode == MODE_ERASE {
            if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
                paintStrokeActive = true;
                paintStrokeChanged = false;
                paintStrokeSnapshot = currentSerialized;
                lastPaintX = cellX;
                lastPaintY = cellY;
                if Input.Mouse.IsCaptured() == false {
                    Input.Mouse.Capture();
                }
                paintStrokeChanged =
                    ApplyStrokeCell(cellX, cellY) or paintStrokeChanged;
            }
            if paintStrokeActive
               and Input.Mouse.IsDown(Input.Mouse.ButtonLeft)
               and (cellX != lastPaintX or cellY != lastPaintY) {
                paintStrokeChanged =
                    ApplyStrokeLine(cellX, cellY) or paintStrokeChanged;
            }
            return false;
        }

        if mode == MODE_RECTANGLE {
            if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
                BeginTileRectangle(cellX, cellY);
            }
            return false;
        }

        if mode == MODE_FILL {
            if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
                var fillTile = ClampInt(
                    Convert.NumToInt(tileSpinner.Value), 0, 1000000);
                return FloodFillSceneTile(
                    activeLayer, cellX, cellY, fillTile) > 0;
            }
            return false;
        }

        if mode == MODE_PICKER {
            if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
                PickSceneTile(activeLayer, cellX, cellY);
            }
            return false;
        }

        if mode == MODE_OBJECT {
            if !Input.Mouse.WasClicked(Input.Mouse.ButtonLeft) { return false; }
            var objectIndex = AddSceneObject(
                "entity",
                UniqueObjectId("object-" + (scene.ObjectCount() + 1)),
                cellX * scene.TileWidth,
                cellY * scene.TileHeight);
            if objectIndex >= 0 {
                toolbarStatus.SetText("Placed object");
                return true;
            }
            return false;
        }

        if Input.Mouse.WasPressed(Input.Mouse.ButtonLeft) {
            var hitObject = FindObjectAtCell(cellX, cellY);
            var additive = CanvasShiftDown();
            var toggle = CanvasPrimaryModifierDown();
            if hitObject >= 0 {
                ApplyCanvasPointSelection(
                    hitObject, additive, toggle);
            } else {
                objectDragActive = false;
                objectDragChanged = false;
                objectDragSnapshot = "";
                objectDragIndex = -1;
                BeginCanvasMarquee(
                    cellX, cellY, additive, toggle);
                RefreshInspector();
                return false;
            }
            objectDragActive = additive == false
                and toggle == false
                and scene_selection.Contains(
                    selectedObjects, hitObject);
            objectDragChanged = false;
            objectDragSnapshot = currentSerialized;
            objectDragIndex = hitObject;
            if objectDragActive {
                objectDragLastX = scene.ObjectX(objectDragIndex);
                objectDragLastY = scene.ObjectY(objectDragIndex);
            } else {
                objectDragSnapshot = "";
                objectDragIndex = -1;
            }
            RefreshInspector();
            renderDirty = true;
            if objectDragActive {
                toolbarStatus.SetText(
                    "Drag " + selectedObjects.count()
                    + " selected object(s) together");
            } else if selectedObjects.count() > 0 {
                toolbarStatus.SetText(
                    "Selected " + selectedObjects.count()
                    + " canvas object(s)");
            } else {
                toolbarStatus.SetText("No canvas objects selected");
            }
        }
        if objectDragActive
           and Input.Mouse.IsDown(Input.Mouse.ButtonLeft)
           and objectDragIndex >= 0
           and objectDragIndex < scene.ObjectCount() {
            var objectX = cellX * scene.TileWidth;
            var objectY = cellY * scene.TileHeight;
            var deltaX = objectX - objectDragLastX;
            var deltaY = objectY - objectDragLastY;
            if deltaX != 0 or deltaY != 0 {
                objectDragChanged = TranslateSelectedObjectsUncommitted(
                    deltaX, deltaY) or objectDragChanged;
                objectDragLastX = objectX;
                objectDragLastY = objectY;
                objectXSpinner.SetValue(objectX);
                objectYSpinner.SetValue(objectY);
                renderDirty = true;
            }
        }
        return false;
    }

    /// @brief Apply focus-safe pixel/grid nudges from the Select canvas proxy.
    /// @details Object-list arrows retain native selection navigation and every
    ///          inspector input retains native editing. Shift uses one authored
    ///          tile on each axis; a diagonal key frame still commits once.
    hide func PumpCanvasKeyboard() -> Boolean {
        if scene == null or mode != MODE_SELECT
           or selectButton == null or selectButton.IsFocused() == false
           or objectDragActive or paintStrokeActive
           or selectedObjects.count() == 0 {
            return false;
        }
        var deltaX = 0;
        var deltaY = 0;
        if Input.Keyboard.WasPressed(Input.Key.Left) {
            deltaX = deltaX - 1;
        }
        if Input.Keyboard.WasPressed(Input.Key.Right) {
            deltaX = deltaX + 1;
        }
        if Input.Keyboard.WasPressed(Input.Key.Up) {
            deltaY = deltaY - 1;
        }
        if Input.Keyboard.WasPressed(Input.Key.Down) {
            deltaY = deltaY + 1;
        }
        if deltaX == 0 and deltaY == 0 { return false; }

        var coarse =
            Input.Keyboard.IsDown(Input.Key.LeftShift)
            or Input.Keyboard.IsDown(Input.Key.RightShift);
        if coarse {
            deltaX = deltaX * scene.TileWidth;
            deltaY = deltaY * scene.TileHeight;
        }
        var changed = TranslateSelectedSceneObjects(deltaX, deltaY);
        if changed {
            toolbarStatus.SetText(
                "Nudged " + selectedObjects.count() + " object(s) by "
                + deltaX + ", " + deltaY);
        }
        return changed;
    }

    /// @brief Return whether scene selection shortcuts belong to this surface.
    /// @details Inspector text/value controls intentionally do not qualify.
    ///          Canvas clicks focus the active mode button because Image is a
    ///          non-focusable presentation widget.
    expose func SceneSelectionCommandsOwnFocus() -> Boolean {
        return (objectTree != null and objectTree.IsFocused())
            or (selectButton != null and selectButton.IsFocused())
            or (paintButton != null and paintButton.IsFocused())
            or (eraseButton != null and eraseButton.IsFocused())
            or (objectButton != null and objectButton.IsFocused())
            or (duplicateObjectButton != null
                and duplicateObjectButton.IsFocused())
            or (removeObjectButton != null
                and removeObjectButton.IsFocused())
            or (objectUpButton != null and objectUpButton.IsFocused())
            or (objectDownButton != null and objectDownButton.IsFocused());
    }

    /// @brief Use the active focusable mode control as the canvas key proxy.
    hide func FocusActiveModeButton() {
        if mode == MODE_PAINT {
            paintButton.Focus();
        } else if mode == MODE_ERASE {
            eraseButton.Focus();
        } else if mode == MODE_RECTANGLE {
            rectangleButton.Focus();
        } else if mode == MODE_FILL {
            fillButton.Focus();
        } else if mode == MODE_PICKER {
            pickerButton.Focus();
        } else if mode == MODE_OBJECT {
            objectButton.Focus();
        } else {
            selectButton.Focus();
        }
    }

    /// @brief Mutate one cell inside the current uncommitted paint stroke.
    hide func ApplyStrokeCell(cellX: Integer, cellY: Integer) -> Boolean {
        var tile = 0;
        if mode == MODE_PAINT {
            tile = Convert.NumToInt(tileSpinner.Value);
            if tile < 0 { tile = 0; }
        }
        return ApplyTileCell(activeLayer, cellX, cellY, tile);
    }

    /// @brief Fill every raster cell between the last and current pointer cell.
    hide func ApplyStrokeLine(targetX: Integer,
                              targetY: Integer) -> Boolean {
        var startX = lastPaintX;
        var startY = lastPaintY;
        if startX < 0 or startY < 0 {
            startX = targetX;
            startY = targetY;
        }
        var tile = 0;
        if mode == MODE_PAINT {
            tile = Convert.NumToInt(tileSpinner.Value);
            if tile < 0 { tile = 0; }
        }
        var changed = ApplyTileLineUncommitted(
            activeLayer, startX, startY, targetX, targetY, tile);
        lastPaintX = targetX;
        lastPaintY = targetY;
        return changed;
    }

    hide func ApplyTileCell(layer: Integer,
                            cellX: Integer,
                            cellY: Integer,
                            tile: Integer) -> Boolean {
        if scene == null or layer < 0 or layer >= scene.LayerCount()
           or cellX < 0 or cellY < 0
           or cellX >= scene.Width or cellY >= scene.Height {
            return false;
        }
        if scene.GetTile(layer, cellX, cellY) == tile { return false; }
        scene.SetTile(layer, cellX, cellY, tile);
        renderDirty = true;
        return true;
    }

    hide func ApplyTileLineUncommitted(layer: Integer,
                                       startX: Integer,
                                       startY: Integer,
                                       targetX: Integer,
                                       targetY: Integer,
                                       tile: Integer) -> Boolean {
        var x = startX;
        var y = startY;
        var dx = AbsInt2D(targetX - x);
        var sx = -1;
        if x < targetX { sx = 1; }
        var dy = 0 - AbsInt2D(targetY - y);
        var sy = -1;
        if y < targetY { sy = 1; }
        var error = dx + dy;
        var changed = false;
        while true {
            changed = ApplyTileCell(layer, x, y, tile) or changed;
            if x == targetX and y == targetY { break; }
            var doubled = error * 2;
            if doubled >= dy {
                error = error + dy;
                x = x + sx;
            }
            if doubled <= dx {
                error = error + dx;
                y = y + sy;
            }
        }
        return changed;
    }

    /// @brief Commit one complete paint gesture as a single history entry.
    hide func FinishPaintStroke() -> Boolean {
        var changed = paintStrokeChanged;
        var snapshot = paintStrokeSnapshot;
        ResetPaintStroke(true);
        if changed == false { return false; }

        var message = "Painted tile stroke";
        if mode == MODE_ERASE { message = "Erased tile stroke"; }
        if CommitScene(message) { return true; }
        RestoreSceneSnapshot(snapshot);
        detailLabel.SetText("The tile stroke could not be committed.");
        return false;
    }

    /// @brief Commit one complete object drag as a single history entry.
    hide func FinishObjectDrag() -> Boolean {
        var changed = objectDragChanged;
        var snapshot = objectDragSnapshot;
        var index = objectDragIndex;
        objectDragActive = false;
        objectDragChanged = false;
        objectDragSnapshot = "";
        objectDragIndex = -1;
        objectDragLastX = 0;
        objectDragLastY = 0;
        if changed == false { return false; }
        selectedObject = index;
        var count = selectedObjects.count();
        var message = "Moved " + count + " objects";
        if count == 1 { message = "Moved scene object"; }
        if CommitScene(message) {
            RefreshInspector();
            return true;
        }
        RestoreSceneSnapshot(snapshot);
        detailLabel.SetText("The object move could not be committed.");
        return false;
    }

    hide func FindObjectAtCell(cellX: Integer, cellY: Integer) -> Integer {
        if scene == null { return -1; }
        var index = scene.ObjectCount() - 1;
        while index >= 0 {
            var objectCellX = scene.ObjectX(index) / scene.TileWidth;
            var objectCellY = scene.ObjectY(index) / scene.TileHeight;
            if objectCellX == cellX and objectCellY == cellY { return index; }
            index = index - 1;
        }
        return -1;
    }

    hide func FitScene() -> Boolean {
        if scene == null or canvasScroll == null { return false; }
        var width = Convert.NumToInt(
            canvasScroll.GetLogicalWidth() - 24.0);
        var height = Convert.NumToInt(
            canvasScroll.GetLogicalHeight() - 24.0);
        if width <= 0 or height <= 0 { return false; }
        zoomPercent = FitZoomPercent(
            scene.Width, scene.Height, width, height);
        SetLogicalScroll(canvasScroll, 0.0, 0.0);
        return true;
    }

    /// @brief Re-render when the viewport changes so centering stays accurate.
    hide func UpdateCanvasViewportSize() {
        if canvasScroll == null { return; }
        var width = Convert.NumToInt(canvasScroll.GetLogicalWidth());
        var height = Convert.NumToInt(canvasScroll.GetLogicalHeight());
        if width != lastCanvasViewportWidth
           or height != lastCanvasViewportHeight {
            lastCanvasViewportWidth = width;
            lastCanvasViewportHeight = height;
            renderDirty = true;
        }
    }

    /// @brief Return the app's logical-to-framebuffer scale for legacy pixel APIs.
    hide func EffectiveUiScale() -> Number {
        if guiApp == null { return 1.0; }
        var scale = guiApp.GetEffectiveScale();
        if scale <= 0.0 { return 1.0; }
        return scale;
    }

    /// @brief Convert a GUI-app pointer coordinate into effective UI units.
    /// @details GUI widget screen bounds are logical while Zanna.Input.Mouse
    ///          receives framebuffer coordinates from GUI application polling.
    hide func PhysicalPointerToUi(value: Number) -> Number {
        return value / EffectiveUiScale();
    }

    /// @brief Read a legacy framebuffer scroll offset as logical UI units.
    hide func LogicalScrollX(scroll: GUI.ScrollView) -> Number {
        if scroll == null { return 0.0; }
        return scroll.GetScrollX() / EffectiveUiScale();
    }

    /// @brief Read a legacy framebuffer scroll offset as logical UI units.
    hide func LogicalScrollY(scroll: GUI.ScrollView) -> Number {
        if scroll == null { return 0.0; }
        return scroll.GetScrollY() / EffectiveUiScale();
    }

    /// @brief Apply logical offsets through ScrollView's framebuffer-pixel API.
    hide func SetLogicalScroll(scroll: GUI.ScrollView,
                               x: Number,
                               y: Number) {
        if scroll == null { return; }
        var scale = EffectiveUiScale();
        scroll.SetScroll(x * scale, y * scale);
    }

    /// @brief Apply logical content dimensions through the legacy pixel API.
    hide func SetLogicalContentSize(scroll: GUI.ScrollView,
                                    width: Number,
                                    height: Number) {
        if scroll == null { return; }
        var scale = EffectiveUiScale();
        scroll.SetContentSize(width * scale, height * scale);
    }

    /// @brief Render a bounded, dependency-free scene preview into GUI.Image.
    hide func RenderScene() {
        renderDirty = false;
        if canvasImage == null { return; }
        if scene == null {
            framePixels = Pixels.New(640, 360);
            framePixels.FillColor(Color.RGB(24, 28, 36));
            framePixels.DrawTextCentered(
                150, "Unable to display this 2D scene", Color.RGB(230, 115, 115));
            framePixels.DrawTextCentered(
                172, "Use New 32x18 or repair the JSON as text",
                Color.RGB(180, 188, 202));
            canvasImage.SetPixels(framePixels, 640, 360);
            canvasImage.SetSize(640, 360);
            var emptyStageWidth = 640;
            var emptyStageHeight = 360;
            if lastCanvasViewportWidth > emptyStageWidth {
                emptyStageWidth = lastCanvasViewportWidth;
            }
            if lastCanvasViewportHeight > emptyStageHeight {
                emptyStageHeight = lastCanvasViewportHeight;
            }
            canvasStage.SetSize(emptyStageWidth, emptyStageHeight);
            SetLogicalContentSize(
                canvasScroll, emptyStageWidth, emptyStageHeight);
            renderedColumns = 0;
            renderedRows = 0;
            viewStatusLabel.SetText("");
            return;
        }

        displayCellSize = BASE_DISPLAY_CELL * zoomPercent / 100;
        if displayCellSize < 1 { displayCellSize = 1; }
        renderedColumns = scene.Width;
        renderedRows = scene.Height;
        if renderedColumns > MAX_RENDER_CELLS_PER_AXIS {
            renderedColumns = MAX_RENDER_CELLS_PER_AXIS;
        }
        if renderedRows > MAX_RENDER_CELLS_PER_AXIS {
            renderedRows = MAX_RENDER_CELLS_PER_AXIS;
        }
        var maxColumns = MAX_RENDER_DIMENSION / displayCellSize;
        var maxRows = MAX_RENDER_DIMENSION / displayCellSize;
        if renderedColumns > maxColumns { renderedColumns = maxColumns; }
        if renderedRows > maxRows { renderedRows = maxRows; }
        if renderedColumns < 1 { renderedColumns = 1; }
        if renderedRows < 1 { renderedRows = 1; }

        var pixelWidth = renderedColumns * displayCellSize + 1;
        var pixelHeight = renderedRows * displayCellSize + 1;
        framePixels = Pixels.New(pixelWidth, pixelHeight);
        framePixels.FillColor(Color.RGB(24, 28, 36));

        var layer = 0;
        while layer < scene.LayerCount() {
            if scene.LayerVisible(layer) {
                var y = 0;
                while y < renderedRows {
                    var x = 0;
                    while x < renderedColumns {
                        var tile = scene.GetTile(layer, x, y);
                        if tile > 0 {
                            var drewAsset = tilesets.DrawTile(
                                framePixels,
                                layer,
                                tile,
                                x * displayCellSize,
                                y * displayCellSize,
                                displayCellSize);
                            if drewAsset == false {
                                framePixels.DrawBox(
                                    x * displayCellSize + 1,
                                    y * displayCellSize + 1,
                                    displayCellSize - 1,
                                    displayCellSize - 1,
                                    TilePreviewColor(tile, layer));
                            }
                        }
                        x = x + 1;
                    }
                    y = y + 1;
                }
            }
            layer = layer + 1;
        }

        var gridColor = Color.RGB(54, 61, 73);
        var x = 0;
        while x <= renderedColumns {
            framePixels.DrawLine(x * displayCellSize, 0,
                                 x * displayCellSize, pixelHeight - 1,
                                 gridColor);
            x = x + 1;
        }
        var y = 0;
        while y <= renderedRows {
            framePixels.DrawLine(0, y * displayCellSize,
                                 pixelWidth - 1, y * displayCellSize,
                                 gridColor);
            y = y + 1;
        }

        var objectIndex = 0;
        while objectIndex < scene.ObjectCount() {
            var objectX = scene.ObjectX(objectIndex) * displayCellSize
                / scene.TileWidth;
            var objectY = scene.ObjectY(objectIndex) * displayCellSize
                / scene.TileHeight;
            var objectColor = Color.RGB(255, 190, 72);
            if scene_selection.Contains(selectedObjects, objectIndex) {
                objectColor = Color.RGB(104, 220, 255);
            }
            if objectIndex == selectedObject {
                objectColor = Color.RGB(170, 242, 255);
            }
            framePixels.DrawDisc(objectX + displayCellSize / 2,
                                 objectY + displayCellSize / 2,
                                 ClampInt(displayCellSize / 4, 2, 10),
                                 objectColor);
            framePixels.DrawFrame(objectX, objectY,
                                  displayCellSize, displayCellSize,
                                  objectColor);
            objectIndex = objectIndex + 1;
        }

        if selectedCellX >= 0 and selectedCellY >= 0
           and selectedCellX < renderedColumns
           and selectedCellY < renderedRows {
            framePixels.DrawFrame(selectedCellX * displayCellSize,
                                  selectedCellY * displayCellSize,
                                  displayCellSize + 1,
                                  displayCellSize + 1,
                                  Color.RGB(255, 255, 255));
        }

        if tileRectangleActive
           and tileRectangleStartX >= 0
           and tileRectangleStartY >= 0
           and tileRectangleCurrentX >= 0
           and tileRectangleCurrentY >= 0 {
            var minimumTileX = tileRectangleStartX;
            var maximumTileX = tileRectangleCurrentX;
            if maximumTileX < minimumTileX {
                minimumTileX = tileRectangleCurrentX;
                maximumTileX = tileRectangleStartX;
            }
            var minimumTileY = tileRectangleStartY;
            var maximumTileY = tileRectangleCurrentY;
            if maximumTileY < minimumTileY {
                minimumTileY = tileRectangleCurrentY;
                maximumTileY = tileRectangleStartY;
            }
            framePixels.DrawFrame(
                minimumTileX * displayCellSize,
                minimumTileY * displayCellSize,
                (maximumTileX - minimumTileX + 1)
                    * displayCellSize + 1,
                (maximumTileY - minimumTileY + 1)
                    * displayCellSize + 1,
                TILE_RECTANGLE_COLOR);
        }

        if canvasMarqueeActive
           and canvasMarqueeStartX >= 0
           and canvasMarqueeStartY >= 0
           and canvasMarqueeCurrentX >= 0
           and canvasMarqueeCurrentY >= 0 {
            var minimumX = canvasMarqueeStartX;
            var maximumX = canvasMarqueeCurrentX;
            if maximumX < minimumX {
                minimumX = canvasMarqueeCurrentX;
                maximumX = canvasMarqueeStartX;
            }
            var minimumY = canvasMarqueeStartY;
            var maximumY = canvasMarqueeCurrentY;
            if maximumY < minimumY {
                minimumY = canvasMarqueeCurrentY;
                maximumY = canvasMarqueeStartY;
            }
            framePixels.DrawFrame(
                minimumX * displayCellSize,
                minimumY * displayCellSize,
                (maximumX - minimumX + 1) * displayCellSize + 1,
                (maximumY - minimumY + 1) * displayCellSize + 1,
                CANVAS_MARQUEE_COLOR);
        }

        canvasImage.SetPixels(framePixels, pixelWidth, pixelHeight);
        canvasImage.SetSize(pixelWidth, pixelHeight);
        var stageWidth = pixelWidth;
        var stageHeight = pixelHeight;
        if lastCanvasViewportWidth > stageWidth {
            stageWidth = lastCanvasViewportWidth;
        }
        if lastCanvasViewportHeight > stageHeight {
            stageHeight = lastCanvasViewportHeight;
        }
        canvasStage.SetSize(stageWidth, stageHeight);
        SetLogicalContentSize(canvasScroll, stageWidth, stageHeight);
        var clipped = renderedColumns < scene.Width or renderedRows < scene.Height;
        var suffix = "";
        if clipped {
            suffix = "  |  preview clipped to "
                + renderedColumns + "x" + renderedRows;
        }
        if tilesets.cacheSaturated {
            suffix = suffix + "  |  tileset preview cache capped";
        }
        var cellStatus = "";
        if selectedCellX >= 0 and selectedCellY >= 0 {
            cellStatus = "  |  cell "
                + selectedCellX + ", " + selectedCellY;
        }
        var marqueeStatus = "";
        if canvasMarqueeActive {
            marqueeStatus = "  |  box "
                + (AbsInt2D(
                    canvasMarqueeCurrentX - canvasMarqueeStartX) + 1)
                + "x"
                + (AbsInt2D(
                    canvasMarqueeCurrentY - canvasMarqueeStartY) + 1);
        }
        var rectangleStatus = "";
        if tileRectangleActive {
            rectangleStatus = "  |  rectangle "
                + (AbsInt2D(
                    tileRectangleCurrentX - tileRectangleStartX) + 1)
                + "x"
                + (AbsInt2D(
                    tileRectangleCurrentY - tileRectangleStartY) + 1);
        }
        viewStatusLabel.SetText(
            "Layer " + (activeLayer + 1) + "/" + scene.LayerCount()
            + "  |  zoom " + zoomPercent + "%"
            + cellStatus + marqueeStatus + rectangleStatus + suffix);
        canvasImage.SetAccessibleDescription(
            scene.ObjectCount() + " authored objects on a "
            + renderedColumns + " by " + renderedRows
            + " cell preview. Tile tools support freehand Paint and Erase, "
            + "captured Rectangle, connected Fill, and active-layer Pick. "
            + "In Select mode, click objects or drag blank space to box-select; "
            + "Shift adds and Control or Command toggles.");
    }
}
