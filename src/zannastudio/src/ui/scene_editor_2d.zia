    /// @brief Build the visual editor into WorkbenchShell.scene2DHost.
    expose func Setup(host: GUI.VBox, app: GUI.App) {
        guiApp = app;
        root = GUI.VBox.New();
        root.SetSpacing(0.0);
        root.SetPadding(0.0);
        root.SetFlex(1.0);
        root.SetName("scene-editor-2d");
        root.SetAccessibleName("2D scene editor");
        host.AddChild(root);

        toolbar = GUI.Flex.New();
        toolbar.SetDirection(GUI.FlexDirection.Row);
        toolbar.SetWrap(GUI.FlexWrap.Wrap);
        toolbar.SetAlign(GUI.Align.Center);
        toolbar.SetGap(4.0);
        toolbar.SetPadding(4.0);
        root.AddChild(toolbar);

        newSceneButton = GUI.Button.New(toolbar, "New Scene");
        newSceneButton.SetTooltip(
            "Replace this document using the inspector dimensions (undoable)");
        importButton = GUI.Button.New(toolbar, "Import Tiled...");
        importButton.SetTooltip("Import a Tiled JSON or TMX map into this document");
        selectButton = GUI.Button.New(toolbar, "Select");
        selectButton.SetTooltip(
            "Select and drag objects; Arrow keys nudge one pixel and "
            + "Shift+Arrow nudges one tile");
        paintButton = GUI.Button.New(toolbar, "Paint");
        paintButton.SetTooltip(
            "Freehand paint the selected tile; Escape cancels a captured stroke");
        eraseButton = GUI.Button.New(toolbar, "Erase");
        eraseButton.SetTooltip(
            "Freehand clear tiles; Escape cancels a captured stroke");
        rectangleButton = GUI.Button.New(toolbar, "Rectangle");
        rectangleButton.SetTooltip(
            "Drag an inclusive rectangle using the selected tile; tile 0 clears");
        fillButton = GUI.Button.New(toolbar, "Fill");
        fillButton.SetTooltip(
            "Replace the clicked four-connected active-layer region");
        pickerButton = GUI.Button.New(toolbar, "Pick");
        pickerButton.SetTooltip(
            "Sample one active-layer tile and return to Paint");
        objectButton = GUI.Button.New(toolbar, "Object");
        toolbarStatus = GUI.Label.New(toolbar, "Open or create a 2D scene");
        toolbarStatus.SetMinSize(0.0, 0.0);
        toolbarStatus.SetPreferredSize(96.0, 0.0);
        toolbarStatus.SetEllipsis(true);
        toolbarStatus.SetMaxLines(1);
        toolbarStatus.SetFlex(1.0);

        viewToolbar = GUI.Flex.New();
        viewToolbar.SetDirection(GUI.FlexDirection.Row);
        viewToolbar.SetWrap(GUI.FlexWrap.Wrap);
        viewToolbar.SetAlign(GUI.Align.Center);
        viewToolbar.SetGap(4.0);
        viewToolbar.SetPadding(4.0);
        root.AddChild(viewToolbar);
        GUI.Label.New(viewToolbar, "Tile");
        tileSpinner = GUI.Spinner.New(viewToolbar);
        tileSpinner.SetAccessibleName("Selected tile ID");
        tileSpinner.SetRange(0.0, 1000000.0);
        tileSpinner.SetStep(1.0);
        tileSpinner.SetDecimals(0);
        tileSpinner.SetValue(1.0);
        tileSpinner.SetPreferredSize(88.0, 0.0);
        GUI.Label.New(viewToolbar, "Zoom");
        zoomOutButton = GUI.Button.New(viewToolbar, "-");
        zoomOutButton.SetTooltip("Zoom out");
        zoomInButton = GUI.Button.New(viewToolbar, "+");
        zoomInButton.SetTooltip("Zoom in");
        fitButton = GUI.Button.New(viewToolbar, "Fit");
        fitButton.SetTooltip("Fit the complete scene in the current viewport");
        inspectorButton = GUI.Button.New(viewToolbar, "Hide Inspector");
        inspectorButton.SetStyle(2);
        inspectorButton.SetTooltip(
            "Hide the scene inspector and give the canvas the full width");
        viewStatusLabel = GUI.Label.New(viewToolbar, "");
        viewStatusLabel.SetMinSize(0.0, 0.0);
        viewStatusLabel.SetPreferredSize(96.0, 0.0);
        viewStatusLabel.SetEllipsis(true);
        viewStatusLabel.SetMaxLines(1);
        viewStatusLabel.SetFlex(1.0);
        UpdateModeButtons();

        bodySplit = GUI.SplitPane.New(root, 1);
        bodySplit.SetFlex(1.0);
        bodySplit.SetPosition(0.68);
        bodySplit.SetMinFirst(280.0);
        bodySplit.SetMinSecond(300.0);

        canvasScroll = GUI.ScrollView.New(bodySplit.First);
        canvasScroll.SetFlex(1.0);
        canvasStage = GUI.VBox.New();
        canvasStage.SetAlign(GUI.Align.Center);
        canvasStage.SetJustify(GUI.Justify.Center);
        canvasScroll.AddChild(canvasStage);
        canvasImage = GUI.Image.New(canvasStage);
        canvasImage.SetScaleMode(0);
        canvasImage.SetFilter(0);
        canvasImage.SetName("scene-2d-canvas");
        canvasImage.SetAccessibleName("2D scene canvas");
        canvasImage.SetTooltip(
            "Paint or erase freehand, drag Rectangle, click Fill or Pick; "
            + "Escape cancels captured tile gestures. In Select mode click or "
            + "drag a box, Shift adds, Control/Command toggles, and object "
            + "drags move the selection. Wheel zooms and middle-drag pans.");

        inspectorScroll = GUI.ScrollView.New(bodySplit.Second);
        inspectorScroll.SetFlex(1.0);
        var inspector = GUI.VBox.New();
        inspector.SetSpacing(6.0);
        inspector.SetPadding(8.0);
        inspectorScroll.AddChild(inspector);

        GUI.Label.New(inspector, "New scene setup");
        var sceneSizeRow = GUI.HBox.New();
        sceneSizeRow.SetSpacing(4.0);
        inspector.AddChild(sceneSizeRow);
        GUI.Label.New(sceneSizeRow, "W");
        sceneWidthSpinner = GUI.Spinner.New(sceneSizeRow);
        ConfigureSceneSpinner(sceneWidthSpinner, DEFAULT_SCENE_WIDTH, 256);
        GUI.Label.New(sceneSizeRow, "H");
        sceneHeightSpinner = GUI.Spinner.New(sceneSizeRow);
        ConfigureSceneSpinner(sceneHeightSpinner, DEFAULT_SCENE_HEIGHT, 256);
        var tileSizeRow = GUI.HBox.New();
        tileSizeRow.SetSpacing(4.0);
        inspector.AddChild(tileSizeRow);
        GUI.Label.New(tileSizeRow, "Tile size");
        sceneTileSizeSpinner = GUI.Spinner.New(tileSizeRow);
        ConfigureSceneSpinner(sceneTileSizeSpinner, DEFAULT_TILE_SIZE, 512);
        var importGroup = GUI.GroupBox.New(inspector, "Project map imports");
        tiledAssetBrowser.Setup(
            importGroup,
            "Import Project Tiled Map...",
            ".tmj,.json,.tmx",
            "Import Map");

        sceneInfoLabel = GUI.Label.New(inspector, "No scene loaded");
        sceneInfoLabel.SetWordWrap(true);

        sceneProperties.Setup(inspector);

        GUI.Label.New(inspector, "Layers");
        layerList = GUI.ListBox.New(inspector);
