    /// @brief Build the complete bottom tool-panel surface under the editor.
    /// @param panelHost Bottom split host that receives all tool panels; they fill
    ///        it via flex and the splitter owns the height.
    /// @param appArg Owning application, used for output wrap width.
    /// @param splitArg Vertical splitter shared with the editor, driven by the
    ///        panel show/hide paths to collapse/restore the bottom area.
    expose func Build(panelHost: GUI.VBox,
                      appArg: GUI.App,
                      splitArg: GUI.SplitPane) {
        editorSplit = splitArg;
        bottomDockHost = panelHost;

        panelRoot = GUI.VBox.New();
        panelRoot.SetSpacing(0.0);
        panelRoot.SetPadding(0.0);
        panelRoot.SetFlex(1.0);
        panelHost.AddChild(panelRoot);

        dockHeader = GUI.HBox.New();
        dockHeader.SetSpacing(4.0);
        dockHeader.SetPadding(4.0);
        panelRoot.AddChild(dockHeader);

        dockDragHandle = GUI.Label.New(dockHeader, "Panels  -  drag to dock");
        dockDragHandle.SetFlex(1.0);
        dockDragHandle.SetTooltip(
            "Drag to a workbench edge or the center Float target");
        dockDragHandle.SetDraggable(true);
        dockDragHandle.SetDragData(workspace_dock.TOOL_PANEL_DRAG_TYPE,
                                   workspace_dock.TOOL_PANEL_DRAG_DATA);

        dockLeftButton = GUI.Button.New(dockHeader, "Left");
        dockLeftButton.SetSize(48, 24);
        dockLeftButton.SetTooltip("Move the selected tool to the left group");
        dockBottomButton = GUI.Button.New(dockHeader, "Bottom");
        dockBottomButton.SetSize(58, 24);
        dockBottomButton.SetTooltip(
            "Move the selected tool below the editor");
        dockRightButton = GUI.Button.New(dockHeader, "Right");
        dockRightButton.SetSize(52, 24);
        dockRightButton.SetTooltip(
            "Move the selected tool to the right group");
        dockFloatButton = GUI.Button.New(dockHeader, "Float");
        dockFloatButton.SetSize(48, 24);
        dockFloatButton.SetTooltip(
            "Move the selected tool into a movable floating window");
        dockHideButton = GUI.Button.New(dockHeader, "Hide");
        dockHideButton.SetSize(46, 24);
        dockHideButton.SetTooltip("Hide the panel area");

        toolTabBar = GUI.TabBar.New(panelRoot);
        toolTabBar.SetAutoClose(false);
        toolProblemsTab = toolTabBar.AddTab("Problems", 0);
        toolOutputTab = toolTabBar.AddTab("Output", 0);
        toolSearchTab = toolTabBar.AddTab("Search", 0);
        toolReferencesTab = toolTabBar.AddTab("References", 0);
        toolVariablesTab = toolTabBar.AddTab("Variables", 0);
        toolCallStackTab = toolTabBar.AddTab("Call Stack", 0);
        toolDebugTab = toolTabBar.AddTab("Debug Console", 0);
        toolTerminalTab = toolTabBar.AddTab("Terminal", 0);
        toolTabBar.SetVisible(false);

        problemsPanel = GUI.VBox.New();
        problemsPanel.SetSpacing(4.0);
        problemsPanel.SetPadding(4.0);
        problemsPanel.SetVisible(false);
        problemsPanel.SetFlex(1.0);
        panelRoot.AddChild(problemsPanel);
