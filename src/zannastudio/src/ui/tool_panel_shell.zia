    /// @brief Attach stable side-dock hosts after WorkbenchShell builds them.
    /// @param dropTarget Whole workbench surface accepting panel-header drops.
    /// @param leftHost First pane of the left docking splitter.
    /// @param rightHost Second pane of the right docking splitter.
    /// @param leftSplit Splitter that reveals/collapses the left dock.
    /// @param rightSplit Splitter that reveals/collapses the right dock.
    expose func ConfigureDocking(dropTarget: GUI.Widget,
                                 leftHost: GUI.VBox,
                                 rightHost: GUI.VBox,
                                 leftSplit: GUI.SplitPane,
                                 rightSplit: GUI.SplitPane) {
        workspaceDropTarget = dropTarget;
        leftDockHost = leftHost;
        rightDockHost = rightHost;
        leftDockSplit = leftSplit;
        rightDockSplit = rightSplit;
        BuildIndependentToolGroups();
        if workspaceDropTarget != null {
            workspaceDropTarget.SetDropTarget(true);
            workspaceDropTarget.SetAcceptedDropTypes(
                workspace_dock.TOOL_PANEL_DRAG_TYPE);
            BuildDockTargets();
        }
        UpdateDockButtons();
    }

    /// @brief Build one stationary auxiliary group in every possible dock.
    /// @details The legacy panelRoot remains the primary group and can still
    ///          migrate as a unit. These roots stay mounted in their hosts so
    ///          individual live panels can move without rebuilding controllers.
    hide func BuildIndependentToolGroups() {
        if leftToolGroupRoot != null { return; }

        leftToolGroupRoot = GUI.VBox.New();
        leftToolGroupRoot.SetName("tool-group-left");
        leftToolGroupRoot.SetSpacing(0.0);
        leftToolGroupRoot.SetPadding(0.0);
        leftToolGroupRoot.SetFlex(1.0);
        leftToolGroupRoot.SetVisible(false);
        leftDockHost.AddChild(leftToolGroupRoot);
        var leftHeader = GUI.HBox.New();
        leftHeader.SetSpacing(4.0);
        leftHeader.SetPadding(4.0);
        leftToolGroupRoot.AddChild(leftHeader);
        leftToolGroupLabel = GUI.Label.New(leftHeader, "Left tools");
        leftToolGroupLabel.SetFlex(1.0);
        leftToolGroupLabel.SetTooltip(
            "Independent tools docked on the left");
        leftToolMoveBottomButton = GUI.Button.New(leftHeader, "↓");
        leftToolMoveBottomButton.SetPreferredSize(24.0, 24.0);
        leftToolMoveBottomButton.SetAccessibleName(
            "Move active left tool to bottom");
        leftToolMoveBottomButton.SetTooltip(
            "Move the selected left tool below the editor");
        leftToolMoveRightButton = GUI.Button.New(leftHeader, "→");
        leftToolMoveRightButton.SetPreferredSize(24.0, 24.0);
        leftToolMoveRightButton.SetAccessibleName(
            "Move active left tool to right");
        leftToolMoveRightButton.SetTooltip(
            "Move the selected left tool to the right group");
        leftToolMoveFloatingButton = GUI.Button.New(leftHeader, "◇");
        leftToolMoveFloatingButton.SetPreferredSize(24.0, 24.0);
        leftToolMoveFloatingButton.SetAccessibleName(
            "Float active left tool");
        leftToolMoveFloatingButton.SetTooltip(
            "Move the selected left tool into the floating window");
        leftToolGroupHideButton = GUI.Button.New(leftHeader, "");
        leftToolGroupHideButton.SetIconName("close");
        leftToolGroupHideButton.SetPreferredSize(24.0, 24.0);
        leftToolGroupHideButton.SetAccessibleName("Hide left tool group");
        leftToolTabBar = GUI.TabBar.New(leftToolGroupRoot);
        leftToolTabBar.SetAutoClose(false);

        bottomToolGroupRoot = GUI.VBox.New();
        bottomToolGroupRoot.SetName("tool-group-bottom");
        bottomToolGroupRoot.SetSpacing(0.0);
        bottomToolGroupRoot.SetPadding(0.0);
        bottomToolGroupRoot.SetFlex(1.0);
        bottomToolGroupRoot.SetVisible(false);
        bottomDockHost.AddChild(bottomToolGroupRoot);
        var bottomHeader = GUI.HBox.New();
        bottomHeader.SetSpacing(4.0);
        bottomHeader.SetPadding(4.0);
        bottomToolGroupRoot.AddChild(bottomHeader);
        bottomToolGroupLabel = GUI.Label.New(bottomHeader, "Bottom tools");
        bottomToolGroupLabel.SetFlex(1.0);
        bottomToolGroupLabel.SetTooltip(
            "Independent tools docked below the editor");
        bottomToolMoveLeftButton = GUI.Button.New(bottomHeader, "←");
        bottomToolMoveLeftButton.SetPreferredSize(24.0, 24.0);
        bottomToolMoveLeftButton.SetAccessibleName(
            "Move active bottom tool to left");
        bottomToolMoveLeftButton.SetTooltip(
            "Move the selected bottom tool to the left group");
        bottomToolMoveRightButton = GUI.Button.New(bottomHeader, "→");
        bottomToolMoveRightButton.SetPreferredSize(24.0, 24.0);
        bottomToolMoveRightButton.SetAccessibleName(
            "Move active bottom tool to right");
        bottomToolMoveRightButton.SetTooltip(
            "Move the selected bottom tool to the right group");
        bottomToolMoveFloatingButton = GUI.Button.New(bottomHeader, "◇");
        bottomToolMoveFloatingButton.SetPreferredSize(24.0, 24.0);
        bottomToolMoveFloatingButton.SetAccessibleName(
            "Float active bottom tool");
        bottomToolMoveFloatingButton.SetTooltip(
            "Move the selected bottom tool into the floating window");
        bottomToolGroupHideButton = GUI.Button.New(bottomHeader, "");
        bottomToolGroupHideButton.SetIconName("close");
        bottomToolGroupHideButton.SetPreferredSize(24.0, 24.0);
        bottomToolGroupHideButton.SetAccessibleName("Hide bottom tool group");
        bottomToolTabBar = GUI.TabBar.New(bottomToolGroupRoot);
        bottomToolTabBar.SetAutoClose(false);

        rightToolGroupRoot = GUI.VBox.New();
        rightToolGroupRoot.SetName("tool-group-right");
        rightToolGroupRoot.SetSpacing(0.0);
        rightToolGroupRoot.SetPadding(0.0);
        rightToolGroupRoot.SetFlex(1.0);
        rightToolGroupRoot.SetVisible(false);
        rightDockHost.AddChild(rightToolGroupRoot);
        var rightHeader = GUI.HBox.New();
        rightHeader.SetSpacing(4.0);
        rightHeader.SetPadding(4.0);
        rightToolGroupRoot.AddChild(rightHeader);
        rightToolGroupLabel = GUI.Label.New(rightHeader, "Right tools");
        rightToolGroupLabel.SetFlex(1.0);
        rightToolGroupLabel.SetTooltip(
            "Independent tools docked on the right");
        rightToolMoveLeftButton = GUI.Button.New(rightHeader, "←");
        rightToolMoveLeftButton.SetPreferredSize(24.0, 24.0);
        rightToolMoveLeftButton.SetAccessibleName(
            "Move active right tool to left");
        rightToolMoveLeftButton.SetTooltip(
            "Move the selected right tool to the left group");
        rightToolMoveBottomButton = GUI.Button.New(rightHeader, "↓");
        rightToolMoveBottomButton.SetPreferredSize(24.0, 24.0);
        rightToolMoveBottomButton.SetAccessibleName(
            "Move active right tool to bottom");
        rightToolMoveBottomButton.SetTooltip(
            "Move the selected right tool below the editor");
        rightToolMoveFloatingButton = GUI.Button.New(rightHeader, "◇");
        rightToolMoveFloatingButton.SetPreferredSize(24.0, 24.0);
        rightToolMoveFloatingButton.SetAccessibleName(
            "Float active right tool");
        rightToolMoveFloatingButton.SetTooltip(
            "Move the selected right tool into the floating window");
        rightToolGroupHideButton = GUI.Button.New(rightHeader, "");
        rightToolGroupHideButton.SetIconName("close");
        rightToolGroupHideButton.SetPreferredSize(24.0, 24.0);
        rightToolGroupHideButton.SetAccessibleName("Hide right tool group");
        rightToolTabBar = GUI.TabBar.New(rightToolGroupRoot);
        rightToolTabBar.SetAutoClose(false);

        BuildFloatingToolGroup();
    }

    /// @brief Build the movable, resizable in-window tool-group overlay.
    /// @details The overlay owns only presentation widgets. Tool surfaces are
    ///          reparented into its VBox exactly like an attached dock, keeping
    ///          terminal/editor focus and controller state alive.
    hide func BuildFloatingToolGroup() {
        if app == null or floatingToolPanel != null { return; }

        floatingToolPanel = GUI.FloatingPanel.New(app);
        floatingToolPanel.SetVisible(false);

        floatingToolGroupRoot = GUI.VBox.New();
        floatingToolGroupRoot.SetSpacing(0.0);
        floatingToolGroupRoot.SetPadding(0.0);
        floatingToolGroupRoot.SetFlex(1.0);
        floatingToolGroupRoot.SetVisible(false);
        floatingToolPanel.AddChild(floatingToolGroupRoot);

        var floatingHeader = GUI.HBox.New();
        floatingHeader.SetSpacing(4.0);
        floatingHeader.SetPadding(4.0);
        floatingToolGroupRoot.AddChild(floatingHeader);
        floatingToolMoveHandle =
            GUI.Label.New(floatingHeader, "Floating tools · drag");
        floatingToolMoveHandle.SetFlex(1.0);
        floatingToolMoveHandle.SetAccessibleName(
            "Move floating tool window");
        floatingToolMoveHandle.SetTooltip(
            "Drag the window; release at an edge to dock the whole group");

        floatingToolMoveLeftButton = GUI.Button.New(floatingHeader, "←");
        floatingToolMoveLeftButton.SetPreferredSize(24.0, 24.0);
        floatingToolMoveLeftButton.SetAccessibleName(
            "Move active floating tool left");
        floatingToolMoveLeftButton.SetTooltip(
            "Move the selected floating tool to the left group");
        floatingToolMoveBottomButton = GUI.Button.New(floatingHeader, "↓");
        floatingToolMoveBottomButton.SetPreferredSize(24.0, 24.0);
        floatingToolMoveBottomButton.SetAccessibleName(
            "Move active floating tool to bottom");
        floatingToolMoveBottomButton.SetTooltip(
            "Move the selected floating tool below the editor");
        floatingToolMoveRightButton = GUI.Button.New(floatingHeader, "→");
        floatingToolMoveRightButton.SetPreferredSize(24.0, 24.0);
        floatingToolMoveRightButton.SetAccessibleName(
            "Move active floating tool right");
        floatingToolMoveRightButton.SetTooltip(
            "Move the selected floating tool to the right group");
        floatingToolGroupHideButton = GUI.Button.New(floatingHeader, "");
        floatingToolGroupHideButton.SetIconName("close");
        floatingToolGroupHideButton.SetPreferredSize(24.0, 24.0);
        floatingToolGroupHideButton.SetAccessibleName(
            "Hide floating tool group");
        floatingToolGroupHideButton.SetTooltip(
            "Hide the floating tools without closing their state");

        floatingToolTabBar = GUI.TabBar.New(floatingToolGroupRoot);
        floatingToolTabBar.SetAutoClose(false);

        floatingToolResizeRow = GUI.HBox.New();
        floatingToolResizeRow.SetSpacing(4.0);
        floatingToolResizeRow.SetPadding(3.0);
        floatingToolGroupRoot.AddChild(floatingToolResizeRow);
        var resizeHint =
            GUI.Label.New(floatingToolResizeRow, "Floating tool window");
        resizeHint.SetFlex(1.0);
        resizeHint.SetColor(ToolColorMuted());
        floatingToolResizeHandle =
            GUI.Label.New(floatingToolResizeRow, "↘");
        floatingToolResizeHandle.SetPreferredSize(28.0, 22.0);
        floatingToolResizeHandle.SetAccessibleName(
            "Resize floating tool window");
        floatingToolResizeHandle.SetTooltip(
            "Drag to resize the floating tool window");

        ApplyFloatingPanelBounds(
            floatingPanelX, floatingPanelY,
            floatingPanelWidth, floatingPanelHeight, false);
    }

    /// @brief Build four stationary workbench targets for panel-header drags.
    /// @details Manual positioning keeps these late children above the normal
    ///          HBox layout without allowing them to consume editor space.
    hide func BuildDockTargets() {
        if workspaceDropTarget == null or dockLeftTarget != null { return; }

        dockLeftTarget = GUI.Button.New(workspaceDropTarget, "Dock Left");
        ConfigureDockTarget(dockLeftTarget,
                            workspace_dock.DOCK_LEFT,
                            "Move the panel area to the left side",
                            "←",
                            0);
        dockRightTarget = GUI.Button.New(workspaceDropTarget, "Dock Right");
        ConfigureDockTarget(dockRightTarget,
                            workspace_dock.DOCK_RIGHT,
                            "Move the panel area to the right side",
                            "→",
                            1);
        dockFloatTarget = GUI.Button.New(workspaceDropTarget, "Float");
        ConfigureDockTarget(dockFloatTarget,
                            workspace_dock.DOCK_FLOATING,
                            "Move the panel group into a floating window",
                            "◇",
                            0);
        // Build Bottom last so it wins hit testing if an unusually compact
        // workbench ever makes the manual target cards overlap.
        dockBottomTarget = GUI.Button.New(workspaceDropTarget, "Dock Bottom");
        ConfigureDockTarget(dockBottomTarget,
                            workspace_dock.DOCK_BOTTOM,
                            "Move the panel area below the editor",
                            "↓",
                            1);
    }

    /// @brief Configure one visible target as a real typed drop receiver.
    hide func ConfigureDockTarget(target: GUI.Button,
                                  location: Integer,
                                  tooltip: String,
                                  icon: String,
                                  iconPosition: Integer) {
        if target == null { return; }
        target.SetName("dock-target-" + workspace_dock.DockLocationName(location));
        target.SetStyle(2);
        target.SetIcon(icon);
        target.SetIconPosition(iconPosition);
        target.SetTooltipRich("Dock panels", tooltip);
        target.SetPosition(0, 0);
        target.SetSize(1, 1);
        target.SetDropTarget(true);
        target.SetAcceptedDropTypes(workspace_dock.TOOL_PANEL_DRAG_TYPE);
        target.SetVisible(false);
    }

    /// @brief Show or hide direct-manipulation targets for an active drag.
    /// @details Exposed so deterministic GUI automation can verify the same
    ///          production surface; callers cannot author a dock change here.
    expose func SetDockDragTargetsVisible(visible: Boolean) {
        if dockLeftTarget == null
           or dockBottomTarget == null
           or dockRightTarget == null
           or dockFloatTarget == null {
            dockTargetsVisible = false;
            return;
        }

        if visible {
            LayoutDockTargets();
            if !dockTargetsVisible {
                dockLeftTarget.SetVisible(true);
                dockBottomTarget.SetVisible(true);
                dockRightTarget.SetVisible(true);
                dockFloatTarget.SetVisible(true);
                ApplyDockTargetFeedback(
                    workspace_dock.DOCK_NONE, dockLocation);
            }
        } else if dockTargetsVisible {
            dockLeftTarget.SetVisible(false);
            dockBottomTarget.SetVisible(false);
            dockRightTarget.SetVisible(false);
            dockFloatTarget.SetVisible(false);
            dockTargetHoverLocation = workspace_dock.DOCK_NONE;
        }
        dockTargetsVisible = visible;
    }

    /// @brief Return whether the stationary target cards are currently shown.
    expose func AreDockDragTargetsVisible() -> Boolean {
        return dockTargetsVisible;
    }

    /// @brief Keep the four target cards inside the current workbench bounds.
    hide func LayoutDockTargets() {
        if workspaceDropTarget == null { return; }
        var width = workspaceDropTarget.GetLogicalWidth();
        var height = workspaceDropTarget.GetLogicalHeight();
        var targetWidth =
            Convert.NumToInt(workspace_dock.DockTargetWidth(width));
        var targetHeight =
            Convert.NumToInt(workspace_dock.DockTargetHeight(height));
        if targetWidth < 1 or targetHeight < 1 { return; }

        dockLeftTarget.SetPosition(
            Convert.NumToInt(workspace_dock.DockTargetX(
                workspace_dock.DOCK_LEFT, width)),
            Convert.NumToInt(workspace_dock.DockTargetY(
                workspace_dock.DOCK_LEFT, height)));
        dockLeftTarget.SetSize(targetWidth, targetHeight);
        dockRightTarget.SetPosition(
            Convert.NumToInt(workspace_dock.DockTargetX(
                workspace_dock.DOCK_RIGHT, width)),
            Convert.NumToInt(workspace_dock.DockTargetY(
                workspace_dock.DOCK_RIGHT, height)));
        dockRightTarget.SetSize(targetWidth, targetHeight);
        dockBottomTarget.SetPosition(
            Convert.NumToInt(workspace_dock.DockTargetX(
                workspace_dock.DOCK_BOTTOM, width)),
            Convert.NumToInt(workspace_dock.DockTargetY(
                workspace_dock.DOCK_BOTTOM, height)));
        dockBottomTarget.SetSize(targetWidth, targetHeight);
        dockFloatTarget.SetPosition(
            Convert.NumToInt(workspace_dock.DockTargetX(
                workspace_dock.DOCK_FLOATING, width)),
            Convert.NumToInt(workspace_dock.DockTargetY(
                workspace_dock.DOCK_FLOATING, height)));
        dockFloatTarget.SetSize(targetWidth, targetHeight);
    }

    /// @brief Return the explicit target currently under the drag pointer.
    hide func DockTargetHoverLocation() -> Integer {
        if dockBottomTarget != null and dockBottomTarget.IsDragOver() {
            return workspace_dock.DOCK_BOTTOM;
        }
        if dockFloatTarget != null and dockFloatTarget.IsDragOver() {
            return workspace_dock.DOCK_FLOATING;
        }
        if dockLeftTarget != null and dockLeftTarget.IsDragOver() {
            return workspace_dock.DOCK_LEFT;
        }
        if dockRightTarget != null and dockRightTarget.IsDragOver() {
            return workspace_dock.DOCK_RIGHT;
        }
        return workspace_dock.DOCK_NONE;
    }

    /// @brief Apply concise copy and a primary hover treatment to target cards.
    hide func ApplyDockTargetFeedback(hoverLocation: Integer,
                                      currentLocation: Integer) {
        dockTargetHoverLocation = hoverLocation;
        dockLeftTarget.SetText(workspace_dock.DockTargetText(
            workspace_dock.DOCK_LEFT,
            currentLocation,
            hoverLocation == workspace_dock.DOCK_LEFT));
        dockBottomTarget.SetText(workspace_dock.DockTargetText(
            workspace_dock.DOCK_BOTTOM,
            currentLocation,
            hoverLocation == workspace_dock.DOCK_BOTTOM));
        dockRightTarget.SetText(workspace_dock.DockTargetText(
            workspace_dock.DOCK_RIGHT,
            currentLocation,
            hoverLocation == workspace_dock.DOCK_RIGHT));
        dockFloatTarget.SetText(workspace_dock.DockTargetText(
            workspace_dock.DOCK_FLOATING,
            currentLocation,
            hoverLocation == workspace_dock.DOCK_FLOATING));

        dockLeftTarget.SetStyle(
            DockTargetStyle(
                workspace_dock.DOCK_LEFT, hoverLocation, currentLocation));
        dockBottomTarget.SetStyle(
            DockTargetStyle(
                workspace_dock.DOCK_BOTTOM, hoverLocation, currentLocation));
        dockRightTarget.SetStyle(
            DockTargetStyle(
                workspace_dock.DOCK_RIGHT, hoverLocation, currentLocation));
        dockFloatTarget.SetStyle(
            DockTargetStyle(
                workspace_dock.DOCK_FLOATING,
                hoverLocation,
                currentLocation));
    }

    /// @brief Return primary/secondary/default styling for one dock card.
    hide func DockTargetStyle(location: Integer,
                              hoverLocation: Integer,
                              currentLocation: Integer) -> Integer {
        if location == hoverLocation { return 1; }
        if location == currentLocation { return 0; }
        return 2;
    }

    /// @brief Consume a valid typed drop from one explicit target.
    hide func DockTargetWasDropped(target: GUI.Button) -> Boolean {
        if target == null or !target.WasDropped() { return false; }
        return target.GetDropType() == workspace_dock.TOOL_PANEL_DRAG_TYPE
            and target.GetDropData() == workspace_dock.TOOL_PANEL_DRAG_DATA;
    }

    /// @brief Consume any explicit target drop and return its location.
    hide func TakeDockTargetDrop() -> Integer {
        if DockTargetWasDropped(dockBottomTarget) {
            return workspace_dock.DOCK_BOTTOM;
        }
        if DockTargetWasDropped(dockLeftTarget) {
            return workspace_dock.DOCK_LEFT;
        }
        if DockTargetWasDropped(dockRightTarget) {
            return workspace_dock.DOCK_RIGHT;
        }
        if DockTargetWasDropped(dockFloatTarget) {
            return workspace_dock.DOCK_FLOATING;
        }
        return workspace_dock.DOCK_NONE;
    }

    /// @brief Apply a persisted dock name without publishing a user change.
    expose func SetDockLocationName(name: String) {
        ApplyDockLocation(workspace_dock.DockLocationFromName(name), false);
    }

    /// @brief Restore the durable tool-dock geometry and tab order defaults.
    /// @details This is an explicit recovery action, so stale drag edges are
    ///          cleared after the controller-authored reset.
    expose func ResetWorkspaceLayout() {
        SetToolPanelGroupLayout(
            "", "bottom", tool_panel_model.DEFAULT_TAB_ORDER);
        SetBottomSplitPct(70);
        SetSidePanelWidthPct(30);
        SetFloatingToolPanelBounds(
            FLOATING_PANEL_DEFAULT_X,
            FLOATING_PANEL_DEFAULT_Y,
            FLOATING_PANEL_DEFAULT_WIDTH,
            FLOATING_PANEL_DEFAULT_HEIGHT);
        HidePanelArea();
        splitFractionDirty = false;
        sideFractionDirty = false;
        dockLocationDirty = false;
        toolTabOrderDirty = false;
        toolPanelGroupLayoutDirty = false;
        floatingPanelGeometryDirty = false;
    }

    /// @brief Move the primary attached group to an edge or floating window.
    /// @param location One supported workspace_dock tool location.
    expose func MovePanelTo(location: Integer) {
        if location == workspace_dock.DOCK_FLOATING {
            MergeToolGroupLocation(
                dockLocation, workspace_dock.DOCK_FLOATING, true);
            return;
        }
        ApplyDockLocation(location, true);
    }

    /// @brief Return the current durable dock name.
    expose func GetDockLocationName() -> String {
        return workspace_dock.DockLocationName(dockLocation);
    }

    /// @brief Consume one user-authored dock-location change.
    /// @return "left", "bottom", "right", or empty when unchanged.
    expose func TakeChangedDockLocation() -> String {
        if dockLocationDirty == false { return ""; }
        dockLocationDirty = false;
        return GetDockLocationName();
    }

    /// @brief Apply a persisted side-panel width percentage.
    /// @param pct Panel share of the side splitter, clamped to [20, 55].
    expose func SetSidePanelWidthPct(pct: Integer) {
        var clamped = pct;
        if clamped < 20 { clamped = 20; }
        if clamped > 55 { clamped = 55; }
        sidePanelFraction = clamped / 100.0;
        if activeLeftToolPanelKind != tool_panel_model.PANEL_NONE {
            ApplySidePanelSplitAt(workspace_dock.DOCK_LEFT);
        }
        if activeRightToolPanelKind != tool_panel_model.PANEL_NONE {
            ApplySidePanelSplitAt(workspace_dock.DOCK_RIGHT);
        }
    }

    /// @brief Consume one user-authored side-panel width change.
    /// @return Rounded panel width percentage, or -1 when unchanged.
    expose func TakeChangedSidePanelWidthPercent() -> Integer {
        if sideFractionDirty == false { return -1; }
        sideFractionDirty = false;
        var scaled = sidePanelFraction * 100.0;
        var pct = 20;
        while pct < 55 and scaled >= pct + 0.5 {
            pct = pct + 1;
        }
        return pct;
    }

    /// @brief Apply persisted floating-window geometry without publishing input.
    expose func SetFloatingToolPanelBounds(x: Integer,
                                           y: Integer,
                                           width: Integer,
                                           height: Integer) {
        ApplyFloatingPanelBounds(x, y, width, height, false);
        floatingPanelGeometryDirty = false;
    }

    /// @brief Consume one user-authored floating move or resize edge.
    expose func TakeFloatingToolPanelGeometryChanged() -> Boolean {
        if !floatingPanelGeometryDirty { return false; }
        floatingPanelGeometryDirty = false;
        return true;
    }

    /// @brief Return the durable floating-window X coordinate.
    expose func GetFloatingToolPanelX() -> Integer { return floatingPanelX; }

    /// @brief Return the durable floating-window Y coordinate.
    expose func GetFloatingToolPanelY() -> Integer { return floatingPanelY; }

    /// @brief Return the durable floating-window width.
    expose func GetFloatingToolPanelWidth() -> Integer {
        return floatingPanelWidth;
    }

    /// @brief Return the durable floating-window height.
    expose func GetFloatingToolPanelHeight() -> Integer {
        return floatingPanelHeight;
    }

    /// @brief Clamp, apply, and optionally publish floating-window geometry.
    hide func ApplyFloatingPanelBounds(x: Integer,
                                       y: Integer,
                                       width: Integer,
                                       height: Integer,
                                       userAuthored: Boolean) {
        var viewportWidth = FloatingViewportWidth();
        var viewportHeight = FloatingViewportHeight();
        var margin = FLOATING_PANEL_VIEWPORT_MARGIN;

        var maxWidth = viewportWidth - margin * 2;
        var maxHeight = viewportHeight - margin * 2;
        if maxWidth < 1 { maxWidth = viewportWidth; }
        if maxHeight < 1 { maxHeight = viewportHeight; }
        if maxWidth < 1 { maxWidth = 1; }
        if maxHeight < 1 { maxHeight = 1; }

        var minWidth = FLOATING_PANEL_MIN_WIDTH;
        var minHeight = FLOATING_PANEL_MIN_HEIGHT;
        if minWidth > maxWidth { minWidth = maxWidth; }
        if minHeight > maxHeight { minHeight = maxHeight; }

        var clampedWidth = width;
        var clampedHeight = height;
        if clampedWidth < minWidth { clampedWidth = minWidth; }
        if clampedWidth > maxWidth { clampedWidth = maxWidth; }
        if clampedHeight < minHeight { clampedHeight = minHeight; }
        if clampedHeight > maxHeight { clampedHeight = maxHeight; }

        var minX = margin;
        var minY = margin;
        var maxX = viewportWidth - margin - clampedWidth;
        var maxY = viewportHeight - margin - clampedHeight;
        if maxX < minX {
            minX = 0;
            maxX = viewportWidth - clampedWidth;
            if maxX < 0 { maxX = 0; }
        }
        if maxY < minY {
            minY = 0;
            maxY = viewportHeight - clampedHeight;
            if maxY < 0 { maxY = 0; }
        }

        var clampedX = x;
        var clampedY = y;
        if clampedX < minX { clampedX = minX; }
        if clampedX > maxX { clampedX = maxX; }
        if clampedY < minY { clampedY = minY; }
        if clampedY > maxY { clampedY = maxY; }

        var changed = clampedX != floatingPanelX
            or clampedY != floatingPanelY
            or clampedWidth != floatingPanelWidth
            or clampedHeight != floatingPanelHeight;
        floatingPanelX = clampedX;
        floatingPanelY = clampedY;
        floatingPanelWidth = clampedWidth;
        floatingPanelHeight = clampedHeight;
        if floatingToolPanel != null {
            floatingToolPanel.SetPosition(floatingPanelX, floatingPanelY);
            floatingToolPanel.SetSize(
                floatingPanelWidth, floatingPanelHeight);
        }
        if floatingToolGroupRoot != null {
            floatingToolGroupRoot.SetPreferredSize(
                floatingPanelWidth, floatingPanelHeight);
        }
        if userAuthored and changed {
            floatingPanelGeometryDirty = true;
        }
    }

    /// @brief Return the app width in effective UI-layout units.
    hide func FloatingViewportWidth() -> Integer {
        if app == null { return 1280; }
        var scale = app.GetEffectiveScale();
        if scale <= 0.0 { scale = 1.0; }
        var width = Convert.NumToInt(app.GetWidth() / scale);
        if width < 1 { return 1280; }
        return width;
    }

    /// @brief Return the app height in effective UI-layout units.
    hide func FloatingViewportHeight() -> Integer {
        if app == null { return 720; }
        var scale = app.GetEffectiveScale();
        if scale <= 0.0 { scale = 1.0; }
        var height = Convert.NumToInt(app.GetHeight() / scale);
        if height < 1 { return 720; }
        return height;
    }

    /// @brief Convert one framebuffer pointer coordinate into UI-layout units.
    hide func PointerToFloatingUnits(value: Number) -> Number {
        if app == null { return value; }
        var scale = app.GetEffectiveScale();
        if scale <= 0.0 { scale = 1.0; }
        return value / scale;
    }

    /// @brief Return whether one logical pointer is inside a visible widget.
    hide func FloatingPointerInside(widget: GUI.Widget,
                                    pointerX: Number,
                                    pointerY: Number) -> Boolean {
        if widget == null or !widget.IsVisible() { return false; }
        return pointerX >= widget.GetScreenX()
            and pointerY >= widget.GetScreenY()
            and pointerX
                <= widget.GetScreenX() + widget.GetScreenWidth()
            and pointerY
                <= widget.GetScreenY() + widget.GetScreenHeight();
    }

    /// @brief Resolve an intentional floating-group dock target.
    /// @details Visible target cards win, followed by a narrow workbench-edge
    ///          strip. This keeps small window moves from becoming surprise
    ///          full-group dock operations.
    hide func FloatingDockLocationForPointer(pointerX: Number,
                                             pointerY: Number) -> Integer {
        if FloatingPointerInside(dockBottomTarget, pointerX, pointerY) {
            return workspace_dock.DOCK_BOTTOM;
        }
        if FloatingPointerInside(dockFloatTarget, pointerX, pointerY) {
            return workspace_dock.DOCK_FLOATING;
        }
        if FloatingPointerInside(dockLeftTarget, pointerX, pointerY) {
            return workspace_dock.DOCK_LEFT;
        }
        if FloatingPointerInside(dockRightTarget, pointerX, pointerY) {
            return workspace_dock.DOCK_RIGHT;
        }
        if workspaceDropTarget == null { return workspace_dock.DOCK_NONE; }
        return workspace_dock.FloatingSnapEdgeForPointer(
            pointerX,
            pointerY,
            workspaceDropTarget.GetScreenX(),
            workspaceDropTarget.GetScreenY(),
            workspaceDropTarget.GetScreenWidth(),
            workspaceDropTarget.GetScreenHeight());
    }

    /// @brief Recover floating geometry after a resize or UI-scale change.
    hide func KeepFloatingPanelInViewport() {
        var width = FloatingViewportWidth();
        var height = FloatingViewportHeight();
        var scale = 1.0;
        if app != null {
            scale = app.GetEffectiveScale();
            if scale <= 0.0 { scale = 1.0; }
        }
        var scaleDelta = scale - floatingViewportScale;
        if scaleDelta < 0.0 { scaleDelta = 0.0 - scaleDelta; }
        if width == floatingViewportWidth
           and height == floatingViewportHeight
           and scaleDelta <= 0.0001 {
            return;
        }
        floatingViewportWidth = width;
        floatingViewportHeight = height;
        floatingViewportScale = scale;
        ApplyFloatingPanelBounds(
            floatingPanelX, floatingPanelY,
            floatingPanelWidth, floatingPanelHeight, false);
    }

    /// @brief Float the complete primary attached group without losing order.
    /// @return True when at least one panel changed location.
    expose func FloatPrimaryToolPanelGroup() -> Boolean {
        return MergeToolGroupLocation(
            dockLocation, workspace_dock.DOCK_FLOATING, true);
    }

    /// @brief Merge one complete group into another while preserving live state.
    hide func MergeToolGroupLocation(source: Integer,
                                     destination: Integer,
                                     userAuthored: Boolean) -> Boolean {
        if !workspace_dock.IsToolLocation(source)
           or !workspace_dock.IsToolLocation(destination)
           or source == destination
           or !toolPanelGroups.HasIdsAt(source) {
            return false;
        }

        var sourceActive = ActiveToolPanelKindAt(source);
        var restoreFocusId = FocusedToolControlId();
        var stableOrder = toolPanelGroups.order;
        var ids = Str.Split(toolPanelGroups.IdsAt(source), ",");
        var i = 0;
        while i < Seq.get_Count(ids) {
            var id = Str.Trim(Obj.ToString(Seq.Get(ids, i)));
            var kind = tool_panel_model.PanelKindForTabId(id);
            if kind != tool_panel_model.PANEL_NONE {
                TransferToolPanel(kind, destination, false);
            }
            i = i + 1;
        }
        toolPanelGroups.SetCompleteOrder(stableOrder);
        ApplyToolTabOrderAt(workspace_dock.DOCK_LEFT);
        ApplyToolTabOrderAt(workspace_dock.DOCK_BOTTOM);
        ApplyToolTabOrderAt(workspace_dock.DOCK_RIGHT);
        ApplyToolTabOrderAt(workspace_dock.DOCK_FLOATING);
        KeepFloatingResizeRowLast();

        if sourceActive != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(sourceActive);
        }
        RestoreToolControlFocus(restoreFocusId);
        if userAuthored {
            toolPanelGroupLayoutDirty = true;
        }
        return true;
    }

    /// @brief Move the primary group, merging an occupied destination group.
    hide func ApplyDockLocation(location: Integer, userAuthored: Boolean) {
        if workspace_dock.IsDockLocation(location) == false { return; }
        if location == dockLocation {
            UpdateDockButtons();
            return;
        }

        var source = dockLocation;
        var restorePanelId = GetActiveToolPanelId();
        var restoreFocusId = FocusedToolControlId();
        var restoreLeft = activeLeftToolPanelKind;
        var restoreBottom = activeBottomToolPanelKind;
        var restoreRight = activeRightToolPanelKind;
        var restoreFloating = activeFloatingToolPanelKind;
        HideAllToolPanels();
        RetireAllToolTabs();
        CollapseAllDockSplits();

        toolPanelGroups.MergeLocation(source, location);
        if panelRoot != null {
            if location == workspace_dock.DOCK_LEFT and leftDockHost != null {
                leftDockHost.AddChild(panelRoot);
            } else if location == workspace_dock.DOCK_RIGHT
                      and rightDockHost != null {
                rightDockHost.AddChild(panelRoot);
            } else if bottomDockHost != null {
                bottomDockHost.AddChild(panelRoot);
            }
        }
        dockLocation = location;
        ApplyResponsiveDockHeader();
        RebuildAllToolTabs();
        toolTabBar.SetVisible(false);
        leftToolTabBar.SetVisible(false);
        bottomToolTabBar.SetVisible(false);
        rightToolTabBar.SetVisible(false);
        floatingToolTabBar.SetVisible(false);
        panelRoot.SetVisible(false);
        leftToolGroupRoot.SetVisible(false);
        bottomToolGroupRoot.SetVisible(false);
        rightToolGroupRoot.SetVisible(false);
        floatingToolGroupRoot.SetVisible(false);
        floatingToolPanel.SetVisible(false);
        activeLeftToolPanelKind = tool_panel_model.PANEL_NONE;
        activeBottomToolPanelKind = tool_panel_model.PANEL_NONE;
        activeRightToolPanelKind = tool_panel_model.PANEL_NONE;
        activeFloatingToolPanelKind = tool_panel_model.PANEL_NONE;
        SetActiveToolPanelKind(tool_panel_model.PANEL_NONE);

        if restoreLeft != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(restoreLeft);
        }
        if restoreBottom != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(restoreBottom);
        }
        if restoreRight != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(restoreRight);
        }
        if restoreFloating != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(restoreFloating);
        }
        if restorePanelId != tool_panel_model.TAB_ID_NONE {
            ShowToolPanelKind(
                tool_panel_model.PanelKindForTabId(restorePanelId));
        }
        RestoreToolControlFocus(restoreFocusId);
        UpdateDockButtons();
        if userAuthored {
            dockLocationDirty = true;
            toolPanelGroupLayoutDirty = true;
        }
    }

    /// @brief Disable the button representing the current dock.
    hide func UpdateDockButtons() {
        if dockLeftButton != null {
            dockLeftButton.SetEnabled(dockLocation != workspace_dock.DOCK_LEFT);
        }
        if dockBottomButton != null {
            dockBottomButton.SetEnabled(dockLocation != workspace_dock.DOCK_BOTTOM);
        }
        if dockRightButton != null {
            dockRightButton.SetEnabled(dockLocation != workspace_dock.DOCK_RIGHT);
        }
    }

    /// @brief Collapse every possible tool dock before a move or full hide.
    hide func CollapseAllDockSplits() {
        if editorSplit != null { editorSplit.CollapseSecond(); }
        if leftDockSplit != null { leftDockSplit.CollapseFirst(); }
        if rightDockSplit != null { rightDockSplit.CollapseSecond(); }
    }

    /// @brief Poll explicit controls and edge-drop docking.
    hide func PumpDockControls() {
        var primaryKind = ActiveToolPanelKindAt(dockLocation);
        if dockLeftButton != null and dockLeftButton.WasClicked() {
            TransferToolPanel(
                primaryKind, workspace_dock.DOCK_LEFT, true);
        } else if dockBottomButton != null and dockBottomButton.WasClicked() {
            TransferToolPanel(
                primaryKind, workspace_dock.DOCK_BOTTOM, true);
        } else if dockRightButton != null and dockRightButton.WasClicked() {
            TransferToolPanel(
                primaryKind, workspace_dock.DOCK_RIGHT, true);
        } else if dockFloatButton != null and dockFloatButton.WasClicked() {
            TransferToolPanel(
                primaryKind, workspace_dock.DOCK_FLOATING, true);
        }

        var explicitDropLocation = TakeDockTargetDrop();
        var dragging = dockDragHandle != null
            and dockDragHandle.IsBeingDragged();
        if dragging and workspaceDropTarget != null {
            SetDockDragTargetsVisible(true);
            var hoverLocation = DockTargetHoverLocation();
            if hoverLocation == workspace_dock.DOCK_NONE {
                hoverLocation = workspace_dock.DockEdgeForPointer(
                    PointerToFloatingUnits(Input.Mouse.X()),
                    PointerToFloatingUnits(Input.Mouse.Y()),
                    workspaceDropTarget.GetScreenX(),
                    workspaceDropTarget.GetScreenY(),
                    workspaceDropTarget.GetScreenWidth(),
                    workspaceDropTarget.GetScreenHeight());
            }
            if hoverLocation != dockTargetHoverLocation {
                ApplyDockTargetFeedback(hoverLocation, dockLocation);
            }
            dockDragHandle.SetText(
                workspace_dock.DockDragHint(hoverLocation));
        } else if !dragging and dockDragWasActive {
            dockDragHandle.SetText(DefaultDockHeaderText());
        }
        if !dragging { SetDockDragTargetsVisible(false); }
        dockDragWasActive = dragging;

        if explicitDropLocation != workspace_dock.DOCK_NONE {
            MovePanelTo(explicitDropLocation);
        } else if workspaceDropTarget != null and workspaceDropTarget.WasDropped()
           and workspaceDropTarget.GetDropType()
               == workspace_dock.TOOL_PANEL_DRAG_TYPE
           and workspaceDropTarget.GetDropData()
               == workspace_dock.TOOL_PANEL_DRAG_DATA {
            var location = workspace_dock.DockLocationForPointer(
                PointerToFloatingUnits(Input.Mouse.X()),
                PointerToFloatingUnits(Input.Mouse.Y()),
                workspaceDropTarget.GetScreenX(),
                workspaceDropTarget.GetScreenY(),
                workspaceDropTarget.GetScreenWidth(),
                workspaceDropTarget.GetScreenHeight(),
                dockLocation);
            MovePanelTo(location);
        }

        if dockHideButton != null and dockHideButton.WasClicked() {
            HidePanelArea();
        }
        if leftToolMoveBottomButton != null
           and leftToolMoveBottomButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_LEFT),
                workspace_dock.DOCK_BOTTOM, true);
        }
        if leftToolMoveRightButton != null
           and leftToolMoveRightButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_LEFT),
                workspace_dock.DOCK_RIGHT, true);
        }
        if leftToolMoveFloatingButton != null
           and leftToolMoveFloatingButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_LEFT),
                workspace_dock.DOCK_FLOATING, true);
        }
        if bottomToolMoveLeftButton != null
           and bottomToolMoveLeftButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_BOTTOM),
                workspace_dock.DOCK_LEFT, true);
        }
        if bottomToolMoveRightButton != null
           and bottomToolMoveRightButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_BOTTOM),
                workspace_dock.DOCK_RIGHT, true);
        }
        if bottomToolMoveFloatingButton != null
           and bottomToolMoveFloatingButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_BOTTOM),
                workspace_dock.DOCK_FLOATING, true);
        }
        if rightToolMoveLeftButton != null
           and rightToolMoveLeftButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_RIGHT),
                workspace_dock.DOCK_LEFT, true);
        }
        if rightToolMoveBottomButton != null
           and rightToolMoveBottomButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_RIGHT),
                workspace_dock.DOCK_BOTTOM, true);
        }
        if rightToolMoveFloatingButton != null
           and rightToolMoveFloatingButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_RIGHT),
                workspace_dock.DOCK_FLOATING, true);
        }
        if leftToolGroupHideButton != null
           and leftToolGroupHideButton.WasClicked() {
            HideToolGroupAt(workspace_dock.DOCK_LEFT);
        }
        if bottomToolGroupHideButton != null
           and bottomToolGroupHideButton.WasClicked() {
            HideToolGroupAt(workspace_dock.DOCK_BOTTOM);
        }
        if rightToolGroupHideButton != null
           and rightToolGroupHideButton.WasClicked() {
            HideToolGroupAt(workspace_dock.DOCK_RIGHT);
        }
        PumpFloatingToolGroupControls();
    }

    /// @brief Poll floating-window move, resize, dock, and per-tool controls.
    hide func PumpFloatingToolGroupControls() {
        KeepFloatingPanelInViewport();
        if floatingToolPanel == null or floatingToolMoveHandle == null {
            return;
        }

        if floatingToolMoveLeftButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_FLOATING),
                workspace_dock.DOCK_LEFT, true);
        } else if floatingToolMoveBottomButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_FLOATING),
                workspace_dock.DOCK_BOTTOM, true);
        } else if floatingToolMoveRightButton.WasClicked() {
            TransferToolPanel(
                ActiveToolPanelKindAt(workspace_dock.DOCK_FLOATING),
                workspace_dock.DOCK_RIGHT, true);
        }
        if floatingToolGroupHideButton.WasClicked() {
            HideToolGroupAt(workspace_dock.DOCK_FLOATING);
        }

        if !floatingToolPanel.IsVisible() {
            var wasManipulating =
                floatingPanelMoving or floatingPanelResizing;
            floatingPanelMoving = false;
            floatingPanelResizing = false;
            if wasManipulating {
                SetDockDragTargetsVisible(false);
            }
            return;
        }

        var pointerX = PointerToFloatingUnits(Input.Mouse.X());
        var pointerY = PointerToFloatingUnits(Input.Mouse.Y());
        var leftDown = Input.Mouse.IsDown(Input.Mouse.ButtonLeft);

        if !floatingPanelMoving and !floatingPanelResizing
           and leftDown and floatingToolMoveHandle.IsPressed() {
            floatingPanelMoving = true;
            floatingPanelManipulationChanged = false;
            floatingPointerOffsetX = pointerX - floatingPanelX;
            floatingPointerOffsetY = pointerY - floatingPanelY;
            floatingMoveStartX = floatingPanelX;
            floatingMoveStartY = floatingPanelY;
        }
        if !floatingPanelMoving and !floatingPanelResizing
           and leftDown and floatingToolResizeHandle.IsPressed() {
            floatingPanelResizing = true;
            floatingPanelManipulationChanged = false;
            floatingResizeStartPointerX = pointerX;
            floatingResizeStartPointerY = pointerY;
            floatingResizeStartWidth = floatingPanelWidth;
            floatingResizeStartHeight = floatingPanelHeight;
        }

        if floatingPanelMoving {
            if leftDown {
                var oldX = floatingPanelX;
                var oldY = floatingPanelY;
                ApplyFloatingPanelBounds(
                    Convert.NumToInt(pointerX - floatingPointerOffsetX),
                    Convert.NumToInt(pointerY - floatingPointerOffsetY),
                    floatingPanelWidth,
                    floatingPanelHeight,
                    false);
                if oldX != floatingPanelX or oldY != floatingPanelY {
                    floatingPanelManipulationChanged = true;
                }

                SetDockDragTargetsVisible(true);
                var hoverLocation =
                    FloatingDockLocationForPointer(pointerX, pointerY);
                ApplyDockTargetFeedback(
                    hoverLocation, workspace_dock.DOCK_FLOATING);
                if hoverLocation == workspace_dock.DOCK_NONE {
                    floatingToolMoveHandle.SetText(
                        "Moving floating tools · release to place");
                } else {
                    floatingToolMoveHandle.SetText(
                        workspace_dock.DockDragHint(hoverLocation));
                }
            } else {
                floatingPanelMoving = false;
                var dropLocation =
                    FloatingDockLocationForPointer(pointerX, pointerY);
                SetDockDragTargetsVisible(false);
                if workspace_dock.IsDockLocation(dropLocation) {
                    ApplyFloatingPanelBounds(
                        floatingMoveStartX,
                        floatingMoveStartY,
                        floatingPanelWidth,
                        floatingPanelHeight,
                        false);
                    MergeToolGroupLocation(
                        workspace_dock.DOCK_FLOATING,
                        dropLocation,
                        true);
                } else if floatingPanelManipulationChanged {
                    floatingPanelGeometryDirty = true;
                }
                floatingPanelManipulationChanged = false;
                floatingToolMoveHandle.SetText(
                    DefaultFloatingToolHeaderText());
            }
        } else if floatingPanelResizing {
            if leftDown {
                var oldWidth = floatingPanelWidth;
                var oldHeight = floatingPanelHeight;
                ApplyFloatingPanelBounds(
                    floatingPanelX,
                    floatingPanelY,
                    floatingResizeStartWidth
                        + Convert.NumToInt(
                            pointerX - floatingResizeStartPointerX),
                    floatingResizeStartHeight
                        + Convert.NumToInt(
                            pointerY - floatingResizeStartPointerY),
                    false);
                if oldWidth != floatingPanelWidth
                   or oldHeight != floatingPanelHeight {
                    floatingPanelManipulationChanged = true;
                }
            } else {
                floatingPanelResizing = false;
                if floatingPanelManipulationChanged {
                    floatingPanelGeometryDirty = true;
                }
                floatingPanelManipulationChanged = false;
            }
        }
    }

    /// @brief Return useful resting copy for the floating move handle.
    hide func DefaultFloatingToolHeaderText() -> String {
        var kind = ActiveToolPanelKindAt(workspace_dock.DOCK_FLOATING);
        if kind == tool_panel_model.PANEL_NONE {
            return "Floating tools · drag";
        }
        return "Floating · " + tool_panel_model.PanelName(kind) + " · drag";
    }

    /// @brief Return the resting drag-handle label for the current header mode.
    hide func DefaultDockHeaderText() -> String {
        if compactDockHeader { return "Panels"; }
        return "Panels  -  drag to dock or float";
    }

    /// @brief Return whether the dock header is using its narrow control set.
    expose func IsDockHeaderCompact() -> Boolean {
        return compactDockHeader;
    }

    /// @brief Keep all docking controls visible in narrow and side-dock headers.
    /// @details Full labels remain in a roomy bottom dock. Side docks use compact
    ///          directional glyphs plus unchanged descriptive tooltips, leaving
    ///          enough drag-handle surface for direct movement.
    hide func ApplyResponsiveDockHeader() {
        if panelRoot == null or dockDragHandle == null { return; }
        var width = panelRoot.GetLogicalWidth();
        if width <= 0.0 { return; }
        var compact = dockLocation != workspace_dock.DOCK_BOTTOM
            or width <= 480.0;
        if compact == compactDockHeader
           and dockHeaderLocation == dockLocation {
            return;
        }
        compactDockHeader = compact;
        dockHeaderLocation = dockLocation;
        dockDragHandle.SetText(DefaultDockHeaderText());
        if compactDockHeader {
            dockLeftButton.SetText("←");
            dockBottomButton.SetText("↓");
            dockRightButton.SetText("→");
            dockFloatButton.SetText("◇");
            dockHideButton.SetText("");
            dockHideButton.SetIconName("close");
            dockLeftButton.SetSize(24, 24);
            dockBottomButton.SetSize(24, 24);
            dockRightButton.SetSize(24, 24);
            dockFloatButton.SetSize(24, 24);
            dockHideButton.SetSize(24, 24);
            dockLeftButton.SetVisible(
                dockLocation != workspace_dock.DOCK_LEFT);
            dockBottomButton.SetVisible(
                dockLocation != workspace_dock.DOCK_BOTTOM);
            dockRightButton.SetVisible(
                dockLocation != workspace_dock.DOCK_RIGHT);
            dockFloatButton.SetVisible(true);
        } else {
            dockLeftButton.SetText("Left");
            dockBottomButton.SetText("Bottom");
            dockRightButton.SetText("Right");
            dockFloatButton.SetText("Float");
            dockHideButton.SetText("Hide");
            dockHideButton.SetIconName("");
            dockLeftButton.SetVisible(true);
            dockBottomButton.SetVisible(true);
            dockRightButton.SetVisible(true);
            dockFloatButton.SetVisible(true);
            dockLeftButton.SetSize(48, 24);
            dockBottomButton.SetSize(58, 24);
            dockRightButton.SetSize(52, 24);
            dockFloatButton.SetSize(48, 24);
            dockHideButton.SetSize(46, 24);
        }
    }

