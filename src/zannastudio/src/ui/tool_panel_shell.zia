            problemsQuickFixButton.SetText("Fix");
            problemsQuickFixButton.SetPreferredSize(44.0, 0.0);
            problemsCountLabel.SetVisible(false);
        } else {
            problemsFilterInput.SetMinSize(120.0, 0.0);
            problemsFilterInput.SetPreferredSize(220.0, 0.0);
            problemsErrorCheck.SetText("Errors");
            problemsWarningCheck.SetText("Warnings");
            problemsInfoCheck.SetText("Info");
            problemsQuickFixButton.SetText("Quick Fix");
            problemsQuickFixButton.SetPreferredSize(76.0, 0.0);
            problemsCountLabel.SetVisible(true);
        }
        problemsResetButton.SetMinSize(40.0, 0.0);
        problemsQuickFixButton.SetMinSize(44.0, 0.0);
    }

