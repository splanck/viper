    /// @brief Return whether Terminal currently uses wrapping equal-width actions.
    expose func IsTerminalActionsCompact() -> Boolean {
        return compactTerminalActions;
    }

    /// @brief Keep every Terminal session action inside narrow side docks.
    /// @details Compact actions retain descriptive text and tooltips. Flex growth
    ///          produces two balanced rows at the minimum dock width, while a
    ///          roomy dock restores natural button widths on a single row.
    hide func ApplyResponsiveTerminalActions() {
        if terminalPanel == null or terminalActionRow == null
           or terminalKill == null {
            return;
        }
        var width = terminalPanel.GetLogicalWidth();
        if width <= 0.0 and panelRoot != null {
            width = panelRoot.GetLogicalWidth();
        }
        if width <= 0.0 { return; }

        var compact = TerminalUsesCompactActions(width);
        if compact == compactTerminalActions { return; }
        compactTerminalActions = compact;
        if compactTerminalActions {
            terminalKill.SetFlex(1.0);
            terminalRestart.SetFlex(1.0);
            terminalNew.SetFlex(1.0);
            terminalNext.SetFlex(1.0);
            terminalKill.SetMinSize(60.0, 0.0);
            terminalRestart.SetMinSize(76.0, 0.0);
            terminalNew.SetMinSize(60.0, 0.0);
            terminalNext.SetMinSize(60.0, 0.0);
            terminalKill.SetPreferredSize(60.0, 0.0);
            terminalRestart.SetPreferredSize(76.0, 0.0);
            terminalNew.SetPreferredSize(60.0, 0.0);
            terminalNext.SetPreferredSize(60.0, 0.0);
        } else {
            terminalKill.SetFlex(0.0);
            terminalRestart.SetFlex(0.0);
            terminalNew.SetFlex(0.0);
            terminalNext.SetFlex(0.0);
            terminalKill.SetPreferredSize(0.0, 0.0);
            terminalRestart.SetPreferredSize(0.0, 0.0);
            terminalNew.SetPreferredSize(0.0, 0.0);
            terminalNext.SetPreferredSize(0.0, 0.0);
            terminalKill.SetMinSize(60.0, 0.0);
            terminalRestart.SetMinSize(60.0, 0.0);
            terminalNew.SetMinSize(60.0, 0.0);
            terminalNext.SetMinSize(60.0, 0.0);
        }
    }

    /// @brief Return whether Variables uses compact watch controls.
    expose func IsWatchToolbarCompact() -> Boolean {
        return compactWatchToolbar;
    }

    /// @brief Keep watch entry and actions within narrow side docks.
    /// @details The Flex row wraps as one stable widget tree. Compact bases
    ///          preserve a useful Variables list below the controls without
    ///          replacing the user's in-progress expression or keyboard focus.
    hide func ApplyResponsiveWatchToolbar() {
        if variablesPanel == null or watchToolbar == null
           or watchExpressionInput == null {
            return;
        }
        var width = variablesPanel.GetLogicalWidth();
        if width <= 0.0 and panelRoot != null {
            width = panelRoot.GetLogicalWidth();
        }
        if width <= 0.0 { return; }

        var compact = WatchToolbarUsesCompactActions(width);
        if compact == compactWatchToolbar { return; }
        compactWatchToolbar = compact;
        if compactWatchToolbar {
            watchExpressionInput.SetMinSize(60.0, 0.0);
            watchExpressionInput.SetPreferredSize(72.0, 0.0);
            watchAddButton.SetPreferredSize(48.0, 0.0);
            watchRemoveButton.SetPreferredSize(64.0, 0.0);
            watchRefreshButton.SetPreferredSize(64.0, 0.0);
            watchClearButton.SetPreferredSize(52.0, 0.0);
        } else {
            watchExpressionInput.SetMinSize(120.0, 0.0);
            watchExpressionInput.SetPreferredSize(180.0, 0.0);
            watchAddButton.SetPreferredSize(0.0, 0.0);
            watchRemoveButton.SetPreferredSize(0.0, 0.0);
            watchRefreshButton.SetPreferredSize(0.0, 0.0);
            watchClearButton.SetPreferredSize(0.0, 0.0);
        }
        watchAddButton.SetMinSize(48.0, 0.0);
        watchRemoveButton.SetMinSize(64.0, 0.0);
        watchRefreshButton.SetMinSize(64.0, 0.0);
        watchClearButton.SetMinSize(52.0, 0.0);
    }

    /// @brief Inject the concrete widgets that make up the bottom tool area.
    /// @param appArg Owning application, used for output wrap width.
    /// @param tabsArg Bottom tool tab bar.
    /// @param problemsTab Problems tab handle.
    /// @param outputTab Output tab handle.
    /// @param searchTab Search tab handle.
    /// @param referencesTab References tab handle.
    /// @param variablesTab Variables tab handle.
    /// @param callStackTab Call Stack tab handle.
    /// @param debugTab Debug Console tab handle.
    /// @param terminalTab Terminal tab handle.
    /// @param diagList Problems ListBox.
    /// @param outPane Raw output pane.
    /// @param outList Row-mode output ListBox.
    /// @param outVirtual Virtual output row helper.
    /// @param searchBoxPanel Search panel container.
    /// @param searchList Search result ListBox.
    /// @param refsList References ListBox.
    /// @param dbgList Debug Console ListBox.
    /// @param varsList Variables ListBox.
    /// @param stackList Call Stack ListBox.
    /// @param termPanel Terminal panel container.
    /// @param termPane Terminal output pane.
    expose func Setup(appArg: GUI.App,
                      tabsArg: GUI.TabBar,
                      problemsTab: GUI.Tab,
                      outputTab: GUI.Tab,
                      searchTab: GUI.Tab,
                      referencesTab: GUI.Tab,
                      variablesTab: GUI.Tab,
                      callStackTab: GUI.Tab,
                      debugTab: GUI.Tab,
                      terminalTab: GUI.Tab,
                      diagList: GUI.ListBox,
                      outPane: GUI.OutputPane,
                      outList: GUI.ListBox,
                      outVirtual: GUI.VirtualList,
                      searchBoxPanel: GUI.VBox,
                      searchList: GUI.ListBox,
                      refsList: GUI.ListBox,
                      dbgList: GUI.ListBox,
                      varsList: GUI.ListBox,
                      stackList: GUI.ListBox,
                      termPanel: GUI.VBox,
                      termPane: GUI.OutputPane) {
        app = appArg;
        toolTabBar = tabsArg;
        toolProblemsTab = problemsTab;
        toolOutputTab = outputTab;
        toolSearchTab = searchTab;
        toolReferencesTab = referencesTab;
        toolVariablesTab = variablesTab;
        toolCallStackTab = callStackTab;
        toolDebugTab = debugTab;
        toolTerminalTab = terminalTab;
        diagListBox = diagList;
        outputPane = outPane;
        outputListBox = outList;
        outputVirtualList = outVirtual;
        searchPanel = searchBoxPanel;
        searchListBox = searchList;
        referencesListBox = refsList;
        debugListBox = dbgList;
        variablesListBox = varsList;
        callStackListBox = stackList;
        terminalPanel = termPanel;
        terminalPane = termPane;
        AssignToolTabIds();
    }

    /// @brief Assign application-stable identities to every movable tool tab.
    /// @details Visual indices are mutable after drag-reorder, so routing and
    ///          persistence use these copied IDs instead.
    hide func AssignToolTabIds() {
        if toolProblemsTab != null {
            toolProblemsTab.SetStableId(tool_panel_model.TAB_ID_PROBLEMS);
        }
        if toolOutputTab != null {
            toolOutputTab.SetStableId(tool_panel_model.TAB_ID_OUTPUT);
        }
        if toolSearchTab != null {
            toolSearchTab.SetStableId(tool_panel_model.TAB_ID_SEARCH);
        }
        if toolReferencesTab != null {
            toolReferencesTab.SetStableId(tool_panel_model.TAB_ID_REFERENCES);
        }
        if toolVariablesTab != null {
            toolVariablesTab.SetStableId(tool_panel_model.TAB_ID_VARIABLES);
        }
        if toolCallStackTab != null {
            toolCallStackTab.SetStableId(tool_panel_model.TAB_ID_CALL_STACK);
        }
        if toolDebugTab != null {
            toolDebugTab.SetStableId(tool_panel_model.TAB_ID_DEBUG);
        }
        if toolTerminalTab != null {
            toolTerminalTab.SetStableId(tool_panel_model.TAB_ID_TERMINAL);
        }
    }

    /// @brief Move one live tool surface into a different independent group.
    /// @details The content widget is reparented and its Tab presentation is
    ///          recreated because GUI.Tab values are owned by exactly one bar.
    ///          Controller/model state and focused text controls remain intact.
    expose func MoveToolPanelTo(kind: Integer, location: Integer) {
        TransferToolPanel(kind, location, true);
    }

    /// @brief Move the most recently selected tool to another dock group.
    /// @return True when a visible built-in tool changed groups.
    expose func MoveActiveToolPanelTo(location: Integer) -> Boolean {
        var id =
            tool_panel_model.TabIdForPanelKind(activeToolPanelKind);
        if id == tool_panel_model.TAB_ID_NONE
           or !workspace_dock.IsToolLocation(location)
           or toolPanelGroups.LocationForId(id) == location {
            return false;
        }
        TransferToolPanel(activeToolPanelKind, location, true);
        return toolPanelGroups.LocationForId(id) == location;
    }

    /// @brief Return the current group location for one panel kind.
    expose func GetToolPanelLocationName(kind: Integer) -> String {
        var id = tool_panel_model.TabIdForPanelKind(kind);
        return workspace_dock.ToolLocationName(
            toolPanelGroups.LocationForId(id));
    }

    /// @brief Return the complete canonical attached-plus-floating layout.
    expose func GetToolPanelGroupLayout() -> String {
        return toolPanelGroups.Encode();
    }

    /// @brief Consume one or more individual moves as one durable layout edge.
    expose func TakeChangedToolPanelGroupLayout() -> String {
        if !toolPanelGroupLayoutDirty { return ""; }
        toolPanelGroupLayoutDirty = false;
        return GetToolPanelGroupLayout();
    }

    /// @brief Apply grouped persistence, falling back atomically to legacy state.
    /// @param encoded Canonical attached/floating membership, or empty to migrate.
    /// @param legacyDockName Legacy location for the primary tool group.
    /// @param legacyOrder Legacy complete stable-ID order.
    expose func SetToolPanelGroupLayout(encoded: String,
                                        legacyDockName: String,
                                        legacyOrder: String) {
        if toolTabBar == null or leftToolTabBar == null { return; }
        var candidate = new tool_panel_groups.ToolPanelGroups();
        candidate.Apply(encoded, legacyDockName, legacyOrder);

        var restorePanelId = GetActiveToolPanelId();
        var restoreFocusId = FocusedToolControlId();
        HideAllToolPanels();
        RetireAllToolTabs();

        CollapseAllDockSplits();
        dockLocation = workspace_dock.DockLocationFromName(legacyDockName);
        var primaryHost = bottomDockHost;
        if dockLocation == workspace_dock.DOCK_LEFT {
            primaryHost = leftDockHost;
        } else if dockLocation == workspace_dock.DOCK_RIGHT {
            primaryHost = rightDockHost;
        }
        primaryHost.AddChild(panelRoot);

        toolPanelGroups = candidate;
        RebuildAllToolTabs();
        toolTabBar.SetVisible(false);
        leftToolTabBar.SetVisible(false);
        bottomToolTabBar.SetVisible(false);
        rightToolTabBar.SetVisible(false);
        floatingToolTabBar.SetVisible(false);
        panelRoot.SetVisible(false);
        leftToolGroupRoot.SetVisible(false);
        bottomToolGroupRoot.SetVisible(false);
        rightToolGroupRoot.SetVisible(false);
        floatingToolGroupRoot.SetVisible(false);
        floatingToolPanel.SetVisible(false);
        activeLeftToolPanelKind = tool_panel_model.PANEL_NONE;
        activeBottomToolPanelKind = tool_panel_model.PANEL_NONE;
        activeRightToolPanelKind = tool_panel_model.PANEL_NONE;
        activeFloatingToolPanelKind = tool_panel_model.PANEL_NONE;
        SetActiveToolPanelKind(tool_panel_model.PANEL_NONE);

        RestoreIndependentGroup(workspace_dock.DOCK_LEFT);
        RestoreIndependentGroup(workspace_dock.DOCK_BOTTOM);
        RestoreIndependentGroup(workspace_dock.DOCK_RIGHT);
        RestoreIndependentGroup(workspace_dock.DOCK_FLOATING);
        if restorePanelId != tool_panel_model.TAB_ID_NONE {
            ShowToolPanelKind(
                tool_panel_model.PanelKindForTabId(restorePanelId));
        }
        RestoreToolControlFocus(restoreFocusId);
        UpdateDockButtons();
        toolTabOrderDirty = false;
        dockLocationDirty = false;
        toolPanelGroupLayoutDirty = false;
    }

    /// @brief Recreate every tab in canonical order around unchanged panels.
    hide func RebuildAllToolTabs() {
        var parts = Str.Split(toolPanelGroups.order, ",");
        var i = 0;
        while i < Seq.get_Count(parts) {
            var id = Str.Trim(Obj.ToString(Seq.Get(parts, i)));
            var kind = tool_panel_model.PanelKindForTabId(id);
            var location = toolPanelGroups.LocationForId(id);
            var root = ToolGroupRootAt(location);
            var bar = ToolTabBarAt(location);
            var panel = ToolPanelWidget(kind);
            if root != null and bar != null and panel != null {
                root.AddChild(panel);
                panel.SetVisible(false);
                SetToolTabForKind(kind, CreateToolTab(bar, kind));
            }
            i = i + 1;
        }
        KeepFloatingResizeRowLast();
    }

    /// @brief Retire every current presentation from its owning TabBar.
    hide func RetireAllToolTabs() {
        RetireToolTab(toolProblemsTab, tool_panel_model.PANEL_PROBLEMS);
        RetireToolTab(toolOutputTab, tool_panel_model.PANEL_OUTPUT);
        RetireToolTab(toolSearchTab, tool_panel_model.PANEL_SEARCH);
        RetireToolTab(toolReferencesTab, tool_panel_model.PANEL_REFERENCES);
        RetireToolTab(toolVariablesTab, tool_panel_model.PANEL_VARIABLES);
        RetireToolTab(toolCallStackTab, tool_panel_model.PANEL_CALL_STACK);
        RetireToolTab(toolDebugTab, tool_panel_model.PANEL_DEBUG);
        RetireToolTab(toolTerminalTab, tool_panel_model.PANEL_TERMINAL);
        toolTabBar.PruneRetiredTabs();
        leftToolTabBar.PruneRetiredTabs();
        bottomToolTabBar.PruneRetiredTabs();
        rightToolTabBar.PruneRetiredTabs();
        floatingToolTabBar.PruneRetiredTabs();
    }

    hide func RetireToolTab(tab: GUI.Tab, kind: Integer) {
        if tab == null { return; }
        var id = tool_panel_model.TabIdForPanelKind(kind);
        var bar = ToolTabBarAt(toolPanelGroups.LocationForId(id));
        if bar != null { bar.RemoveTab(tab); }
    }

    /// @brief Transfer one presentation/content pair and optionally publish it.
    hide func TransferToolPanel(kind: Integer,
                                location: Integer,
                                userAuthored: Boolean) {
        var id = tool_panel_model.TabIdForPanelKind(kind);
        if id == tool_panel_model.TAB_ID_NONE
           or !workspace_dock.IsToolLocation(location) {
            return;
        }
        var source = toolPanelGroups.LocationForId(id);
        if source == location { return; }

        var sourceBar = ToolTabBarAt(source);
        var destinationBar = ToolTabBarAt(location);
        var destinationRoot = ToolGroupRootAt(location);
        var panel = ToolPanelWidget(kind);
        var oldTab = ToolTabForKind(kind);
        if sourceBar == null or destinationBar == null
           or destinationRoot == null or panel == null or oldTab == null {
            return;
        }

        var wasVisible = panel.IsVisible();
        var wasSourceActive = ActiveToolPanelKindAt(source) == kind;
        var restoreFocusId = FocusedToolControlId();
        sourceBar.RemoveTab(oldTab);
        sourceBar.PruneRetiredTabs();
        destinationRoot.AddChild(panel);
        KeepFloatingResizeRowLast();
        toolPanelGroups.MoveId(id, location);
        SetToolTabForKind(kind, CreateToolTab(destinationBar, kind));

        if wasSourceActive {
            if toolPanelGroups.HasIdsAt(source) {
                var fallbackId = toolPanelGroups.FirstIdAt(source);
                ShowToolPanelKind(
                    tool_panel_model.PanelKindForTabId(fallbackId));
            } else {
                CollapseEmptyIndependentGroup(source);
            }
        } else {
            CollapseEmptyIndependentGroup(source);
        }

        if wasVisible or userAuthored {
            ShowToolPanelKind(kind);
        } else {
            panel.SetVisible(false);
        }
        RestoreToolControlFocus(restoreFocusId);
        if userAuthored {
            toolPanelGroupLayoutDirty = true;
            toolTabOrderDirty = true;
        }
    }

    /// @brief Restore the first tab of one non-empty persisted group.
    hide func RestoreIndependentGroup(location: Integer) {
        if !toolPanelGroups.HasIdsAt(location) {
            return;
        }
        var id = toolPanelGroups.FirstIdAt(location);
        ShowToolPanelKind(tool_panel_model.PanelKindForTabId(id));
    }

    /// @brief Collapse a now-empty auxiliary group without touching other docks.
    hide func CollapseEmptyIndependentGroup(location: Integer) {
        var bar = ToolTabBarAt(location);
        var root = ToolGroupRootAt(location);
        if bar == null or root == null or bar.TabCount > 0 { return; }
        HideToolGroupAt(location);
    }

    /// @brief Return the selected panel for one physical dock.
    hide func ActiveToolPanelKindAt(location: Integer) -> Integer {
        if location == workspace_dock.DOCK_LEFT {
            return activeLeftToolPanelKind;
        }
        if location == workspace_dock.DOCK_RIGHT {
            return activeRightToolPanelKind;
        }
        if location == workspace_dock.DOCK_BOTTOM {
            return activeBottomToolPanelKind;
        }
        if location == workspace_dock.DOCK_FLOATING {
            return activeFloatingToolPanelKind;
        }
        return tool_panel_model.PANEL_NONE;
    }

    /// @brief Update one dock's selection without disturbing sibling groups.
    hide func SetActiveToolPanelKindAt(location: Integer, kind: Integer) {
        if location == workspace_dock.DOCK_LEFT {
            activeLeftToolPanelKind = kind;
        } else if location == workspace_dock.DOCK_RIGHT {
            activeRightToolPanelKind = kind;
        } else if location == workspace_dock.DOCK_BOTTOM {
            activeBottomToolPanelKind = kind;
        } else if location == workspace_dock.DOCK_FLOATING {
            activeFloatingToolPanelKind = kind;
        }
    }

    /// @brief Return a remaining visible selection after one group closes.
    hide func AnyActiveToolPanelKind() -> Integer {
        if activeBottomToolPanelKind != tool_panel_model.PANEL_NONE {
            return activeBottomToolPanelKind;
        }
        if activeLeftToolPanelKind != tool_panel_model.PANEL_NONE {
            return activeLeftToolPanelKind;
        }
        if activeRightToolPanelKind != tool_panel_model.PANEL_NONE {
            return activeRightToolPanelKind;
        }
        return activeFloatingToolPanelKind;
    }

    /// @brief Return whether one panel is selected in its own physical group.
    hide func IsToolPanelSelected(kind: Integer) -> Boolean {
        var id = tool_panel_model.TabIdForPanelKind(kind);
        var location = toolPanelGroups.LocationForId(id);
        return ActiveToolPanelKindAt(location) == kind;
    }

    hide func ToolTabBarAt(location: Integer) -> GUI.TabBar {
        if location == dockLocation { return toolTabBar; }
        if location == workspace_dock.DOCK_FLOATING {
            return floatingToolTabBar;
        }
        if location == workspace_dock.DOCK_LEFT { return leftToolTabBar; }
        if location == workspace_dock.DOCK_RIGHT { return rightToolTabBar; }
        return bottomToolTabBar;
    }

    hide func ToolGroupRootAt(location: Integer) -> GUI.VBox {
        if location == dockLocation { return panelRoot; }
        if location == workspace_dock.DOCK_FLOATING {
            return floatingToolGroupRoot;
        }
        if location == workspace_dock.DOCK_LEFT { return leftToolGroupRoot; }
        if location == workspace_dock.DOCK_RIGHT { return rightToolGroupRoot; }
        return bottomToolGroupRoot;
    }

    /// @brief Keep the resize affordance after any reparented tool surfaces.
    hide func KeepFloatingResizeRowLast() {
        if floatingToolGroupRoot != null and floatingToolResizeRow != null {
            floatingToolGroupRoot.AddChild(floatingToolResizeRow);
        }
    }

    hide func ToolPanelWidget(kind: Integer) -> GUI.VBox {
        if kind == tool_panel_model.PANEL_PROBLEMS { return problemsPanel; }
        if kind == tool_panel_model.PANEL_OUTPUT { return outputPanel; }
        if kind == tool_panel_model.PANEL_SEARCH { return searchPanel; }
        if kind == tool_panel_model.PANEL_REFERENCES { return referencesPanel; }
        if kind == tool_panel_model.PANEL_VARIABLES { return variablesPanel; }
        if kind == tool_panel_model.PANEL_CALL_STACK { return callStackPanel; }
        if kind == tool_panel_model.PANEL_DEBUG { return debugPanel; }
        if kind == tool_panel_model.PANEL_TERMINAL { return terminalPanel; }
        return null;
    }

    hide func ToolTabForKind(kind: Integer) -> GUI.Tab {
        if kind == tool_panel_model.PANEL_PROBLEMS { return toolProblemsTab; }
        if kind == tool_panel_model.PANEL_OUTPUT { return toolOutputTab; }
        if kind == tool_panel_model.PANEL_SEARCH { return toolSearchTab; }
        if kind == tool_panel_model.PANEL_REFERENCES {
            return toolReferencesTab;
        }
        if kind == tool_panel_model.PANEL_VARIABLES {
            return toolVariablesTab;
        }
        if kind == tool_panel_model.PANEL_CALL_STACK {
            return toolCallStackTab;
        }
        if kind == tool_panel_model.PANEL_DEBUG { return toolDebugTab; }
        if kind == tool_panel_model.PANEL_TERMINAL { return toolTerminalTab; }
        return null;
    }

    hide func SetToolTabForKind(kind: Integer, tab: GUI.Tab) {
        if kind == tool_panel_model.PANEL_PROBLEMS {
            toolProblemsTab = tab;
        } else if kind == tool_panel_model.PANEL_OUTPUT {
            toolOutputTab = tab;
        } else if kind == tool_panel_model.PANEL_SEARCH {
            toolSearchTab = tab;
        } else if kind == tool_panel_model.PANEL_REFERENCES {
            toolReferencesTab = tab;
        } else if kind == tool_panel_model.PANEL_VARIABLES {
            toolVariablesTab = tab;
        } else if kind == tool_panel_model.PANEL_CALL_STACK {
            toolCallStackTab = tab;
        } else if kind == tool_panel_model.PANEL_DEBUG {
            toolDebugTab = tab;
        } else if kind == tool_panel_model.PANEL_TERMINAL {
            toolTerminalTab = tab;
        }
    }

    hide func CreateToolTab(bar: GUI.TabBar, kind: Integer) -> GUI.Tab {
        var tab: GUI.Tab =
            bar.AddTab(tool_panel_model.PanelName(kind), 0);
        var id = tool_panel_model.TabIdForPanelKind(kind);
        tab.SetStableId(id);
        tab.SetTooltip(tool_panel_model.PanelName(kind));
        return tab;
    }

    hide func ShowToolPanelKind(kind: Integer) {
        if kind == tool_panel_model.PANEL_PROBLEMS { ShowProblemsPanel(); }
        else if kind == tool_panel_model.PANEL_OUTPUT { ShowOutputPanel(); }
        else if kind == tool_panel_model.PANEL_SEARCH { ShowSearchPanel(); }
        else if kind == tool_panel_model.PANEL_REFERENCES {
            ShowReferencesPanel();
        } else if kind == tool_panel_model.PANEL_VARIABLES {
            ShowVariablesPanel();
        } else if kind == tool_panel_model.PANEL_CALL_STACK {
            ShowCallStackPanel();
        } else if kind == tool_panel_model.PANEL_DEBUG { ShowDebugPanel(); }
        else if kind == tool_panel_model.PANEL_TERMINAL {
            ShowTerminalPanel();
        }
    }

    /// @brief Record the exact focused control across a panel reparent.
    hide func FocusedToolControlId() -> String {
        if terminalPane != null and terminalPane.IsFocused() {
            return "terminal";
        }
        if searchQueryInput != null and searchQueryInput.IsFocused() {
            return "search-query";
        }
        if searchReplaceInput != null and searchReplaceInput.IsFocused() {
            return "search-replace";
        }
        if searchKindsInput != null and searchKindsInput.IsFocused() {
            return "search-kinds";
        }
        if searchIncludeInput != null and searchIncludeInput.IsFocused() {
            return "search-include";
        }
        if searchExcludeInput != null and searchExcludeInput.IsFocused() {
            return "search-exclude";
        }
        if problemsFilterInput != null and problemsFilterInput.IsFocused() {
            return "problems-filter";
        }
        if outputFilterInput != null and outputFilterInput.IsFocused() {
            return "output-filter";
        }
        if referencesFilterInput != null
           and referencesFilterInput.IsFocused() {
            return "references-filter";
        }
        if debugFilterInput != null and debugFilterInput.IsFocused() {
            return "debug-filter";
        }
        if callStackFilterInput != null and callStackFilterInput.IsFocused() {
            return "stack-filter";
        }
        if watchExpressionInput != null and watchExpressionInput.IsFocused() {
            return "watch";
        }
        return "";
    }

    hide func RestoreToolControlFocus(id: String) {
        if id == "terminal" { terminalPane.Focus(); }
        else if id == "search-query" { searchQueryInput.Focus(); }
        else if id == "search-replace" { searchReplaceInput.Focus(); }
        else if id == "search-kinds" { searchKindsInput.Focus(); }
        else if id == "search-include" { searchIncludeInput.Focus(); }
        else if id == "search-exclude" { searchExcludeInput.Focus(); }
        else if id == "problems-filter" { problemsFilterInput.Focus(); }
        else if id == "output-filter" { outputFilterInput.Focus(); }
        else if id == "references-filter" {
            referencesFilterInput.Focus();
        } else if id == "debug-filter" { debugFilterInput.Focus(); }
        else if id == "stack-filter" { callStackFilterInput.Focus(); }
        else if id == "watch" { watchExpressionInput.Focus(); }
    }

    /// @brief Apply a complete persisted tool-tab order.
    /// @details Malformed, duplicate, or future-only orders fall back atomically
    ///          to the built-in order. Programmatic moves consume their reorder
    ///          edge so they never look like fresh user input.
    expose func SetToolTabOrder(encoded: String) {
        if toolTabBar == null { return; }
        var order = encoded;
        if IsValidToolTabOrder(order) == false {
            order = tool_panel_model.DEFAULT_TAB_ORDER;
        }
        toolPanelGroups.SetCompleteOrder(order);
        ApplyToolTabOrderAt(workspace_dock.DOCK_LEFT);
        ApplyToolTabOrderAt(workspace_dock.DOCK_BOTTOM);
        ApplyToolTabOrderAt(workspace_dock.DOCK_RIGHT);
        ApplyToolTabOrderAt(workspace_dock.DOCK_FLOATING);
        toolTabBar.WasReordered();
        if leftToolTabBar != null { leftToolTabBar.WasReordered(); }
        if bottomToolTabBar != null { bottomToolTabBar.WasReordered(); }
        if rightToolTabBar != null { rightToolTabBar.WasReordered(); }
        if floatingToolTabBar != null { floatingToolTabBar.WasReordered(); }
        toolTabOrderDirty = false;
    }

    /// @brief Restore the built-in tool-tab order without publishing a drag.
    expose func ResetToolTabOrder() {
        SetToolTabOrder(tool_panel_model.DEFAULT_TAB_ORDER);
    }

    /// @brief Return the current order as comma-separated stable tab IDs.
    expose func GetToolTabOrder() -> String {
        if toolTabBar == null { return ""; }
        return toolPanelGroups.order;
    }

    /// @brief Consume one user-authored tool-tab reorder.
    /// @return Current serialized order, or empty when unchanged.
    expose func TakeChangedToolTabOrder() -> String {
        if toolTabOrderDirty == false { return ""; }
        toolTabOrderDirty = false;
        return GetToolTabOrder();
    }

    /// @brief Validate that an encoded order names every known tab exactly once.
    hide func IsValidToolTabOrder(encoded: String) -> Boolean {
        var parts = Str.Split(encoded, ",");
        if Seq.get_Count(parts) != 8 { return false; }
        var i = 0;
        while i < Seq.get_Count(parts) {
            var id = Str.Trim(Obj.ToString(Seq.Get(parts, i)));
            if IsKnownToolTabId(id) == false { return false; }
            var j = 0;
            while j < i {
                if Str.Trim(Obj.ToString(Seq.Get(parts, j))) == id {
                    return false;
                }
                j = j + 1;
            }
            i = i + 1;
        }
        return true;
    }

    /// @brief Return whether an ID belongs to one built-in tool panel.
    hide func IsKnownToolTabId(id: String) -> Boolean {
        return id == tool_panel_model.TAB_ID_PROBLEMS
            or id == tool_panel_model.TAB_ID_OUTPUT
            or id == tool_panel_model.TAB_ID_SEARCH
            or id == tool_panel_model.TAB_ID_REFERENCES
            or id == tool_panel_model.TAB_ID_VARIABLES
            or id == tool_panel_model.TAB_ID_CALL_STACK
            or id == tool_panel_model.TAB_ID_DEBUG
            or id == tool_panel_model.TAB_ID_TERMINAL;
    }

    /// @brief Find a tab by stable ID in the mutable visual order.
    hide func FindToolTabIndex(id: String) -> Integer {
        return FindToolTabIndexInBar(toolTabBar, id);
    }

    /// @brief Find one stable ID inside a particular dock group's tab bar.
    hide func FindToolTabIndexInBar(bar: GUI.TabBar,
                                    id: String) -> Integer {
        if bar == null { return -1; }
        var i = 0;
        while i < bar.TabCount {
            var tab: GUI.Tab = bar.GetTabAt(i);
            if tab != null and tab.GetStableId() == id { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Apply durable ordering to the subset assigned to one group.
    hide func ApplyToolTabOrderAt(location: Integer) {
        var bar = ToolTabBarAt(location);
        if bar == null { return; }
        var parts = Str.Split(toolPanelGroups.IdsAt(location), ",");
        var target = 0;
        var i = 0;
        while i < Seq.get_Count(parts) {
            var wanted = Str.Trim(Obj.ToString(Seq.Get(parts, i)));
            if wanted != "" {
                var from = FindToolTabIndexInBar(bar, wanted);
                if from >= 0 and from != target {
                    bar.MoveTab(from, target);
                }
                target = target + 1;
            }
            i = i + 1;
        }
    }

    /// @brief Serialize one group's current visual order.
    hide func ToolTabOrderAt(location: Integer) -> String {
        var bar = ToolTabBarAt(location);
        if bar == null { return ""; }
        var result = "";
        var i = 0;
        while i < bar.TabCount {
            var tab: GUI.Tab = bar.GetTabAt(i);
            if tab != null {
                if result != "" { result = result + ","; }
                result = result + tab.GetStableId();
            }
            i = i + 1;
        }
        return result;
    }

    /// @brief Synchronize the durable order after a drag in any group.
    hide func CaptureToolTabOrder() {
        var result = ToolTabOrderAt(workspace_dock.DOCK_LEFT);
        var bottom = ToolTabOrderAt(workspace_dock.DOCK_BOTTOM);
        var right = ToolTabOrderAt(workspace_dock.DOCK_RIGHT);
        var floating = ToolTabOrderAt(workspace_dock.DOCK_FLOATING);
        if bottom != "" {
            if result != "" { result = result + ","; }
            result = result + bottom;
        }
        if right != "" {
            if result != "" { result = result + ","; }
            result = result + right;
        }
        if floating != "" {
            if result != "" { result = result + ","; }
            result = result + floating;
        }
        if toolPanelGroups.SetCompleteOrder(result) {
            toolTabOrderDirty = true;
            toolPanelGroupLayoutDirty = true;
        }
    }

    /// @brief Populate the build-output panel with complete stdout/stderr text.
    /// @param output Complete captured output, or empty to clear the panel.
    expose func SetBuildOutput(output: String) {
        if output == lastBuildOutput {
            return;
        }
        if output == "" {
            ClearOutputPanel();
            return;
        }

        if lastBuildOutput != "" and Str.EndsWith(lastBuildOutput, "\n")
           and Str.StartsWith(output, lastBuildOutput) {
            var delta = Str.Mid(output, Str.get_Length(lastBuildOutput) + 1);
            if output_cache.ShouldUseRawPane(outputFilterText, outputWrapLines) {
                AppendBuildOutput(delta);
            } else {
                lastBuildOutput = output_cache.Bound("", output);
                RenderOutputRows(lastBuildOutput);
                ShowOutputPanel();
            }
            return;
        }

        lastBuildOutput = output_cache.Bound("", output);
        if output_cache.ShouldUseRawPane(outputFilterText, outputWrapLines) {
            RenderOutputPane(lastBuildOutput);
        } else {
            RenderOutputRows(lastBuildOutput);
        }
        ShowOutputPanel();
    }

    /// @brief Append incremental process output to the active output surface.
    /// @param output Newly captured stdout/stderr text.
    expose func AppendBuildOutput(output: String) {
        UpdateBuildOutput(output);
        if output != "" { ShowOutputPanel(); }
    }

    /// @brief Append process output without changing the selected tool panel.
    /// @details Build jobs stream through this path after their initial reveal,
    ///          allowing the user to move to Terminal or another tool mid-job.
    expose func UpdateBuildOutput(output: String) {
        if output == "" { return; }
        var previousLen = Str.get_Length(lastBuildOutput);
        lastBuildOutput = output_cache.Bound(lastBuildOutput, output);
        var trimmed = output_cache.AppendWouldTrim(previousLen, output);
        if output_cache.ShouldUseRawPane(outputFilterText, outputWrapLines) {
            UseOutputPane();
            if trimmed {
                RenderOutputPane(lastBuildOutput);
            } else {
                outputPane.Append(output);
            }
            return;
        }

        if outputPartialItem != null {
            outputListBox.RemoveItem(outputPartialItem);
            outputPartialItem = null;
        }

        var combined = outputPartialLine + output;
        outputPartialLine = "";

        var lines = Str.Split(combined, "\n");
        var n = Seq.get_Count(lines);
        var endsWithNewline = Str.EndsWith(combined, "\n");
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            var isLast = i == n - 1;
            if isLast and endsWithNewline == false {
                outputPartialLine = line;
                if line != "" {
                    outputPartialItem = AddOutputDisplayLine(line);
                }
            } else if line != "" {
                AddOutputDisplayLine(line);
            }
            i = i + 1;
        }

        if trimmed {
            RenderOutputRows(lastBuildOutput);
        }
    }

    /// @brief Switch output rendering to the raw output pane and repaint it.
    /// @param output Complete output text to display.
    hide func RenderOutputPane(output: String) {
        UseOutputPane();
        outputPane.Clear();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
        outputPane.Append(output);
    }

    /// @brief Switch output rendering to ListBox rows and repaint all rows.
    /// @param output Complete output text to split into display rows.
    hide func RenderOutputRows(output: String) {
        UseOutputRows();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
        AddBuildOutputLines(output);
    }

    /// @brief Use the raw append-only output pane for the Output tab.
    hide func UseOutputPane() {
        outputPaneMode = true;
        outputListBox.SetVisible(false);
        if IsToolPanelSelected(tool_panel_model.PANEL_OUTPUT) {
            outputPane.SetVisible(true);
        }
    }

    /// @brief Use the row-mode output ListBox for the Output tab.
    expose func UseOutputRows() {
        outputPaneMode = false;
        outputPane.SetVisible(false);
        if IsToolPanelSelected(tool_panel_model.PANEL_OUTPUT) {
            outputListBox.SetVisible(true);
        }
    }

    /// @brief Clear output rows and prepare for row-by-row population.
    expose func BeginOutputRows() {
        UseOutputRows();
        outputListBox.Clear();
        ResetOutputRows();
        outputPartialLine = "";
        outputPartialItem = null;
        UpdateOutputToolbarState();
    }

    /// @brief Begin a generated report that replaces the captured-output cache.
    /// @details Views such as Keyboard Shortcuts and Recent Files are complete
    ///          Output-panel documents of their own. Their Copy action must not
    ///          silently return an older build log.
    expose func BeginGeneratedOutputRows() {
        BeginOutputRows();
        lastBuildOutput = "";
        UpdateOutputToolbarState();
    }

    /// @brief Retain the complete source behind a caller-rendered row snapshot.
    /// @details Build diagnostics render structured rows so they can carry
    ///          navigation metadata, while Copy and later filtering still need
    ///          the original unfiltered text.
    expose func SetOutputRowSource(output: String) {
        lastBuildOutput = output_cache.Bound("", output);
        UpdateOutputToolbarState();
    }

    /// @brief Return whether Output has visible or cached content.
    /// @return True when raw text, row output, or cached output exists.
    expose func HasOutputContent() -> Boolean {
        if lastBuildOutput != "" { return true; }
        if outputPaneMode and outputPane.LineCount > 0 { return true; }
        if outputListBox.Count > 0 { return true; }
        return false;
    }

    /// @brief Clear a ListBox-backed tool panel and its row model.
    /// @param listBox Tool-panel ListBox to clear.
    expose func ClearToolRows(listBox: GUI.ListBox) {
        if listBox == null { return; }
        if listBox == referencesListBox {
            referencesListBox.Clear();
            referencesRows.Clear();
            referencesResultCount = 0;
            visibleReferenceCount = 0;
            currentReferenceGroupId = "";
            UpdateReferencesToolbarState();
            ApplyReferenceSurfaceVisibility();
            return;
        }
        listBox.Clear();
        var model = ToolRowsForListBox(listBox);
        if model != null {
            model.Clear();
        }
    }

    /// @brief Add a plain row through the bounded row model.
    /// @param listBox Destination ListBox.
    /// @param text Row text.
    /// @param color Optional text color, or zero for default.
    /// @return Concrete ListBox item handle, or null.
    expose func AddToolPlainRow(listBox: GUI.ListBox,
                                text: String,
                                color: Integer) -> Any {
        if listBox == null { return null; }
        if listBox == referencesListBox {
            return AddReferenceModelRow(text, text, color, false);
        }
        var model = ToolRowsForListBox(listBox);
        if model != null {
            EnsureToolRowsCapacity(listBox, model);
            var row = model.Add(text, color);
            var item = listBox.AddItem(text);
            row.item = item;
            if color != 0 {
                GUI.ListBox.ItemSetTextColor(item, color);
            }
            return item;
        }
        var fallback = listBox.AddItem(text);
        if color != 0 {
            GUI.ListBox.ItemSetTextColor(fallback, color);
        }
        return fallback;
    }

    /// @brief Add a muted section/header row to a tool panel.
    /// @param listBox Destination ListBox.
    /// @param text Header text.
    /// @return Concrete ListBox item handle, or null.
    expose func AddToolSectionRow(listBox: GUI.ListBox,
                                  text: String) -> Any {
        return AddToolPlainRow(listBox, text, ToolColorMuted());
    }

    /// @brief Add one durable References row and realize it when it is visible.
    /// @details Group headers are deferred while filtering until a matching
    ///          child arrives. This prevents empty headings during incremental
    ///          workspace-result publication without forcing an O(n²) repaint.
    hide func AddReferenceModelRow(text: String,
                                   searchText: String,
                                   color: Integer,
                                   isGroupHeader: Boolean) -> Any {
        if referencesListBox == null or referencesRows == null { return null; }
        var wasAtCapacity = referencesRows.maxRows > 0
            and referencesRows.Count() >= referencesRows.maxRows;
        EnsureToolRowsCapacity(referencesListBox, referencesRows);
        if wasAtCapacity {
            RecountReferenceResults();
        }

        var row = referencesRows.Add(text, color);
        row.searchText = searchText;
        row.isGroupHeader = isGroupHeader;
        if isGroupHeader {
            row.groupId = row.id;
            currentReferenceGroupId = row.id;
        } else {
            row.groupId = currentReferenceGroupId;
            referencesResultCount = referencesResultCount + 1;
        }

        var item: Any = null;
        if isGroupHeader {
            if referencesFilterText == "" {
                item = RenderReferenceModelRow(row);
            }
        } else {
            var group = FindReferenceRow(row.groupId);
            var visible = ReferenceRowMatches(row);
            if group != null and ReferenceRowMatches(group) {
                visible = true;
            }
            if visible {
                if group != null and group.item == null {
                    RenderReferenceModelRow(group);
                }
                item = RenderReferenceModelRow(row);
                visibleReferenceCount = visibleReferenceCount + 1;
            }
        }
        UpdateReferencesToolbarState();
        ApplyReferenceSurfaceVisibility();
        return item;
    }

    /// @brief Realize one durable References row with its navigation metadata.
    hide func RenderReferenceModelRow(
        row: tool_panel_model.ToolPanelRow) -> Any {
        if row == null or referencesListBox == null { return null; }
        var item = referencesListBox.AddItem(row.text);
        row.item = item;
        if row.color != 0 {
            GUI.ListBox.ItemSetTextColor(item, row.color);
        }
        if row.data != "" {
            GUI.ListBox.ItemSetData(item, row.data);
        }
        return item;
    }

    /// @brief Find one References row by its stable model identity.
    hide func FindReferenceRow(id: String)
        -> tool_panel_model.ToolPanelRow {
        if id == "" or referencesRows == null { return null; }
        var i = 0;
        while i < referencesRows.rows.count() {
            var row = referencesRows.rows.get(i);
            if row != null and row.id == id { return row; }
            i = i + 1;
        }
        return null;
    }

    /// @brief Return whether one durable row passes the current text filter.
    hide func ReferenceRowMatches(
        row: tool_panel_model.ToolPanelRow) -> Boolean {
        if row == null { return false; }
        if referencesFilterText == "" { return true; }
        return Str.Contains(Str.ToLower(row.searchText), referencesFilterText);
    }

    /// @brief Recount non-header results after bounded model eviction.
    hide func RecountReferenceResults() {
        referencesResultCount = 0;
        var i = 0;
        while referencesRows != null and i < referencesRows.rows.count() {
            var row = referencesRows.rows.get(i);
            if row != null and row.isGroupHeader == false {
                referencesResultCount = referencesResultCount + 1;
            }
            i = i + 1;
        }
    }

    /// @brief Rebuild References rows without discarding durable identities.
    /// @details A matching group heading includes all of its children. A
    ///          matching child includes its heading, and empty groups are
    ///          omitted. Navigation IDs are reapplied to every realized row.
    hide func RefreshReferenceRows() {
        if referencesListBox == null or referencesRows == null { return; }
        referencesListBox.Clear();
        visibleReferenceCount = 0;

        var resetIndex = 0;
        while resetIndex < referencesRows.rows.count() {
            var resetRow = referencesRows.rows.get(resetIndex);
            if resetRow != null { resetRow.item = null; }
            resetIndex = resetIndex + 1;
        }

        var i = 0;
        while i < referencesRows.rows.count() {
            var row = referencesRows.rows.get(i);
            if row == null {
                i = i + 1;
            } else if row.isGroupHeader {
                var groupMatches = ReferenceRowMatches(row);
                var renderedHeader = false;
                var j = i + 1;
                while j < referencesRows.rows.count() {
                    var child = referencesRows.rows.get(j);
                    if child == null {
                        j = j + 1;
                    } else if child.isGroupHeader
                              or child.groupId != row.id {
                        break;
                    } else {
                        if groupMatches or ReferenceRowMatches(child) {
                            if renderedHeader == false {
                                RenderReferenceModelRow(row);
                                renderedHeader = true;
                            }
                            RenderReferenceModelRow(child);
                            visibleReferenceCount =
                                visibleReferenceCount + 1;
                        }
                        j = j + 1;
                    }
                }
                i = j;
            } else {
                // A bounded eviction can orphan an old child from its header.
                // Keep that valid result independently filterable.
                if ReferenceRowMatches(row) {
                    RenderReferenceModelRow(row);
                    visibleReferenceCount = visibleReferenceCount + 1;
                }
                i = i + 1;
            }
        }
        RecountReferenceResults();
        UpdateReferencesToolbarState();
        ApplyReferenceSurfaceVisibility();
    }

    /// @brief Attach metadata to the most recently added structured row.
    /// @details References callers invoke this immediately after adding a
    ///          result. Durable data survives filtered-out and rebuilt items.
    expose func SetAddedToolRowLocationData(listBox: GUI.ListBox,
                                            item: Any,
                                            locationData: String) {
        if listBox == referencesListBox and referencesRows.Count() > 0 {
            var row = referencesRows.rows.get(referencesRows.Count() - 1);
            row.data = locationData;
            if row.item != null {
                GUI.ListBox.ItemSetData(row.item, locationData);
            }
            return;
        }
        if item != null {
            GUI.ListBox.ItemSetData(item, locationData);
        }
    }

    /// @brief Return the row model associated with a concrete ListBox.
    /// @param listBox Tool-panel ListBox.
    /// @return Matching row model, or null for non-tool lists.
    hide func ToolRowsForListBox(listBox: GUI.ListBox) -> tool_panel_model.ToolPanelRows {
        if listBox == diagListBox { return problemsRows; }
        if listBox == searchListBox { return searchRows; }
        if listBox == referencesListBox { return referencesRows; }
        if listBox == debugListBox { return debugRows; }
        if listBox == variablesListBox { return variablesRows; }
        if listBox == callStackListBox { return callStackRows; }
        return null;
    }

    /// @brief Trim oldest realized rows before adding another row.
    /// @param listBox Concrete ListBox that owns visible row items.
    /// @param model Bounded row model aligned with the ListBox.
    hide func EnsureToolRowsCapacity(listBox: GUI.ListBox,
                                     model: tool_panel_model.ToolPanelRows) {
        if listBox == null or model == null { return; }
        var removeCount = tool_panel_model.DEFAULT_TRIM_BATCH_ROWS;
        if removeCount < 1 { removeCount = 1; }
        while model.maxRows > 0 and model.Count() >= model.maxRows
              and removeCount > 0 {
            var row = model.First();
            if row != null and row.item != null {
                listBox.RemoveItem(row.item);
            }
            model.RemoveFirst();
            removeCount = removeCount - 1;
        }
    }

    /// @brief Replace debug-console rows from complete debug output text.
    /// @param output Debug output text.
    expose func SetDebugOutput(output: String) {
        UpdateDebugOutput(output);
        ShowDebugPanel();
    }

    /// @brief Refresh Debug Console contents without changing the selected tab.
    /// @details Adapter events can arrive while the user works in Terminal,
    ///          Variables, or another panel; background output must stay passive.
    expose func UpdateDebugOutput(output: String) {
        SetDebugConsoleSource(output, output != "");
    }

    /// @brief Refresh separately owned program output and debugger status text.
    /// @details Only program output is clearable. Stop/termination status remains
    ///          truthful after Clear and can still be filtered or copied.
    expose func UpdateDebugOutputParts(programOutput: String,
                                       statusText: String) {
        var combined = programOutput;
        if statusText != "" {
            if combined != "" and Str.EndsWith(combined, "\n") == false {
                combined = combined + "\n";
            }
            combined = combined + statusText;
        }
        SetDebugConsoleSource(combined, programOutput != "");
    }

    /// @brief Replace the complete bounded Debug Console source and repaint.
    hide func SetDebugConsoleSource(output: String,
                                    canClear: Boolean) {
        debugConsoleSource = output;
        debugConsoleCanClear = canClear;
        debugConsoleClearRequested = false;
        RefreshDebugConsoleRows();
    }

    /// @brief Rebuild filtered/wrapped Debug Console rows from durable source.
    hide func RefreshDebugConsoleRows() {
        ClearToolRows(debugListBox);
        debugConsoleLineCount = 0;
        visibleDebugConsoleLineCount = 0;
        var lines = Str.Split(debugConsoleSource, "\n");
        var n = Seq.get_Count(lines);
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            if line != "" {
                debugConsoleLineCount = debugConsoleLineCount + 1;
                if DebugConsoleLineMatches(line) {
                    visibleDebugConsoleLineCount =
                        visibleDebugConsoleLineCount + 1;
                    RenderDebugConsoleLine(line);
                }
            }
            i = i + 1;
        }
        UpdateDebugToolbarState();
        ApplyDebugConsoleSurfaceVisibility();
    }

    /// @brief Return whether one source line passes the current debug filter.
    hide func DebugConsoleLineMatches(line: String) -> Boolean {
        if debugFilterText == "" { return true; }
        return Str.Contains(Str.ToLower(line), debugFilterText);
    }

    /// @brief Render one logical debug line, optionally split into wrap chunks.
    hide func RenderDebugConsoleLine(line: String) {
        var layoutWidth = 0;
        if debugListBox != null {
            layoutWidth = Convert.NumToInt(debugListBox.GetLogicalWidth());
        }
        if layoutWidth <= 0 and app != null {
            var scale = app.GetEffectiveScale();
            if scale <= 0.0 { scale = 1.0; }
            layoutWidth = Convert.NumToInt(app.GetWidth() / scale);
        }
        var wrapColumn = output_cache.WrapColumn(layoutWidth);
        if debugWrapLines == false or Str.get_Length(line) <= wrapColumn {
            var item = AddToolPlainRow(debugListBox, line, 0);
            ApplyDebugLineColor(item, line);
            return;
        }

        var start = 1;
        while start <= Str.get_Length(line) {
            var chunk = Str.MidLen(line, start, wrapColumn);
            var item = AddToolPlainRow(debugListBox, chunk, 0);
            ApplyDebugLineColor(item, line);
            start = start + wrapColumn;
        }
    }

    /// @brief Set the case-insensitive Debug Console filter.
    expose func SetDebugConsoleFilter(filter: String) {
        var filterHadFocus =
            debugFilterInput != null and debugFilterInput.IsFocused();
        if debugFilterInput != null
           and debugFilterInput.get_Text() != filter {
            debugFilterInput.SetText(filter);
            debugFilterInput.WasChanged();
        }
        debugFilterText = Str.ToLower(Str.Trim(filter));
        RefreshDebugConsoleRows();
        if filterHadFocus { debugFilterInput.Focus(); }
    }

    /// @brief Enable or disable Debug Console line wrapping.
    expose func SetDebugConsoleWrap(enabled: Boolean) {
        debugWrapLines = enabled;
        if debugWrapCheck != null and debugWrapCheck.IsChecked() != enabled {
            debugWrapCheck.SetChecked(enabled);
            debugWrapCheck.WasChanged();
        }
        RefreshDebugConsoleRows();
    }

    /// @brief Copy the complete unfiltered Debug Console source.
    expose func CopyDebugConsoleText() -> Boolean {
        if debugConsoleSource == "" { return false; }
        GUI.ClipboardText.SetText(debugConsoleSource);
        return true;
    }

    /// @brief Consume one user request to clear debugger-owned program output.
    expose func TakeDebugConsoleClearRequest() -> Boolean {
        if debugConsoleClearRequested == false { return false; }
        debugConsoleClearRequested = false;
        return true;
    }

    /// @brief Poll live Debug Console filters and local copy/wrap actions.
    hide func PumpDebugConsoleToolbar() {
        if debugFilterInput == null { return; }
        if debugFilterInput.WasChanged() {
            debugFilterText =
                Str.ToLower(Str.Trim(debugFilterInput.get_Text()));
            RefreshDebugConsoleRows();
        }
        if debugFilterClearButton != null
           and debugFilterClearButton.WasClicked() {
            debugFilterInput.SetText("");
            debugFilterInput.WasChanged();
            debugFilterText = "";
            RefreshDebugConsoleRows();
            debugFilterInput.Focus();
        }
        if debugWrapCheck != null and debugWrapCheck.WasChanged() {
            debugWrapLines = debugWrapCheck.IsChecked();
            RefreshDebugConsoleRows();
        }
        if debugCopyButton != null and debugCopyButton.WasClicked() {
            CopyDebugConsoleText();
        }
        if debugClearButton != null and debugClearButton.WasClicked()
           and debugConsoleCanClear {
            debugConsoleClearRequested = true;
        }
        UpdateDebugToolbarState();
    }

    /// @brief Synchronize Debug Console counts and truthful action state.
    hide func UpdateDebugToolbarState() {
        if debugCountLabel != null {
            var countText = "";
            if debugFilterText != "" {
                countText = "" + visibleDebugConsoleLineCount + " of "
                    + debugConsoleLineCount + " lines";
            } else {
                countText = "" + debugConsoleLineCount + " line";
                if debugConsoleLineCount != 1 {
                    countText = countText + "s";
                }
            }
            debugCountLabel.SetText(countText);
        }
        if debugFilterClearButton != null {
            debugFilterClearButton.SetEnabled(
                debugFilterInput != null
                and debugFilterInput.get_Text() != "");
        }
        if debugCopyButton != null {
            debugCopyButton.SetEnabled(debugConsoleSource != "");
        }
        if debugClearButton != null {
            debugClearButton.SetEnabled(
                debugConsoleCanClear and debugConsoleClearRequested == false);
        }
        if debugEmptyLabel != null {
            var emptyText = "Debug console is idle";
            if debugConsoleLineCount > 0
               and visibleDebugConsoleLineCount == 0 {
                emptyText = "No debug output matches the current filter";
            }
            debugEmptyLabel.SetText(emptyText);
            debugEmptyLabel.SetAccessibleName(emptyText);
        }
    }

    /// @brief Reveal either Debug Console rows or the contextual empty state.
    hide func ApplyDebugConsoleSurfaceVisibility() {
        var panelVisible =
            IsToolPanelSelected(tool_panel_model.PANEL_DEBUG)
            and debugPanel != null and debugPanel.IsVisible();
        if debugListBox != null {
            debugListBox.SetVisible(
                panelVisible and visibleDebugConsoleLineCount > 0);
        }
        if debugEmptyLabel != null {
            debugEmptyLabel.SetVisible(
                panelVisible and visibleDebugConsoleLineCount == 0);
        }
    }

    /// @brief Apply semantic text color to one debug row.
    /// @param item Debug row item.
    /// @param line Row text used to infer severity.
    hide func ApplyDebugLineColor(item: Any,
                                  line: String) {
        if item == null { return; }
        var lower = Str.ToLower(line);
        if Str.IndexOf(lower, "error") != 0
           or Str.IndexOf(lower, "failed") != 0
           or Str.IndexOf(lower, "trap") != 0
           or Str.IndexOf(lower, "not found") != 0 {
            GUI.ListBox.ItemSetTextColor(item, ToolColorError());
        } else if Str.IndexOf(lower, "warning") != 0
                  or Str.IndexOf(lower, "warn") != 0 {
            GUI.ListBox.ItemSetTextColor(item, ToolColorWarning());
        } else if Str.IndexOf(lower, "stopped") != 0
                  or Str.IndexOf(lower, "breakpoint") != 0 {
            GUI.ListBox.ItemSetTextColor(item, ToolColorInfo());
        } else if Str.IndexOf(lower, "terminated") != 0
                  or Str.IndexOf(lower, "exited") != 0
                  or Str.IndexOf(lower, "exit") != 0 {
            GUI.ListBox.ItemSetTextColor(item, ToolColorSuccess());
        } else if Str.StartsWith(lower, "[debug]") {
            GUI.ListBox.ItemSetTextColor(item, ToolColorMuted());
        }
    }

    /// @brief Start one debugger-owned Call Stack snapshot.
    /// @param state Human-readable debugger state such as Paused or Running.
    expose func BeginCallStack(state: String) {
        callStackStateText = state;
        if callStackStateText == "" { callStackStateText = "Idle"; }
        if callStackListBox != null { callStackListBox.Clear(); }
        if callStackRows != null { callStackRows.Clear(); }
        visibleCallStackFrameCount = 0;
        UpdateCallStackToolbarState();
        ApplyCallStackSurfaceVisibility();
    }

    /// @brief Add one stable frame identity to the current Call Stack snapshot.
    /// @return Concrete row handle, or null while filtered out.
    expose func AddCallStackFrame(frameIndex: Integer,
                                  label: String) -> Any {
        if callStackListBox == null or callStackRows == null { return null; }
        var wasAtCapacity = callStackRows.maxRows > 0
            and callStackRows.Count() >= callStackRows.maxRows;
        EnsureToolRowsCapacity(callStackListBox, callStackRows);
        if wasAtCapacity { RefreshCallStackRows(); }
        var row = callStackRows.Add("#" + frameIndex + "  " + label, 0);
        row.searchText = label;
        row.data = "" + frameIndex;
        if frameIndex == 0 { row.color = ToolColorInfo(); }
        var item: Any = null;
        if CallStackRowMatches(row) {
            item = RenderCallStackRow(row);
            visibleCallStackFrameCount = visibleCallStackFrameCount + 1;
        }
        UpdateCallStackToolbarState();
        ApplyCallStackSurfaceVisibility();
        return item;
    }

    /// @brief Render one durable Call Stack frame with its original frame index.
    hide func RenderCallStackRow(
        row: tool_panel_model.ToolPanelRow) -> Any {
        if row == null or callStackListBox == null { return null; }
        var item = callStackListBox.AddItem(row.text);
        row.item = item;
        GUI.ListBox.ItemSetData(item, row.data);
        if row.color != 0 {
            GUI.ListBox.ItemSetTextColor(item, row.color);
        }
        return item;
    }

    /// @brief Return whether one Call Stack frame passes the live filter.
    hide func CallStackRowMatches(
        row: tool_panel_model.ToolPanelRow) -> Boolean {
        if row == null { return false; }
        if callStackFilterText == "" { return true; }
        return Str.Contains(Str.ToLower(row.searchText), callStackFilterText);
    }

    /// @brief Rebuild filtered Call Stack rows without renumbering frames.
    hide func RefreshCallStackRows() {
        if callStackListBox == null or callStackRows == null { return; }
        callStackListBox.Clear();
        visibleCallStackFrameCount = 0;
        var i = 0;
        while i < callStackRows.rows.count() {
            var row = callStackRows.rows.get(i);
            if row != null {
                row.item = null;
                if CallStackRowMatches(row) {
                    RenderCallStackRow(row);
                    visibleCallStackFrameCount =
                        visibleCallStackFrameCount + 1;
                }
            }
            i = i + 1;
        }
        UpdateCallStackToolbarState();
        ApplyCallStackSurfaceVisibility();
    }

    /// @brief Set the case-insensitive Call Stack filter.
    expose func SetCallStackFilter(filter: String) {
        var filterHadFocus =
            callStackFilterInput != null and callStackFilterInput.IsFocused();
        if callStackFilterInput != null
           and callStackFilterInput.get_Text() != filter {
            callStackFilterInput.SetText(filter);
            callStackFilterInput.WasChanged();
        }
        callStackFilterText = Str.ToLower(Str.Trim(filter));
        RefreshCallStackRows();
        if filterHadFocus { callStackFilterInput.Focus(); }
    }

    /// @brief Return the original debugger frame index for the visible selection.
    expose func GetSelectedCallStackFrameIndex() -> Integer {
        if callStackListBox == null or callStackListBox.Selected == null {
            return -1;
        }
        var data = GUI.ListBox.ItemGetData(callStackListBox.Selected);
        if data == "" { return -1; }
        return Convert.ToInt64(data);
    }

    /// @brief Copy the complete unfiltered paused call stack.
    expose func CopyCallStackText() -> Boolean {
        if callStackRows == null or callStackRows.Count() == 0 {
            return false;
        }
        var text = "";
        var i = 0;
        while i < callStackRows.rows.count() {
            var row = callStackRows.rows.get(i);
            if row != null {
                if text != "" { text = text + "\n"; }
                text = text + row.text;
            }
            i = i + 1;
        }
        if text == "" { return false; }
        GUI.ClipboardText.SetText(text);
        return true;
    }

    /// @brief Return whether a paused stack snapshot contains frames.
    expose func HasCallStackFrames() -> Boolean {
        return callStackRows != null and callStackRows.Count() > 0;
    }

    /// @brief Poll Call Stack filtering and copy controls.
    hide func PumpCallStackToolbar() {
        if callStackFilterInput == null { return; }
        if callStackFilterInput.WasChanged() {
            callStackFilterText =
                Str.ToLower(Str.Trim(callStackFilterInput.get_Text()));
            RefreshCallStackRows();
        }
        if callStackFilterClearButton != null
           and callStackFilterClearButton.WasClicked() {
            callStackFilterInput.SetText("");
            callStackFilterInput.WasChanged();
            callStackFilterText = "";
            RefreshCallStackRows();
            callStackFilterInput.Focus();
        }
        if callStackCopyButton != null
           and callStackCopyButton.WasClicked() {
            CopyCallStackText();
        }
        UpdateCallStackToolbarState();
    }

    /// @brief Synchronize Call Stack counts, debugger state, and actions.
    hide func UpdateCallStackToolbarState() {
        var total = 0;
        if callStackRows != null { total = callStackRows.Count(); }
        if callStackCountLabel != null {
            var countText = "";
            if callStackFilterText != "" {
                countText = "" + visibleCallStackFrameCount + " of "
                    + total + " frames · " + callStackStateText;
            } else {
                countText = "" + total + " frame";
                if total != 1 { countText = countText + "s"; }
                countText = countText + " · " + callStackStateText;
            }
            callStackCountLabel.SetText(countText);
        }
        if callStackFilterClearButton != null {
            callStackFilterClearButton.SetEnabled(
                callStackFilterInput != null
                and callStackFilterInput.get_Text() != "");
        }
        if callStackCopyButton != null {
            callStackCopyButton.SetEnabled(total > 0);
        }
        if callStackEmptyLabel != null {
            var emptyText =
                "Start debugging to inspect the call stack";
            if total > 0 and visibleCallStackFrameCount == 0 {
                emptyText = "No frames match the current filter";
            } else if callStackStateText == "Paused" {
                emptyText = "No stack frames were reported at this stop";
            } else if callStackStateText == "Running"
                      or callStackStateText == "Pausing" {
                emptyText = "Pause the debugger to inspect the call stack";
            } else if callStackStateText == "Stopping" {
                emptyText = "Waiting for the debugger to stop";
            } else if callStackStateText == "Restarting" {
                emptyText = "Waiting for the debugger to restart";
            } else if callStackStateText == "Terminated" {
                emptyText = "The debug session has ended";
            }
            callStackEmptyLabel.SetText(emptyText);
            callStackEmptyLabel.SetAccessibleName(emptyText);
        }
    }

    /// @brief Reveal either Call Stack frames or its state-aware empty message.
    hide func ApplyCallStackSurfaceVisibility() {
        var panelVisible =
            IsToolPanelSelected(tool_panel_model.PANEL_CALL_STACK)
            and callStackPanel != null and callStackPanel.IsVisible();
        if callStackListBox != null {
            callStackListBox.SetVisible(
                panelVisible and visibleCallStackFrameCount > 0);
        }
        if callStackEmptyLabel != null {
            callStackEmptyLabel.SetVisible(
                panelVisible and visibleCallStackFrameCount == 0);
        }
    }

    /// @brief Split output text into rows and append each non-empty line.
    /// @param output Complete output text.
    hide func AddBuildOutputLines(output: String) {
        var lines = Str.Split(output, "\n");
        var n = Seq.get_Count(lines);
        var i = 0;
        while i < n {
            var line = Obj.ToString(Seq.Get(lines, i));
            if line != "" {
                AddOutputDisplayLine(line);
            }
            i = i + 1;
        }
    }

    /// @brief Set the Output panel text filter and repaint the active surface.
    /// @param filter Case-insensitive substring filter.
    expose func SetOutputFilter(filter: String) {
        var wasActive = IsOutputPanelActive();
        var filterHadFocus =
            outputFilterInput != null and outputFilterInput.IsFocused();
        if outputFilterInput != null
           and outputFilterInput.get_Text() != filter {
            outputFilterInput.SetText(filter);
            // This is controller synchronization, not fresh user input.
            outputFilterInput.WasChanged();
        }
        outputFilterText = Str.ToLower(Str.Trim(filter));
        if output_cache.ShouldUseRawPane(outputFilterText, outputWrapLines) {
            RenderOutputPane(lastBuildOutput);
            if wasActive or lastBuildOutput != "" or outputFilterText != "" {
                ShowOutputPanel();
            } else {
                HideOutputPanel();
            }
            if filterHadFocus { outputFilterInput.Focus(); }
            UpdateOutputToolbarState();
            return;
        }
        RenderOutputRows(lastBuildOutput);
        if wasActive or outputListBox.Count > 0 or outputFilterText != "" {
            ShowOutputPanel();
        } else {
            HideOutputPanel();
        }
        if filterHadFocus { outputFilterInput.Focus(); }
        UpdateOutputToolbarState();
    }

    /// @brief Set row-mode wrapping and synchronize the visible checkbox.
    /// @param enabled True to wrap long output rows to the panel width.
    expose func SetOutputWrap(enabled: Boolean) {
        var wasActive = IsOutputPanelActive();
        var filterHadFocus =
            outputFilterInput != null and outputFilterInput.IsFocused();
        outputWrapLines = enabled;
        if outputWrapCheck != null
           and outputWrapCheck.IsChecked() != enabled {
            outputWrapCheck.SetChecked(enabled);
            outputWrapCheck.WasChanged();
        }
        if output_cache.ShouldUseRawPane(outputFilterText, outputWrapLines) {
            RenderOutputPane(lastBuildOutput);
        } else {
            RenderOutputRows(lastBuildOutput);
        }
        if wasActive or HasOutputContent() or outputFilterText != "" {
            ShowOutputPanel();
        }
        if filterHadFocus { outputFilterInput.Focus(); }
        UpdateOutputToolbarState();
    }

    /// @brief Toggle row-mode wrapping for the Output panel.
    /// @return New wrapping state.
    expose func ToggleOutputWrap() -> Boolean {
        SetOutputWrap(outputWrapLines == false);
        return outputWrapLines;
    }

    /// @brief Enable or disable auto-scroll for the output pane.
    /// @param enabled True to scroll to new output as it arrives.
    expose func SetOutputAutoScroll(enabled: Boolean) {
        outputAutoScroll = enabled;
        if outputPane != null {
            outputPane.SetAutoScroll(enabled);
        }
        if outputFollowCheck != null
           and outputFollowCheck.IsChecked() != enabled {
            outputFollowCheck.SetChecked(enabled);
            outputFollowCheck.WasChanged();
        }
        UpdateOutputToolbarState();
    }

    /// @brief Toggle output auto-scroll.
    /// @return New auto-scroll state.
    expose func ToggleOutputAutoScroll() -> Boolean {
        outputAutoScroll = outputAutoScroll == false;
        SetOutputAutoScroll(outputAutoScroll);
        return outputAutoScroll;
    }

    /// @brief Clear output text and rows while retaining the current panel.
    /// @details The inline Clear action must not make the surface disappear
    ///          beneath the pointer. Command-level clearing can explicitly hide
    ///          it through ClearOutputPanel.
    expose func ClearOutputContent() {
        if outputPane != null { outputPane.Clear(); }
        if outputListBox != null { outputListBox.Clear(); }
        ResetOutputRows();
        lastBuildOutput = "";
        outputPartialLine = "";
        outputPartialItem = null;
        outputPaneMode = true;
        if IsOutputPanelActive() {
            outputPane.SetVisible(true);
            outputListBox.SetVisible(false);
        }
        UpdateOutputToolbarState();
    }

    /// @brief Clear output text, rows, partial-line state, and visibility.
    expose func ClearOutputPanel() {
        ClearOutputContent();
        HideOutputPanel();
    }

    /// @brief Copy complete captured text or the current generated rows.
    /// @return True when text was copied.
    expose func CopyOutputText() -> Boolean {
        var text = lastBuildOutput;
        if text == "" {
            var i = 0;
            while i < outputRenderedItems.count() {
                var item = outputRenderedItems.get(i);
                if item != null {
                    if text != "" { text = text + "\n"; }
                    text = text + GUI.ListBox.ItemGetText(item);
                }
                i = i + 1;
            }
        }
        if text == "" { return false; }
        GUI.ClipboardText.SetText(text);
        return true;
    }

    /// @brief Poll live Output toolbar state and execute direct local actions.
    /// @details These actions alter only the Output surface, so they do not need
    ///          command-palette routing or unrelated notification popups.
    hide func PumpOutputToolbar() {
        if outputFilterInput == null { return; }
        if outputFilterInput.WasChanged() {
            SetOutputFilter(outputFilterInput.get_Text());
        }
        if outputFilterClearButton != null
           and outputFilterClearButton.WasClicked() {
            outputFilterInput.SetText("");
            outputFilterInput.WasChanged();
            SetOutputFilter("");
            outputFilterInput.Focus();
        }
        if outputWrapCheck != null and outputWrapCheck.WasChanged() {
            SetOutputWrap(outputWrapCheck.IsChecked());
        }
        if outputFollowCheck != null and outputFollowCheck.WasChanged() {
            SetOutputAutoScroll(outputFollowCheck.IsChecked());
        }
        if outputCopyButton != null and outputCopyButton.WasClicked() {
            CopyOutputText();
        }
        if outputClearButton != null and outputClearButton.WasClicked() {
            ClearOutputContent();
        }
        UpdateOutputToolbarState();
    }

    /// @brief Keep Output actions truthful to the current cached content.
    hide func UpdateOutputToolbarState() {
        if outputFilterClearButton != null {
            outputFilterClearButton.SetEnabled(
                outputFilterInput != null
                and outputFilterInput.get_Text() != "");
        }
        if outputCopyButton != null {
            outputCopyButton.SetEnabled(
                lastBuildOutput != "" or outputRenderedItems.count() > 0);
        }
        if outputClearButton != null {
            outputClearButton.SetEnabled(HasOutputContent());
        }
    }

    /// @brief Set the case-insensitive References query and repaint immediately.
    expose func SetReferencesFilter(filter: String) {
        var filterHadFocus =
            referencesFilterInput != null and referencesFilterInput.IsFocused();
        if referencesFilterInput != null
           and referencesFilterInput.get_Text() != filter {
            referencesFilterInput.SetText(filter);
            // Consume the synchronization edge; this method performs the repaint.
            referencesFilterInput.WasChanged();
        }
        referencesFilterText = Str.ToLower(Str.Trim(filter));
        RefreshReferenceRows();
        if filterHadFocus { referencesFilterInput.Focus(); }
    }

    /// @brief Restore the unfiltered References view without closing the panel.
    expose func ResetReferencesFilter() {
        SetReferencesFilter("");
    }

    /// @brief Copy the complete durable grouped References result set.
    /// @return True when at least one actual result was copied.
    expose func CopyReferenceResults() -> Boolean {
        if referencesRows == null or referencesResultCount <= 0 {
            return false;
        }
        var text = "";
        var i = 0;
        while i < referencesRows.rows.count() {
            var row = referencesRows.rows.get(i);
            if row != null {
                if text != "" { text = text + "\n"; }
                if row.isGroupHeader {
                    text = text + row.text;
                } else {
                    text = text + "  " + row.text;
                }
            }
            i = i + 1;
        }
        if text == "" { return false; }
        GUI.ClipboardText.SetText(text);
        return true;
    }

    /// @brief Clear References content while retaining the active surface.
    expose func ClearReferenceResults() {
        ClearToolRows(referencesListBox);
    }

    /// @brief Return whether durable References content can claim fallback space.
    expose func HasReferenceResults() -> Boolean {
        return referencesResultCount > 0;
    }

    /// @brief Poll live References filtering and direct local actions.
    hide func PumpReferencesToolbar() {
        if referencesFilterInput == null { return; }
        if referencesFilterInput.WasChanged() {
            referencesFilterText =
                Str.ToLower(Str.Trim(referencesFilterInput.get_Text()));
            RefreshReferenceRows();
        }
        if referencesFilterClearButton != null
           and referencesFilterClearButton.WasClicked() {
            referencesFilterInput.SetText("");
            referencesFilterInput.WasChanged();
            referencesFilterText = "";
            RefreshReferenceRows();
            referencesFilterInput.Focus();
        }
        if referencesCopyButton != null
           and referencesCopyButton.WasClicked() {
            CopyReferenceResults();
        }
        if referencesClearButton != null
           and referencesClearButton.WasClicked() {
            ClearReferenceResults();
        }
        UpdateReferencesToolbarState();
    }

    /// @brief Synchronize References counts, actions, and honest empty copy.
    hide func UpdateReferencesToolbarState() {
        if referencesCountLabel != null {
            var countText = "";
            if referencesFilterText != "" {
                countText = "" + visibleReferenceCount + " of "
                    + referencesResultCount + " references";
            } else {
                countText = "" + referencesResultCount + " reference";
                if referencesResultCount != 1 {
                    countText = countText + "s";
                }
            }
            referencesCountLabel.SetText(countText);
        }
        if referencesFilterClearButton != null {
            referencesFilterClearButton.SetEnabled(
                referencesFilterInput != null
                and referencesFilterInput.get_Text() != "");
        }
        if referencesCopyButton != null {
            referencesCopyButton.SetEnabled(referencesResultCount > 0);
        }
        if referencesClearButton != null {
            referencesClearButton.SetEnabled(referencesResultCount > 0);
        }
        if referencesEmptyLabel != null {
            var emptyText = "No reference results";
            if referencesResultCount > 0 and visibleReferenceCount == 0 {
                emptyText = "No references match the current filter";
            }
            referencesEmptyLabel.SetText(emptyText);
            referencesEmptyLabel.SetAccessibleName(emptyText);
        }
    }

    /// @brief Reveal either the References list or its contextual empty state.
    hide func ApplyReferenceSurfaceVisibility() {
        var panelVisible =
            IsToolPanelSelected(tool_panel_model.PANEL_REFERENCES)
            and referencesPanel != null and referencesPanel.IsVisible();
        if referencesListBox != null {
            referencesListBox.SetVisible(
                panelVisible and visibleReferenceCount > 0);
        }
        if referencesEmptyLabel != null {
            referencesEmptyLabel.SetVisible(
                panelVisible and visibleReferenceCount == 0);
        }
    }

    /// @brief Copy the selected row from the active tool panel.
    /// @return True when a non-empty selection was copied.
    expose func CopySelectedToolRow() -> Boolean {
        var selectedText = outputListBox.GetSelectedText();
        if activeToolPanelKind == tool_panel_model.PANEL_OUTPUT and outputPaneMode {
            selectedText = outputPane.GetSelection();
        }
        if activeToolPanelKind == tool_panel_model.PANEL_PROBLEMS { selectedText = diagListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_SEARCH { selectedText = searchListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_REFERENCES { selectedText = referencesListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_CALL_STACK { selectedText = callStackListBox.GetSelectedText(); }
        if activeToolPanelKind == tool_panel_model.PANEL_DEBUG { selectedText = debugListBox.GetSelectedText(); }
        if selectedText == "" { return false; }
        GUI.ClipboardText.SetText(selectedText);
        return true;
    }

    /// @brief Add a line to the row-mode output display.
    /// @param line Raw output line.
    /// @return First created ListBox item, or null when filtered out.
    expose func AddOutputDisplayLine(line: String) -> Any {
        if outputFilterText != "" and Str.IndexOf(Str.ToLower(line), outputFilterText) == 0 {
            return null;
        }
        EnsureOutputRowCapacity();
        var layoutWidth = 0;
        if outputListBox != null {
            layoutWidth = Convert.NumToInt(outputListBox.GetLogicalWidth());
        }
        if layoutWidth <= 0 and app != null {
            var scale = app.GetEffectiveScale();
            if scale <= 0.0 { scale = 1.0; }
            layoutWidth = Convert.NumToInt(app.GetWidth() / scale);
        }
        var wrapColumn = output_cache.WrapColumn(layoutWidth);
        if outputWrapLines == false or Str.get_Length(line) <= wrapColumn {
            var item = outputListBox.AddItem(line);
            RegisterOutputRow(item, line);
            ApplyOutputLineColor(item, line);
            if outputAutoScroll {
                outputListBox.ScrollToBottom();
            }
            return item;
        }

        var first: Any = null;
        var start = 1;
        while start <= Str.get_Length(line) {
            var chunk = Str.MidLen(line, start, wrapColumn);
            var item = outputListBox.AddItem(chunk);
            RegisterOutputRow(item, chunk);
            ApplyOutputLineColor(item, line);
            if first == null { first = item; }
            if outputAutoScroll {
                outputListBox.ScrollToBottom();
            }
            start = start + wrapColumn;
        }
        return first;
    }

    /// @brief Keep row-mode output bounded by evicting old realized rows.
    hide func EnsureOutputRowCapacity() {
        var removeCount = tool_panel_model.DEFAULT_TRIM_BATCH_ROWS;
        if removeCount < 1 { removeCount = 1; }
        while outputRenderedItems.count() >= MAX_OUTPUT_ROW_COUNT
              and removeCount > 0 {
            var oldest = outputRenderedItems.get(0);
            outputRenderedItems.removeAt(0);
            if oldest != null {
                outputListBox.RemoveItem(oldest);
            }
            removeCount = removeCount - 1;
        }
        if outputVirtualList != null {
            outputVirtualList.SetCount(outputRenderedRowCount);
        }
    }

    /// @brief Reset row-mode output bookkeeping after a full repaint.
    hide func ResetOutputRows() {
        outputRenderedItems = new List();
        outputRenderedRowCount = 0;
        if outputVirtualList != null {
            outputVirtualList.SetCount(0);
        }
    }

    /// @brief Record one newly-created output row in the virtual row model.
    /// @param item Concrete ListBox item handle.
    /// @param text Rendered row text used to derive a stable row id.
    hide func RegisterOutputRow(item: Any,
                                text: String) {
        if item == null { return; }
        outputRenderedRowCount = outputRenderedRowCount + 1;
        outputRenderedItems.add(item);
        if outputVirtualList != null {
            outputVirtualList.SetCount(outputRenderedRowCount);
            outputVirtualList.SetRowId(outputRenderedRowCount - 1,
                                       "out:" + outputRenderedRowCount + ":" + Str.get_Length(text));
        }
    }

    /// @brief Clear the Problems panel and hide it from fallback selection.
    expose func ClearProblemsPanel() {
        problemRecords.clear();
        visibleProblemRecords.clear();
        ClearToolRows(diagListBox);
        problemsHaveDiagnostics = false;
        problemsErrorCount = 0;
        problemsWarningCount = 0;
        problemsInfoCount = 0;
        visibleProblemCount = 0;
        UpdateProblemsToolbarState();
        HideProblemsPanel();
    }

    /// @brief Begin a fresh Problems panel render with a table header.
    expose func BeginProblems() {
        problemRecords.clear();
        visibleProblemRecords.clear();
        problemsHaveDiagnostics = false;
        problemsErrorCount = 0;
        problemsWarningCount = 0;
        problemsInfoCount = 0;
        visibleProblemCount = 0;
        RefreshProblemRows();
    }

    /// @brief Rebuild concrete Problems rows from durable filtered records.
    hide func RefreshProblemRows() {
        ClearToolRows(diagListBox);
        visibleProblemRecords.clear();
        var header = AddToolPlainRow(diagListBox,
                                     PadToolColumn("TYPE", TOOL_KIND_COL)
                                     + "  " + PadToolColumn("SOURCE", TOOL_SOURCE_COL)
                                     + "  " + PadToolColumn("LOCATION", TOOL_LOCATION_COL)
                                     + "  " + PadToolColumn("CODE", TOOL_CODE_COL)
                                     + "  MESSAGE"
                                     + "  " + PadToolColumn("ACTION", TOOL_ACTION_COL),
                                     ToolColorMuted());
        if header != null {
            GUI.ListBox.ItemSetTextColor(header, ToolColorMuted());
        }

        var i = 0;
        while i < problemRecords.count() {
            var record = problemRecords.get(i);
            if ProblemMatchesFilters(record) {
                visibleProblemRecords.add(record);
                RenderProblemRecord(record);
            }
            i = i + 1;
        }
        visibleProblemCount = visibleProblemRecords.count();
        if problemRecords.count() > 0 and visibleProblemCount == 0 {
            AddToolInfoRow(diagListBox, "filter",
                           "No problems match the current filters");
        }
        UpdateProblemsToolbarState();
    }

    /// @brief Add one diagnostics row to Problems.
    /// @return Concrete ListBox item handle, or null when filtered out.
    expose func AddProblem(severity: String,
                           source: String,
                           filePath: String,
                           line: Integer,
                           column: Integer,
                           code: String,
                           message: String,
                           action: String) -> Any {
        if problemRecords.count() >= tool_panel_model.DEFAULT_MAX_ROWS {
            var oldest = problemRecords.get(0);
            DecrementProblemSeverityCount(oldest);
            problemRecords.removeAt(0);
            RefreshProblemRows();
        }

        var record = new tool_panel_model.ProblemRecord();
        record.severity = severity;
        record.source = source;
        record.filePath = filePath;
        record.line = line;
        record.column = column;
        record.code = code;
        record.message = message;
        record.action = action;
        problemRecords.add(record);
        IncrementProblemSeverityCount(record);
        problemsHaveDiagnostics = true;

        var item: Any = null;
        if ProblemMatchesFilters(record) {
            visibleProblemRecords.add(record);
            item = RenderProblemRecord(record);
        }
        visibleProblemCount = visibleProblemRecords.count();
        UpdateProblemsToolbarState();
        return item;
    }

    /// @brief Attach navigation metadata to the most recently added diagnostic.
    /// @details Callers invoke this immediately after AddProblem. The durable
    ///          record retains the location even when filtering retires its
    ///          concrete ListBox item.
    expose func SetAddedProblemLocationData(item: Any,
                                            locationData: String) {
        if problemRecords.count() > 0 {
            var record = problemRecords.get(problemRecords.count() - 1);
            record.locationData = locationData;
        }
        if item != null {
            GUI.ListBox.ItemSetData(item, locationData);
        }
    }

    /// @brief Render one durable diagnostic into the current ListBox.
    /// @return Newly-created concrete item.
    hide func RenderProblemRecord(
        record: tool_panel_model.ProblemRecord) -> Any {
        if record == null { return null; }
        var displayCode = record.code;
        if displayCode == "" { displayCode = "-"; }
        var displayAction = record.action;
        if displayAction == "" or displayAction == "No quick fix" { displayAction = "-"; }
        var displaySource = record.source;
        if displaySource == "" { displaySource = "-"; }
        var location = record.filePath + ":" + record.line + ":" + record.column;
        var item = AddToolLocationRow(diagListBox,
                                      ProblemSeverityLabel(record.severity),
                                      displaySource, location, displayCode,
                                      record.message, displayAction);
        ApplyProblemSeverityColor(item, record.severity);
        if item != null and record.locationData != "" {
            GUI.ListBox.ItemSetData(item, record.locationData);
        }
        return item;
    }

    /// @brief Return whether one diagnostic passes severity and text filters.
    hide func ProblemMatchesFilters(
        record: tool_panel_model.ProblemRecord) -> Boolean {
        if record == null { return false; }
        var severity = Str.ToLower(record.severity);
        if severity == "error" and problemsShowErrors == false {
            return false;
        }
        if (severity == "warning" or severity == "warn")
           and problemsShowWarnings == false {
            return false;
        }
        if severity != "error" and severity != "warning" and severity != "warn"
           and problemsShowInfo == false {
            return false;
        }
        if problemsFilterText == "" { return true; }
        var searchable = Str.ToLower(
            record.source + " " + record.filePath + " " + record.code + " "
            + record.message + " " + record.action);
        return Str.Contains(searchable, problemsFilterText);
    }

    /// @brief Increment one normalized severity counter.
    hide func IncrementProblemSeverityCount(
        record: tool_panel_model.ProblemRecord) {
        if record == null { return; }
        var severity = Str.ToLower(record.severity);
        if severity == "error" {
            problemsErrorCount = problemsErrorCount + 1;
        } else if severity == "warning" or severity == "warn" {
            problemsWarningCount = problemsWarningCount + 1;
        } else {
            problemsInfoCount = problemsInfoCount + 1;
        }
    }

    /// @brief Decrement one normalized severity counter during bounded eviction.
    hide func DecrementProblemSeverityCount(
        record: tool_panel_model.ProblemRecord) {
        if record == null { return; }
        var severity = Str.ToLower(record.severity);
        if severity == "error" and problemsErrorCount > 0 {
            problemsErrorCount = problemsErrorCount - 1;
        } else if (severity == "warning" or severity == "warn")
                  and problemsWarningCount > 0 {
            problemsWarningCount = problemsWarningCount - 1;
        } else if severity != "error" and severity != "warning"
                  and severity != "warn" and problemsInfoCount > 0 {
            problemsInfoCount = problemsInfoCount - 1;
        }
    }

    /// @brief Set the case-insensitive Problems query and repaint immediately.
    expose func SetProblemsFilter(filter: String) {
        if problemsFilterInput != null
           and problemsFilterInput.get_Text() != filter {
            problemsFilterInput.SetText(filter);
            problemsFilterInput.WasChanged();
        }
        problemsFilterText = Str.ToLower(Str.Trim(filter));
        RefreshProblemRows();
    }

    /// @brief Set all severity filters atomically.
    expose func SetProblemSeverityFilters(showErrors: Boolean,
                                          showWarnings: Boolean,
                                          showInfo: Boolean) {
        problemsShowErrors = showErrors;
        problemsShowWarnings = showWarnings;
        problemsShowInfo = showInfo;
        if problemsErrorCheck != null
           and problemsErrorCheck.IsChecked() != showErrors {
            problemsErrorCheck.SetChecked(showErrors);
            problemsErrorCheck.WasChanged();
        }
        if problemsWarningCheck != null
           and problemsWarningCheck.IsChecked() != showWarnings {
            problemsWarningCheck.SetChecked(showWarnings);
            problemsWarningCheck.WasChanged();
        }
        if problemsInfoCheck != null
           and problemsInfoCheck.IsChecked() != showInfo {
            problemsInfoCheck.SetChecked(showInfo);
            problemsInfoCheck.WasChanged();
        }
        RefreshProblemRows();
    }

    /// @brief Restore the unfiltered Problems view without moving keyboard focus.
    expose func ResetProblemFilters() {
        SetProblemsFilter("");
        SetProblemSeverityFilters(true, true, true);
    }

    /// @brief Return the selected durable record, excluding headers/state rows.
    expose func GetSelectedProblemRecord()
        -> tool_panel_model.ProblemRecord {
        if diagListBox == null { return null; }
        var index = diagListBox.SelectedIndex - 1;
        if index < 0 or index >= visibleProblemRecords.count() {
            return null;
        }
        return visibleProblemRecords.get(index);
    }

    /// @brief Return the selected quick-fix label.
    expose func GetSelectedProblemAction() -> String {
        var record = GetSelectedProblemRecord();
        if record == null { return ""; }
        return record.action;
    }

    /// @brief Return the selected diagnostic's durable location identifier.
    expose func GetSelectedProblemLocationData() -> String {
        var record = GetSelectedProblemRecord();
        if record == null { return ""; }
        return record.locationData;
    }

    /// @brief Set whether an asynchronous diagnostic action owns the toolbar.
    expose func SetProblemsActionBusy(busy: Boolean) {
        problemsActionBusy = busy;
        UpdateProblemsToolbarState();
    }

    /// @brief Consume a pointer or keyboard activation of the Quick Fix button.
    expose func ProblemsQuickFixWasRequested() -> Boolean {
        if problemsQuickFixButton == null
           or problemsQuickFixButton.WasClicked() == false {
            return false;
        }
        var action = GetSelectedProblemAction();
        return problemsActionBusy == false
            and action != "" and action != "No quick fix" and action != "-";
    }

    /// @brief Poll live Problems filters and keep contextual actions synchronized.
    hide func PumpProblemsToolbar() {
        if problemsFilterInput == null { return; }
        var changed = false;
        if problemsFilterInput.WasChanged() {
            problemsFilterText =
                Str.ToLower(Str.Trim(problemsFilterInput.get_Text()));
            changed = true;
        }
        if problemsErrorCheck != null and problemsErrorCheck.WasChanged() {
            problemsShowErrors = problemsErrorCheck.IsChecked();
            changed = true;
        }
        if problemsWarningCheck != null
           and problemsWarningCheck.WasChanged() {
            problemsShowWarnings = problemsWarningCheck.IsChecked();
            changed = true;
        }
        if problemsInfoCheck != null and problemsInfoCheck.WasChanged() {
            problemsShowInfo = problemsInfoCheck.IsChecked();
            changed = true;
        }
        if problemsResetButton != null and problemsResetButton.WasClicked() {
            problemsFilterInput.SetText("");
            problemsFilterInput.WasChanged();
            problemsErrorCheck.SetChecked(true);
            problemsErrorCheck.WasChanged();
            problemsWarningCheck.SetChecked(true);
            problemsWarningCheck.WasChanged();
            problemsInfoCheck.SetChecked(true);
            problemsInfoCheck.WasChanged();
            problemsFilterText = "";
            problemsShowErrors = true;
            problemsShowWarnings = true;
            problemsShowInfo = true;
            changed = true;
        }
        if changed { RefreshProblemRows(); }
        UpdateProblemsToolbarState();
    }

    /// @brief Update counts, reset availability, and selected-action truth.
    hide func UpdateProblemsToolbarState() {
        var total = problemRecords.count();
        visibleProblemCount = visibleProblemRecords.count();
        if problemsCountLabel != null {
            var countText = "" + visibleProblemCount + " of " + total
                + "  ·  " + problemsErrorCount + " error";
            if problemsErrorCount != 1 { countText = countText + "s"; }
            countText = countText + "  ·  " + problemsWarningCount + " warning";
            if problemsWarningCount != 1 { countText = countText + "s"; }
            countText = countText + "  ·  " + problemsInfoCount + " info";
            problemsCountLabel.SetText(countText);
        }
        if problemsResetButton != null {
            problemsResetButton.SetEnabled(
                problemsFilterText != ""
                or problemsShowErrors == false
                or problemsShowWarnings == false
                or problemsShowInfo == false);
        }
        if problemsQuickFixButton != null {
            var action = GetSelectedProblemAction();
            var enabled = problemsActionBusy == false
                and action != "" and action != "No quick fix" and action != "-";
            problemsQuickFixButton.SetEnabled(enabled);
            if problemsActionBusy {
                problemsQuickFixButton.SetTooltip(
                    "A diagnostic action is already running");
            } else if enabled {
                problemsQuickFixButton.SetTooltip(action);
            } else {
                problemsQuickFixButton.SetTooltip(
                    "Select a diagnostic with an available quick fix");
            }
        }
    }

    /// @brief Add a muted group header row.
    /// @return Concrete ListBox item handle.
    expose func AddToolGroupHeader(listBox: GUI.ListBox,
                                   title: String,
                                   detail: String) -> Any {
        if listBox == null { return null; }
        var text = TrimToolText(title, 36);
        if detail != "" and detail != title {
            text = text + "  " + TrimToolText(detail, 96);
        }
        if listBox == referencesListBox {
            return AddReferenceModelRow(
                text, title + " " + detail, ToolColorMuted(), true);
        }
        return AddToolPlainRow(listBox, text, ToolColorMuted());
    }

    /// @brief Add a fixed-column location row to a tool panel.
    /// @return Concrete ListBox item handle.
    expose func AddToolLocationRow(listBox: GUI.ListBox,
                                   kind: String,
                                   source: String,
                                   location: String,
                                   code: String,
                                   preview: String,
                                   action: String) -> Any {
        if listBox == null { return null; }
        var displayKind = kind;
        if displayKind == "" { displayKind = "-"; }
        var displaySource = source;
        if displaySource == "" { displaySource = "-"; }
        var displayCode = code;
        if displayCode == "" { displayCode = "-"; }
        var text = PadToolColumn(displayKind, TOOL_KIND_COL)
                   + "  " + PadToolColumn(displaySource, TOOL_SOURCE_COL)
                   + "  " + PadToolColumn(location, TOOL_LOCATION_COL)
                   + "  " + PadToolColumn(displayCode, TOOL_CODE_COL)
                   + "  " + TrimToolText(preview, 96);
        if action != "" {
            text = text + "  " + PadToolColumn(action, TOOL_ACTION_COL);
        }
        if listBox == referencesListBox {
            return AddReferenceModelRow(
                text,
                kind + " " + source + " " + location + " " + code + " "
                    + preview + " " + action,
                0,
                false);
        }
        return AddToolPlainRow(listBox, text, 0);
    }

    /// @brief Add a colorized state row to a tool panel.
    /// @return Concrete ListBox item handle.
    expose func AddToolStateRow(listBox: GUI.ListBox,
                                kind: String,
                                source: String,
                                message: String,
                                color: Integer) -> Any {
        var item = AddToolLocationRow(listBox, kind, source, "-", "-", message, "-");
        if item != null {
            GUI.ListBox.ItemSetTextColor(item, color);
        }
        if listBox == referencesListBox and referencesRows.Count() > 0 {
            var row = referencesRows.rows.get(referencesRows.Count() - 1);
            row.color = color;
        }
        return item;
    }

    /// @brief Add a muted informational state row.
    /// @return Concrete ListBox item handle.
    expose func AddToolInfoRow(listBox: GUI.ListBox,
                               source: String,
                               message: String) -> Any {
        return AddToolStateRow(listBox, "INFO", source, message, ToolColorMuted());
    }

    /// @brief Add a success state row.
    /// @return Concrete ListBox item handle.
    expose func AddToolSuccessRow(listBox: GUI.ListBox,
                                  source: String,
                                  message: String) -> Any {
        return AddToolStateRow(listBox, "OK", source, message, ToolColorSuccess());
    }

    /// @brief Format a diagnostics severity label.
    /// @return Short normalized severity text.
    expose func ProblemSeverityLabel(severity: String) -> String {
        return tool_panel_text.ProblemSeverityLabel(severity);
    }

    /// @brief Pad or trim a fixed-width panel column.
    /// @return Column text with stable width.
    expose func PadToolColumn(text: String, width: Integer) -> String {
        return tool_panel_text.PadToolColumn(text, width);
    }

    /// @brief Trim panel text to a bounded display width.
    /// @return Trimmed display text.
    expose func TrimToolText(text: String, width: Integer) -> String {
        return tool_panel_text.TrimToolText(text, width);
    }

    /// @brief Apply severity color to a Problems row.
    expose func ApplyProblemSeverityColor(item: Any, severity: String) {
        if item == null { return; }
        GUI.ListBox.ItemSetTextColor(item, tool_panel_text.ProblemSeverityColor(severity));
    }

    /// @brief Apply semantic color to an output row.
    expose func ApplyOutputLineColor(item: Any, line: String) {
        if item == null { return; }
        var color = tool_panel_text.OutputLineColor(line);
        if color != 0 {
            GUI.ListBox.ItemSetTextColor(item, color);
        }
    }

    /// @brief Format the diagnostics status item text.
    /// @return Short diagnostics summary.
    expose func FormatDiagnosticsSummary(errors: Integer,
                                         warnings: Integer,
                                         notes: Integer) -> String {
        return tool_panel_text.FormatDiagnosticsSummary(errors, warnings, notes);
    }

    /// @brief Pick the diagnostics status item color.
    /// @return RGB color integer.
    expose func DiagnosticsSummaryColor(errors: Integer,
                                        warnings: Integer,
                                        notes: Integer) -> Integer {
        return tool_panel_text.DiagnosticsSummaryColor(errors, warnings, notes);
    }

    /// @brief Format a language display name.
    /// @return Human-readable language name.
    expose func FormatLanguageName(languageName: String) -> String {
        return tool_panel_text.FormatLanguageName(languageName);
    }

    /// @brief Finish Problems rendering and show or hide the panel.
    /// @param problemCount Number of diagnostics rendered.
    expose func FinishProblems(problemCount: Integer) {
        UpdateProblems(problemCount);
        if problemCount > 0 { ShowProblemsPanel(); }
    }

    /// @brief Finish Problems rendering without changing the selected panel.
    /// @details Live diagnostics and background builds can update the model
    ///          after the user has moved to Terminal or another tool.
    expose func UpdateProblems(problemCount: Integer) {
        if problemCount > 0 {
            problemsHaveDiagnostics = true;
            if IsToolPanelSelected(tool_panel_model.PANEL_PROBLEMS) {
                if problemsPanel != null { problemsPanel.SetVisible(true); }
                diagListBox.SetVisible(true);
            }
        } else {
            problemsHaveDiagnostics = false;
            AddCleanProblemsRow();
            HideProblemsPanel();
        }
        UpdateProblemsToolbarState();
    }

    /// @brief Add the clean-state Problems row after a successful check.
    hide func AddCleanProblemsRow() {
        AddToolSuccessRow(diagListBox, "build", "No diagnostics from the latest check");
    }

    /// @brief Restore one physical tool dock without changing sibling splits.
    hide func ExpandToolDockAt(location: Integer,
                               minimumBottomHeight: Number) {
        if location == workspace_dock.DOCK_FLOATING {
            KeepFloatingPanelInViewport();
            if floatingToolPanel != null {
                floatingToolPanel.SetVisible(true);
            }
        } else if location == workspace_dock.DOCK_BOTTOM {
            ApplyBottomPanelSplit(minimumBottomHeight);
        } else {
            ApplySidePanelSplitAt(location);
        }
    }

    /// @brief Return Search's minimum height in physical layout units.
    /// @details Tool-panel widgets grow with both HiDPI backing scale and user
    ///          UI zoom, so the reserved results viewport must follow the same
    ///          effective scale instead of remaining a fixed pixel count.
    hide func SearchPanelMinimumHeight() -> Number {
        var scale = 1.0;
        if app != null {
            scale = app.GetScale() * app.GetUiScale();
            if scale <= 0.0 { scale = 1.0; }
        }
        var logicalHeight = SEARCH_PANEL_MIN_LOGICAL_HEIGHT;
        if compactSearchControls {
            logicalHeight = SEARCH_PANEL_COMPACT_MIN_LOGICAL_HEIGHT;
        }
        return logicalHeight * scale;
    }

    /// @brief Apply the configured split while reserving optional panel height.
    /// @details The splitter position is the editor's fraction. Search uses a
    ///          temporary cap derived from the live splitter height, so compact
    ///          windows retain result rows without overwriting the persisted
    ///          fraction used by every other tool panel.
    /// @param minimumPanelHeight Minimum requested height for the second pane.
    hide func ApplyBottomPanelSplit(minimumPanelHeight: Number) {
        if editorSplit == null { return; }
        if editorSplit.GetCollapsedSide() != 0 {
            editorSplit.Restore();
        }
        var desired = bottomSplitFraction;
        var splitHeight = editorSplit.GetHeight();
        if minimumPanelHeight > 0.0 and splitHeight > 0.0 {
            var maximumEditorFraction = 1.0 - minimumPanelHeight / splitHeight;
            if maximumEditorFraction < 0.3 { maximumEditorFraction = 0.3; }
            if desired > maximumEditorFraction { desired = maximumEditorFraction; }
        }
        var delta = editorSplit.GetPosition() - desired;
        if delta < 0.0 { delta = 0.0 - delta; }
        if delta > 0.001 {
            editorSplit.SetPosition(desired);
        }
        appliedSplitFraction = desired;
    }

    /// @brief Apply the shared configured width to one physical side dock.
    hide func ApplySidePanelSplitAt(location: Integer) {
        var split = leftDockSplit;
        var desired = sidePanelFraction;
        if location == workspace_dock.DOCK_RIGHT {
            split = rightDockSplit;
            desired = 1.0 - sidePanelFraction;
        } else if location != workspace_dock.DOCK_LEFT {
            return;
        }
        if split == null { return; }
        if split.GetCollapsedSide() != 0 { split.Restore(); }
        var delta = split.GetPosition() - desired;
        if delta < 0.0 { delta = 0.0 - delta; }
        if delta > 0.001 { split.SetPosition(desired); }
        appliedSideSplitPosition = desired;
    }

    /// @brief Collapse one physical tool dock without disturbing the others.
    hide func CollapseToolDockAt(location: Integer) {
        if location == workspace_dock.DOCK_FLOATING {
            if floatingToolPanel != null {
                floatingToolPanel.SetVisible(false);
            }
        } else if location == workspace_dock.DOCK_LEFT {
            if leftDockSplit != null { leftDockSplit.CollapseFirst(); }
        } else if location == workspace_dock.DOCK_RIGHT {
            if rightDockSplit != null { rightDockSplit.CollapseSecond(); }
        } else if location == workspace_dock.DOCK_BOTTOM
                  and editorSplit != null {
            editorSplit.CollapseSecond();
        }
    }

    /// @brief Capture live splitter drags for every simultaneously open group.
    hide func CaptureSplitDrag() {
        if activeBottomToolPanelKind != tool_panel_model.PANEL_NONE
           and editorSplit != null
           and editorSplit.GetCollapsedSide() == 0 {
            var bottomPos = editorSplit.GetPosition();
            if bottomPos >= 0.3 and bottomPos <= 0.985 {
                var bottomDelta = bottomPos - appliedSplitFraction;
                if bottomDelta < 0.0 {
                    bottomDelta = 0.0 - bottomDelta;
                }
                if bottomDelta > 0.004 {
                    bottomSplitFraction = bottomPos;
                    appliedSplitFraction = bottomPos;
                    splitFractionDirty = true;
                }
            }
        }
        CaptureSideSplitDragAt(workspace_dock.DOCK_LEFT);
        CaptureSideSplitDragAt(workspace_dock.DOCK_RIGHT);
    }

    /// @brief Capture one side width as the shared durable panel fraction.
    hide func CaptureSideSplitDragAt(location: Integer) {
        if ActiveToolPanelKindAt(location)
               == tool_panel_model.PANEL_NONE {
            return;
        }
        var sideSplit = leftDockSplit;
        if location == workspace_dock.DOCK_RIGHT {
            sideSplit = rightDockSplit;
        }
        if sideSplit == null or sideSplit.GetCollapsedSide() != 0 { return; }
        var sidePosition = sideSplit.GetPosition();
        var panelFraction = sidePosition;
        if location == workspace_dock.DOCK_RIGHT {
            panelFraction = 1.0 - sidePosition;
        }
        if panelFraction < 0.20 or panelFraction > 0.55 { return; }
        var sideDelta = panelFraction - sidePanelFraction;
        if sideDelta < 0.0 { sideDelta = 0.0 - sideDelta; }
        if sideDelta > 0.004 {
            sidePanelFraction = panelFraction;
            appliedSideSplitPosition = sidePosition;
            sideFractionDirty = true;
            var sibling = workspace_dock.DOCK_RIGHT;
            if location == workspace_dock.DOCK_RIGHT {
                sibling = workspace_dock.DOCK_LEFT;
            }
            if ActiveToolPanelKindAt(sibling)
                   != tool_panel_model.PANEL_NONE {
                ApplySidePanelSplitAt(sibling);
            }
        }
    }

    /// @brief Apply a persisted editor-height percentage (settings-driven).
    /// @param pct Editor's share of the split, clamped to [30, 95].
    expose func SetBottomSplitPct(pct: Integer) {
        var clamped = pct;
        if clamped < 30 { clamped = 30; }
        if clamped > 95 { clamped = 95; }
        bottomSplitFraction = clamped / 100.0; // int/float promotes to Number
        if editorSplit != null
           and activeBottomToolPanelKind
               != tool_panel_model.PANEL_NONE {
            if activeBottomToolPanelKind
                   == tool_panel_model.PANEL_SEARCH {
                ApplyBottomPanelSplit(SearchPanelMinimumHeight());
            } else {
                ExpandToolDockAt(workspace_dock.DOCK_BOTTOM, 0.0);
            }
        }
    }

    /// @brief Consume a user-authored split change as a persisted percentage.
    /// @details Controller-authored Search expansion never sets the dirty bit.
    ///          Live drag values round to the nearest percent and clamp to the
    ///          same [30, 95] range accepted by SettingsManager.
    /// @return Changed percentage, or -1 when there is nothing to persist.
    expose func TakeChangedSplitPercent() -> Integer {
        if splitFractionDirty == false { return -1; }
        splitFractionDirty = false;
        var scaled = bottomSplitFraction * 100.0;
        var pct = 30;
        while pct < 95 and scaled >= pct + 0.5 {
            pct = pct + 1;
        }
        return pct;
    }

    /// @brief Switch long tool-tab labels to discoverable compact names.
    /// @details The tab bar remains horizontally scrollable, but at the native
    ///          minimum the full labels hid Debug and Terminal completely. The
    ///          compact set fits common narrow workbench widths while explicit
    ///          tooltips retain every unabbreviated name. GetLogicalWidth has
    ///          already removed both backing scale and user zoom.
    hide func ApplyResponsiveToolTabLabels() {
        if toolTabBar == null { return; }
        var width = toolTabBar.GetLogicalWidth();
        if width <= 0.0 { return; }
        var compact = width <= TOOL_TABS_COMPACT_MAX_WIDTH;
        if compact == compactToolTabs { return; }
        compactToolTabs = compact;
        if compactToolTabs {
            toolReferencesTab.SetTitle("Refs");
            toolVariablesTab.SetTitle("Vars");
            toolCallStackTab.SetTitle("Stack");
            toolDebugTab.SetTitle("Debug");
            toolTerminalTab.SetTitle("Term");
        } else {
            toolReferencesTab.SetTitle("References");
            toolVariablesTab.SetTitle("Variables");
            toolCallStackTab.SetTitle("Call Stack");
            toolDebugTab.SetTitle("Debug Console");
            toolTerminalTab.SetTitle("Terminal");
        }
        toolReferencesTab.SetTooltip("References");
        toolVariablesTab.SetTooltip("Variables");
        toolCallStackTab.SetTooltip("Call Stack");
        toolDebugTab.SetTooltip("Debug Console");
        toolTerminalTab.SetTooltip("Terminal");
    }

    /// @brief Hide one tool surface while retaining all buffered/controller data.
    hide func HideToolPanelSurface(kind: Integer) {
        if kind == tool_panel_model.PANEL_PROBLEMS {
            if problemsPanel != null { problemsPanel.SetVisible(false); }
            if diagListBox != null { diagListBox.SetVisible(false); }
        } else if kind == tool_panel_model.PANEL_OUTPUT {
            if outputPanel != null { outputPanel.SetVisible(false); }
            if outputPane != null { outputPane.SetVisible(false); }
            if outputListBox != null { outputListBox.SetVisible(false); }
        } else if kind == tool_panel_model.PANEL_SEARCH {
            if searchPanel != null { searchPanel.SetVisible(false); }
            if searchListBox != null { searchListBox.SetVisible(false); }
        } else if kind == tool_panel_model.PANEL_REFERENCES {
            if referencesPanel != null { referencesPanel.SetVisible(false); }
            if referencesListBox != null {
                referencesListBox.SetVisible(false);
            }
            if referencesEmptyLabel != null {
                referencesEmptyLabel.SetVisible(false);
            }
        } else if kind == tool_panel_model.PANEL_VARIABLES {
            if variablesPanel != null { variablesPanel.SetVisible(false); }
            if variablesListBox != null {
                variablesListBox.SetVisible(false);
            }
        } else if kind == tool_panel_model.PANEL_CALL_STACK {
            if callStackPanel != null { callStackPanel.SetVisible(false); }
            if callStackListBox != null {
                callStackListBox.SetVisible(false);
            }
            if callStackEmptyLabel != null {
                callStackEmptyLabel.SetVisible(false);
            }
        } else if kind == tool_panel_model.PANEL_DEBUG {
            if debugPanel != null { debugPanel.SetVisible(false); }
            if debugListBox != null { debugListBox.SetVisible(false); }
            if debugEmptyLabel != null {
                debugEmptyLabel.SetVisible(false);
            }
        } else if kind == tool_panel_model.PANEL_TERMINAL {
            if terminalPanel != null { terminalPanel.SetVisible(false); }
        }
    }

    /// @brief Hide only the panels assigned to one dock group.
    hide func HideToolPanelsAt(location: Integer) {
        var parts = Str.Split(toolPanelGroups.IdsAt(location), ",");
        var i = 0;
        while i < Seq.get_Count(parts) {
            var id = Str.Trim(Obj.ToString(Seq.Get(parts, i)));
            if id != "" {
                HideToolPanelSurface(
                    tool_panel_model.PanelKindForTabId(id));
            }
            i = i + 1;
        }
    }

    /// @brief Prepare one group for selection without hiding sibling groups.
    hide func PrepareToolPanel(kind: Integer,
                               minimumBottomHeight: Number) {
        var id = tool_panel_model.TabIdForPanelKind(kind);
        var location = toolPanelGroups.LocationForId(id);
        var root = ToolGroupRootAt(location);
        var bar = ToolTabBarAt(location);
        var tab = ToolTabForKind(kind);
        if id == tool_panel_model.TAB_ID_NONE
           or root == null or bar == null or tab == null {
            return;
        }

        HideToolPanelsAt(location);
        root.SetVisible(true);
        bar.SetVisible(true);
        ExpandToolDockAt(location, minimumBottomHeight);
        bar.SetActive(tab);
        SetActiveToolPanelKindAt(location, kind);
        SetActiveToolPanelKind(kind);
        UpdateToolGroupLabel(location, kind);
    }

    /// @brief Keep auxiliary headers specific and useful at narrow widths.
    hide func UpdateToolGroupLabel(location: Integer, kind: Integer) {
        if location == dockLocation { return; }
        if location == workspace_dock.DOCK_FLOATING {
            if floatingToolMoveHandle != null and !floatingPanelMoving {
                floatingToolMoveHandle.SetText(
                    DefaultFloatingToolHeaderText());
                floatingToolMoveHandle.SetAccessibleName(
                    "Move floating tool window, "
                    + tool_panel_model.PanelName(kind) + " selected");
            }
            return;
        }
        var prefix = "Bottom";
        var label = bottomToolGroupLabel;
        if location == workspace_dock.DOCK_LEFT {
            prefix = "Left";
            label = leftToolGroupLabel;
        } else if location == workspace_dock.DOCK_RIGHT {
            prefix = "Right";
            label = rightToolGroupLabel;
        }
        if label == null { return; }
        var text = prefix + " · " + tool_panel_model.PanelName(kind);
        label.SetText(text);
        label.SetAccessibleName(
            prefix + " tool group, " + tool_panel_model.PanelName(kind));
    }

    /// @brief Hide and collapse one complete group while siblings stay live.
    hide func HideToolGroupAt(location: Integer) {
        HideToolPanelsAt(location);
        var bar = ToolTabBarAt(location);
        var root = ToolGroupRootAt(location);
        if bar != null { bar.SetVisible(false); }
        if root != null { root.SetVisible(false); }
        SetActiveToolPanelKindAt(location, tool_panel_model.PANEL_NONE);
        CollapseToolDockAt(location);
        var activeId =
            tool_panel_model.TabIdForPanelKind(activeToolPanelKind);
        if toolPanelGroups.LocationForId(activeId) == location {
            SetActiveToolPanelKind(AnyActiveToolPanelKind());
        }
    }

    /// @brief Hide every tool surface across all physical dock groups.
    hide func HideAllToolPanels() {
        HideToolPanelSurface(tool_panel_model.PANEL_PROBLEMS);
        HideToolPanelSurface(tool_panel_model.PANEL_OUTPUT);
        HideToolPanelSurface(tool_panel_model.PANEL_SEARCH);
        HideToolPanelSurface(tool_panel_model.PANEL_REFERENCES);
        HideToolPanelSurface(tool_panel_model.PANEL_VARIABLES);
        HideToolPanelSurface(tool_panel_model.PANEL_CALL_STACK);
        HideToolPanelSurface(tool_panel_model.PANEL_DEBUG);
        HideToolPanelSurface(tool_panel_model.PANEL_TERMINAL);
    }

    /// @brief Hide the entire panel area while retaining its buffered content.
    /// @details Any later panel command reopens the current dock; no terminal,
    ///          diagnostic, search, or output state is destroyed.
    expose func HidePanelArea() {
        HideAllToolPanels();
        if toolTabBar != null { toolTabBar.SetVisible(false); }
        if leftToolTabBar != null { leftToolTabBar.SetVisible(false); }
        if bottomToolTabBar != null { bottomToolTabBar.SetVisible(false); }
        if rightToolTabBar != null { rightToolTabBar.SetVisible(false); }
        if floatingToolTabBar != null {
            floatingToolTabBar.SetVisible(false);
        }
        if panelRoot != null { panelRoot.SetVisible(false); }
        if leftToolGroupRoot != null {
            leftToolGroupRoot.SetVisible(false);
        }
        if bottomToolGroupRoot != null {
            bottomToolGroupRoot.SetVisible(false);
        }
        if rightToolGroupRoot != null {
            rightToolGroupRoot.SetVisible(false);
        }
        if floatingToolGroupRoot != null {
            floatingToolGroupRoot.SetVisible(false);
        }
        if floatingToolPanel != null {
            floatingToolPanel.SetVisible(false);
        }
        activeLeftToolPanelKind = tool_panel_model.PANEL_NONE;
        activeBottomToolPanelKind = tool_panel_model.PANEL_NONE;
        activeRightToolPanelKind = tool_panel_model.PANEL_NONE;
        activeFloatingToolPanelKind = tool_panel_model.PANEL_NONE;
        SetActiveToolPanelKind(tool_panel_model.PANEL_NONE);
        CollapseAllDockSplits();
    }

    /// @brief Return the durable stable ID of the visible tool panel.
    /// @return A built-in tab ID, or "none" while the dock is hidden.
    expose func GetActiveToolPanelId() -> String {
        return tool_panel_model.TabIdForPanelKind(activeToolPanelKind);
    }

    /// @brief Restore one durable panel selection without relying on tab order.
    /// @details Unknown/future IDs collapse safely instead of choosing a nearby
    ///          visual tab. Panel contents remain owned by their live controllers.
    expose func SetActiveToolPanelId(id: String) {
        var kind = tool_panel_model.PanelKindForTabId(id);
        if kind == tool_panel_model.PANEL_PROBLEMS {
            ShowProblemsPanel();
        } else if kind == tool_panel_model.PANEL_OUTPUT {
            ShowOutputPanel();
        } else if kind == tool_panel_model.PANEL_SEARCH {
            ShowSearchPanel();
        } else if kind == tool_panel_model.PANEL_REFERENCES {
            ShowReferencesPanel();
        } else if kind == tool_panel_model.PANEL_VARIABLES {
            ShowVariablesPanel();
        } else if kind == tool_panel_model.PANEL_CALL_STACK {
            ShowCallStackPanel();
        } else if kind == tool_panel_model.PANEL_DEBUG {
            ShowDebugPanel();
        } else if kind == tool_panel_model.PANEL_TERMINAL {
            ShowTerminalPanel();
        } else {
            HidePanelArea();
        }
    }

    /// @brief Show the Problems panel and select its tab.
    expose func ShowProblemsPanel() {
        var filterHadFocus =
            problemsFilterInput != null and problemsFilterInput.IsFocused();
        ApplyResponsiveProblemsToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_PROBLEMS, 0.0);
        if problemsPanel != null { problemsPanel.SetVisible(true); }
        diagListBox.SetVisible(true);
        if filterHadFocus { problemsFilterInput.Focus(); }
        UpdateProblemsToolbarState();
    }

    /// @brief Hide Problems and select a fallback panel if content remains.
    expose func HideProblemsPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_PROBLEMS);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_PROBLEMS;
        if problemsPanel != null { problemsPanel.SetVisible(false); }
        diagListBox.SetVisible(false);
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Show the Output panel and select its tab.
    expose func ShowOutputPanel() {
        var filterHadFocus =
            outputFilterInput != null and outputFilterInput.IsFocused();
        ApplyResponsiveOutputToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_OUTPUT, 0.0);
        if outputPanel != null { outputPanel.SetVisible(true); }
        if outputPaneMode {
            outputPane.SetVisible(true);
        } else {
            outputListBox.SetVisible(true);
        }
        if filterHadFocus { outputFilterInput.Focus(); }
        UpdateOutputToolbarState();
    }

    /// @brief Hide Output and select a fallback panel if content remains.
    expose func HideOutputPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_OUTPUT);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_OUTPUT;
        if outputPanel != null { outputPanel.SetVisible(false); }
        outputPane.SetVisible(false);
        outputListBox.SetVisible(false);
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Show the Search panel and select its tab.
    /// @details A queued TabBar change can replay this call one frame after an
    ///          explicit command focused an input. Preserve that ownership
    ///          across the temporary HideAllToolPanels visibility transition.
    expose func ShowSearchPanel() {
        var queryHadFocus =
            searchQueryInput != null and searchQueryInput.IsFocused();
        var replaceHadFocus =
            searchReplaceInput != null and searchReplaceInput.IsFocused();
        var kindsHadFocus =
            searchKindsInput != null and searchKindsInput.IsFocused();
        var includeHadFocus =
            searchIncludeInput != null and searchIncludeInput.IsFocused();
        var excludeHadFocus =
            searchExcludeInput != null and searchExcludeInput.IsFocused();
        ApplyResponsiveSearchControls();
        PrepareToolPanel(tool_panel_model.PANEL_SEARCH,
                         SearchPanelMinimumHeight());
        searchPanel.SetVisible(true);
        searchListBox.SetVisible(true);
        if queryHadFocus { searchQueryInput.Focus(); }
        else if replaceHadFocus { searchReplaceInput.Focus(); }
        else if kindsHadFocus { searchKindsInput.Focus(); }
        else if includeHadFocus { searchIncludeInput.Focus(); }
        else if excludeHadFocus { searchExcludeInput.Focus(); }
    }

    /// @brief Hide Search and select a fallback panel if content remains.
    expose func HideSearchPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_SEARCH);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_SEARCH;
        searchPanel.SetVisible(false);
        searchListBox.SetVisible(false);
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Show the References panel and select its tab.
    expose func ShowReferencesPanel() {
        var filterHadFocus =
            referencesFilterInput != null and referencesFilterInput.IsFocused();
        ApplyResponsiveReferencesToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_REFERENCES, 0.0);
        if referencesPanel != null { referencesPanel.SetVisible(true); }
        ApplyReferenceSurfaceVisibility();
        if filterHadFocus { referencesFilterInput.Focus(); }
        UpdateReferencesToolbarState();
    }

    /// @brief Hide References and select a fallback panel if content remains.
    expose func HideReferencesPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_REFERENCES);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_REFERENCES;
        if referencesPanel != null { referencesPanel.SetVisible(false); }
        referencesListBox.SetVisible(false);
        if referencesEmptyLabel != null {
            referencesEmptyLabel.SetVisible(false);
        }
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Show the Variables panel and select its tab.
    expose func ShowVariablesPanel() {
        var watchHadFocus =
            watchExpressionInput != null and watchExpressionInput.IsFocused();
        ApplyResponsiveWatchToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_VARIABLES, 0.0);
        if variablesPanel != null { variablesPanel.SetVisible(true); }
        variablesListBox.SetVisible(true);
        if watchHadFocus { watchExpressionInput.Focus(); }
    }

    /// @brief Show the Call Stack panel and select its tab.
    expose func ShowCallStackPanel() {
        var filterHadFocus =
            callStackFilterInput != null and callStackFilterInput.IsFocused();
        ApplyResponsiveCallStackToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_CALL_STACK, 0.0);
        if callStackPanel != null { callStackPanel.SetVisible(true); }
        ApplyCallStackSurfaceVisibility();
        if filterHadFocus { callStackFilterInput.Focus(); }
        UpdateCallStackToolbarState();
    }

    /// @brief Hide Call Stack and select a fallback panel if content remains.
    expose func HideCallStackPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_CALL_STACK);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_CALL_STACK;
        if callStackPanel != null { callStackPanel.SetVisible(false); }
        callStackListBox.SetVisible(false);
        if callStackEmptyLabel != null {
            callStackEmptyLabel.SetVisible(false);
        }
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Show the Debug Console panel and select its tab.
    expose func ShowDebugPanel() {
        var filterHadFocus =
            debugFilterInput != null and debugFilterInput.IsFocused();
        ApplyResponsiveDebugToolbar();
        PrepareToolPanel(tool_panel_model.PANEL_DEBUG, 0.0);
        if debugPanel != null { debugPanel.SetVisible(true); }
        ApplyDebugConsoleSurfaceVisibility();
        if filterHadFocus { debugFilterInput.Focus(); }
        UpdateDebugToolbarState();
    }

    /// @brief Show the Terminal panel and focus its pane.
    expose func ShowTerminalPanel() {
        ApplyResponsiveTerminalActions();
        PrepareToolPanel(tool_panel_model.PANEL_TERMINAL, 0.0);
        terminalPanel.SetVisible(true);
        if terminalPane != null { terminalPane.Focus(); }
    }

    /// @brief Hide Terminal without destroying its session.
    expose func HideTerminalPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_TERMINAL);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_TERMINAL;
        terminalPanel.SetVisible(false);
        if wasSelected { ShowFallbackToolPanelWithoutTerminal(); }
    }

    /// @brief Toggle terminal panel visibility.
    expose func ToggleTerminalPanel() {
        if terminalPanel != null and terminalPanel.IsVisible() {
            HideTerminalPanel();
        } else {
            ShowTerminalPanel();
        }
    }

    /// @brief Return true when the terminal panel is visible.
    expose func IsTerminalPanelVisible() -> Boolean {
        return terminalPanel != null and terminalPanel.IsVisible();
    }

    /// @brief Read the inline debugger watch expression exactly as authored.
    expose func GetWatchExpressionText() -> String {
        if watchExpressionInput == null { return ""; }
        return watchExpressionInput.get_Text();
    }

    /// @brief Seed the inline watch field without changing panel selection.
    expose func SetWatchExpressionText(text: String) {
        if watchExpressionInput != null {
            watchExpressionInput.SetText(text);
        }
    }

    /// @brief Clear the inline watch field after a successful add.
    expose func ClearWatchExpression() {
        SetWatchExpressionText("");
    }

    /// @brief Give an explicit Add Watch command keyboard ownership.
    expose func FocusWatchExpression() {
        if variablesPanel != null and variablesPanel.IsVisible()
           and watchExpressionInput != null {
            watchExpressionInput.Focus();
        }
    }

    /// @brief Return whether watch text entry owns keyboard input.
    expose func IsWatchExpressionFocused() -> Boolean {
        return watchExpressionInput != null
            and watchExpressionInput.IsFocused()
            and variablesPanel != null
            and variablesPanel.IsVisible();
    }

    /// @brief Consume an Add click or Enter from the inline watch field.
    expose func WatchAddWasRequested() -> Boolean {
        if watchAddButton != null and watchAddButton.WasClicked() {
            return true;
        }
        return IsWatchExpressionFocused()
            and Str.Trim(GetWatchExpressionText()) != ""
            and Input.Keyboard.WasPressed(Zanna.Input.Key.Enter);
    }

    /// @brief Consume the selected-watch removal action.
    expose func WatchRemoveWasRequested() -> Boolean {
        return watchRemoveButton != null and watchRemoveButton.WasClicked();
    }

    /// @brief Consume the manual watch-refresh action.
    expose func WatchRefreshWasRequested() -> Boolean {
        return watchRefreshButton != null and watchRefreshButton.WasClicked();
    }

    /// @brief Consume the clear-all-watches action.
    expose func WatchClearWasRequested() -> Boolean {
        return watchClearButton != null and watchClearButton.WasClicked();
    }

    /// @brief Synchronize watch action availability with live debugger state.
    /// @param sessionAvailable True when a DebugSession owns the watch list.
    /// @param selectedWatch True when the selected Variables row is a watch.
    /// @param stopped True while watch expressions can be evaluated.
    /// @param watchCount Current number of persistent watch expressions.
    expose func SetWatchToolbarState(sessionAvailable: Boolean,
                                     selectedWatch: Boolean,
                                     stopped: Boolean,
                                     watchCount: Integer) {
        if watchAddButton == null { return; }
        watchAddButton.SetEnabled(
            sessionAvailable
            and Str.Trim(GetWatchExpressionText()) != "");
        watchRemoveButton.SetEnabled(sessionAvailable and selectedWatch);
        watchRefreshButton.SetEnabled(
            sessionAvailable and stopped and watchCount > 0);
        watchClearButton.SetEnabled(sessionAvailable and watchCount > 0);
    }

    /// @brief Return whether a text field in the Search panel owns keyboard input.
    /// @details Global Enter/Escape state must not run or cancel a workspace
    ///          search while the user is typing in Terminal, the editor, or an
    ///          unrelated overlay merely because the Search panel is visible.
    expose func IsSearchInputFocused() -> Boolean {
        return (searchQueryInput != null and searchQueryInput.IsFocused())
            or (searchReplaceInput != null and searchReplaceInput.IsFocused())
            or (searchKindsInput != null and searchKindsInput.IsFocused())
            or (searchIncludeInput != null and searchIncludeInput.IsFocused())
            or (searchExcludeInput != null and searchExcludeInput.IsFocused());
    }

    /// @brief Return whether Enter should run the current text-search request.
    /// @details The replacement field deliberately does not qualify: pressing
    ///          Enter while authoring replacement text must never rerun search
    ///          or imply the destructive Replace All action.
    expose func IsSearchRunInputFocused() -> Boolean {
        return (searchQueryInput != null and searchQueryInput.IsFocused())
            or (searchKindsInput != null and searchKindsInput.IsFocused())
            or (searchIncludeInput != null and searchIncludeInput.IsFocused())
            or (searchExcludeInput != null and searchExcludeInput.IsFocused());
    }

    /// @brief Give an explicitly opened Search workflow keyboard ownership.
    /// @details ShowSearchPanel intentionally does not focus: background search
    ///          completion may reveal results without stealing editor/terminal
    ///          input. Command entry points call this after revealing the panel.
    expose func FocusSearchQuery() {
        if searchPanel != null and searchPanel.IsVisible()
           and searchQueryInput != null {
            searchQueryInput.Focus();
        }
    }

    /// @brief Return whether Search currently owns the visible tool dock.
    /// @details Background search completion uses this to avoid stealing the
    ///          dock or raising routine result toasts after the user moved on.
    expose func IsSearchPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_SEARCH)
            and searchPanel != null and searchPanel.IsVisible();
    }

    /// @brief Return whether Output currently owns the visible tool dock.
    expose func IsOutputPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_OUTPUT)
            and ((outputPanel != null and outputPanel.IsVisible())
                 or (outputPanel == null
                     and ((outputPane != null and outputPane.IsVisible())
                          or (outputListBox != null
                              and outputListBox.IsVisible()))));
    }

    /// @brief Return whether Problems currently owns the visible tool dock.
    expose func IsProblemsPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_PROBLEMS)
            and ((problemsPanel != null and problemsPanel.IsVisible())
                 or (problemsPanel == null and diagListBox != null
                     and diagListBox.IsVisible()));
    }

    /// @brief Return whether References currently owns the visible tool dock.
    expose func IsReferencesPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_REFERENCES)
            and referencesPanel != null and referencesPanel.IsVisible();
    }

    /// @brief Return whether Debug Console currently owns the visible tool dock.
    expose func IsDebugPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_DEBUG)
            and debugPanel != null and debugPanel.IsVisible();
    }

    /// @brief Return whether Call Stack currently owns the visible tool dock.
    expose func IsCallStackPanelActive() -> Boolean {
        return IsToolPanelSelected(tool_panel_model.PANEL_CALL_STACK)
            and callStackPanel != null and callStackPanel.IsVisible();
    }

    /// @brief Return the monotonic tool-panel selection revision.
    expose func GetPanelSelectionRevision() -> Integer {
        return panelSelectionRevision;
    }

    /// @brief Publish one actual panel selection transition.
    hide func SetActiveToolPanelKind(kind: Integer) {
        if activeToolPanelKind != kind {
            activeToolPanelKind = kind;
            panelSelectionRevision = panelSelectionRevision + 1;
        }
    }

    /// @brief Hide Debug Console and select a fallback panel if content remains.
    expose func HideDebugPanel() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_DEBUG);
        var wasSelected =
            ActiveToolPanelKindAt(location)
                == tool_panel_model.PANEL_DEBUG;
        if debugPanel != null { debugPanel.SetVisible(false); }
        debugListBox.SetVisible(false);
        if debugEmptyLabel != null { debugEmptyLabel.SetVisible(false); }
        if wasSelected { ShowFallbackToolPanelAt(location); }
    }

    /// @brief Select useful retained content without crossing dock groups.
    hide func ShowFallbackToolPanelAt(location: Integer) {
        if toolPanelGroups.LocationForId(tool_panel_model.TAB_ID_OUTPUT)
               == location
           and HasOutputContent() {
            ShowOutputPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_PROBLEMS) == location
                  and HasActiveProblemsContent() {
            ShowProblemsPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_SEARCH) == location
                  and searchListBox.Count > 0 {
            ShowSearchPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_REFERENCES) == location
                  and HasReferenceResults() {
            ShowReferencesPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_VARIABLES) == location
                  and variablesListBox.Count > 0 {
            ShowVariablesPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_CALL_STACK) == location
                  and HasCallStackFrames() {
            ShowCallStackPanel();
        } else if toolPanelGroups.LocationForId(
                      tool_panel_model.TAB_ID_DEBUG) == location
                  and debugConsoleSource != "" {
            ShowDebugPanel();
        } else {
            HideToolGroupAt(location);
        }
    }

    /// @brief Select fallback panel after hiding Terminal.
    hide func ShowFallbackToolPanelWithoutTerminal() {
        var location = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_TERMINAL);
        ShowFallbackToolPanelAt(location);
    }

    /// @brief Return whether Problems should claim fallback space.
    /// @return True when active diagnostics are present.
    hide func HasActiveProblemsContent() -> Boolean {
        return problemsHaveDiagnostics and problemRecords.count() > 0;
    }

    /// @brief Poll bottom tool tabs and show the selected panel.
    expose func PumpToolTabs() {
        if toolTabBar == null { return; }
        ApplyResponsiveDockHeader();
        PumpDockControls();
        ApplyResponsiveProblemsToolbar();
        ApplyResponsiveOutputToolbar();
        ApplyResponsiveReferencesToolbar();
        ApplyResponsiveDebugToolbar();
        ApplyResponsiveCallStackToolbar();
        ApplyResponsiveSearchControls();
        ApplyResponsiveTerminalActions();
        ApplyResponsiveWatchToolbar();
        PumpProblemsToolbar();
        PumpOutputToolbar();
        PumpReferencesToolbar();
        PumpDebugConsoleToolbar();
        PumpCallStackToolbar();
        CaptureSplitDrag(); // every frame: keep a live splitter drag remembered
        ApplyResponsiveToolTabLabels();
        var reordered = false;
        var leftBar = ToolTabBarAt(workspace_dock.DOCK_LEFT);
        var bottomBar = ToolTabBarAt(workspace_dock.DOCK_BOTTOM);
        var rightBar = ToolTabBarAt(workspace_dock.DOCK_RIGHT);
        var floatingBar = ToolTabBarAt(workspace_dock.DOCK_FLOATING);
        if leftBar != null and leftBar.WasReordered() {
            reordered = true;
        }
        if bottomBar != null and bottomBar.WasReordered() {
            reordered = true;
        }
        if rightBar != null and rightBar.WasReordered() {
            reordered = true;
        }
        if floatingBar != null and floatingBar.WasReordered() {
            reordered = true;
        }
        if reordered { CaptureToolTabOrder(); }

        var searchLocation = toolPanelGroups.LocationForId(
            tool_panel_model.TAB_ID_SEARCH);
        if ActiveToolPanelKindAt(searchLocation)
               == tool_panel_model.PANEL_SEARCH {
            // Recompute after a window resize; the configured fraction remains
            // untouched and is restored automatically on a roomier viewport.
            ExpandToolDockAt(searchLocation, SearchPanelMinimumHeight());
        }

        PumpToolTabSelectionAt(workspace_dock.DOCK_LEFT);
        PumpToolTabSelectionAt(workspace_dock.DOCK_BOTTOM);
        PumpToolTabSelectionAt(workspace_dock.DOCK_RIGHT);
        PumpToolTabSelectionAt(workspace_dock.DOCK_FLOATING);
    }

    /// @brief Consume one group's tab selection and route by stable ID.
    hide func PumpToolTabSelectionAt(location: Integer) {
        var bar = ToolTabBarAt(location);
        if bar == null or !bar.WasChanged() { return; }
        var idx = bar.GetActiveIndex();
        if idx < 0 or idx >= bar.TabCount { return; }
        var activeTab: GUI.Tab = bar.GetTabAt(idx);
        if activeTab == null { return; }
        var panelKind =
            tool_panel_model.PanelKindForTabId(activeTab.GetStableId());
        if panelKind != tool_panel_model.PANEL_NONE {
            ShowToolPanelKind(panelKind);
            return;
        }
        ShowFallbackToolPanelAt(location);
    }
}
