        tbOpen = toolbar.AddNamedButton("open-folder", "Open File (Ctrl+O)");
        tbSave = toolbar.AddNamedButton("save", "Save File (Ctrl+S)");
        tbSaveAll = toolbar.AddNamedButton("save-all", "Save All Files (Ctrl+Alt+Shift+S)");
        toolbar.AddSeparator();
        tbBuild = toolbar.AddNamedButton("build", "Build (Ctrl+Shift+B)");
        tbRun = toolbar.AddNamedButton("run", "Build & Run (F5)");
        tbStop = toolbar.AddNamedButton("stop", "Stop Running Job (Shift+F5)");
        tbDebug = toolbar.AddNamedButton("debug", "Start Debugging (F6)");
        tbDebugContinue = toolbar.AddNamedButton("continue", "Continue Debugging (F7)");
        tbDebugStep = toolbar.AddNamedButton("step-over", "Step Over (F10)");
        toolbar.AddSeparator();
        tbFind = toolbar.AddNamedButton("find", "Find (Ctrl+F)");
    }

