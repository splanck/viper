    /// @brief Apply command-catalog shortcuts to visible menu/context items.
    /// @param registry Runtime command registry populated from command_catalog.
    expose func ApplyCommandShortcuts(registry: command_registry.CommandRegistry) {
        if registry == null { return; }
        appliedShortcutRegistry = registry;
        ApplyShortcut(miNew, "new", registry);
        ApplyShortcut(miNewScene2D, "newscene2d", registry);
        ApplyShortcut(miNewScene3D, "newscene3d", registry);
        ApplyShortcut(miOpen, "open", registry);
        ApplyShortcut(miOpenFolder, "openfolder", registry);
        ApplyShortcut(miAddFolder, "addfolder", registry);
        ApplyShortcut(miRemoveFolder, "removefolder", registry);
        ApplyShortcut(miCloseWorkspace, "closeworkspace", registry);
        ApplyShortcut(miQuickOpen, "quickopen", registry);
        ApplyShortcut(miSave, "save", registry);
        ApplyShortcut(miSaveAs, "saveas", registry);
        ApplyShortcut(miSaveAll, "saveall", registry);
        ApplyShortcut(miClose, "close", registry);
        ApplyShortcut(miReload, "reload", registry);
        ApplyShortcut(miRecentFiles, "recentfiles", registry);
        ApplyShortcut(miReopenClosed, "reopenclosed", registry);
        ApplyShortcut(miUndo, "undo", registry);
        ApplyShortcut(miRedo, "redo", registry);
        ApplyShortcut(miCut, "cut", registry);
        ApplyShortcut(miCopy, "copy", registry);
        ApplyShortcut(miPaste, "paste", registry);
        ApplyShortcut(miSelectAll, "selectall", registry);
        ApplyShortcut(miDuplicateSelection, "duplicateline", registry);
        ApplyShortcut(
            miDeleteSceneSelection, "deletesceneselection", registry);
        ApplyShortcut(miFind, "find", registry);
        ApplyShortcut(miSearchProject, "searchproject", registry);
        ApplyShortcut(miGoToLine, "goto", registry);
        ApplyShortcut(miRenameSymbol, "rename", registry);
        ApplyShortcut(miPreferences, "settings", registry);
        ApplyShortcut(miGoToDefinition, "gotodef", registry);
        ApplyShortcut(miFindReferences, "findrefs", registry);
        ApplyShortcut(miIncomingCalls, "incomingcalls", registry);
        ApplyShortcut(miOutgoingCalls, "outgoingcalls", registry);
        ApplyShortcut(miWorkspaceSymbols, "workspacesymbols", registry);
        ApplyShortcut(miSymbolOutline, "symboloutline", registry);
        ApplyShortcut(miNextError, "nexterror", registry);
        ApplyShortcut(miPreviousError, "preverror", registry);
        ApplyShortcut(miSignatureHelp, "signature_trigger", registry);
        ApplyShortcut(miToggleSidebar, "togglesidebar", registry);
        ApplyShortcut(miToggleStatusBar, "statusbar", registry);
        ApplyShortcut(miResetWorkspaceLayout, "resetworkspacelayout", registry);
        ApplyShortcut(miZoomIn, "zoomin", registry);
        ApplyShortcut(miZoomOut, "zoomout", registry);
        ApplyShortcut(miZoomReset, "zoomreset", registry);
        ApplyShortcut(miUiZoomIn, "uizoomin", registry);
        ApplyShortcut(miUiZoomOut, "uizoomout", registry);
        ApplyShortcut(miUiZoomReset, "uizoomreset", registry);
        ApplyShortcut(miToggleTheme, "toggletheme", registry);
        ApplyShortcut(miFullscreen, "fullscreen", registry);
        ApplyShortcut(miToggleMinimap, "minimap", registry);
        ApplyShortcut(miTerminal, "terminal", registry);
        ApplyShortcut(miBuild, "build", registry);
        ApplyShortcut(miBuildAndRun, "buildrun", registry);
        ApplyShortcut(miRun, "run", registry);
        ApplyShortcut(miStop, "stopjob", registry);
        ApplyShortcut(miDebugStart, "debugstart", registry);
        ApplyShortcut(miDebugContinue, "debugcontinue", registry);
        ApplyShortcut(miDebugStepOver, "debugstepover", registry);
        ApplyShortcut(miDebugStepIn, "debugstepin", registry);
        ApplyShortcut(miDebugStepOut, "debugstepout", registry);
        ApplyShortcut(miDebugRestart, "debugrestart", registry);
        ApplyShortcut(miToggleBreakpoint, "togglebreakpoint", registry);
        ApplyShortcut(miKeyboardShortcuts, "keybindings", registry);
        ApplyShortcut(ctxRename, "treerename", registry);
        ApplyShortcut(ctxDelete, "treedelete", registry);
        ApplyShortcut(ctxNewFile, "treenewfile", registry);
        ApplyShortcut(ctxNewFolder, "treenewfolder", registry);
        ApplyShortcut(ctxRefresh, "treerefresh", registry);
        ApplyShortcut(ecCut, "cut", registry);
        ApplyShortcut(ecCopy, "copy", registry);
        ApplyShortcut(ecPaste, "paste", registry);
        ApplyShortcut(ecGotoDef, "gotodef", registry);
        ApplyShortcut(ecFindRefs, "findrefs", registry);
        ApplyShortcut(ecRename, "rename", registry);
        ApplyShortcut(ecFormat, "formatdocument", registry);
        ApplyShortcut(ecToggleBreakpoint, "togglebreakpoint", registry);
        ApplyShortcut(ecPalette, "palette", registry);

        // Shortcut edits happen while the command context is otherwise
        // unchanged. Force one state refresh so toolbar hover text switches to
        // the same binding immediately instead of retaining a stale default.
        if commandContextInitialized {
            commandContextInitialized = false;
            SetCommandContextAvailable(documentContextAvailable,
                                       projectContextAvailable,
                                       buildTargetAvailable,
                                       debugTargetAvailable);
        }
    }

    /// @brief Apply one command shortcut to one menu item.
    /// @param item Menu or context-menu item that displays a shortcut label.
    /// @param commandId Command id in CommandRegistry.
    /// @param registry Runtime command registry to query.
    hide func ApplyShortcut(item: GUI.MenuItem,
                            commandId: String,
                            registry: command_registry.CommandRegistry) {
        if item == null or registry == null { return; }
        var shortcut = registry.ShortcutFor(commandId);
        item.SetShortcut(shortcut);
    }

    /// @brief Apply whether document and build commands have valid targets.
    /// @param hasDocument True when at least one editor document is open.
    /// @param hasProject True when a workspace root is open.
    /// @param hasBuildTarget True when a project or document can be built.
    /// @param hasDebugTarget True when a saved document can be debugged.
    expose func SetCommandContextAvailable(hasDocument: Boolean,
                                           hasProject: Boolean,
                                           hasBuildTarget: Boolean,
                                           hasDebugTarget: Boolean) {
        if commandContextInitialized
           and documentContextAvailable == hasDocument
           and projectContextAvailable == hasProject
           and buildTargetAvailable == hasBuildTarget
           and debugTargetAvailable == hasDebugTarget {
            return;
        }
        commandContextInitialized = true;
        documentContextAvailable = hasDocument;
        projectContextAvailable = hasProject;
        buildTargetAvailable = hasBuildTarget;
        debugTargetAvailable = hasDebugTarget;

        SetMenuEnabled(miSave, hasDocument);
        SetMenuEnabled(miSaveAs, hasDocument);
        SetMenuEnabled(miSaveAll, hasDocument);
        SetMenuEnabled(miClose, hasDocument);
        SetMenuEnabled(miReload, hasDocument);
        SetMenuEnabled(miUndo, hasDocument);
        SetMenuEnabled(miRedo, hasDocument);
        SetMenuEnabled(miCut, hasDocument);
        SetMenuEnabled(miCopy, hasDocument);
        SetMenuEnabled(miPaste, hasDocument);
        SetMenuEnabled(miSelectAll, hasDocument);
        SetMenuEnabled(miDuplicateSelection, hasDocument);
        SetMenuEnabled(miDeleteSceneSelection, false);
        SetMenuEnabled(miFind, hasDocument);
        SetMenuEnabled(miGoToLine, hasDocument);
        SetMenuEnabled(miToggleMinimap, hasDocument);
        SetMenuEnabled(miToggleBreakpoint, hasDocument);
        SetMenuEnabled(miRemoveFolder, hasProject);
        SetMenuEnabled(miCloseWorkspace, hasProject);
        SetMenuEnabled(miQuickOpen, hasProject);
        SetMenuEnabled(miSearchProject, hasProject);
        SetMenuEnabled(miWorkspaceSymbols,
                       hasProject and languageSymbolsAvailable);

        SetMenuEnabled(ecCut, hasDocument);
        SetMenuEnabled(ecCopy, hasDocument);
        SetMenuEnabled(ecPaste, hasDocument);
        SetMenuEnabled(ecFormat, hasDocument);
        SetMenuEnabled(ecToggleBreakpoint, hasDocument);
        SetMenuEnabled(ecEvaluate, hasDocument);

        SetToolbarItemState(tbSave, hasDocument,
                            CommandTooltip("Save File", "save", "Ctrl+S"),
                            "Open a document to save");
        SetToolbarItemState(tbSaveAll, hasDocument,
                            CommandTooltip("Save All Files", "saveall", "Ctrl+Alt+Shift+S"),
                            "Open a document to save");
        SetToolbarItemState(tbFind, hasDocument,
                            CommandTooltip("Find", "find", "Ctrl+F"),
                            "Open a document to find text");

        if hasDocument == false {
            SetMenuEnabled(miGoToDefinition, false);
            SetMenuEnabled(miFindReferences, false);
            SetMenuEnabled(miIncomingCalls, false);
            SetMenuEnabled(miOutgoingCalls, false);
            SetMenuEnabled(miRenameSymbol, false);
            SetMenuEnabled(miSymbolOutline, false);
            SetMenuEnabled(miSignatureHelp, false);
            SetMenuEnabled(ecGotoDef, false);
            SetMenuEnabled(ecFindRefs, false);
            SetMenuEnabled(ecRename, false);
        }

        ApplyExecutionCommandState();
    }

    /// @brief Grey code-editor actions while a visual scene surface is active.
    /// @details This is applied after language capability state each frame so a
    ///          stale Zia/Basic service cannot re-enable commands that would
    ///          otherwise mutate the hidden CodeEditor buffer.
    expose func SetTextEditorContextAvailable(available: Boolean) {
        SetMenuEnabled(miCut, available);
        SetMenuEnabled(miCopy, available);
        SetMenuEnabled(miPaste, available);
        SetMenuEnabled(miSelectAll, available);
        SetMenuEnabled(miDuplicateSelection, available);
        SetMenuEnabled(miDeleteSceneSelection, false);
        SetMenuEnabled(miFind, available);
        SetMenuEnabled(miGoToLine, available);
        SetMenuEnabled(miGoToDefinition, available);
        SetMenuEnabled(miFindReferences, available);
        SetMenuEnabled(miIncomingCalls, available);
        SetMenuEnabled(miOutgoingCalls, available);
        SetMenuEnabled(miRenameSymbol, available);
        SetMenuEnabled(miSymbolOutline, available);
        SetMenuEnabled(miSignatureHelp, available);
        SetMenuEnabled(miZoomIn, available);
        SetMenuEnabled(miZoomOut, available);
        SetMenuEnabled(miZoomReset, available);
        SetMenuEnabled(miToggleMinimap, available);
        SetMenuEnabled(miToggleBreakpoint, available);
        SetMenuEnabled(ecCut, available);
        SetMenuEnabled(ecCopy, available);
        SetMenuEnabled(ecPaste, available);
        SetMenuEnabled(ecGotoDef, available);
        SetMenuEnabled(ecFindRefs, available);
        SetMenuEnabled(ecRename, available);
        SetMenuEnabled(ecFormat, available);
        SetMenuEnabled(ecToggleBreakpoint, available);
        SetMenuEnabled(ecEvaluate, available);
        if tbFind != null {
            SetToolbarItemState(
                tbFind, available,
                CommandTooltip("Find", "find", "Ctrl+F"),
                "Find is available in source and text editors");
        }
    }

    /// @brief Reflect standard edit actions owned by the active surface.
    /// @details Main applies this after the code-editor gate so a 2D/3D scene
    ///          may expose only actions with a live selection or clipboard
    ///          candidate while all source-only commands remain disabled.
    expose func SetSurfaceEditActionsAvailable(canCut: Boolean,
                                               canCopy: Boolean,
                                               canPaste: Boolean,
                                               canSelectAll: Boolean,
                                               canDuplicate: Boolean,
                                               canDeleteScene: Boolean) {
        SetMenuEnabled(miCut, canCut);
        SetMenuEnabled(miCopy, canCopy);
        SetMenuEnabled(miPaste, canPaste);
        SetMenuEnabled(miSelectAll, canSelectAll);
        SetMenuEnabled(miDuplicateSelection, canDuplicate);
        SetMenuEnabled(miDeleteSceneSelection, canDeleteScene);
        SetMenuEnabled(ecCut, canCut);
        SetMenuEnabled(ecCopy, canCopy);
        SetMenuEnabled(ecPaste, canPaste);
    }

    /// @brief Reflect undo/redo history owned by the active editor surface.
    expose func SetEditHistoryAvailable(canUndo: Boolean,
                                        canRedo: Boolean) {
        SetMenuEnabled(miUndo, canUndo);
        SetMenuEnabled(miRedo, canRedo);
    }

    /// @brief Apply build/run job state to toolbar and menu controls.
    /// @param active True while a build/run job is active.
    /// @param name Human-readable job name.
    expose func SetBuildJobActive(active: Boolean, name: String) {
        if executionStateInitialized and jobActiveState == active
           and activeJobName == name {
            return;
        }
        jobActiveState = active;
        activeJobName = name;
        executionStateInitialized = true;
        ApplyExecutionCommandState();
    }

    /// @brief Apply running/paused debug-session state to visible controls.
    /// @param active True while a debug adapter session exists.
    /// @param stopped True while the debuggee is paused at a stop location.
    /// @param buildJobActive True while the build/run process controller is busy.
    expose func SetDebugSessionState(active: Boolean,
                                     stopped: Boolean,
                                     buildJobActive: Boolean) {
        if executionStateInitialized and debugSessionActive == active
           and debugSessionStopped == stopped
           and jobActiveState == buildJobActive {
            return;
        }
        debugSessionActive = active;
        debugSessionStopped = stopped;
        jobActiveState = buildJobActive;
        executionStateInitialized = true;
        ApplyExecutionCommandState();
    }

    /// @brief Reconcile target, build-job, and debugger state in one place.
    hide func ApplyExecutionCommandState() {
        executionStateApplyCount = executionStateApplyCount + 1;
        SetMenuEnabled(miRemoveFolder,
                       projectContextAvailable and jobActiveState == false
                       and debugSessionActive == false);
        SetMenuEnabled(miCloseWorkspace,
                       projectContextAvailable and jobActiveState == false
                       and debugSessionActive == false);
        var buildEnabled = buildTargetAvailable;
        if jobActiveState or debugSessionActive { buildEnabled = false; }

        var startEnabled = debugTargetAvailable;
        if debugSessionActive or jobActiveState { startEnabled = false; }
        var pausedEnabled = false;
        if debugSessionActive and debugSessionStopped { pausedEnabled = true; }
        var runningEnabled = false;
        if debugSessionActive and debugSessionStopped == false { runningEnabled = true; }
        var activeEnabled = false;
        if debugSessionActive { activeEnabled = true; }

        var buildDisabled = "Open a project or document to build";
        var runDisabled = "Open a project or document to run";
        if jobActiveState {
            var jobName = status_bar_model.JobDisplayName(activeJobName);
            buildDisabled = "Build disabled while " + jobName + " is running";
            runDisabled = "Run disabled while " + jobName + " is running";
        } else if debugSessionActive {
            buildDisabled = "Build disabled while debugging";
            runDisabled = "Run disabled while debugging";
        }
        SetToolbarItemState(tbBuild, buildEnabled,
                            CommandTooltip("Build", "build", "Ctrl+Shift+B"), buildDisabled);
        SetToolbarItemState(tbRun, buildEnabled,
                            CommandTooltip("Build & Run", "buildrun", "F5"), runDisabled);
        SetMenuEnabled(miBuild, buildEnabled);
        SetMenuEnabled(miBuildAndRun, buildEnabled);
        SetMenuEnabled(miRun, buildEnabled);

        var startDisabled = "Open or save a document to debug";
        if jobActiveState { startDisabled = "Debug disabled while another job is running"; }
        if debugSessionActive { startDisabled = "Debug session already running"; }
        SetToolbarItemState(tbDebug, startEnabled,
                            CommandTooltip("Start Debugging", "debugstart", "F6"), startDisabled);
        SetToolbarItemState(tbDebugContinue, pausedEnabled,
                            CommandTooltip("Continue Debugging", "debugcontinue", "F7"),
                            "Continue is available while paused at a breakpoint");
        SetToolbarItemState(tbDebugStep, pausedEnabled,
                            CommandTooltip("Step Over", "debugstepover", "F10"),
                            "Step is available while paused at a breakpoint");

        SetMenuEnabled(miDebugStart, startEnabled);
        SetMenuEnabled(miDebugContinue, pausedEnabled);
        SetMenuEnabled(miDebugStepOver, pausedEnabled);
        SetMenuEnabled(miDebugStepIn, pausedEnabled);
        SetMenuEnabled(miDebugStepOut, pausedEnabled);
        SetMenuEnabled(miDebugPause, runningEnabled);
        SetMenuEnabled(miDebugRestart, activeEnabled);
        SetMenuEnabled(miDebugStop, activeEnabled);

        if tbStop != null {
            tbStop.SetEnabled(jobActiveState);
            if jobActiveState {
                tbStop.SetTooltip("Stop " + status_bar_model.JobDisplayName(activeJobName)
                                  + ShortcutSuffix("stopjob", "Shift+F5"));
            } else {
                tbStop.SetTooltip("No running job");
            }
        }
        SetMenuEnabled(miStop, jobActiveState);
    }

    /// @brief Apply active-language capability state to semantic menu actions.
    /// @param service Capability record selected for the active document.
    expose func ApplyLanguageCommandState(service: language_service.LanguageService) {
        var canDefinition = false;
        var canReferences = false;
        var canRename = false;
        var canSymbols = false;
        var canSignature = false;
        if service != null and documentContextAvailable {
            canDefinition = service.canGoToDefinition;
            canReferences = service.canFindReferences;
            canRename = service.canRename;
            canSymbols = service.canDocumentSymbols;
            canSignature = service.canSignatureHelp;
        }
        languageSymbolsAvailable = canSymbols;
        SetMenuEnabled(miGoToDefinition, canDefinition);
        SetMenuEnabled(miFindReferences, canReferences);
        SetMenuEnabled(miIncomingCalls, canReferences);
        SetMenuEnabled(miOutgoingCalls, canDefinition);
        SetMenuEnabled(miRenameSymbol, canRename);
        SetMenuEnabled(miWorkspaceSymbols, canSymbols and projectContextAvailable);
        SetMenuEnabled(miSymbolOutline, canSymbols);
        SetMenuEnabled(miSignatureHelp, canSignature);
        SetMenuEnabled(ecGotoDef, canDefinition);
        SetMenuEnabled(ecFindRefs, canReferences);
        SetMenuEnabled(ecRename, canRename);
    }

    /// @brief Enable or disable one menu item when the handle exists.
    /// @param item Menu item handle that may be null during partial setup.
    /// @param enabled True to enable, false to grey the item out.
    expose func SetMenuEnabled(item: GUI.MenuItem, enabled: Boolean) {
        if item == null { return; }
        item.SetEnabled(enabled);
    }

    /// @brief Format one active command shortcut for toolbar hover text.
    hide func CommandTooltip(label: String,
                             commandId: String,
                             canonicalDefault: String) -> String {
        var shortcut = command_catalog.PlatformShortcut(canonicalDefault);
        if appliedShortcutRegistry != null {
            shortcut = appliedShortcutRegistry.ShortcutFor(commandId);
        }
        if shortcut == "" { return label; }
        return label + " (" + shortcut + ")";
    }

    /// @brief Return a parenthesized shortcut suffix, or empty when unbound.
    hide func ShortcutSuffix(commandId: String, canonicalDefault: String) -> String {
        var shortcut = command_catalog.PlatformShortcut(canonicalDefault);
        if appliedShortcutRegistry != null {
            shortcut = appliedShortcutRegistry.ShortcutFor(commandId);
        }
        if shortcut == "" { return ""; }
        return " (" + shortcut + ")";
    }

    /// @brief Apply enabled state and matching hover text to one toolbar item.
    /// @param item Toolbar item handle; null is ignored during partial setup.
    /// @param enabled Runtime GUI enabled flag.
    /// @param enabledTooltip Tooltip used when the item can be activated.
    /// @param disabledTooltip Tooltip used when the item is disabled.
    hide func SetToolbarItemState(item: GUI.ToolbarItem,
                                  enabled: Boolean,
                                  enabledTooltip: String,
                                  disabledTooltip: String) {
        if item == null { return; }
        item.SetEnabled(enabled);
        if enabled {
            item.SetTooltip(enabledTooltip);
        } else {
            item.SetTooltip(disabledTooltip);
        }
    }
}
