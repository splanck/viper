    /// @brief Apply one command shortcut to one menu item.
    /// @param item Menu or context-menu item that displays a shortcut label.
    /// @param commandId Command id in CommandRegistry.
    /// @param registry Runtime command registry to query.
    hide func ApplyShortcut(item: GUI.MenuItem,
                            commandId: String,
                            registry: command_registry.CommandRegistry) {
        if item == null or registry == null { return; }
        var shortcut = registry.ShortcutFor(commandId);
        if shortcut == "" { return; }
        item.SetShortcut(shortcut);
    }

    /// @brief Apply build/run job state to toolbar and menu controls.
    /// @param active True while a build/run job is active.
    /// @param name Human-readable job name.
    expose func SetBuildJobActive(active: Boolean, name: String) {
        var enabled = true;
        var stopEnabled = false;
        var jobName = status_bar_model.JobDisplayName(name);
        if active {
            enabled = false;
            stopEnabled = true;
        }
        SetToolbarItemState(tbBuild, enabled,
                            "Build (Ctrl+Shift+B)",
                            "Build disabled while " + jobName + " is running");
        SetToolbarItemState(tbRun, enabled,
                            "Build & Run (F5)",
                            "Run disabled while " + jobName + " is running");
        SetToolbarItemState(tbDebug, enabled,
                            "Start Debugging (F6)",
                            "Debug disabled while " + jobName + " is running");
        if tbStop != null {
            tbStop.SetEnabled(stopEnabled);
            if active {
                tbStop.SetTooltip("Stop " + jobName + " (Shift+F5)");
            } else {
                tbStop.SetTooltip("No running job");
            }
        }
        SetMenuEnabled(miBuild, enabled);
        SetMenuEnabled(miBuildAndRun, enabled);
        SetMenuEnabled(miRun, enabled);
        SetMenuEnabled(miDebugStart, enabled);
        SetMenuEnabled(miStop, stopEnabled);
    }

    /// @brief Apply running/paused debug-session state to visible controls.
    /// @param active True while a debug adapter session exists.
    /// @param stopped True while the debuggee is paused at a stop location.
    /// @param buildJobActive True while the build/run process controller is busy.
    expose func SetDebugSessionState(active: Boolean,
                                     stopped: Boolean,
                                     buildJobActive: Boolean) {
        var startEnabled = true;
        if active or buildJobActive { startEnabled = false; }
        var pausedEnabled = false;
        if active and stopped { pausedEnabled = true; }
        var runningEnabled = false;
        if active and stopped == false { runningEnabled = true; }
        var activeEnabled = false;
        if active { activeEnabled = true; }

        if active {
            SetToolbarItemState(tbBuild, false,
                                "Build (Ctrl+Shift+B)",
                                "Build disabled while debugging");
            SetToolbarItemState(tbRun, false,
                                "Build & Run (F5)",
                                "Run disabled while debugging");
            SetMenuEnabled(miBuild, false);
            SetMenuEnabled(miBuildAndRun, false);
            SetMenuEnabled(miRun, false);
        } else if buildJobActive == false {
            SetToolbarItemState(tbBuild, true,
                                "Build (Ctrl+Shift+B)",
                                "Build disabled while another job is running");
            SetToolbarItemState(tbRun, true,
                                "Build & Run (F5)",
                                "Run disabled while another job is running");
            SetMenuEnabled(miBuild, true);
            SetMenuEnabled(miBuildAndRun, true);
            SetMenuEnabled(miRun, true);
        }

        var startDisabled = "Debug disabled while another job is running";
        if active { startDisabled = "Debug session already running"; }
        SetToolbarItemState(tbDebug, startEnabled,
                            "Start Debugging (F6)", startDisabled);
        SetToolbarItemState(tbDebugContinue, pausedEnabled,
                            "Continue Debugging (F7)",
                            "Continue is available while paused at a breakpoint");
        SetToolbarItemState(tbDebugStep, pausedEnabled,
                            "Step Over (F10)",
                            "Step is available while paused at a breakpoint");

        SetMenuEnabled(miDebugStart, startEnabled);
        SetMenuEnabled(miDebugContinue, pausedEnabled);
        SetMenuEnabled(miDebugStepOver, pausedEnabled);
        SetMenuEnabled(miDebugStepIn, pausedEnabled);
        SetMenuEnabled(miDebugStepOut, pausedEnabled);
        SetMenuEnabled(miDebugPause, runningEnabled);
        SetMenuEnabled(miDebugRestart, activeEnabled);
        SetMenuEnabled(miDebugStop, activeEnabled);
    }

    /// @brief Apply active-language capability state to semantic menu actions.
    /// @param service Capability record selected for the active document.
    expose func ApplyLanguageCommandState(service: language_service.LanguageService) {
        var canDefinition = false;
        var canReferences = false;
        var canRename = false;
        var canSymbols = false;
        var canSignature = false;
        if service != null {
            canDefinition = service.canGoToDefinition;
            canReferences = service.canFindReferences;
            canRename = service.canRename;
            canSymbols = service.canDocumentSymbols;
            canSignature = service.canSignatureHelp;
        }
        SetMenuEnabled(miGoToDefinition, canDefinition);
        SetMenuEnabled(miFindReferences, canReferences);
        SetMenuEnabled(miIncomingCalls, canReferences);
        SetMenuEnabled(miOutgoingCalls, canDefinition);
        SetMenuEnabled(miRenameSymbol, canRename);
        SetMenuEnabled(miWorkspaceSymbols, canSymbols);
        SetMenuEnabled(miSymbolOutline, canSymbols);
        SetMenuEnabled(miSignatureHelp, canSignature);
        SetMenuEnabled(ecGotoDef, canDefinition);
        SetMenuEnabled(ecFindRefs, canReferences);
        SetMenuEnabled(ecRename, canRename);
    }

    /// @brief Enable or disable one menu item when the handle exists.
    /// @param item Menu item handle that may be null during partial setup.
    /// @param enabled True to enable, false to grey the item out.
    expose func SetMenuEnabled(item: GUI.MenuItem, enabled: Boolean) {
        if item == null { return; }
        item.SetEnabled(enabled);
    }

    /// @brief Apply enabled state and matching hover text to one toolbar item.
    /// @param item Toolbar item handle; null is ignored during partial setup.
    /// @param enabled Runtime GUI enabled flag.
    /// @param enabledTooltip Tooltip used when the item can be activated.
    /// @param disabledTooltip Tooltip used when the item is disabled.
    hide func SetToolbarItemState(item: GUI.ToolbarItem,
                                  enabled: Boolean,
                                  enabledTooltip: String,
                                  disabledTooltip: String) {
        if item == null { return; }
        item.SetEnabled(enabled);
        if enabled {
            item.SetTooltip(enabledTooltip);
        } else {
            item.SetTooltip(disabledTooltip);
        }
    }
}
