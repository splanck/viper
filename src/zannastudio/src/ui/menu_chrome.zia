    expose GUI.MenuItem tcCloseOthers;
    expose GUI.MenuItem tcCloseAll;
    expose GUI.MenuItem tcCloseSaved;
    expose GUI.MenuItem tcCopyPath;
    expose GUI.MenuItem tcCopyRelativePath;
    expose GUI.MenuItem tcReveal;

    // Command availability is the product of UI context and asynchronous
    // execution state. Keep both here so a job/debug refresh cannot
    // accidentally re-enable commands on the empty welcome surface.
    expose Boolean commandContextInitialized;
    expose Boolean documentContextAvailable;
    expose Boolean projectContextAvailable;
    expose Boolean buildTargetAvailable;
    expose Boolean debugTargetAvailable;
    hide Boolean languageSymbolsAvailable;
    hide Boolean jobActiveState;
    hide String activeJobName;
    hide Boolean debugSessionActive;
    hide Boolean debugSessionStopped;
    hide Boolean executionStateInitialized;
    expose Integer executionStateApplyCount;
    hide command_registry.CommandRegistry appliedShortcutRegistry;

    /// @brief Create an empty menu chrome controller.
    expose func init() {
        commandContextInitialized = false;
        documentContextAvailable = false;
        projectContextAvailable = false;
        buildTargetAvailable = false;
        debugTargetAvailable = false;
        languageSymbolsAvailable = false;
        jobActiveState = false;
        activeJobName = "";
        debugSessionActive = false;
        debugSessionStopped = false;
        executionStateInitialized = false;
        executionStateApplyCount = 0;
        appliedShortcutRegistry = null;
    }

    /// @brief Build the top menu bar and all command menu items.
    /// @param parent Main vertical container that receives the menu bar.
    expose func BuildMainMenus(parent: GUI.VBox) {
        menuBar = GUI.MenuBar.New(parent);
        BuildFileMenu();
        BuildEditMenu();
        BuildNavigateMenu();
        BuildViewMenu();
        BuildBuildMenu();
        BuildHelpMenu();
    }

