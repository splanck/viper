        ApplyShortcut(miNew, "new", registry);
        ApplyShortcut(miOpen, "open", registry);
        ApplyShortcut(miOpenFolder, "openfolder", registry);
        ApplyShortcut(miQuickOpen, "quickopen", registry);
        ApplyShortcut(miSave, "save", registry);
        ApplyShortcut(miSaveAs, "saveas", registry);
        ApplyShortcut(miSaveAll, "saveall", registry);
        ApplyShortcut(miClose, "close", registry);
        ApplyShortcut(miReload, "reload", registry);
        ApplyShortcut(miRecentFiles, "recentfiles", registry);
        ApplyShortcut(miReopenClosed, "reopenclosed", registry);
        ApplyShortcut(miUndo, "undo", registry);
        ApplyShortcut(miRedo, "redo", registry);
        ApplyShortcut(miCut, "cut", registry);
        ApplyShortcut(miCopy, "copy", registry);
        ApplyShortcut(miPaste, "paste", registry);
        ApplyShortcut(miSelectAll, "selectall", registry);
        ApplyShortcut(miFind, "find", registry);
        ApplyShortcut(miSearchProject, "searchproject", registry);
        ApplyShortcut(miGoToLine, "goto", registry);
        ApplyShortcut(miRenameSymbol, "rename", registry);
        ApplyShortcut(miPreferences, "settings", registry);
        ApplyShortcut(miGoToDefinition, "gotodef", registry);
        ApplyShortcut(miFindReferences, "findrefs", registry);
        ApplyShortcut(miIncomingCalls, "incomingcalls", registry);
        ApplyShortcut(miOutgoingCalls, "outgoingcalls", registry);
        ApplyShortcut(miWorkspaceSymbols, "workspacesymbols", registry);
        ApplyShortcut(miSymbolOutline, "symboloutline", registry);
        ApplyShortcut(miNextError, "nexterror", registry);
        ApplyShortcut(miPreviousError, "preverror", registry);
        ApplyShortcut(miSignatureHelp, "signature_trigger", registry);
        ApplyShortcut(miToggleSidebar, "togglesidebar", registry);
        ApplyShortcut(miToggleStatusBar, "statusbar", registry);
        ApplyShortcut(miZoomIn, "zoomin", registry);
        ApplyShortcut(miZoomOut, "zoomout", registry);
        ApplyShortcut(miZoomReset, "zoomreset", registry);
        ApplyShortcut(miUiZoomIn, "uizoomin", registry);
        ApplyShortcut(miUiZoomOut, "uizoomout", registry);
        ApplyShortcut(miUiZoomReset, "uizoomreset", registry);
        ApplyShortcut(miToggleTheme, "toggletheme", registry);
        ApplyShortcut(miFullscreen, "fullscreen", registry);
        ApplyShortcut(miToggleMinimap, "minimap", registry);
        ApplyShortcut(miTerminal, "terminal", registry);
        ApplyShortcut(miBuild, "build", registry);
        ApplyShortcut(miBuildAndRun, "buildrun", registry);
        ApplyShortcut(miRun, "run", registry);
        ApplyShortcut(miStop, "stopjob", registry);
        ApplyShortcut(miDebugStart, "debugstart", registry);
        ApplyShortcut(miDebugContinue, "debugcontinue", registry);
        ApplyShortcut(miDebugStepOver, "debugstepover", registry);
        ApplyShortcut(miDebugStepIn, "debugstepin", registry);
        ApplyShortcut(miDebugStepOut, "debugstepout", registry);
        ApplyShortcut(miDebugRestart, "debugrestart", registry);
        ApplyShortcut(miToggleBreakpoint, "togglebreakpoint", registry);
        ApplyShortcut(miKeyboardShortcuts, "keybindings", registry);
        ApplyShortcut(ctxRename, "treerename", registry);
        ApplyShortcut(ctxDelete, "treedelete", registry);
        ApplyShortcut(ctxNewFile, "treenewfile", registry);
        ApplyShortcut(ctxNewFolder, "treenewfolder", registry);
        ApplyShortcut(ctxRefresh, "treerefresh", registry);
        ApplyShortcut(ecCut, "cut", registry);
