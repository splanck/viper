//
// File: zannastudio/src/ui/menu_chrome.zia
// Purpose: Menu bar, toolbar, and context-menu construction for Zanna Studio.
// Key invariants:
//   - This module owns persistent command chrome, not editor/workbench layout.
//   - Menu items remain exposed so the dispatcher can poll stable handles.
// Ownership/Lifetime:
//   - AppShell owns one MenuChrome for the lifetime of the IDE window.
//   - GUI widgets are created during BuildMainMenus/BuildToolbar/BuildContextMenus.
// Links: zannastudio/src/ui/app_shell.zia, zannastudio/src/commands/command_catalog.zia
//
//===----------------------------------------------------------------------===//

module menu_chrome;

bind "../commands/command_registry";
bind "../editor/language_service";
bind "../ui/status_bar_model";

bind Zanna.GUI as GUI;

/// @brief Owns the IDE's command menus, toolbar, and context menus.
/// @details The main dispatcher polls these exposed handles directly. Keeping
///          them together prevents the top-level AppShell from becoming a giant
///          constructor while preserving the existing pull-based event model.
class MenuChrome {
    expose GUI.MenuBar menuBar;
    expose GUI.Menu fileMenu;
    expose GUI.Menu editMenu;
    expose GUI.Menu navigateMenu;
    expose GUI.Menu viewMenu;
    expose GUI.Menu helpMenu;
    expose GUI.Menu buildMenu;

    expose GUI.MenuItem miNew;
