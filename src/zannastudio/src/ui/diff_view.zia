//
// File: zannastudio/src/ui/diff_view.zia
// Purpose: Async side-by-side diff overlay with incrementally rendered rows.
// Key invariants:
//   - Diff computation never runs on the interactive UI thread.
//   - At most a fixed row batch is materialized into widgets per frame.
//   - The overlay stays inside the current logical viewport after every resize.
//   - Colors derive from the live theme palette (never hardcoded).
//   - A visible diff owns the shell's sole focus-taking transient-surface slot.
// Ownership/Lifetime:
//   - The floating panel and its children are created once per AppShell and
//     reused for every diff; DiffView owns and drains its DiffJob.
// Links: zannastudio/src/services/diff_job.zia,
//        zannastudio/src/scm/scm_view.zia
//
//===----------------------------------------------------------------------===//

module diff_view;

bind "../services/diff_engine";
bind "../services/diff_job";
bind "../services/theme_colors";
bind "../ui/app_shell";

bind Zanna.GUI as GUI;
bind Str = Zanna.String;

final DIFF_COLUMN_WIDTH = 56;
final DIFF_ROWS_PER_FRAME = 100;
final DIFF_PANEL_WIDTH = 980;
final DIFF_PANEL_HEIGHT = 560;
final DIFF_PANEL_MARGIN = 28;

/// @brief Reusable side-by-side diff overlay.
class DiffView {
    expose GUI.FloatingPanel panel;
    expose GUI.Label titleLabel;
    expose GUI.ListBox rowsList;
    expose GUI.Button closeButton;
    expose Boolean visible;
    expose diff_job.DiffJob job;
    expose Integer pendingGeneration;
    expose diff_engine.DiffBuildResult renderResult;
    expose Integer renderIndex;
    expose Integer lastPumpRenderCount;
    expose String activeTitle;
    expose String lastError;
    hide GUI.App rootApp;
    hide app_shell.AppShell rootShell;

    expose func init() {
        panel = null;
        titleLabel = null;
        rowsList = null;
        closeButton = null;
        visible = false;
        job = new diff_job.DiffJob();
        pendingGeneration = 0;
        renderResult = null;
        renderIndex = 0;
        lastPumpRenderCount = 0;
        activeTitle = "";
        lastError = "";
        rootApp = null;
        rootShell = null;
    }

    /// @brief Build the reusable overlay into the app root.
    /// @param shell Workbench shell whose app owns the floating panel.
    expose func Setup(shell: app_shell.AppShell) {
        if shell == null or shell.app == null or panel != null { return; }
        rootShell = shell;
        rootApp = shell.app;
        panel = GUI.FloatingPanel.New(rootApp);
        panel.SetSize(DIFF_PANEL_WIDTH, DIFF_PANEL_HEIGHT);

        var column = GUI.VBox.New();
        column.SetPadding(16.0);
        column.SetSpacing(10.0);
        panel.AddChild(column);

        var headerRow = GUI.HBox.New();
        headerRow.SetSpacing(8.0);
        column.AddChild(headerRow);
        titleLabel = GUI.Label.New(headerRow, "Diff");
        titleLabel.SetFlex(1.0);
        titleLabel.SetEllipsis(true);
        closeButton = GUI.Button.New(headerRow, "Close");

        rowsList = GUI.ListBox.New(null);
        rowsList.SetFlex(1.0);
        column.AddChild(rowsList);

        panel.SetVisible(false);
    }

    /// @brief Pad or trim one cell to the fixed diff column width.
    hide func Cell(text: String) -> String {
        var cell = text;
        if Str.get_Length(cell) > DIFF_COLUMN_WIDTH {
            cell = Str.Left(cell, DIFF_COLUMN_WIDTH - 1) + "…";
        }
        while Str.get_Length(cell) < DIFF_COLUMN_WIDTH {
            cell = cell + " ";
        }
        return cell;
    }

    /// @brief Format a 1-based line number cell (blank when zero).
    hide func LineCell(lineNumber: Integer) -> String {
        if lineNumber <= 0 { return "     "; }
        var text = "" + lineNumber;
        while Str.get_Length(text) < 5 {
            text = " " + text;
        }
        return text;
    }

    /// @brief Show the overlay with an aligned side-by-side diff.
    /// @param title Header text (e.g. the file path).
    /// @param leftText "Before" document text.
    /// @param rightText "After" document text.
    expose func Open(title: String, leftText: String, rightText: String) {
        if panel == null or rowsList == null { return; }
        ResetRendering();
        activeTitle = title;
        lastError = "";
        titleLabel.SetText(title + "  (computing...)");
        rowsList.Clear();
        rowsList.AddItem("Computing bounded diff...");
        pendingGeneration = job.Queue(title, leftText, rightText);

        Layout();
        rootShell.ClaimTransientSurface(app_shell.TRANSIENT_SURFACE_DIFF, panel);
        visible = true;
    }

    /// @brief Hide the overlay.
    expose func Close() {
        job.Cancel();
        pendingGeneration = 0;
        ResetRendering();
        if panel != null { panel.SetVisible(false); }
        visible = false;
        if rootShell != null {
            rootShell.ReleaseTransientSurface(app_shell.TRANSIENT_SURFACE_DIFF);
        }
    }

    /// @brief Poll worker completion, render one row batch, and handle close.
    expose func Pump() {
        lastPumpRenderCount = 0;
        job.Pump();
        if visible == false {
            job.TakeCompleted();
            return;
        }
        if rootShell == null
           or rootShell.OwnsTransientSurface(
               app_shell.TRANSIENT_SURFACE_DIFF) == false {
            Close();
            return;
        }
        Layout();
        if closeButton != null and closeButton.WasClicked() {
            Close();
            return;
        }
        if Zanna.Input.Keyboard.WasPressed(Zanna.Input.Key.Escape) {
            Close();
            return;
        }

        var request = job.TakeCompleted();
        if request != null and request!.generation == pendingGeneration {
            FinishRequest(request!);
        }
        PumpRenderRows();
    }

    /// @brief Cancel and drain worker ownership before runtime teardown.
    expose func Shutdown() -> Boolean {
        pendingGeneration = 0;
        ResetRendering();
        if panel != null { panel.SetVisible(false); }
        visible = false;
        if rootShell != null {
            rootShell.ReleaseTransientSurface(app_shell.TRANSIENT_SURFACE_DIFF);
        }
        return job.CancelAndWait();
    }

    expose func IsBusy() -> Boolean {
        return pendingGeneration > 0 or job.IsBusy() or renderResult != null;
    }

    /// @brief Validate one worker result and begin incremental publication.
    hide func FinishRequest(request: diff_job.DiffRequest) {
        pendingGeneration = 0;
        rowsList.Clear();
        if request.succeeded == false or request.error != "" {
            lastError = request.error;
            if lastError == "" { lastError = "Diff computation failed"; }
            rowsList.AddItem(lastError);
            titleLabel.SetText(activeTitle + "  (unavailable)");
            return;
        }
        if request.reason != "" {
            if request.reason == "source_too_large" {
                lastError = "Diff supports files up to 4 MB each";
            } else if request.reason == "too_many_lines" {
                lastError = "Diff supports up to 20,000 combined lines";
            } else {
                lastError = "Diff input exceeds safety limits";
            }
            rowsList.AddItem(lastError);
            titleLabel.SetText(activeTitle + "  (limited)");
            return;
        }
        if request.result == null {
            lastError = "Diff computation returned no result";
            rowsList.AddItem(lastError);
            titleLabel.SetText(activeTitle + "  (unavailable)");
            return;
        }
        renderResult = request.result;
        renderIndex = 0;
        titleLabel.SetText(activeTitle + "  (rendering 0/"
                           + renderResult.rows.count() + ")");
    }

    /// @brief Add no more than DIFF_ROWS_PER_FRAME formatted list rows.
    hide func PumpRenderRows() {
        if renderResult == null or rowsList == null { return; }
        var stop = renderIndex + DIFF_ROWS_PER_FRAME;
        if stop > renderResult.rows.count() { stop = renderResult.rows.count(); }
        while renderIndex < stop {
            AddDisplayRow(renderResult.rows.get(renderIndex) as diff_engine.DiffRow);
            renderIndex = renderIndex + 1;
            lastPumpRenderCount = lastPumpRenderCount + 1;
        }
        if renderIndex < renderResult.rows.count() {
            titleLabel.SetText(activeTitle + "  (rendering " + renderIndex + "/"
                               + renderResult.rows.count() + ")");
            return;
        }

        if renderResult.truncated {
            rowsList.AddItem("… " + (renderResult.totalRows - renderResult.rows.count())
                             + " more rows truncated");
        }
        titleLabel.SetText(activeTitle + "  (~" + renderResult.changedCount
                           + "  +" + renderResult.addedCount
                           + "  -" + renderResult.removedCount + ")");
        renderResult = null;
        renderIndex = 0;
    }

    /// @brief Format and color one aligned worker-produced row.
    hide func AddDisplayRow(row: diff_engine.DiffRow) {
        if row == null or rowsList == null { return; }
        var marker = "  ";
        if row.kind == diff_engine.ROW_ADDED { marker = "+ "; }
        if row.kind == diff_engine.ROW_REMOVED { marker = "- "; }
        if row.kind == diff_engine.ROW_CHANGED { marker = "~ "; }
        var text = marker + LineCell(row.leftLine) + " " + Cell(row.leftText)
                   + " │ " + LineCell(row.rightLine) + " " + row.rightText;
        var item = rowsList.AddItem(text);
        if row.kind == diff_engine.ROW_ADDED {
            GUI.ListBox.ItemSetTextColor(item, theme_colors.Rgb("accentSuccess"));
        }
        if row.kind == diff_engine.ROW_REMOVED {
            GUI.ListBox.ItemSetTextColor(item, theme_colors.Rgb("accentDanger"));
        }
        if row.kind == diff_engine.ROW_CHANGED {
            GUI.ListBox.ItemSetTextColor(item, theme_colors.Rgb("accentWarning"));
        }
    }

    hide func ResetRendering() {
        renderResult = null;
        renderIndex = 0;
        lastPumpRenderCount = 0;
    }

    /// @brief Fit and center the overlay in the current logical app viewport.
    hide func Layout() {
        if panel == null or rootApp == null { return; }
        var rootW = app_shell.UiViewportWidth(rootApp);
        var rootH = app_shell.UiViewportHeight(rootApp);
        if rootW <= 0 { rootW = 1280; }
        if rootH <= 0 { rootH = 800; }
        var panelW = DIFF_PANEL_WIDTH;
        var panelH = DIFF_PANEL_HEIGHT;
        var maxW = rootW - (DIFF_PANEL_MARGIN * 2);
        var maxH = rootH - (DIFF_PANEL_MARGIN * 2);
        if panelW > maxW { panelW = maxW; }
        if panelH > maxH { panelH = maxH; }
        if panelW < 1 { panelW = 1; }
        if panelH < 1 { panelH = 1; }
        panel.SetSize(panelW, panelH);
        // The retained app root can still carry its preceding dimensions
        // during the resize frame. Center against the authoritative viewport
        // used for clamping instead of the parent's stale arranged bounds.
        panel.SetPosition((rootW - panelW) / 2, (rootH - panelH) / 2);
    }
}
