//
// File: zannastudio/src/ui/scene_transform_3d.zia
// Purpose: Pure transform-mode, snapping, and pointer-drag math for Studio's
//          3D scene gizmo.
// Key invariants:
//   - Pointer projection remains deterministic and independent of GUI widgets.
//   - Plane motion uses a conditioned two-axis solve and rejects edge-on bases.
//   - One projected handle width maps to one scale unit on both plane axes.
//   - Rotation rings invert their projected ellipse and unwrap angular deltas.
//   - Snapping quantizes the resulting axis value, never each pointer delta.
//   - Scale cannot collapse through an unusable zero value.
//   - Transform-space validation keeps persisted local/world state bounded.
// Ownership/Lifetime: Stateless helper module borrowed by SceneEditor3D.
// Links: zannastudio/src/ui/scene_editor_3d.zia,
//        zannastudio/src/probes/scene_editor_3d_probe.zia,
//        zannastudio/src/probes/scene_rotation_ring_probe.zia,
//        zannastudio/src/probes/scene_scale_plane_probe.zia,
//        docs/adr/0166-exact-scenenode-world-matrix-assignment.md
//
//===----------------------------------------------------------------------===//

module scene_transform_3d;

bind Math = Zanna.Math;

// ============================================================================
// MODULE: scene_transform_3d
// PURPOSE: Give viewport manipulation one probeable math contract shared by
//          live drags and deterministic scene-editor commands.
//
// WHERE-THIS-FITS: SceneEditor3D owns widgets and SceneNode mutation. This
//          module owns only mode validation, projected drag scaling, and snap.
//
// TEACHING-NOTE: Snap the target value derived from the drag origin. Snapping
//          frame-by-frame deltas loses sub-step motion and makes handles stick.
// ============================================================================

final TRANSFORM_MOVE: Integer = 0;
final TRANSFORM_ROTATE: Integer = 1;
final TRANSFORM_SCALE: Integer = 2;
final TRANSFORM_SPACE_LOCAL: Integer = 0;
final TRANSFORM_SPACE_WORLD: Integer = 1;

final MOVE_SNAP_INCREMENT: Number = 0.5;
final ROTATE_SNAP_INCREMENT: Number = 15.0;
final SCALE_SNAP_INCREMENT: Number = 0.1;
final ROTATE_DEGREES_PER_HANDLE: Number = 45.0;
final SCALE_UNITS_PER_HANDLE: Number = 1.0;
final MIN_ABSOLUTE_SCALE: Number = 0.001;
final VALUE_EPSILON: Number = 0.0000001;
final MIN_PLANE_SIN_SQUARED: Number = 0.01;
final RING_RAD_TO_DEG: Number = 57.29577951308232;

/// @brief Two scene-space amounts decoded from one projected plane drag.
class PlaneDragResult {
    expose Boolean valid;
    expose Number amountA;
    expose Number amountB;

    expose func init() {
        valid = false;
        amountA = 0.0;
        amountB = 0.0;
    }
}

/// @brief One decoded angular coordinate on a projected rotation ring.
class RingAngleResult {
    expose Boolean valid;
    expose Number degrees;

    expose func init() {
        valid = false;
        degrees = 0.0;
    }
}

/// @brief Return whether an integer names a supported transform mode.
func IsValidMode(mode: Integer) -> Boolean {
    return mode == TRANSFORM_MOVE
        or mode == TRANSFORM_ROTATE
        or mode == TRANSFORM_SCALE;
}

/// @brief Return whether an integer names a supported gizmo coordinate space.
func IsValidSpace(space: Integer) -> Boolean {
    return space == TRANSFORM_SPACE_LOCAL
        or space == TRANSFORM_SPACE_WORLD;
}

/// @brief Return the concise label shown by the transform-space control.
func SpaceLabel(space: Integer) -> String {
    if space == TRANSFORM_SPACE_WORLD { return "World"; }
    return "Local";
}

/// @brief Return the user-facing transform mode label.
func ModeLabel(mode: Integer) -> String {
    if mode == TRANSFORM_ROTATE { return "Rotate"; }
    if mode == TRANSFORM_SCALE { return "Scale"; }
    return "Move";
}

/// @brief Return the present-participle action used during one drag.
func ModeAction(mode: Integer) -> String {
    if mode == TRANSFORM_ROTATE { return "Rotating"; }
    if mode == TRANSFORM_SCALE { return "Scaling"; }
    return "Moving";
}

/// @brief Return the history verb used after one committed drag.
func ModeHistoryVerb(mode: Integer) -> String {
    if mode == TRANSFORM_ROTATE { return "Rotated"; }
    if mode == TRANSFORM_SCALE { return "Scaled"; }
    return "Moved";
}

/// @brief Return the mode-specific snap increment.
func SnapIncrement(mode: Integer) -> Number {
    if mode == TRANSFORM_ROTATE { return ROTATE_SNAP_INCREMENT; }
    if mode == TRANSFORM_SCALE { return SCALE_SNAP_INCREMENT; }
    return MOVE_SNAP_INCREMENT;
}

/// @brief Describe the active snapping contract without hiding its precision.
func SnapDescription(mode: Integer) -> String {
    if mode == TRANSFORM_ROTATE { return "15°"; }
    if mode == TRANSFORM_SCALE { return "0.1"; }
    return "0.5 units";
}

/// @brief Convert screen-space mouse motion into an accumulated axis amount.
/// @param localLength Local translation units represented by the handle.
/// @details Move uses scene units, Rotate maps one full handle to 45 degrees,
///          and Scale maps one full handle to one scale unit.
func AxisDragAmount(mode: Integer,
                    deltaX: Number,
                    deltaY: Number,
                    axisX: Number,
                    axisY: Number,
                    localLength: Number) -> Number {
    if IsValidMode(mode) == false { return 0.0; }
    var lengthSquared = axisX * axisX + axisY * axisY;
    if lengthSquared <= VALUE_EPSILON { return 0.0; }
    var fraction = (deltaX * axisX + deltaY * axisY)
        / lengthSquared;
    if mode == TRANSFORM_ROTATE {
        return fraction * ROTATE_DEGREES_PER_HANDLE;
    }
    if mode == TRANSFORM_SCALE {
        return fraction * SCALE_UNITS_PER_HANDLE;
    }
    return fraction * localLength;
}

/// @brief Return whether two projected axes can define a stable drag plane.
/// @details The relative sine threshold rejects views within roughly six
///          degrees of edge-on instead of amplifying tiny pointer noise.
expose func PlaneProjectionIsUsable(axisAX: Number,
                                    axisAY: Number,
                                    axisBX: Number,
                                    axisBY: Number) -> Boolean {
    var lengthASquared = axisAX * axisAX + axisAY * axisAY;
    var lengthBSquared = axisBX * axisBX + axisBY * axisBY;
    if lengthASquared <= VALUE_EPSILON
       or lengthBSquared <= VALUE_EPSILON {
        return false;
    }
    var determinant = axisAX * axisBY - axisAY * axisBX;
    return determinant * determinant
        > lengthASquared * lengthBSquared * MIN_PLANE_SIN_SQUARED;
}

/// @brief Decode pointer motion into amounts along two projected plane axes.
/// @details Solving the complete 2x2 basis avoids the diagonal drift produced
///          by projecting the same mouse delta independently onto each axis.
expose func PlaneDragAmounts(deltaX: Number,
                             deltaY: Number,
                             axisAX: Number,
                             axisAY: Number,
                             axisBX: Number,
                             axisBY: Number,
                             lengthA: Number,
                             lengthB: Number) -> PlaneDragResult {
    var result = new PlaneDragResult();
    if PlaneProjectionIsUsable(
           axisAX, axisAY, axisBX, axisBY) == false
       or lengthA <= VALUE_EPSILON
       or lengthB <= VALUE_EPSILON {
        return result;
    }
    var determinant = axisAX * axisBY - axisAY * axisBX;
    var fractionA =
        (deltaX * axisBY - deltaY * axisBX) / determinant;
    var fractionB =
        (axisAX * deltaY - axisAY * deltaX) / determinant;
    result.amountA = fractionA * lengthA;
    result.amountB = fractionB * lengthB;
    result.valid = true;
    return result;
}

/// @brief Decode one Move or Scale pointer drag across two projected axes.
/// @details Move retains scene-unit handle lengths. Scale deliberately uses
///          one unit per complete handle on both axes, matching axis scaling
///          even when parent transforms require unequal local handle lengths.
expose func PlanarDragAmounts(mode: Integer,
                              deltaX: Number,
                              deltaY: Number,
                              axisAX: Number,
                              axisAY: Number,
                              axisBX: Number,
                              axisBY: Number,
                              lengthA: Number,
                              lengthB: Number) -> PlaneDragResult {
    if mode == TRANSFORM_SCALE {
        return PlaneDragAmounts(
            deltaX, deltaY,
            axisAX, axisAY, axisBX, axisBY,
            SCALE_UNITS_PER_HANDLE, SCALE_UNITS_PER_HANDLE);
    }
    if mode == TRANSFORM_MOVE {
        return PlaneDragAmounts(
            deltaX, deltaY,
            axisAX, axisAY, axisBX, axisBY,
            lengthA, lengthB);
    }
    return new PlaneDragResult();
}

/// @brief Decode a pointer coordinate on one projected rotation ellipse.
/// @details The projected ring axes form a complete 2x2 basis. Inverting that
///          basis recovers the circle coordinate before Atan2, so angular
///          motion stays correct on a foreshortened ellipse. Edge-on rings are
///          rejected by the same relative conditioning contract as move planes.
expose func RotationRingAngle(pointerX: Number,
                              pointerY: Number,
                              originX: Number,
                              originY: Number,
                              axisAX: Number,
                              axisAY: Number,
                              axisBX: Number,
                              axisBY: Number) -> RingAngleResult {
    var result = new RingAngleResult();
    var vectorAX = axisAX - originX;
    var vectorAY = axisAY - originY;
    var vectorBX = axisBX - originX;
    var vectorBY = axisBY - originY;
    if PlaneProjectionIsUsable(
           vectorAX, vectorAY, vectorBX, vectorBY) == false {
        return result;
    }
    var relativeX = pointerX - originX;
    var relativeY = pointerY - originY;
    var determinant =
        vectorAX * vectorBY - vectorAY * vectorBX;
    var coordinateA =
        (relativeX * vectorBY - relativeY * vectorBX) / determinant;
    var coordinateB =
        (vectorAX * relativeY - vectorAY * relativeX) / determinant;
    if coordinateA * coordinateA + coordinateB * coordinateB
       <= VALUE_EPSILON {
        return result;
    }
    result.degrees =
        Math.Atan2(coordinateB, coordinateA) * RING_RAD_TO_DEG;
    result.valid = true;
    return result;
}

/// @brief Return the shortest signed angular step across the ±180 seam.
expose func SignedAngleDelta(previousDegrees: Number,
                             currentDegrees: Number) -> Number {
    var delta = currentDegrees - previousDegrees;
    while delta > 180.0 { delta = delta - 360.0; }
    while delta < -180.0 { delta = delta + 360.0; }
    return delta;
}

/// @brief Resolve one drag-origin axis value plus accumulated motion.
/// @details Quantization happens around global step boundaries so separate
///          drags agree with inspector values and imported transforms.
func AxisTarget(mode: Integer,
                startValue: Number,
                accumulatedAmount: Number,
                snapEnabled: Boolean) -> Number {
    if IsValidMode(mode) == false { return startValue; }
    var target = startValue + accumulatedAmount;
    if snapEnabled {
        var increment = SnapIncrement(mode);
        target = Math.Round(target / increment) * increment;
    }
    if mode == TRANSFORM_SCALE {
        return UsableScale(target, startValue);
    }
    return target;
}

/// @brief Keep scale editable while preserving an existing sign when possible.
func UsableScale(value: Number, fallback: Number) -> Number {
    if value >= MIN_ABSOLUTE_SCALE or value <= 0.0 - MIN_ABSOLUTE_SCALE {
        return value;
    }
    if value < 0.0 or (value < VALUE_EPSILON and fallback < 0.0) {
        return 0.0 - MIN_ABSOLUTE_SCALE;
    }
    return MIN_ABSOLUTE_SCALE;
}

/// @brief Compare transform values using the editor's mutation epsilon.
func NearlyEqual(left: Number, right: Number) -> Boolean {
    var difference = left - right;
    if difference < 0.0 { difference = 0.0 - difference; }
    return difference <= VALUE_EPSILON;
}
