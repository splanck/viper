//
// File: zannastudio/src/ui/workbench_shell.zia
// Purpose: Central dockable workbench layout construction for Zanna Studio.
// Key invariants:
//   - This module owns persistent editor/sidebar and tool-dock hosts only.
//   - Explorer, Source Control, and Run/Debug use stable sibling view hosts.
//   - One primary-sidebar tree reparents between nested left/right splitters.
//   - Typed header drags reveal bounded targets and publish one durable edge.
//   - Tool-panel behavior remains delegated to ToolPanelShell.
//   - A requested minimap is suppressed while its editor lane is too narrow.
// Ownership/Lifetime:
//   - AppShell owns one WorkbenchShell for the lifetime of the IDE window.
//   - EditorEngine, ProjectManager, and other controllers attach to exposed
//     widgets after Build() completes.
// Links: zannastudio/src/ui/app_shell.zia, zannastudio/src/ui/tool_panel_shell.zia
//
//===----------------------------------------------------------------------===//

module workbench_shell;

bind "../ui/tool_panel_shell";
bind "../ui/primary_sidebar_dock";
bind "../services/file_utils";

bind Zanna.GUI as GUI;

// Preserve a genuinely useful code viewport after the 100-pixel minimap and
// editor gutters are accounted for. The editor row is measured in effective
// UI-layout units, so this threshold remains stable under HiDPI and UI zoom.
final MINIMAP_EDITOR_LANE_THRESHOLD: Number = 620.0;

/// @brief Owns the IDE's sidebar/editor layout widgets.
class WorkbenchShell {
    expose GUI.HBox workbenchHost;
    expose GUI.SplitPane splitPane;
    expose GUI.SplitPane rightSidebarSplit;
    expose GUI.SplitPane editorSplit;
    expose GUI.SplitPane leftDockSplit;
    expose GUI.SplitPane rightDockSplit;
    expose GUI.HBox workbenchRow;
    expose GUI.HBox centerRow;
    expose GUI.VBox editorArea;
    expose GUI.VBox bottomPanelHost;
    expose GUI.VBox leftPanelHost;
    expose GUI.VBox rightPanelHost;
    expose GUI.HBox editorRow;
    expose GUI.VBox scene2DHost;
    expose GUI.VBox scene3DHost;
    expose GUI.VBox welcomeHost;
    expose GUI.VBox preferencesPanel;
    expose GUI.TabBar tabBar;
    expose GUI.Breadcrumb breadcrumb;
    expose GUI.TreeView sidebarTree;
    expose GUI.Toolbar activityBar;
    expose GUI.ToolbarItem abExplorer;
    expose GUI.ToolbarItem abSourceControl;
    expose GUI.ToolbarItem abRunDebug;
    expose GUI.VBox leftViewStack;
    expose GUI.VBox leftSidebarHost;
    expose GUI.VBox rightSidebarHost;
    expose primary_sidebar_dock.PrimarySidebarDock primarySidebar;
    expose GUI.VBox explorerView;
    expose GUI.VBox scmViewHost;
    expose GUI.VBox runDebugViewHost;
    expose GUI.FindBar findBar;
    expose GUI.Minimap minimap;
    expose Boolean minimapRequestedVisible;
    expose Integer activeSurfaceKind;
    expose Integer activeDocumentSurfaceKind;

    /// @brief Initialize detached workbench state.
    expose func init() {
        workbenchHost = null;
        splitPane = null;
        rightSidebarSplit = null;
        editorSplit = null;
        leftDockSplit = null;
        rightDockSplit = null;
        workbenchRow = null;
        centerRow = null;
        editorArea = null;
        bottomPanelHost = null;
        leftPanelHost = null;
        rightPanelHost = null;
        editorRow = null;
        scene2DHost = null;
        scene3DHost = null;
        welcomeHost = null;
        preferencesPanel = null;
        tabBar = null;
        breadcrumb = null;
        sidebarTree = null;
        activityBar = null;
        abExplorer = null;
        abSourceControl = null;
        abRunDebug = null;
        leftViewStack = null;
        leftSidebarHost = null;
        rightSidebarHost = null;
        primarySidebar = new primary_sidebar_dock.PrimarySidebarDock();
        explorerView = null;
        scmViewHost = null;
        runDebugViewHost = null;
        findBar = null;
        minimap = null;
        minimapRequestedVisible = true;
        activeSurfaceKind = 0;
        activeDocumentSurfaceKind = 0;
    }

    /// @brief Build the activity bar, split pane, editor host, and tool panels.
    /// @param parent Main vertical container that receives the workbench.
    /// @param toolPanels Bottom tool-panel controller to build under editorArea.
    /// @param app Owning application, passed to ToolPanelShell for output layout.
    expose func Build(parent: GUI.VBox,
                      toolPanels: tool_panel_shell.ToolPanelShell,
                      app: GUI.App) {
        workbenchHost = GUI.HBox.New();
        workbenchHost.SetSpacing(0.0);
        workbenchHost.SetPadding(0.0);
        workbenchHost.SetFlex(1.0);
        parent.AddChild(workbenchHost);

        activityBar = GUI.Toolbar.NewVertical(workbenchHost);
        abExplorer = activityBar.AddNamedButton("explorer", "Explorer");
        abSourceControl = activityBar.AddNamedButton("source-control", "Source Control");
        abRunDebug = activityBar.AddNamedButton("debug", "Run and Debug");

        splitPane = GUI.SplitPane.New(workbenchHost, 1);
        splitPane.SetFlex(1.0);
        splitPane.SetPosition(primarySidebar.sidebarWidthFraction);
        splitPane.SetMinFirst(140.0);
        splitPane.SetMinSecond(320.0);

        leftSidebarHost = GUI.VBox.New();
        leftSidebarHost.SetSpacing(0.0);
        leftSidebarHost.SetPadding(0.0);
        leftSidebarHost.SetFlex(1.0);
        splitPane.First.AddChild(leftSidebarHost);

        leftViewStack = GUI.VBox.New();
        leftViewStack.SetSpacing(0.0);
        leftViewStack.SetPadding(0.0);
        leftViewStack.SetFlex(1.0);
        leftSidebarHost.AddChild(leftViewStack);
        primarySidebar.BuildHeader(leftViewStack);

        explorerView = GUI.VBox.New();
        explorerView.SetSpacing(0.0);
        explorerView.SetPadding(0.0);
        explorerView.SetFlex(1.0);
        leftViewStack.AddChild(explorerView);
        sidebarTree = GUI.TreeView.New(explorerView);
        sidebarTree.SetFlex(1.0);

        scmViewHost = GUI.VBox.New();
        scmViewHost.SetSpacing(0.0);
        scmViewHost.SetPadding(0.0);
        scmViewHost.SetFlex(1.0);
        scmViewHost.SetVisible(false);
        leftViewStack.AddChild(scmViewHost);

        runDebugViewHost = GUI.VBox.New();
        runDebugViewHost.SetSpacing(0.0);
        runDebugViewHost.SetPadding(0.0);
        runDebugViewHost.SetFlex(1.0);
        runDebugViewHost.SetVisible(false);
        leftViewStack.AddChild(runDebugViewHost);

        // The editor/workbench stays mounted in the first pane of a nested
        // right-sidebar splitter. Moving the sidebar reparents only its own
        // stable view tree, so editor and terminal focus are never disturbed.
        rightSidebarSplit = GUI.SplitPane.New(splitPane.Second, 1);
        rightSidebarSplit.SetFlex(1.0);
        rightSidebarSplit.SetPosition(
            1.0 - primarySidebar.sidebarWidthFraction);
        rightSidebarSplit.SetMinFirst(320.0);
        rightSidebarSplit.SetMinSecond(140.0);

        workbenchRow = GUI.HBox.New();
        workbenchRow.SetSpacing(0.0);
        workbenchRow.SetPadding(0.0);
        workbenchRow.SetFlex(1.0);
        rightSidebarSplit.First.AddChild(workbenchRow);

        rightSidebarHost = GUI.VBox.New();
        rightSidebarHost.SetSpacing(0.0);
        rightSidebarHost.SetPadding(0.0);
        rightSidebarHost.SetFlex(1.0);
        rightSidebarSplit.Second.AddChild(rightSidebarHost);

        // Nested horizontal splitters provide stable left/right tool-panel
        // targets without special-case platform windows. Both side panes start
        // explicitly collapsed and are restored only when the panel is docked.
        leftDockSplit = GUI.SplitPane.New(workbenchRow, 1);
        leftDockSplit.SetFlex(1.0);
        leftDockSplit.SetPosition(0.30);
        leftDockSplit.SetMinFirst(180.0);
        leftDockSplit.SetMinSecond(300.0);

        leftPanelHost = GUI.VBox.New();
        leftPanelHost.SetSpacing(0.0);
        leftPanelHost.SetPadding(0.0);
        leftPanelHost.SetFlex(1.0);
        leftDockSplit.First.AddChild(leftPanelHost);

        rightDockSplit = GUI.SplitPane.New(leftDockSplit.Second, 1);
        rightDockSplit.SetFlex(1.0);
        rightDockSplit.SetPosition(0.70);
        rightDockSplit.SetMinFirst(300.0);
        rightDockSplit.SetMinSecond(180.0);

        centerRow = GUI.HBox.New();
        centerRow.SetSpacing(0.0);
        centerRow.SetPadding(0.0);
        centerRow.SetFlex(1.0);
        rightDockSplit.First.AddChild(centerRow);

        rightPanelHost = GUI.VBox.New();
        rightPanelHost.SetSpacing(0.0);
        rightPanelHost.SetPadding(0.0);
        rightPanelHost.SetFlex(1.0);
        rightDockSplit.Second.AddChild(rightPanelHost);

        editorArea = GUI.VBox.New();
        editorArea.SetSpacing(0.0);
        editorArea.SetPadding(0.0);
        editorArea.SetFlex(1.0);
        centerRow.AddChild(editorArea);

        preferencesPanel = GUI.VBox.New();
        preferencesPanel.SetSpacing(0.0);
        preferencesPanel.SetPadding(0.0);
        preferencesPanel.SetSize(420, 0);
        preferencesPanel.SetVisible(false);
        centerRow.AddChild(preferencesPanel);

        tabBar = GUI.TabBar.New(editorArea);
        // An empty strip reads as a broken editor above the welcome card and
        // wastes vertical space at startup. EditorTabs makes it visible when
        // the first real document is admitted.
        tabBar.SetVisible(false);
        breadcrumb = GUI.Breadcrumb.New(editorArea);
        breadcrumb.SetSeparator(" / ");
        breadcrumb.SetMaxItems(6);
        breadcrumb.SetVisible(false);

        findBar = GUI.FindBar.New(editorArea);
        findBar.SetVisible(false);

        // Editor and the bottom tool panels share one vertical splitter so the
        // panel area has a single drag-resizable height instead of each panel
        // carrying its own fixed height (which made the editor jump when the user
        // switched panel tabs). 0 = vertical (top/bottom) split.
        editorSplit = GUI.SplitPane.New(editorArea, 0);
        editorSplit.SetFlex(1.0);

        var editorHost: GUI.Widget = editorSplit.First;

        editorRow = GUI.HBox.New();
        editorRow.SetSpacing(0.0);
        editorRow.SetPadding(0.0);
        editorRow.SetFlex(1.0);
        editorHost.AddChild(editorRow);

        scene2DHost = GUI.VBox.New();
        scene2DHost.SetSpacing(0.0);
        scene2DHost.SetPadding(0.0);
        scene2DHost.SetFlex(1.0);
        scene2DHost.SetVisible(false);
        editorHost.AddChild(scene2DHost);

        scene3DHost = GUI.VBox.New();
        scene3DHost.SetSpacing(0.0);
        scene3DHost.SetPadding(0.0);
        scene3DHost.SetFlex(1.0);
        scene3DHost.SetVisible(false);
        editorHost.AddChild(scene3DHost);

        // Welcome / start surface, shown in place of the editor when no
        // documents are open. Built empty here; WelcomeView fills it.
        welcomeHost = GUI.VBox.New();
        welcomeHost.SetFlex(1.0);
        welcomeHost.SetVisible(false);
        editorHost.AddChild(welcomeHost);

        // Bottom half of the split hosts every tool panel; they fill it via flex
        // and the splitter owns the height.
        bottomPanelHost = GUI.VBox.New();
        bottomPanelHost.SetSpacing(0.0);
        bottomPanelHost.SetPadding(0.0);
        bottomPanelHost.SetFlex(1.0);
        editorSplit.Second.AddChild(bottomPanelHost);

        if toolPanels != null {
            toolPanels.Build(bottomPanelHost, app, editorSplit);
            toolPanels.ConfigureDocking(workbenchRow,
                                        leftPanelHost,
                                        rightPanelHost,
                                        leftDockSplit,
                                        rightDockSplit);
        }
        primarySidebar.Configure(
            workbenchHost, activityBar, splitPane, rightSidebarSplit,
            leftSidebarHost, rightSidebarHost, leftViewStack, sidebarTree,
            workbenchRow);
        // A divider position of 1.0 is still subject to the second pane's
        // measured minimum height. Use the splitter's explicit collapsed state
        // so a hidden tool area consumes no editor viewport space or divider.
        editorSplit.CollapseSecond();
        leftDockSplit.CollapseFirst();
        rightDockSplit.CollapseSecond();
    }

    /// @brief Toggle the sidebar by collapsing or restoring the split position.
    expose func ToggleSidebar() {
        primarySidebar.ToggleVisible();
    }

    /// @brief Explicitly show or fully collapse the sidebar content pane.
    /// @details The activity rail remains reachable on the configured edge.
    /// @param visible True to restore the pane, false to reclaim its full width.
    expose func SetSidebarVisible(visible: Boolean) {
        primarySidebar.SetVisible(visible);
    }

    /// @brief Return the current effective sidebar visibility.
    expose func IsSidebarVisible() -> Boolean {
        return primarySidebar.sidebarVisible;
    }

    /// @brief Apply a persisted sidebar width percentage.
    expose func SetSidebarWidthPct(pct: Integer) {
        primarySidebar.SetWidthPercent(pct);
    }

    /// @brief Consume one user-authored sidebar-divider change.
    /// @return Rounded sidebar width percentage, or -1 when unchanged.
    expose func TakeChangedSidebarWidthPercent() -> Integer {
        return primarySidebar.TakeChangedWidthPercent();
    }

    /// @brief Apply persisted primary-sidebar placement without a dirty edge.
    expose func SetSidebarPositionName(name: String) {
        primarySidebar.SetLocationName(name);
    }

    /// @brief Move the primary sidebar and publish one durable position edge.
    expose func MoveSidebarTo(location: Integer) {
        primarySidebar.MoveTo(location);
    }

    /// @brief Return "left" or "right" for the primary sidebar.
    expose func GetSidebarPositionName() -> String {
        return primarySidebar.GetLocationName();
    }

    /// @brief Consume one user-authored primary-sidebar position change.
    expose func TakeChangedSidebarPosition() -> String {
        return primarySidebar.TakeChangedLocation();
    }

    /// @brief Pump direct primary-sidebar buttons and typed drag targets.
    expose func PumpSidebarDocking() {
        primarySidebar.Pump();
    }

    /// @brief Return whether primary-sidebar drag targets are visible.
    expose func AreSidebarDockTargetsVisible() -> Boolean {
        return primarySidebar.AreTargetsVisible();
    }

    /// @brief Restore default primary-sidebar geometry and placement.
    expose func ResetSidebarLayout(visible: Boolean) {
        primarySidebar.Reset(visible);
    }

    /// @brief Store the user's minimap preference and apply the current lane policy.
    /// @details Compact suppression is deliberately not written back to Settings;
    ///          widening the editor therefore restores a requested minimap.
    /// @param visible True when the user wants the minimap where space permits.
    expose func SetMinimapRequestedVisible(visible: Boolean) {
        minimapRequestedVisible = visible;
        RefreshResponsiveMinimap();
    }

    /// @brief Reconcile effective minimap visibility with current editor width.
    /// @return True when effective visibility changed and layout needs repainting.
    expose func RefreshResponsiveMinimap() -> Boolean {
        if minimap == null { return false; }

        var shouldShow = minimapRequestedVisible;
        if shouldShow and editorRow != null {
            var laneWidth = editorRow.GetLogicalWidth();
            // A zero width means the row has not completed its first layout or
            // is temporarily replaced by the welcome surface. Preserve the
            // preference until a real editor-lane measurement is available.
            if laneWidth > 0.0 and laneWidth < MINIMAP_EDITOR_LANE_THRESHOLD {
                shouldShow = false;
            }
        }
        if minimap.IsVisible() == shouldShow { return false; }
        minimap.SetVisible(shouldShow);
        return true;
    }

    /// @brief Select exactly one document surface for the active file kind.
    /// @param kind Surface kind selected by the caller.
    expose func SelectSurface(kind: Integer) {
        activeSurfaceKind = kind;
        activeDocumentSurfaceKind = kind;
        editorRow.SetVisible(file_utils.IsVisualKind(kind) == false);
        scene2DHost.SetVisible(kind == file_utils.DOC_KIND_SCENE_2D);
        scene3DHost.SetVisible(kind == file_utils.DOC_KIND_SCENE_3D);
        welcomeHost.SetVisible(false);
    }

    /// @brief Set the breadcrumb path and hide it when empty.
    /// @param path File path to show in breadcrumb form.
    expose func SetBreadcrumbPath(path: String) {
        if path == "" {
            breadcrumb.SetPath("", "/");
            breadcrumb.SetVisible(false);
            return;
        }
        breadcrumb.SetPath(path, "/");
        breadcrumb.SetVisible(true);
    }
}
