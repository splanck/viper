//
// File: zannastudio/src/ui/app_shell.zia
// Purpose: Top-level Zanna Studio window lifecycle and UI-band coordination.
// Key invariants:
//   - AppShell owns the application window and persistent UI controllers.
//   - Construction details live in focused shell modules, not in this facade.
//   - The production workbench publishes a zoom-aware native minimum window size.
//   - Responsive editor chrome is reconciled whenever layout dimensions change.
//   - At most one focus-taking transient surface owns the workbench at a time.
//   - Surface Edit availability is forwarded unchanged to menu and toolbar
//     chrome; the shell does not infer text-editor-only behavior.
// Ownership/Lifetime:
//   - Constructed once by main.zia and destroyed during IDE shutdown.
//   - MenuChrome, WorkbenchShell, ToolPanelShell, and StatusShell live for the
//     same duration as the GUI.App window.
// Links: zannastudio/src/main.zia, zannastudio/src/ui/menu_chrome.zia
//
//===----------------------------------------------------------------------===//

module app_shell;

bind "../commands/command_registry";
bind "../editor/language_service";
bind "../ui/menu_chrome";
bind "../ui/status_shell";
bind "../ui/tool_panel_shell";
bind "../ui/workbench_shell";

bind Zanna.GUI as GUI;
bind Convert = Zanna.Core.Convert;

final WORKBENCH_MIN_WIDTH = 720;
final WORKBENCH_MIN_HEIGHT = 520;
final TRANSIENT_SURFACE_NONE: Integer = 0;
final TRANSIENT_SURFACE_SETTINGS: Integer = 1;
final TRANSIENT_SURFACE_ABOUT: Integer = 2;
final TRANSIENT_SURFACE_EXPLORER_ACTION: Integer = 3;
final TRANSIENT_SURFACE_DEBUG_BREAKPOINT: Integer = 4;
final TRANSIENT_SURFACE_COMMAND_INPUT: Integer = 5;
final TRANSIENT_SURFACE_DIFF: Integer = 6;
final TRANSIENT_SURFACE_WORKSPACE_EDIT_PREVIEW: Integer = 7;
// Reserve desktop chrome as well as a visible resize margin. Monitor metrics
// describe the full display, not the platform work area; 32 pixels was smaller
// than the macOS menu bar plus title bar and could strand the status bar below
// the screen at high UI zoom.
final WORKBENCH_SCREEN_GAP = 96;

/// @brief Preserve a window's center while keeping primary-monitor growth visible.
/// @details The runtime currently exposes the containing monitor's size but not
///          its global origin. Clamp only when the previous window center is in
///          the primary-origin coordinate range; secondary-monitor coordinates
///          retain their center instead of being pulled onto the primary screen.
func ExpandedWindowPosition(position: Integer,
                            previousExtent: Integer,
                            targetExtent: Integer,
                            monitorExtent: Integer) -> Integer {
    var next = position - (targetExtent - previousExtent) / 2;
    var previousCenter = position + previousExtent / 2;
    if monitorExtent <= 0 or previousCenter < 0
       or previousCenter > monitorExtent {
        return next;
    }
    var edge = WORKBENCH_SCREEN_GAP / 2;
    var minimum = edge;
    var maximum = monitorExtent - targetExtent - edge;
    if maximum < minimum {
        minimum = 0;
        maximum = monitorExtent - targetExtent;
    }
    if maximum < minimum { return next; }
    if next < minimum { next = minimum; }
    if next > maximum { next = maximum; }
    return next;
}

/// @brief Return the window width in effective UI-layout units.
/// @details App.GetLogicalWidth removes only the backing scale. Widget geometry
///          also includes user zoom, so overlay placement must divide the raw
///          framebuffer width by the complete effective scale.
expose func UiViewportWidth(app: GUI.App) -> Integer {
    if app == null { return 0; }
    var scale = app.GetEffectiveScale();
    if scale <= 0.0 { scale = 1.0; }
    return Convert.NumToInt(app.GetWidth() / scale);
}

/// @brief Return the window height in effective UI-layout units.
expose func UiViewportHeight(app: GUI.App) -> Integer {
    if app == null { return 0; }
    var scale = app.GetEffectiveScale();
    if scale <= 0.0 { scale = 1.0; }
    return Convert.NumToInt(app.GetHeight() / scale);
}

/// @brief Convert one framebuffer-space coordinate into effective UI units.
expose func PhysicalToUi(app: GUI.App, value: Number) -> Number {
    if app == null { return value; }
    var scale = app.GetEffectiveScale();
    if scale <= 0.0 { scale = 1.0; }
    return value / scale;
}

/// @brief Coordinates the IDE window and focused persistent UI shell modules.
class AppShell {
    expose GUI.App app;
    expose GUI.VBox mainVBox;
    expose menu_chrome.MenuChrome menuChrome;
    expose workbench_shell.WorkbenchShell workbench;
    expose tool_panel_shell.ToolPanelShell toolPanels;
    expose status_shell.StatusShell statusShell;
    expose GUI.CommandPalette commandPalette;
    expose String contextPath;
    expose String contextDir;
    expose Integer tabContextIndex;
    hide Integer activeTransientOwner;
    hide GUI.Widget activeTransientSurface;

    /// @brief Initialize detached UI controllers.
    expose func init() {
        menuChrome = new menu_chrome.MenuChrome();
        workbench = new workbench_shell.WorkbenchShell();
        toolPanels = new tool_panel_shell.ToolPanelShell();
        statusShell = new status_shell.StatusShell();
        contextPath = "";
        contextDir = "";
        tabContextIndex = -1;
        activeTransientOwner = TRANSIENT_SURFACE_NONE;
        activeTransientSurface = null;
    }

    /// @brief Construct the IDE window and persistent UI bands.
    /// @param title Window title.
    /// @param width Initial window width in logical pixels.
    /// @param height Initial window height in logical pixels.
    expose func Build(title: String, width: Integer, height: Integer) {
        app = GUI.App.New(title, width, height);
        app.SetPreventClose(true);
        GUI.Theme.SetDark();
        // Keep transient feedback out of editor chrome and prevent background
        // activity from filling the workbench with a tall notification stack.
        GUI.Toast.SetPosition(2);
        GUI.Toast.SetMaxVisible(3);

        mainVBox = GUI.VBox.New();
        mainVBox.SetSpacing(0.0);
        mainVBox.SetPadding(0.0);
        mainVBox.SetFlex(1.0);
        var root: GUI.Widget = app.Root;
        root.AddChild(mainVBox);

        menuChrome.BuildMainMenus(mainVBox);
        menuChrome.BuildToolbar(mainVBox);
        workbench.Build(mainVBox, toolPanels, app);
        menuChrome.BuildContextMenus();
        statusShell.Build(mainVBox);

        commandPalette = GUI.CommandPalette.New(app);
        commandPalette.SetPlaceholder("Type a command...");

        SetBuildJobActive(false, "");
        SetDebugSessionState(false, false, false);
        SetCommandContextAvailable(false, false, false, false);
    }

    /// @brief Give one focus-taking transient surface exclusive ownership.
    /// @details Claiming hides the prior surface plus popup menus immediately.
    ///          Its old controller observes the lost token during its next Pump
    ///          and clears stale logical state without disturbing the new owner.
    /// @param owner Stable TRANSIENT_SURFACE_* identity for the controller.
    /// @param surface Widget to show, including docked Settings or a floating panel.
    expose func ClaimTransientSurface(owner: Integer, surface: GUI.Widget) {
        if owner == TRANSIENT_SURFACE_NONE {
            DismissTransientSurface();
            return;
        }
        if activeTransientOwner != owner and activeTransientSurface != null {
            activeTransientSurface.SetVisible(false);
        }
        activeTransientOwner = owner;
        activeTransientSurface = surface;
        if surface != null { surface.SetVisible(true); }

        if commandPalette != null and commandPalette.IsVisible() {
            commandPalette.Hide();
        }
        if menuChrome != null {
            if menuChrome.treeContextMenu != null
               and menuChrome.treeContextMenu.IsVisible() {
                menuChrome.treeContextMenu.Hide();
            }
            if menuChrome.editorContextMenu != null
               and menuChrome.editorContextMenu.IsVisible() {
                menuChrome.editorContextMenu.Hide();
            }
            if menuChrome.tabContextMenu != null
               and menuChrome.tabContextMenu.IsVisible() {
                menuChrome.tabContextMenu.Hide();
            }
        }
    }

    /// @brief Return whether a controller still owns the transient surface slot.
    expose func OwnsTransientSurface(owner: Integer) -> Boolean {
        return owner != TRANSIENT_SURFACE_NONE and activeTransientOwner == owner;
    }

    /// @brief Release ownership only when it still belongs to the caller.
    /// @details A superseded controller may close a frame later; owner matching
    ///          prevents that stale close from hiding a newer surface.
    expose func ReleaseTransientSurface(owner: Integer) {
        if OwnsTransientSurface(owner) == false { return; }
        if activeTransientSurface != null {
            activeTransientSurface.SetVisible(false);
        }
        activeTransientSurface = null;
        activeTransientOwner = TRANSIENT_SURFACE_NONE;
    }

    /// @brief Hide and forget whichever focus-taking surface is currently active.
    expose func DismissTransientSurface() {
        if activeTransientSurface != null {
            activeTransientSurface.SetVisible(false);
        }
        activeTransientSurface = null;
        activeTransientOwner = TRANSIENT_SURFACE_NONE;
    }

    /// @brief Apply command-catalog shortcuts to visible menu/context items.
    /// @param registry Runtime command registry populated from command_catalog.
    expose func ApplyCommandShortcuts(registry: command_registry.CommandRegistry) {
        menuChrome.ApplyCommandShortcuts(registry);
    }

    /// @brief True if the user requested window close.
    expose func ShouldClose() -> Boolean {
        return app.ShouldClose;
    }

    /// @brief Return true once for a prevented close request.
    expose func WasCloseRequested() -> Boolean {
        return app.WasCloseRequested();
    }

    /// @brief Pump the event queue.
    expose func Poll() {
        app.Poll();
    }

    /// @brief Block up to timeoutMs for OS events, then pump — a drop-in for
    ///        Poll() that lets an idle IDE sleep instead of busy-looping.
    /// @param timeoutMs Maximum idle wait in ms (clamped to [0,1000] in runtime).
    /// @return True if input woke the wait, false on timeout.
    expose func PollWait(timeoutMs: Integer) -> Boolean {
        return app.PollWait(timeoutMs);
    }

    /// @brief Ask the OS to make this app/window foreground-active.
    expose func Activate() {
        app.Activate();
    }

    /// @brief Publish Studio's minimum usable native-window dimensions.
    /// @details The normal floor leaves room for activity/sidebar chrome and a
    ///          useful editor surface. Whole-UI zoom raises that floor so larger
    ///          controls do not consume the effective workspace. On an unusually
    ///          small display, the floor contracts to the available logical work
    ///          area so the window does not become larger than the screen.
    expose func ApplyWorkbenchWindowConstraints() {
        var zoomPct = Convert.NumToInt(app.GetUiScale() * 100.0 + 0.5);
        if zoomPct < 100 { zoomPct = 100; }
        if zoomPct > 300 { zoomPct = 300; }
        var minW = (WORKBENCH_MIN_WIDTH * zoomPct + 99) / 100;
        var minH = (WORKBENCH_MIN_HEIGHT * zoomPct + 99) / 100;
        var monitorW = app.GetMonitorWidth();
        var monitorH = app.GetMonitorHeight();
        if monitorW > WORKBENCH_SCREEN_GAP
           and minW > monitorW - WORKBENCH_SCREEN_GAP {
            minW = monitorW - WORKBENCH_SCREEN_GAP;
        }
        if monitorH > WORKBENCH_SCREEN_GAP
           and minH > monitorH - WORKBENCH_SCREEN_GAP {
            minH = monitorH - WORKBENCH_SCREEN_GAP;
        }
        if minW < 1 { minW = 1; }
        if minH < 1 { minH = 1; }
        app.SetMinimumSize(minW, minH);

        // Raising a native constraint does not consistently resize an already
        // smaller window across platform adapters. Expand ordinary windows now;
        // fullscreen/maximized/minimized windows will inherit the native floor
        // when the platform restores their normal frame.
        if app.IsFullscreen() == false
           and app.IsMaximized() == false
           and app.IsMinimized() == false {
            var previousW = app.GetLogicalWidth();
            var previousH = app.GetLogicalHeight();
            var previousX = app.GetX();
            var previousY = app.GetY();
            var targetW = previousW;
            var targetH = previousH;
            if targetW < minW { targetW = minW; }
            if targetH < minH { targetH = minH; }
            if targetW != previousW or targetH != previousH {
                app.SetWindowSize(targetW, targetH);
                // Grow around the existing window center. Leaving the old
                // top-left untouched can push the newly enlarged bottom edge
                // below the desktop; preserving the center also avoids jumping
                // a window from its current monitor to the primary display.
                app.SetPosition(ExpandedWindowPosition(previousX, previousW,
                                                       targetW, monitorW),
                                ExpandedWindowPosition(previousY, previousH,
                                                       targetH, monitorH));
            }
        }
    }

    /// @brief Paint the current frame.
    expose func Render() {
        // A resize updates widget geometry during layout. Reconcile once with
        // the previous geometry, render that layout, then immediately repaint
        // if the new lane width crossed the minimap threshold. This prevents a
        // compact workbench from remaining crowded until some later input.
        workbench.RefreshResponsiveMinimap();
        app.Render();
        if workbench.RefreshResponsiveMinimap() {
            app.Render();
        }
    }

    /// @brief Destroy the GUI application window.
    expose func Destroy() {
        DismissTransientSurface();
        app.Destroy();
    }

    /// @brief Set the left status message text.
    /// @param text Message to show.
    /// @details Routine synchronous confirmations and expected unavailable
    ///          states belong here. Reserve transient toasts for failures that
    ///          need attention, important recovery/conflict state, and
    ///          user-initiated asynchronous completion.
    expose func SetStatusLeft(text: String) {
        statusShell.SetStatusLeft(text);
    }

    /// @brief Set the cursor-position status text.
    /// @param text Cursor display text.
    expose func SetStatusCenter(text: String) {
        statusShell.SetStatusCenter(text);
    }

    /// @brief Set the right status text.
    /// @param text Right status display text.
    expose func SetStatusRight(text: String) {
        statusShell.SetStatusRight(text);
    }

    /// @brief Switch status chrome between welcome and document contexts.
    /// @param active True while no document editor is visible.
    expose func SetWelcomeStatusMode(active: Boolean) {
        statusShell.SetWelcomeMode(active);
    }

    /// @brief Enable commands that require an open document or build target.
    /// @param hasDocument True when at least one editor document is open.
    /// @param hasProject True when a workspace root is open.
    /// @param hasBuildTarget True when a project or document can be built.
    /// @param hasDebugTarget True when a saved document can be debugged.
    expose func SetCommandContextAvailable(hasDocument: Boolean,
                                           hasProject: Boolean,
                                           hasBuildTarget: Boolean,
                                           hasDebugTarget: Boolean) {
        menuChrome.SetCommandContextAvailable(hasDocument,
                                              hasProject,
                                              hasBuildTarget,
                                              hasDebugTarget);
    }

    /// @brief Apply whether the active tab owns a visible CodeEditor surface.
    expose func SetTextEditorContextAvailable(available: Boolean) {
        menuChrome.SetTextEditorContextAvailable(available);
    }

    /// @brief Reflect selection edits for the active editor surface.
    expose func SetSurfaceEditActionsAvailable(canCut: Boolean,
                                               canCopy: Boolean,
                                               canPaste: Boolean,
                                               canSelectAll: Boolean,
                                               canDuplicate: Boolean,
                                               canDeleteScene: Boolean,
                                               canFind: Boolean) {
        menuChrome.SetSurfaceEditActionsAvailable(
            canCut, canCopy, canPaste, canSelectAll,
            canDuplicate, canDeleteScene, canFind);
    }

    /// @brief Reflect undo/redo availability for code or visual scene history.
    expose func SetEditHistoryAvailable(canUndo: Boolean,
                                        canRedo: Boolean) {
        menuChrome.SetEditHistoryAvailable(canUndo, canRedo);
    }

    /// @brief Update active project and language status items.
    /// @param projectName Project name, or empty when no project is open.
    /// @param languageName Active language display name.
    expose func SetWorkspaceStatus(projectName: String,
                                   languageName: String) {
        statusShell.SetWorkspaceStatus(projectName, languageName);
    }

    /// @brief Update the workspace-index status item.
    /// @param status Short index status text.
    expose func SetIndexStatus(status: String) {
        statusShell.SetIndexStatus(status);
    }

    /// @brief Update diagnostics summary status.
    /// @param errors Current error count.
    /// @param warnings Current warning count.
    /// @param notes Current note count.
    expose func SetDiagnosticsSummary(errors: Integer,
                                      warnings: Integer,
                                      notes: Integer) {
        statusShell.SetDiagnosticsSummary(errors, warnings, notes);
    }

    /// @brief Apply build/run job state to menu, toolbar, and status controls.
    /// @param active True while a build/run job is active.
    /// @param name Human-readable job name.
    expose func SetBuildJobActive(active: Boolean, name: String) {
        menuChrome.SetBuildJobActive(active, name);
        statusShell.SetBuildJobActive(active, name);
    }

    /// @brief Update the background editor-task status item.
    /// @param status Short scheduler status text.
    expose func SetSchedulerStatus(status: String) {
        statusShell.SetSchedulerStatus(status);
    }

    /// @brief Apply running/paused debug-session state to command chrome.
    /// @param active True while a debug adapter session exists.
    /// @param stopped True while the debuggee is paused at a stop location.
    /// @param buildJobActive True while the build/run controller is busy.
    expose func SetDebugSessionState(active: Boolean,
                                     stopped: Boolean,
                                     buildJobActive: Boolean) {
        menuChrome.SetDebugSessionState(active, stopped, buildJobActive);
    }

    /// @brief Apply active-language capability state to semantic commands.
    /// @param service Capability record selected for the active document.
    expose func ApplyLanguageCommandState(service: language_service.LanguageService) {
        menuChrome.ApplyLanguageCommandState(service);
    }

    /// @brief Set the breadcrumb path; auto-hides when path is empty.
    /// @param path File path to display.
    expose func SetBreadcrumbPath(path: String) {
        workbench.SetBreadcrumbPath(path);
    }

    /// @brief Format diagnostics summary text.
    /// @return Short diagnostics summary.
    expose func FormatDiagnosticsSummary(errors: Integer,
                                         warnings: Integer,
                                         notes: Integer) -> String {
        return statusShell.FormatDiagnosticsSummary(errors, warnings, notes);
    }

    /// @brief Pick diagnostics status color.
    /// @return RGB color integer.
    expose func DiagnosticsSummaryColor(errors: Integer,
                                        warnings: Integer,
                                        notes: Integer) -> Integer {
        return statusShell.DiagnosticsSummaryColor(errors, warnings, notes);
    }

    /// @brief Toggle sidebar visibility.
    expose func ToggleSidebar() {
        workbench.ToggleSidebar();
    }

    /// @brief Explicitly show or fully collapse the sidebar content pane.
    expose func SetSidebarVisible(visible: Boolean) {
        workbench.SetSidebarVisible(visible);
    }

    /// @brief Select the active document surface.
    /// @param kind Surface kind selected by the caller.
    expose func SelectSurface(kind: Integer) {
        workbench.SelectSurface(kind);
    }

    /// @brief Resize to scalePct percent of the monitor and center on screen.
    /// @param scalePct Desired monitor percentage for initial window size.
    expose func CenterAndSize(scalePct: Integer) {
        var mw = app.GetMonitorWidth();
        var mh = app.GetMonitorHeight();
        if mw <= 0 { mw = 1440; }
        if mh <= 0 { mh = 900; }
        var w = (mw * scalePct) / 100;
        var h = (mh * scalePct) / 100;
        var edgeGap = 96;
        var maxW = 1540;
        var maxH = 980;
        if maxW > mw - edgeGap { maxW = mw - edgeGap; }
        if maxH > mh - edgeGap { maxH = mh - edgeGap; }
        if maxW > 0 and w > maxW { w = maxW; }
        if maxH > 0 and h > maxH { h = maxH; }
        if w > mw - 32 { w = mw - 32; }
        if h > mh - 32 { h = mh - 32; }
        if mw > 760 and w < 720 { w = 720; }
        if mh > 560 and h < 520 { h = 520; }
        if w < 1 { w = 1; }
        if h < 1 { h = 1; }
        app.SetWindowSize(w, h);
        app.SetPosition((mw - w) / 2, (mh - h) / 2);
    }
}
