//
// File: zannastudio/src/app/file_watch_controller.zia
// Purpose: Track external changes to open documents without allowing watcher
//          races or OS resource exhaustion to terminate the Studio process.
// Key invariants:
//   - hasWatcher is true only while a native watcher actually reports active.
//   - A path disappearing between validation and Watcher.New degrades to polling.
//   - Steady-state frames never stat the active file merely to poll a watcher.
//   - Open-document metadata polling visits only a fixed number of tabs per frame.
// Ownership/Lifetime:
//   - Main owns one controller and destroys its watcher during IDE cleanup.
// Links: zannastudio/src/main.zia,
//        zannastudio/src/core/document_manager.zia
//
//===----------------------------------------------------------------------===//

module file_watch_controller;

bind "../core/document_manager";
bind "../core/document";
bind "../ui/app_shell";

bind Zanna.GUI;
bind IO = Zanna.IO;
bind Time = Zanna.Time;

final OPEN_DOCUMENT_STATS_PER_FRAME = 4;
final WATCHER_RETRY_MIN_MS = 1000;

// ============================================================================
// MODULE: file_watch_controller
// PURPOSE: Active-file watcher and open-document timestamp polling.
//
// WHERE-THIS-FITS: main.zia owns the frame loop. This controller owns the
//          stateful file-watching details so the loop can call one Pump method
//          instead of carrying watcher variables and timestamp polling inline.
//
// TEACHING-NOTE: The active document uses the platform watcher for fast user
//          feedback. Inactive open tabs are polled by timestamp so the IDE can
//          still mark changed documents without starting one watcher per tab.
// ============================================================================

/// @brief Tracks external file changes for active and inactive open documents.
class FileWatchController {
    expose String watchedPath;
    expose Boolean hasWatcher;
    expose IO.Watcher fileWatcher;
    expose Boolean pendingReload;
    expose Integer lastOpenDocPollMs;
    expose Integer lastWatcherAttemptMs;
    expose Boolean openDocPollActive;
    expose Integer openDocPollIndex;
    expose Integer openDocPollChangedCount;
    expose String openDocPollFirstName;
    expose Integer lastOpenDocPollCount;

    /// @brief Initialize with no active watched path.
    /// @details The watcher stays null until the first valid named file becomes
    ///          active, avoiding a pointless watcher construction for the CWD.
    expose func init() {
        watchedPath = "";
        hasWatcher = false;
        fileWatcher = null;
        pendingReload = false;
        lastOpenDocPollMs = 0;
        lastWatcherAttemptMs = 0;
        openDocPollActive = false;
        openDocPollIndex = 0;
        openDocPollChangedCount = 0;
        openDocPollFirstName = "";
        lastOpenDocPollCount = 0;
    }

    /// @brief Clear the pending reload flag after a user action resolved it.
    expose func ResetPendingReload() {
        pendingReload = false;
    }

    /// @brief Stop any active watcher before application shutdown.
    expose func Destroy() {
        if hasWatcher and fileWatcher != null {
            fileWatcher.Stop();
        }
        hasWatcher = false;
        watchedPath = "";
        fileWatcher = null;
        pendingReload = false;
        lastWatcherAttemptMs = 0;
        openDocPollActive = false;
        openDocPollIndex = 0;
        openDocPollChangedCount = 0;
        openDocPollFirstName = "";
        lastOpenDocPollCount = 0;
    }

    /// @brief Pump active-file watch events and inactive-tab timestamp checks.
    /// @param shell Workbench shell used for warning toasts and status text.
    /// @param docMgr Open document manager to inspect.
    /// @param openDocPollMs Milliseconds between inactive-document timestamp scans.
    /// @return True when the active document has an unresolved external change.
    expose func Pump(shell: app_shell.AppShell,
                     docMgr: document_manager.DocumentManager,
                     openDocPollMs: Integer) -> Boolean {
        lastOpenDocPollCount = 0;
        PumpActiveDocument(shell, docMgr, openDocPollMs);
        PumpOpenDocumentTimestamps(shell, docMgr, openDocPollMs);
        return pendingReload;
    }

    /// @brief Watch the current active document when it has a saved path.
    /// @param shell Workbench shell used for warning toasts and status text.
    /// @param docMgr Open document manager to inspect.
    hide func PumpActiveDocument(shell: app_shell.AppShell,
                                 docMgr: document_manager.DocumentManager,
                                 openDocPollMs: Integer) {
        if docMgr == null {
            StopWatching();
            return;
        }
        var activeDoc = docMgr.GetActive();
        if activeDoc == null {
            StopWatching();
            return;
        }
        var doc = activeDoc!;
        if doc.isNew {
            StopWatching();
            return;
        }
        if doc.filePath != watchedPath {
            StartWatching(doc.filePath);
        } else if hasWatcher == false {
            // A missing file or exhausted watcher resource must not trigger an
            // Exists/Watcher.New retry on every frame. Retry slowly so a file
            // recreated by another process can regain native notifications.
            var retryMs = openDocPollMs;
            if retryMs < WATCHER_RETRY_MIN_MS { retryMs = WATCHER_RETRY_MIN_MS; }
            var now = Time.Clock.NowMs();
            if now - lastWatcherAttemptMs >= retryMs {
                StartWatching(doc.filePath);
            }
        }
        if doc.externalState != document.EXTERNAL_STATE_CLEAN {
            pendingReload = true;
        }
        if hasWatcher == false { return; }
        var watchEvent = fileWatcher.Poll();
        if watchEvent == fileWatcher.EventModified {
            NotifyExternalState(shell, docMgr, docMgr.activeIndex,
                                document.EXTERNAL_STATE_CHANGED,
                                doc.fileName + " changed on disk");
        } else if watchEvent == fileWatcher.EventDeleted {
            NotifyExternalState(shell, docMgr, docMgr.activeIndex,
                                document.EXTERNAL_STATE_DELETED,
                                doc.fileName + " was deleted on disk");
        } else if watchEvent == fileWatcher.EventRenamed {
            NotifyExternalState(shell, docMgr, docMgr.activeIndex,
                                document.EXTERNAL_STATE_RENAMED,
                                doc.fileName + " was renamed or moved on disk");
        } else if watchEvent == fileWatcher.EventOverflow {
            var overflowState = docMgr.ExternalState(docMgr.activeIndex);
            if overflowState != document.EXTERNAL_STATE_CLEAN {
                NotifyExternalState(shell, docMgr, docMgr.activeIndex, overflowState,
                                    docMgr.ExternalStateMessage(docMgr.activeIndex));
            }
        }
    }

    /// @brief Start watching a single saved file path.
    /// @param path File path to watch.
    hide func StartWatching(path: String) {
        if hasWatcher {
            fileWatcher.Stop();
        }
        hasWatcher = false;
        watchedPath = "";
        fileWatcher = null;
        pendingReload = false;
        lastWatcherAttemptMs = Time.Clock.NowMs();
        if path == "" {
            return;
        }
        // Remember an attempted path even if the OS refuses a native watcher;
        // otherwise the frame loop would retry allocation every idle tick.
        watchedPath = path;
        if IO.File.Exists(path) == false { return; }
        try {
            var candidate = IO.Watcher.New(path);
            candidate.Start();
            if candidate.IsWatching {
                fileWatcher = candidate;
                watchedPath = path;
                hasWatcher = true;
            }
        } catch {
            // The file can disappear after Exists, and the OS can refuse a
            // watcher under descriptor pressure. Metadata polling remains live.
            fileWatcher = null;
            watchedPath = path;
            hasWatcher = false;
        }
    }

    /// @brief Stop the active file watcher and clear watcher state.
    hide func StopWatching() {
        if hasWatcher {
            fileWatcher.Stop();
        }
        hasWatcher = false;
        watchedPath = "";
        fileWatcher = null;
        pendingReload = false;
    }

    /// @brief Poll inactive open documents for external timestamp changes.
    /// @param shell Workbench shell used for warning toasts and status text.
    /// @param docMgr Open document manager to scan.
    /// @param openDocPollMs Milliseconds between timestamp scans.
    hide func PumpOpenDocumentTimestamps(shell: app_shell.AppShell,
                                         docMgr: document_manager.DocumentManager,
                                         openDocPollMs: Integer) {
        if docMgr == null {
            CancelOpenDocumentPoll();
            return;
        }
        if openDocPollActive == false {
            var now = Time.Clock.NowMs();
            if openDocPollMs > 0 and now - lastOpenDocPollMs < openDocPollMs { return; }
            BeginOpenDocumentPoll();
        }
        PumpOpenDocumentPollPage(shell, docMgr);
    }

    /// @brief Start a resumable metadata pass over all open documents.
    hide func BeginOpenDocumentPoll() {
        openDocPollActive = true;
        openDocPollIndex = 0;
        openDocPollChangedCount = 0;
        openDocPollFirstName = "";
    }

    /// @brief Visit at most OPEN_DOCUMENT_STATS_PER_FRAME documents.
    /// @details Each document may require several metadata syscalls, so the
    ///          budget is intentionally small and independent of tab count.
    hide func PumpOpenDocumentPollPage(shell: app_shell.AppShell,
                                       docMgr: document_manager.DocumentManager) {
        if openDocPollActive == false or docMgr == null { return; }
        var visited = 0;
        while openDocPollIndex < docMgr.GetCount()
              and visited < OPEN_DOCUMENT_STATS_PER_FRAME {
            var index = openDocPollIndex;
            openDocPollIndex = openDocPollIndex + 1;
            visited = visited + 1;
            var doc = docMgr.GetDocument(index);
            if doc != null {
                var state = docMgr.ExternalState(index);
                if state != document.EXTERNAL_STATE_CLEAN and doc!.externalChangeNotified == false {
                    docMgr.MarkExternalState(index, state, ExternalStateMessageForDoc(doc!, state));
                    openDocPollChangedCount = openDocPollChangedCount + 1;
                    if openDocPollFirstName == "" { openDocPollFirstName = doc!.fileName; }
                }
                if index == docMgr.activeIndex and state != document.EXTERNAL_STATE_CLEAN {
                    pendingReload = true;
                }
            }
        }
        lastOpenDocPollCount = visited;
        if openDocPollIndex >= docMgr.GetCount() {
            CompleteOpenDocumentPoll(shell);
        }
    }

    /// @brief Publish one completed metadata pass and restart its interval.
    hide func CompleteOpenDocumentPoll(shell: app_shell.AppShell) {
        if shell != null and openDocPollChangedCount == 1 {
            GUI.Toast.Warning("File changed on disk: " + openDocPollFirstName);
            shell.SetStatusLeft("Warning: external change - " + openDocPollFirstName);
        } else if shell != null and openDocPollChangedCount > 1 {
            GUI.Toast.Warning("" + openDocPollChangedCount + " open files changed on disk");
            shell.SetStatusLeft("Warning: " + openDocPollChangedCount
                                + " open files changed on disk");
        }
        openDocPollActive = false;
        openDocPollIndex = 0;
        openDocPollChangedCount = 0;
        openDocPollFirstName = "";
        lastOpenDocPollMs = Time.Clock.NowMs();
    }

    /// @brief Discard a partial pass when no document manager is available.
    hide func CancelOpenDocumentPoll() {
        openDocPollActive = false;
        openDocPollIndex = 0;
        openDocPollChangedCount = 0;
        openDocPollFirstName = "";
        lastOpenDocPollCount = 0;
    }

    /// @brief Mark a document state and emit one concise user notification.
    hide func NotifyExternalState(shell: app_shell.AppShell,
                                  docMgr: document_manager.DocumentManager,
                                  index: Integer,
                                  state: Integer,
                                  message: String) {
        if docMgr == null or index < 0 or index >= docMgr.GetCount() { return; }
        var maybeDoc = docMgr.GetDocument(index);
        if maybeDoc == null { return; }
        var doc = maybeDoc!;
        if doc.externalChangeNotified == false or doc.externalState != state {
            docMgr.MarkExternalState(index, state, message);
            pendingReload = true;
            if state == document.EXTERNAL_STATE_CHANGED {
                GUI.Toast.Warning("File changed on disk. Use File > Reload File to update.");
            } else if state == document.EXTERNAL_STATE_DELETED {
                GUI.Toast.Warning("File deleted on disk. Save will recreate it after confirmation.");
            } else if state == document.EXTERNAL_STATE_RENAMED {
                GUI.Toast.Warning("File moved on disk. Save will recreate the original path after confirmation.");
            } else {
                GUI.Toast.Warning("File missing on disk. Save will recreate it after confirmation.");
            }
            if shell != null {
                shell.SetStatusLeft("Warning: " + message);
            }
        } else if docMgr.HasExternalChange(index) {
            pendingReload = true;
        }
    }

    /// @brief Stable status text for inactive-tab polling.
    hide func ExternalStateMessageForDoc(doc: document.Document,
                                         state: Integer) -> String {
        if state == document.EXTERNAL_STATE_CHANGED {
            return doc.fileName + " changed on disk";
        }
        if state == document.EXTERNAL_STATE_DELETED {
            return doc.fileName + " was deleted on disk";
        }
        if state == document.EXTERNAL_STATE_RENAMED {
            return doc.fileName + " was renamed or moved on disk";
        }
        if state == document.EXTERNAL_STATE_MISSING {
            return doc.fileName + " is missing on disk";
        }
        return doc.fileName + " changed on disk";
    }
}
