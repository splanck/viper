//
// File: zannastudio/src/app/workspace_watcher.zia
// Purpose: Keep bounded native workspace watchers and cooperative fallback
//          scans synchronized with every open project root.
// Key invariants:
//   - Opening or refreshing a workspace performs only bounded work per frame.
//   - Ordinary file modifications never rebuild the entire watcher set.
//   - Watcher exhaustion degrades to an incremental fingerprint scan.
//   - Watchers never follow linked descendants outside an opened root.
// Ownership/Lifetime:
//   - Main owns one WorkspaceWatcherState and destroys it during IDE cleanup.
// Links: zannastudio/src/main.zia,
//        zannastudio/src/core/project_manager.zia
//
//===----------------------------------------------------------------------===//

module workspace_watcher;

bind "../ui/app_shell";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/project_index";
bind "../services/locations";
bind "../services/workspace_file_index";

bind IO = Zanna.IO;
bind Path = Zanna.IO.Path;
bind Dir = Zanna.IO.Dir;
bind Str = Zanna.String;
bind Seq = Zanna.Collections.Seq;
bind Map = Zanna.Collections.Map;
bind FileIndex = Zanna.Workspace.FileIndex;
bind Threads = Zanna.Threads;

final WORKSPACE_WATCHER_MAX_DIRS = 2048;
final WORKSPACE_WATCHER_DIR_PAGE_SIZE = 64;
final WORKSPACE_WATCHER_DIRECTORY_FILTER = ".__zanna_watcher_directory_only__";
final WORKSPACE_WATCHERS_PER_FRAME = 32;
final WORKSPACE_WATCHER_EVENTS_PER_FRAME = 32;
final WORKSPACE_FALLBACK_PAGE_SIZE = 256;
final WORKSPACE_FINGERPRINT_MODULUS = 2000000011;

// ============================================================================
// MODULE: workspace_watcher
// PURPOSE: Project-root file watching, fallback rescans, workspace index refresh,
//          and cached-location invalidation for Zanna Studio.
//
// WHERE-THIS-FITS: main.zia owns the frame loop and calls PumpWorkspaceWatcher
//          once per frame. This module owns the watcher lifecycle and the exact
//          refresh work required when files are created, deleted, renamed, or
//          externally modified inside the open workspace.
//
// TEACHING-NOTE: Keep file-system event interpretation here. UI command handlers
//          should ask this module to reindex/invalidate instead of duplicating
//          the sequence of tree refresh, semantic index reset, panel clearing,
//          and editor highlight cleanup.
// ============================================================================

/// @brief Mutable project-root watcher state owned by the main frame loop.
/// @details Zia scalar parameters are passed by value, so project watcher
///          lifecycle state is grouped into this object and updated by
///          `PumpWorkspaceWatcher`.
class WorkspaceWatcherState {
    expose IO.Watcher watcher;
    expose List[IO.Watcher] watchers;
    expose List[String] watcherPaths;
    expose Boolean watching;
    expose Boolean degraded;
    expose String rootPath;
    expose String rootSignature;
    expose List[String] rootPaths;
    expose List[String] rootIgnorePatterns;
    expose List lastEntryCounts;
    expose List lastFingerprints;
    expose Integer watcherPollPos;
    expose Threads.Throttler rescanThrottle;
    expose Integer lastEntryCount;
    expose Integer lastFingerprint;
    expose Boolean discoveryActive;
    expose Integer discoveryRootIndex;
    expose Integer discoveryPageOffset;
    expose Boolean discoveryRootAdded;
    expose Boolean fallbackScanActive;
    expose Boolean fallbackBaselineReady;
    expose Integer fallbackRootIndex;
    expose Integer fallbackPageOffset;
    expose Integer fallbackCurrentCount;
    expose Integer fallbackCurrentFingerprint;
    expose List fallbackEntryCounts;
    expose List fallbackFingerprints;
    expose Integer lastWatcherPollCount;

    /// @brief Initialize as detached from any workspace root.
    expose func init() {
        watcher = null;
        watchers = new List();
        watcherPaths = new List();
        watching = false;
        degraded = false;
        rootPath = "";
        rootSignature = "";
        rootPaths = new List();
        rootIgnorePatterns = new List();
        lastEntryCounts = new List();
        lastFingerprints = new List();
        watcherPollPos = 0;
        rescanThrottle = Threads.Throttler.New(3000);
        lastEntryCount = -1;
        lastFingerprint = 0;
        discoveryActive = false;
        discoveryRootIndex = 0;
        discoveryPageOffset = 0;
        discoveryRootAdded = false;
        fallbackScanActive = false;
        fallbackBaselineReady = false;
        fallbackRootIndex = 0;
        fallbackPageOffset = 0;
        fallbackCurrentCount = 0;
        fallbackCurrentFingerprint = 0;
        fallbackEntryCounts = new List();
        fallbackFingerprints = new List();
        lastWatcherPollCount = 0;
    }
}

/// @brief Keep recursive workspace directory watchers aligned to the open project.
/// @details `Zanna.IO.Watcher` watches one path, so Zanna Studio owns a capped set of
///          directory watchers discovered through FileIndex. Native events handle
///          normal nested edits; fallback scans run only when the watcher set is
///          degraded, capped, or sees an overflow.
expose func PumpWorkspaceWatcher(shell: app_shell.AppShell,
                                 projMgr: project_manager.ProjectManager,
                                 docMgr: document_manager.DocumentManager,
                                 indexer: project_index.ProjectIndexer,
                                 locStore: locations.LocationStore,
                                 engine: editor_engine.EditorEngine,
                                 state: WorkspaceWatcherState) {
    var root = "";
    var signature = "";
    if projMgr != null and projMgr.project != null and projMgr.project.isOpen {
        root = projMgr.project.rootPath;
        signature = projMgr.WorkspaceSignature();
    }
    if root == "" or signature == "" or Dir.Exists(root) == false {
        StopWorkspaceWatcher(state);
        return;
    }

    if state.rootSignature != signature {
        StartWorkspaceWatchers(state, projMgr);
        PumpWorkspaceWatcherDiscovery(state, projMgr);
        return;
    }

    PumpWorkspaceWatcherDiscovery(state, projMgr);
    PollWorkspaceWatchers(shell, projMgr, docMgr, indexer, locStore, engine, state);
    if state.degraded {
        PumpWorkspaceWatcherFallbackScan(shell, projMgr, docMgr, indexer, locStore, engine, state);
    }
}

/// @brief Stop and clear project-root watcher state.
/// @param state Mutable watcher state owned by the main loop.
expose func StopWorkspaceWatcher(state: WorkspaceWatcherState) {
    if state == null { return; }
    var i = 0;
    while i < state.watchers.count() {
        var w = state.watchers.get(i);
        if w != null {
            w.Stop();
        }
        i = i + 1;
    }
    if state.watching and state.watcher != null {
        state.watcher.Stop();
    }
    state.watcher = null;
    state.watchers = new List();
    state.watcherPaths = new List();
    state.watching = false;
    state.degraded = false;
    state.rootPath = "";
    state.rootSignature = "";
    state.rootPaths = new List();
    state.rootIgnorePatterns = new List();
    state.lastEntryCounts = new List();
    state.lastFingerprints = new List();
    state.watcherPollPos = 0;
    state.rescanThrottle.Reset();
    state.lastEntryCount = -1;
    state.lastFingerprint = 0;
    state.discoveryActive = false;
    state.discoveryRootIndex = 0;
    state.discoveryPageOffset = 0;
    state.discoveryRootAdded = false;
    state.fallbackScanActive = false;
    state.fallbackBaselineReady = false;
    state.fallbackRootIndex = 0;
    state.fallbackPageOffset = 0;
    state.fallbackCurrentCount = 0;
    state.fallbackCurrentFingerprint = 0;
    state.fallbackEntryCounts = new List();
    state.fallbackFingerprints = new List();
    state.lastWatcherPollCount = 0;
}

/// @brief Build the capped recursive watcher set for every workspace root.
/// @details This only resets state and records roots. Directory enumeration is
///          deliberately deferred to PumpWorkspaceWatcherDiscovery so Open Folder
///          never performs a recursive traversal in one UI frame.
func StartWorkspaceWatchers(state: WorkspaceWatcherState,
                            projMgr: project_manager.ProjectManager) {
    if state == null or projMgr == null or projMgr.IsOpen() == false { return; }
    StopWorkspaceWatcher(state);
    state.rootPath = projMgr.RootPath();
    state.rootSignature = projMgr.WorkspaceSignature();
    state.rootPaths = new List();
    state.rootIgnorePatterns = new List();
    state.watchers = new List();
    state.watcherPaths = new List();
    var rootIndex = 0;
    while rootIndex < projMgr.RootCount() {
        var root = projMgr.RootPathAt(rootIndex);
        rootIndex = rootIndex + 1;
        if root == "" or Dir.Exists(root) == false { continue; }
        state.rootPaths.Push(root);
        state.rootIgnorePatterns.Push(projMgr.RootIgnorePatternsAt(rootIndex - 1));
    }
    state.discoveryActive = state.rootPaths.count() > 0;
    state.discoveryRootIndex = 0;
    state.discoveryPageOffset = 0;
    state.discoveryRootAdded = false;
    state.fallbackScanActive = false;
    state.fallbackBaselineReady = false;
    state.watcherPollPos = 0;
}

/// @brief Add one bounded page of directory watchers.
/// @details FileIndex's private cursor resumes at discoveryPageOffset, so every
///          frame visits at most WORKSPACE_WATCHER_DIR_PAGE_SIZE workspace rows.
///          File rows are deliberately paged and ignored here: filtering them
///          out would let FileIndex scan an unbounded file-heavy tree while
///          searching for the next directory row in a single UI frame.
expose func PumpWorkspaceWatcherDiscovery(state: WorkspaceWatcherState,
                                          projMgr: project_manager.ProjectManager) -> Integer {
    if state == null or projMgr == null or state.discoveryActive == false { return 0; }
    if state.discoveryRootIndex >= state.rootPaths.count() {
        state.discoveryActive = false;
        state.watching = state.watchers.count() > 0;
        return 0;
    }
    if state.watchers.count() >= WORKSPACE_WATCHER_MAX_DIRS {
        state.degraded = true;
        state.discoveryActive = false;
        return 0;
    }

    var rootIndex = state.discoveryRootIndex;
    var root = state.rootPaths.get(rootIndex);
    if root == "" or Dir.Exists(root) == false {
        state.degraded = true;
        AdvanceWatcherDiscoveryRoot(state);
        return 0;
    }

    var added = 0;
    if state.discoveryRootAdded == false {
        var rootAlreadyKnown = ListContainsString(state.watcherPaths, root);
        if AddDirectoryWatcher(state, root) == false {
            state.discoveryActive = false;
            return 0;
        }
        if rootAlreadyKnown == false { added = added + 1; }
        state.discoveryRootAdded = true;
    }

    var ignores = "";
    if rootIndex < state.rootIgnorePatterns.count() {
        ignores = state.rootIgnorePatterns.get(rootIndex);
    }
    var page = FileIndex.Page(root,
                              WORKSPACE_WATCHER_DIRECTORY_FILTER,
                              ignores,
                              true,
                              state.discoveryPageOffset,
                              WORKSPACE_WATCHER_DIR_PAGE_SIZE);
    if Map.GetBool(page, "valid") == false {
        state.degraded = true;
        AdvanceWatcherDiscoveryRoot(state);
        return added;
    }
    var entries = Map.Get(page, "entries");
    var entryCount = 0;
    if entries != null { entryCount = Seq.get_Count(entries); }
    var i = 0;
    while entries != null and i < entryCount {
        var entry = Seq.Get(entries, i);
        i = i + 1;
        if Map.GetBool(entry, "isDirectory") {
            var dirPath = Map.GetStr(entry, "path");
            if WorkspaceWatcherCanWatchDirectory(state, dirPath) {
                var alreadyKnown = ListContainsString(state.watcherPaths, dirPath);
                if AddDirectoryWatcher(state, dirPath) == false {
                    state.discoveryActive = false;
                    return added;
                }
                if alreadyKnown == false { added = added + 1; }
            }
        }
        if state.watchers.count() >= WORKSPACE_WATCHER_MAX_DIRS {
            state.degraded = true;
            state.discoveryActive = false;
            return added;
        }
    }
    state.discoveryPageOffset = Map.GetInt(page, "nextOffset");
    var done = Map.GetBool(page, "done");
    if Map.GetBool(page, "truncated") {
        state.degraded = true;
        done = true;
    }
    if entryCount == 0 and done == false {
        state.degraded = true;
        done = true;
    }
    if done { AdvanceWatcherDiscoveryRoot(state); }
    state.watching = state.watchers.count() > 0;
    return added;
}

/// @brief Advance cooperative watcher discovery to the next workspace root.
func AdvanceWatcherDiscoveryRoot(state: WorkspaceWatcherState) {
    state.discoveryRootIndex = state.discoveryRootIndex + 1;
    state.discoveryPageOffset = 0;
    state.discoveryRootAdded = false;
    if state.discoveryRootIndex >= state.rootPaths.count() {
        state.discoveryActive = false;
        state.watching = state.watchers.count() > 0;
    }
}

/// @brief Request an additive directory pass without dropping live watchers.
func BeginAdditiveWatcherDiscovery(state: WorkspaceWatcherState) {
    if state == null or state.discoveryActive
       or state.watchers.count() >= WORKSPACE_WATCHER_MAX_DIRS {
        return;
    }
    // Do not resume a metadata snapshot across a topology change. The runtime
    // cursor is harmlessly evicted later; the next degraded scan starts a
    // coherent snapshot from offset zero after discovery settles.
    state.fallbackScanActive = false;
    state.fallbackRootIndex = 0;
    state.fallbackPageOffset = 0;
    state.fallbackCurrentCount = 0;
    state.fallbackCurrentFingerprint = 0;
    state.discoveryRootIndex = 0;
    state.discoveryPageOffset = 0;
    state.discoveryRootAdded = false;
    state.discoveryActive = state.rootPaths.count() > 0;
}

/// @brief Create and start a watcher for @p dirPath.
/// @return false when the OS refused to start the watcher (e.g. descriptor
///         exhaustion); the runtime leaves it inactive instead of trapping, so
///         the caller should stop adding more and rely on periodic rescans.
func AddDirectoryWatcher(state: WorkspaceWatcherState,
                         dirPath: String) -> Boolean {
    if state == null or dirPath == "" { return true; }
    if Dir.Exists(dirPath) == false { return true; }
    if WorkspaceWatcherCanWatchDirectory(state, dirPath) == false { return true; }
    if ListContainsString(state.watcherPaths, dirPath) { return true; }
    if state.watchers.count() >= WORKSPACE_WATCHER_MAX_DIRS {
        state.degraded = true;
        return false;
    }
    try {
        var watcher = IO.Watcher.New(dirPath);
        watcher.Start();
        if watcher.IsWatching == false {
            // Ran out of OS watch resources; degrade to fingerprint rescans.
            state.degraded = true;
            return false;
        }
        state.watchers.add(watcher);
        state.watcherPaths.add(dirPath);
        if state.watcher == null {
            state.watcher = watcher;
        }
        state.watching = true;
        return true;
    } catch {
        state.degraded = true;
    }
    return false;
}

/// @brief Test whether a watcher path stays within a root without linked descendants.
/// @details A configured root may itself be a symlink because opening that root
///          is an explicit user choice. Any linked component below it is a hard
///          boundary: watching it would surface changes from outside the
///          workspace and could trigger misleading tree/index refreshes.
expose func WorkspaceWatcherCanWatchDirectory(state: WorkspaceWatcherState,
                                              dirPath: String) -> Boolean {
    if state == null or dirPath == "" or Dir.Exists(dirPath) == false { return false; }
    var rootIndex = WorkspaceWatcherRootIndexForPath(state, dirPath);
    if rootIndex < 0 or rootIndex >= state.rootPaths.count() { return false; }
    var root = Path.Normalize(Path.Absolute(state.rootPaths.get(rootIndex)));
    var current = Path.Normalize(Path.Absolute(dirPath));
    while current != root {
        if Path.IsLink(current) { return false; }
        var parent = Path.Normalize(Path.Absolute(Path.Directory(current)));
        if parent == current
           or workspace_file_index.IsWithinRoot(parent, root) == false {
            return false;
        }
        current = parent;
    }
    return true;
}

func ListContainsString(items: List[String],
                        value: String) -> Boolean {
    var i = 0;
    while i < items.count() {
        if items.get(i) == value {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func PollWorkspaceWatchers(shell: app_shell.AppShell,
                           projMgr: project_manager.ProjectManager,
                           docMgr: document_manager.DocumentManager,
                           indexer: project_index.ProjectIndexer,
                           locStore: locations.LocationStore,
                           engine: editor_engine.EditorEngine,
                           state: WorkspaceWatcherState) -> Integer {
    if state == null { return 0; }
    state.lastWatcherPollCount = 0;
    if state.watchers.count() == 0 { return 0; }
    var changed = 0;
    var polled = 0;
    var total = state.watchers.count();
    var restartDiscovery = false;
    while polled < WORKSPACE_WATCHERS_PER_FRAME and polled < total
          and changed < WORKSPACE_WATCHER_EVENTS_PER_FRAME {
        if state.watcherPollPos >= total { state.watcherPollPos = 0; }
        var watcher = state.watchers.get(state.watcherPollPos);
        state.watcherPollPos = state.watcherPollPos + 1;
        polled = polled + 1;
        if watcher == null { continue; }
        if watcher.IsWatching == false {
            state.degraded = true;
            continue;
        }
        // Polling a quiet watcher should not allocate an empty Seq/Map graph.
        // Build a batch only after the first real event, then drain this one
        // watcher under the same global event budget used before.
        var eventType = watcher.Poll();
        var events: Any = null;
        while eventType != watcher.EventNone
              and changed < WORKSPACE_WATCHER_EVENTS_PER_FRAME {
            if events == null { events = Seq.New(); }
            Seq.Push(events, WatcherEventRecord(watcher, eventType));
            changed = changed + 1;
            if changed < WORKSPACE_WATCHER_EVENTS_PER_FRAME {
                eventType = watcher.Poll();
            }
        }
        if events != null and Seq.get_Count(events) > 0 {
            if EventsRequireFallback(events) {
                state.degraded = true;
            }
            if ObserveWorkspaceTopologyEvents(state, events) {
                restartDiscovery = true;
            }
            HandleWorkspaceWatcherEvents(shell, projMgr, docMgr, indexer, locStore, engine, events);
        }
    }
    state.lastWatcherPollCount = polled;
    if restartDiscovery {
        StartWorkspaceWatchers(state, projMgr);
    }
    return changed;
}

/// @brief Snapshot the current Watcher event into the map shape used by the
///        topology and workspace refresh handlers.
func WatcherEventRecord(watcher: IO.Watcher,
                        eventType: Integer) -> Any {
    var event = Map.New();
    Map.SetStr(event, "path", watcher.EventPath());
    var typeName = "none";
    if eventType == watcher.EventCreated {
        typeName = "created";
    } else if eventType == watcher.EventModified {
        typeName = "modified";
    } else if eventType == watcher.EventDeleted {
        typeName = "deleted";
    } else if eventType == watcher.EventRenamed {
        typeName = "renamed";
    } else if eventType == watcher.EventOverflow {
        typeName = "overflow";
    }
    Map.SetStr(event, "typeName", typeName);
    Map.SetInt(event, "type", eventType);
    Map.SetInt(event, "overflowCount",
               eventType == watcher.EventOverflow ? watcher.EventOverflowCount() : 0);
    Map.SetBool(event, "requiresRescan", eventType == watcher.EventOverflow);
    return event;
}

func EventsRequireFallback(events: Any) -> Boolean {
    if events == null { return false; }
    var i = 0;
    while i < Seq.get_Count(events) {
        var ev = Seq.Get(events, i);
        i = i + 1;
        if Map.GetBool(ev, "requiresRescan") {
            return true;
        }
    }
    return false;
}

/// @brief Incorporate directory topology events without rebuilding for file edits.
/// @details Linux/Windows commonly report a new child path, while macOS kqueue
///          reports the watched parent directory. Either shape schedules a
///          bounded additive FileIndex pass while retaining existing watchers.
///          A watched directory that was deleted/renamed, or an overflow event,
///          requests a fresh cooperative pass after the current poll batch.
/// @return True when the live watcher set must be restarted cooperatively.
expose func ObserveWorkspaceTopologyEvents(state: WorkspaceWatcherState,
                                           events: Any) -> Boolean {
    if state == null or events == null { return false; }
    var restart = false;
    var requestAdditiveDiscovery = false;
    var i = 0;
    while i < Seq.get_Count(events) {
        var ev = Seq.Get(events, i);
        i = i + 1;
        var path = Map.GetStr(ev, "path");
        var typeName = Map.GetStr(ev, "typeName");
        if Map.GetBool(ev, "requiresRescan") {
            restart = true;
            continue;
        }
        if (typeName == "deleted" or typeName == "renamed")
           and ListContainsString(state.watcherPaths, path) {
            restart = true;
            continue;
        }
        if path != "" and Dir.Exists(path) {
            var rootIndex = WorkspaceWatcherRootIndexForPath(state, path);
            if rootIndex >= 0
               and WorkspaceWatcherCanWatchDirectory(state, path)
               and WorkspaceWatcherDirectoryIgnored(state, rootIndex, path) == false {
                var known = ListContainsString(state.watcherPaths, path);
                if AddDirectoryWatcher(state, path) == false {
                    continue;
                }
                // A directory event may name a newly-created child (Linux and
                // Windows) or only the already-watched parent (macOS). In both
                // cases, a bounded additive FileIndex pass discovers any new
                // nested directories without allocating an unbounded immediate
                // child list on the input frame.
                if known == false or typeName == "modified" or typeName == "created" {
                    requestAdditiveDiscovery = true;
                }
            }
        }
    }
    if requestAdditiveDiscovery { BeginAdditiveWatcherDiscovery(state); }
    return restart;
}

/// @brief Find the longest configured workspace root containing @p path.
func WorkspaceWatcherRootIndexForPath(state: WorkspaceWatcherState,
                                      path: String) -> Integer {
    if state == null or path == "" { return -1; }
    var normalized = Path.Normalize(Path.Absolute(path));
    var best = -1;
    var bestLength = -1;
    var i = 0;
    while i < state.rootPaths.count() {
        var root = Path.Normalize(Path.Absolute(state.rootPaths.get(i)));
        if workspace_file_index.IsWithinRoot(normalized, root)
           and Str.get_Length(root) > bestLength {
            best = i;
            bestLength = Str.get_Length(root);
        }
        i = i + 1;
    }
    return best;
}

/// @brief Apply the owning root's FileIndex ignore policy to one directory.
func WorkspaceWatcherDirectoryIgnored(state: WorkspaceWatcherState,
                                      rootIndex: Integer,
                                      path: String) -> Boolean {
    if state == null or rootIndex < 0 or rootIndex >= state.rootPaths.count() {
        return true;
    }
    var ignores = "";
    if rootIndex < state.rootIgnorePatterns.count() {
        ignores = state.rootIgnorePatterns.get(rootIndex);
    }
    return workspace_file_index.ShouldIgnorePath(state.rootPaths.get(rootIndex),
                                                 path,
                                                 true,
                                                 ignores);
}

/// @brief Periodically rescan workspace structure when native watcher is quiet.
/// @details Each call consumes at most one bounded FileIndex page. This avoids
///          the former synchronous FileIndex.Status traversal, which could freeze
///          Open Folder and repeat that freeze every three seconds in a capped
///          workspace. Entry count plus a stable metadata aggregate detects the
///          same structural and modification classes incrementally.
/// @param shell Workbench shell for user-visible status.
/// @param projMgr Project tree manager to refresh.
/// @param docMgr Document manager whose open documents are re-synced.
/// @param indexer Semantic project index to rebuild.
/// @param locStore Stored locations invalidated by tree/index rebuilds.
/// @param engine Editor engine used by location invalidation.
/// @param state Watcher state carrying the last fallback snapshot.
func PumpWorkspaceWatcherFallbackScan(shell: app_shell.AppShell,
                                      projMgr: project_manager.ProjectManager,
                                      docMgr: document_manager.DocumentManager,
                                      indexer: project_index.ProjectIndexer,
                                      locStore: locations.LocationStore,
                                      engine: editor_engine.EditorEngine,
                                      state: WorkspaceWatcherState) {
    if state == null or state.rootPaths.count() == 0 { return; }
    if state.discoveryActive { return; }
    if state.fallbackScanActive == false {
        if state.rescanThrottle.TryAcquire() == false { return; }
        BeginWorkspaceFallbackScan(state);
    }
    if state.fallbackRootIndex >= state.rootPaths.count() {
        CompleteWorkspaceFallbackScan(shell, projMgr, docMgr, indexer,
                                      locStore, engine, state);
        return;
    }

    var rootIndex = state.fallbackRootIndex;
    var root = state.rootPaths.get(rootIndex);
    var ignores = "";
    if rootIndex < state.rootIgnorePatterns.count() {
        ignores = state.rootIgnorePatterns.get(rootIndex);
    }
    var page = FileIndex.Page(root,
                              "",
                              ignores,
                              true,
                              state.fallbackPageOffset,
                              WORKSPACE_FALLBACK_PAGE_SIZE);
    if Map.GetBool(page, "valid") == false {
        state.degraded = true;
        FinishWorkspaceFallbackRoot(state);
        return;
    }
    var entries = Map.Get(page, "entries");
    var entryCount = 0;
    if entries != null { entryCount = Seq.get_Count(entries); }
    var i = 0;
    while entries != null and i < entryCount {
        AccumulateWorkspaceFallbackEntry(state, Seq.Get(entries, i));
        i = i + 1;
    }
    state.fallbackPageOffset = Map.GetInt(page, "nextOffset");
    var done = Map.GetBool(page, "done");
    if Map.GetBool(page, "truncated") {
        state.degraded = true;
        done = true;
    }
    if entryCount == 0 and done == false {
        state.degraded = true;
        done = true;
    }
    if done { FinishWorkspaceFallbackRoot(state); }
    if state.fallbackRootIndex >= state.rootPaths.count() {
        CompleteWorkspaceFallbackScan(shell, projMgr, docMgr, indexer,
                                      locStore, engine, state);
    }
}

/// @brief Reset one cooperative fallback traversal.
func BeginWorkspaceFallbackScan(state: WorkspaceWatcherState) {
    state.fallbackScanActive = true;
    state.fallbackRootIndex = 0;
    state.fallbackPageOffset = 0;
    state.fallbackCurrentCount = 0;
    state.fallbackCurrentFingerprint = 0;
    state.fallbackEntryCounts = new List();
    state.fallbackFingerprints = new List();
}

/// @brief Fold one FileIndex row into a bounded, order-independent metadata key.
func AccumulateWorkspaceFallbackEntry(state: WorkspaceWatcherState,
                                      entry: Any) {
    if state == null or entry == null { return; }
    var idPart = NormalizeWorkspaceFingerprintPart(Map.GetInt(entry, "id"));
    var modifiedPart = NormalizeWorkspaceFingerprintPart(Map.GetInt(entry, "modified"));
    var sizePart = NormalizeWorkspaceFingerprintPart(Map.GetInt(entry, "size"));
    var term = idPart;
    term = (term + modifiedPart * 31) % WORKSPACE_FINGERPRINT_MODULUS;
    term = (term + sizePart * 131) % WORKSPACE_FINGERPRINT_MODULUS;
    if Map.GetBool(entry, "isDirectory") {
        term = (term + 104729) % WORKSPACE_FINGERPRINT_MODULUS;
    }
    state.fallbackCurrentFingerprint =
        (state.fallbackCurrentFingerprint + term) % WORKSPACE_FINGERPRINT_MODULUS;
    state.fallbackCurrentCount = state.fallbackCurrentCount + 1;
}

/// @brief Normalize a signed metadata value into the fallback modulus.
func NormalizeWorkspaceFingerprintPart(value: Integer) -> Integer {
    var result = value % WORKSPACE_FINGERPRINT_MODULUS;
    if result < 0 { result = result + WORKSPACE_FINGERPRINT_MODULUS; }
    return result;
}

/// @brief Commit the current root aggregate and advance the fallback cursor.
func FinishWorkspaceFallbackRoot(state: WorkspaceWatcherState) {
    state.fallbackEntryCounts.Push(state.fallbackCurrentCount);
    state.fallbackFingerprints.Push(state.fallbackCurrentFingerprint);
    state.fallbackRootIndex = state.fallbackRootIndex + 1;
    state.fallbackPageOffset = 0;
    state.fallbackCurrentCount = 0;
    state.fallbackCurrentFingerprint = 0;
}

/// @brief Compare and publish one completed cooperative fallback snapshot.
func CompleteWorkspaceFallbackScan(shell: app_shell.AppShell,
                                   projMgr: project_manager.ProjectManager,
                                   docMgr: document_manager.DocumentManager,
                                   indexer: project_index.ProjectIndexer,
                                   locStore: locations.LocationStore,
                                   engine: editor_engine.EditorEngine,
                                   state: WorkspaceWatcherState) {
    var changed = false;
    if state.fallbackBaselineReady
       and state.lastEntryCounts.count() == state.fallbackEntryCounts.count()
       and state.lastFingerprints.count() == state.fallbackFingerprints.count() {
        var i = 0;
        while i < state.fallbackEntryCounts.count() {
            if state.lastEntryCounts.get(i) != state.fallbackEntryCounts.get(i)
               or state.lastFingerprints.get(i) != state.fallbackFingerprints.get(i) {
                changed = true;
            }
            i = i + 1;
        }
    } else if state.fallbackBaselineReady {
        changed = true;
    }
    state.lastEntryCounts = state.fallbackEntryCounts;
    state.lastFingerprints = state.fallbackFingerprints;
    state.fallbackBaselineReady = true;
    state.fallbackScanActive = false;
    if state.lastEntryCounts.count() > 0 {
        state.lastEntryCount = state.lastEntryCounts.get(0);
        state.lastFingerprint = state.lastFingerprints.get(0);
    } else {
        state.lastEntryCount = -1;
        state.lastFingerprint = 0;
    }
    // Measure the next interval from completion, not from the beginning of a
    // long scan; otherwise a large workspace would rescan continuously.
    state.rescanThrottle.Reset();
    state.rescanThrottle.TryAcquire();

    if changed {
        if projMgr != null { projMgr.RefreshTree(); }
        ReindexAfterTreeMove(projMgr, indexer, docMgr);
        InvalidateWorkspaceLocations(shell, locStore, engine);
        if shell != null {
            shell.SetStatusLeft("Workspace changed: refreshed nested files");
        }
    }
}

/// @brief Apply a batch of project-root watcher events to UI and index state.
/// @details Structural changes refresh the tree and invalidate cached search
///          locations. Direct `.zia` file changes update or remove index entries
///          incrementally; overflow events trigger a full project reindex.
func HandleWorkspaceWatcherEvents(shell: app_shell.AppShell,
                                  projMgr: project_manager.ProjectManager,
                                  docMgr: document_manager.DocumentManager,
                                  indexer: project_index.ProjectIndexer,
                                  locStore: locations.LocationStore,
                                  engine: editor_engine.EditorEngine,
                                  events: Any) {
    var refreshTree = false;
    var fullReindex = false;
    var touchedIndex = false;
    var changed = 0;
    var i = 0;
    while i < Seq.get_Count(events) {
        var ev = Seq.Get(events, i);
        i = i + 1;
        changed = changed + 1;
        var eventPath = Map.GetStr(ev, "path");
        var typeName = Map.GetStr(ev, "typeName");
        if Map.GetBool(ev, "requiresRescan") {
            refreshTree = true;
            fullReindex = true;
            continue;
        }
        if eventPath != "" and Dir.Exists(eventPath) {
            refreshTree = true;
            fullReindex = true;
            continue;
        }
        if typeName == "created" or typeName == "deleted" or typeName == "renamed" {
            refreshTree = true;
        }
        if eventPath != "" and Str.ToLower(Path.Extension(eventPath)) == ".zia" {
            if indexer != null {
                if typeName == "deleted" or typeName == "renamed" {
                    indexer.RemoveFile(eventPath);
                } else {
                    indexer.UpdateFile(eventPath);
                }
            }
            touchedIndex = true;
        }
    }

    if fullReindex {
        ReindexAfterTreeMove(projMgr, indexer, docMgr);
    }
    if refreshTree and projMgr != null {
        projMgr.RefreshTree();
        InvalidateWorkspaceLocations(shell, locStore, engine);
    } else if touchedIndex and locStore != null {
        locStore.Clear();
    }
    if changed > 0 {
        if shell != null {
            shell.SetStatusLeft("Workspace changed: " + changed + " event(s)");
        }
    }
}

/// @brief Refresh the semantic index after a tree mutation.
/// @param projMgr Project manager that may own an open project root.
/// @param indexer Semantic project indexer to update.
/// @param docMgr Open documents that seed the index when no project is open.
/// @details Project workspaces are reopened from the root so added/removed files
///          are reflected. No-project sessions fall back to indexing open tabs.
expose func ReindexAfterTreeMove(projMgr: project_manager.ProjectManager,
                          indexer: project_index.ProjectIndexer,
                          docMgr: document_manager.DocumentManager) {
    if indexer == null { return; }
    if projMgr != null and projMgr.project != null and projMgr.project.isOpen {
        indexer.OpenProject(projMgr, docMgr);
        return;
    }
    indexer.SyncOpenDocuments(docMgr);
}

/// @brief Clear cached problem/search/reference locations after workspace changes.
/// @param shell Workbench shell whose panels and minimap markers are cleared.
/// @param locStore Central location store used by diagnostics and search panels.
/// @param engine Editor engine whose transient highlights are cleared.
/// @details File moves and deletes can make old line locations point at the wrong
///          source. Clearing all derived markers is safer than leaving stale UI.
expose func InvalidateWorkspaceLocations(shell: app_shell.AppShell,
                                  locStore: locations.LocationStore,
                                  engine: editor_engine.EditorEngine) {
    if locStore != null {
        locStore.Clear();
    }
    if shell != null {
        shell.toolPanels.ClearProblemsPanel();
        shell.toolPanels.ClearToolRows(shell.toolPanels.searchListBox);
        shell.toolPanels.HideSearchPanel();
        shell.toolPanels.ClearToolRows(shell.toolPanels.referencesListBox);
        shell.toolPanels.HideReferencesPanel();
        shell.workbench.minimap.ClearMarkers();
    }
    if engine != null and engine.editor != null {
        engine.editor.ClearHighlights();
    }
}
