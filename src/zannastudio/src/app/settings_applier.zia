//
// File: zannastudio/src/app/settings_applier.zia
// Purpose: Validate, apply, and persist settings edited in the Studio overlay.
// Key invariants:
//   - Invalid external font resources never partially apply the overlay.
//   - Persistence failures remain visible and never masquerade as success.
// Ownership/Lifetime: Borrows live UI, settings, editor, and scheduler models.
// Links: zannastudio/src/core/settings.zia,
//        zannastudio/src/ui/ide_overlays.zia
//
//===----------------------------------------------------------------------===//

module settings_applier;

bind "../ui/app_shell";
bind "../ui/ide_overlays";
bind "../core/settings";
bind "../editor/editor_engine";
bind "../editor/diagnostics";
bind "../editor/scheduler";
bind "../commands/file_commands";
bind "../commands/view_commands";

bind Zanna.GUI;

// ============================================================================
// MODULE: settings_applier
// PURPOSE: Copy values out of the Settings overlay, validate font choices, apply
//          them to live controllers, and persist the resulting SettingsManager.
//
// WHERE-THIS-FITS: main.zia handles the overlay action event and delegates the
//          actual apply sequence here. This prevents the event loop from owning
//          a long list of individual settings fields.
//
// TEACHING-NOTE: Settings changes touch several subsystems. Keep the order here:
//          validate external resources, copy values, reconfigure schedulers,
//          apply UI/editor settings, update file-command policy, save, then
//          invalidate diagnostics so live analysis uses the new preferences.
// ============================================================================

/// @brief Apply the currently edited Settings overlay values to the running IDE.
/// @param shell Workbench shell for status and toast feedback.
/// @param overlay Settings/about overlay controller.
/// @param appSettings Persistent settings model to mutate and save.
/// @param engine Editor engine that receives appearance/editor preferences.
/// @param liveDiag Live diagnostics controller invalidated after preference changes.
/// @param editorScheduler Scheduler reconfigured with new debounce settings.
/// @return True when settings were applied and persisted; false when validation
///         or persistence failed.
/// @details A non-empty font path is validated by loading and immediately
///          destroying the font. If validation fails, no settings are copied so
///          the user can correct the path without partially applying the form.
expose func ApplySettingsFromOverlay(shell: app_shell.AppShell,
                                     overlay: ide_overlays.IdeOverlays,
                                     appSettings: settings.SettingsManager,
                                     engine: editor_engine.EditorEngine,
                                     liveDiag: diagnostics.LiveDiagnostics,
                                     editorScheduler: scheduler.EditorScheduler) -> Boolean {
    var requestedPath = overlay.ReadFontPath();
    if requestedPath != "" {
        var previewFont = GUI.Font.Load(requestedPath);
        if previewFont == null {
            GUI.Toast.Warning("Could not load font: " + requestedPath);
            shell.SetStatusLeft("Font preview failed");
            return false;
        }
        GUI.Font.Destroy(previewFont);
        appSettings.fontPath = requestedPath;
    } else {
        appSettings.fontPath = "";
    }

    CopyOverlayValues(overlay, appSettings);
    editorScheduler.Configure(appSettings.diagnosticsDelayMs, appSettings.completionDelayMs);
    view_commands.applyPersistentSettings(shell, engine, liveDiag, appSettings);
    file_commands.SetConfirmDirtyClose(appSettings.confirmOnExitWithUnsavedChanges);
    file_commands.SetSaveFormatOptions(appSettings.trimTrailingWhitespace,
                                       appSettings.ensureFinalNewline);
    liveDiag.invalidate();
    if appSettings.Save() == false {
        shell.SetStatusLeft("Settings applied, but could not be saved");
        GUI.Toast.Error("Could not save settings");
        return false;
    }
    shell.SetStatusLeft("Settings applied");
    GUI.Toast.Success("Settings updated");
    overlay.CloseSettings();
    return true;
}

/// @brief Copy scalar values from the overlay into the settings model.
/// @param overlay Settings overlay exposing validated widget reads.
/// @param appSettings Settings manager that will be saved after live apply.
/// @details The font path is intentionally excluded because ApplySettingsFromOverlay
///          validates it first. Every other field is a scalar/toggle/spinner value
///          supplied by the overlay widgets.
func CopyOverlayValues(overlay: ide_overlays.IdeOverlays,
                       appSettings: settings.SettingsManager) {
    appSettings.fontSize = overlay.ReadFontSize();
    appSettings.tabWidth = overlay.ReadTabWidth();
    appSettings.theme = overlay.ReadTheme();
    appSettings.minimapVisible = overlay.ReadMinimapVisible();
    appSettings.statusBarVisible = overlay.ReadStatusBarVisible();
    appSettings.fullscreen = overlay.ReadFullscreen();
    appSettings.autoCheckOnSave = overlay.ReadAutoCheck();
    appSettings.codeFolding = overlay.ReadCodeFolding();
    appSettings.wordWrap = overlay.ReadWordWrap();
    appSettings.lineNumbers = overlay.ReadLineNumbers();
    appSettings.insertSpaces = overlay.ReadInsertSpaces();
    appSettings.trimTrailingWhitespace = overlay.ReadTrimTrailingWhitespace();
    appSettings.ensureFinalNewline = overlay.ReadEnsureFinalNewline();
    appSettings.autoSave = overlay.ReadAutoSave();
    appSettings.saveAllBeforeBuild = overlay.ReadSaveAllBeforeBuild();
    appSettings.diagnosticsDelayMs = overlay.ReadDiagnosticsDelayMs();
    appSettings.completionDelayMs = overlay.ReadCompletionDelayMs();
    appSettings.uiZoomPercent = overlay.ReadUiZoom();
    appSettings.restoreSession = overlay.ReadRestoreSession();
    appSettings.restoreLastProject = overlay.ReadRestoreLastProject();
    appSettings.confirmOnExitWithUnsavedChanges = overlay.ReadConfirmClose();
}
