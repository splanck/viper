//
// File: zannastudio/src/app/explorer_action_runner.zia
// Purpose: Execute Explorer mutations and shared file-open/session workflows.
// Key invariants:
//   - Rejected files never enter session history.
//   - Explorer mutations refresh every dependent document/project model.
//   - Path-only mutations never rebuild an already-focused editor buffer.
//   - Deleted documents release any live split-pane owner after disk commit.
// Ownership/Lifetime: Stateless coordinator borrowing application controllers.
// Links: zannastudio/src/commands/file_commands.zia,
//        zannastudio/src/core/project_manager.zia
//
//===----------------------------------------------------------------------===//

module explorer_action_runner;

bind "../app/context_menus";
bind "../app/workspace_watcher";
bind "../ui/app_shell";
bind "../ui/explorer_actions";
bind "../core/document";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../core/session";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../editor/project_index";
bind "../services/locations";
bind "../services/safe_io";
bind "../commands/file_commands";

bind Zanna.GUI;
bind IO = Zanna.IO;
bind Path = Zanna.IO.Path;
bind Dir = Zanna.IO.Dir;

// ============================================================================
// MODULE: explorer_action_runner
// PURPOSE: Execute Explorer overlay actions and shared file-open/session helpers.
//          The overlay owns user input; this module owns the filesystem mutation,
//          document retargeting, semantic-index refresh, and user feedback.
//
// WHERE-THIS-FITS: main.zia pumps the ExplorerActionOverlay and delegates the
//          completed action here. File tree clicks, context-menu commands, and
//          palette commands all flow through these helpers for consistent results.
//
// TEACHING-NOTE: Explorer actions have side effects across several subsystems.
//          Keep that orchestration in one module so future developers can see
//          the full checklist: save editor state, mutate disk, refresh tree,
//          update open documents/tabs, refresh the index, clear stale locations,
//          and record session history when a file opens.
// ============================================================================

/// @brief Record the active named document in the recent-file session list.
/// @param sessionMgr Session manager that owns recent-file persistence.
/// @param docMgr Document manager used to find the active document.
/// @details Untitled/new documents are intentionally skipped because they have
///          no durable path that can be reopened in a future session.
expose func RecordActiveFile(sessionMgr: session.SessionManager,
                      docMgr: document_manager.DocumentManager) {
    if sessionMgr == null or docMgr == null { return; }
    var doc = docMgr.GetActive();
    if doc != null and doc!.filePath != "" and doc!.isNew == false {
        sessionMgr.RecordRecentFile(doc!.filePath);
    }
}

/// @brief Open a file path and add it to the recent-file session list.
/// @param shell Workbench shell passed to the file command handler.
/// @param docMgr Document manager receiving the opened file.
/// @param engine Editor engine that loads the opened document.
/// @param tabs Tab controller refreshed by the file command handler.
/// @param sessionMgr Session manager used to record recent files.
/// @param path Absolute path to open.
expose func OpenFileAndRecord(shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine,
                       tabs: editor_tabs.EditorTabs,
                       sessionMgr: session.SessionManager,
                       path: String) -> Boolean {
    if file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, path) == false {
        if sessionMgr != null { sessionMgr.PruneRecentFiles(); }
        return false;
    }
    if sessionMgr != null { sessionMgr.RecordRecentFile(path); }
    return true;
}

/// @brief Apply a completed non-modal explorer action.
/// @details The floating explorer overlay gathers user intent while this helper
///          performs filesystem mutation, document retargeting, project-tree
///          refresh, semantic-index invalidation, and status updates. Keeping
///          that orchestration here gives right-click, palette, and shortcut
///          paths identical behavior.
/// @param shell Workbench shell for status, toasts, and overlay validation.
/// @param overlay Completed explorer overlay carrying target and input state.
/// @param action One of explorer_actions.ACTION_*.
/// @param projMgr Project/file-tree manager.
/// @param docMgr Open document manager.
/// @param engine Active editor engine.
/// @param tabs Editor tab controller.
/// @param sessionMgr Session manager used to record opened files.
/// @param indexer Semantic project indexer.
/// @param locStore Stored locations invalidated by tree moves.
/// @return True when the action changed the active file lifecycle and the
///         caller should suppress an IDE-authored file-watch notification.
expose func ApplyExplorerAction(shell: app_shell.AppShell,
                         overlay: explorer_actions.ExplorerActionOverlay,
                         action: Integer,
                         projMgr: project_manager.ProjectManager,
                         docMgr: document_manager.DocumentManager,
                         engine: editor_engine.EditorEngine,
                         tabs: editor_tabs.EditorTabs,
                         sessionMgr: session.SessionManager,
                         indexer: project_index.ProjectIndexer,
                         locStore: locations.LocationStore) -> Boolean {
    if action == explorer_actions.EXPLORER_ACTION_NEW_FILE {
        return ApplyExplorerNewFile(shell, overlay, projMgr, docMgr, engine, tabs, sessionMgr, indexer);
    }
    if action == explorer_actions.EXPLORER_ACTION_NEW_FOLDER {
        ApplyExplorerNewFolder(shell, overlay, projMgr);
        return false;
    }
    if action == explorer_actions.EXPLORER_ACTION_DUPLICATE {
        ApplyExplorerDuplicate(shell, overlay, projMgr, indexer);
        return false;
    }
    if action == explorer_actions.EXPLORER_ACTION_RENAME {
        return ApplyExplorerRename(shell, overlay, projMgr, docMgr, engine,
                                   tabs, indexer, locStore);
    }
    if action == explorer_actions.EXPLORER_ACTION_DELETE {
        return ApplyExplorerDelete(shell, overlay, projMgr, docMgr, engine,
                                   tabs, indexer, locStore);
    }
    return false;
}

/// @brief Create a new file from the explorer overlay.
/// @return True when the new file was opened in the editor.
func ApplyExplorerNewFile(shell: app_shell.AppShell,
                          overlay: explorer_actions.ExplorerActionOverlay,
                          projMgr: project_manager.ProjectManager,
                          docMgr: document_manager.DocumentManager,
                          engine: editor_engine.EditorEngine,
                          tabs: editor_tabs.EditorTabs,
                          sessionMgr: session.SessionManager,
                          indexer: project_index.ProjectIndexer) -> Boolean {
    var name = overlay.ReadValue();
    var dir = overlay.TargetDir();
    if ValidateExplorerChildName(shell, overlay, name) == false { return false; }
    if projMgr.CanCreateInDirectory(dir) == false {
        overlay.Reject(shell, "Choose a folder inside the workspace.");
        return false;
    }
    var newPath = Path.Join(dir, name);
    if IO.File.Exists(newPath) or Dir.Exists(newPath) {
        overlay.Reject(shell, "Target already exists.");
        return false;
    }
    if safe_io.CreateTextFile(newPath, "") == false {
        overlay.Reject(shell, "Could not create the file. Check folder permissions and try again.");
        return false;
    }
    projMgr.RefreshTree();
    indexer.UpdateFile(newPath);
    var opened = OpenFileAndRecord(shell, docMgr, engine, tabs, sessionMgr, newPath);
    if opened {
        shell.SetStatusLeft("Created: " + name);
    } else {
        shell.SetStatusLeft("Created but cannot open in the text editor: " + name);
    }
    overlay.Finish();
    return opened;
}

/// @brief Create a new folder from the explorer overlay.
func ApplyExplorerNewFolder(shell: app_shell.AppShell,
                            overlay: explorer_actions.ExplorerActionOverlay,
                            projMgr: project_manager.ProjectManager) {
    var name = overlay.ReadValue();
    var dir = overlay.TargetDir();
    if ValidateExplorerChildName(shell, overlay, name) == false { return; }
    if projMgr.CanCreateInDirectory(dir) == false {
        overlay.Reject(shell, "Choose a folder inside the workspace.");
        return;
    }
    var newPath = Path.Join(dir, name);
    if IO.File.Exists(newPath) or Dir.Exists(newPath) {
        overlay.Reject(shell, "Target already exists.");
        return;
    }
    if safe_io.MakeAll(newPath) == false {
        overlay.Reject(shell, "Could not create the folder. Check folder permissions and try again.");
        return;
    }
    projMgr.RefreshTree();
    shell.SetStatusLeft("Created folder: " + name);
    overlay.Finish();
}

/// @brief Duplicate an existing file from the explorer overlay.
func ApplyExplorerDuplicate(shell: app_shell.AppShell,
                            overlay: explorer_actions.ExplorerActionOverlay,
                            projMgr: project_manager.ProjectManager,
                            indexer: project_index.ProjectIndexer) {
    var name = overlay.ReadValue();
    var sourcePath = overlay.TargetPath();
    if ValidateExplorerChildName(shell, overlay, name) == false { return; }
    if projMgr.CanMutatePath(sourcePath) == false or IO.File.Exists(sourcePath) == false {
        overlay.Reject(shell, "Duplicate is available for files.");
        return;
    }
    var targetPath = Path.Join(Path.Directory(sourcePath), name);
    if IO.File.Exists(targetPath) or Dir.Exists(targetPath) {
        overlay.Reject(shell, "Target already exists.");
        return;
    }
    if safe_io.CopyFile(sourcePath, targetPath) == false {
        overlay.Reject(shell, "Could not duplicate the file. The target may have changed.");
        return;
    }
    projMgr.RefreshTree();
    indexer.UpdateFile(targetPath);
    shell.SetStatusLeft("Duplicated: " + name);
    overlay.Finish();
}

/// @brief Rename a file or folder from the explorer overlay.
func ApplyExplorerRename(shell: app_shell.AppShell,
                         overlay: explorer_actions.ExplorerActionOverlay,
                         projMgr: project_manager.ProjectManager,
                         docMgr: document_manager.DocumentManager,
                         engine: editor_engine.EditorEngine,
                         tabs: editor_tabs.EditorTabs,
                         indexer: project_index.ProjectIndexer,
                         locStore: locations.LocationStore) -> Boolean {
    var name = overlay.ReadValue();
    var selectedPath = overlay.TargetPath();
    if ValidateExplorerChildName(shell, overlay, name) == false { return false; }
    if selectedPath == "" {
        overlay.Reject(shell, "Choose a file or folder to rename.");
        return false;
    }
    var targetPath = Path.Join(Path.Directory(selectedPath), name);
    if IO.File.Exists(targetPath) or Dir.Exists(targetPath) {
        overlay.Reject(shell, "Target already exists.");
        return false;
    }
    var rewritePreview = projMgr.PreviewBindRewriteCount(selectedPath, name, docMgr);
    if rewritePreview > 0 {
        var previewMsg = "Rename will update " + rewritePreview + " Zia bind path";
        if rewritePreview != 1 { previewMsg = previewMsg + "s"; }
        previewMsg = previewMsg + " for " + name + ". Press Rename again to continue.";
        if overlay.validationMessage != previewMsg {
            overlay.Reject(shell, previewMsg);
            return false;
        }
    }

    file_commands.SaveEditorState(docMgr, engine);
    var renamedPath = projMgr.RenamePath(selectedPath, name, docMgr);
    if renamedPath == "" {
        var reason = projMgr.lastOperationError;
        if reason == "" { reason = "Rename failed."; }
        overlay.Reject(shell, reason);
        return false;
    }
    SynchronizeDocumentMutationUI(shell, docMgr, engine, tabs);
    file_commands.SyncRecoverySwaps(docMgr, engine);
    indexer.RemoveFile(selectedPath);
    workspace_watcher.ReindexAfterTreeMove(projMgr, indexer, docMgr);
    workspace_watcher.InvalidateWorkspaceLocations(shell, locStore, engine);
    var status = "Renamed: " + Path.Name(renamedPath);
    if projMgr.lastBindRewriteCount > 0 {
        status = status + " (" + projMgr.lastBindRewriteCount + " bind updates)";
    }
    if projMgr.lastOperationError != "" {
        status = status + ". " + projMgr.lastOperationError;
        shell.SetStatusLeft(status);
        GUI.Toast.Warning(projMgr.lastOperationError);
    } else {
        shell.SetStatusLeft(status);
    }
    overlay.Finish();
    return true;
}

/// @brief Move a file or folder to project trash from the explorer overlay.
func ApplyExplorerDelete(shell: app_shell.AppShell,
                         overlay: explorer_actions.ExplorerActionOverlay,
                         projMgr: project_manager.ProjectManager,
                         docMgr: document_manager.DocumentManager,
                         engine: editor_engine.EditorEngine,
                         tabs: editor_tabs.EditorTabs,
                         indexer: project_index.ProjectIndexer,
                         locStore: locations.LocationStore) -> Boolean {
    var deletePath = overlay.TargetPath();
    if deletePath == "" {
        overlay.Reject(shell, "Choose a file or folder to move to trash.");
        return false;
    }
    if file_commands.ConfirmCloseDocumentsUnderPath(shell, docMgr, engine, "Move to Trash",
                                                    deletePath) == false {
        shell.SetStatusLeft("Move to trash canceled");
        overlay.Finish();
        return false;
    }
    if DeletePathAndReleaseDocuments(projMgr, docMgr, engine, deletePath) == false {
        var reason = projMgr.lastOperationError;
        if reason == "" { reason = "Move to trash failed."; }
        overlay.Reject(shell, reason);
        return false;
    }
    indexer.RemoveFile(deletePath);
    workspace_watcher.ReindexAfterTreeMove(projMgr, indexer, docMgr);
    workspace_watcher.InvalidateWorkspaceLocations(shell, locStore, engine);
    SynchronizeDocumentMutationUI(shell, docMgr, engine, tabs);
    file_commands.SyncRecoverySwaps(docMgr, engine);
    if projMgr.lastTrashPath != "" {
        shell.SetStatusLeft("Moved to trash: " + Path.Name(deletePath)
                            + " -> " + projMgr.RelativePath(projMgr.lastTrashPath));
    } else {
        shell.SetStatusLeft("Moved to trash: " + Path.Name(deletePath));
    }
    overlay.Finish();
    return true;
}

/// @brief Move one Explorer path to trash and release every removed live buffer.
/// @details ProjectManager owns the filesystem transaction and removes matching
///          DocumentManager entries after it commits. Capture object references
///          first so a document displayed in either split pane can be detached
///          after success; releasing before the move would collapse the user's
///          split even when the filesystem operation fails.
/// @return True only when the path moved and all removed buffers were released.
func DeletePathAndReleaseDocuments(projMgr: project_manager.ProjectManager,
                                   docMgr: document_manager.DocumentManager,
                                   engine: editor_engine.EditorEngine,
                                   path: String) -> Boolean {
    var closingDocs: List[document.Document] = [];
    var i = 0;
    while i < docMgr.GetCount() {
        var maybeDoc = docMgr.GetDocument(i);
        if maybeDoc != null and file_commands.DocumentIsUnderPath(maybeDoc!, path) {
            closingDocs.Push(maybeDoc!);
        }
        i = i + 1;
    }

    if projMgr.DeletePath(path, docMgr) == false { return false; }

    i = 0;
    while i < closingDocs.count() {
        engine.ReleaseDocument(closingDocs.get(i));
        i = i + 1;
    }
    return true;
}

/// @brief Reconcile tabs and active-document chrome after an Explorer mutation.
/// @details Path-only changes must not call LoadDocument on the already-focused
///          document: that API intentionally creates a fresh buffer for reloads
///          and would erase undo, selection, folds, and scroll. A different
///          surviving active document is loaded only after delete released the
///          old owner.
func SynchronizeDocumentMutationUI(shell: app_shell.AppShell,
                                   docMgr: document_manager.DocumentManager,
                                   engine: editor_engine.EditorEngine,
                                   tabs: editor_tabs.EditorTabs) {
    tabs.RefreshFromDocuments(docMgr);
    var active = docMgr.GetActive();
    if active != null {
        var doc = active!;
        if engine.currentDoc != doc { engine.LoadDocument(doc); }
        shell.SelectSurface(doc.kind);
        shell.SetBreadcrumbPath(doc.filePath);
        shell.SetStatusRight(file_commands.DocStatusLabel(doc));
        return;
    }

    engine.SetText("");
    engine.ClearModified();
    shell.SetBreadcrumbPath("");
    shell.SetStatusRight("No file");
}

/// @brief Validate a user-entered explorer child name and keep the overlay open on failure.
/// @return True when the name is safe to use as a single path component.
func ValidateExplorerChildName(shell: app_shell.AppShell,
                               overlay: explorer_actions.ExplorerActionOverlay,
                               name: String) -> Boolean {
    if context_menus.IsSafeChildName(name) {
        return true;
    }
    overlay.Reject(shell, "Use a plain name, not a path.");
    return false;
}

/// @brief Reopen the most recently closed named file, if one is available.
/// @param shell Workbench shell for status/toast feedback.
/// @param docMgr Document manager that tracks recently closed paths.
/// @param engine Editor engine that loads the reopened document.
/// @param tabs Tab controller refreshed by the file-open command.
/// @param sessionMgr Session manager used to re-record the reopened file.
expose func ReopenClosedFile(shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine,
                      tabs: editor_tabs.EditorTabs,
                      sessionMgr: session.SessionManager) {
    var path = docMgr.PopRecentlyClosedPath();
    if path == "" {
        shell.SetStatusLeft("No recently closed file");
        return;
    }
    if OpenFileAndRecord(shell, docMgr, engine, tabs, sessionMgr, path) == false {
        shell.SetStatusLeft("Could not reopen: " + Path.Name(path));
        return;
    }
    shell.SetStatusLeft("Reopened: " + Path.Name(path));
}

/// @brief Compatibility entry point that opens the integrated new-file overlay.
/// @details Older tree command wiring called this helper directly. The active
///          workbench now routes through ExplorerActionOverlay so file creation
///          stays visually integrated with the IDE instead of opening a blocking
///          message box.
expose func TreeNewFile(shell: app_shell.AppShell,
                 overlay: explorer_actions.ExplorerActionOverlay,
                 projMgr: project_manager.ProjectManager) {
    var dir = context_menus.ContextDirForPath(projMgr, projMgr.SelectedPath());
    if dir == "" {
        shell.SetStatusLeft("Choose a project folder first");
        return;
    }
    overlay.OpenNewFile(shell, dir);
}

/// @brief Compatibility entry point that opens the integrated new-folder overlay.
/// @details Keeps legacy command handlers on the same non-modal explorer action
///          path used by the file tree context menu and command palette.
expose func TreeNewFolder(shell: app_shell.AppShell,
                   overlay: explorer_actions.ExplorerActionOverlay,
                   projMgr: project_manager.ProjectManager) {
    var dir = context_menus.ContextDirForPath(projMgr, projMgr.SelectedPath());
    if dir == "" {
        shell.SetStatusLeft("Choose a project folder first");
        return;
    }
    overlay.OpenNewFolder(shell, dir);
}

/// @brief Compatibility entry point that opens the integrated rename overlay.
/// @details Rename confirmation and bind-rewrite preview now stay inside the
///          explorer overlay so the operation feels like an IDE interaction.
expose func TreeRename(shell: app_shell.AppShell,
                overlay: explorer_actions.ExplorerActionOverlay,
                projMgr: project_manager.ProjectManager) {
    var selectedPath = projMgr.SelectedPath();
    if projMgr.CanMutatePath(selectedPath) == false {
        shell.SetStatusLeft("Choose a file or folder inside the project to rename");
        return;
    }
    overlay.OpenRename(shell, selectedPath);
}

/// @brief Compatibility entry point that opens the integrated move-to-trash overlay.
/// @details The active deletion path uses an inline confirmation panel and then
///          delegates to ApplyExplorerDelete after the user confirms.
expose func TreeDelete(shell: app_shell.AppShell,
                overlay: explorer_actions.ExplorerActionOverlay,
                projMgr: project_manager.ProjectManager) {
    var deletePath = projMgr.SelectedPath();
    if projMgr.CanMutatePath(deletePath) == false {
        shell.SetStatusLeft("Choose a file or folder inside the project to move to trash");
        return;
    }
    overlay.OpenDelete(shell, deletePath);
}

/// @brief Per-frame: apply a completed file-tree drag-and-drop as a file move.
/// @details Reads the latched drop (source/target node paths), moves the source
///          into the target folder through ProjectManager.MovePathInto (which
///          updates open documents and project binds), reindexes, refreshes the
///          active editor, and reports the result. Invalid drops are rejected
///          with a status message.
expose func PumpTreeDrops(shell: app_shell.AppShell,
                          projMgr: project_manager.ProjectManager,
                          docMgr: document_manager.DocumentManager,
                          engine: editor_engine.EditorEngine,
                          tabs: editor_tabs.EditorTabs,
                          indexer: project_index.ProjectIndexer,
                          locStore: locations.LocationStore) -> Boolean {
    var tree = shell.workbench.sidebarTree;
    if tree == null { return false; }
    if tree.WasDropReceived() == false { return false; }
    var src = tree.GetDropSourceData();
    var dst = tree.GetDropTargetData();
    tree.ClearDrop();
    if src == "" or dst == "" { return false; }

    file_commands.SaveEditorState(docMgr, engine);
    var movedPath = projMgr.MovePathInto(src, dst, docMgr);
    if movedPath == "" {
        var reason = projMgr.lastOperationError;
        if reason == "" { reason = "Move canceled (invalid drop target)"; }
        shell.SetStatusLeft(reason);
        return false;
    }

    SynchronizeDocumentMutationUI(shell, docMgr, engine, tabs);
    file_commands.SyncRecoverySwaps(docMgr, engine);
    workspace_watcher.ReindexAfterTreeMove(projMgr, indexer, docMgr);
    workspace_watcher.InvalidateWorkspaceLocations(shell, locStore, engine);
    var status = "Moved " + Path.Name(movedPath) + " to folder";
    if projMgr.lastBindRewriteCount > 0 {
        status = status + " (" + projMgr.lastBindRewriteCount + " bind updates)";
    }
    if projMgr.lastOperationError != "" {
        status = status + ". " + projMgr.lastOperationError;
        GUI.Toast.Warning(projMgr.lastOperationError);
    }
    shell.SetStatusLeft(status);
    return true;
}
