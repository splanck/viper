final MOUSE_BUTTON_RIGHT = 1;

// ============================================================================
// MODULE: zannastudio (main entry point)
// PURPOSE: Bootstraps every subsystem and runs the per-frame event loop.
//          The loop polls input, dispatches commands via menu items +
//          shortcuts + command palette, ticks completion / diagnostics /
//          hover / symbols, syncs document <-> tab state, and renders.
//
// WHERE-THIS-FITS: Top of the dependency tree. Owns the lifecycle of
//          every controller; everyone else is constructed here.
//
// KEY-DESIGN-CHOICES:
//   * SINGLE FRAME LOOP, MANY POLLS. Rather than callbacks, the IDE
//     uses a frame-driven design: each frame, every controller is
//     polled. Commands are dispatched by checking which menu item /
//     toolbar item / shortcut / palette command was hit this frame.
//   * COMMAND DISPATCH PATTERN. The `dispatch_helpers.Triggered(name, menuItem,
//     toolbarItem, paletteSelection)` helper checks all three input
//     sources for a single command name and returns true if any of
//     them fired. This unifies "user clicked menu" / "user clicked
//     toolbar" / "user pressed shortcut" / "user picked from
//     palette" without duplicating handler dispatch.
//   * PER-DOCUMENT INTELLISENSE. Every controller (completion /
//     diagnostics / hover / symbols) has its source path set to the
//     active document's path each frame. This is what enables the
//     path-aware `*ForFile` completion APIs to resolve relative bind
//     paths against the right directory.
//   * STARTUP ORDER MATTERS. Shell construction first (so widgets
//     exist), then engine setup (which adds the editor widget into
//     the shell), then minimap binding, then settings load and
//     theme apply. Mixing this ordering generally explodes because
//     widget parents must exist before children.
//
// HOW-TO-READ: Constants -> main() top-of-function (component
//   construction) -> shortcut registration -> command palette
//   population -> welcome doc / settings load -> the giant while
//   loop with per-frame work.
// ============================================================================

final WIN_WIDTH = 1280;
final WIN_HEIGHT = 800;
final WINDOW_SIZE_PERCENT = 72;  // % of monitor size on first launch.
final AUTO_SAVE_IDLE_MS = 1500;
final OPEN_DOC_EXTERNAL_POLL_MS = 1000;
final POLL_WAIT_BACKGROUND_MS = 8;
final POLL_WAIT_IDLE_FOCUSED_MS = 50;
final POLL_WAIT_IDLE_UNFOCUSED_MS = 150;
final BREADCRUMB_SCAN_LINES_PER_FRAME = 256;
final SESSION_RESTORE_ENTRIES_PER_PAINT = 1;
final RECOVERY_SCAN_ENTRIES_PER_PAINT = 1;
final PANEL_SPLIT_SAVE_IDLE_MS = 600;

/// @brief Route the selected Problems quick fix through its real source anchor.
/// @details Filtering rebuilds ListBox rows, so the tool-panel model supplies
///          durable action/location metadata. Opening that location first makes
///          the existing asynchronous diagnostic controller validate and edit
///          exactly the diagnostic the user selected.
func HandleProblemsQuickFix(
    shell: app_shell.AppShell,
    docMgr: document_manager.DocumentManager,
    engine: editor_engine.EditorEngine,
    tabs: editor_tabs.EditorTabs,
    projMgr: project_manager.ProjectManager,
    locStore: locations.LocationStore,
    controller: diagnostic_edit_commands.DiagnosticActionController) {
    if shell == null or controller == null
       or shell.toolPanels.ProblemsQuickFixWasRequested() == false {
        return;
    }
    diagnostic_edit_commands.StartSelectedProblemAction(
        controller, shell, docMgr, engine, tabs, projMgr, locStore);
    shell.toolPanels.SetProblemsActionBusy(controller.IsBusy());
}

/// @brief Return whether the active document owns the visible CodeEditor.
func ActiveUsesTextEditor(docMgr: document_manager.DocumentManager) -> Boolean {
    if docMgr == null { return false; }
    var doc = docMgr.GetActive();
    return doc != null and doc!.isReadOnlyPreview == false
           and file_utils.IsVisualKind(doc!.kind) == false;
}

/// @brief Return the active surface's cheap content revision.
/// @details Visual editors own their canonical Document content directly, so
///          auto-save/recovery must not watch the hidden CodeEditor revision.
func ActiveContentRevision(docMgr: document_manager.DocumentManager,
                           engine: editor_engine.EditorEngine,
                           scene2D: scene_editor_2d.SceneEditor2D,
                           scene3D: scene_editor_3d.SceneEditor3D) -> Integer {
    if docMgr != null {
        var doc = docMgr.GetActive();
        if doc != null {
            if doc!.kind == file_utils.DOC_KIND_SCENE_2D and scene2D != null {
                return scene2D.GetRevision();
            }
            if doc!.kind == file_utils.DOC_KIND_SCENE_3D and scene3D != null {
                return scene3D.GetRevision();
            }
        }
    }
    if engine == null { return 0; }
    return engine.GetRevision();
}

/// @brief Flush unsettled dock location and splitter changes before shutdown.
/// @details Normal frames debounce writes; shutdown consumes every remaining
///          edge-trigger and commits it together as one settings transaction.
func FlushWorkspaceLayout(shell: app_shell.AppShell,
                          engine: editor_engine.EditorEngine,
                          projMgr: project_manager.ProjectManager,
                          activityBarCtrl: activity_bar.ActivityBar,
                          appSettings: settings.SettingsManager,
                          savePending: Boolean) {
    if shell == null or appSettings == null { return; }
    var shouldSave = savePending;
    var changedPct = shell.toolPanels.TakeChangedSplitPercent();
    if changedPct >= 0 {
        appSettings.bottomPanelSplitPct = changedPct;
        shouldSave = true;
    }
    var changedSidePct = shell.toolPanels.TakeChangedSidePanelWidthPercent();
    if changedSidePct >= 0 {
        appSettings.sidePanelWidthPct = changedSidePct;
        shouldSave = true;
    }
    if shell.toolPanels.TakeFloatingToolPanelGeometryChanged() {
        appSettings.floatingToolPanelX =
            shell.toolPanels.GetFloatingToolPanelX();
        appSettings.floatingToolPanelY =
            shell.toolPanels.GetFloatingToolPanelY();
        appSettings.floatingToolPanelWidth =
            shell.toolPanels.GetFloatingToolPanelWidth();
        appSettings.floatingToolPanelHeight =
            shell.toolPanels.GetFloatingToolPanelHeight();
        shouldSave = true;
    }
    var changedSidebarPct =
        shell.workbench.TakeChangedSidebarWidthPercent();
    if changedSidebarPct >= 0 {
        appSettings.sidebarWidthPct = changedSidebarPct;
        shouldSave = true;
    }
    var changedSidebarPosition =
        shell.workbench.TakeChangedSidebarPosition();
    if changedSidebarPosition != "" {
        appSettings.primarySidebarPosition = changedSidebarPosition;
        shouldSave = true;
    }
    if HasPersistentSidebarContext(projMgr, activityBarCtrl)
       and appSettings.sidebarVisible != shell.workbench.IsSidebarVisible() {
        appSettings.sidebarVisible = shell.workbench.IsSidebarVisible();
        shouldSave = true;
    }
    if activityBarCtrl != null
       and appSettings.activeSidebarViewId != activityBarCtrl.activeView {
        appSettings.activeSidebarViewId = activityBarCtrl.activeView;
        shouldSave = true;
    }
    if engine != null {
        var changedEditorSplitPct =
            engine.TakeChangedSplitPositionPercent();
        if changedEditorSplitPct >= 0 {
            appSettings.editorSplitPct = changedEditorSplitPct;
            shouldSave = true;
        }
    }
    var changedDock = shell.toolPanels.TakeChangedDockLocation();
    if changedDock != "" {
        appSettings.panelDockPosition = changedDock;
        shouldSave = true;
    }
    var changedGroupLayout =
        shell.toolPanels.TakeChangedToolPanelGroupLayout();
    if changedGroupLayout != "" {
        appSettings.toolPanelGroupLayout = changedGroupLayout;
        shouldSave = true;
    }
    var changedTabOrder = shell.toolPanels.TakeChangedToolTabOrder();
    if changedTabOrder != "" {
        appSettings.toolPanelTabOrder = changedTabOrder;
        shouldSave = true;
    }
    var activeToolPanelId = shell.toolPanels.GetActiveToolPanelId();
    if appSettings.activeToolPanelId != activeToolPanelId {
        appSettings.activeToolPanelId = activeToolPanelId;
        shouldSave = true;
    }
    if shouldSave { appSettings.Save(); }
}

/// @brief Re-point the focused-pane controllers at engine.editor after a split
///        or focus change. Minimap and find bar bind the widget directly; the
///        completion controller re-syncs via SetEngine. Hover and signature read
///        engine.editor fresh each frame, so they need no explicit re-bind.
func RebindFocusedPane(shell: app_shell.AppShell,
                       engine: editor_engine.EditorEngine,
                       completer: completion.CompletionController) {
    if shell == null or engine == null { return; }
    if shell.workbench.minimap != null { shell.workbench.minimap.BindEditor(engine.editor); }
    if shell.workbench.findBar != null { shell.workbench.findBar.BindEditor(engine.editor); }
    if completer != null { completer.SetEngine(engine); }
}

/// @brief Select a distinct open document for a new secondary pane.
func SplitCompanionDocument(docMgr: document_manager.DocumentManager,
                            primary: document.Document) -> document.Document? {
    if docMgr == null or editor_engine.IsSplitDocumentEligible(primary) == false {
        return null;
    }
    var i = 0;
    while i < docMgr.GetCount() {
        var candidate = docMgr.GetDocument(i);
        if candidate != null and candidate! != primary
           and editor_engine.IsSplitDocumentEligible(candidate!) {
            return candidate;
        }
        i = i + 1;
    }
    return null;
}

/// @brief Open a safe two-document split, optionally explaining rejection.
func OpenSplitWithCompanion(shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            notifyOnFailure: Boolean) -> Boolean {
    var companion = SplitCompanionDocument(docMgr, engine.currentDoc);
    if companion == null {
        if notifyOnFailure {
            var reason = "Open a second file before splitting the editor";
            shell.SetStatusLeft(reason);
        }
        return false;
    }
    return engine.SplitRight(companion!);
}

/// @brief Align the global document/tab model with the physically focused pane.
func SyncFocusedPaneSelection(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine,
                              tabs: editor_tabs.EditorTabs) -> Boolean {
    if shell == null or docMgr == null or engine == null or tabs == null
       or engine.currentDoc == null {
        return false;
    }
    var focused = engine.currentDoc;
    var focusedIndex = docMgr.SetActiveDocument(focused);
    if focusedIndex < 0 { return false; }
    tabs.SetActive(focusedIndex);

    // FocusOtherPane captures the pane it leaves. Reflect that dirty state even
    // when typing and native focus movement arrived in the same frame.
    var i = 0;
    while i < docMgr.GetCount() {
        var doc = docMgr.GetDocument(i);
        if doc != null { tabs.SetModified(i, doc!.isModified); }
        i = i + 1;
    }

    shell.SelectSurface(focused.kind);
    if focused.isNew { shell.SetBreadcrumbPath(""); }
    else { shell.SetBreadcrumbPath(focused.filePath); }
    shell.SetStatusRight(file_commands.DocStatusLabel(focused));
    return true;
}

/// @brief Rebuild an exact durable left/right editor arrangement.
/// @details The session maps durable file slots back to Document identities
///          during validation. Startup therefore never substitutes a different
///          tab when one saved pane owner is missing or rejected.
func OpenRestoredSplit(docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine,
                       tabs: editor_tabs.EditorTabs,
                       sessionMgr: session.SessionManager) -> Boolean {
    if docMgr == null or engine == null or tabs == null or sessionMgr == null {
        return false;
    }
    var first = sessionMgr.RestoredSplitFirstDocument();
    var second = sessionMgr.RestoredSplitSecondDocument();
    if first == null or second == null or first! == second!
       or editor_engine.IsSplitDocumentEligible(first!) == false
       or editor_engine.IsSplitDocumentEligible(second!) == false {
        return false;
    }
    var firstIndex = docMgr.SetActiveDocument(first!);
    if firstIndex < 0 { return false; }
    tabs.SetActive(firstIndex);
    engine.LoadDocument(first!);
    if engine.SplitRight(second!) == false { return false; }
    if sessionMgr.splitSecondFocused {
        engine.FocusOtherPane();
    }
    return true;
}

/// @brief Consume and publish an engine-level pane focus transition.
func ReconcilePaneFocus(shell: app_shell.AppShell,
                        docMgr: document_manager.DocumentManager,
                        engine: editor_engine.EditorEngine,
                        tabs: editor_tabs.EditorTabs,
                        completer: completion.CompletionController) {
    if engine == null or engine.ConsumePaneFocusChanged() == false { return; }
    SyncFocusedPaneSelection(shell, docMgr, engine, tabs);
    RebindFocusedPane(shell, engine, completer);
}

func hasArg(name: String) -> Boolean {
    var i = 0;
    while i < Env.GetArgumentCount() {
        if Env.GetArgument(i) == name { return true; }
        i = i + 1;
    }
    return false;
}

func handleCommandLine() -> Boolean {
    if hasArg("--version") {
        Terminal.Say(build_info.BuildSummary());
        return true;
    }
    if hasArg("--help") or hasArg("-h") {
        Terminal.Say("Usage: zannastudio [--version] [--help] [file]");
        return true;
    }
    return false;
}

func envFlagEnabled(name: String) -> Boolean {
    if Env.HasVariable(name) == false { return false; }
    var v = Str.ToLower(Env.GetVariable(name));
    return v == "1" or v == "true" or v == "yes" or v == "on";
}

/// @brief Compute how long the next PollWait may sleep without delaying live work.
func computePollWaitMs(shell: app_shell.AppShell,
                       focusThrottle: focus_throttle.FocusThrottle,
                       buildSys: build_system.BuildSystem,
                       dbgSession: debug_session.DebugSession,
                       terminalCtrl: terminal_controller.TerminalController,
                       editorScheduler: scheduler.EditorScheduler,
                       indexer: project_index.ProjectIndexer,
                       projMgr: project_manager.ProjectManager,
                       overlays: ide_overlays.IdeOverlays) -> Integer {
    if shell == null { return 0; }
    if buildSys != null and buildSys.IsActive() { return 0; }
    if dbgSession != null and dbgSession.IsActive() { return 0; }
    if terminalCtrl != null and terminalCtrl.HasActiveSession() { return 0; }
    if shell.commandPalette != null and shell.commandPalette.IsVisible() { return 0; }
    if overlays != null and (overlays.settingsVisible or overlays.aboutVisible) { return 0; }

    if editorScheduler != null and editorScheduler.QueuedCount() > 0 {
        return POLL_WAIT_BACKGROUND_MS;
    }
    if indexer != null and indexer.indexing {
        return POLL_WAIT_BACKGROUND_MS;
    }
    if projMgr != null and projMgr.fileCacheRefreshing {
        return POLL_WAIT_BACKGROUND_MS;
    }

    if focusThrottle != null and focusThrottle.focused == false {
        return POLL_WAIT_IDLE_UNFOCUSED_MS;
    }
    return POLL_WAIT_IDLE_FOCUSED_MS;
}

/// @brief Return whether sidebar visibility has meaningful persistent context.
/// @details Explorer/SCM need a workspace; Run and Debug also serves standalone
///          source files and therefore persists visibility without a project.
func HasPersistentSidebarContext(
    projMgr: project_manager.ProjectManager,
    activityBarCtrl: activity_bar.ActivityBar) -> Boolean {
    if projMgr != null and projMgr.IsOpen() { return true; }
    return activityBarCtrl != null
        and activityBarCtrl.activeView == activity_bar.VIEW_RUN_DEBUG;
}

/// @brief Program entry point. Constructs the IDE and runs the main loop.
func main() {
    if handleCommandLine() { return; }

    // ========================================================================
    // Initialize components
    // ========================================================================
    var shell = new app_shell.AppShell();
    var docMgr = new document_manager.DocumentManager();
    var engine = new editor_engine.EditorEngine();
    var tabs = new editor_tabs.EditorTabs();
    var projMgr = new project_manager.ProjectManager();
    var activityBarCtrl = new activity_bar.ActivityBar();
    var runDebugView = new run_debug_view.RunDebugView();
    var scmView = new scm_view.ScmView();
    var diffOverlay = new diff_view.DiffView();
    var renamePreview =
        new workspace_edit_preview.WorkspaceEditPreview();
    var terminalCtrl = new terminal_controller.TerminalController();
    var buildSys = new build_system.BuildSystem();
    var breakpointStore = new breakpoints.BreakpointStore();
    var dbgSession = new debug_session.DebugSession();
    var locStore = new locations.LocationStore();
    var commandRegistry = new command_registry.CommandRegistry();
    var languageServices = new language_service.LanguageServiceManager();
    var activeWorkbench = new workbench_state.ActiveWorkbenchState();
    var perfMon = new perf_monitor.PerfMonitor();
    var indexer = new project_index.ProjectIndexer();
    var editorScheduler = new scheduler.EditorScheduler();
    var searcher = new search_commands.SearchController();
    var paletteCtrl = new command_palette_controller.CommandPaletteController();
    var fileWatchCtrl = new file_watch_controller.FileWatchController();
    var focusThrottle = new focus_throttle.FocusThrottle();
    var basicWorkspaceCommands =
        new basic_workspace_commands.BasicWorkspaceCommandController();
    var diagnosticActions =
        new diagnostic_edit_commands.DiagnosticActionController();
    var ziaWorkspaceCommands =
        new zia_workspace_commands.ZiaWorkspaceCommandController();
    indexer.SetScheduler(editorScheduler);

    shell.Build("Zanna Studio", WIN_WIDTH, WIN_HEIGHT);
    view_commands.applyShellFont(shell);
    shell.ApplyWorkbenchWindowConstraints();
    shell.CenterAndSize(WINDOW_SIZE_PERCENT);
    shell.SetStatusLeft("Starting...");
    shell.SetStatusCenter("");
    shell.SetStatusRight("");

    var overlays = new ide_overlays.IdeOverlays();
    overlays.Setup(shell);
    var explorerOverlay = new explorer_actions.ExplorerActionOverlay();
    explorerOverlay.Setup(shell);
    var debugOverlay = new debug_breakpoint_overlay.DebugBreakpointOverlay();
    debugOverlay.Setup(shell);
    var commandInputOverlay = new command_input.CommandInputOverlay();
    commandInputOverlay.Setup(shell);
    renamePreview.Setup(shell);
    basicWorkspaceCommands.renamePreview = renamePreview;
    ziaWorkspaceCommands.renamePreview = renamePreview;

    var welcomeView = new welcome_view.WelcomeView();
    welcomeView.Setup(shell.workbench.welcomeHost,
                      shell.workbench.editorRow,
                      shell.workbench.scene2DHost,
                      shell.workbench.scene3DHost);
    // Paint a complete, truthful startup surface before synchronous settings,
    // session, recovery, and project restoration can occupy the UI thread.
    // This replaces the former blank split-pane frame that looked like a hung
    // or mangled editor on larger workspaces.
    shell.SetSidebarVisible(false);
    welcomeView.SetStartupMode(true);
    welcomeView.SetShown(true);
    shell.SetWelcomeStatusMode(true);
    // Let the platform deliver its initial show/resize events before the first
    // paint. Activating the window earlier exposes a blank workbench while the
    // startup widgets are still being constructed; rendering without this
    // poll can also paint against the pre-show window extent on some backends.
    shell.Activate();
    shell.Poll();
    shell.Render();

    engine.Setup(shell.workbench.editorRow);
    engine.editor.Focus();
    var scene2DEditor = new scene_editor_2d.SceneEditor2D();
    scene2DEditor.Setup(shell.workbench.scene2DHost, shell.app);
    scene2DEditor.SetWorkspaceContext(projMgr);
    var scene3DEditor = new scene_editor_3d.SceneEditor3D();
    scene3DEditor.Setup(shell.workbench.scene3DHost, shell.app);
    scene3DEditor.SetWorkspaceContext(projMgr);

    var completer = new completion.CompletionController();
    completer.Setup(engine.editor, shell.app);
    completer.SetEngine(engine);
    completer.SetScheduler(editorScheduler);
    completer.SetWorkspaceContext(projMgr, docMgr);

    // Real-time diagnostics (errors-as-you-type)
    var liveDiag = new diagnostics.LiveDiagnostics();
    liveDiag.SetScheduler(editorScheduler);
    var semHighlighter = new semantic_tokens.SemanticHighlighter();

    // Hover tooltips (type info on mouse dwell)
    var hoverCtrl = new hover.HoverController();
    hoverCtrl.setup(shell.app);
    hoverCtrl.SetScheduler(editorScheduler);

    var sigCtrl = new signature.SignatureController();
    sigCtrl.setup(shell.app);
    sigCtrl.SetScheduler(editorScheduler);

    var inlayCtrl = new inlay_hints.InlayHintController();

    // Symbol outline panel (below diagnostics, toggled via View menu)
    var symbolOutline = new symbols.SymbolOutline();
    symbolOutline.setup(shell.workbench.editorArea);
    symbolOutline.SetScheduler(editorScheduler);

    var languageFrame = new language_tool_frame.LanguageToolFrameController();
    languageFrame.Setup(completer, liveDiag, semHighlighter, hoverCtrl,
                        sigCtrl, inlayCtrl, symbolOutline, indexer,
                        editorScheduler, perfMon);

    shell.workbench.minimap = GUI.Minimap.New(shell.workbench.editorRow);
    shell.workbench.minimap.SetWidth(100);
    shell.workbench.minimap.BindEditor(engine.editor);

    tabs.Setup(shell.workbench.tabBar);
    projMgr.Setup(shell.workbench.sidebarTree);
    runDebugView.Setup(shell.workbench.runDebugViewHost);
    activityBarCtrl.Setup(shell.workbench.explorerView,
                          shell.workbench.scmViewHost,
                          shell.workbench.runDebugViewHost,
                          shell.workbench.abExplorer,
                          shell.workbench.abSourceControl,
                          shell.workbench.abRunDebug);
    scmView.Setup(shell.workbench.scmViewHost);
    diffOverlay.Setup(shell);
    scmView.diffOverlay = diffOverlay;
    terminalCtrl.Setup(shell.toolPanels.terminalPanel, shell.toolPanels.terminalPane,
                       shell.toolPanels.terminalKill, shell.toolPanels.terminalRestart);
    terminalCtrl.SetupButtons(shell.toolPanels.terminalNew, shell.toolPanels.terminalNext);

    shell.ApplyCommandShortcuts(commandRegistry);
    commandRegistry.InstallShortcuts();
    paletteCtrl.ResetToCommands(shell, commandRegistry, languageServices.ziaService);

    // ========================================================================
    // Load persistent settings and restore session
    // ========================================================================
    var appSettings = new settings.SettingsManager();
    appSettings.Load();
    if appSettings.keybindingOverrides != "" {
        commandRegistry.ApplyOverrides(appSettings.keybindingOverrides);
        commandRegistry.InstallShortcuts();
        shell.ApplyCommandShortcuts(commandRegistry);
    }
    breakpointStore.Setup(appSettings.settingsPath);
    breakpointStore.Load();
    editorScheduler.Configure(appSettings.diagnosticsDelayMs, appSettings.completionDelayMs);
    view_commands.applyPersistentSettings(shell, engine, liveDiag, appSettings);
    file_commands.SetConfirmDirtyClose(appSettings.confirmOnExitWithUnsavedChanges);
    file_commands.SetSaveFormatOptions(appSettings.trimTrailingWhitespace,
                                       appSettings.ensureFinalNewline);

    var sessionMgr = new session.SessionManager();
    sessionMgr.Setup(appSettings.settingsPath);
    var recoveryStore = new recovery_store.RecoveryStore();
    recoveryStore.Setup(appSettings.settingsDir);
    file_commands.SetRecoveryStore(recoveryStore);
    var restoredCount = 0;
    var restoreSplitRequested = false;
    if appSettings.restoreSession {
        // Restore one durable root/tab per painted startup frame. Individual
        // text files are already size-bounded; this outer budget prevents a
        // large 256-tab session from making the native window look hung while
        // all of them are validated, read, hashed, and added to the tab bar.
        var restoreJob = sessionMgr.BeginRestore(docMgr, projMgr, tabs);
        while restoreJob.active {
            sessionMgr.PumpRestore(restoreJob, SESSION_RESTORE_ENTRIES_PER_PAINT);
            var restoreProgress = sessionMgr.RestoreProgressText(restoreJob);
            welcomeView.SetStartupProgress(restoreProgress);
            shell.SetStatusLeft(restoreProgress);
            shell.Poll();
            shell.Render();
        }
        restoredCount = restoreJob.restoredCount;
        restoreSplitRequested = sessionMgr.splitActive;
    }

    // Page the flat recovery directory even after a clean exit so abandoned
    // worker staging files are retired without an unbounded Setup enumeration.
    // On an unclean exit the same pass validates and retains bounded swap pairs.
    var recoveryScan = recoveryStore.BeginRecoveryScan(recoveryStore.uncleanExit);
    while recoveryScan.active {
        recoveryStore.PumpRecoveryScan(recoveryScan, RECOVERY_SCAN_ENTRIES_PER_PAINT);
        var recoveryScanStatus = "Cleaning recovery data: "
            + recoveryScan.entriesScanned + " entries";
        if recoveryStore.uncleanExit {
            recoveryScanStatus = "Checking crash recovery: "
                + recoveryScan.entriesScanned + " entries";
        }
        welcomeView.SetStartupProgress(recoveryScanStatus);
        shell.SetStatusLeft(recoveryScanStatus);
        shell.Poll();
        shell.Render();
    }

    // After an unclean exit, re-open captured documents one painted item at a
    // time. Keep swaps durable until a later save or clean shutdown so a second
    // immediate crash cannot lose the recovered buffer.
    if recoveryStore.uncleanExit {
        var recovered = recoveryScan.records;
        var rc = recovered.count();
        var ri = 0;
        var recoveredOpened = 0;
        var lastRecoveredIndex = -1;
        while ri < rc {
            var rec = recovered.get(ri) as recovery_store.RecoveryRecord;
            var countBeforeRecovery = docMgr.GetCount();
            var rdoc = docMgr.ApplyRecoveredText(rec.path, rec.content);
            if docMgr.GetCount() > countBeforeRecovery {
                tabs.AddTab(rdoc.fileName, 1);
                tabs.SetTooltip(docMgr.activeIndex, rdoc.filePath);
            }
            tabs.SetModified(docMgr.activeIndex, true);
            lastRecoveredIndex = docMgr.activeIndex;
            recoveredOpened = recoveredOpened + 1;
            ri = ri + 1;
            var recoveryApplyStatus = "Recovering unsaved files: " + ri + "/" + rc;
            welcomeView.SetStartupProgress(recoveryApplyStatus);
            shell.SetStatusLeft(recoveryApplyStatus);
            shell.Poll();
            shell.Render();
        }
        if recoveredOpened > 0 {
            docMgr.SetActive(lastRecoveredIndex);
            tabs.SetActive(lastRecoveredIndex);
            restoredCount = restoredCount + recoveredOpened;
            // Crash-recovered work is the most urgent startup context. Keep the
            // last recovered buffer focused instead of replacing it with an
            // older clean-session pane arrangement.
            restoreSplitRequested = false;
            GUI.Toast.Info("Recovered " + recoveredOpened + " unsaved file(s) from a previous session");
        }
        if recoveryScan.truncated {
            GUI.Toast.Warning("Some crash-recovery entries exceeded Studio safety limits");
        }
    }

    // Shell/Open With launches provide one positional source path. Open it
    // after session recovery so the explicitly requested document wins focus.
    var startupFile = startup_arguments.CommandLineFile();
    if startupFile != "" {
        if explorer_action_runner.OpenFileAndRecord(
               shell, docMgr, engine, tabs, sessionMgr, startupFile) {
            restoredCount = restoredCount + 1;
            // An explicit Open With / command-line target owns startup focus.
            // Do not replace it with the prior session's pane arrangement.
            restoreSplitRequested = false;
        }
    }

    // Restore the selected workspace view only after project restoration so
    // Source Control is already pointed at the live root before it is revealed.
    if projMgr.IsOpen() {
        scmView.SetRepo(projMgr.RootPath());
    }
    activityBarCtrl.ShowView(appSettings.activeSidebarViewId);

    // A blank Explorer pane makes the no-project opening surface look broken
    // and pushes the welcome card visibly off-center. Restore the pane only
    // when session loading actually produced a workspace.
    shell.SetSidebarVisible(settings.EffectiveSidebarVisibility(
        projMgr.IsOpen(), appSettings.sidebarVisible,
        activityBarCtrl.activeView));
    welcomeView.SetStartupMode(false);

    // ========================================================================
    // Show the welcome surface if no session was restored, otherwise load the
    // restored active document. No fake editable "welcome document" is created.
    // ========================================================================
    if restoredCount == 0 {
        welcomeView.Refresh(sessionMgr);
        welcomeView.SetShown(true);
        shell.SetWelcomeStatusMode(true);
        shell.SetStatusRight("");
    } else {
        welcomeView.SetShown(false);
        shell.SetWelcomeStatusMode(false);
        var restoredDoc = docMgr.GetActive();
        if restoredDoc != null {
            var exactSplitAvailable = restoreSplitRequested
                and sessionMgr.RestoredSplitFirstDocument() != null
                and sessionMgr.RestoredSplitSecondDocument() != null;
            var exactSplitOpened = false;
            if exactSplitAvailable {
                exactSplitOpened = OpenRestoredSplit(
                    docMgr, engine, tabs, sessionMgr);
            }
            if exactSplitOpened == false {
                engine.LoadDocument(restoredDoc);
            }
            if restoreSplitRequested and exactSplitAvailable == false {
                OpenSplitWithCompanion(shell, docMgr, engine, false);
            }
            SyncFocusedPaneSelection(shell, docMgr, engine, tabs);
            engine.ConsumePaneFocusChanged();
            RebindFocusedPane(shell, engine, completer);
        }
    }

    if projMgr.IsOpen() {
        terminalCtrl.SetCwd(projMgr.RootPath());
    }
    shell.toolPanels.SetActiveToolPanelId(appSettings.activeToolPanelId);

    shell.SetStatusLeft("Ready");
    if restoredCount == 0 {
        shell.SetStatusCenter("");
    } else {
        shell.SetStatusCenter("Ln 1, Col 1  |  Lines: " + engine.GetLineCount());
    }

    // Present the resolved welcome/document state before the event loop's
    // first idle wait. Without this frame, a fast restore can replace the
    // startup card in memory but leave the native window showing only its
    // empty shell until an unrelated event wakes the renderer.
    shell.Render();

    shell.workbench.findBar.BindEditor(engine.editor);

    // File watcher state lives in FileWatchController so the frame loop only
    // resets/bumps it when commands resolve external-change notifications.
    var workspaceWatcherState = new workspace_watcher.WorkspaceWatcherState();

    // Command routing dependencies are stable after startup.
    var commandContext = new command_context.CommandContext();
    commandContext.shell = shell;
    commandContext.docMgr = docMgr;
    commandContext.projMgr = projMgr;
    commandContext.engine = engine;
    commandContext.tabs = tabs;
    commandContext.activityBarCtrl = activityBarCtrl;
    commandContext.scene2DEditor = scene2DEditor;
    commandContext.scene3DEditor = scene3DEditor;
    commandContext.buildSys = buildSys;
    commandContext.dbgSession = dbgSession;
    commandContext.terminalCtrl = terminalCtrl;
    commandContext.scmView = scmView;
    commandContext.diffOverlay = diffOverlay;
    commandContext.fileWatchCtrl = fileWatchCtrl;
    commandContext.workspaceWatcherState = workspaceWatcherState;
    commandContext.indexer = indexer;
    commandContext.breakpointStore = breakpointStore;
    commandContext.sessionMgr = sessionMgr;
    commandContext.locStore = locStore;
    commandContext.commandRegistry = commandRegistry;
    commandContext.paletteCtrl = paletteCtrl;
    commandContext.explorerOverlay = explorerOverlay;
    commandContext.debugOverlay = debugOverlay;
    commandContext.commandInputOverlay = commandInputOverlay;
    commandContext.overlays = overlays;
    commandContext.liveDiag = liveDiag;
    commandContext.symbolOutline = symbolOutline;
    commandContext.sigCtrl = sigCtrl;
    commandContext.searcher = searcher;
    commandContext.basicWorkspaceCommands = basicWorkspaceCommands;
    commandContext.diagnosticActions = diagnosticActions;
    commandContext.ziaWorkspaceCommands = ziaWorkspaceCommands;
    commandContext.appSettings = appSettings;
    // Session restore happens after the view controllers are constructed.
    // Apply its workspace through the same transition used by every live
    // folder-open route so SCM, terminal, Explorer, and indexing agree before
    // the first interactive frame.
    main_command_dispatcher.ActivateOpenWorkspace(commandContext, true);

    // Welcome-surface visibility tracking (refresh recents on transition to shown).
    var prevDocCount = -1;

    // Cursor tracking for dot-trigger and status bar caching
    var prevCursorLine = 1;
    var prevCursorCol  = 1;
    var prevStatusRevision = engine.GetRevision();
    var prevStatusLineCount = engine.GetLineCount();
    var prevStatusCursorCount = engine.editor.GetCursorCount();
    var didPostFirstFrameActivate = false;
    var autoSaveRevision = ActiveContentRevision(
        docMgr, engine, scene2DEditor, scene3DEditor);
    var autoSaveActiveIndex = docMgr.activeIndex;
    var autoSaveDebounce = Threads.Debouncer.New(AUTO_SAVE_IDLE_MS);
    var recoveryRevision = autoSaveRevision;
    var recoveryActiveIndex = docMgr.activeIndex;
    var recoveryDebounce = Threads.Debouncer.New(2000);
    var scmGutter = new scm_gutter_controller.ScmGutterController();
    var scmGutterRevision = engine.GetRevision();
    var scmGutterDebounce = Threads.Debouncer.New(700);
    var scmGutterActiveIndex = -1;
    var breadcrumbFunctions = new breadcrumb_index.IncrementalBreadcrumbIndex();
    var panelSplitSaveDebounce = Threads.Debouncer.New(PANEL_SPLIT_SAVE_IDLE_MS);
    var panelSplitSavePending = false;

    // ========================================================================
    // Main event loop
    // ========================================================================
    while shell != null and shell.ShouldClose() == false {
        perfMon.BeginFrame();
        shell.PollWait(computePollWaitMs(shell, focusThrottle, buildSys,
                                         dbgSession, terminalCtrl, editorScheduler,
                                         indexer, projMgr, overlays));

        // Ration background work (indexing, budgeted tools, workspace watching)
        // when the window is unfocused. Input, rendering, process streams
        // (build/debug/terminal), and auto-save are never gated.
        focusThrottle.Update(shell.app);
        var allowBackground = focusThrottle.AllowBackgroundWork();

        // Activity bar — switch the persistent left workbench view.
        if shell.workbench.abExplorer.WasClicked() {
            activityBarCtrl.ShowView(activity_bar.VIEW_EXPLORER);
            shell.SetSidebarVisible(true);
        }
        if shell.workbench.abSourceControl.WasClicked() {
            activityBarCtrl.ShowView(activity_bar.VIEW_SCM);
            shell.SetSidebarVisible(true);
            if projMgr.IsOpen() { scmView.SetRepo(projMgr.RootPath()); }
            else { scmView.SetRepo(""); }
        }
        if shell.workbench.abRunDebug.WasClicked() {
            activityBarCtrl.ShowView(activity_bar.VIEW_RUN_DEBUG);
            shell.SetSidebarVisible(true);
        }
        scmView.HandleEvents();
        diffOverlay.Pump();
        terminalCtrl.Pump();

        // Welcome / start surface: shown only when no documents are open.
        var curDocCount = docMgr.GetCount();
        var activeBeforeSplitRepair = docMgr.GetActive();
        if engine.ReconcileSplitEligibility(activeBeforeSplitRepair) {
            SyncFocusedPaneSelection(shell, docMgr, engine, tabs);
            engine.ConsumePaneFocusChanged();
            RebindFocusedPane(shell, engine, completer);
        }
        var textEditorContextAvailable = ActiveUsesTextEditor(docMgr);
        var hasBuildTarget = build_commands.HasExecutionTarget(docMgr, projMgr);
        var hasDebugTarget = debug_commands.HasDebugTarget(docMgr);
        shell.SetCommandContextAvailable(curDocCount > 0,
                                         projMgr.IsOpen(),
                                         hasBuildTarget,
                                         hasDebugTarget);
        if curDocCount == 0 {
            if prevDocCount != 0 {
                welcomeView.Refresh(sessionMgr);
                shell.SetStatusCenter("");
                shell.SetStatusRight("");
            }
            shell.SetWelcomeStatusMode(true);
            welcomeView.SetShown(true);
            if welcomeView.newFileButton.WasClicked() {
                file_commands.handleNew(shell, docMgr, engine, tabs);
            }
            if welcomeView.newScene2DButton.WasClicked() {
                file_commands.handleNewScene2D(shell, docMgr, engine, tabs);
            }
            if welcomeView.newScene3DButton.WasClicked() {
                file_commands.handleNewScene3D(shell, docMgr, engine, tabs);
            }
            if welcomeView.openFileButton.WasClicked()
               and file_commands.handleOpen(shell, docMgr, engine, tabs) {
                explorer_action_runner.RecordActiveFile(sessionMgr, docMgr);
                fileWatchCtrl.ResetPendingReload();
            }
            if welcomeView.openFolderButton.WasClicked() {
                if file_commands.handleOpenFolder(shell, projMgr) {
                    main_command_dispatcher.ActivateOpenWorkspace(commandContext, true);
                    sessionMgr.RecordRecentProject(projMgr.RootPath());
                    welcomeView.Refresh(sessionMgr);
                }
            }
            var recentSel = welcomeView.TakeRecentSelection();
            if Str.StartsWith(recentSel, "folder:") {
                var recentFolder = Str.Mid(recentSel, 8);
                if projMgr.OpenFolder(recentFolder) {
                    main_command_dispatcher.ActivateOpenWorkspace(commandContext, true);
                    sessionMgr.RecordRecentProject(recentFolder);
                } else {
                    sessionMgr.PruneRecentProjects();
                }
                welcomeView.Refresh(sessionMgr);
            } else if Str.StartsWith(recentSel, "file:") {
                var recentPath = Str.Mid(recentSel, 6);
                if explorer_action_runner.OpenFileAndRecord(
                       shell, docMgr, engine, tabs, sessionMgr, recentPath) {
                    fileWatchCtrl.ResetPendingReload();
                } else {
                    welcomeView.Refresh(sessionMgr);
                }
            }
        } else {
            shell.SetWelcomeStatusMode(false);
            welcomeView.SetShown(false);
        }
        prevDocCount = curDocCount;

        var activeVisualDoc = docMgr.GetActive();
        if activeVisualDoc != null {
            if scene2DEditor.Pump(activeVisualDoc) {
                tabs.SetModified(docMgr.activeIndex,
                                 activeVisualDoc!.isModified);
                shell.SetStatusRight(file_commands.DocStatusLabel(activeVisualDoc));
            }
            if scene3DEditor.Pump(activeVisualDoc) {
                tabs.SetModified(docMgr.activeIndex,
                                 activeVisualDoc!.isModified);
                shell.SetStatusRight(file_commands.DocStatusLabel(activeVisualDoc));
            }
        }
        if shell.WasCloseRequested() {
            if file_commands.handleExit(shell, docMgr, engine) {
                FlushWorkspaceLayout(
                    shell, engine, projMgr, activityBarCtrl, appSettings,
                    panelSplitSavePending);
                diffOverlay.Shutdown();
                basicWorkspaceCommands.Shutdown();
                diagnosticActions.Shutdown();
                ziaWorkspaceCommands.Shutdown();
                lifecycle_controller.CleanupIde(shell, docMgr, projMgr, engine, buildSys, dbgSession,
                                                terminalCtrl, fileWatchCtrl, workspaceWatcherState,
                                                indexer, breakpointStore, sessionMgr, recoveryStore);
                return;
            }
        }

        // ====================================================================
        // Code Completion + IDE Intelligence
        // ====================================================================
        languageFrame.BeginFrame(shell, docMgr, projMgr, languageServices,
                                 activeWorkbench, paletteCtrl, commandRegistry,
                                 appSettings, engine);
        var activeService = languageFrame.activeService;
        shell.SetTextEditorContextAvailable(textEditorContextAvailable);
        commandRegistry.SetTextEditorAvailable(textEditorContextAvailable);
        var visualSceneEditorAvailable = false;
        var canCutSurface = textEditorContextAvailable;
        var canCopySurface = textEditorContextAvailable;
        var canPasteSurface = textEditorContextAvailable;
        var canSelectAllSurface = textEditorContextAvailable;
        var canDuplicateSurface = textEditorContextAvailable;
        var canDeleteSceneSurface = false;
        var canFindSurface = textEditorContextAvailable;
        if textEditorContextAvailable == false and activeVisualDoc != null
           and activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_2D {
            visualSceneEditorAvailable = true;
            canFindSurface = true;
            canCutSurface = scene2DEditor.HasSceneObjectSelection();
            canCopySurface = canCutSurface;
            canPasteSurface = scene2DEditor.CanPasteSceneObjects();
            canSelectAllSurface =
                scene2DEditor.CanSelectAllSceneObjects();
            canDuplicateSurface = canCutSurface;
            canDeleteSceneSurface = canCutSurface;
        } else if textEditorContextAvailable == false
                  and activeVisualDoc != null
                  and activeVisualDoc!.kind
                      == file_utils.DOC_KIND_SCENE_3D {
            visualSceneEditorAvailable = true;
            canFindSurface = true;
            canCutSurface = scene3DEditor.HasSceneNodeSelection();
            canCopySurface = canCutSurface;
            canPasteSurface = scene3DEditor.CanPasteSceneNodes();
            canSelectAllSurface =
                scene3DEditor.CanSelectAllSceneNodes();
            canDuplicateSurface = canCutSurface;
            canDeleteSceneSurface = canCutSurface;
        }
        shell.SetSurfaceEditActionsAvailable(
            canCutSurface, canCopySurface,
            canPasteSurface, canSelectAllSurface,
            canDuplicateSurface, canDeleteSceneSurface,
            canFindSurface);
        commandRegistry.SetVisualSceneEditorAvailable(
            visualSceneEditorAvailable);
        commandRegistry.SetSplitEditorContext(
            textEditorContextAvailable
                and engine.PaneCount() < 2
                and SplitCompanionDocument(docMgr, engine.currentDoc) != null,
            engine.PaneCount() == 2);
        var canUndoSurface = false;
        var canRedoSurface = false;
        if textEditorContextAvailable and engine != null and engine.editor != null {
            canUndoSurface = engine.editor.CanUndo();
            canRedoSurface = engine.editor.CanRedo();
        } else if activeVisualDoc != null
                  and activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_2D {
            canUndoSurface = scene2DEditor.CanUndo();
            canRedoSurface = scene2DEditor.CanRedo();
        } else if activeVisualDoc != null
                  and activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_3D {
            canUndoSurface = scene3DEditor.CanUndo();
            canRedoSurface = scene3DEditor.CanRedo();
        }
        shell.SetEditHistoryAvailable(canUndoSurface, canRedoSurface);
        if textEditorContextAvailable == false and activeVisualDoc != null {
            var visualService = "2D Scene";
            if activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_3D {
                visualService = "3D Scene";
            }
            shell.SetWorkspaceStatus(activeWorkbench.activeProjectName, visualService);
        }
        if allowBackground {
            languageFrame.PumpWorkspace(shell, projMgr, docMgr, engine);
        }
        languageFrame.SyncBreakpoints(engine, breakpointStore);
        if textEditorContextAvailable {
            debug_commands.PumpGutter(shell, docMgr, engine, breakpointStore);
        }

        languageFrame.RouteCompletionKeys();
        languageFrame.PumpForegroundTools(shell, docMgr, engine, tabs, locStore,
                                          buildSys, dbgSession, breakpointStore);
        debug_commands.PumpRunDebugView(
            shell, runDebugView, docMgr, engine, tabs, buildSys,
            breakpointStore, dbgSession, debugOverlay,
            appSettings.saveAllBeforeBuild);
        diagnosticActions.Pump(shell, docMgr, engine, projMgr);
        shell.toolPanels.SetProblemsActionBusy(diagnosticActions.IsBusy());
        ziaWorkspaceCommands.Pump(shell, docMgr, projMgr, engine, tabs,
                                  indexer, locStore);
        // Keep keyboard shortcuts and command-palette selections under the
        // same target/job/debug policy as the visible menu and toolbar.
        commandRegistry.ApplyCommandContext(curDocCount > 0,
                                            projMgr.IsOpen(),
                                            hasBuildTarget,
                                            hasDebugTarget,
                                            buildSys.IsActive(),
                                            dbgSession.IsActive(),
                                            dbgSession.stopped,
                                            activeService);
        if allowBackground {
            languageFrame.PumpBudgetedTools(shell, docMgr, engine, locStore,
                                            searcher, projMgr);
        }
        languageFrame.HandleManualIntelligenceTriggers(engine);
        languageFrame.HandleTypedLanguageTriggers(engine);
        var curCursorLine = languageFrame.curCursorLine;
        var curCursorCol = languageFrame.curCursorCol;

        // ====================================================================
        // Command Palette + trigger source detection
        // ====================================================================
        // Live palette prefix modes (":" go to line) update rows per keystroke.
        paletteCtrl.PumpLiveQuery(shell, commandRegistry, activeService);
        quick_open_commands.PumpQuickOpenPalette(shell, projMgr, paletteCtrl);

        var cpSelected = "";
        if shell.commandPalette.WasSelected() {
            var rawPaletteSelection = shell.commandPalette.GetSelected();
            if paletteCtrl.IsGoto() {
                edit_commands.handleGoToLineText(shell, engine,
                                                 paletteCtrl.GotoArgFromId(rawPaletteSelection));
                paletteCtrl.ResetToCommands(shell, commandRegistry, activeService);
            } else if paletteCtrl.IsQuickOpen() {
                search_commands.HandleQuickOpenPaletteSelection(shell, projMgr, docMgr, engine, tabs,
                                                                rawPaletteSelection);
                paletteCtrl.ResetToCommands(shell, commandRegistry, activeService);
            } else {
                cpSelected = commandRegistry.NormalizeId(rawPaletteSelection);
                if cpSelected != "" and commandRegistry.IsExecutable(cpSelected, activeService) == false {
                    var disabledReason = commandRegistry.DisabledReason(cpSelected, activeService);
                    shell.SetStatusLeft(disabledReason);
                    cpSelected = "";
                }
            }
        }
        paletteCtrl.RestoreCommandsWhenClosed(shell, commandRegistry, activeService);
        if Shortcuts.WasTriggered("palette") {
            paletteCtrl.OpenCommands(shell, commandRegistry, activeService);
        }

        var suppressTreeOpen = context_menu_dispatcher.PumpContextMenus(
            shell, engine, projMgr, docMgr, tabs, sessionMgr, fileWatchCtrl,
            buildSys, locStore, searcher, explorerOverlay, paletteCtrl,
            commandRegistry, indexer, activeService, dbgSession, breakpointStore,
            commandInputOverlay, basicWorkspaceCommands, ziaWorkspaceCommands,
            appSettings);

        // Apply any completed file-tree drag-and-drop as a file move.
        if explorer_action_runner.PumpTreeDrops(shell, projMgr, docMgr, engine,
                                                tabs, indexer, locStore) {
            fileWatchCtrl.ResetPendingReload();
        }

        // ====================================================================
        // Dispatch commands via trigger helper
        // ====================================================================

        if main_command_dispatcher.DispatchCommandContext(commandContext,
                                                          cpSelected,
                                                          suppressTreeOpen) {
            FlushWorkspaceLayout(
                shell, engine, projMgr, activityBarCtrl, appSettings,
                panelSplitSavePending);
            diffOverlay.Shutdown();
            basicWorkspaceCommands.Shutdown();
            diagnosticActions.Shutdown();
            ziaWorkspaceCommands.Shutdown();
            lifecycle_controller.CleanupIde(shell, docMgr, projMgr, engine, buildSys, dbgSession,
                                            terminalCtrl, fileWatchCtrl, workspaceWatcherState,
                                            indexer, breakpointStore, sessionMgr, recoveryStore);
            return;
        }

        // Split-editor commands. Handled here (not the dispatcher) so the
        // focused-pane controllers can be re-bound with `completer` in scope.
        if dispatch_helpers.TriggeredNoMenu("spliteditorright", cpSelected) {
            if engine.PaneCount() < 2 {
                if OpenSplitWithCompanion(shell, docMgr, engine, true) {
                    RebindFocusedPane(shell, engine, completer);
                }
            }
        }
        if dispatch_helpers.TriggeredNoMenu("focusotherpane", cpSelected) {
            engine.FocusOtherPane();
        }
        if dispatch_helpers.TriggeredNoMenu("closesplit", cpSelected) {
            engine.CloseSplit();
        }
        // Click-to-focus: when the other pane gains keyboard focus, retarget the
        // focused-pane controllers to it.
        engine.SyncFocusFromWidgets();
        ReconcilePaneFocus(shell, docMgr, engine, tabs, completer);

        // FindBar per-frame updates
        if shell.workbench.findBar.IsVisible() {
            shell.workbench.findBar.FindNext();
            shell.workbench.findBar.FindPrevious();
            shell.workbench.findBar.Replace();
            shell.workbench.findBar.ReplaceAll();
            var matchCount = shell.workbench.findBar.GetMatchCount();
            if matchCount > 0 {
                var currMatch = shell.workbench.findBar.GetCurrentMatch();
                shell.SetStatusLeft("" + currMatch + " of " + matchCount + " matches");
            }
        }

        // Diagnostics panel: click to navigate to error line
        if shell.toolPanels.diagListBox.WasSelectionChanged() {
            var selItem = shell.toolPanels.diagListBox.Selected;
            if selItem != null {
                locStore.OpenLocation(shell, docMgr, engine, tabs, GUI.ListBox.ItemGetData(selItem));
            }
        }

        if shell.toolPanels.outputListBox.WasSelectionChanged() {
            var outItem = shell.toolPanels.outputListBox.Selected;
            if outItem != null {
                var data = GUI.ListBox.ItemGetData(outItem);
                if locations.IsLocationData(data) {
                    locStore.OpenLocation(shell, docMgr, engine, tabs, data);
                } else if Str.StartsWith(data, "file:") {
                    var recentPath = Str.Mid(data, 6);
                    if explorer_action_runner.OpenFileAndRecord(
                           shell, docMgr, engine, tabs, sessionMgr, recentPath) {
                        fileWatchCtrl.ResetPendingReload();
                    }
                }
            }
        }
        if shell.toolPanels.searchListBox.WasSelectionChanged() {
            var searchItem = shell.toolPanels.searchListBox.Selected;
            if searchItem != null {
                var searchData = GUI.ListBox.ItemGetData(searchItem);
                if locations.IsLocationData(searchData) {
                    locStore.OpenLocation(shell, docMgr, engine, tabs, searchData);
                }
            }
        }
        if shell.toolPanels.referencesListBox.WasSelectionChanged() {
            var refItem = shell.toolPanels.referencesListBox.Selected;
            if refItem != null {
                var refData = GUI.ListBox.ItemGetData(refItem);
                if locations.IsLocationData(refData) {
                    locStore.OpenLocation(shell, docMgr, engine, tabs, refData);
                }
            }
        }
        if shell.toolPanels.callStackListBox.WasSelectionChanged() {
            debug_commands.handleCallStackSelect(shell, docMgr, engine, tabs, dbgSession);
        }
        if shell.toolPanels.variablesListBox.WasSelectionChanged() {
            debug_commands.HandleVariableActivate(shell, dbgSession);
        }
        debug_commands.HandleWatchToolbar(shell, dbgSession);
        shell.workbench.PumpSidebarDocking();
        shell.toolPanels.PumpToolTabs();
        if shell.toolPanels.TakeDebugConsoleClearRequest() {
            debug_commands.handleClearDebugConsole(shell, dbgSession);
        }
        HandleProblemsQuickFix(shell, docMgr, engine, tabs, projMgr, locStore,
                               diagnosticActions);
        var workspaceLayoutChanged = false;
        var changedPanelSplitPct = shell.toolPanels.TakeChangedSplitPercent();
        if changedPanelSplitPct >= 0 {
            appSettings.bottomPanelSplitPct = changedPanelSplitPct;
            workspaceLayoutChanged = true;
        }
        var changedSidePanelPct =
            shell.toolPanels.TakeChangedSidePanelWidthPercent();
        if changedSidePanelPct >= 0 {
            appSettings.sidePanelWidthPct = changedSidePanelPct;
            workspaceLayoutChanged = true;
        }
        if shell.toolPanels.TakeFloatingToolPanelGeometryChanged() {
            appSettings.floatingToolPanelX =
                shell.toolPanels.GetFloatingToolPanelX();
            appSettings.floatingToolPanelY =
                shell.toolPanels.GetFloatingToolPanelY();
            appSettings.floatingToolPanelWidth =
                shell.toolPanels.GetFloatingToolPanelWidth();
            appSettings.floatingToolPanelHeight =
                shell.toolPanels.GetFloatingToolPanelHeight();
            workspaceLayoutChanged = true;
        }
        var changedSidebarPct =
            shell.workbench.TakeChangedSidebarWidthPercent();
        if changedSidebarPct >= 0 {
            appSettings.sidebarWidthPct = changedSidebarPct;
            workspaceLayoutChanged = true;
        }
        var changedSidebarPosition =
            shell.workbench.TakeChangedSidebarPosition();
        if changedSidebarPosition != "" {
            appSettings.primarySidebarPosition = changedSidebarPosition;
            shell.SetStatusLeft(
                "Primary sidebar moved " + changedSidebarPosition);
            workspaceLayoutChanged = true;
        }
        if HasPersistentSidebarContext(projMgr, activityBarCtrl)
           and appSettings.sidebarVisible != shell.workbench.IsSidebarVisible() {
            appSettings.sidebarVisible = shell.workbench.IsSidebarVisible();
            workspaceLayoutChanged = true;
        }
        if appSettings.activeSidebarViewId != activityBarCtrl.activeView {
            appSettings.activeSidebarViewId = activityBarCtrl.activeView;
            workspaceLayoutChanged = true;
        }
        var changedEditorSplitPct =
            engine.TakeChangedSplitPositionPercent();
        if changedEditorSplitPct >= 0 {
            appSettings.editorSplitPct = changedEditorSplitPct;
            workspaceLayoutChanged = true;
        }
        var changedPanelDock = shell.toolPanels.TakeChangedDockLocation();
        if changedPanelDock != "" {
            appSettings.panelDockPosition = changedPanelDock;
            workspaceLayoutChanged = true;
        }
        var changedToolGroupLayout =
            shell.toolPanels.TakeChangedToolPanelGroupLayout();
        if changedToolGroupLayout != "" {
            appSettings.toolPanelGroupLayout = changedToolGroupLayout;
            workspaceLayoutChanged = true;
        }
        var changedToolTabOrder = shell.toolPanels.TakeChangedToolTabOrder();
        if changedToolTabOrder != "" {
            appSettings.toolPanelTabOrder = changedToolTabOrder;
            workspaceLayoutChanged = true;
        }
        var activeToolPanelId = shell.toolPanels.GetActiveToolPanelId();
        if appSettings.activeToolPanelId != activeToolPanelId {
            appSettings.activeToolPanelId = activeToolPanelId;
            workspaceLayoutChanged = true;
        }
        if workspaceLayoutChanged {
            panelSplitSavePending = true;
            panelSplitSaveDebounce.Signal();
        } else if panelSplitSavePending and panelSplitSaveDebounce.get_IsReady() {
            view_commands.PersistSettings(shell, appSettings);
            panelSplitSavePending = false;
            panelSplitSaveDebounce.Reset();
        }

        // Inline overlay actions
        // Preferences search spans setting keywords and live command bindings.
        // Populate commands before applying card visibility so a command-name
        // match can keep Keybindings visible even when it is not a section word.
        if overlays.settingsVisible {
            if overlays.keybindingListInitialized == false {
                overlays.PopulateKeybindings(commandRegistry,
                                             overlays.settingsFilterInput.get_Text());
                overlays.ApplySettingsFilter(
                    overlays.settingsFilterInput.get_Text());
            }
            if overlays.settingsFilterClearButton != null
               and overlays.settingsFilterClearButton.WasClicked() {
                overlays.settingsFilterInput.SetText("");
                overlays.settingsFilterInput.Focus();
                overlays.PopulateKeybindings(commandRegistry, "");
                overlays.ApplySettingsFilter("");
            } else if overlays.settingsFilterInput != null
                      and overlays.settingsFilterInput.WasChanged() {
                var settingsFilter = overlays.settingsFilterInput.get_Text();
                overlays.PopulateKeybindings(commandRegistry, settingsFilter);
                overlays.ApplySettingsFilter(settingsFilter);
            }
            if overlays.keybindingSetButton != null
               and overlays.keybindingSetButton.WasClicked() {
                var keyId = overlays.SelectedKeybindingId();
                if keyId != "" {
                    var newShortcut = commandRegistry.NormalizeShortcut(
                        overlays.keybindingShortcutInput.get_Text());
                    if commandRegistry.IsValidShortcut(newShortcut) == false {
                        overlays.keybindingStatusLabel.SetText(
                            "Invalid shortcut. Join modifiers with + and separate chord strokes with a space.");
                        shell.SetStatusLeft("Keybinding was not changed");
                        GUI.Toast.Warning("Invalid keyboard shortcut");
                    } else {
                        appSettings.keybindingOverrides = commandRegistry.UpsertOverride(
                            appSettings.keybindingOverrides, keyId, newShortcut);
                        var keyEntry = commandRegistry.Find(keyId);
                        if keyEntry != null { keyEntry.shortcut = newShortcut; }
                        commandRegistry.InstallShortcuts();
                        shell.ApplyCommandShortcuts(commandRegistry);
                        var keybindingSaved = appSettings.Save();
                        overlays.PopulateKeybindings(commandRegistry,
                                                     overlays.settingsFilterInput.get_Text());
                        overlays.ApplySettingsFilter(
                            overlays.settingsFilterInput.get_Text());
                        var keybindingStatus = commandRegistry.ShortcutConflictSummary();
                        if keybindingSaved == false {
                            keybindingStatus = "Could not save keybinding changes. " + keybindingStatus;
                            shell.SetStatusLeft("Keybinding changed, but could not be saved");
                            GUI.Toast.Error("Could not save keybinding changes");
                        }
                        overlays.keybindingStatusLabel.SetText(keybindingStatus);
                    }
                }
            }
            if overlays.keybindingClearButton != null
               and overlays.keybindingClearButton.WasClicked() {
                var resetId = overlays.SelectedKeybindingId();
                if resetId != "" {
                    appSettings.keybindingOverrides = commandRegistry.RemoveOverride(
                        appSettings.keybindingOverrides, resetId);
                    var resetEntry = commandRegistry.Find(resetId);
                    if resetEntry != null {
                        resetEntry.shortcut = commandRegistry.DefaultShortcutFor(resetId);
                    }
                    commandRegistry.InstallShortcuts();
                    shell.ApplyCommandShortcuts(commandRegistry);
                    var resetSaved = appSettings.Save();
                    overlays.PopulateKeybindings(commandRegistry,
                                                 overlays.settingsFilterInput.get_Text());
                    overlays.ApplySettingsFilter(
                        overlays.settingsFilterInput.get_Text());
                    var resetStatus = commandRegistry.ShortcutConflictSummary();
                    if resetSaved == false {
                        resetStatus = "Could not save keybinding changes. " + resetStatus;
                        shell.SetStatusLeft("Keybinding changed, but could not be saved");
                        GUI.Toast.Error("Could not save keybinding changes");
                    }
                    overlays.keybindingStatusLabel.SetText(resetStatus);
                }
            }
        }
        var overlayAction = overlays.Pump(shell);
        if overlayAction == ide_overlays.ACTION_BROWSE_FONT {
            var fontPath = GUI.FileDialog.Open("Choose Editor Font", "", "*.ttf;*.otf;*.ttc");
            if fontPath != "" {
                overlays.SetFontPath(fontPath);
            }
        }
        if overlayAction == ide_overlays.ACTION_USE_SYSTEM_FONT {
            overlays.UseSystemFont();
        }
        if overlayAction == ide_overlays.ACTION_RESET_FONT_SIZE {
            overlays.ResetFontSize();
        }
        if overlayAction == ide_overlays.ACTION_RESET_APPEARANCE {
            shell.SetStatusLeft("Appearance defaults restored");
        }
        if overlayAction == ide_overlays.ACTION_RESET_EDITING {
            shell.SetStatusLeft("Editing defaults restored");
        }
        if overlayAction == ide_overlays.ACTION_RESET_INTELLISENSE {
            shell.SetStatusLeft("IntelliSense defaults restored");
        }
        if overlayAction == ide_overlays.ACTION_RESET_STARTUP {
            shell.SetStatusLeft("Startup defaults restored");
        }
        if overlayAction == ide_overlays.ACTION_APPLY_SETTINGS {
            settings_applier.ApplySettingsFromOverlay(shell, overlays, appSettings,
                                                      engine, liveDiag, editorScheduler);
        }
        if overlayAction == ide_overlays.ACTION_CLOSE_SETTINGS {
            overlays.CloseSettings();
            shell.SetStatusLeft("Ready");
        }
        if overlayAction == ide_overlays.ACTION_CLOSE_ABOUT {
            overlays.CloseAbout();
            shell.SetStatusLeft("Ready");
        }

        workspace_edit_preview_commands.PumpRenamePreview(
            renamePreview, shell, docMgr, engine, tabs, indexer);

        var commandInputAction = commandInputOverlay.Pump(shell);
        if commandInputAction == command_input.COMMAND_INPUT_NEW_PROJECT_CONSOLE
           or commandInputAction == command_input.COMMAND_INPUT_NEW_PROJECT_GUI
           or commandInputAction == command_input.COMMAND_INPUT_NEW_PROJECT_LIBRARY {
            var templateKind = project_templates.KIND_CONSOLE;
            if commandInputAction == command_input.COMMAND_INPUT_NEW_PROJECT_GUI {
                templateKind = project_templates.KIND_GUI;
            }
            if commandInputAction == command_input.COMMAND_INPUT_NEW_PROJECT_LIBRARY {
                templateKind = project_templates.KIND_LIBRARY;
            }
            var projectName = Str.Trim(commandInputOverlay.ReadValue());
            var projectsBase = project_templates.DefaultProjectsBase();
            if projectsBase == "" {
                shell.SetStatusLeft("Could not resolve the user projects folder");
                commandInputOverlay.Reject(
                    shell,
                    "The user projects folder could not be resolved. Check the account home directory.");
                continue;
            }
            if safe_io.MakeAll(projectsBase) == false {
                shell.SetStatusLeft("Could not create the user projects folder");
                commandInputOverlay.Reject(
                    shell,
                    "The projects folder could not be created. Check folder permissions and try again.");
                continue;
            }
            if project_templates.ValidName(projectName) == false {
                shell.SetStatusLeft("Enter a valid project name");
                commandInputOverlay.Reject(
                    shell,
                    "Use 1-64 letters, numbers, hyphens, or underscores.");
                continue;
            }
            var requestedProjectPath = IO.Path.Join(projectsBase, projectName);
            if IO.Dir.Exists(requestedProjectPath)
               or IO.File.Exists(requestedProjectPath) {
                shell.SetStatusLeft("A project named " + projectName + " already exists");
                commandInputOverlay.Reject(
                    shell,
                    "That project name already exists. Choose a different name.");
                continue;
            }
            var newProjectPath = project_templates.Scaffold(projectsBase, projectName, templateKind);
            if newProjectPath == "" {
                shell.SetStatusLeft("Could not create project " + projectName);
                commandInputOverlay.Reject(
                    shell,
                    "The project could not be created. Check folder permissions and try again.");
            } else {
                projMgr.OpenFolder(newProjectPath);
                main_command_dispatcher.ActivateOpenWorkspace(commandContext, true);
                sessionMgr.RecordRecentProject(newProjectPath);
                var mainPath = IO.Path.Join(IO.Path.Join(newProjectPath, "src"), "main.zia");
                file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, mainPath);
                shell.SetStatusLeft("Created project: " + projectName);
                commandInputOverlay.Finish();
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_GOTO_LINE {
            if edit_commands.handleGoToLineText(
                   shell, engine, commandInputOverlay.ReadValue()) {
                commandInputOverlay.Finish();
            } else {
                commandInputOverlay.Reject(
                    shell, "Enter a positive line number.");
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_FILTER_OUTPUT {
            shell.toolPanels.SetOutputFilter(commandInputOverlay.ReadValue());
            commandInputOverlay.Finish();
        }
        if commandInputAction == command_input.COMMAND_INPUT_WORKSPACE_SYMBOLS {
            if search_commands.handleWorkspaceSymbolsTextAsync(
                   shell, projMgr, docMgr, engine, locStore, searcher,
                   commandInputOverlay.ReadValue()) {
                commandInputOverlay.Finish();
            } else {
                commandInputOverlay.Reject(
                    shell,
                    "Open a project folder before searching workspace symbols.");
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_RENAME_SYMBOL {
            var renameDoc = docMgr.GetActive();
            var renameStarted = false;
            if renameDoc != null and renameDoc!.language == "basic" {
                renameStarted = basicWorkspaceCommands.StartRename(
                    commandInputOverlay.ReadValue(), shell, docMgr, projMgr,
                    engine);
            } else {
                renameStarted = ziaWorkspaceCommands.StartRename(
                    commandInputOverlay.ReadValue(), shell, docMgr, projMgr,
                    engine, indexer);
            }
            if renameStarted {
                commandInputOverlay.Finish();
            } else {
                commandInputOverlay.Reject(
                    shell,
                    "Use a valid identifier and save the source file before renaming.");
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_EXTRACT_LOCAL {
            if edit_commands.handleExtractLocalVariableText(
                   shell, docMgr, engine, commandInputOverlay.ReadValue()) {
                commandInputOverlay.Finish();
            } else {
                commandInputOverlay.Reject(
                    shell,
                    "Select one Zia expression and enter a valid variable name.");
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_EXTRACT_FUNCTION {
            if edit_commands.handleExtractFunctionText(
                   shell, docMgr, engine, commandInputOverlay.ReadValue()) {
                commandInputOverlay.Finish();
            } else {
                commandInputOverlay.Reject(
                    shell,
                    "Select Zia statements and enter a valid function name.");
            }
        }
        if commandInputAction == command_input.COMMAND_INPUT_CANCEL {
            commandInputOverlay.Finish();
            shell.SetStatusLeft("Command canceled");
        }

        // ====================================================================
        // Tab switching
        // ====================================================================
        if shell.workbench.tabBar.WasReordered() {
            var reorderFrom = shell.workbench.tabBar.GetReorderedFrom();
            var reorderTo = shell.workbench.tabBar.GetReorderedTo();
            docMgr.MoveDocument(reorderFrom, reorderTo);
        }
        if shell.workbench.tabBar.WasChanged() {
            var newIdx = shell.workbench.tabBar.GetActiveIndex();
            if newIdx >= 0 and newIdx < docMgr.GetCount() and newIdx != docMgr.activeIndex {
                file_commands.SaveEditorState(docMgr, engine);
                docMgr.SetActive(newIdx);
                var switchDoc = docMgr.GetActive();
                if switchDoc != null {
                    engine.LoadDocument(switchDoc);
                    shell.SelectSurface(switchDoc.kind);
                    if switchDoc.isNew {
                        shell.SetBreadcrumbPath("");
                    } else {
                        shell.SetBreadcrumbPath(switchDoc.filePath);
                    }
                    shell.SetStatusRight(file_commands.DocStatusLabel(switchDoc));
                    shell.SetStatusLeft("Switched to: " + switchDoc.fileName);
                    fileWatchCtrl.ResetPendingReload();
                }
            }
        }

        // A tab/open/navigation request may have targeted the document already
        // owned by the other pane. LoadDocument focuses that owner; publish the
        // transition before dirty tracking, auto-save, recovery, and watchers.
        ReconcilePaneFocus(shell, docMgr, engine, tabs, completer);

        // ====================================================================
        // Track modified state
        // ====================================================================
        if engine != null and docMgr != null and docMgr.GetCount() > 0 {
            if engine.IsModified() {
                var curDoc = docMgr.GetActive();
                if curDoc != null {
                    var doc = curDoc!;
                    if doc.isReadOnlyPreview {
                        engine.ClearModified();
                        tabs.SetModified(docMgr.activeIndex, false);
                    } else if doc.isModified == false {
                        doc.isModified = true;
                        tabs.SetModified(docMgr.activeIndex, true);
                    }
                }
            }
        }

        var autoDoc = docMgr.GetActive();
        var currentRevisionForSave = ActiveContentRevision(
            docMgr, engine, scene2DEditor, scene3DEditor);
        if appSettings.autoSave and autoDoc != null and autoDoc!.isNew == false {
            if docMgr.activeIndex != autoSaveActiveIndex {
                autoSaveActiveIndex = docMgr.activeIndex;
                autoSaveRevision = currentRevisionForSave;
                if autoDoc!.isModified { autoSaveDebounce.Signal(); }
                else { autoSaveDebounce.Reset(); }
            } else if currentRevisionForSave != autoSaveRevision {
                autoSaveRevision = currentRevisionForSave;
                autoSaveDebounce.Signal();
            } else if autoSaveDebounce.get_IsReady() and autoDoc!.isModified {
                if file_commands.AutoSaveActive(shell, docMgr, engine, tabs) {
                    autoSaveRevision = ActiveContentRevision(
                        docMgr, engine, scene2DEditor, scene3DEditor);
                    autoSaveDebounce.Reset();
                    fileWatchCtrl.ResetPendingReload();
                }
            }
        } else {
            autoSaveActiveIndex = docMgr.activeIndex;
            autoSaveRevision = currentRevisionForSave;
            autoSaveDebounce.Reset();
        }

        // Crash-recovery swaps: immutable editor snapshots are queued after
        // edits settle, then all filesystem work runs on a coalescing worker.
        // Pump every frame even while unfocused so completed worker state and a
        // newer pending snapshot cannot remain stranded. Track the active tab
        // separately because two swapped editor buffers may share a revision.
        recoveryStore.PumpAsync();
        if currentRevisionForSave != recoveryRevision
           or docMgr.activeIndex != recoveryActiveIndex {
            recoveryRevision = currentRevisionForSave;
            recoveryActiveIndex = docMgr.activeIndex;
            recoveryDebounce.Signal();
        } else if recoveryDebounce.get_IsReady() {
            recoveryStore.QueueSwaps(docMgr, engine);
            recoveryDebounce.Reset();
        }

        // SCM gutter change bars: the child is drained every frame so pipe
        // buffers cannot back up while focus changes. New diffs are requested
        // on a tab switch or shortly after edits settle; requests coalesce and
        // never wait for Git on the UI thread.
        if textEditorContextAvailable {
            scmGutter.Pump(engine, docMgr, projMgr);
        }
        if allowBackground and textEditorContextAvailable {
            if docMgr.activeIndex != scmGutterActiveIndex {
                scmGutterActiveIndex = docMgr.activeIndex;
                scmGutter.RefreshActive(engine, docMgr, projMgr);
            } else if currentRevisionForSave != scmGutterRevision {
                scmGutterRevision = currentRevisionForSave;
                scmGutterDebounce.Signal();
            } else if scmGutterDebounce.get_IsReady() {
                scmGutter.RefreshActive(engine, docMgr, projMgr);
                scmGutterDebounce.Reset();
            }
        }

        // ====================================================================
        // File change detection
        // ====================================================================
        if allowBackground {
            fileWatchCtrl.Pump(shell, docMgr, OPEN_DOC_EXTERNAL_POLL_MS);
        }

        if allowBackground {
            workspace_watcher.PumpWorkspaceWatcher(shell, projMgr, docMgr, indexer, locStore, engine,
                                 workspaceWatcherState);
        }

        // ====================================================================
        // Update status bar (only when cursor moves)
        // ====================================================================
        var statusRevision = currentRevisionForSave;
        var statusLineCount = engine.GetLineCount();
        var statusCursorCount = engine.editor.GetCursorCount();
        if textEditorContextAvailable == false and activeVisualDoc != null {
            var visualStatus = "Visual scene";
            if activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_2D
               and scene2DEditor.scene != null {
                visualStatus = "Canvas " + scene2DEditor.scene.Width
                    + " × " + scene2DEditor.scene.Height
                    + "  |  Layers " + scene2DEditor.scene.LayerCount()
                    + "  |  Objects " + scene2DEditor.scene.ObjectCount();
            } else if activeVisualDoc!.kind == file_utils.DOC_KIND_SCENE_3D
                      and scene3DEditor.scene != null {
                visualStatus = "Hierarchy " + (scene3DEditor.scene.NodeCount - 1)
                    + " node(s)  |  VSCN";
            }
            shell.SetStatusCenter(visualStatus);
        } else if curCursorLine != prevCursorLine or curCursorCol != prevCursorCol
           or statusRevision != prevStatusRevision
           or statusLineCount != prevStatusLineCount
           or statusCursorCount != prevStatusCursorCount {
            var cursorText = "Ln " + curCursorLine + ", Col " + curCursorCol + "  |  Lines: " + statusLineCount;
            if statusCursorCount > 1 {
                cursorText = cursorText + "  |  Cursors: " + statusCursorCount;
            }
            shell.SetStatusCenter(cursorText);
        }
        // Breadcrumb symbol segment: incrementally scan only as far as the
        // current caret, with a strict per-frame line budget. The former path
        // materialized and split the entire editor buffer twice on every caret
        // line change, which made navigation through large files visibly stall.
        var crumbDocOpt = docMgr.GetActive();
        var crumbReset = false;
        var crumbReadyBefore = false;
        var crumbReadyAfter = false;
        if crumbDocOpt != null {
            var crumbDoc = crumbDocOpt!;
            if crumbDoc.isNew == false and crumbDoc.filePath != ""
               and crumbDoc.language == "zia" {
                crumbReset = breadcrumbFunctions.EnsureSource(
                    crumbDoc.filePath, statusRevision, statusLineCount);
                crumbReadyBefore = breadcrumbFunctions.IsReadyForLine(curCursorLine);
                var crumbLinesPumped = 0;
                while crumbLinesPumped < BREADCRUMB_SCAN_LINES_PER_FRAME
                      and breadcrumbFunctions.HasRemaining()
                      and breadcrumbFunctions.IsReadyForLine(curCursorLine) == false {
                    breadcrumbFunctions.PumpLine(
                        engine.editor.GetLine(breadcrumbFunctions.nextLine - 1));
                    crumbLinesPumped = crumbLinesPumped + 1;
                }
                crumbReadyAfter = breadcrumbFunctions.IsReadyForLine(curCursorLine);
                if curCursorLine != prevCursorLine or crumbReset
                   or (crumbReadyBefore == false and crumbReadyAfter) {
                    var enclosing = breadcrumbFunctions.EnclosingName(curCursorLine);
                    if enclosing != "" {
                        shell.SetBreadcrumbPath(crumbDoc.filePath + "  ›  " + enclosing);
                    } else {
                        shell.SetBreadcrumbPath(crumbDoc.filePath);
                    }
                }
            } else {
                crumbReset = breadcrumbFunctions.EnsureSource("", statusRevision, 0);
                if curCursorLine != prevCursorLine or crumbReset {
                    if crumbDoc.isNew or crumbDoc.filePath == "" {
                        shell.SetBreadcrumbPath("");
                    } else {
                        shell.SetBreadcrumbPath(crumbDoc.filePath);
                    }
                }
            }
        } else {
            crumbReset = breadcrumbFunctions.EnsureSource("", statusRevision, 0);
            if crumbReset { shell.SetBreadcrumbPath(""); }
        }
        prevCursorLine = curCursorLine;
        prevCursorCol  = curCursorCol;
        prevStatusRevision = statusRevision;
        prevStatusLineCount = statusLineCount;
        prevStatusCursorCount = statusCursorCount;

        var perfSpan = perfMon.StartSpan();
        shell.Render();
        if didPostFirstFrameActivate == false {
            shell.Activate();
            if Machine.Os == "macos" and shell.app.IsFocused() == false
               and envFlagEnabled("ZANNA_GFX_NO_ACTIVATE") == false
               and envFlagEnabled("ZANNA_GFX_HIDE_WINDOWS") == false {
                shell.SetStatusLeft("Window activation is blocked by macOS");
                GUI.Toast.Info("Zanna Studio is visible but macOS did not make it active");
            }
            didPostFirstFrameActivate = true;
        }
        perfMon.AddRender(perfSpan);
        perfMon.EndFrame(engine.editor, indexer);
    }

    // ========================================================================
    // Cleanup
    // ========================================================================
    scmGutter.Cancel();
    recoveryStore.CancelAsync();
    diffOverlay.Shutdown();
    basicWorkspaceCommands.Shutdown();
    diagnosticActions.Shutdown();
    ziaWorkspaceCommands.Shutdown();
    FlushWorkspaceLayout(
        shell, engine, projMgr, activityBarCtrl, appSettings,
        panelSplitSavePending);
    lifecycle_controller.CleanupIde(shell, docMgr, projMgr, engine, buildSys, dbgSession,
                                    terminalCtrl, fileWatchCtrl, workspaceWatcherState,
                                    indexer, breakpointStore, sessionMgr, recoveryStore);
}
