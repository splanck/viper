module semantic_scan;

bind Map = Zanna.Collections.Map;
bind Seq = Zanna.Collections.Seq;
bind Obj = Zanna.Core.Object;
bind Str = Zanna.String;

final BASIC_MAX_SIGNATURE_BACKTRACK_LINES = 200;

// ============================================================================
// MODULE: semantic_scan
// PURPOSE: Lightweight BASIC semantic scanning for IDE navigation.
//
// WHERE-THIS-FITS: The BASIC compiler bridge exposes diagnostics, completion,
//          hover, and document symbols. This module fills editor-only project
//          navigation gaps without changing runtime ABI: go-to-definition,
//          references, rename edits, call hierarchy tokens, workspace symbols,
//          and signature-help records.
//
// TEACHING-NOTE: This is not a replacement parser. It mirrors BASIC's lexical
//          rules closely enough for IDE assists: case-insensitive identifiers,
//          optional type suffixes, apostrophe/REM comments, and doubled-quote
//          string escapes. Compiler diagnostics remain the source of truth.
// ============================================================================

expose func IdentifierAt(source: String,
                         lineNumber: Integer,
                         col0: Integer) -> String {
    var line = SourceLine(source, lineNumber);
    if line == "" { return ""; }
    var at = col0 + 1;
    if at < 1 { at = 1; }
    if at > Str.get_Length(line) { at = Str.get_Length(line); }
    if at < 1 { return ""; }

    if IsBasicIdentifierChar(Str.MidLen(line, at, 1)) == false {
        if at > 1 and IsBasicIdentifierChar(Str.MidLen(line, at - 1, 1)) {
            at = at - 1;
        } else {
            return "";
        }
    }

    var start = at;
    while start > 1 and IsBasicIdentifierChar(Str.MidLen(line, start - 1, 1)) {
        start = start - 1;
    }
    var endPos = at;
    while endPos < Str.get_Length(line) and IsBasicIdentifierChar(Str.MidLen(line, endPos + 1, 1)) {
        endPos = endPos + 1;
    }
    return Str.MidLen(line, start, endPos - start + 1);
}

expose func CanonicalName(name: String) -> String {
    return Str.ToLower(StripTypeSuffix(name));
}

expose func IsValidBasicIdentifier(name: String) -> Boolean {
    if name == "" { return false; }
    var base = StripTypeSuffix(name);
    if base == "" { return false; }
    if IsKeyword(base) { return false; }
    if IsBasicIdentifierStart(Str.MidLen(base, 1, 1)) == false { return false; }
    var i = 2;
    while i <= Str.get_Length(base) {
        if IsBasicIdentifierPart(Str.MidLen(base, i, 1)) == false { return false; }
        i = i + 1;
    }
    return true;
}

expose func ReplacementForOccurrence(oldToken: String,
                                     newName: String) -> String {
    if HasTypeSuffix(newName) { return newName; }
    var suffix = TypeSuffix(oldToken);
    if suffix != "" { return newName + suffix; }
    return newName;
}

expose func NewNotFound() -> Any {
    var item = Map.New();
    Map.SetBool(item, "found", false);
    return item;
}

expose func DeclarationsForFile(path: String,
                                source: String) -> Any {
    var decls = Seq.New();
    AddDeclarations(decls, path, source);
    return decls;
}

expose func AddDeclarations(decls: Any,
                            path: String,
                            source: String) {
    if decls == null or source == "" { return; }
    var lines = Str.Split(source, "\n");
    var lineCount = Seq.get_Count(lines);
    var i = 1;
    while i <= lineCount {
        var rawLine = Obj.ToString(Seq.Get(lines, i - 1));
        var code = StripLineComment(rawLine);
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "FUNCTION", "function");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "SUB", "function");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "PROPERTY", "property");
        AddDestructorDeclaration(decls, path, source, code, i);
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "CLASS", "type");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "INTERFACE", "interface");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "TYPE", "type");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "ENUM", "enum");
        AddBlockDeclaration(decls, path, source, code, i, lineCount, "NAMESPACE", "module");
        AddLabelDeclaration(decls, path, code, i, lineCount);
        AddDimDeclarations(decls, path, source, code, i, lineCount);
        AddConstDeclaration(decls, path, source, code, i, lineCount);
        AddClassFieldDeclaration(decls, path, source, code, i, lineCount);
        i = i + 1;
    }
}

expose func BestDefinition(decls: Any,
                           activePath: String,
                           activeLine: Integer,
                           token: String) -> Any {
    if decls == null or token == "" { return NewNotFound(); }
    var canon = CanonicalName(token);
    if canon == "" { return NewNotFound(); }

    var best = NewNotFound();
    var bestScore = -1;
    var i = 0;
    while i < Seq.get_Count(decls) {
        var decl = Seq.Get(decls, i);
        if Map.GetStr(decl, "canon") == canon {
            var score = DefinitionScore(decl, activePath, activeLine);
            if score > bestScore {
                best = decl;
                bestScore = score;
            }
        }
        i = i + 1;
    }
    if bestScore < 0 { return NewNotFound(); }
    Map.SetBool(best, "found", true);
    return best;
}

expose func AddReferencesForFile(refs: Any,
                                 path: String,
                                 source: String,
                                 def: Any) {
    if refs == null or def == null or source == "" { return; }
    var canon = Map.GetStr(def, "canon");
    if canon == "" { return; }

    var localOnly = Map.GetBool(def, "local") or Map.GetStr(def, "kind") == "label";
    var fromLine = 1;
    var toLine = LineCount(source);
    if localOnly {
        if path != Map.GetStr(def, "file") { return; }
        fromLine = Map.GetIntOr(def, "scopeStart", 1);
        toLine = Map.GetIntOr(def, "scopeEnd", toLine);
    }

    var lines = Str.Split(source, "\n");
    var i = fromLine;
    while i <= toLine and i <= Seq.get_Count(lines) {
        AddLineReferences(refs, path, Obj.ToString(Seq.Get(lines, i - 1)), i, def, canon);
        i = i + 1;
    }
}

expose func RenameEditsFromReferences(refs: Any,
                                      newName: String) -> Any {
    var edits = Seq.New();
    if refs == null { return edits; }
    var i = 0;
    while i < Seq.get_Count(refs) {
        var ref = Seq.Get(refs, i);
        var edit = Map.New();
        Map.SetStr(edit, "file", Map.GetStr(ref, "file"));
        Map.SetInt(edit, "startLine", Map.GetInt(ref, "line"));
        Map.SetInt(edit, "startColumn", Map.GetInt(ref, "column"));
        Map.SetInt(edit, "endLine", Map.GetInt(ref, "endLine"));
        Map.SetInt(edit, "endColumn", Map.GetInt(ref, "endColumn"));
        Map.SetStr(edit, "newText",
                   ReplacementForOccurrence(Map.GetStr(ref, "text"), newName));
        Seq.Push(edits, edit);
        i = i + 1;
    }
    return edits;
}

expose func EnclosingBasicProcedureStartLine(source: String,
                                             lineNumber: Integer) -> Integer {
    var lines = Str.Split(source, "\n");
    var i = lineNumber;
    if i > Seq.get_Count(lines) { i = Seq.get_Count(lines); }
    while i >= 1 {
        var code = StripLineComment(Obj.ToString(Seq.Get(lines, i - 1)));
        var kind = ProcedureKeywordOnLine(code);
        if kind != "" {
            var endLine = BasicBlockEndLine(source, i, kind);
            if lineNumber <= endLine {
                return i;
            }
        }
        i = i - 1;
    }
    return 0;
}

expose func EnclosingBasicProcedureName(source: String,
                                        lineNumber: Integer) -> String {
    var start = EnclosingBasicProcedureStartLine(source, lineNumber);
    if start <= 0 { return ""; }
    var decl = ProcedureDeclarationFromLine("<editor>", source,
                                            SourceLine(source, start), start,
                                            LineCount(source));
    if Map.GetBool(decl, "found") { return Map.GetStr(decl, "name"); }
    return "";
}

expose func BasicProcedureEndLine(source: String,
                                  startLine: Integer) -> Integer {
    if startLine <= 0 { return 0; }
    var kind = ProcedureKeywordOnLine(SourceLine(source, startLine));
    if kind == "" { return startLine; }
    return BasicBlockEndLine(source, startLine, kind);
}

expose func OutgoingBasicCallTokens(source: String,
                                    startLine: Integer,
                                    endLine: Integer) -> Any {
    var tokens = Seq.New();
    if source == "" { return tokens; }
    var lines = Str.Split(source, "\n");
    var fromLine = startLine;
    var toLine = endLine;
    if fromLine < 1 { fromLine = 1; }
    if toLine < fromLine { toLine = fromLine; }
    if toLine > Seq.get_Count(lines) { toLine = Seq.get_Count(lines); }

    var i = fromLine;
    while i <= toLine {
        AddOutgoingCallsFromLine(tokens, Obj.ToString(Seq.Get(lines, i - 1)), i);
        i = i + 1;
    }
    return tokens;
}

expose func SignatureInfoForFile(path: String,
                                 source: String,
                                 lineNumber: Integer,
                                 col0: Integer) -> Any {
    var info = Map.New();
    Map.SetBool(info, "available", false);
    var call = ActiveCallAt(source, lineNumber, col0);
    if Map.GetBool(call, "available") == false { return info; }

    var callName = Map.GetStr(call, "name");
    var decls = DeclarationsForFile(path, source);
    var overloads = Seq.New();
    var i = 0;
    while i < Seq.get_Count(decls) {
        var decl = Seq.Get(decls, i);
        if Map.GetStr(decl, "canon") == CanonicalName(callName)
           and IsCallableKind(Map.GetStr(decl, "kind")) {
            Seq.Push(overloads, SignatureRecordForDeclaration(decl));
        }
        i = i + 1;
    }
    if Seq.get_Count(overloads) == 0 { return info; }

    var first = Seq.Get(overloads, 0);
    Map.SetBool(info, "available", true);
    Map.SetInt(info, "activeSignature", 0);
    Map.SetInt(info, "activeParameter", Map.GetInt(call, "activeParameter"));
    Map.SetInt(info, "overloadCount", Seq.get_Count(overloads));
    Map.Set(info, "overloads", overloads);
    Map.SetStr(info, "name", Map.GetStr(first, "name"));
    Map.SetStr(info, "display", Map.GetStr(first, "display"));
    Map.Set(info, "parameters", Map.Get(first, "parameters"));
    Map.SetStr(info, "returnType", Map.GetStr(first, "returnType"));
    Map.SetStr(info, "documentation", "");
    Map.SetStr(info, "source", "basic");
    return info;
}

expose func WorkspaceSymbolMatchesDecl(decl: Any,
                                       needle: String) -> Boolean {
    if decl == null { return false; }
    if needle == "" { return true; }
    if Str.IndexOf(Str.ToLower(Map.GetStr(decl, "name")), needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(Map.GetStr(decl, "kind")), needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(Map.GetStr(decl, "file")), needle) != 0 { return true; }
    return false;
}

func DefinitionScore(decl: Any,
                     activePath: String,
                     activeLine: Integer) -> Integer {
    var score = 0;
    var file = Map.GetStr(decl, "file");
    var scopeStart = Map.GetIntOr(decl, "scopeStart", 1);
    var scopeEnd = Map.GetIntOr(decl, "scopeEnd", scopeStart);
    if file == activePath { score = score + 10000; }
    if activeLine >= scopeStart and activeLine <= scopeEnd {
        score = score + 50000;
        var span = scopeEnd - scopeStart;
        if span < 0 { span = 0; }
        score = score + 10000 - span;
    }
    if Map.GetBool(decl, "local") { score = score + 1000; }
    if IsCallableKind(Map.GetStr(decl, "kind")) { score = score + 100; }
    return score;
}

func AddBlockDeclaration(decls: Any,
                         path: String,
                         source: String,
                         line: String,
                         lineNumber: Integer,
                         lineCount: Integer,
                         keyword: String,
                         kind: String) {
    var decl = ProcedureOrBlockDeclaration(path, source, line, lineNumber,
                                           lineCount, keyword, kind);
    if Map.GetBool(decl, "found") == false { return; }
    Seq.Push(decls, decl);
    if keyword == "FUNCTION" or keyword == "SUB" or keyword == "PROPERTY" {
        AddParameterDeclarations(decls, path, decl);
    }
}

func ProcedureDeclarationFromLine(path: String,
                                  source: String,
                                  line: String,
                                  lineNumber: Integer,
                                  lineCount: Integer) -> Any {
    var kind = ProcedureKeywordOnLine(line);
    if kind == "" { return NewNotFound(); }
    return ProcedureOrBlockDeclaration(path, source, line, lineNumber,
                                       lineCount, kind, "function");
}

func ProcedureOrBlockDeclaration(path: String,
                                 source: String,
                                 line: String,
                                 lineNumber: Integer,
                                 lineCount: Integer,
                                 keyword: String,
                                 kind: String) -> Any {
    var code = StripLineComment(line);
    var keywordCol = KeywordColumn(code, keyword);
    if keywordCol <= 0 { return NewNotFound(); }
    if EndsWithToken(Str.Trim(Str.Left(code, keywordCol - 1)), "END") {
        return NewNotFound();
    }
    var nameStart = SkipWhitespace(code, keywordCol + Str.get_Length(keyword));
    var name = ReadBasicIdentifierAt(code, nameStart);
    if name == "" { return NewNotFound(); }

    var endLine = lineCount;
    if IsBlockKeyword(keyword) {
        endLine = BasicBlockEndLine(source, lineNumber, keyword);
    }
    var openParen = Str.IndexOfFrom(code, nameStart + Str.get_Length(name), "(");
    var closeParen = 0;
    var paramsText = "";
    if openParen != 0 {
        closeParen = MatchingParenOnLine(code, openParen);
        if closeParen > openParen {
            paramsText = Str.MidLen(code, openParen + 1, closeParen - openParen - 1);
        }
    }
    var returnType = ReturnTypeFromDeclarationLine(code, closeParen);
    var signature = SignatureDisplay(keyword, name, paramsText, returnType);
    var decl = NewDecl(path, name, kind, lineNumber, nameStart,
                       nameStart + Str.get_Length(name), lineNumber, endLine,
                       false, signature, paramsText, returnType);
    Map.SetStr(decl, "signatureLine", code);
    if keyword == "FUNCTION" { Map.SetStr(decl, "kind", "function"); }
    if keyword == "SUB" { Map.SetStr(decl, "kind", "function"); }
    if keyword == "PROPERTY" { Map.SetStr(decl, "kind", "property"); }
    if kind == "type" or kind == "interface" or kind == "enum" or kind == "module" {
        Map.SetBool(decl, "local", false);
    }
    return decl;
}

func AddDestructorDeclaration(decls: Any,
                              path: String,
                              source: String,
                              line: String,
                              lineNumber: Integer) {
    var keywordCol = KeywordColumn(line, "DESTRUCTOR");
    if keywordCol <= 0 { return; }
    if EndsWithToken(Str.Trim(Str.Left(line, keywordCol - 1)), "END") { return; }
    var endLine = BasicBlockEndLine(source, lineNumber, "DESTRUCTOR");
    var decl = NewDecl(path, "DESTRUCTOR", "function", lineNumber, keywordCol,
                       keywordCol + Str.get_Length("DESTRUCTOR"), lineNumber,
                       endLine, false, "DESTRUCTOR", "", "");
    Seq.Push(decls, decl);
}

func AddLabelDeclaration(decls: Any,
                         path: String,
                         line: String,
                         lineNumber: Integer,
                         lineCount: Integer) {
    var code = Str.Trim(line);
    if code == "" { return; }
    var offset = LeadingWhitespaceLength(line) + 1;
    var name = ReadBasicIdentifierAt(line, offset);
    if name == "" or IsKeyword(name) { return; }
    var after = offset + Str.get_Length(name);
    if after <= Str.get_Length(line) and Str.MidLen(line, after, 1) == ":" {
        var decl = NewDecl(path, name, "label", lineNumber, offset,
                           offset + Str.get_Length(name), 1, lineCount,
                           true, name + ":", "", "");
        Seq.Push(decls, decl);
    }
}

func AddDimDeclarations(decls: Any,
                        path: String,
                        source: String,
                        line: String,
                        lineNumber: Integer,
                        lineCount: Integer) {
    var dimCol = KeywordColumn(line, "DIM");
    if dimCol <= 0 { return; }
    var scopeStart = EnclosingBasicProcedureStartLine(source, lineNumber);
    var scopeEnd = lineCount;
    var local = false;
    if scopeStart > 0 {
        scopeEnd = BasicProcedureEndLine(source, scopeStart);
        local = true;
    }
    AddVariableDeclarationsFromList(decls, path, line, lineNumber,
                                    dimCol + Str.get_Length("DIM"),
                                    scopeStart, scopeEnd, local, "variable");
}

func AddConstDeclaration(decls: Any,
                         path: String,
                         source: String,
                         line: String,
                         lineNumber: Integer,
                         lineCount: Integer) {
    var constCol = KeywordColumn(line, "CONST");
    if constCol <= 0 { return; }
    var scopeStart = EnclosingBasicProcedureStartLine(source, lineNumber);
    var scopeEnd = lineCount;
    var local = false;
    if scopeStart > 0 {
        scopeEnd = BasicProcedureEndLine(source, scopeStart);
        local = true;
    }
    AddVariableDeclarationsFromList(decls, path, line, lineNumber,
                                    constCol + Str.get_Length("CONST"),
                                    scopeStart, scopeEnd, local, "constant");
}

func AddClassFieldDeclaration(decls: Any,
                              path: String,
                              source: String,
                              line: String,
                              lineNumber: Integer,
                              lineCount: Integer) {
    if EnclosingBasicProcedureStartLine(source, lineNumber) > 0 { return; }
    var code = Str.Trim(line);
    if code == "" { return; }
    var firstCol = LeadingWhitespaceLength(line) + 1;
    var name = ReadBasicIdentifierAt(line, firstCol);
    if name == "" or IsKeyword(name) { return; }
    var afterName = firstCol + Str.get_Length(name);
    var asCol = KeywordColumnFrom(line, "AS", afterName);
    if asCol <= 0 { return; }
    var decl = NewDecl(path, name, "field", lineNumber, firstCol,
                       firstCol + Str.get_Length(name), 1, lineCount,
                       false, name, "", TypeTextAfterAs(line, asCol));
    Seq.Push(decls, decl);
}

func AddVariableDeclarationsFromList(decls: Any,
                                     path: String,
                                     line: String,
                                     lineNumber: Integer,
                                     startPos: Integer,
                                     scopeStart: Integer,
                                     scopeEnd: Integer,
                                     local: Boolean,
                                     kind: String) {
    var pos = startPos;
    var actualScopeStart = scopeStart;
    if actualScopeStart <= 0 { actualScopeStart = 1; }
    while pos <= Str.get_Length(line) {
        pos = SkipWhitespaceAndCommas(line, pos);
        if pos > Str.get_Length(line) { break; }
        var name = ReadBasicIdentifierAt(line, pos);
        if name == "" { break; }
        var typeText = "";
        var asCol = KeywordColumnFrom(line, "AS", pos + Str.get_Length(name));
        var commaCol = NextCommaOutsideParens(line, pos + Str.get_Length(name));
        if asCol > 0 and (commaCol == 0 or asCol < commaCol) {
            typeText = TypeTextAfterAs(line, asCol);
        }
        var decl = NewDecl(path, name, kind, lineNumber, pos,
                           pos + Str.get_Length(name), actualScopeStart, scopeEnd,
                           local, name, "", typeText);
        Seq.Push(decls, decl);
        if commaCol == 0 { break; }
        pos = commaCol + 1;
    }
}

func AddParameterDeclarations(decls: Any,
                              path: String,
                              procDecl: Any) {
    var paramsText = Map.GetStr(procDecl, "paramsText");
    if paramsText == "" { return; }
    var procLine = Map.GetInt(procDecl, "line");
    var scopeStart = Map.GetInt(procDecl, "scopeStart");
    var scopeEnd = Map.GetInt(procDecl, "scopeEnd");
    var line = Map.GetStr(procDecl, "signatureLine");
    var openParen = Str.IndexOf(line, "(");
    if openParen == 0 { return; }

    var pos = openParen + 1;
    while pos <= Str.get_Length(line) {
        pos = SkipWhitespaceAndCommas(line, pos);
        pos = SkipParameterModifier(line, pos);
        var name = ReadBasicIdentifierAt(line, pos);
        if name == "" { break; }
        var commaCol = NextCommaOutsideParens(line, pos + Str.get_Length(name));
        var asCol = KeywordColumnFrom(line, "AS", pos + Str.get_Length(name));
        var typeText = "";
        if asCol > 0 and (commaCol == 0 or asCol < commaCol) {
            typeText = TypeTextAfterAs(line, asCol);
        }
        var decl = NewDecl(path, name, "parameter", procLine, pos,
                           pos + Str.get_Length(name), scopeStart, scopeEnd,
                           true, name, "", typeText);
        Seq.Push(decls, decl);
        if commaCol == 0 { break; }
        pos = commaCol + 1;
    }
}

func NewDecl(path: String,
             name: String,
             kind: String,
             lineNumber: Integer,
             column: Integer,
             endColumn: Integer,
             scopeStart: Integer,
             scopeEnd: Integer,
             local: Boolean,
             signature: String,
             paramsText: String,
             returnType: String) -> Any {
    var decl = Map.New();
    Map.SetBool(decl, "found", true);
    Map.SetStr(decl, "file", path);
    Map.SetStr(decl, "name", name);
    Map.SetStr(decl, "canon", CanonicalName(name));
    Map.SetStr(decl, "kind", kind);
    Map.SetInt(decl, "line", lineNumber);
    Map.SetInt(decl, "column", column);
    Map.SetInt(decl, "endLine", lineNumber);
    Map.SetInt(decl, "endColumn", endColumn);
    Map.SetInt(decl, "scopeStart", scopeStart);
    Map.SetInt(decl, "scopeEnd", scopeEnd);
    Map.SetBool(decl, "local", local);
    Map.SetStr(decl, "signature", signature);
    Map.SetStr(decl, "signatureLine", SourceSafeLine(signature));
    Map.SetStr(decl, "paramsText", paramsText);
    Map.SetStr(decl, "returnType", returnType);
    return decl;
}

func SourceSafeLine(text: String) -> String {
    return text;
}

func AddLineReferences(refs: Any,
                       path: String,
                       line: String,
                       lineNumber: Integer,
                       def: Any,
                       canon: String) {
    var pos = 1;
    var inString = false;
    var n = Str.get_Length(line);
    while pos <= n {
        var ch = Str.MidLen(line, pos, 1);
        if inString {
            if ch == "\"" {
                if pos < n and Str.MidLen(line, pos + 1, 1) == "\"" {
                    pos = pos + 2;
                    continue;
                }
                inString = false;
            }
            pos = pos + 1;
            continue;
        }
        if ch == "\"" {
            inString = true;
            pos = pos + 1;
            continue;
        }
        if ch == "'" { break; }
        if IsRemCommentAt(line, pos) { break; }
        if IsBasicIdentifierStart(ch) {
            var start = pos;
            var token = ReadBasicIdentifierAt(line, start);
            if token != "" {
                if CanonicalName(token) == canon {
                    var ref = Map.New();
                    Map.SetStr(ref, "file", path);
                    Map.SetStr(ref, "name", Map.GetStr(def, "name"));
                    Map.SetStr(ref, "text", token);
                    Map.SetInt(ref, "line", lineNumber);
                    Map.SetInt(ref, "column", start);
                    Map.SetInt(ref, "endLine", lineNumber);
                    Map.SetInt(ref, "endColumn", start + Str.get_Length(token));
                    Map.SetBool(ref, "isDefinition",
                                path == Map.GetStr(def, "file")
                                and lineNumber == Map.GetInt(def, "line")
                                and start == Map.GetInt(def, "column"));
                    Seq.Push(refs, ref);
                }
                pos = start + Str.get_Length(token);
                continue;
            }
        }
        pos = pos + 1;
    }
}

func AddOutgoingCallsFromLine(tokens: Any,
                              line: String,
                              lineNumber: Integer) {
    var pos = 1;
    var inString = false;
    var n = Str.get_Length(line);
    while pos <= n {
        var ch = Str.MidLen(line, pos, 1);
        if inString {
            if ch == "\"" {
                if pos < n and Str.MidLen(line, pos + 1, 1) == "\"" {
                    pos = pos + 2;
                    continue;
                }
                inString = false;
            }
            pos = pos + 1;
            continue;
        }
        if ch == "\"" {
            inString = true;
            pos = pos + 1;
            continue;
        }
        if ch == "'" { break; }
        if IsRemCommentAt(line, pos) { break; }
        if IsBasicIdentifierStart(ch) {
            var start = pos;
            var name = ReadBasicIdentifierAt(line, start);
            var next = SkipWhitespace(line, start + Str.get_Length(name));
            if IsKeyword(name) == false
               and IsDeclarationNameAt(line, start) == false
               and next <= n
               and Str.MidLen(line, next, 1) == "(" {
                var token = Map.New();
                Map.SetStr(token, "name", name);
                Map.SetInt(token, "line", lineNumber);
                Map.SetInt(token, "column", start);
                Seq.Push(tokens, token);
            }
            pos = start + Str.get_Length(name);
            continue;
        }
        pos = pos + 1;
    }
}

func ActiveCallAt(source: String,
                  lineNumber: Integer,
                  col0: Integer) -> Any {
    var result = Map.New();
    Map.SetBool(result, "available", false);
    var lines = Str.Split(source, "\n");
    var lineIdx = lineNumber - 1;
    if lineIdx >= Seq.get_Count(lines) { lineIdx = Seq.get_Count(lines) - 1; }
    if lineIdx < 0 { return result; }

    var minLine = lineIdx - BASIC_MAX_SIGNATURE_BACKTRACK_LINES + 1;
    if minLine < 0 { minLine = 0; }
    var depth = 0;
    var activeParam = 0;
    var row = lineIdx;
    while row >= minLine {
        var text = StripLineComment(Obj.ToString(Seq.Get(lines, row)));
        var pos = Str.get_Length(text);
        if row == lineIdx {
            pos = col0;
            if pos > Str.get_Length(text) { pos = Str.get_Length(text); }
        }
        while pos >= 1 {
            var ch = Str.MidLen(text, pos, 1);
            if ch == ")" {
                depth = depth + 1;
            } else if ch == "(" {
                if depth == 0 {
                    var name = CallNameBeforeOpenParen(text, pos);
                    if name == "" { return result; }
                    Map.SetBool(result, "available", true);
                    Map.SetStr(result, "name", name);
                    Map.SetInt(result, "activeParameter", activeParam);
                    Map.SetInt(result, "line", row + 1);
                    Map.SetInt(result, "column", pos);
                    return result;
                }
                depth = depth - 1;
            } else if ch == "," and depth == 0 {
                activeParam = activeParam + 1;
            }
            pos = pos - 1;
        }
        row = row - 1;
    }
    return result;
}

func CallNameBeforeOpenParen(line: String,
                             openCol: Integer) -> String {
    var pos = openCol - 1;
    while pos >= 1 and IsSpace(Str.MidLen(line, pos, 1)) { pos = pos - 1; }
    var endPos = pos;
    while pos >= 1 and IsBasicIdentifierChar(Str.MidLen(line, pos, 1)) {
        pos = pos - 1;
    }
    if endPos < pos + 1 { return ""; }
    return Str.MidLen(line, pos + 1, endPos - pos);
}

func SignatureRecordForDeclaration(decl: Any) -> Any {
    var sig = Map.New();
    var params = ParamsSeqFromText(Map.GetStr(decl, "paramsText"));
    Map.SetStr(sig, "name", Map.GetStr(decl, "name"));
    Map.SetStr(sig, "display", Map.GetStr(decl, "signature"));
    Map.Set(sig, "parameters", params);
    Map.SetStr(sig, "returnType", Map.GetStr(decl, "returnType"));
    Map.SetStr(sig, "documentation", "");
    Map.SetStr(sig, "source", "basic");
    return sig;
}

func ParamsSeqFromText(paramsText: String) -> Any {
    var params = Seq.New();
    var pos = 1;
    while pos <= Str.get_Length(paramsText) {
        pos = SkipWhitespaceAndCommas(paramsText, pos);
        pos = SkipParameterModifier(paramsText, pos);
        var name = ReadBasicIdentifierAt(paramsText, pos);
        if name == "" { break; }
        var commaCol = NextCommaOutsideParens(paramsText, pos + Str.get_Length(name));
        var asCol = KeywordColumnFrom(paramsText, "AS", pos + Str.get_Length(name));
        var typeText = "";
        if asCol > 0 and (commaCol == 0 or asCol < commaCol) {
            typeText = TypeTextAfterAs(paramsText, asCol);
        }
        var param = Map.New();
        Map.SetStr(param, "name", name);
        Map.SetStr(param, "type", typeText);
        Seq.Push(params, param);
        if commaCol == 0 { break; }
        pos = commaCol + 1;
    }
    return params;
}

func SignatureDisplay(keyword: String,
                      name: String,
                      paramsText: String,
                      returnType: String) -> String {
    var text = keyword + " " + name + "(" + CleanInline(paramsText) + ")";
    if returnType != "" {
        text = text + " AS " + returnType;
    }
    return text;
}

func IsCallableKind(kind: String) -> Boolean {
    return kind == "function" or kind == "property";
}

func ProcedureKeywordOnLine(line: String) -> String {
    var code = StripLineComment(line);
    if KeywordColumn(code, "FUNCTION") > 0 { return "FUNCTION"; }
    if KeywordColumn(code, "SUB") > 0 { return "SUB"; }
    if KeywordColumn(code, "PROPERTY") > 0 { return "PROPERTY"; }
    if KeywordColumn(code, "DESTRUCTOR") > 0 { return "DESTRUCTOR"; }
    return "";
}

func BasicBlockEndLine(source: String,
                       startLine: Integer,
                       keyword: String) -> Integer {
    var lines = Str.Split(source, "\n");
    var i = startLine + 1;
    while i <= Seq.get_Count(lines) {
        var code = Str.Trim(StripLineComment(Obj.ToString(Seq.Get(lines, i - 1))));
        if IsEndKeywordLine(code, keyword) {
            return i;
        }
        i = i + 1;
    }
    return Seq.get_Count(lines);
}

func IsEndKeywordLine(code: String,
                      keyword: String) -> Boolean {
    var upper = Str.ToUpper(Str.Trim(code));
    if Str.StartsWith(upper, "END " + keyword) { return true; }
    if keyword == "FUNCTION" and Str.StartsWith(upper, "ENDFUNCTION") { return true; }
    if keyword == "SUB" and Str.StartsWith(upper, "ENDSUB") { return true; }
    return false;
}

func IsBlockKeyword(keyword: String) -> Boolean {
    if keyword == "FUNCTION" or keyword == "SUB" or keyword == "PROPERTY"
       or keyword == "DESTRUCTOR" or keyword == "CLASS"
       or keyword == "INTERFACE" or keyword == "TYPE"
       or keyword == "ENUM" or keyword == "NAMESPACE" {
        return true;
    }
    return false;
}

func KeywordColumn(line: String,
                   keyword: String) -> Integer {
    return KeywordColumnFrom(line, keyword, 1);
}

func KeywordColumnFrom(line: String,
                       keyword: String,
                       startPos: Integer) -> Integer {
    var pos = startPos;
    while pos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, pos, 1);
        if ch == "\"" {
            pos = SkipString(line, pos);
            continue;
        }
        if ch == "'" { return 0; }
        if IsRemCommentAt(line, pos) { return 0; }
        if IsBasicIdentifierStart(ch) {
            var token = ReadBasicIdentifierAt(line, pos);
            if Str.ToUpper(StripTypeSuffix(token)) == keyword {
                return pos;
            }
            pos = pos + Str.get_Length(token);
            continue;
        }
        pos = pos + 1;
    }
    return 0;
}

func StripLineComment(line: String) -> String {
    var pos = 1;
    var inString = false;
    while pos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, pos, 1);
        if inString {
            if ch == "\"" {
                if pos < Str.get_Length(line) and Str.MidLen(line, pos + 1, 1) == "\"" {
                    pos = pos + 2;
                    continue;
                }
                inString = false;
            }
            pos = pos + 1;
            continue;
        }
        if ch == "\"" {
            inString = true;
            pos = pos + 1;
            continue;
        }
        if ch == "'" or IsRemCommentAt(line, pos) {
            if pos <= 1 { return ""; }
            return Str.Left(line, pos - 1);
        }
        pos = pos + 1;
    }
    return line;
}

func IsRemCommentAt(line: String,
                    pos: Integer) -> Boolean {
    if pos < 1 or pos + 2 > Str.get_Length(line) { return false; }
    if Str.ToUpper(Str.MidLen(line, pos, 3)) != "REM" { return false; }
    var beforeOk = pos == 1 or IsBasicIdentifierChar(Str.MidLen(line, pos - 1, 1)) == false;
    var afterPos = pos + 3;
    var afterOk = afterPos > Str.get_Length(line)
                  or IsBasicIdentifierChar(Str.MidLen(line, afterPos, 1)) == false;
    return beforeOk and afterOk;
}

func ReadBasicIdentifierAt(line: String,
                           startPos: Integer) -> String {
    if startPos < 1 or startPos > Str.get_Length(line) { return ""; }
    if IsBasicIdentifierStart(Str.MidLen(line, startPos, 1)) == false { return ""; }
    var pos = startPos;
    var name = "";
    while pos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, pos, 1);
        if name == "" {
            if IsBasicIdentifierStart(ch) == false { return ""; }
        } else if IsBasicIdentifierPart(ch) == false {
            break;
        }
        name = name + ch;
        pos = pos + 1;
    }
    if pos <= Str.get_Length(line) and IsTypeSuffix(Str.MidLen(line, pos, 1)) {
        name = name + Str.MidLen(line, pos, 1);
    }
    return name;
}

func IsDeclarationNameAt(line: String,
                         nameCol: Integer) -> Boolean {
    var before = Str.ToUpper(Str.Trim(Str.Left(line, nameCol - 1)));
    return EndsWithToken(before, "FUNCTION")
           or EndsWithToken(before, "SUB")
           or EndsWithToken(before, "PROPERTY")
           or EndsWithToken(before, "CLASS")
           or EndsWithToken(before, "TYPE")
           or EndsWithToken(before, "ENUM")
           or EndsWithToken(before, "INTERFACE")
           or EndsWithToken(before, "NAMESPACE")
           or EndsWithToken(before, "DIM")
           or EndsWithToken(before, "CONST");
}

func EndsWithToken(text: String,
                   token: String) -> Boolean {
    var trimmed = Str.ToUpper(Str.Trim(text));
    if trimmed == token { return true; }
    return Str.EndsWith(trimmed, " " + token);
}

func MatchingParenOnLine(line: String,
                         openCol: Integer) -> Integer {
    var depth = 0;
    var pos = openCol;
    while pos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, pos, 1);
        if ch == "(" {
            depth = depth + 1;
        } else if ch == ")" {
            depth = depth - 1;
            if depth == 0 { return pos; }
        } else if ch == "\"" {
            pos = SkipString(line, pos);
            continue;
        }
        pos = pos + 1;
    }
    return 0;
}

func NextCommaOutsideParens(line: String,
                            startPos: Integer) -> Integer {
    var depth = 0;
    var pos = startPos;
    while pos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, pos, 1);
        if ch == "\"" {
            pos = SkipString(line, pos);
            continue;
        }
        if ch == "(" {
            depth = depth + 1;
        } else if ch == ")" {
            if depth > 0 { depth = depth - 1; }
        } else if ch == "," and depth == 0 {
            return pos;
        } else if ch == "'" {
            return 0;
        }
        pos = pos + 1;
    }
    return 0;
}

func ReturnTypeFromDeclarationLine(line: String,
                                   closeParen: Integer) -> String {
    var start = closeParen;
    if start <= 0 { start = 1; }
    var asCol = KeywordColumnFrom(line, "AS", start);
    if asCol <= 0 { return ""; }
    return TypeTextAfterAs(line, asCol);
}

func TypeTextAfterAs(line: String,
                     asCol: Integer) -> String {
    var pos = SkipWhitespace(line, asCol + Str.get_Length("AS"));
    var endPos = pos;
    while endPos <= Str.get_Length(line) {
        var ch = Str.MidLen(line, endPos, 1);
        if ch == "," or ch == ")" or ch == ":" or ch == "=" { break; }
        endPos = endPos + 1;
    }
    if endPos <= pos { return ""; }
    return CleanInline(Str.MidLen(line, pos, endPos - pos));
}

func SkipString(line: String,
                quoteCol: Integer) -> Integer {
    var pos = quoteCol + 1;
    while pos <= Str.get_Length(line) {
        if Str.MidLen(line, pos, 1) == "\"" {
            if pos < Str.get_Length(line) and Str.MidLen(line, pos + 1, 1) == "\"" {
                pos = pos + 2;
                continue;
            }
            return pos + 1;
        }
        pos = pos + 1;
    }
    return Str.get_Length(line) + 1;
}

func SkipWhitespace(line: String,
                    pos: Integer) -> Integer {
    var i = pos;
    while i <= Str.get_Length(line) and IsSpace(Str.MidLen(line, i, 1)) {
        i = i + 1;
    }
    return i;
}

func SkipWhitespaceAndCommas(line: String,
                             pos: Integer) -> Integer {
    var i = pos;
    while i <= Str.get_Length(line) {
        var ch = Str.MidLen(line, i, 1);
        if IsSpace(ch) or ch == "," {
            i = i + 1;
        } else {
            break;
        }
    }
    return i;
}

func SkipParameterModifier(line: String,
                           pos: Integer) -> Integer {
    var i = SkipWhitespace(line, pos);
    var token = ReadBasicIdentifierAt(line, i);
    var upper = Str.ToUpper(StripTypeSuffix(token));
    if upper == "BYVAL" or upper == "BYREF" or upper == "OPTIONAL" or upper == "PARAMARRAY" {
        return SkipWhitespace(line, i + Str.get_Length(token));
    }
    return i;
}

func LeadingWhitespaceLength(line: String) -> Integer {
    var i = 1;
    while i <= Str.get_Length(line) and IsSpace(Str.MidLen(line, i, 1)) {
        i = i + 1;
    }
    return i - 1;
}

func SourceLine(source: String,
                lineNumber: Integer) -> String {
    if source == "" { return ""; }
    var lines = Str.Split(source, "\n");
    if lineNumber < 1 or lineNumber > Seq.get_Count(lines) { return ""; }
    return Obj.ToString(Seq.Get(lines, lineNumber - 1));
}

func LineCount(source: String) -> Integer {
    if source == "" { return 0; }
    return Seq.get_Count(Str.Split(source, "\n"));
}

func CleanInline(text: String) -> String {
    return Str.Trim(Str.Replace(Str.Replace(text, "\n", " "), "\t", " "));
}

func StripTypeSuffix(name: String) -> String {
    if HasTypeSuffix(name) {
        return Str.Left(name, Str.get_Length(name) - 1);
    }
    return name;
}

func TypeSuffix(name: String) -> String {
    if name == "" { return ""; }
    var last = Str.Right(name, 1);
    if IsTypeSuffix(last) { return last; }
    return "";
}

func HasTypeSuffix(name: String) -> Boolean {
    return TypeSuffix(name) != "";
}

func IsTypeSuffix(ch: String) -> Boolean {
    return ch == "$" or ch == "%" or ch == "&" or ch == "!" or ch == "#";
}

func IsBasicIdentifierStart(ch: String) -> Boolean {
    if ch >= "a" and ch <= "z" { return true; }
    if ch >= "A" and ch <= "Z" { return true; }
    if ch == "_" { return true; }
    return false;
}

func IsBasicIdentifierPart(ch: String) -> Boolean {
    if IsBasicIdentifierStart(ch) { return true; }
    if ch >= "0" and ch <= "9" { return true; }
    return false;
}

func IsBasicIdentifierChar(ch: String) -> Boolean {
    return IsBasicIdentifierPart(ch) or IsTypeSuffix(ch);
}

func IsSpace(ch: String) -> Boolean {
    return ch == " " or ch == "\t";
}

func IsKeyword(name: String) -> Boolean {
    var upper = Str.ToUpper(StripTypeSuffix(name));
    if upper == "AND" or upper == "ANDALSO" or upper == "AS" { return true; }
    if upper == "BASE" or upper == "BOOLEAN" or upper == "BYREF" or upper == "BYVAL" { return true; }
    if upper == "CALL" or upper == "CASE" or upper == "CATCH" or upper == "CLASS" or upper == "CONST" { return true; }
    if upper == "DELETE" or upper == "DIM" or upper == "DO" or upper == "DOUBLE" { return true; }
    if upper == "ELSE" or upper == "ELSEIF" or upper == "END" or upper == "ENUM" or upper == "EXIT" { return true; }
    if upper == "FALSE" or upper == "FINAL" or upper == "FOR" or upper == "FUNCTION" { return true; }
    if upper == "GOSUB" or upper == "GOTO" { return true; }
    if upper == "IF" or upper == "IMPLEMENTS" or upper == "INHERITS" or upper == "INTEGER" or upper == "INTERFACE" or upper == "IS" { return true; }
    if upper == "LET" or upper == "LOOP" { return true; }
    if upper == "ME" or upper == "MOD" { return true; }
    if upper == "NAMESPACE" or upper == "NEW" or upper == "NEXT" or upper == "NOT" or upper == "NULL" { return true; }
    if upper == "OR" or upper == "ORELSE" or upper == "OVERRIDE" { return true; }
    if upper == "PRIVATE" or upper == "PROPERTY" or upper == "PUBLIC" { return true; }
    if upper == "REM" or upper == "RETURN" { return true; }
    if upper == "SELECT" or upper == "STATIC" or upper == "STEP" or upper == "STRING" or upper == "SUB" { return true; }
    if upper == "THEN" or upper == "TO" or upper == "TRUE" or upper == "TRY" or upper == "TYPE" { return true; }
    if upper == "UNTIL" or upper == "USING" { return true; }
    if upper == "VIRTUAL" { return true; }
    if upper == "WEND" or upper == "WHILE" { return true; }
    return false;
}
