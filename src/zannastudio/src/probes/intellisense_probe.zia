//
// File: zannastudio/src/probes/intellisense_probe.zia
// Purpose: Regress Studio completion, diagnostics, navigation, and semantic UI.
// Key invariants:
//   - Language jobs publish only results for their original editor state.
//   - Workspace completion resets when the project file-cache identity changes.
//   - IntelliSense overlays remain inside the effective viewport at UI zoom.
// Ownership/Lifetime: The probe owns and destroys its shell and temporary data.
// Links: zannastudio/src/editor/completion.zia,
//        zannastudio/src/editor/project_index.zia
//
//===----------------------------------------------------------------------===//

module intellisense_probe;

// ============================================================================
// MODULE: intellisense_probe
// PURPOSE: Broad regression probe for completion, diagnostics, hover, signature
//          help, symbols, inlay hints, and semantic project-index behavior.
//
// WHERE-THIS-FITS: This is an executable probe, not production IDE logic. It
//          exercises controllers through the same public surfaces used by the app
//          and reports RESULT lines for the test harness.
//
// TEACHING-NOTE: Large probes should still read as grouped scenarios. Keep helper
//          assertions close to the behavior they validate, and move new focused
//          coverage into smaller probes when a section grows.
// ============================================================================

bind "../ui/app_shell";
bind "../editor/editor_engine";
bind "../editor/completion";
bind "../editor/signature";
bind "../editor/hover";
bind "../editor/symbols";
bind "../editor/diagnostics";
bind "../editor/inlay_hints";
bind "../editor/project_index";
bind "../commands/edit_commands";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../services/locations";
bind "../services/workspace_edits";

bind Zanna.GUI;
bind ZiaCompletion = Zanna.Zia.Completion;
bind ZiaToolchain = Zanna.Zia.Toolchain;
bind BasicCompletion = Zanna.Basic.LanguageService;
bind BasicToolchain = Zanna.Basic.LanguageService;
bind SemanticJob = Zanna.Zia.SemanticJob;
bind Clock = Zanna.Time.Clock;
bind TempFile = Zanna.IO.TempFile;
bind File = Zanna.IO.File;
bind Dir = Zanna.IO.Dir;
bind Path = Zanna.IO.Path;
bind Terminal = Zanna.Terminal;
bind Str = Zanna.String;
bind Obj = Zanna.Core.Object;
bind Seq = Zanna.Collections.Seq;
bind Map = Zanna.Collections.Map;

final SEMANTIC_JOB_WAIT_MS = 4000;

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

func listContains(items: List, label: String) -> Boolean {
    var i = 0;
    while i < items.count() {
        if Obj.ToString(items.get(i)) == label {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func pumpCompletion(completer: completion.CompletionController, maxTicks: Integer) {
    var i = 0;
    while i < maxTicks and completer.isVisible == false {
        completer.Update("");
        Clock.Sleep(1);
        i = i + 1;
    }
}

func pumpSignature(sigCtrl: signature.SignatureController,
                   engine: editor_engine.EditorEngine,
                   maxTicks: Integer) {
    var i = 0;
    while i < maxTicks and sigCtrl.visible == false {
        sigCtrl.update(engine);
        Clock.Sleep(1);
        i = i + 1;
    }
}

func panelFitsUiViewport(app: GUI.App, panel: GUI.FloatingPanel) -> Boolean {
    if app == null or panel == null { return false; }
    return panel.GetScreenX() >= 0.0
        and panel.GetScreenY() >= 0.0
        and panel.GetScreenX() + panel.GetScreenWidth()
            <= app_shell.UiViewportWidth(app) + 1.0
        and panel.GetScreenY() + panel.GetScreenHeight()
            <= app_shell.UiViewportHeight(app) + 1.0;
}

func waitSemanticJob(job: Any, maxTicks: Integer) -> Boolean {
    if job == null { return false; }
    var i = 0;
    while i < maxTicks {
        if SemanticJob.IsDone(job) {
            return true;
        }
        Clock.Sleep(1);
        i = i + 1;
    }
    return false;
}

func completionItemsContain(items: Any, label: String) -> Boolean {
    if items == null { return false; }
    var i = 0;
    while i < Seq.get_Count(items) {
        var item = Seq.Get(items, i);
        if Map.GetStr(item, "label") == label {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func completionItemDocumentationContains(items: Any, label: String, needle: String) -> Boolean {
    if items == null { return false; }
    var i = 0;
    while i < Seq.get_Count(items) {
        var item = Seq.Get(items, i);
        if Map.GetStr(item, "label") == label
           and Str.IndexOf(Map.GetStr(item, "documentation"), needle) > 0 {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func main() {
    var shell = new app_shell.AppShell();
    var engine = new editor_engine.EditorEngine();
    var completer = new completion.CompletionController();
    var sigCtrl = new signature.SignatureController();
    var inlayCtrl = new inlay_hints.InlayHintController();
    var docMgr = new document_manager.DocumentManager();
    var projMgr = new project_manager.ProjectManager();

    shell.Build("Zanna Studio IntelliSense Probe", 820, 520);
    engine.Setup(shell.workbench.editorRow);
    projMgr.Setup(shell.workbench.sidebarTree);
    completer.Setup(engine.editor, shell.app);
    completer.SetEngine(engine);
    completer.SetWorkspaceContext(projMgr, docMgr);
    completer.SetSourcePath("intellisense_probe.zia");
    sigCtrl.setup(shell.app);
    sigCtrl.setSourcePath("intellisense_probe.zia");

    var hintSource = "module HintProbe;\n"
        + "func add(value: Integer, amount: Integer) -> Integer { return value + amount; }\n"
        + "func main() {\n"
        + "    var total = add(1, 2);\n"
        + "}\n";
    engine.SetText(hintSource);
    inlayCtrl.Refresh(engine);
    if inlayCtrl.lastHintCount < 2 or engine.editor.GetInlayHintCount() < 2 {
        fail(shell, "inlay hint controller");
        return;
    }
    inlayCtrl.SetEnabled(false);
    inlayCtrl.Refresh(engine);
    if engine.editor.GetInlayHintCount() != 0 {
        fail(shell, "inlay hint clear");
        return;
    }
    inlayCtrl.SetEnabled(true);

    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
        + "func main() {\n"
        + "    gr\n"
        + "}\n");
    engine.editor.SetCursor(3, 6);
    engine.editor.Focus();
    completer.TriggerCompletion();
    pumpCompletion(completer, 200);

    if completer.isVisible == false or completer.itemCount <= 0 {
        fail(shell, "completion did not open");
        return;
    }
    shell.app.SetWindowSize(400, 360);
    shell.Poll();
    completer.Update("");
    shell.Render();
    if panelFitsUiViewport(shell.app, completer.popup) == false {
        fail(shell, "completion popup escaped a compact viewport");
        return;
    }

    // UI zoom participates in widget geometry. The popup must use the
    // effective viewport rather than the backing-scale-only App logical size.
    shell.app.SetUiScale(2.0);
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    completer.Update("");
    shell.Render();
    if panelFitsUiViewport(shell.app, completer.popup) == false {
        fail(shell, "completion popup escaped the zoomed viewport");
        return;
    }
    shell.app.SetUiScale(1.0);
    shell.app.SetWindowSize(820, 520);
    shell.Poll();
    completer.Update("");
    shell.Render();
    if !engine.editor.IsFocused() {
        fail(shell, "completion stole editor focus");
        return;
    }
    if listContains(completer.allLabels, "greet") == false {
        fail(shell, "completion missing project function");
        return;
    }

    var structured = ZiaCompletion.ItemsForFile(engine.GetTextSnapshot(),
                                                "intellisense_probe.zia", 4, 6);
    var foundStructured = false;
    var s = 0;
    while s < Seq.get_Count(structured) {
        var item = Seq.Get(structured, s);
        if Map.GetStr(item, "label") == "greet" {
            foundStructured = true;
            if Map.GetStr(item, "insertText") != "greet"
               or Map.GetInt(item, "replacementStartColumn") != 4
               or Map.GetInt(item, "replacementEndColumn") != 6 {
                fail(shell, "structured completion replacement range");
                return;
            }
        }
        s = s + 1;
    }
    if foundStructured == false {
        fail(shell, "structured completion missing project function");
        return;
    }
    var completionDisplay = completion.FormatCompletionDisplay("greet", 6,
                                                               "Integer",
                                                               "Greets a value\nfor display",
                                                               "scope");
    if Str.IndexOf(completionDisplay, "[fn] greet") == 0
       or Str.IndexOf(completionDisplay, "Integer") == 0
       or Str.IndexOf(completionDisplay, "Greets a value for display") == 0
       or Str.IndexOf(completionDisplay, "[scope]") == 0 {
        fail(shell, "completion metadata display");
        return;
    }
    if completion.ShouldSuppressAutoCompletionLine("    // gr", 9) == false {
        fail(shell, "completion auto trigger not suppressed in line comment");
        return;
    }
    if completion.ShouldSuppressAutoCompletionLine("    var text = \"gr", 18) == false {
        fail(shell, "completion auto trigger not suppressed in string");
        return;
    }
    if completion.ShouldSuppressAutoCompletionLine("    var text = \"gr\".", 20) {
        fail(shell, "completion auto trigger suppressed after closed string");
        return;
    }
    engine.SetText("module IntelliProbe;\nfunc main() {\n    // gr\n}\n");
    engine.editor.SetCursor(2, 9);
    if completer.ShouldSuppressAutoTrigger() == false {
        fail(shell, "completion controller auto trigger context");
        return;
    }
    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
        + "func main() {\n"
        + "    gr\n"
        + "}\n");
    engine.editor.SetCursor(3, 6);
    var typeItems = ZiaCompletion.ItemsForFile(
        "module IntelliProbe;\nfunc main() {\n    var typed: I = 0;\n}\n",
        "intellisense_probe.zia",
        3,
        16);
    if completionItemsContain(typeItems, "Integer") == false {
        fail(shell, "type annotation completion after spaced colon");
        return;
    }
    var newItems = ZiaCompletion.ItemsForFile(
        "module IntelliProbe;\nclass LocalThing {\n}\nfunc main() {\n    var make = new Lo();\n}\n",
        "intellisense_probe.zia",
        5,
        21);
    if completionItemsContain(newItems, "LocalThing") == false {
        fail(shell, "new expression type completion");
        return;
    }

    var asyncJob = ZiaCompletion.BeginItemsForFile(engine.GetTextSnapshot(),
                                                   "intellisense_probe.zia", 4, 6);
    if waitSemanticJob(asyncJob, SEMANTIC_JOB_WAIT_MS) == false {
        fail(shell, "async completion job did not finish");
        return;
    }
    if SemanticJob.IsError(asyncJob) {
        fail(shell, "async completion error: " + SemanticJob.Error(asyncJob).UnwrapOrStr(""));
        return;
    }
    if completionItemsContain(SemanticJob.CompletionItems(asyncJob), "greet") == false {
        fail(shell, "async completion missing project function");
        return;
    }

    var symbolsJob = ZiaCompletion.BeginSymbolsForFile(engine.GetTextSnapshot(),
                                                       "intellisense_probe.zia");
    if waitSemanticJob(symbolsJob, SEMANTIC_JOB_WAIT_MS) == false {
        fail(shell, "async symbols job did not finish");
        return;
    }
    if Str.IndexOf(SemanticJob.Symbols(symbolsJob), "greet") == 0 {
        fail(shell, "async symbols missing project function");
        return;
    }
    completer.Hide();

    var workspaceRoot = TempFile.CreateDirWithPrefix("zannastudio_completion_workspace_");
    var workspaceMain = Path.Join(workspaceRoot, "main.zia");
    var workspaceHelper = Path.Join(workspaceRoot, "helper.zia");
    File.WriteAllText(workspaceMain,
        "module WorkspaceMain;\nfunc main() {\n    work\n}\n");
    File.WriteAllText(workspaceHelper,
        "module WorkspaceHelper;\nfunc workspaceHelper(value: Integer) -> Integer { return value; }\n");
    projMgr.OpenFolder(workspaceRoot);
    docMgr.OpenFile(workspaceMain);
    engine.SetText("module WorkspaceMain;\nfunc main() {\n    work\n}\n");
    engine.editor.SetCursor(2, 8);
    completer.SetSourcePath(workspaceMain);
    var workspacePumpTicks = 0;
    while listContains(completer.workspaceLabels, "workspaceHelper") == false
          and workspacePumpTicks < 400 {
        completer.PumpWorkspaceSymbolCache(20);
        Clock.Sleep(1);
        workspacePumpTicks = workspacePumpTicks + 1;
    }
    if listContains(completer.workspaceLabels, "workspaceHelper") == false {
        fail(shell, "workspace symbol cache missing project function count=" + completer.workspaceLabels.count());
        return;
    }
    completer.TriggerCompletion();
    pumpCompletion(completer, 600);
    if listContains(completer.allLabels, "workspaceHelper") == false {
        fail(shell, "workspace symbol completion missing project function");
        return;
    }
    completer.Hide();

    // A same-root refresh can produce the same file count while replacing
    // every cached path. Completion must use cache identity, not count alone,
    // or deleted symbols remain offered indefinitely.
    completer.workspaceLabels.Push("staleWorkspaceCompletion");
    var symbolCacheGeneration = projMgr.FileCacheGeneration();
    projMgr.RefreshTree();
    completer.PumpWorkspaceSymbolCache(1);
    if projMgr.FileCacheGeneration() == symbolCacheGeneration
       or completer.workspaceCacheGeneration != projMgr.FileCacheGeneration()
       or listContains(completer.workspaceLabels, "staleWorkspaceCompletion") {
        fail(shell, "workspace completion retained refreshed cache results");
        return;
    }
    projMgr.CloseProject();
    completer.PumpWorkspaceSymbolCache(1);

    var idleWorkspaceRoot = TempFile.CreateDirWithPrefix("zannastudio_completion_idle_workspace_");
    File.WriteAllText(Path.Join(idleWorkspaceRoot, "idle.zia"),
        "module IdleWorkspace;\nfunc idleWorkspaceSymbol() -> Integer { return 1; }\n");
    projMgr.OpenFolder(idleWorkspaceRoot);
    completer.Update("");
    if completer.workspaceRoot == idleWorkspaceRoot or completer.workspacePendingJob != null {
        fail(shell, "workspace symbol cache pumped while completion idle");
        return;
    }
    projMgr.CloseProject();
    Dir.RemoveAll(idleWorkspaceRoot);

    var activeWorkspaceRoot = TempFile.CreateDirWithPrefix("zannastudio_completion_active_workspace_");
    File.WriteAllText(Path.Join(activeWorkspaceRoot, "active.zia"),
        "module ActiveWorkspace;\nfunc activeWorkspaceSymbol() -> Integer { return 1; }\n");
    projMgr.OpenFolder(activeWorkspaceRoot);
    engine.SetText("module ActiveMain;\nfunc main() {\n    ac\n}\n");
    engine.editor.SetCursor(2, 6);
    completer.SetSourcePath(Path.Join(activeWorkspaceRoot, "main.zia"));
    completer.TriggerCompletion();
    pumpCompletion(completer, 200);
    completer.Update("x");
    if completer.workspaceRoot == activeWorkspaceRoot or completer.workspacePendingJob != null {
        fail(shell, "workspace symbol cache pumped while completion active");
        return;
    }
    completer.Hide();
    projMgr.CloseProject();
    Dir.RemoveAll(activeWorkspaceRoot);
    completer.SetSourcePath("intellisense_probe.zia");

    var badSrc = "module IntelliProbe;\nfunc f() -> Integer { return ; }\n";
    var diagJob = ZiaToolchain.BeginCheckForFile(badSrc, "intellisense_probe.zia");
    if waitSemanticJob(diagJob, SEMANTIC_JOB_WAIT_MS) == false {
        fail(shell, "async diagnostics job did not finish");
        return;
    }
    if Seq.get_Count(SemanticJob.Diagnostics(diagJob)) == 0 {
        fail(shell, "async diagnostics missing parser error");
        return;
    }
    var suppressSource = "module SuppressProbe;\n"
        + "func main() {\n"
        + "    var unusedValue = 1;\n"
        + "}\n";
    var suppressRecords = ZiaToolchain.CheckForFile(suppressSource, "intellisense_probe.zia");
    var suppressCode = edit_commands.SuppressibleDiagnosticCodeAt(suppressRecords, 3);
    if suppressCode == "" {
        fail(shell, "suppress warning diagnostic code");
        return;
    }
    engine.SetText(suppressSource);
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "zia";
    }
    engine.editor.SetCursor(2, 8);
    edit_commands.handleSuppressDiagnostic(shell, docMgr, engine);
    if Str.IndexOf(engine.GetTextSnapshot(), "// @suppress(" + suppressCode + ")") == 0 {
        fail(shell, "suppress warning command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != suppressSource {
        fail(shell, "suppress warning undo");
        return;
    }
    var fixSource = "module FixProbe;\n"
        + "func greet() -> Integer { return 1; }\n"
        + "func main() {\n"
        + "    grete();\n"
        + "}\n";
    var fixRecords = ZiaToolchain.CheckForFile(fixSource, "intellisense_probe.zia");
    var fixRecord = edit_commands.DiagnosticFixItAt(fixRecords, 4);
    if fixRecord == null or Map.GetBool(fixRecord, "hasFixit") == false
       or Map.GetStr(fixRecord, "fixitReplacement") != "greet" {
        fail(shell, "diagnostic fixit record");
        return;
    }
    if diagnostics.ProblemActionForDiagnosticRecord(fixRecord) == "No quick fix" {
        fail(shell, "diagnostic fixit problem action");
        return;
    }
    engine.SetText(fixSource);
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "zia";
    }
    engine.editor.SetCursor(3, 6);
    edit_commands.handleApplyDiagnosticFix(shell, docMgr, engine);
    if Str.IndexOf(engine.GetTextSnapshot(), "greet();") == 0 {
        fail(shell, "apply diagnostic fixit command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != fixSource {
        fail(shell, "apply diagnostic fixit undo");
        return;
    }
    var missingBindSource = "module MissingBindProbe;\n"
        + "func main() {\n"
        + "    Terminal.Say(\"hi\");\n"
        + "}\n";
    var missingBindRecords = ZiaToolchain.CheckForFile(missingBindSource,
                                                       "intellisense_probe.zia");
    var missingBindName = edit_commands.MissingRuntimeBindIdentifierAt(missingBindRecords, 3);
    if missingBindName != "Terminal" {
        fail(shell, "missing runtime bind diagnostic");
        return;
    }
    var missingBindRecord: Any = null;
    var mb = 0;
    while mb < Seq.get_Count(missingBindRecords) {
        var candidateMissingBind = Seq.Get(missingBindRecords, mb);
        if Map.GetInt(candidateMissingBind, "line") == 3 {
            missingBindRecord = candidateMissingBind;
        }
        mb = mb + 1;
    }
    if diagnostics.ProblemActionForDiagnosticRecord(missingBindRecord) != "Create Missing Bind" {
        fail(shell, "missing runtime bind problem action");
        return;
    }
    var expectedMissingBind = "module MissingBindProbe;\n"
        + "bind Terminal = Zanna.Terminal;\n"
        + "func main() {\n"
        + "    Terminal.Say(\"hi\");\n"
        + "}\n";
    if edit_commands.CreateMissingRuntimeBindText(missingBindSource, "Terminal")
       != expectedMissingBind {
        fail(shell, "missing runtime bind helper");
        return;
    }
    engine.SetText(missingBindSource);
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "zia";
    }
    engine.editor.SetCursor(2, 8);
    edit_commands.handleCreateMissingBind(shell, docMgr, engine, projMgr);
    if engine.GetTextSnapshot() != expectedMissingBind {
        fail(shell, "create missing bind command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != missingBindSource {
        fail(shell, "create missing bind undo");
        return;
    }

    if edit_commands.ProjectFileDefinesIdentifier(
        "module HelperModule;\nexpose func helperValue() -> Integer { return 1; }\n",
        "helperValue") == false {
        fail(shell, "project bind symbol detector");
        return;
    }

    var projectBindRoot = TempFile.CreateDirWithPrefix("zannastudio_missing_project_bind_");
    var projectBindMain = Path.Join(projectBindRoot, "main.zia");
    var projectBindHelper = Path.Join(projectBindRoot, "helper.zia");
    var projectBindSource = "module ProjectBindMain;\n"
        + "func main() -> Integer {\n"
        + "    return helperValue();\n"
        + "}\n";
    var projectBindExpected = "module ProjectBindMain;\n"
        + "bind \"./helper\";\n"
        + "func main() -> Integer {\n"
        + "    return helperValue();\n"
        + "}\n";
    File.WriteAllText(projectBindMain, projectBindSource);
    File.WriteAllText(projectBindHelper,
        "module HelperModule;\nexpose func helperValue() -> Integer { return 1; }\n");
    projMgr.OpenFolder(projectBindRoot);
    docMgr.OpenFile(projectBindMain);
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "zia";
    }
    engine.SetText(projectBindSource);
    engine.editor.SetCursor(2, 12);
    if edit_commands.CreateMissingProjectBindText(projectBindSource, "./helper")
       != projectBindExpected {
        fail(shell, "missing project bind helper");
        return;
    }
    edit_commands.handleCreateMissingBind(shell, docMgr, engine, projMgr);
    if engine.GetTextSnapshot() != projectBindExpected {
        fail(shell, "create missing project bind command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != projectBindSource {
        fail(shell, "create missing project bind undo");
        return;
    }

    File.WriteAllText(Path.Join(projectBindRoot, "other.zia"),
        "module OtherHelper;\nexpose func sharedThing() -> Integer { return 2; }\n");
    File.WriteAllText(projectBindHelper,
        "module HelperModule;\nexpose func sharedThing() -> Integer { return 1; }\n");
    projMgr.OpenFolder(projectBindRoot);
    var ambiguousSource = "module ProjectBindMain;\n"
        + "func main() -> Integer {\n"
        + "    return sharedThing();\n"
        + "}\n";
    engine.SetText(ambiguousSource);
    engine.editor.SetCursor(2, 12);
    edit_commands.handleCreateMissingBind(shell, docMgr, engine, projMgr);
    if engine.GetTextSnapshot() != ambiguousSource {
        fail(shell, "ambiguous project bind should not edit");
        return;
    }
    projMgr.CloseProject();
    Dir.RemoveAll(projectBindRoot);

    var snippetItems = ZiaCompletion.ItemsForFile(
        "module IntelliProbe;\nfunc main() {\n    wh\n}\n",
        "intellisense_probe.zia", 3, 6);
    var foundSnippetCursor = false;
    s = 0;
    while s < Seq.get_Count(snippetItems) {
        var snippet = Seq.Get(snippetItems, s);
        if Map.GetStr(snippet, "label") == "while" and Map.GetBool(snippet, "isSnippet") {
            foundSnippetCursor = Map.GetInt(snippet, "cursorOffset") > 0;
        }
        s = s + 1;
    }
    if foundSnippetCursor == false {
        fail(shell, "snippet completion cursor offset");
        return;
    }

    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
        + "func main() {\n"
        + "    gr\n"
        + "}\n");
    engine.editor.SetCursor(3, 6);
    completer.TriggerCompletion();
    pumpCompletion(completer, 200);
    if completer.AcceptTabKey() == false {
        fail(shell, "completion tab key accept not consumed");
        return;
    }
    var line = engine.editor.GetLine(3);
    if line != "    greet" {
        fail(shell, "completion tab key accept did not replace prefix cleanly: " + line);
        return;
    }

    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
        + "func main() {\n"
        + "    gr\n"
        + "}\n");
    engine.editor.SetCursor(3, 6);
    completer.TriggerCompletion();
    pumpCompletion(completer, 200);
    engine.editor.InsertAtCursor("    ");
    if completer.AcceptTypedTab("\t") == false {
        fail(shell, "completion tab accept not consumed");
        return;
    }
    line = engine.editor.GetLine(3);
    if line != "    greet" {
        fail(shell, "completion tab accept did not replace prefix cleanly: " + line);
        return;
    }

    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
        + "func main() {\n"
        + "    gr\n"
        + "}\n");
    engine.editor.SetCursor(3, 6);
    completer.TriggerCompletion();
    pumpCompletion(completer, 200);
    engine.editor.InsertAtCursor("    ");
    if completer.AcceptIfEditorInsertedTab() == false {
        fail(shell, "completion native tab fallback not consumed");
        return;
    }
    line = engine.editor.GetLine(3);
    if line != "    greet" {
        fail(shell, "completion native tab fallback did not replace prefix cleanly: " + line);
        return;
    }

    engine.SetText(
        "module IntelliProbe;\n"
        + "func greet(value: Integer) -> Integer { return value; }\n"
