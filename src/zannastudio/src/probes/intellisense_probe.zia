    inlineDoc.language = "zia";
    engine.LoadDocument(inlineDoc);
    engine.editor.SetCursor(2, 8);
    edit_commands.handleInlineLocalVariable(shell, inlineDocMgr, engine);
    if Str.IndexOf(engine.GetTextSnapshot(), "Say((count + 1))") == 0 {
        fail(shell, "inline local command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != inlineSource {
        fail(shell, "inline local undo");
        return;
    }

    var messyBinds = "module BindProbe;\n"
        + "bind Zeta = Zanna.Zeta;\n"
        + "bind Alpha = Zanna.Alpha;\n"
        + "bind Zeta = Zanna.Zeta;\n"
        + "\n"
        + "func main() {\n"
        + "}\n";
    var expectedBinds = "module BindProbe;\n"
        + "bind Alpha = Zanna.Alpha;\n"
        + "bind Zeta = Zanna.Zeta;\n"
        + "\n"
        + "func main() {\n"
        + "}\n";
    if edit_commands.OrganizeZiaBindsText(messyBinds) != expectedBinds {
        fail(shell, "organize binds pure helper");
        return;
    }
    engine.SetText(messyBinds);
    edit_commands.handleOrganizeBinds(shell, docMgr, engine);
    if engine.GetTextSnapshot() != expectedBinds {
        fail(shell, "organize binds command");
        return;
    }
    var messyWhitespace = "module TrimProbe;  \n"
        + "func main() {\t\n"
        + "    var value = 1;   \n"
        + "}\n";
    var expectedWhitespace = "module TrimProbe;\n"
        + "func main() {\n"
        + "    var value = 1;\n"
        + "}\n";
    if edit_commands.TrimTrailingWhitespaceText(messyWhitespace) != expectedWhitespace {
        fail(shell, "trim trailing whitespace pure helper");
        return;
    }
    engine.SetText(messyWhitespace);
    edit_commands.handleTrimTrailingWhitespace(shell, docMgr, engine);
    if engine.GetTextSnapshot() != expectedWhitespace {
        fail(shell, "trim trailing whitespace command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != messyWhitespace {
        fail(shell, "trim trailing whitespace undo");
        return;
    }
    if edit_commands.ZiaFunctionNameFromLine("expose func visible(value: Integer) -> Integer {") != "visible" {
        fail(shell, "call hierarchy function parser");
        return;
    }
    var callSource = "module CallProbe;\n"
        + "func target() -> Integer {\n"
        + "    return 1;\n"
        + "}\n"
        + "func caller() -> Integer {\n"
        + "    return target();\n"
        + "}\n";
    if edit_commands.EnclosingZiaFunctionName(callSource, 6) != "caller" {
        fail(shell, "incoming call enclosing function");
        return;
    }
    var callRoot = TempFile.CreateDirWithPrefix("zannastudio_incoming_calls_");
    var callPath = Path.Join(callRoot, "calls.zia");
    File.WriteAllText(callPath, callSource);
    var callDocMgr = new document_manager.DocumentManager();
    callDocMgr.OpenFile(callPath);
    engine.SetText(callSource);
    engine.editor.SetCursor(1, 8);
    var callIndexer = new project_index.ProjectIndexer();
    callIndexer.Open(callRoot, callDocMgr);
    callIndexer.FinishPendingIndex();
    var callLocs = new locations.LocationStore();
    edit_commands.handleIncomingCalls(shell, callDocMgr, engine, callIndexer, callLocs);
    if shell.toolPanels.referencesListBox.Count < 2 or callLocs.items.count() != 1 {
        fail(shell, "incoming calls command rows");
        return;
    }
    var foundCaller = false;
    var refIdx = 0;
    while refIdx < shell.toolPanels.referencesListBox.Count {
        shell.toolPanels.referencesListBox.SelectIndex(refIdx);
        if shell.toolPanels.referencesListBox.Selected != null {
            var rowText = GUI.ListBox.ItemGetText(shell.toolPanels.referencesListBox.Selected);
            if Str.IndexOf(rowText, "caller") != 0 {
                foundCaller = true;
            }
        }
        refIdx = refIdx + 1;
    }
    if foundCaller == false {
        fail(shell, "incoming calls missing caller group");
        return;
    }
    if edit_commands.ZiaFunctionEndLine(callSource, 5) != 7 {
        fail(shell, "outgoing call function end");
        return;
    }
    var outgoingTokens = edit_commands.OutgoingZiaCallTokens(callSource, 5, 7);
    if Seq.get_Count(outgoingTokens) != 1
       or Map.GetStr(Seq.Get(outgoingTokens, 0), "name") != "target" {
        fail(shell, "outgoing call token scan");
        return;
    }
    engine.SetText(callSource);
    engine.editor.SetCursor(5, 15);
    var outLocs = new locations.LocationStore();
    edit_commands.handleOutgoingCalls(shell, callDocMgr, engine, callIndexer, outLocs);
    if shell.toolPanels.referencesListBox.Count < 2 or outLocs.items.count() != 1 {
        fail(shell, "outgoing calls command rows");
        return;
    }
    var foundTarget = false;
    refIdx = 0;
    while refIdx < shell.toolPanels.referencesListBox.Count {
        shell.toolPanels.referencesListBox.SelectIndex(refIdx);
        if shell.toolPanels.referencesListBox.Selected != null {
            var rowText2 = GUI.ListBox.ItemGetText(shell.toolPanels.referencesListBox.Selected);
            if Str.IndexOf(rowText2, "target") != 0 {
                foundTarget = true;
            }
        }
        refIdx = refIdx + 1;
    }
    if foundTarget == false {
        fail(shell, "outgoing calls missing target group");
        return;
    }
    var undoRenameBefore = "module UndoRename;\n"
        + "func oldName() -> Integer {\n"
        + "    return 1;\n"
        + "}\n";
    var undoRenameAfter = "module UndoRename;\n"
        + "func newName() -> Integer {\n"
        + "    return 1;\n"
        + "}\n";
    engine.SetText(undoRenameBefore);
    callDocMgr.GetActive()!.content = undoRenameAfter;
    if edit_commands.ApplyActiveDocumentContentToEditor(callDocMgr, engine, null) == false {
        fail(shell, "active rename editor apply");
        return;
    }
    if engine.GetTextSnapshot() != undoRenameAfter {
        fail(shell, "active rename editor content");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != undoRenameBefore {
        fail(shell, "active rename undo step");
        return;
    }
    callIndexer.Destroy();
    Dir.RemoveAll(callRoot);
    engine.SetText("module IntelliProbe;\n    value\n");
    engine.editor.SetCursor(1, 9);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    if engine.editor.GetLine(1) != "    /* value */" {
        fail(shell, "toggle block comment add line");
        return;
    }
    engine.editor.Undo();
    if engine.editor.GetLine(1) != "    value" {
        fail(shell, "toggle block comment undo line");
        return;
    }
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    if engine.editor.GetLine(1) != "    value" {
        fail(shell, "toggle block comment remove line");
        return;
    }
    engine.SetText("alpha beta");
    engine.editor.SetCursorSelection(0, 0, 0, 0, 5);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    if engine.editor.GetLine(0) != "/* alpha */ beta" {
        fail(shell, "toggle block comment add selection");
        return;
    }
    engine.editor.Undo();
    if engine.editor.GetLine(0) != "alpha beta" {
        fail(shell, "toggle block comment undo selection");
        return;
    }
    engine.editor.SetCursorSelection(0, 0, 0, 0, 5);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    engine.editor.SetCursorSelection(0, 0, 0, 0, 11);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    if engine.editor.GetLine(0) != "alpha beta" {
        fail(shell, "toggle block comment remove selection");
        return;
    }
    var multiBlockBefore = "alpha\nbeta";
    engine.SetText(multiBlockBefore);
    engine.editor.SetCursorSelection(0, 0, 0, 1, 4);
    edit_commands.handleToggleBlockComment(shell, docMgr, engine);
    engine.editor.Undo();
    if engine.GetTextSnapshot() != multiBlockBefore {
        fail(shell, "toggle block comment undo multiline");
        return;
    }
    engine.SetText("alpha beta\ngamma");
    engine.editor.SetCursor(0, 2);
    edit_commands.handleExpandSelection(shell, engine);
    if !engine.editor.CursorHasSelection(0)
       or engine.editor.GetSelectionStartLineAt(0) != 0
       or engine.editor.GetSelectionStartColAt(0) != 0
       or engine.editor.GetSelectionEndColAt(0) != 5 {
        fail(shell, "expand selection word");
        return;
    }
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionEndColAt(0) != 10 {
        fail(shell, "expand selection line");
        return;
    }
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionEndLineAt(0) != 1
       or engine.editor.GetSelectionEndColAt(0) != 5 {
        fail(shell, "expand selection document");
        return;
    }
    edit_commands.handleShrinkSelection(shell, engine);
    if engine.editor.GetSelectionEndLineAt(0) != 0
       or engine.editor.GetSelectionEndColAt(0) != 10 {
        fail(shell, "shrink selection line");
        return;
    }
    edit_commands.handleShrinkSelection(shell, engine);
    if engine.editor.GetSelectionEndColAt(0) != 5 {
        fail(shell, "shrink selection word");
        return;
    }
    edit_commands.handleShrinkSelection(shell, engine);
    if engine.editor.CursorHasSelection(0) {
        fail(shell, "shrink selection collapse");
        return;
    }
    var inlineExpr = "call(alpha, beta)";
    if edit_commands.EnclosingInlineDelimiterOpenCol(inlineExpr, 7) != 4
       or edit_commands.MatchingInlineDelimiterCloseCol(inlineExpr, 4) != 16 {
        fail(shell, "inline delimiter helpers");
        return;
    }
    engine.SetText(inlineExpr);
    engine.editor.SetCursor(0, 7);
    edit_commands.handleExpandSelection(shell, engine);
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionStartColAt(0) != 4
       or engine.editor.GetSelectionEndColAt(0) != 17 {
        fail(shell, "expand selection inline delimiter");
        return;
    }
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionStartColAt(0) != 0
       or engine.editor.GetSelectionEndColAt(0) != 17 {
        fail(shell, "expand selection line after inline delimiter");
        return;
    }
    var blockExpandSource = "module ExpandProbe;\n"
        + "func main() {\n"
        + "    alpha beta\n"
        + "}\n"
        + "func other() {}\n";
    if edit_commands.EnclosingBraceOpenLine(blockExpandSource, 2) != 1
       or edit_commands.MatchingBraceCloseLine(blockExpandSource, 1) != 3 {
        fail(shell, "brace block helpers");
        return;
    }
    engine.SetText(blockExpandSource);
    engine.editor.SetCursor(2, 6);
    edit_commands.handleExpandSelection(shell, engine);
    edit_commands.handleExpandSelection(shell, engine);
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionStartLineAt(0) != 1
       or engine.editor.GetSelectionEndLineAt(0) != 3 {
        fail(shell, "expand selection block");
        return;
    }
    edit_commands.handleExpandSelection(shell, engine);
    if engine.editor.GetSelectionStartLineAt(0) != 0
       or engine.editor.GetSelectionEndLineAt(0) != 5 {
        fail(shell, "expand selection document after block");
        return;
    }
    engine.SetText("module IntelliProbe;\n    value\n");
    engine.editor.SetCursor(1, 9);
    edit_commands.handleDuplicateLine(shell, engine);
    if engine.editor.GetLine(2) != "    value" {
        fail(shell, "duplicate line");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != "module IntelliProbe;\n    value\n" {
        fail(shell, "duplicate line undo");
        return;
    }
    engine.SetText("one\ntwo\nthree");
    engine.editor.SetCursor(1, 1);
    edit_commands.handleMoveLineUp(shell, engine);
    if engine.editor.GetLine(0) != "two" or engine.editor.GetLine(1) != "one" {
        fail(shell, "move line up");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != "one\ntwo\nthree" {
        fail(shell, "move line up undo");
        return;
    }
    engine.editor.SetCursor(1, 1);
    edit_commands.handleMoveLineDown(shell, engine);
    if engine.editor.GetLine(1) != "three" or engine.editor.GetLine(2) != "two" {
        fail(shell, "move line down");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != "one\ntwo\nthree" {
        fail(shell, "move line down undo");
        return;
    }
    var messyFormat = "module FormatProbe;\n"
        + "func main() {\n"
        + "var x = 1;\n"
        + "if x {\n"
        + "Terminal.Say(\"{\");\n"
        + "}\n"
        + "}\n";
    var expectedFormat = "module FormatProbe;\n"
        + "func main() {\n"
        + "    var x = 1;\n"
        + "    if x {\n"
        + "        Terminal.Say(\"{\");\n"
        + "    }\n"
        + "}\n";
    if edit_commands.FormatZiaText(messyFormat, 4, true) != expectedFormat {
        fail(shell, "format zia helper");
        return;
    }
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "zia";
    }
    engine.SetText(messyFormat);
    edit_commands.handleFormatDocument(shell, docMgr, engine);
    if engine.GetTextSnapshot() != expectedFormat {
        fail(shell, "format document command");
        return;
    }
    engine.editor.Undo();
    if engine.GetTextSnapshot() != messyFormat {
        fail(shell, "format document undo");
        return;
    }
    var messySelection = "module FormatProbe;\n"
        + "func main() {\n"
        + "var x = 1;\n"
        + "if x {\n"
        + "Terminal.Say(\"}\");\n"
        + "}\n"
        + "}\n";
    var expectedSelection = "module FormatProbe;\n"
        + "func main() {\n"
        + "    var x = 1;\n"
        + "    if x {\n"
        + "        Terminal.Say(\"}\");\n"
        + "    }\n"
        + "}\n";
    engine.SetText(messySelection);
    engine.editor.SetCursorSelection(0, 2, 0, 5, 1);
    edit_commands.handleFormatSelection(shell, docMgr, engine);
    if engine.GetTextSnapshot() != expectedSelection {
        fail(shell, "format selection command");
        return;
    }
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "text";
    }
    engine.SetText("alpha   \nbeta   \n");
    engine.editor.SetCursorSelection(0, 0, 0, 0, 8);
    edit_commands.handleFormatSelection(shell, docMgr, engine);
    if engine.GetTextSnapshot() != "alpha\nbeta   \n" {
        fail(shell, "format text selection");
        return;
    }
    if docMgr.GetActive() != null {
        docMgr.GetActive()!.language = "basic";
    }
    engine.SetText(messyFormat);
    edit_commands.handleFormatDocument(shell, docMgr, engine);
    if engine.GetTextSnapshot() != messyFormat {
        fail(shell, "format unsupported basic");
        return;
    }

    // ===== Zanna BASIC language services via the Zanna.Basic.* bridge (Phase 4) =====
    // Sync, in-process: a type-mismatch must be flagged, and completion at the cursor
    // must surface in-scope symbols (keyword TO + the DIM'd TOTAL).
    var basicBad = "DIM x AS INTEGER\nx = \"hello\"\n";
    var basicDiags = BasicToolchain.CheckForFile(basicBad, "probe.bas");
    if Seq.get_Count(basicDiags) == 0 {
        fail(shell, "basic diagnostics missing type-mismatch error");
        return;
    }
    var basicSrc = "DIM total AS INTEGER\ntotal = 1\nPRINT to";
    var basicItems = BasicCompletion.ItemsForFile(basicSrc, "probe.bas", 3, 9);
    if Seq.get_Count(basicItems) == 0 {
        fail(shell, "basic completion returned no items");
        return;
    }
    // BASIC canonicalizes identifiers to uppercase, so the symbol is "GREET".
    var basicSyms = BasicCompletion.SymbolsForFile("SUB Greet()\n  PRINT \"hi\"\nEND SUB\n", "probe.bas");
    if Str.IndexOf(basicSyms, "GREET") == 0 {
        fail(shell, "basic symbols missing SUB Greet");
        return;
    }
    var basicHover = BasicCompletion.HoverInfoForFile(basicSrc, "probe.bas", 2, 0);
    if Map.GetBool(basicHover, "available") == false {
        fail(shell, "basic hover not available for 'total'");
        return;
    }

    shell.Destroy();
    Terminal.Say("RESULT: ok");
}
