    var editB = Map.New();
    Map.SetStr(editB, "file", inactiveRenamePath);
    Map.SetInt(editB, "startLine", 1);
    Map.SetInt(editB, "startColumn", 1);
    Map.SetInt(editB, "endLine", 1);
    Map.SetInt(editB, "endColumn", 4);
    Map.SetStr(editB, "newText", "new");
