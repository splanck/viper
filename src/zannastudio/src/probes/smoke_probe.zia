//
// File: zannastudio/src/probes/smoke_probe.zia
// Purpose: Smoke-test Zanna Studio shell construction, rendering, activation, and
//          idle event waiting.
// Key invariants:
//   - Probe exits with RESULT: ok on successful startup/render coverage.
//   - Hidden/no-activate graphics modes remain usable for automated tests.
//   - Compact editor lanes suppress the minimap and wider lanes restore it.
// Ownership/Lifetime: The probe owns and destroys its shell and editor models.
// Links: zannastudio/src/ui/app_shell.zia,
//        zannastudio/src/ui/workbench_shell.zia
//
//===----------------------------------------------------------------------===//

module smoke_probe;

bind "../ui/app_shell";
bind "../core/document_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";

bind Zanna.GUI as GUI;
bind Zanna.Terminal as Terminal;

// ============================================================================
// MODULE: smoke_probe
// PURPOSE: Headless smoke test for the IDE shell. Builds the window,
//          sets up the editor + minimap + tab, loads a synthetic
//          document, probes editor hit-testing and tab state restore,
//          polls + renders ONE frame, then tears down and
//          prints "RESULT: ok".
//
// WHERE-THIS-FITS: Run by the ctest target `zia_smoke_zannastudio` in CI
//          to catch construction-time regressions (a misnamed widget,
//          missing runtime binding, etc.) without needing a display.
//          Exits cleanly so the test harness can detect failure as a
//          non-zero exit code.
//
// KEY-DESIGN-CHOICES:
//   * SINGLE FRAME. We only Poll + Render once. The goal is construction
//     plus cheap editor state probes; full interaction testing belongs in
//     a dedicated GUI automation harness.
//   * MINIMAP TOGGLE. The Off-then-On dance exercises the minimap's
//     SetVisible runtime which was a source of regressions during the
//     visibility-API rollout.
//   * RESULT MARKER. The test harness greps stdout for "RESULT: ok"
//     to confirm success — exit code alone wouldn't distinguish "ran
//     to completion" from "crashed during teardown after work."
// ============================================================================

/// @brief Smoke-probe entry point. Builds, ticks one frame, exits ok.
func main() {
    var shell = new app_shell.AppShell();
    var docMgr = new document_manager.DocumentManager();
    var engine = new editor_engine.EditorEngine();
    var tabs = new editor_tabs.EditorTabs();

    shell.Build("Zanna Studio Smoke", 960, 640);
    shell.CenterAndSize(72);
    shell.Activate();
    engine.Setup(shell.workbench.editorRow);

    shell.workbench.minimap = GUI.Minimap.New(shell.workbench.editorRow);
    shell.workbench.minimap.SetWidth(80);
    shell.workbench.minimap.BindEditor(engine.editor);
    shell.workbench.minimap.SetVisible(false);
    shell.workbench.minimap.SetVisible(true);

    tabs.Setup(shell.workbench.tabBar);

    var doc = docMgr.NewDocument();
    doc.content = "func main() {\n    return;\n}\n";
    tabs.AddTab(doc.fileName, 1);
    tabs.SetActive(0);
    engine.LoadDocument(doc);
    engine.SetSize(400, 40);

    var failed = "";

    engine.editor.SetCursor(1, 4);
    var cursorX = engine.editor.GetCursorPixelX();
    var cursorY = engine.editor.GetCursorPixelY();
    if engine.editor.GetLineAtPixel(cursorY) != 1 {
        failed = "hit-test line";
    } else if engine.editor.GetColAtPixel(cursorX, cursorY) != 4 {
        failed = "hit-test column";
    }

    doc.content = "line0\nline1\nline2\nline3\nline4\nline5\nline6\nline7\n";
    engine.LoadDocument(doc);
    engine.SetSize(400, 30);
    engine.editor.SetCursor(3, 2);
    engine.editor.ScrollTopLine = 3;
    engine.SaveToDocument(doc);

    var doc2 = docMgr.NewDocument();
    doc2.content = "other\n";
    tabs.AddTab(doc2.fileName, 1);
    tabs.SetActive(1);
    engine.LoadDocument(doc2);

    tabs.SetActive(0);
    engine.LoadDocument(doc);
    if failed == "" and engine.GetCursorLine() != 4 {
        failed = "tab cursor line restore";
    } else if failed == "" and engine.GetCursorCol() != 3 {
        failed = "tab cursor column restore";
    } else if failed == "" and engine.GetScrollLine() != 4 {
        failed = "tab scroll restore";
    }

    shell.SetStatusLeft("Smoke");
    shell.SetStatusCenter("Ln 1, Col 1");
    shell.SetStatusRight(doc.fileName);

    // The supported window minimum is still too narrow for the sidebar,
    // editor, and a permanently reserved minimap. Keep the user's enabled
    // preference, but reclaim the minimap width until the editor lane grows.
    shell.ApplyWorkbenchWindowConstraints();
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    shell.Render();
    shell.Poll();
    shell.Render();
    if shell.workbench.minimap.IsVisible()
       or shell.workbench.minimapRequestedVisible == false {
        failed = "compact editor retained minimap";
    } else {
        shell.app.SetWindowSize(1100, 700);
        shell.Poll();
        shell.Render();
        shell.Poll();
        shell.Render();
        if shell.workbench.minimap.IsVisible() == false {
            failed = "wide editor did not restore minimap";
        } else {
            shell.workbench.SetMinimapRequestedVisible(false);
            shell.Render();
            if shell.workbench.minimap.IsVisible() {
                failed = "disabled minimap preference was ignored";
            }
            shell.workbench.SetMinimapRequestedVisible(true);
        }
    }

    if failed != "" {
        shell.Destroy();
        Terminal.Say("RESULT: fail " + failed);
        return;
    }

    shell.Poll();
    shell.Render();
    shell.Activate();

    // PollWait must return within its (clamped) timeout and not trap: a couple
    // of short idle waits exercise the blocking-event-wait runtime path.
    var i = 0;
    while i < 3 {
        shell.PollWait(5);
        shell.Render();
        i = i + 1;
    }

    shell.Destroy();

    Terminal.Say("RESULT: ok");
}
