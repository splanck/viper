//===----------------------------------------------------------------------===//
//
// File: zannastudio/src/probes/welcome_probe.zia
// Purpose: Exercise the Zanna Studio welcome surface and guard its layout,
//          compact build metadata, empty state, and visibility transitions.
// Key invariants:
//   - Primary welcome sections remain vertically ordered without overlap.
//   - Diagnostic build metadata never leaks multi-line paths into the hero.
//   - Empty editor tab chrome never consumes welcome-screen space.
//   - The supported workbench minimum retains a compact recent-work card.
//   - Whole-UI zoom raises the native floor instead of shrinking usable space.
//   - Whole-UI zoom crosses chrome font scaling exactly once.
//   - The About overlay keeps its footer bounded and long metadata scrollable.
//   - Opening command input replaces About instead of stacking focus surfaces.
//   - Visual-hold modes keep standard and zoomed surfaces open for screenshot QA.
// Ownership/Lifetime:
//   - The probe owns one AppShell and destroys it before reporting success.
// Links: zannastudio/src/ui/welcome_view.zia,
//        zannastudio/src/app/build_info.zia
//
//===----------------------------------------------------------------------===//

module welcome_probe;

// ============================================================================
// MODULE: welcome_probe
// PURPOSE: Verify the welcome/start surface (plan 18): SetShown toggles the
//          welcome host and editor row inversely, Refresh populates recents
//          without trapping, and the action buttons exist.
// ============================================================================

bind "../ui/app_shell";
bind "../ui/welcome_view";
bind "../ui/ide_overlays";
bind "../ui/command_input";
bind "../app/build_info";
bind "../commands/command_catalog";
bind "../commands/view_commands";
bind "../core/session";
bind "../editor/editor_tabs";

bind Zanna.GUI as GUI;
bind Terminal = Zanna.Terminal;
bind Env = Zanna.System.Environment;
bind Machine = Zanna.System.Machine;
bind Dir = Zanna.IO.Dir;
bind File = Zanna.IO.File;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;

func HasArg(name: String) -> Boolean {
    // VM `zanna run -- ...` arguments begin at zero; native probe binaries may
    // include an executable slot, so scan every entry for this explicit flag.
    var i = 0;
    while i < Env.GetArgumentCount() {
        if Env.GetArgument(i) == name { return true; }
        i = i + 1;
    }
    return false;
}

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

func panelFitsUiViewport(app: GUI.App, panel: GUI.FloatingPanel) -> Boolean {
    if app == null or panel == null { return false; }
    return panel.GetScreenX() >= 0.0
        and panel.GetScreenY() >= 0.0
        and panel.GetScreenX() + panel.GetScreenWidth()
            <= app_shell.UiViewportWidth(app) + 1.0
        and panel.GetScreenY() + panel.GetScreenHeight()
            <= app_shell.UiViewportHeight(app) + 1.0;
}

func main() {
    var shell = new app_shell.AppShell();
    shell.Build("Zanna Studio Welcome Probe", 900, 640);
    // Match the production startup path so native HiDPI sizing and centering
    // are part of the visual/layout regression rather than testing only the
    // constructor's provisional window extent.
    shell.CenterAndSize(72);

    if shell.menuChrome.tbSave.IsEnabled()
       or shell.menuChrome.tbSaveAll.IsEnabled()
       or shell.menuChrome.tbBuild.IsEnabled()
       or shell.menuChrome.tbRun.IsEnabled()
       or shell.menuChrome.tbDebug.IsEnabled()
       or shell.menuChrome.tbFind.IsEnabled()
       or shell.menuChrome.miSave.IsEnabled()
       or shell.menuChrome.miClose.IsEnabled()
       or shell.menuChrome.miQuickOpen.IsEnabled()
       or shell.menuChrome.miSearchProject.IsEnabled()
       or shell.menuChrome.miBuild.IsEnabled()
       or shell.menuChrome.miDebugStart.IsEnabled()
       or shell.menuChrome.tbNew.IsEnabled() == false
       or shell.menuChrome.tbOpen.IsEnabled() == false {
        fail(shell, "empty welcome command chrome");
        return;
    }

    // Periodic idle state refreshes must not override the empty-context gate.
    var idleExecutionApplyCount = shell.menuChrome.executionStateApplyCount;
    shell.SetBuildJobActive(false, "");
    shell.SetDebugSessionState(false, false, false);
    if shell.menuChrome.tbBuild.IsEnabled()
       or shell.menuChrome.tbRun.IsEnabled()
       or shell.menuChrome.tbDebug.IsEnabled()
       or shell.menuChrome.executionStateApplyCount != idleExecutionApplyCount {
        fail(shell, "idle refresh re-enabled empty welcome commands");
        return;
    }

    // A project can build from its manifest without an editor tab, but the
    // debugger still requires a concrete saved source file.
    shell.SetCommandContextAvailable(false, true, true, false);
    if shell.menuChrome.tbBuild.IsEnabled() == false
       or shell.menuChrome.tbRun.IsEnabled() == false
       or shell.menuChrome.tbDebug.IsEnabled()
       or shell.menuChrome.tbSave.IsEnabled()
       or shell.menuChrome.tbFind.IsEnabled()
       or shell.menuChrome.miQuickOpen.IsEnabled() == false
       or shell.menuChrome.miSearchProject.IsEnabled() == false {
        fail(shell, "project-only welcome command chrome");
        return;
    }
    shell.SetCommandContextAvailable(false, false, false, false);

    var wv = new welcome_view.WelcomeView();
    wv.Setup(shell.workbench.welcomeHost, shell.workbench.editorRow);
    var overlays = new ide_overlays.IdeOverlays();
    overlays.Setup(shell);
    var commandOverlay = new command_input.CommandInputOverlay();
    commandOverlay.Setup(shell);
    var tabs = new editor_tabs.EditorTabs();
    tabs.Setup(shell.workbench.tabBar);
    if shell.workbench.tabBar.IsVisible() {
        fail(shell, "empty tab strip visible on welcome screen");
        return;
    }
    tabs.AddTab("first.zia", 1);
    if shell.workbench.tabBar.IsVisible() == false {
        fail(shell, "first document did not restore tab strip");
        return;
    }
    tabs.RemoveTab(0);
    if shell.workbench.tabBar.IsVisible() {
        fail(shell, "last tab close left empty strip visible");
        return;
    }
    // Match main's no-project startup chrome: the activity bar remains usable,
    // while the otherwise empty Explorer pane must not offset the welcome card.
    shell.SetSidebarVisible(false);

    shell.SetWelcomeStatusMode(true);
    shell.Poll();
    shell.Render();
    if shell.statusShell.welcomeMode == false {
        fail(shell, "welcome status policy did not activate");
        return;
    }
    shell.SetWelcomeStatusMode(false);
    shell.Poll();
    shell.Render();
    if shell.statusShell.welcomeMode {
        fail(shell, "document status policy did not restore");
        return;
    }
    shell.SetWelcomeStatusMode(true);

    if wv.content == null or wv.buildLabel == null or wv.actionRow == null
        or wv.recentHeader == null or wv.newFileButton == null
        or wv.openFolderButton == null or wv.recentList == null
        or wv.emptyRecentLabel == null or wv.hintLabel == null {
        fail(shell, "welcome widgets not built");
        return;
    }
    if wv.commandPaletteShortcut
       != command_catalog.PlatformShortcut("Ctrl+Shift+P") {
        fail(shell, "welcome command hint is not platform-native");
        return;
    }

    // Cooperative restore must show an intentional progress card between
    // bounded pages instead of exposing empty split panes and live controls.
    wv.SetStartupMode(true);
    wv.SetStartupProgress("Restoring your workspace: 2/5");
    wv.SetShown(true);
    shell.Poll();
    shell.Render();
    if wv.startupMode == false or wv.actionRow.IsVisible()
        or wv.recentHeader.IsVisible() or wv.recentList.IsVisible()
        or wv.emptyRecentLabel.IsVisible() or wv.hintLabel.IsVisible()
        or wv.startupProgressText != "Restoring your workspace: 2/5"
        or shell.workbench.welcomeHost.IsVisible() == false
        or shell.workbench.editorRow.IsVisible() {
        fail(shell, "startup restore surface exposes empty editor or live content");
        return;
    }
    wv.SetStartupMode(false);
    if wv.startupMode or wv.actionRow.IsVisible() == false
        or wv.recentHeader.IsVisible() == false
        or wv.emptyRecentLabel.IsVisible() == false
        or wv.hintLabel.IsVisible() == false {
        fail(shell, "welcome content did not restore after startup");
        return;
    }

    var compact = build_info.CompactSummary(
        "Build: probe\nSource: /private/source\nOutput: /private/output\nZanna: /private/zanna");
    if compact != "Build: probe" {
        fail(shell, "welcome build summary should be one line");
        return;
    }
    var versionedCompact = build_info.CompactSummary(
        "Zanna Studio 9.8.7-test\nBuild: probe\nSource: private");
    if versionedCompact != "Zanna Studio 9.8.7-test" {
        fail(shell, "welcome should prefer stamped product identity");
        return;
    }
    if welcome_view.ContentWidthForHost(1200.0) < 719.5
        or welcome_view.ContentWidthForHost(600.0) < 527.5
        or welcome_view.ContentWidthForHost(600.0) > 528.5
        or welcome_view.ContentWidthForHost(300.0) < 317.5 {
        fail(shell, "welcome content width should clamp to its host");
        return;
    }
    if welcome_view.UsesCompactLayout(455.0) == false
        or welcome_view.CanShowCompactRecents(455.0) == false
        or welcome_view.CanShowCompactRecents(300.0) {
        fail(shell, "welcome compact-height policy hides usable recent work");
        return;
    }

    // Shown: welcome host visible, editor row hidden.
    wv.SetShown(true);
    shell.Poll();
    shell.Render();
    if shell.workbench.leftViewStack.GetWidth() > 1 {
        fail(shell, "empty startup sidebar still consumes width");
        return;
    }
    if shell.workbench.welcomeHost.IsVisible() == false {
        fail(shell, "welcome host not visible when shown");
        return;
    }
    if shell.workbench.editorRow.IsVisible() {
        fail(shell, "editor row should be hidden when welcome shown");
        return;
    }

    var buildBottom = wv.buildLabel.GetLogicalY() + wv.buildLabel.GetLogicalHeight();
    if buildBottom > wv.actionRow.GetLogicalY() {
        fail(shell, "build metadata overlaps welcome actions");
        return;
    }
    var actionBottom = wv.actionRow.GetLogicalY() + wv.actionRow.GetLogicalHeight();
    if actionBottom > wv.recentHeader.GetLogicalY() {
        fail(shell, "welcome actions overlap recent header");
        return;
    }
    var headerBottom = wv.recentHeader.GetLogicalY() + wv.recentHeader.GetLogicalHeight();
    if headerBottom > wv.emptyRecentLabel.GetLogicalY() {
        fail(shell, "recent header overlaps empty state");
        return;
    }
    var recentBottom = wv.emptyRecentLabel.GetLogicalY()
        + wv.emptyRecentLabel.GetLogicalHeight();
    if wv.hintLabel.IsVisible()
       and recentBottom > wv.hintLabel.GetLogicalY() {
        fail(shell, "recent empty state overlaps command hint");
        return;
    }

    // Optional manual visual-QA mode. Hold the already-rendered desktop-sized
    // surface before the automated resize cases below; macOS can deliver those
    // synthetic resize notifications after the calls return, which would make
    // a screenshot observe an unrelated transient viewport.
    if HasArg("--visual-hold") {
        Terminal.Say("VISUAL: window=" + shell.app.GetWidth() + "x"
            + shell.app.GetHeight() + " logical=" + shell.app.GetLogicalWidth()
            + "x" + shell.app.GetLogicalHeight() + " scale="
            + shell.app.GetScale() + " monitor=" + shell.app.GetMonitorWidth()
            + "x" + shell.app.GetMonitorHeight());
        while true {
            shell.PollWait(16);
            if shell.WasCloseRequested() { break; }
            wv.SetShown(true);
            shell.Render();
        }
    }

    // The production shell publishes a native minimum instead of allowing the
    // workbench to collapse to a sliver. Explicit resize requests share the
    // same floor, which keeps automation and interactive resizing consistent.
    shell.ApplyWorkbenchWindowConstraints();
    var expectedMinW = 720;
    var expectedMinH = 520;
    if shell.app.GetMonitorWidth() > 96
       and expectedMinW > shell.app.GetMonitorWidth() - 96 {
        expectedMinW = shell.app.GetMonitorWidth() - 96;
    }
    if shell.app.GetMonitorHeight() > 96
       and expectedMinH > shell.app.GetMonitorHeight() - 96 {
        expectedMinH = shell.app.GetMonitorHeight() - 96;
    }
    shell.app.SetWindowSize(64, 64);
    shell.Poll();
    shell.Render();
    wv.SetShown(true);
    shell.Poll();
    shell.Render();
    if shell.app.GetLogicalWidth() < expectedMinW
       or shell.app.GetLogicalHeight() < expectedMinH {
        fail(shell, "native workbench minimum size was not enforced");
        return;
    }
    var constrainedHostHeight = shell.workbench.welcomeHost.GetHeight();
    if welcome_view.CanShowCompactRecents(constrainedHostHeight)
       and (wv.recentHeader.IsVisible() == false
            or wv.emptyRecentLabel.IsVisible() == false) {
        fail(shell, "workbench minimum hid reachable recent work");
        return;
    }
    if welcome_view.UsesCompactLayout(constrainedHostHeight)
       and wv.hintLabel.IsVisible() {
        fail(shell, "compact welcome retained the low-priority command hint");
        return;
    }

    // Whole-UI zoom grows control metrics, padding, and typography. Keeping the
    // same native floor would halve the effective workbench at 200% and bring
    // clipped chrome back. Grow the floor with zoom, but retain the same
    // monitor-gap cap used for unusually small displays.
    shell.app.SetUiScale(2.0);
    shell.ApplyWorkbenchWindowConstraints();
    view_commands.applyShellFont(shell);
    var zoomedLogicalChromeSize = shell.app.GetLogicalFontSize();
    if zoomedLogicalChromeSize < 14.9 or zoomedLogicalChromeSize > 15.1 {
        fail(shell, "UI zoom was applied twice to the chrome font");
        return;
    }
    var expectedZoomMinW = 1440;
    var expectedZoomMinH = 1040;
    if shell.app.GetMonitorWidth() > 96
       and expectedZoomMinW > shell.app.GetMonitorWidth() - 96 {
        expectedZoomMinW = shell.app.GetMonitorWidth() - 96;
    }
    if shell.app.GetMonitorHeight() > 96
       and expectedZoomMinH > shell.app.GetMonitorHeight() - 96 {
        expectedZoomMinH = shell.app.GetMonitorHeight() - 96;
    }
    shell.Poll();
    shell.Render();
    if shell.app.GetLogicalWidth() < expectedZoomMinW
       or shell.app.GetLogicalHeight() < expectedZoomMinH {
        fail(shell, "UI zoom did not expand the undersized workbench");
        return;
    }
    if Machine.Os == "macos" {
        if shell.app.GetX() < 0
           or shell.app.GetX() + shell.app.GetLogicalWidth()
               > shell.app.GetMonitorWidth()
           or shell.app.GetY() < 0
           or shell.app.GetY() + shell.app.GetLogicalHeight()
               > shell.app.GetMonitorHeight() - 16 {
            fail(shell, "zoom expansion left the workbench outside the desktop");
            return;
        }
    }
    shell.app.SetWindowSize(64, 64);
    shell.Poll();
    shell.Render();
    if shell.app.GetLogicalWidth() < expectedZoomMinW
       or shell.app.GetLogicalHeight() < expectedZoomMinH {
        fail(shell, "UI zoom did not raise the native workbench minimum");
        return;
    }

    overlays.OpenAbout(shell);
    shell.Poll();
    shell.Render();
    if panelFitsUiViewport(shell.app, overlays.aboutPanel) == false {
        fail(shell, "About overlay escaped the zoomed workbench");
        return;
    }
    if HasArg("--visual-zoom-hold") {
        Terminal.Say("VISUAL: zoomed window=" + shell.app.GetLogicalWidth() + "x"
            + shell.app.GetLogicalHeight() + " ui=" + shell.app.GetUiScale()
            + " logical-font=" + shell.app.GetLogicalFontSize()
            + " position=" + shell.app.GetX() + "," + shell.app.GetY()
            + " monitor=" + shell.app.GetMonitorWidth() + "x"
            + shell.app.GetMonitorHeight());
        while true {
            shell.PollWait(16);
            if shell.WasCloseRequested() { break; }
            shell.Render();
        }
    }
    overlays.CloseAbout();

    // Return to the normal scale/floor before testing the production About
    // card at the standard compact workbench size.
    shell.app.SetUiScale(1.0);
    shell.ApplyWorkbenchWindowConstraints();
    view_commands.applyShellFont(shell);
    shell.app.SetWindowSize(expectedMinW, expectedMinH);
    shell.Poll();
    shell.Render();

    // About is part of the no-project opening experience. Its diagnostic build
    // metadata can be much taller than the common case, so keep it clipped in
    // a scroll viewport while the Close action remains fixed inside the card.
    overlays.OpenAbout(shell);
    shell.Poll();
    shell.Render();
    var panelBottom = overlays.aboutPanel.GetScreenY()
        + overlays.aboutPanel.GetScreenHeight();
    var closeBottom = overlays.aboutCloseButton.GetScreenY()
        + overlays.aboutCloseButton.GetScreenHeight();
    if panelFitsUiViewport(shell.app, overlays.aboutPanel) == false
       or closeBottom > panelBottom {
        fail(shell, "About overlay escaped the supported workbench bounds");
        return;
    }
    var footerTop = overlays.aboutCloseButton.GetScreenY();
    overlays.aboutBuildInfo.SetText(
        "Zanna Studio layout probe\n"
        + "Build: 2026-07-22T12:34:56Z\n"
        + "Source: /a/very/long/project/path/used/to/exercise/wrapped/build/metadata/source\n"
        + "Output: /a/very/long/project/path/used/to/exercise/wrapped/build/metadata/output\n"
        + "Compiler: /a/very/long/toolchain/path/used/to/exercise/wrapped/build/metadata/compiler\n"
        + "Commit: 0123456789abcdef0123456789abcdef01234567\n"
        + "Configuration: native-release-with-debug-information\n"
        + "Target: arm64-apple-darwin\n"
        + "Runtime: embedded-vm-and-native-code-generator\n"
        + "Diagnostics: complete standalone build metadata");
    shell.Render();
    overlays.aboutBodyScroll.SetScroll(0.0, 100000.0);
    shell.Render();
    var scrolledFooterTop = overlays.aboutCloseButton.GetScreenY();
    if overlays.aboutBodyScroll.GetScrollY() <= 0.0
       or scrolledFooterTop < footerTop - 0.5
       or scrolledFooterTop > footerTop + 0.5
       or overlays.aboutCloseButton.GetScreenY()
              + overlays.aboutCloseButton.GetScreenHeight() > panelBottom {
        fail(shell, "About metadata is not independently scrollable");
        return;
    }
    overlays.CloseAbout();
    shell.Render();

    // Interactive overlays must replace one another. Stacking two focusable
    // panels makes Enter/Escape ambiguous and visually mangles the workbench.
    overlays.OpenAbout(shell);
    commandOverlay.OpenGoToLine(shell, 12);
    overlays.Pump(shell);
    commandOverlay.Pump(shell);
    if overlays.aboutVisible or overlays.aboutPanel.IsVisible()
       or commandOverlay.IsVisible() == false {
        fail(shell, "command input stacked over About");
        return;
    }
    commandOverlay.Cancel();

    // Restore the unconstrained runtime default so this component probe can
    // still exercise defensive compact layout below Studio's production floor.
    shell.app.SetMinimumSize(1, 1);
    shell.app.SetWindowSize(560, 360);
    shell.Poll();
    shell.Render();
    wv.SetShown(true);
    shell.Poll();
    shell.Render();
    if welcome_view.UsesCompactLayout(shell.workbench.welcomeHost.GetLogicalHeight()) == false
        or welcome_view.CanShowCompactRecents(shell.workbench.welcomeHost.GetLogicalHeight())
        or wv.recentHeader.IsVisible() or wv.recentList.IsVisible()
        or wv.emptyRecentLabel.IsVisible() or wv.hintLabel.IsVisible() {
        fail(shell, "compact welcome leaves clipped secondary content");
        return;
    }

    shell.app.SetWindowSize(900, 640);
    shell.Poll();
    shell.Render();
    wv.SetShown(true);
    shell.Poll();
    shell.Render();
    if welcome_view.UsesCompactLayout(shell.workbench.welcomeHost.GetLogicalHeight())
        or wv.recentHeader.IsVisible() == false or wv.hintLabel.IsVisible() == false {
        fail(shell, "welcome secondary content did not restore after resize");
        return;
    }

    // Hidden: inverse.
    wv.SetShown(false);
    shell.Poll();
    shell.Render();
    if shell.workbench.welcomeHost.IsVisible() {
        fail(shell, "welcome host should hide when not shown");
        return;
    }
    if shell.workbench.editorRow.IsVisible() == false {
        fail(shell, "editor row should be visible when welcome hidden");
        return;
    }

    // Workspace folders are first-class recent rows. They lead recent files,
    // remain visually distinguishable, and return a typed selection payload.
    var recentDir = TempFile.CreateDirWithPrefix("zannastudio_welcome_recent_");
    var recentProject = Path.Join(recentDir, "sample workspace");
    Dir.MakeAll(recentProject);
    var recentFile = Path.Join(recentDir, "sample.zia");
    File.WriteAllText(recentFile, "module WelcomeRecent;\n");
    var populatedSession = new session.SessionManager();
    populatedSession.Setup(Path.Join(recentDir, "settings.ini"));
    if populatedSession.RecordRecentFile(recentFile) == false
       or populatedSession.RecordRecentProject(recentProject) == false {
        fail(shell, "recent welcome fixtures were not persisted");
        return;
    }
    wv.Refresh(populatedSession);
    if wv.recentList.Count != 2 or wv.recentList.IsVisible() == false
       or wv.emptyRecentLabel.IsVisible()
       or welcome_view.GUIRecentProjectDisplayText(recentProject)
          != "sample workspace/    " + recentDir {
        fail(shell, "recent workspace and file rows were not composed");
        return;
    }
    wv.recentList.SelectIndex(0);
    if wv.TakeRecentSelection() != "folder:" + recentProject {
        fail(shell, "recent workspace selection lost its action type");
        return;
    }
    wv.recentList.SelectIndex(1);
    if wv.TakeRecentSelection() != "file:" + recentFile {
        fail(shell, "recent file selection lost its action type");
        return;
    }

    // Refresh against an empty session must not trap.
    var sessionMgr = new session.SessionManager();
    wv.Refresh(sessionMgr);
    shell.Render();
    if wv.recentList.IsVisible() or wv.emptyRecentLabel.IsVisible() == false {
        fail(shell, "empty recent-file state not shown");
        return;
    }

    shell.Destroy();
    Terminal.Say("RESULT: ok");
}
