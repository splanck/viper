//
// File: zannastudio/src/probes/diff_view_probe.zia
// Purpose: Regress exact, capped, and asynchronously owned Studio diff work.
// Key invariants:
//   - Uncapped rows reconstruct both inputs exactly.
//   - Capped rows retain a bounded prefix but count the complete result.
//   - Latest-wins worker jobs publish no canceled request.
// Ownership/Lifetime: The probe owns and drains every DiffJob it starts.
// Links: zannastudio/src/services/diff_engine.zia,
//        zannastudio/src/services/diff_job.zia
//
//===----------------------------------------------------------------------===//

module diff_view_probe;

// ============================================================================
// MODULE: diff_view_probe
// PURPOSE: Verify the plan 07 diff engine — identical inputs align as SAME,
//          insertions/deletions/changes classify correctly, row line numbers
//          stay 1-based and monotone, and the aligned rows reconstruct both
//          input documents exactly.
// ============================================================================

bind "../services/diff_engine";
bind "../services/diff_job";

bind Terminal = Zanna.Terminal;
bind Clock = Zanna.Time.Clock;
bind Str = Zanna.String;

func fail(reason: String) {
    Terminal.Say("RESULT: fail " + reason);
}

/// @brief Rebuild the left document from aligned rows.
func RebuildLeft(rows: List) -> String {
    var out = "";
    var first = true;
    var i = 0;
    while i < rows.count() {
        var row = rows.get(i) as diff_engine.DiffRow;
        if row.kind != diff_engine.ROW_ADDED {
            if first == false { out = out + "\n"; }
            out = out + row.leftText;
            first = false;
        }
        i = i + 1;
    }
    return out;
}

/// @brief Rebuild the right document from aligned rows.
func RebuildRight(rows: List) -> String {
    var out = "";
    var first = true;
    var i = 0;
    while i < rows.count() {
        var row = rows.get(i) as diff_engine.DiffRow;
        if row.kind != diff_engine.ROW_REMOVED {
            if first == false { out = out + "\n"; }
            out = out + row.rightText;
            first = false;
        }
        i = i + 1;
    }
    return out;
}

func main() {
    // Identical documents: every row SAME.
    var same = diff_engine.BuildRows("a\nb\nc", "a\nb\nc");
    if diff_engine.CountKind(same, diff_engine.ROW_SAME) != 3
       or same.count() != 3 {
        fail("identical inputs must align as three SAME rows");
        return;
    }

    // Pure insertion.
    var ins = diff_engine.BuildRows("a\nc", "a\nb\nc");
    if diff_engine.CountKind(ins, diff_engine.ROW_ADDED) != 1 {
        fail("insertion not classified");
        return;
    }

    // Pure deletion.
    var del = diff_engine.BuildRows("a\nb\nc", "a\nc");
    if diff_engine.CountKind(del, diff_engine.ROW_REMOVED) != 1 {
        fail("deletion not classified");
        return;
    }

    // Change pairs into a CHANGED row.
    var chg = diff_engine.BuildRows("a\nold\nc", "a\nnew\nc");
    if diff_engine.CountKind(chg, diff_engine.ROW_CHANGED) != 1 {
        fail("change not classified");
        return;
    }

    // Reconstruction: rows must rebuild both documents exactly.
    var leftDoc = "alpha\nbravo\ncharlie\ndelta\necho";
    var rightDoc = "alpha\nbravo2\ncharlie\ninserted\ndelta\nfoxtrot";
    var rows = diff_engine.BuildRows(leftDoc, rightDoc);
    if RebuildLeft(rows) != leftDoc {
        fail("left reconstruction mismatch: " + RebuildLeft(rows));
        return;
    }
    if RebuildRight(rows) != rightDoc {
        fail("right reconstruction mismatch: " + RebuildRight(rows));
        return;
    }

    // Line numbers stay monotone and 1-based.
    var lastLeft = 0;
    var lastRight = 0;
    var i = 0;
    while i < rows.count() {
        var row = rows.get(i) as diff_engine.DiffRow;
        if row.leftLine != 0 {
            if row.leftLine != lastLeft + 1 {
                fail("left line numbering broke at row " + i);
                return;
            }
            lastLeft = row.leftLine;
        }
        if row.rightLine != 0 {
            if row.rightLine != lastRight + 1 {
                fail("right line numbering broke at row " + i);
                return;
            }
            lastRight = row.rightLine;
        }
        i = i + 1;
    }

    // Empty edges.
    var emptyBoth = diff_engine.BuildRows("", "");
    if diff_engine.CountKind(emptyBoth, diff_engine.ROW_SAME) != emptyBoth.count() {
        fail("empty-vs-empty should be trivially same");
        return;
    }
    var addAll = diff_engine.BuildRows("", "x\ny");
    if diff_engine.CountKind(addAll, diff_engine.ROW_ADDED) < 1 {
        fail("empty-to-content should classify additions");
        return;
    }

    // Display-sized row retention must not lose full summary counts.
    var capped = diff_engine.BuildRowsCapped(
        "a\nb\nc\nd\ne", "A\nB\nC\nD\nE", 3);
    if capped.rows.count() != 3 or capped.totalRows != 5
       or capped.changedCount != 5 or capped.truncated == false {
        fail("capped diff rows or summary counts");
        return;
    }

    // The owned worker returns immediately, publishes a typed bounded result,
    // and can be drained safely during teardown.
    var job = new diff_job.DiffJob();
    var generation = job.Queue("small", leftDoc, rightDoc);
    if generation <= 0 or job.IsBusy() == false {
        fail("diff worker did not start asynchronously");
        return;
    }
    var attempts = 0;
    while job.IsBusy() and attempts < 5000 {
        job.Pump();
        Clock.Sleep(1);
        attempts = attempts + 1;
    }
    job.Pump();
    var completed = job.TakeCompleted();
    if completed == null or completed!.generation != generation
       or completed!.succeeded == false or completed!.result == null
       or completed!.result.totalRows != rows.count() {
        job.CancelAndWait();
        fail("diff worker result");
        return;
    }

    // A later request supersedes a live calculation; only the latest title may
    // publish after the serial worker drains.
    var heavyLeft = new Zanna.Text.StringBuilder();
    var heavyRight = new Zanna.Text.StringBuilder();
    i = 0;
    while i < 1200 {
        if i > 0 {
            heavyLeft.Append("\n");
            heavyRight.Append("\n");
        }
        heavyLeft.Append("left-" + i);
        heavyRight.Append("right-" + i);
        i = i + 1;
    }
    job.Queue("obsolete", heavyLeft.ToString(), heavyRight.ToString());
    var latestGeneration = job.Queue("latest", "one\ntwo", "one\nthree");
    attempts = 0;
    while job.IsBusy() and attempts < 5000 {
        job.Pump();
        Clock.Sleep(1);
        attempts = attempts + 1;
    }
    job.Pump();
    completed = job.TakeCompleted();
    if completed == null or completed!.generation != latestGeneration
       or completed!.title != "latest" or job.cancelledCount <= 0 {
        job.CancelAndWait();
        fail("diff worker latest-wins cancellation");
        return;
    }

    // Line-shape limits fail logically without entering the diff engine.
    var limited = new diff_job.DiffRequest();
    limited.leftText = Str.Repeat("\n", 20000);
    limited.rightText = "";
    diff_job.RunDiff(limited);
    if limited.succeeded == false or limited.reason != "too_many_lines"
       or limited.result != null {
        job.CancelAndWait();
        fail("diff worker line limit");
        return;
    }
    if job.CancelAndWait() == false {
        fail("diff worker shutdown drain");
        return;
    }

    Terminal.Say("RESULT: ok");
}
