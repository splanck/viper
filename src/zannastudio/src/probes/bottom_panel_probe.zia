//
// File: zannastudio/src/probes/bottom_panel_probe.zia
// Purpose: Verify dockable-panel collapse, movement, sizing, and tab stability.
// Key invariants:
//   - A hidden bottom panel consumes no editor viewport height.
//   - One panel tree moves among left, bottom, and right splitter hosts.
//   - Real pointer drags reveal stationary targets and commit only valid drops.
//   - Individual tools form simultaneous left/bottom/right/floating groups
//     without reconstructing live widgets or publishing restore edges.
//   - The floating group moves, resizes, docks back, and persists bounds.
//   - The primary sidebar moves left/right without losing width, focus, or state.
//   - Showing or switching tool panels preserves the configured split.
//   - Responsive tool tabs use effective logical width exactly once.
//   - Search controls wrap inside narrow side docks and restore wide geometry.
//   - `--visual-hold` displays a reordered right-dock fixture for screenshot QA.
// Ownership/Lifetime:
//   - The probe owns and destroys its isolated AppShell window.
// Links: zannastudio/src/ui/tool_panel_shell.zia,
//        zannastudio/src/ui/workbench_shell.zia
//
//===----------------------------------------------------------------------===//

module bottom_panel_probe;

// ============================================================================
// MODULE: bottom_panel_probe
// PURPOSE: Validate plan 11 — the editor and bottom tool panels share one
//          vertical splitter, so every panel tab has the same height (no editor
//          jump on tab switch), the bottom area collapses when no panel is shown,
//          and a persisted split percentage is applied.
//
// WHERE-THIS-FITS: workbench_shell builds the vertical SplitPane (First = editor,
//          Second = panel host); tool_panel_shell drives collapse/restore from
//          the panel show/hide paths.
// ============================================================================

bind "../ui/app_shell";
bind "../ui/tool_panel_model";
bind "../ui/tool_panel_shell";
bind "../ui/workspace_dock";

bind Zanna.GUI as GUI;
bind Terminal = Zanna.Terminal;
bind Env = Zanna.System.Environment;
bind Convert = Zanna.Core.Convert;

func HasArg(name: String) -> Boolean {
    var i = 0;
    while i < Env.GetArgumentCount() {
        if Env.GetArgument(i) == name { return true; }
        i = i + 1;
    }
    return false;
}

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

/// @brief Return whether one live widget remains inside a parent screen rect.
func ContainsWidget(parent: GUI.Widget, child: GUI.Widget) -> Boolean {
    if parent == null or child == null { return false; }
    return child.GetScreenX() >= parent.GetScreenX() - 1.0
        and child.GetScreenY() >= parent.GetScreenY() - 1.0
        and child.GetScreenX() + child.GetScreenWidth()
            <= parent.GetScreenX() + parent.GetScreenWidth() + 1.0
        and child.GetScreenY() + child.GetScreenHeight()
            <= parent.GetScreenY() + parent.GetScreenHeight() + 1.0;
}

/// @brief Dispatch authored pointer input through the normal app event path.
func DispatchDockFrame(shell: app_shell.AppShell,
                       harness: GUI.TestHarness) -> Boolean {
    var accepted = harness.DispatchPending();
    shell.workbench.PumpSidebarDocking();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    return accepted >= 0;
}

/// @brief Convert public logical widget geometry to harness framebuffer pixels.
func HarnessCoordinate(shell: app_shell.AppShell,
                       logical: Number) -> Integer {
    var scale = shell.app.GetEffectiveScale();
    if scale <= 0.0 { scale = 1.0; }
    return Convert.NumToInt(logical * scale);
}

/// @brief Click one rendered dock control through the production event route.
func ClickDockControl(shell: app_shell.AppShell,
                      harness: GUI.TestHarness,
                      widget: GUI.Widget) -> Boolean {
    var x = HarnessCoordinate(shell,
        widget.GetScreenX() + widget.GetScreenWidth() / 2.0);
    var y = HarnessCoordinate(shell,
        widget.GetScreenY() + widget.GetScreenHeight() / 2.0);
    harness.SendMouse("move", x, y, 0);
    harness.SendMouse("down", x, y, 0);
    harness.SendMouse("up", x, y, 0);
    return DispatchDockFrame(shell, harness);
}

/// @brief Press and move the real panel header beyond the drag dead zone.
func BeginDockDrag(shell: app_shell.AppShell,
                   harness: GUI.TestHarness) -> Boolean {
    var dragX = HarnessCoordinate(shell,
        shell.toolPanels.dockDragHandle.GetScreenX()
        + shell.toolPanels.dockDragHandle.GetScreenWidth() / 2.0);
    var dragY = HarnessCoordinate(shell,
        shell.toolPanels.dockDragHandle.GetScreenY()
        + shell.toolPanels.dockDragHandle.GetScreenHeight() / 2.0);
    harness.SendMouse("move", dragX, dragY, 0);
    harness.SendMouse("down", dragX, dragY, 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "move", dragX + HarnessCoordinate(shell, 8.0), dragY, 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    return shell.toolPanels.dockDragHandle.IsBeingDragged()
        and shell.toolPanels.AreDockDragTargetsVisible();
}

/// @brief Press and move the real primary-sidebar header beyond the dead zone.
func BeginSidebarDrag(shell: app_shell.AppShell,
                      harness: GUI.TestHarness) -> Boolean {
    var dragX = HarnessCoordinate(shell,
        shell.workbench.primarySidebar.dragHandle.GetScreenX()
        + shell.workbench.primarySidebar.dragHandle.GetScreenWidth() / 2.0);
    var dragY = HarnessCoordinate(shell,
        shell.workbench.primarySidebar.dragHandle.GetScreenY()
        + shell.workbench.primarySidebar.dragHandle.GetScreenHeight() / 2.0);
    harness.SendMouse("move", dragX, dragY, 0);
    harness.SendMouse("down", dragX, dragY, 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "move", dragX + HarnessCoordinate(shell, 8.0), dragY, 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    return shell.workbench.primarySidebar.dragHandle.IsBeingDragged()
        and shell.workbench.AreSidebarDockTargetsVisible();
}

/// @brief Move an active real pointer drag to one physical coordinate.
func MoveDockDrag(shell: app_shell.AppShell,
                  harness: GUI.TestHarness,
                  x: Integer,
                  y: Integer) -> Boolean {
    harness.SendMouse(
        "move", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    return DispatchDockFrame(shell, harness);
}

/// @brief Release an active real pointer drag at one physical coordinate.
func ReleaseDockDrag(shell: app_shell.AppShell,
                     harness: GUI.TestHarness,
                     x: Integer,
                     y: Integer) -> Boolean {
    harness.SendMouse(
        "up", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    return DispatchDockFrame(shell, harness);
}

/// @brief Drag a pressed floating-window handle by one logical delta.
func DragFloatingControl(shell: app_shell.AppShell,
                         harness: GUI.TestHarness,
                         widget: GUI.Widget,
                         deltaX: Integer,
                         deltaY: Integer) -> Boolean {
    var x = widget.GetScreenX() + widget.GetScreenWidth() / 2.0;
    var y = widget.GetScreenY() + widget.GetScreenHeight() / 2.0;
    harness.SendMouse(
        "move", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    harness.SendMouse(
        "down", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "move",
        HarnessCoordinate(shell, x + deltaX),
        HarnessCoordinate(shell, y + deltaY),
        0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "up",
        HarnessCoordinate(shell, x + deltaX),
        HarnessCoordinate(shell, y + deltaY),
        0);
    return DispatchDockFrame(shell, harness);
}

/// @brief Drag the floating group to one attached workbench edge.
func DockFloatingGroupAt(shell: app_shell.AppShell,
                         harness: GUI.TestHarness,
                         location: Integer) -> Boolean {
    var handle = shell.toolPanels.floatingToolMoveHandle;
    var x = handle.GetScreenX() + handle.GetScreenWidth() / 2.0;
    var y = handle.GetScreenY() + handle.GetScreenHeight() / 2.0;
    var targetX = Convert.NumToInt(
        shell.toolPanels.workspaceDropTarget.GetScreenX()
        + shell.toolPanels.workspaceDropTarget.GetScreenWidth() / 2.0);
    var targetY = Convert.NumToInt(
        shell.toolPanels.workspaceDropTarget.GetScreenY()
        + shell.toolPanels.workspaceDropTarget.GetScreenHeight() * 0.42);
    if location == workspace_dock.DOCK_LEFT {
        targetX = Convert.NumToInt(
            shell.toolPanels.workspaceDropTarget.GetScreenX() + 4.0);
    } else if location == workspace_dock.DOCK_RIGHT {
        targetX = Convert.NumToInt(
            shell.toolPanels.workspaceDropTarget.GetScreenX()
            + shell.toolPanels.workspaceDropTarget.GetScreenWidth() - 4.0);
    } else if location == workspace_dock.DOCK_BOTTOM {
        targetY = Convert.NumToInt(
            shell.toolPanels.workspaceDropTarget.GetScreenY()
            + shell.toolPanels.workspaceDropTarget.GetScreenHeight() - 4.0);
    } else {
        return false;
    }
    harness.SendMouse(
        "move", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    harness.SendMouse(
        "down", HarnessCoordinate(shell, x), HarnessCoordinate(shell, y), 0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "move",
        HarnessCoordinate(shell, targetX),
        HarnessCoordinate(shell, targetY),
        0);
    if !DispatchDockFrame(shell, harness) { return false; }
    harness.SendMouse(
        "up",
        HarnessCoordinate(shell, targetX),
        HarnessCoordinate(shell, targetY),
        0);
    return DispatchDockFrame(shell, harness);
}

func main() {
    var shell = new app_shell.AppShell();
    shell.Build("Zanna Studio Bottom Panel Probe", 1100, 760);
    shell.Poll();
    shell.Render();

    if !tool_panel_shell.SearchUsesCompactControls(520.0)
       or tool_panel_shell.SearchUsesCompactControls(520.01)
       or tool_panel_shell.SearchUsesCompactControls(0.0)
       or !tool_panel_shell.TerminalUsesCompactActions(360.0)
       or tool_panel_shell.TerminalUsesCompactActions(360.01)
       or tool_panel_shell.TerminalUsesCompactActions(0.0) {
        fail(shell, "tool-panel responsive thresholds were unstable");
        return;
    }

    var split = shell.workbench.editorSplit;
    if split == null { fail(shell, "editorSplit missing"); return; }

    // No panel yet: use the explicit collapsed-side state. Merely moving the
    // divider to 1.0 still leaves the second child's minimum-height strip in
    // the layout, which looks like a permanently empty bottom panel.
    if split.GetCollapsedSide() != 2 {
        fail(shell, "bottom has no explicit collapsed state: " + split.GetCollapsedSide());
        return;
    }
    if shell.workbench.bottomPanelHost.GetHeight() > 1 {
        fail(shell, "hidden bottom still consumes height: "
              + shell.workbench.bottomPanelHost.GetHeight());
        return;
    }

    // Sidebar collapse uses the same explicit splitter contract. The vertical
    // activity bar sits outside this split and remains available while the
    // explorer/source-control pane itself must shrink all the way to zero.
    var sidebarPosition = shell.workbench.splitPane.GetPosition();
    shell.workbench.ToggleSidebar();
    shell.Render();
    if shell.workbench.splitPane.GetCollapsedSide() != 1
       or shell.workbench.leftViewStack.GetWidth() > 1 {
        fail(shell, "hidden sidebar still consumes width");
        return;
    }
    shell.workbench.ToggleSidebar();
    shell.Render();
    var restoredSidebarPosition = shell.workbench.splitPane.GetPosition();
    var sidebarDelta = restoredSidebarPosition - sidebarPosition;
    if sidebarDelta < 0.0 { sidebarDelta = 0.0 - sidebarDelta; }
    if shell.workbench.splitPane.GetCollapsedSide() != 0
       or sidebarDelta > 0.01
       or shell.workbench.leftViewStack.GetWidth() <= 1 {
        fail(shell, "sidebar restore lost its previous width");
        return;
    }

    // Sidebar divider changes are durable workspace state. Controller-authored
    // restores establish a new baseline and must not publish an input edge.
    shell.workbench.splitPane.SetPosition(0.333);
    if shell.workbench.TakeChangedSidebarWidthPercent() != 33
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "sidebar drag did not publish one rounded width");
        return;
    }
    shell.workbench.SetSidebarWidthPct(24);
    if shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "persisted sidebar width masqueraded as a drag");
        return;
    }
    shell.workbench.SetSidebarVisible(false);
    shell.workbench.SetSidebarWidthPct(35);
    if shell.workbench.splitPane.GetCollapsedSide() != 1 {
        fail(shell, "hidden persisted sidebar width reopened the pane");
        return;
    }
    shell.workbench.SetSidebarVisible(true);
    shell.Render();
    var restoredPersistedSidebar = shell.workbench.splitPane.GetPosition();
    if restoredPersistedSidebar < 0.34
       or restoredPersistedSidebar > 0.36
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "hidden sidebar width did not restore cleanly");
        return;
    }
    shell.workbench.SetSidebarWidthPct(24);

    // The primary sidebar is a real movable dock rather than a fixed left
    // column. Moving it keeps the same live view tree, focus, logical width,
    // collapsed state, and one-shot persistence edges.
    if shell.workbench.GetSidebarPositionName() != "left"
       or shell.workbench.rightSidebarSplit.GetCollapsedSide() != 2 {
        fail(shell, "primary sidebar did not start in the left dock");
        return;
    }
    shell.workbench.sidebarTree.Focus();
    shell.workbench.MoveSidebarTo(workspace_dock.DOCK_RIGHT);
    shell.Render();
    if shell.workbench.GetSidebarPositionName() != "right"
       or shell.workbench.splitPane.GetCollapsedSide() != 1
       or shell.workbench.rightSidebarSplit.GetCollapsedSide() != 0
       or shell.workbench.leftSidebarHost.GetChildCount() != 0
       or shell.workbench.rightSidebarHost.GetChildCount() != 1
       or shell.workbench.sidebarTree.IsFocused() == false
       or shell.workbench.leftViewStack.GetScreenX()
              <= shell.workbench.workbenchRow.GetScreenX()
       or shell.workbench.activityBar.GetScreenX()
              < shell.workbench.leftViewStack.GetScreenX()
                + shell.workbench.leftViewStack.GetScreenWidth() - 1.0 {
        fail(shell, "right sidebar move lost topology, focus, or placement");
        return;
    }
    if shell.workbench.TakeChangedSidebarPosition() != "right"
       or shell.workbench.TakeChangedSidebarPosition() != "" {
        fail(shell, "right sidebar move did not publish one durable edge");
        return;
    }

    shell.workbench.rightSidebarSplit.SetPosition(0.667);
    if shell.workbench.TakeChangedSidebarWidthPercent() != 33
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "right sidebar divider did not publish logical width");
        return;
    }
    shell.workbench.SetSidebarWidthPct(24);
    if shell.workbench.rightSidebarSplit.GetPosition() < 0.75
       or shell.workbench.rightSidebarSplit.GetPosition() > 0.77
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "right sidebar persisted width replay was not mirrored");
        return;
    }
    shell.workbench.SetSidebarVisible(false);
    shell.workbench.SetSidebarWidthPct(35);
    if shell.workbench.rightSidebarSplit.GetCollapsedSide() != 2
       or shell.workbench.activityBar.IsVisible() == false {
        fail(shell, "hidden right sidebar consumed space or hid activity rail");
        return;
    }
    shell.workbench.SetSidebarVisible(true);
    shell.Render();
    if shell.workbench.rightSidebarSplit.GetPosition() < 0.64
       or shell.workbench.rightSidebarSplit.GetPosition() > 0.66
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1 {
        fail(shell, "hidden right sidebar width did not restore cleanly");
        return;
    }

    // Persisted/controller-authored placement never masquerades as user input.
    shell.workbench.SetSidebarPositionName("left");
    shell.workbench.SetSidebarWidthPct(24);
    shell.Render();
    if shell.workbench.GetSidebarPositionName() != "left"
       or shell.workbench.TakeChangedSidebarPosition() != ""
       or shell.workbench.splitPane.GetCollapsedSide() != 0
       or shell.workbench.rightSidebarSplit.GetCollapsedSide() != 2 {
        fail(shell, "persisted left sidebar placement leaked an input edge");
        return;
    }

    // Exercise the production header drag and stationary target cards. The
    // cards are bounded inside the editor workbench and only the hovered edge
    // accepts the typed primary-sidebar payload.
    var sidebarHarness = GUI.TestHarness.New();
    if !sidebarHarness.BindApp(shell.app) {
        fail(shell, "sidebar dock automation could not bind the app");
        return;
    }
    shell.workbench.sidebarTree.Focus();
    if !BeginSidebarDrag(shell, sidebarHarness) {
        fail(shell, "primary sidebar header did not begin a real drag: "
             + "dragging="
             + shell.workbench.primarySidebar.dragHandle.IsBeingDragged()
             + " targets="
             + shell.workbench.AreSidebarDockTargetsVisible()
             + " hovered="
             + shell.workbench.primarySidebar.dragHandle.IsHovered()
             + " pressed="
             + shell.workbench.primarySidebar.dragHandle.IsPressed()
             + " handle="
             + shell.workbench.primarySidebar.dragHandle.GetScreenX()
             + "," + shell.workbench.primarySidebar.dragHandle.GetScreenY()
             + " size="
             + shell.workbench.primarySidebar.dragHandle.GetScreenWidth()
             + "x"
             + shell.workbench.primarySidebar.dragHandle.GetScreenHeight());
        return;
    }
    if shell.workbench.primarySidebar.leftTarget.IsVisible() == false
       or shell.workbench.primarySidebar.rightTarget.IsVisible() == false
       or shell.workbench.primarySidebar.leftTarget.GetLogicalX() < 0.0
       or shell.workbench.primarySidebar.rightTarget.GetLogicalX()
              + shell.workbench.primarySidebar.rightTarget.GetLogicalWidth()
              > shell.workbench.workbenchRow.GetLogicalWidth() + 1.0
       or shell.workbench.primarySidebar.leftTarget.GetLogicalX()
              >= shell.workbench.primarySidebar.rightTarget.GetLogicalX() {
        fail(shell, "primary sidebar targets were not bounded edge cards");
        return;
    }
    var sidebarRightX = Convert.NumToInt(
        shell.workbench.primarySidebar.rightTarget.GetScreenX()
        + shell.workbench.primarySidebar.rightTarget.GetScreenWidth() / 2.0);
    var sidebarRightY = Convert.NumToInt(
        shell.workbench.primarySidebar.rightTarget.GetScreenY()
        + shell.workbench.primarySidebar.rightTarget.GetScreenHeight() / 2.0);
    if !MoveDockDrag(
           shell, sidebarHarness, sidebarRightX, sidebarRightY)
       or shell.workbench.primarySidebar.rightTarget.IsDragOver() == false
       or shell.workbench.primarySidebar.leftTarget.IsDragOver() {
        fail(shell, "right primary-sidebar target did not own drag hover");
        return;
    }
    if !ReleaseDockDrag(
           shell, sidebarHarness, sidebarRightX, sidebarRightY) {
        fail(shell, "right primary-sidebar target release was not dispatched");
        return;
    }
    shell.workbench.PumpSidebarDocking();
    shell.Render();
    if shell.workbench.GetSidebarPositionName() != "right"
       or shell.workbench.AreSidebarDockTargetsVisible()
       or shell.workbench.sidebarTree.IsFocused() == false
       or shell.workbench.TakeChangedSidebarPosition() != "right"
       or shell.workbench.TakeChangedSidebarPosition() != "" {
        fail(shell, "real sidebar drop lost focus, state, or persistence edge");
        return;
    }
    shell.workbench.SetSidebarPositionName("left");
    shell.workbench.SetSidebarWidthPct(24);
    shell.Render();

    // Showing a panel restores the split to the configured fraction (default 70%
    // editor). Terminal needs no content to display.
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    if split.GetCollapsedSide() != 0 {
        fail(shell, "terminal show did not restore second pane");
        return;
    }
    var p1 = split.GetPosition();
    if p1 < 0.6 or p1 > 0.8 {
        fail(shell, "terminal show did not restore split (~0.70): " + p1);
        return;
    }
    var editorH1 = shell.workbench.editorRow.GetHeight();

    // Switching to another panel keeps the SAME split position — the editor must
    // not jump. Variables and Terminal share one height now.
    shell.toolPanels.ShowVariablesPanel();
    shell.Render();
    var p2 = split.GetPosition();
    if p2 < 0.6 or p2 > 0.8 {
        fail(shell, "variables show changed split unexpectedly: " + p2);
        return;
    }
    var editorH2 = shell.workbench.editorRow.GetHeight();
    if editorH1 != editorH2 {
        fail(shell, "editor height jumped between tabs: " + editorH1 + " vs " + editorH2);
        return;
    }

    // Tool tabs are genuinely movable: routing follows stable tab identity,
    // and a successful drag publishes one serialized order for persistence.
    if shell.toolPanels.GetToolTabOrder()
       != tool_panel_model.DEFAULT_TAB_ORDER {
        fail(shell, "tool tabs did not start in the stable default order");
        return;
    }
    if shell.toolPanels.toolTabBar.MoveTab(7, 0) == false {
        fail(shell, "tool tab reorder was rejected");
        return;
    }
    shell.toolPanels.PumpToolTabs();
    var movedOrder = shell.toolPanels.TakeChangedToolTabOrder();
    if movedOrder
       != "terminal,problems,output,search,references,variables,call-stack,debug-console"
       or shell.toolPanels.TakeChangedToolTabOrder() != "" {
        fail(shell, "tool tab reorder did not publish one durable order");
        return;
    }
    shell.toolPanels.toolTabBar.SetActive(shell.toolPanels.toolSearchTab);
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.activeToolPanelKind
       != tool_panel_model.PANEL_SEARCH
       or shell.toolPanels.GetActiveToolPanelId() != "search" {
        fail(shell, "reordered Search tab routed by stale visual index");
        return;
    }
    shell.toolPanels.toolTabBar.SetActive(shell.toolPanels.toolTerminalTab);
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.activeToolPanelKind
       != tool_panel_model.PANEL_TERMINAL
       or shell.toolPanels.terminalPanel.IsVisible() == false
       or shell.toolPanels.GetActiveToolPanelId() != "terminal" {
        fail(shell, "reordered Terminal tab routed to the wrong panel");
        return;
    }
    shell.toolPanels.SetToolTabOrder(tool_panel_model.DEFAULT_TAB_ORDER);
    if shell.toolPanels.GetToolTabOrder()
           != tool_panel_model.DEFAULT_TAB_ORDER
       or shell.toolPanels.TakeChangedToolTabOrder() != "" {
        fail(shell, "persisted tool tab order replayed as user input");
        return;
    }
    shell.toolPanels.SetToolTabOrder("terminal,terminal");
    if shell.toolPanels.GetToolTabOrder()
           != tool_panel_model.DEFAULT_TAB_ORDER
       or shell.toolPanels.TakeChangedToolTabOrder() != "" {
        fail(shell, "malformed tool tab order did not recover atomically");
        return;
    }
    shell.toolPanels.SetActiveToolPanelId("search");
    if shell.toolPanels.GetActiveToolPanelId() != "search"
       or shell.toolPanels.searchPanel.IsVisible() == false {
        fail(shell, "stable active-panel replay did not select Search");
        return;
    }
    shell.toolPanels.SetActiveToolPanelId("future-panel");
    if shell.toolPanels.GetActiveToolPanelId() != "none"
       or split.GetCollapsedSide() != 2 {
        fail(shell, "unknown active-panel state did not collapse safely");
        return;
    }

    // Individual tools can split into independent groups while the remaining
    // bottom strip stays live. Moving Terminal preserves its native input
    // widget, then Problems can occupy the opposite side simultaneously.
    var groupHarness = GUI.TestHarness.New();
    if !groupHarness.BindApp(shell.app) {
        fail(shell, "group dock-control automation could not bind the app");
        return;
    }
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    shell.toolPanels.terminalPane.Focus();
    if !ClickDockControl(
           shell, groupHarness, shell.toolPanels.dockRightButton) {
        groupHarness.UnbindApp();
        fail(shell, "primary group control could not move Terminal right");
        return;
    }
    shell.toolPanels.ShowOutputPanel();
    shell.toolPanels.ShowProblemsPanel();
    shell.Render();
    if !ClickDockControl(
           shell, groupHarness, shell.toolPanels.dockLeftButton) {
        groupHarness.UnbindApp();
        fail(shell, "primary group control could not move Problems left");
        return;
    }
    shell.Render();
    if !ClickDockControl(
           shell, groupHarness,
           shell.toolPanels.rightToolMoveBottomButton)
       or shell.toolPanels.GetToolPanelLocationName(
              tool_panel_model.PANEL_TERMINAL) != "bottom"
       or !ClickDockControl(
              shell, groupHarness, shell.toolPanels.dockRightButton) {
        groupHarness.UnbindApp();
        fail(shell, "auxiliary group controls did not round-trip Terminal");
        return;
    }
    shell.Render();
    if shell.toolPanels.GetToolPanelLocationName(
           tool_panel_model.PANEL_PROBLEMS) != "left"
       or shell.toolPanels.GetToolPanelLocationName(
              tool_panel_model.PANEL_TERMINAL) != "right"
       or shell.toolPanels.GetToolPanelLocationName(
              tool_panel_model.PANEL_OUTPUT) != "bottom"
       or shell.toolPanels.leftToolTabBar.TabCount != 1
       or shell.toolPanels.toolTabBar.TabCount != 6
       or shell.toolPanels.rightToolTabBar.TabCount != 1
       or !shell.toolPanels.problemsPanel.IsVisible()
       or !shell.toolPanels.outputPanel.IsVisible()
       or !shell.toolPanels.terminalPanel.IsVisible()
       or shell.workbench.leftDockSplit.GetCollapsedSide() != 0
       or shell.workbench.editorSplit.GetCollapsedSide() != 0
       or shell.workbench.rightDockSplit.GetCollapsedSide() != 0 {
        fail(shell, "three independent tool groups were not simultaneously live");
        return;
    }

    // The same live Terminal surface can become a movable overlay. Programmatic
    // geometry replay is quiet; real handle/resize drags each publish one
    // durable edge, and releasing the move handle at an edge docks the whole
    // floating group without rebuilding the terminal widget or losing focus.
    shell.toolPanels.SetFloatingToolPanelBounds(140, 108, 700, 430);
    if shell.toolPanels.TakeFloatingToolPanelGeometryChanged() {
        groupHarness.UnbindApp();
        fail(shell, "persisted floating bounds masqueraded as pointer input");
        return;
    }
    var stableFloatingTerminal = shell.toolPanels.terminalPanel;
    shell.toolPanels.terminalPane.SetTerminalMode(true);
    shell.toolPanels.terminalPane.Focus();
    if !ClickDockControl(
           shell, groupHarness,
           shell.toolPanels.rightToolMoveFloatingButton) {
        groupHarness.UnbindApp();
        fail(shell, "right tool could not enter the floating group");
        return;
    }
    shell.Render();
    if shell.toolPanels.GetToolPanelLocationName(
           tool_panel_model.PANEL_TERMINAL) != "floating"
       or !shell.toolPanels.floatingToolPanel.IsVisible()
       or !shell.toolPanels.floatingToolGroupRoot.IsVisible()
       or shell.toolPanels.floatingToolTabBar.TabCount != 1
       or shell.toolPanels.rightToolTabBar.TabCount != 0
       or shell.toolPanels.terminalPanel != stableFloatingTerminal {
        groupHarness.UnbindApp();
        fail(shell, "floating transfer lost topology, state, or focus");
        return;
    }
    shell.toolPanels.terminalPane.Focus();
    shell.Poll();
    if !shell.toolPanels.terminalPane.IsFocused() {
        groupHarness.UnbindApp();
        fail(shell, "floating terminal could not retain focus before movement");
        return;
    }

    var floatingXBefore = shell.toolPanels.GetFloatingToolPanelX();
    var floatingYBefore = shell.toolPanels.GetFloatingToolPanelY();
    var floatingMoveDispatched = DragFloatingControl(
        shell, groupHarness,
        shell.toolPanels.floatingToolMoveHandle, 34, 26);
    var floatingMoveChanged =
        shell.toolPanels.TakeFloatingToolPanelGeometryChanged();
    var floatingMoveChangedAgain =
        shell.toolPanels.TakeFloatingToolPanelGeometryChanged();
    if !floatingMoveDispatched
       or shell.toolPanels.GetFloatingToolPanelX() <= floatingXBefore
       or shell.toolPanels.GetFloatingToolPanelY() <= floatingYBefore
       or !floatingMoveChanged
       or floatingMoveChangedAgain
       or !shell.toolPanels.terminalPane.IsFocused() {
        groupHarness.UnbindApp();
        fail(shell, "floating move did not clamp and publish one bounds edge: "
             + "dispatched=" + floatingMoveDispatched
             + " before=" + floatingXBefore + "," + floatingYBefore
             + " after="
             + shell.toolPanels.GetFloatingToolPanelX() + ","
             + shell.toolPanels.GetFloatingToolPanelY()
             + " changed=" + floatingMoveChanged
             + "/" + floatingMoveChangedAgain
             + " handle="
             + shell.toolPanels.floatingToolMoveHandle.GetScreenX()
             + ","
             + shell.toolPanels.floatingToolMoveHandle.GetScreenY()
             + " "
             + shell.toolPanels.floatingToolMoveHandle.GetScreenWidth()
             + "x"
             + shell.toolPanels.floatingToolMoveHandle.GetScreenHeight()
             + " hovered="
             + shell.toolPanels.floatingToolMoveHandle.IsHovered()
             + " scale=" + shell.app.GetEffectiveScale()
             + " panel="
             + shell.toolPanels.floatingToolPanel.GetScreenX()
             + ","
             + shell.toolPanels.floatingToolPanel.GetScreenY()
             + " "
             + shell.toolPanels.floatingToolPanel.GetScreenWidth()
             + "x"
             + shell.toolPanels.floatingToolPanel.GetScreenHeight()
             + " focus="
             + shell.toolPanels.terminalPane.IsFocused()
             + " root="
             + shell.toolPanels.floatingToolGroupRoot.GetScreenX()
             + ","
             + shell.toolPanels.floatingToolGroupRoot.GetScreenY()
             + " "
             + shell.toolPanels.floatingToolGroupRoot.GetScreenWidth()
             + "x"
             + shell.toolPanels.floatingToolGroupRoot.GetScreenHeight());
        return;
    }
    var floatingWidthBefore = shell.toolPanels.GetFloatingToolPanelWidth();
    var floatingHeightBefore = shell.toolPanels.GetFloatingToolPanelHeight();
    if !DragFloatingControl(
           shell, groupHarness,
           shell.toolPanels.floatingToolResizeHandle, 28, 24)
       or shell.toolPanels.GetFloatingToolPanelWidth()
              <= floatingWidthBefore
       or shell.toolPanels.GetFloatingToolPanelHeight()
              <= floatingHeightBefore
       or !shell.toolPanels.TakeFloatingToolPanelGeometryChanged()
       or shell.toolPanels.TakeFloatingToolPanelGeometryChanged()
       or !shell.toolPanels.terminalPane.IsFocused() {
        groupHarness.UnbindApp();
        fail(shell, "floating resize did not publish one bounded geometry edge");
        return;
    }
    var floatingDockedRight = DockFloatingGroupAt(
        shell, groupHarness, workspace_dock.DOCK_RIGHT);
    if !floatingDockedRight
       or shell.toolPanels.GetToolPanelLocationName(
              tool_panel_model.PANEL_TERMINAL) != "right"
       or shell.toolPanels.floatingToolPanel.IsVisible()
       or shell.toolPanels.floatingToolTabBar.TabCount != 0
       or shell.toolPanels.rightToolTabBar.TabCount != 1
       or shell.toolPanels.terminalPanel != stableFloatingTerminal
       or !shell.toolPanels.terminalPane.IsFocused() {
        groupHarness.UnbindApp();
        fail(shell, "floating group did not dock back intact at an edge: "
             + "dispatched=" + floatingDockedRight
             + " location="
             + shell.toolPanels.GetToolPanelLocationName(
                 tool_panel_model.PANEL_TERMINAL)
             + " visible="
             + shell.toolPanels.floatingToolPanel.IsVisible()
             + " tabs="
             + shell.toolPanels.floatingToolTabBar.TabCount + "/"
             + shell.toolPanels.rightToolTabBar.TabCount
             + " stable="
             + (shell.toolPanels.terminalPanel == stableFloatingTerminal)
             + " focus="
             + shell.toolPanels.terminalPane.IsFocused());
        return;
    }
    groupHarness.UnbindApp();

    var groupedLayout = shell.toolPanels.GetToolPanelGroupLayout();
    if groupedLayout
           != "left=problems;bottom=output,search,references,variables,"
              + "call-stack,debug-console;right=terminal;floating="
       or shell.toolPanels.TakeChangedToolPanelGroupLayout() != groupedLayout
       or shell.toolPanels.TakeChangedToolPanelGroupLayout() != "" {
        fail(shell, "individual tool movement did not publish one grouped layout");
        return;
    }

    // Settings replay reconstructs the presentations around the same panel
    // widgets, merges all tools into the legacy bottom strip, and remains clean.
    var stableTerminalPanel = shell.toolPanels.terminalPanel;
    shell.toolPanels.SetToolPanelGroupLayout(
        "", "bottom", tool_panel_model.DEFAULT_TAB_ORDER);
    shell.toolPanels.HidePanelArea();
    shell.Render();
    if shell.toolPanels.GetToolPanelGroupLayout()
           != "left=;bottom=problems,output,search,references,variables,"
              + "call-stack,debug-console,terminal;right=;floating="
       or shell.toolPanels.toolTabBar.TabCount != 8
       or shell.toolPanels.leftToolTabBar.TabCount != 0
       or shell.toolPanels.rightToolTabBar.TabCount != 0
       or shell.toolPanels.floatingToolTabBar.TabCount != 0
       or shell.toolPanels.terminalPanel != stableTerminalPanel
       or shell.toolPanels.TakeChangedToolPanelGroupLayout() != ""
       or shell.workbench.leftDockSplit.GetCollapsedSide() != 1
       or shell.workbench.rightDockSplit.GetCollapsedSide() != 2 {
        fail(shell, "grouped tool layout replay was not atomic and focus-safe");
        return;
    }

    // Reparenting a focused terminal must not hand keyboard ownership back to
    // the hidden editor or panel header.
    shell.toolPanels.terminalPane.SetTerminalMode(true);
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    shell.toolPanels.terminalPane.Focus();
    shell.Poll();
    if shell.toolPanels.terminalPane.IsFocused() == false {
        fail(shell, "terminal was not focused before dock movement");
        return;
    }

    // Exercise the production drag/drop route with real pointer events. The
    // target cards appear only after the header crosses the drag dead zone and
    // remain stationary over the workbench while the source header moves.
    var panelRoot = shell.toolPanels.panelRoot;
    var dockHarness = GUI.TestHarness.New();
    if !dockHarness.BindApp(shell.app) {
        fail(shell, "dock automation could not bind the app");
        return;
    }
    var panelHeaderDragStarted = BeginDockDrag(shell, dockHarness);
    if !panelHeaderDragStarted {
        fail(shell, "panel header did not begin a real drag: "
             + "dragging="
             + shell.toolPanels.dockDragHandle.IsBeingDragged()
             + " targets="
             + shell.toolPanels.AreDockDragTargetsVisible()
             + " hovered=" + shell.toolPanels.dockDragHandle.IsHovered()
             + " pressed=" + shell.toolPanels.dockDragHandle.IsPressed()
             + " bounds="
             + shell.toolPanels.dockDragHandle.GetScreenX() + ","
             + shell.toolPanels.dockDragHandle.GetScreenY() + " "
             + shell.toolPanels.dockDragHandle.GetScreenWidth() + "x"
             + shell.toolPanels.dockDragHandle.GetScreenHeight());
        return;
    }
    var dockWorkspaceWidth =
        shell.toolPanels.workspaceDropTarget.GetLogicalWidth();
    var dockWorkspaceHeight =
        shell.toolPanels.workspaceDropTarget.GetLogicalHeight();
    if !shell.toolPanels.dockLeftTarget.IsVisible()
       or !shell.toolPanels.dockBottomTarget.IsVisible()
       or !shell.toolPanels.dockRightTarget.IsVisible()
       or !shell.toolPanels.dockFloatTarget.IsVisible()
       or shell.toolPanels.dockLeftTarget.GetLogicalX() < 0.0
       or shell.toolPanels.dockLeftTarget.GetLogicalY() < 0.0
       or shell.toolPanels.dockRightTarget.GetLogicalX()
              + shell.toolPanels.dockRightTarget.GetLogicalWidth()
              > dockWorkspaceWidth + 1.0
       or shell.toolPanels.dockBottomTarget.GetLogicalY()
              + shell.toolPanels.dockBottomTarget.GetLogicalHeight()
              > dockWorkspaceHeight + 1.0
       or shell.toolPanels.dockFloatTarget.GetLogicalX() < 0.0
       or shell.toolPanels.dockFloatTarget.GetLogicalY() < 0.0
       or shell.toolPanels.dockLeftTarget.GetLogicalX()
              >= shell.toolPanels.dockBottomTarget.GetLogicalX()
       or shell.toolPanels.dockRightTarget.GetLogicalX()
              <= shell.toolPanels.dockBottomTarget.GetLogicalX()
       or shell.toolPanels.dockBottomTarget.GetLogicalY()
              <= shell.toolPanels.dockLeftTarget.GetLogicalY() {
        fail(shell, "dock targets were not visible, bounded edge cards");
        return;
    }

    var leftTargetX = Convert.NumToInt(
        shell.toolPanels.dockLeftTarget.GetScreenX()
        + shell.toolPanels.dockLeftTarget.GetScreenWidth() / 2.0);
    var leftTargetY = Convert.NumToInt(
        shell.toolPanels.dockLeftTarget.GetScreenY()
        + shell.toolPanels.dockLeftTarget.GetScreenHeight() / 2.0);
    if !MoveDockDrag(shell, dockHarness, leftTargetX, leftTargetY)
       or !shell.toolPanels.dockLeftTarget.IsDragOver()
       or shell.toolPanels.dockBottomTarget.IsDragOver()
       or shell.toolPanels.dockRightTarget.IsDragOver()
       or shell.toolPanels.dockFloatTarget.IsDragOver() {
        fail(shell, "left target did not receive exclusive drag hover");
        return;
    }
    if !ReleaseDockDrag(shell, dockHarness, leftTargetX, leftTargetY) {
        fail(shell, "left target release was not dispatched");
        return;
    }

    // The same live panel tree moves without reconstructing terminal/output
    // state. A target drop publishes exactly one durable location and inactive
    // splitters collapse completely.
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    if shell.toolPanels.GetDockLocationName() != "left"
       or shell.workbench.leftDockSplit.GetCollapsedSide() != 0
       or shell.workbench.editorSplit.GetCollapsedSide() != 2
       or shell.workbench.rightDockSplit.GetCollapsedSide() != 2
       or !ContainsWidget(shell.workbench.leftPanelHost, panelRoot)
       or shell.toolPanels.panelRoot != panelRoot
       or shell.toolPanels.AreDockDragTargetsVisible()
       or shell.toolPanels.terminalPane.IsFocused() == false {
        fail(shell, "left target did not reparent one stable panel tree");
        return;
    }
    var sideHeaderRight = shell.toolPanels.dockHeader.GetScreenX()
        + shell.toolPanels.dockHeader.GetScreenWidth();
    var sideHideRight = shell.toolPanels.dockHideButton.GetScreenX()
        + shell.toolPanels.dockHideButton.GetScreenWidth();
    if shell.toolPanels.IsDockHeaderCompact() == false
       or shell.toolPanels.dockDragHandle.GetScreenWidth() < 32.0
       or sideHideRight > sideHeaderRight + 1.0 {
        fail(shell, "side-dock header controls did not compact cleanly: compact="
              + shell.toolPanels.IsDockHeaderCompact()
              + " drag=" + shell.toolPanels.dockDragHandle.GetScreenWidth()
              + " hideRight=" + sideHideRight
              + " headerRight=" + sideHeaderRight
              + " root=" + shell.toolPanels.panelRoot.GetScreenWidth()
              + " header=" + shell.toolPanels.dockHeader.GetScreenWidth()
              + " left=" + shell.toolPanels.dockLeftButton.GetScreenWidth()
              + " bottom="
              + shell.toolPanels.dockBottomButton.GetScreenWidth()
              + " right="
              + shell.toolPanels.dockRightButton.GetScreenWidth()
              + " float="
              + shell.toolPanels.dockFloatButton.GetScreenWidth()
              + " hide=" + shell.toolPanels.dockHideButton.GetScreenWidth());
        return;
    }
    if shell.toolPanels.TakeChangedDockLocation() != "left"
       or shell.toolPanels.TakeChangedDockLocation() != "" {
        fail(shell, "left dock did not publish one persistence edge");
        return;
    }

    shell.toolPanels.SetSidePanelWidthPct(45);
    shell.Render();
    var leftPosition = shell.workbench.leftDockSplit.GetPosition();
    if leftPosition < 0.43 or leftPosition > 0.47 {
        fail(shell, "persisted left panel width not applied: " + leftPosition);
        return;
    }

    // Search keeps one live set of inputs while responsive Flex rows reflow.
    // At the minimum side width, every action remains reachable and path
    // filters stack instead of producing horizontal overflow.
    shell.toolPanels.ShowSearchPanel();
    shell.Render();
    shell.toolPanels.FocusSearchQuery();
    shell.toolPanels.SetSidePanelWidthPct(20);
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    if !shell.toolPanels.IsSearchControlsCompact()
       or !shell.toolPanels.searchQueryInput.IsFocused()
       or shell.toolPanels.searchRunButton.GetLogicalWidth() > 46.0
       or shell.toolPanels.searchReplaceButton.GetLogicalWidth() > 66.0
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchQueryInput)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchRunButton)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchCancelButton)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchReplaceInput)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchReplaceButton)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchCaseCheck)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchWholeWordCheck)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchRegexCheck)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchKindsInput)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchIncludeInput)
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchExcludeInput)
       or shell.toolPanels.searchExcludeInput.GetScreenY()
              <= shell.toolPanels.searchIncludeInput.GetScreenY()
       or shell.toolPanels.searchListBox.GetScreenHeight() < 48.0 {
        fail(shell, "narrow side Search controls clipped or lost focus: panel="
             + shell.toolPanels.searchPanel.GetLogicalWidth()
             + " query=" + shell.toolPanels.searchQueryInput.GetLogicalWidth()
             + " run=" + shell.toolPanels.searchRunButton.GetLogicalWidth()
             + " replace=" + shell.toolPanels.searchReplaceButton.GetLogicalWidth()
             + " compact=" + shell.toolPanels.IsSearchControlsCompact()
             + " focus=" + shell.toolPanels.searchQueryInput.IsFocused()
             + " q=" + ContainsWidget(shell.toolPanels.searchPanel,
                                       shell.toolPanels.searchQueryInput)
             + " go=" + ContainsWidget(shell.toolPanels.searchPanel,
                                        shell.toolPanels.searchRunButton)
             + " stop=" + ContainsWidget(shell.toolPanels.searchPanel,
                                          shell.toolPanels.searchCancelButton)
             + " repl=" + ContainsWidget(shell.toolPanels.searchPanel,
                                          shell.toolPanels.searchReplaceInput)
             + " all=" + ContainsWidget(shell.toolPanels.searchPanel,
                                         shell.toolPanels.searchReplaceButton)
             + " case=" + ContainsWidget(shell.toolPanels.searchPanel,
                                          shell.toolPanels.searchCaseCheck)
             + " word=" + ContainsWidget(shell.toolPanels.searchPanel,
                                          shell.toolPanels.searchWholeWordCheck)
             + " regex=" + ContainsWidget(shell.toolPanels.searchPanel,
                                           shell.toolPanels.searchRegexCheck)
             + " kinds=" + ContainsWidget(shell.toolPanels.searchPanel,
                                           shell.toolPanels.searchKindsInput)
             + " include=" + ContainsWidget(shell.toolPanels.searchPanel,
                                             shell.toolPanels.searchIncludeInput)
             + " exclude=" + ContainsWidget(shell.toolPanels.searchPanel,
                                             shell.toolPanels.searchExcludeInput)
             + " pathY=" + shell.toolPanels.searchIncludeInput.GetScreenY()
             + "/" + shell.toolPanels.searchExcludeInput.GetScreenY()
             + " results=" + shell.toolPanels.searchListBox.GetScreenHeight());
        return;
    }

    // The adjacent Terminal strip uses the same responsive dock contract. Its
    // four session actions become two balanced rows while the PTY pane retains
    // keyboard ownership and the majority of the vertical viewport.
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    if !shell.toolPanels.IsTerminalActionsCompact()
       or !shell.toolPanels.terminalPane.IsFocused()
       or !ContainsWidget(shell.toolPanels.terminalPanel,
                          shell.toolPanels.terminalActionRow)
       or !ContainsWidget(shell.toolPanels.terminalActionRow,
                          shell.toolPanels.terminalKill)
       or !ContainsWidget(shell.toolPanels.terminalActionRow,
                          shell.toolPanels.terminalRestart)
       or !ContainsWidget(shell.toolPanels.terminalActionRow,
                          shell.toolPanels.terminalNew)
       or !ContainsWidget(shell.toolPanels.terminalActionRow,
                          shell.toolPanels.terminalNext)
       or shell.toolPanels.terminalNew.GetScreenY()
              <= shell.toolPanels.terminalKill.GetScreenY()
       or shell.toolPanels.terminalPane.GetScreenHeight() < 240.0 {
        fail(shell, "narrow side Terminal actions clipped or stole PTY space: "
             + "panel=" + shell.toolPanels.terminalPanel.GetLogicalWidth()
             + " row=" + shell.toolPanels.terminalActionRow.GetScreenHeight()
             + " pane=" + shell.toolPanels.terminalPane.GetScreenHeight()
             + " compact=" + shell.toolPanels.IsTerminalActionsCompact()
             + " focus=" + shell.toolPanels.terminalPane.IsFocused());
        return;
    }
    shell.toolPanels.ShowSearchPanel();
    shell.Render();
    shell.toolPanels.FocusSearchQuery();

    // Widening the same side dock restores descriptive action geometry and
    // places include/exclude filters back on one row without rebuilding input.
    // Collapse the primary sidebar so low-resolution and fractionally scaled
    // Windows test desktops still have room to cross the 520 px threshold.
    shell.workbench.SetSidebarVisible(false);
    shell.app.SetSize(1400, 760);
    shell.Poll();
    shell.toolPanels.SetSidePanelWidthPct(55);
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    var pathRowDelta = shell.toolPanels.searchExcludeInput.GetScreenY()
        - shell.toolPanels.searchIncludeInput.GetScreenY();
    if pathRowDelta < 0.0 { pathRowDelta = 0.0 - pathRowDelta; }
    if shell.toolPanels.IsSearchControlsCompact()
       or !shell.toolPanels.searchQueryInput.IsFocused()
       or shell.toolPanels.searchRunButton.GetLogicalWidth() < 58.0
       or shell.toolPanels.searchReplaceButton.GetLogicalWidth() < 78.0
       or pathRowDelta > 1.0
       or !ContainsWidget(shell.toolPanels.searchPanel,
                          shell.toolPanels.searchExcludeInput) {
        fail(shell, "wide side Search geometry did not restore: panel="
             + shell.toolPanels.searchPanel.GetLogicalWidth()
             + " run=" + shell.toolPanels.searchRunButton.GetLogicalWidth()
             + " replace=" + shell.toolPanels.searchReplaceButton.GetLogicalWidth()
             + " pathDelta=" + pathRowDelta);
        return;
    }

    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    var terminalRowDelta = shell.toolPanels.terminalNext.GetScreenY()
        - shell.toolPanels.terminalKill.GetScreenY();
    if terminalRowDelta < 0.0 {
        terminalRowDelta = 0.0 - terminalRowDelta;
    }
    if shell.toolPanels.IsTerminalActionsCompact()
       or !shell.toolPanels.terminalPane.IsFocused()
       or terminalRowDelta > 1.0
       or !ContainsWidget(shell.toolPanels.terminalActionRow,
                          shell.toolPanels.terminalNext) {
        fail(shell, "wide side Terminal actions did not restore one row: panel="
             + shell.toolPanels.terminalPanel.GetLogicalWidth()
             + " rowDelta=" + terminalRowDelta);
        return;
    }
    shell.toolPanels.ShowSearchPanel();
    shell.Render();
    shell.toolPanels.FocusSearchQuery();

    shell.workbench.SetSidebarVisible(true);
    shell.app.SetSize(1100, 760);
    shell.Poll();
    shell.toolPanels.SetSidePanelWidthPct(45);
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();

    shell.toolPanels.MovePanelTo(workspace_dock.DOCK_RIGHT);
    shell.Render();
    var rightPosition = shell.workbench.rightDockSplit.GetPosition();
    if rightPosition < 0.53 or rightPosition > 0.57
       or shell.workbench.leftDockSplit.GetCollapsedSide() != 1
       or !ContainsWidget(shell.workbench.rightPanelHost,
                          shell.toolPanels.panelRoot)
       or !shell.toolPanels.searchQueryInput.IsFocused() {
        fail(shell, "right dock did not preserve the configured panel width");
        return;
    }
    if shell.toolPanels.TakeChangedDockLocation() != "right" {
        fail(shell, "right dock change was not published");
        return;
    }
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();

    // A side-divider drag stores panel width rather than splitter orientation,
    // so the same percentage has the same meaning on left and right.
    shell.toolPanels.PumpToolTabs();
    shell.workbench.rightDockSplit.SetPosition(0.62);
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.TakeChangedSidePanelWidthPercent() != 38
       or shell.toolPanels.TakeChangedSidePanelWidthPercent() != -1 {
        fail(shell, "right splitter drag did not publish panel width");
        return;
    }

    shell.toolPanels.MovePanelTo(workspace_dock.DOCK_BOTTOM);
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    if shell.toolPanels.GetDockLocationName() != "bottom"
       or shell.workbench.editorSplit.GetCollapsedSide() != 0
       or shell.workbench.leftDockSplit.GetCollapsedSide() != 1
       or shell.workbench.rightDockSplit.GetCollapsedSide() != 2
       or !ContainsWidget(shell.workbench.bottomPanelHost,
                          shell.toolPanels.panelRoot) {
        fail(shell, "bottom redock did not collapse both side hosts");
        return;
    }
    if shell.toolPanels.IsDockHeaderCompact() {
        fail(shell, "roomy bottom-dock header did not restore full labels");
        return;
    }
    if shell.toolPanels.TakeChangedDockLocation() != "bottom" {
        fail(shell, "bottom dock change was not published");
        return;
    }

    // Loading a setting must move the panel without masquerading as input.
    shell.toolPanels.SetDockLocationName("left");
    shell.Render();
    if shell.toolPanels.GetDockLocationName() != "left"
       or shell.toolPanels.TakeChangedDockLocation() != "" {
        fail(shell, "persisted dock location was reported as a user move");
        return;
    }
    shell.toolPanels.SetDockLocationName("bottom");
    shell.Render();

    // Edge-drop geometry is pure and keeps a central drop at the current dock.
    if workspace_dock.DockEdgeForPointer(
           5.0, 50.0, 0.0, 0.0, 100.0, 100.0)
           != workspace_dock.DOCK_LEFT
       or workspace_dock.DockEdgeForPointer(
           95.0, 50.0, 0.0, 0.0, 100.0, 100.0)
           != workspace_dock.DOCK_RIGHT
       or workspace_dock.DockEdgeForPointer(
           50.0, 50.0, 0.0, 0.0, 100.0, 100.0)
           != workspace_dock.DOCK_NONE
       or workspace_dock.DockDragHint(workspace_dock.DOCK_LEFT)
           != "Release to dock panels left"
       or workspace_dock.DockDragHint(workspace_dock.DOCK_NONE)
           != "Move to an edge or the Float target"
       or workspace_dock.DockDragHint(workspace_dock.DOCK_FLOATING)
           != "Release to float panel group"
       or workspace_dock.DockTargetText(
              workspace_dock.DOCK_LEFT,
              workspace_dock.DOCK_BOTTOM,
              false) != "Dock Left"
       or workspace_dock.DockTargetText(
              workspace_dock.DOCK_BOTTOM,
              workspace_dock.DOCK_BOTTOM,
              false) != "Bottom (current)"
       or workspace_dock.DockTargetText(
              workspace_dock.DOCK_RIGHT,
              workspace_dock.DOCK_BOTTOM,
              true) != "Release: Right"
       or workspace_dock.DockTargetText(
              workspace_dock.DOCK_FLOATING,
              workspace_dock.DOCK_BOTTOM,
              false) != "Dock Float"
       or workspace_dock.DockTargetText(
              workspace_dock.DOCK_NONE,
              workspace_dock.DOCK_BOTTOM,
              true) != ""
       or workspace_dock.DockTargetX(
              workspace_dock.DOCK_LEFT, 24.0) < 0.0
       or workspace_dock.DockTargetX(
              workspace_dock.DOCK_RIGHT, 24.0)
              + workspace_dock.DockTargetWidth(24.0) > 24.0
       or workspace_dock.DockTargetY(
              workspace_dock.DOCK_BOTTOM, 20.0)
              + workspace_dock.DockTargetHeight(20.0) > 20.0
       or workspace_dock.DockLocationForPointer(
           5.0, 50.0, 0.0, 0.0, 100.0, 100.0,
           workspace_dock.DOCK_BOTTOM) != workspace_dock.DOCK_LEFT
       or workspace_dock.DockLocationForPointer(
           95.0, 50.0, 0.0, 0.0, 100.0, 100.0,
           workspace_dock.DOCK_BOTTOM) != workspace_dock.DOCK_RIGHT
       or workspace_dock.DockLocationForPointer(
           5.0, 90.0, 0.0, 0.0, 100.0, 100.0,
           workspace_dock.DOCK_LEFT) != workspace_dock.DOCK_BOTTOM
       or workspace_dock.DockLocationForPointer(
           50.0, 50.0, 0.0, 0.0, 100.0, 100.0,
           workspace_dock.DOCK_RIGHT) != workspace_dock.DOCK_RIGHT
       or workspace_dock.FloatingSnapEdgeForPointer(
              164.0, 120.0, 0.0, 0.0, 800.0, 700.0)
              != workspace_dock.DOCK_NONE
       or workspace_dock.FloatingSnapEdgeForPointer(
              4.0, 120.0, 0.0, 0.0, 800.0, 700.0)
              != workspace_dock.DOCK_LEFT
       or workspace_dock.FloatingSnapEdgeForPointer(
              796.0, 120.0, 0.0, 0.0, 800.0, 700.0)
              != workspace_dock.DOCK_RIGHT
       or workspace_dock.FloatingSnapEdgeForPointer(
              400.0, 696.0, 0.0, 0.0, 800.0, 700.0)
              != workspace_dock.DOCK_BOTTOM {
        fail(shell, "dock edge geometry selected the wrong location");
        return;
    }

    // The explicit central Float target moves the complete primary group into
    // the overlay. DockEdgeForPointer still returns NONE in the center, so a
    // broad workbench drop outside the target remains a no-op.
    if !BeginDockDrag(shell, dockHarness) {
        fail(shell, "central-drop fixture could not begin a drag");
        return;
    }
    var centerDropX = Convert.NumToInt(
        shell.toolPanels.workspaceDropTarget.GetScreenX()
        + shell.toolPanels.workspaceDropTarget.GetScreenWidth() * 0.5);
    var centerDropY = Convert.NumToInt(
        shell.toolPanels.workspaceDropTarget.GetScreenY()
        + shell.toolPanels.workspaceDropTarget.GetScreenHeight() * 0.45);
    if !MoveDockDrag(shell, dockHarness, centerDropX, centerDropY)
       or shell.toolPanels.dockLeftTarget.IsDragOver()
       or shell.toolPanels.dockBottomTarget.IsDragOver()
       or shell.toolPanels.dockRightTarget.IsDragOver()
       or !shell.toolPanels.dockFloatTarget.IsDragOver()
       or !ReleaseDockDrag(shell, dockHarness, centerDropX, centerDropY) {
        fail(shell, "central Float target did not accept the panel group");
        return;
    }
    if shell.toolPanels.GetDockLocationName() != "bottom"
       or shell.toolPanels.TakeChangedDockLocation() != ""
       or !shell.toolPanels.floatingToolPanel.IsVisible()
       or shell.toolPanels.GetToolPanelGroupLayout()
              != "left=;bottom=;right=;floating=problems,output,search,"
                 + "references,variables,call-stack,debug-console,terminal"
       or shell.toolPanels.TakeChangedToolPanelGroupLayout()
              != shell.toolPanels.GetToolPanelGroupLayout()
       or shell.toolPanels.AreDockDragTargetsVisible() {
        fail(shell, "central Float target lost group state or dock compatibility");
        return;
    }
    if !DockFloatingGroupAt(
           shell, dockHarness, workspace_dock.DOCK_BOTTOM)
       or shell.toolPanels.floatingToolPanel.IsVisible()
       or shell.toolPanels.GetToolPanelGroupLayout()
              != "left=;bottom=problems,output,search,references,variables,"
                 + "call-stack,debug-console,terminal;right=;floating="
       or shell.toolPanels.TakeChangedToolPanelGroupLayout()
              != shell.toolPanels.GetToolPanelGroupLayout() {
        fail(shell, "floating primary group did not redock at bottom");
        return;
    }
    dockHarness.UnbindApp();

    // A persisted percentage is applied while a panel is open.
    shell.toolPanels.SetBottomSplitPct(50);
    shell.Render();
    var p3 = split.GetPosition();
    if p3 < 0.45 or p3 > 0.55 {
        fail(shell, "SetBottomSplitPct(50) not applied: " + p3);
        return;
    }
    shell.toolPanels.SetBottomSplitPct(85);
    shell.Render();
    var p4 = split.GetPosition();
    if p4 < 0.80 or p4 > 0.90 {
        fail(shell, "SetBottomSplitPct(85) not applied: " + p4);
        return;
    }

    // Out-of-range percentages clamp to [30, 95].
    shell.toolPanels.SetBottomSplitPct(5);
    var p5 = split.GetPosition();
    if p5 < 0.28 or p5 > 0.32 {
        fail(shell, "SetBottomSplitPct(5) did not clamp to 30: " + p5);
        return;
    }

    // The Search panel has four rows of controls above its result list. At the
    // native minimum window size it must temporarily claim enough height for a
    // useful results viewport, without overwriting the user's normal split.
    shell.toolPanels.SetBottomSplitPct(70);
    shell.toolPanels.splitFractionDirty = false;
    shell.toolPanels.ShowSearchPanel();
    shell.Render();
    shell.app.SetSize(720, 520);
    shell.Poll();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    shell.Render();
    if shell.toolPanels.searchListBox.GetHeight() < 48 {
        fail(shell, "compact search has no usable results viewport: "
              + shell.toolPanels.searchListBox.GetHeight()
              + " split=" + split.GetHeight()
              + " host=" + shell.workbench.bottomPanelHost.GetHeight());
        return;
    }
    if shell.workbench.editorRow.GetHeight() < 120 {
        fail(shell, "compact search consumed the editor viewport: "
              + shell.workbench.editorRow.GetHeight());
        return;
    }
    if shell.toolPanels.bottomSplitFraction < 0.68
       or shell.toolPanels.bottomSplitFraction > 0.72
       or shell.toolPanels.splitFractionDirty {
        fail(shell, "compact search overwrote the configured split");
        return;
    }
    if shell.toolPanels.toolReferencesTab.GetTitle() != "Refs"
       or shell.toolPanels.toolDebugTab.GetTitle() != "Debug"
       or shell.toolPanels.toolTerminalTab.GetTitle() != "Term" {
        fail(shell, "compact tool tabs still hide late panels");
        return;
    }
    shell.toolPanels.ShowTerminalPanel();
    shell.Render();
    var restoredCompactSplit = split.GetPosition();
    if restoredCompactSplit < 0.68 or restoredCompactSplit > 0.72 {
        fail(shell, "leaving compact search changed the configured split: "
              + restoredCompactSplit);
        return;
    }

    // A real user drag publishes one rounded percentage for debounced durable
    // storage. Reading it is edge-triggered; controller-authored positioning
    // above must never masquerade as a user preference.
    shell.toolPanels.PumpToolTabs();
    split.SetPosition(0.553);
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.TakeChangedSplitPercent() != 55
       or shell.toolPanels.TakeChangedSplitPercent() != -1 {
        fail(shell, "split drag did not publish one rounded persistence value");
        return;
    }
    shell.toolPanels.SetBottomSplitPct(70);

    // Growing the window restores descriptive labels instead of leaving the
    // compact abbreviations stuck for the rest of the session.
    shell.app.SetSize(1100, 760);
    shell.Poll();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.toolReferencesTab.GetTitle() != "References"
       or shell.toolPanels.toolDebugTab.GetTitle() != "Debug Console"
       or shell.toolPanels.toolTerminalTab.GetTitle() != "Terminal" {
        fail(shell, "wide tool tabs did not restore full labels");
        return;
    }

    // GetLogicalWidth already removes both backing scale and whole-UI zoom.
    // A second zoom division incorrectly keeps abbreviations on a genuinely
    // wide workbench. Use 150% so a high-DPI Windows monitor's native maximum
    // tracking width can still provide a wide effective viewport.
    shell.workbench.ToggleSidebar();
    shell.app.SetUiScale(1.5);
    shell.app.SetSize(1800, 1040);
    shell.Poll();
    shell.Render();
    shell.toolPanels.PumpToolTabs();
    if shell.toolPanels.toolTabBar.GetLogicalWidth() <= 720.0 {
        fail(shell, "zoomed wide tool-tab fixture did not reach wide layout: "
            + shell.toolPanels.toolTabBar.GetLogicalWidth()
            + " window=" + shell.app.GetWidth()
            + " logical=" + shell.app.GetLogicalWidth()
            + " effective=" + shell.app.GetEffectiveScale()
            + " split=" + shell.workbench.splitPane.GetLogicalWidth());
        return;
    }
    if shell.toolPanels.toolReferencesTab.GetTitle() != "References"
       or shell.toolPanels.toolDebugTab.GetTitle() != "Debug Console"
       or shell.toolPanels.toolTerminalTab.GetTitle() != "Terminal" {
        fail(shell, "zoom was applied twice to responsive tool-tab width");
        return;
    }
    shell.app.SetUiScale(1.0);
    shell.app.SetSize(1100, 760);
    shell.workbench.ToggleSidebar();
    shell.Poll();
    shell.Render();
    shell.toolPanels.PumpToolTabs();

    // Layout recovery returns every movable workspace dimension to a known
    // configuration without leaking stale drag edges into persistence.
    shell.toolPanels.MovePanelTo(workspace_dock.DOCK_LEFT);
    shell.workbench.MoveSidebarTo(workspace_dock.DOCK_RIGHT);
    shell.toolPanels.toolTabBar.MoveTab(7, 0);
    shell.toolPanels.PumpToolTabs();
    shell.toolPanels.ResetWorkspaceLayout();
    shell.workbench.SetSidebarPositionName("left");
    shell.workbench.SetSidebarWidthPct(24);
    shell.workbench.SetSidebarVisible(true);
    shell.Render();
    if shell.toolPanels.GetDockLocationName() != "bottom"
       or shell.toolPanels.GetToolTabOrder()
           != tool_panel_model.DEFAULT_TAB_ORDER
       or shell.toolPanels.TakeChangedDockLocation() != ""
       or shell.toolPanels.TakeChangedToolTabOrder() != ""
       or shell.toolPanels.TakeChangedSplitPercent() != -1
       or shell.toolPanels.TakeChangedSidePanelWidthPercent() != -1
       or shell.workbench.TakeChangedSidebarWidthPercent() != -1
       or shell.workbench.GetSidebarPositionName() != "left"
       or shell.workbench.TakeChangedSidebarPosition() != ""
       or shell.toolPanels.GetActiveToolPanelId() != "none"
       or split.GetCollapsedSide() != 2 {
        fail(shell, "workspace reset left non-default state or stale edges");
        return;
    }

    if HasArg("--visual-hold") {
        shell.toolPanels.ShowTerminalPanel();
        shell.toolPanels.MovePanelTo(workspace_dock.DOCK_RIGHT);
        shell.toolPanels.toolTabBar.MoveTab(7, 0);
        shell.toolPanels.PumpToolTabs();
        shell.SetStatusLeft("Tool tabs can be reordered and panels docked");
        shell.Render();
        while true {
            shell.PollWait(16);
            if shell.WasCloseRequested() { break; }
            shell.toolPanels.PumpToolTabs();
            shell.Render();
        }
        shell.toolPanels.ResetWorkspaceLayout();
    }

    // Hiding the last visible panel must reclaim the entire bottom area again.
    shell.toolPanels.ShowTerminalPanel();
    shell.toolPanels.HideTerminalPanel();
    shell.Render();
    if split.GetCollapsedSide() != 2
       or shell.workbench.bottomPanelHost.GetHeight() > 1 {
        fail(shell, "last panel hide did not fully collapse bottom area");
        return;
    }

    shell.Destroy();
    Terminal.Say("RESULT: ok");
}
