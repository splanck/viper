//===----------------------------------------------------------------------===//
//
// File: zannastudio/src/probes/phase0_phase1_probe.zia
// Purpose: Exercise core Studio documents, settings, sessions, commands, and
//          workspace-edit behavior without depending on the native shell.
// Key invariants:
//   - Session persistence restores editable text and rejects preview payloads.
//   - Session/settings reads and writes obey global record/payload size caps.
//   - Core model helpers remain deterministic and filesystem-isolated.
// Ownership/Lifetime:
//   - The probe owns all temporary files and model instances it creates.
// Links: zannastudio/src/core/session.zia,
//        zannastudio/src/core/document_manager.zia
//
//===----------------------------------------------------------------------===//

module phase0_phase1_probe;

// ============================================================================
// MODULE: phase0_phase1_probe
// PURPOSE: Headless regression coverage for core IDE model and command helpers.
//
// WHERE-THIS-FITS: This probe exercises early Zanna Studio slices: documents,
//          settings/session persistence, command registry, language gates,
//          project helpers, and workspace edit safety.
//
// TEACHING-NOTE: Keep phase probes deterministic and file-system isolated. They
//          should validate model contracts without depending on visual rendering.
// ============================================================================

bind "../commands/command_registry";
bind "../commands/command_catalog";
bind "../commands/edit_commands";
bind "../commands/file_commands";
bind "../commands/search_commands";
bind "../app/startup_arguments";
bind "../core/document";
bind "../core/document_manager";
bind "../core/project";
bind "../editor/language_service";
bind "../editor/project_index";
bind "../editor/scheduler";
bind "../editor/signature";
bind "../services/file_utils";
bind "../services/locations";
bind "../services/project_templates";
bind "../services/safe_io";
bind "../services/workspace_edits";
bind "../core/project_manager";
bind "../core/session";
bind "../core/settings";
bind "../ui/status_bar_model";
bind "../basic/semantic_scan";

bind Terminal = Zanna.Terminal;
bind File = Zanna.IO.File;
bind Dir = Zanna.IO.Dir;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;
bind Ini = Zanna.Data.Ini;
bind Codec = Zanna.Text.Codec;
bind Seq = Zanna.Collections.Seq;
bind Map = Zanna.Collections.Map;
bind Str = Zanna.String;
bind Bytes = Zanna.Collections.Bytes;

func fail(msg: String) {
    Terminal.Say("RESULT: fail " + msg);
}

func assertTrue(cond: Boolean, msg: String) -> Boolean {
    if cond == false {
        fail(msg);
        return false;
    }
    return true;
}

func AddEdit(edits: Any,
             filePath: String,
             startLine: Integer,
             startColumn: Integer,
             endLine: Integer,
             endColumn: Integer,
             newText: String) {
    var edit = Map.New();
    Map.SetStr(edit, "file", filePath);
    Map.SetInt(edit, "startLine", startLine);
    Map.SetInt(edit, "startColumn", startColumn);
    Map.SetInt(edit, "endLine", endLine);
    Map.SetInt(edit, "endColumn", endColumn);
    Map.SetStr(edit, "newText", newText);
    Seq.Push(edits, edit);
}

func main() {
    if assertTrue(file_utils.DetectKind("LEVEL.Scene") == file_utils.DOC_KIND_SCENE,
                  "scene kind case-insensitive") == false { return; }
    if assertTrue(file_utils.DetectLanguage("game.BAS") == "basic",
                  "basic language case-insensitive") == false { return; }
    if assertTrue(file_utils.DetectLanguage("level.scene") == "scene",
                  "scene language routed explicitly") == false { return; }
    var defaultProjectsBase = project_templates.DefaultProjectsBase();
    if assertTrue(defaultProjectsBase != ""
                  and Path.Name(defaultProjectsBase) == "ZannaProjects",
                  "new projects use the native user home") == false { return; }

    // Runtime file moves trap on ordinary user-facing failures. Studio's safe
    // boundary must turn a destination collision into false while preserving
    // both files, then still permit an ordinary no-overwrite move.
    var safeIoRoot = TempFile.CreateDirWithPrefix("zannastudio_safe_io_");
    var safeIoSource = Path.Join(safeIoRoot, "source.txt");
    var safeIoCollision = Path.Join(safeIoRoot, "collision.txt");
    var safeIoMoved = Path.Join(safeIoRoot, "moved.txt");
    File.WriteAllText(safeIoSource, "source");
    File.WriteAllText(safeIoCollision, "collision");
    if assertTrue(safe_io.MoveFile(safeIoSource, safeIoCollision) == false
                  and File.ReadAllText(safeIoSource) == "source"
                  and File.ReadAllText(safeIoCollision) == "collision",
                  "safe file move contains destination traps") == false { return; }
    if assertTrue(safe_io.MoveFile(safeIoSource, safeIoMoved)
                  and File.Exists(safeIoSource) == false
                  and File.ReadAllText(safeIoMoved) == "source",
                  "safe file move succeeds without overwrite") == false { return; }
    var safeIoCopied = Path.Join(safeIoRoot, "copied.txt");
    if assertTrue(safe_io.CopyFile(safeIoMoved, safeIoCollision) == false
                  and safe_io.CopyFile(safeIoMoved, safeIoCopied)
                  and File.ReadAllText(safeIoCopied) == "source"
                  and File.ReadAllText(safeIoCollision) == "collision",
                  "safe file copy succeeds without overwriting collisions") == false { return; }
    var longStagingName = "";
    var longNameIndex = 0;
    while longNameIndex < 230 {
        longStagingName = longStagingName + "n";
        longNameIndex = longNameIndex + 1;
    }
    var longStagingTarget = Path.Join(safeIoRoot, longStagingName + ".txt");
    var shortStagingPath = safe_io.SiblingTempPath(longStagingTarget, "probe");
    if assertTrue(shortStagingPath != ""
                  and Path.Directory(shortStagingPath) == safeIoRoot
                  and Str.StartsWith(Path.Name(shortStagingPath),
                                     ".zannastudio-probe-")
                  and Str.get_Length(Path.Name(shortStagingPath)) < 96
                  and safe_io.SiblingTempPath(longStagingTarget, "../escape") == "",
                  "atomic staging names stay short and reject unsafe labels") == false { return; }
    var safeCreated = Path.Join(safeIoRoot, "created.txt");
    if assertTrue(safe_io.CreateTextFile(safeCreated, "created")
                  and File.ReadAllText(safeCreated) == "created"
                  and safe_io.CreateTextFile(safeCreated, "replacement") == false
                  and File.ReadAllText(safeCreated) == "created",
                  "atomic text creation preserves no-overwrite behavior") == false { return; }
    var missingSafeRead = safe_io.ReadAllText(Path.Join(safeIoRoot, "missing.txt"));
    if assertTrue(missingSafeRead.ok == false
                  and safe_io.SizeBytes(Path.Join(safeIoRoot, "missing.txt")) == -1
                  and safe_io.Modified(Path.Join(safeIoRoot, "missing.txt")) == -1,
                  "safe metadata and text reads contain missing-file traps") == false { return; }
    var missingSafeList = safe_io.ListFiles(Path.Join(safeIoRoot, "missing-dir"));
    var missingProject = new project.Project();
    missingProject.Open(Path.Join(safeIoRoot, "missing-dir"));
    if assertTrue(missingSafeList.items.count() == 0 and missingProject.isOpen == false,
                  "missing folders fail without opening or trapping") == false { return; }

    var entryRoot = Path.Join(safeIoRoot, "entry-project");
    var entrySrc = Path.Join(entryRoot, "src");
    Dir.MakeAll(entrySrc);
    var entryFile = Path.Join(entrySrc, "main.zia");
    File.WriteAllText(entryFile, "module Entry;\n");
    var entryProject = new project.Project();
    entryProject.Open(entryRoot);
    var detachedProjectManager = new project_manager.ProjectManager();
    if assertTrue(detachedProjectManager.OpenFolder(entryRoot)
                  and detachedProjectManager.IsOpen(),
                  "folder open is safe before Explorer widget setup") == false { return; }
    var entryManager = new project_manager.ProjectManager();
    entryManager.project = entryProject;
    Dir.MakeAll(Path.Join(entryRoot, "zanna.project"));
    if assertTrue(entryManager.SetEntryFile(entryFile) == false
                  and entryProject.entryFile == "main.zia"
                  and entryProject.hasProjectFile == false,
                  "failed entry persistence leaves the in-memory project unchanged") == false {
        return;
    }

    var registry = new command_registry.CommandRegistry();
    if assertTrue(registry.NormalizeId("sidebar") == "togglesidebar",
                  "sidebar command normalized") == false { return; }
    if assertTrue(registry.IsKnown("rename"), "rename command registered") == false { return; }
    if assertTrue(registry.Find("save").category == "File"
                  and registry.Find("saveas").category == "File"
                  and registry.Find("openfolder").category == "File"
                  and registry.Find("rename").category == "Refactor"
                  and registry.Find("extractfunction").category == "Refactor"
                  and registry.Find("searchproject").category == "Search"
                  and registry.Find("signature_trigger").category == "Navigate"
                  and registry.Find("signaturenextoverload").category == "Navigate",
                  "command palette categories assigned") == false { return; }
    if assertTrue(registry.Find("saveas").shortcut
                      == command_catalog.PlatformShortcut("Ctrl+Shift+S")
                  and registry.Find("saveall").shortcut
                      == command_catalog.PlatformShortcut("Ctrl+Alt+Shift+S")
                  and registry.Find("openfolder").shortcut
                      == command_catalog.PlatformShortcut("Ctrl+Alt+O"),
                  "file command shortcuts are discoverable and conflict-free") == false { return; }

    var langMgr = new language_service.LanguageServiceManager();
    var basicDoc = new document.Document();
    basicDoc.language = "basic";
    var basicService = langMgr.ForDocument(basicDoc);
    // BASIC combines the Zanna.Basic.* runtime bridge with the IDE-side BASIC
    // scanner for navigation, references, rename, and signature help.
    if assertTrue(basicService.canComplete and basicService.canDiagnose
                  and basicService.canGoToDefinition
                  and basicService.canFindReferences
                  and basicService.canRename
                  and basicService.canSignatureHelp,
                  "basic language assistance enabled") == false { return; }
    if assertTrue(status_bar_model.LanguageStatusText("basic") == "Lang: BASIC",
                  "basic status text is first-class") == false { return; }
    var ziaDoc = new document.Document();
    ziaDoc.language = "zia";
    ziaDoc.kind = file_utils.DOC_KIND_CODE;
    var ziaService = langMgr.ForDocument(ziaDoc);
    if assertTrue(ziaService.canRename,
                  "zia rename capability enabled") == false { return; }
    if assertTrue(registry.IsExecutable("rename", basicService)
                  and registry.IsExecutable("rename", ziaService),
                  "command registry gates language capabilities") == false { return; }
    if assertTrue(registry.IsExecutable("signaturenextoverload", basicService)
                  and registry.IsExecutable("signatureprevoverload", ziaService)
                  and registry.IsExecutable("signature_trigger", ziaService),
                  "signature overload commands gate language capabilities") == false { return; }
    var disabledReason = registry.DisabledReason("extractlocal", basicService);
    if assertTrue(Str.IndexOf(disabledReason, "Zia source syntax") != 0,
                  "disabled command reason labels Zia-only transform") == false { return; }

    registry.ApplyCommandContext(false, false, false, false,
                                 false, false, false, ziaService);
    if assertTrue(registry.IsExecutable("new", ziaService)
                  and registry.IsExecutable("open", ziaService)
                  and registry.IsExecutable("toggletheme", ziaService)
                  and registry.IsExecutable("save", ziaService) == false
                  and registry.IsExecutable("find", ziaService) == false
                  and registry.IsExecutable("build", ziaService) == false
                  and registry.IsExecutable("debugstart", ziaService) == false
                  and registry.IsExecutable("quickopen", ziaService) == false
                  and registry.IsExecutable("stopjob", ziaService) == false,
                  "empty welcome gates shortcuts and palette commands") == false { return; }
    if assertTrue(Str.IndexOf(registry.DisabledReason("save", ziaService),
                              "Open a document") != 0
                  and Str.IndexOf(registry.DisabledReason("quickopen", ziaService),
                                  "Open a project") != 0,
                  "context-disabled commands explain how to enable them") == false { return; }

    registry.ApplyCommandContext(true, true, true, true,
                                 false, false, false, ziaService);
    if assertTrue(registry.IsExecutable("save", ziaService)
                  and registry.IsExecutable("find", ziaService)
                  and registry.IsExecutable("build", ziaService)
                  and registry.IsExecutable("debugstart", ziaService)
                  and registry.IsExecutable("quickopen", ziaService)
                  and registry.IsExecutable("stopjob", ziaService) == false
                  and registry.IsExecutable("debugcontinue", ziaService) == false,
                  "document and project context enables target commands") == false { return; }

    registry.ApplyCommandContext(true, true, true, true,
                                 true, false, false, ziaService);
    if assertTrue(registry.IsExecutable("build", ziaService) == false
                  and registry.IsExecutable("debugstart", ziaService) == false
                  and registry.IsExecutable("stopjob", ziaService),
                  "active jobs gate competing shortcut and palette commands") == false { return; }

    registry.ApplyCommandContext(true, true, true, true,
                                 false, true, true, ziaService);
    if assertTrue(registry.IsExecutable("build", ziaService) == false
                  and registry.IsExecutable("debugstart", ziaService) == false
                  and registry.IsExecutable("debugcontinue", ziaService)
                  and registry.IsExecutable("debugstepover", ziaService)
                  and registry.IsExecutable("debugpause", ziaService) == false
                  and registry.IsExecutable("debugrestart", ziaService)
                  and registry.IsExecutable("debugstop", ziaService),
                  "paused debug sessions expose only valid controls") == false { return; }

    registry.ApplyCommandContext(false, true, true, false,
                                 false, false, false, ziaService);
    if assertTrue(registry.IsExecutable("build", ziaService)
                  and registry.IsExecutable("run", ziaService)
                  and registry.IsExecutable("quickopen", ziaService)
                  and registry.IsExecutable("debugstart", ziaService) == false,
                  "project-only context builds without advertising file debugging") == false {
        return;
    }
    var shortcutRefreshes = registry.shortcutStateRefreshCount;
    registry.ApplyCommandContext(false, true, true, false,
                                 false, false, false, ziaService);
    if assertTrue(registry.shortcutStateRefreshCount == shortcutRefreshes,
                  "stable frame context avoids redundant shortcut refresh") == false {
        return;
    }

    var basicSource = "SUB Greet(name$)\n  PRINT name$\nEND SUB\nGreet(\"Ada\")\n";
    var basicDecls = semantic_scan.DeclarationsForFile("probe.bas", basicSource);
    var greetDef = semantic_scan.BestDefinition(basicDecls, "probe.bas", 4, "Greet");
    if assertTrue(greetDef != null and Map.GetBool(greetDef, "found")
                  and Map.GetInt(greetDef, "line") == 1,
                  "basic scanner finds procedure definitions") == false { return; }
    var basicRefs = Seq.New();
    semantic_scan.AddReferencesForFile(basicRefs, "probe.bas", basicSource, greetDef);
    if assertTrue(Seq.get_Count(basicRefs) >= 2,
                  "basic scanner finds procedure references") == false { return; }
    var basicRenameEdits = semantic_scan.RenameEditsFromReferences(basicRefs, "Welcome");
    if assertTrue(Seq.get_Count(basicRenameEdits) >= 2
                  and Map.GetStr(Seq.Get(basicRenameEdits, 0), "newText") == "Welcome",
                  "basic scanner emits rename edits") == false { return; }
    var basicSig = semantic_scan.SignatureInfoForFile("probe.bas", basicSource, 4, 8);
    if assertTrue(Map.GetBool(basicSig, "available")
                  and Map.GetStr(basicSig, "name") == "Greet",
                  "basic scanner returns signature help") == false { return; }

    var previewPath = Path.Join(TempFile.Dir(), "zannastudio_preview.png");
    File.WriteAllText(previewPath, "not actually image data");
    var previewDocs = new document_manager.DocumentManager();
    var previewDoc = previewDocs.OpenFile(previewPath);
    if assertTrue(previewDoc.isReadOnlyPreview
                  and Str.IndexOf(previewDoc.content, "Binary preview is not available") != 0
                  and previewDocs.SaveDocument(previewDocs.activeIndex) == false,
                  "binary files open as read-only previews") == false { return; }

    var locs = new locations.LocationStore();
    var id = locs.Add("C:\\tmp\\a file.zia", 3, 4, 3, 8, locations.KIND_SEARCH, "hit");
    var loc = locs.Get(id);
    if assertTrue(loc != null and loc!.filePath == "C:\\tmp\\a file.zia",
                  "location store preserves colon path") == false { return; }

    if assertTrue(search_commands.LineMatches("foobar foo", "foo", false, true),
                  "whole-word search finds later whole token") == false { return; }
    if assertTrue(search_commands.LineMatches("Alpha", "alpha", false, false),
                  "case-insensitive search") == false { return; }
    if assertTrue(search_commands.LineMatches("Alpha", "alpha", true, false) == false,
                  "case-sensitive search") == false { return; }

    var shortcutRegistry = new command_registry.CommandRegistry();
    if assertTrue(shortcutRegistry.ShortcutConflictCount() == 0,
                  "default keybindings have no conflicts") == false { return; }
    var saveShortcut = shortcutRegistry.ShortcutFor("save");
    shortcutRegistry.Add("probe.conflict", "Probe Conflict", "Intentional conflict",
                         saveShortcut, "", true);
    if assertTrue(shortcutRegistry.ShortcutConflictCount() == 1
                  and shortcutRegistry.ShortcutHasConflict(saveShortcut)
                  and Str.IndexOf(shortcutRegistry.ShortcutConflictSummary(), "save") != 0,
                  "keybinding conflict detection reports duplicates") == false { return; }

    var workScheduler = new scheduler.EditorScheduler();
    var firstGen = workScheduler.Queue(scheduler.JOB_DIAGNOSTICS, "a.zia", 1, 0);
    var secondGen = workScheduler.Queue(scheduler.JOB_DIAGNOSTICS, "a.zia", 2, 0);
    if assertTrue(workScheduler.IsCurrent(scheduler.JOB_DIAGNOSTICS, firstGen) == false
                  and workScheduler.IsCurrent(scheduler.JOB_DIAGNOSTICS, secondGen)
                  and workScheduler.QueuedGeneration(scheduler.JOB_DIAGNOSTICS) == secondGen,
                  "scheduler generations reject stale jobs") == false { return; }
    workScheduler.Cancel(scheduler.JOB_DIAGNOSTICS);
    if assertTrue(workScheduler.IsCurrent(scheduler.JOB_DIAGNOSTICS, secondGen) == false
                  and workScheduler.QueuedGeneration(scheduler.JOB_DIAGNOSTICS) == 0,
                  "scheduler cancel invalidates queued generation") == false { return; }

    var defaultSettings = new settings.SettingsManager();
    if assertTrue(defaultSettings.fontSize == settings.DEFAULT_FONT_SIZE
                  and settings.DEFAULT_FONT_SIZE == 15,
                  "default editor font size is readable") == false { return; }
    if assertTrue(defaultSettings.minimapVisible,
                  "minimap defaults on: the line-summary cache renders incrementally") == false { return; }
    if assertTrue(defaultSettings.wordWrap == false and defaultSettings.lineNumbers,
                  "editor view settings have stable defaults") == false { return; }
    if assertTrue(defaultSettings.insertSpaces
                  and defaultSettings.ensureFinalNewline
                  and defaultSettings.autoSave == false
                  and defaultSettings.saveAllBeforeBuild
                  and defaultSettings.trimTrailingWhitespace == false,
                  "editor save settings have stable defaults") == false { return; }
    if assertTrue(defaultSettings.uiZoomPercent == 100,
                  "UI zoom defaults to 100 percent") == false { return; }

    var sigSource = "module Demo;\nfunc f() { outer(inner(a, b), c); }\n";
    if assertTrue(signature.ActiveParameter(sigSource, 2, 27) == 1,
                  "nested signature active parameter") == false { return; }

    if assertTrue(edit_commands.IsValidIdentifier("newName_1"),
                  "valid rename identifier") == false { return; }
    if assertTrue(edit_commands.IsValidIdentifier("1bad") == false,
                  "invalid rename identifier") == false { return; }
    if assertTrue(edit_commands.IsValidIdentifier("while") == false,
                  "keyword rename identifier rejected") == false { return; }

    var closeMgr = new document_manager.DocumentManager();
    var closeA = closeMgr.NewDocument();
    closeA.fileName = "a.zia";
    var closeB = closeMgr.NewDocument();
    closeB.fileName = "b.zia";
    var closeC = closeMgr.NewDocument();
    closeC.fileName = "c.zia";
    closeMgr.SetActive(2);
    closeMgr.CloseDocument(0);
    var stillActive = closeMgr.GetActive();
    if assertTrue(closeMgr.activeIndex == 1 and stillActive != null and stillActive!.fileName == "c.zia",
                  "closing tab left of active keeps same document active") == false { return; }

    var root = TempFile.CreateDirWithPrefix("zannastudio_phase_probe_");
    var filePath = Path.Join(root, "main.zia");
    File.WriteAllText(filePath, "module Main;\nfunc start() {\n    var oldName = 1;\n    var useName = oldName;\n}\n");
    var aliasDir = Path.Join(root, "path-alias");
    Dir.MakeAll(aliasDir);
    var equivalentFilePath = Path.Join(Path.Join(aliasDir, ".."), "main.zia");
    var canonicalDocs = new document_manager.DocumentManager();
    var canonicalDoc = canonicalDocs.OpenFile(equivalentFilePath);
    canonicalDocs.OpenFile(filePath);
    if assertTrue(canonicalDoc.filePath == Path.Normalize(Path.Absolute(filePath))
                  and canonicalDocs.GetCount() == 1,
                  "document paths are canonicalized before storage and de-duplication") == false {
        return;
    }
    if assertTrue(File.SameFile(filePath, equivalentFilePath),
                  "runtime file identity recognizes equivalent path spellings") == false {
        return;
    }
    var caseEquivalentFilePath = Path.Join(root, "MAIN.ZIA");
    if File.Exists(caseEquivalentFilePath)
       and File.SameFile(filePath, caseEquivalentFilePath) {
        canonicalDocs.OpenFile(caseEquivalentFilePath);
        if assertTrue(canonicalDocs.GetCount() == 1,
                      "case-equivalent file identity cannot create duplicate tabs") == false {
            return;
        }
    }
    canonicalDocs.ApplyRecoveredText(equivalentFilePath, "module RecoveredExisting;\n");
    if assertTrue(canonicalDocs.GetCount() == 1 and canonicalDoc.isModified
                  and canonicalDoc.content == "module RecoveredExisting;\n",
                  "crash recovery reuses an existing canonical document") == false { return; }
    var missingRecoveredDoc = canonicalDocs.ApplyRecoveredText(
        Path.Join(root, "missing-swap-origin.zia"), "module RecoveredDraft;\n");
    if assertTrue(canonicalDocs.GetCount() == 2 and missingRecoveredDoc.isNew
                  and missingRecoveredDoc.filePath == ""
                  and Str.IndexOf(missingRecoveredDoc.fileName, "Recovered") != 0,
                  "crash recovery detaches missing origins into safe drafts") == false { return; }
    var binaryPath = Path.Join(root, "zannastudio");
    var binaryBytes = Bytes.New(8);
    Bytes.Set(binaryBytes, 0, 0xCF);
    Bytes.Set(binaryBytes, 1, 0xFA);
    Bytes.Set(binaryBytes, 2, 0xED);
    Bytes.Set(binaryBytes, 3, 0xFE);
    Bytes.Set(binaryBytes, 4, 0);
    Bytes.Set(binaryBytes, 5, 1);
    Bytes.Set(binaryBytes, 6, 2);
    Bytes.Set(binaryBytes, 7, 3);
    File.WriteAllBytes(binaryPath, binaryBytes);
    if assertTrue(document_manager.IsEditableTextFile(filePath)
                  and !document_manager.IsEditableTextFile(binaryPath),
                  "editable-file gate detects extensionless binary payloads") == false { return; }
    if assertTrue(startup_arguments.IsUserFileArgument(0, binaryPath) == false
                  and startup_arguments.IsUserFileArgument(0, filePath)
                  and startup_arguments.IsUserFileArgument(1, filePath),
                  "startup arguments reject executable payloads and accept source files") == false { return; }

    var saveCollisionPath = Path.Join(root, "already-open.zia");
    File.WriteAllText(saveCollisionPath, "module AlreadyOpen;\n");
    var saveCollisionMgr = new document_manager.DocumentManager();
    var saveSource = saveCollisionMgr.OpenFile(filePath);
    saveCollisionMgr.OpenFile(saveCollisionPath);
    saveCollisionMgr.SetActive(0);
    saveSource.content = "module Replacement;\n";
    if assertTrue(saveCollisionMgr.SaveAs(saveCollisionPath) == false
                  and saveCollisionMgr.GetCount() == 2
                  and saveCollisionMgr.FindByPath(filePath) == 0
                  and saveCollisionMgr.FindByPath(saveCollisionPath) == 1
                  and File.ReadAllText(saveCollisionPath) == "module AlreadyOpen;\n",
                  "Save As rejects a path owned by another open document") == false { return; }

    // Save-time conflict checks include a content hash, so a same-size rewrite
    // is protected even on filesystems with coarse or preserved timestamps.
    var conflictPath = Path.Join(root, "save-conflict.zia");
    File.WriteAllText(conflictPath, "module Alpha;\n");
    var conflictMgr = new document_manager.DocumentManager();
    var conflictDoc = conflictMgr.OpenFile(conflictPath);
    File.WriteAllText(conflictPath, "module Bravo;\n");
    conflictDoc.content = "module Saved;\n";
    conflictDoc.isModified = true;
    var conflictState = conflictMgr.ExternalStateForSave(0);
    if assertTrue(conflictState == document.EXTERNAL_STATE_CHANGED
                  and conflictMgr.SaveDocument(0) == false
                  and File.ReadAllText(conflictPath) == "module Bravo;\n"
                  and conflictDoc.isModified,
                  "ordinary save rejects a same-size external rewrite") == false { return; }
    if assertTrue(conflictMgr.SaveDocumentAfterExternalConfirmation(0, conflictState)
                  and File.ReadAllText(conflictPath) == "module Saved;\n"
                  and conflictDoc.isModified == false,
                  "confirmed external overwrite commits one stable replacement") == false { return; }

    File.Delete(conflictPath);
    conflictDoc.content = "module Recreated;\n";
    conflictDoc.isModified = true;
    var missingState = conflictMgr.ExternalStateForSave(0);
    if assertTrue(missingState == document.EXTERNAL_STATE_MISSING
                  and conflictMgr.SaveDocument(0) == false
                  and conflictMgr.SaveDocumentAfterExternalConfirmation(0, missingState)
                  and File.ReadAllText(conflictPath) == "module Recreated;\n",
                  "missing file is recreated only after explicit confirmation") == false { return; }

    var binarySaveMgr = new document_manager.DocumentManager();
    var binarySaveDoc = binarySaveMgr.NewDocument();
    binarySaveDoc.content = "module NotAnImage;\n";
    var binarySavePath = Path.Join(root, "not-an-image.png");
    if assertTrue(binarySaveMgr.SaveAs(binarySavePath) == false
                  and File.Exists(binarySavePath) == false
                  and binarySaveDoc.isNew
                  and binarySaveDoc.filePath == "",
                  "Save As rejects known binary extensions without mutating the document") == false { return; }

    var tinySettingsPath = Path.Join(root, "tiny-settings.ini");
    File.WriteAllText(tinySettingsPath, "[settings]\nfontSize=8\n");
    var tinySettings = new settings.SettingsManager();
    tinySettings.settingsDir = root;
    tinySettings.settingsPath = tinySettingsPath;
    tinySettings.Load();
    if assertTrue(tinySettings.fontSize == settings.DEFAULT_FONT_SIZE,
                  "tiny persisted font size migrates to readable default") == false { return; }

    var viewSettingsPath = Path.Join(root, "view-settings.ini");
    File.WriteAllText(viewSettingsPath,
        "[settings]\nwordWrap=1\nlineNumbers=0\ninsertSpaces=0\n"
        + "trimTrailingWhitespace=1\nensureFinalNewline=0\nautoSave=1\nsaveAllBeforeBuild=0\n"
        + "diagnosticsDelayMs=750\ncompletionDelayMs=90\nuiZoomPercent=125\n");
    var viewSettings = new settings.SettingsManager();
    viewSettings.settingsDir = root;
    viewSettings.settingsPath = viewSettingsPath;
    viewSettings.Load();
    if assertTrue(viewSettings.wordWrap and viewSettings.lineNumbers == false
                  and viewSettings.insertSpaces == false
                  and viewSettings.trimTrailingWhitespace
                  and viewSettings.ensureFinalNewline == false
                  and viewSettings.autoSave
                  and viewSettings.saveAllBeforeBuild == false
                  and viewSettings.diagnosticsDelayMs == 750
                  and viewSettings.completionDelayMs == 90
                  and viewSettings.uiZoomPercent == 125,
                  "view settings load from persistent preferences") == false { return; }

    var clampSettingsPath = Path.Join(root, "clamp-settings.ini");
    File.WriteAllText(clampSettingsPath, "[settings]\nuiZoomPercent=9999\n");
    var clampSettings = new settings.SettingsManager();
    clampSettings.settingsDir = root;
    clampSettings.settingsPath = clampSettingsPath;
    clampSettings.Load();
    if assertTrue(clampSettings.uiZoomPercent == 100,
                  "out-of-range persisted UI zoom is rejected to the default") == false { return; }
    var invalidSettingsTarget = new settings.SettingsManager();
    invalidSettingsTarget.settingsDir = root;
    invalidSettingsTarget.settingsPath = root;
    invalidSettingsTarget.Load();
    if assertTrue(invalidSettingsTarget.Save() == false,
                  "settings I/O failures return false without trapping") == false { return; }
    if assertTrue(viewSettings.Save(),
                  "ordinary settings save reports success") == false { return; }
    var viewSettingsIni = Ini.Parse(File.ReadAllText(viewSettingsPath));
    if assertTrue(Ini.Get(viewSettingsIni, "settings", "wordWrap") == "1"
                  and Ini.Get(viewSettingsIni, "settings", "lineNumbers") == "0",
                  "view settings save to persistent preferences") == false { return; }
    if assertTrue(Ini.Get(viewSettingsIni, "settings", "insertSpaces") == "0"
                  and Ini.Get(viewSettingsIni, "settings", "trimTrailingWhitespace") == "1"
                  and Ini.Get(viewSettingsIni, "settings", "ensureFinalNewline") == "0"
                  and Ini.Get(viewSettingsIni, "settings", "autoSave") == "1"
                  and Ini.Get(viewSettingsIni, "settings", "saveAllBeforeBuild") == "0"
                  and Ini.Get(viewSettingsIni, "settings", "diagnosticsDelayMs") == "750"
                  and Ini.Get(viewSettingsIni, "settings", "completionDelayMs") == "90",
                  "editor behavior settings save to persistent preferences") == false { return; }

    file_commands.SetSaveFormatOptions(true, true);
    if assertTrue(file_commands.ApplySaveTextRules("one  \n\t\nthree\t") == "one\n\nthree\n",
                  "save formatting trims trailing whitespace and final newline") == false { return; }

    var settingsPath = Path.Join(root, "settings.ini");
    var oldProjectRoot = Path.Join(root, "OldProject");
    var olderProjectRoot = Path.Join(root, "OlderProject");
    Dir.MakeAll(oldProjectRoot);
    Dir.MakeAll(olderProjectRoot);
    File.WriteAllText(settingsPath,
        "[settings]\nrestoreSession=0\nrestoreLastProject=0\nconfirmOnExitWithUnsavedChanges=0\n"
        + "[recent]\ncount=2\npath.0=" + oldProjectRoot
        + "\npath.1=" + olderProjectRoot + "\n");
    var projectRoot = Path.Join(root, "ProjectA");
    Dir.MakeAll(projectRoot);
    var sessMgr = new session.SessionManager();
    sessMgr.Setup(settingsPath);
    var sessionDocMgr = new document_manager.DocumentManager();
    sessionDocMgr.OpenFile(filePath);
    var dirtySessionDoc = sessionDocMgr.GetActive();
    if dirtySessionDoc != null {
        dirtySessionDoc!.content = dirtySessionDoc!.content + "// unsaved recovery edit\n";
        dirtySessionDoc!.isModified = true;
    }
    var sessionProjMgr = new project_manager.ProjectManager();
    sessionProjMgr.project = new project.Project();
    sessionProjMgr.project.Open(projectRoot);
    if assertTrue(sessMgr.Save(sessionDocMgr, sessionProjMgr),
                  "ordinary session save reports success") == false { return; }
    var savedIni = Ini.Parse(File.ReadAllText(settingsPath));
    if assertTrue(Ini.Get(savedIni, "settings", "restoreSession") == "0",
                  "session save preserves disabled restoreSession") == false { return; }
    if assertTrue(Ini.Get(savedIni, "settings", "restoreLastProject") == "0",
                  "session save preserves disabled restoreLastProject") == false { return; }
    if assertTrue(Ini.Get(savedIni, "settings", "confirmOnExitWithUnsavedChanges") == "0",
                  "session save preserves close confirmation setting") == false { return; }
    if assertTrue(Ini.Get(savedIni, "recent", "count") == "3"
                  and Ini.Get(savedIni, "recent", "path.0") == projectRoot
                  and Ini.Get(savedIni, "recent", "path.1") == oldProjectRoot,
                  "session save prepends recent project history") == false { return; }
    if assertTrue(Ini.Get(savedIni, "recentFiles", "count") == "1"
                  and Ini.Get(savedIni, "recentFiles", "path.0") == filePath,
                  "session save records recent file history") == false { return; }
    if assertTrue(Ini.Get(savedIni, "session.file.0", "recoveryModified") == "1"
                  and Ini.Get(savedIni, "session.file.0", "recoveryEncoding") == "base64"
                  and Str.IndexOf(Codec.Base64Decode(Ini.Get(savedIni, "session.file.0", "recovery")),
                                  "unsaved recovery edit") != 0,
                  "session save snapshots dirty existing files") == false { return; }

    // Writer limits must mirror restore limits. A large live tab set used to
    // serialize every document even though startup would read only 256, causing
    // long close stalls and leaving the active tab outside the restorable set.
    var cappedSessionPath = Path.Join(root, "capped-session.ini");
    File.WriteAllText(cappedSessionPath, "[settings]\nrestoreSession=1\n");
    var cappedDocs = new document_manager.DocumentManager();
    var capIndex = 0;
    var cappedActivePath = "";
    while capIndex < 260 {
        var cappedDoc = cappedDocs.NewDocument();
        cappedDoc.fileName = "cap-" + capIndex + ".zia";
        cappedDoc.filePath = Path.Join(root, cappedDoc.fileName);
        File.WriteAllText(cappedDoc.filePath, "module Cap" + capIndex + ";\n");
        cappedDoc.isNew = false;
        cappedDoc.isModified = false;
        cappedActivePath = cappedDoc.filePath;
        capIndex = capIndex + 1;
    }
    var cappedSession = new session.SessionManager();
    cappedSession.Setup(cappedSessionPath);
    if assertTrue(cappedSession.SaveCleanExit(
                      cappedDocs, new project_manager.ProjectManager()),
                  "capped session save succeeds") == false { return; }
    var cappedIni = Ini.Parse(File.ReadAllText(cappedSessionPath));
    if assertTrue(Ini.Get(cappedIni, "session", "count") == "256"
                  and Ini.Get(cappedIni, "session", "activeIndex") == "255"
                  and Ini.Get(cappedIni, "session", "activePath") == cappedActivePath
                  and Ini.Get(cappedIni, "session.file.254", "name") == "cap-254.zia"
                  and Ini.Get(cappedIni, "session.file.255", "name") == "cap-259.zia"
                  and Ini.Get(cappedIni, "session.file.256", "path") == "",
                  "session writer caps tabs and retains the active tail tab") == false {
        return;
    }

    // Embedded legacy recovery is aggregate-bounded as well as per-document
    // bounded. Reserve capacity for the active draft and omit an untitled tab
    // entirely when its only durable content cannot fit.
    var recoveryCapPath = Path.Join(root, "capped-session-recovery.ini");
    File.WriteAllText(recoveryCapPath, "[settings]\nrestoreSession=1\n");
    var recoveryCapDocs = new document_manager.DocumentManager();
    var recoveryCapIndex = 0;
    var recoveryChunk = Str.Repeat("x", session.MAX_SESSION_RECOVERY_CHARS);
    while recoveryCapIndex < 21 {
        var recoveryCapDoc = recoveryCapDocs.NewDocument();
        recoveryCapDoc.fileName = "recovery-" + recoveryCapIndex;
        recoveryCapDoc.content = recoveryChunk;
        recoveryCapDoc.isModified = true;
        recoveryCapIndex = recoveryCapIndex + 1;
    }
    var recoveryCapSession = new session.SessionManager();
    recoveryCapSession.Setup(recoveryCapPath);
    if assertTrue(recoveryCapSession.Save(
                      recoveryCapDocs, new project_manager.ProjectManager()),
                  "aggregate recovery-capped session save succeeds") == false { return; }
    var recoveryCapIni = Ini.Parse(File.ReadAllText(recoveryCapPath));
    if assertTrue(Ini.Get(recoveryCapIni, "session", "count") == "20"
                  and Ini.Get(recoveryCapIni, "session", "activeIndex") == "19"
                  and Ini.Get(recoveryCapIni, "session.file.19", "name") == "recovery-20"
                  and File.SizeBytes(recoveryCapPath) <= safe_io.MAX_STUDIO_STATE_BYTES,
                  "aggregate recovery cap reserves the active draft within state limit") == false {
        return;
    }

    // A hostile or corrupt shared state file is rejected from metadata alone.
    // Save paths must also decline to clobber it because preserving unknown
    // sections is impossible without first reading a complete bounded snapshot.
    var oversizedSettingsPath = Path.Join(root, "oversized-settings.ini");
    var oversizedSettingsText = "[settings]\ntheme=light\n"
        + Str.Repeat("x", safe_io.MAX_STUDIO_STATE_BYTES + 1);
    File.WriteAllText(oversizedSettingsPath, oversizedSettingsText);
    var oversizedSettingsBytes = File.SizeBytes(oversizedSettingsPath);
    var oversizedSettings = new settings.SettingsManager();
    oversizedSettings.settingsDir = root;
    oversizedSettings.settingsPath = oversizedSettingsPath;
    oversizedSettings.Load();
    if assertTrue(oversizedSettings.theme == "dark"
                  and oversizedSettings.Save() == false
                  and File.SizeBytes(oversizedSettingsPath) == oversizedSettingsBytes,
                  "oversized shared state keeps defaults and is not overwritten") == false {
        return;
    }

    var invalidSessionTarget = new session.SessionManager();
    invalidSessionTarget.Setup(root);
    if assertTrue(invalidSessionTarget.Save(sessionDocMgr, sessionProjMgr) == false
                  and invalidSessionTarget.RecordRecentFile(filePath) == false
                  and invalidSessionTarget.RecentFileCount() == 0,
                  "session I/O failures return safely without corrupting history") == false {
        return;
    }

    var corruptRecoveryPath = Path.Join(root, "corrupt-recovery.ini");
    File.WriteAllText(corruptRecoveryPath,
        "[settings]\nrestoreSession=1\nrestoreLastProject=0\n"
        + "[session]\ncount=1\nactiveIndex=0\n"
        + "[session.file.0]\npath=\nname=corrupt-recovery\n"
        + "recovery=%%%not-base64%%%\nrecoveryEncoding=base64\nrecoveryModified=1\n"
        + "[recentFiles]\ncount=999999999\n");
    var corruptSession = new session.SessionManager();
    corruptSession.Setup(corruptRecoveryPath);
    var corruptDocs = new document_manager.DocumentManager();
    if assertTrue(corruptSession.Restore(corruptDocs,
                                         new project_manager.ProjectManager(), null) == 0
                  and corruptDocs.GetCount() == 0
                  and corruptSession.RecentFileCount() == 0,
                  "corrupt recovery payloads and counts are bounded at startup") == false {
        return;
    }

    var binarySettingsPath = Path.Join(root, "binary-session.ini");
    File.WriteAllText(binarySettingsPath,
        "[settings]\nrestoreSession=1\nrestoreLastProject=0\n"
        + "[session]\ncount=1\nactivePath=" + binaryPath + "\nactiveIndex=0\n"
        + "[session.file.0]\npath=" + binaryPath + "\nname=zannastudio\n"
        + "recovery=\nrecoveryEncoding=\nrecoveryModified=0\n"
        + "[recentFiles]\ncount=2\npath.0=" + binaryPath + "\npath.1=" + filePath + "\n");
    var binarySession = new session.SessionManager();
    binarySession.Setup(binarySettingsPath);
    var prunedHistoryIni = Ini.Parse(File.ReadAllText(binarySettingsPath));
    if assertTrue(binarySession.RecentFileCount() == 1
                  and binarySession.RecentFileAt(0) == filePath
                  and Ini.Get(prunedHistoryIni, "recentFiles", "path.1") == "",
                  "session setup purges binary recent-file entries") == false { return; }
    var binaryRestoreDocs = new document_manager.DocumentManager();
    var binaryRestored = binarySession.Restore(binaryRestoreDocs,
                                               new project_manager.ProjectManager(), null);
    if assertTrue(binaryRestored == 0 and binaryRestoreDocs.GetCount() == 0,
                  "session restore does not reopen a binary preview") == false { return; }
    var binaryRestoreIni = Ini.Parse(File.ReadAllText(binarySettingsPath));
    if assertTrue(Ini.Get(binaryRestoreIni, "session.file.0", "path") == ""
                  and Ini.Get(binaryRestoreIni, "session", "activePath") == "",
                  "session restore removes rejected persisted paths") == false { return; }

    var duplicateRecentPath = Path.Join(root, "duplicate-recents.ini");
    File.WriteAllText(duplicateRecentPath,
        "[recentFiles]\ncount=2\npath.0=" + equivalentFilePath
        + "\npath.1=" + filePath + "\n");
    var duplicateRecentSession = new session.SessionManager();
    duplicateRecentSession.Setup(duplicateRecentPath);
    if assertTrue(duplicateRecentSession.RecentFileCount() == 1
                  and duplicateRecentSession.RecentFileAt(0)
                      == Path.Normalize(Path.Absolute(filePath)),
                  "recent files canonicalize equivalent path spellings") == false { return; }

    var duplicateProjectRecentPath = Path.Join(root, "duplicate-project-recents.ini");
    File.WriteAllText(duplicateProjectRecentPath,
        "[recent]\ncount=3\npath.0=" + Path.Join(oldProjectRoot, ".")
        + "\npath.1=" + oldProjectRoot
        + "\npath.2=" + Path.Join(root, "missing-project") + "\n");
    var duplicateProjectRecentSession = new session.SessionManager();
    duplicateProjectRecentSession.Setup(duplicateProjectRecentPath);
    var prunedProjectRecentIni = Ini.Parse(File.ReadAllText(duplicateProjectRecentPath));
    if assertTrue(duplicateProjectRecentSession.RecentProjectCount() == 1
                  and duplicateProjectRecentSession.RecentProjectAt(0)
                      == Path.Normalize(Path.Absolute(oldProjectRoot))
                  and Ini.Get(prunedProjectRecentIni, "recent", "path.1") == "",
                  "recent projects prune missing and equivalent paths") == false { return; }

    var duplicateRestorePath = Path.Join(root, "duplicate-restore.ini");
    File.WriteAllText(duplicateRestorePath,
        "[settings]\nrestoreSession=1\nrestoreLastProject=0\n"
        + "[session]\ncount=2\nactivePath=" + filePath + "\nactiveIndex=1\n"
        + "[session.file.0]\npath=" + equivalentFilePath + "\n"
        + "[session.file.1]\npath=" + filePath + "\n");
    var duplicateRestoreSession = new session.SessionManager();
    duplicateRestoreSession.Setup(duplicateRestorePath);
    var duplicateRestoreDocs = new document_manager.DocumentManager();
    var duplicateRestored = duplicateRestoreSession.Restore(
        duplicateRestoreDocs, new project_manager.ProjectManager(), null);
    var duplicateRestoreIni = Ini.Parse(File.ReadAllText(duplicateRestorePath));
    if assertTrue(duplicateRestored == 1 and duplicateRestoreDocs.GetCount() == 1
                  and Ini.Get(duplicateRestoreIni, "session.file.1", "path") == "",
                  "session restore removes canonically duplicate document slots") == false {
        return;
    }

    // The startup-facing restore API must honor its caller's root/file budget;
    // otherwise a valid 256-tab session monopolizes the UI before main can
    // poll or repaint the already-visible welcome surface.
    var stagedRestorePath = Path.Join(root, "staged-restore.ini");
    var stagedRestoreText = "[settings]\nrestoreSession=1\nrestoreLastProject=0\n"
        + "[session]\ncount=5\nactiveIndex=4\n";
    var stagedIndex = 0;
    var stagedActivePath = "";
    while stagedIndex < 5 {
        var stagedFile = Path.Join(root, "staged-" + stagedIndex + ".zia");
        File.WriteAllText(stagedFile, "module Staged" + stagedIndex + ";\n");
        stagedRestoreText = stagedRestoreText
            + "[session.file." + stagedIndex + "]\npath=" + stagedFile + "\n";
        stagedActivePath = stagedFile;
        stagedIndex = stagedIndex + 1;
    }
    stagedRestoreText = stagedRestoreText
        + "[session]\nactivePath=" + stagedActivePath + "\n";
    File.WriteAllText(stagedRestorePath, stagedRestoreText);
    var stagedSession = new session.SessionManager();
    stagedSession.Setup(stagedRestorePath);
    var stagedDocs = new document_manager.DocumentManager();
    var stagedJob = stagedSession.BeginRestore(
        stagedDocs, new project_manager.ProjectManager(), null);
    var firstRestorePump = stagedSession.PumpRestore(stagedJob, 2);
    if assertTrue(firstRestorePump == 2 and stagedJob.active
                  and stagedJob.completedWork == 2 and stagedDocs.GetCount() == 2,
                  "session restore yields after its first bounded page") == false {
        return;
    }
    var stagedPumpSafe = true;
    var stagedPumpCount = 0;
    while stagedJob.active and stagedPumpCount < 10 {
        var restoredThisPump = stagedSession.PumpRestore(stagedJob, 2);
        if restoredThisPump <= 0 or restoredThisPump > 2 {
            stagedPumpSafe = false;
        }
        stagedPumpCount = stagedPumpCount + 1;
    }
    var stagedActive = stagedDocs.GetActive();
    if assertTrue(stagedPumpSafe and stagedJob.active == false
                  and stagedJob.restoredCount == 5 and stagedDocs.GetCount() == 5
                  and stagedJob.completedWork == 5
                  and stagedSession.RestoreProgressText(stagedJob)
                      == "Restoring your workspace: 5/5"
                  and stagedActive != null and stagedActive!.filePath == stagedActivePath,
                  "session restore completes bounded pages and restores active tab") == false {
        return;
    }

    var missingRecoveryPath = Path.Join(root, "missing-recovery.ini");
    var missingSourcePath = Path.Join(root, "deleted-before-restore.zia");
    File.WriteAllText(missingRecoveryPath,
        "[settings]\nrestoreSession=1\nrestoreLastProject=0\n"
        + "[session]\ncount=1\nactivePath=" + missingSourcePath + "\nactiveIndex=0\n"
        + "[session.file.0]\npath=" + missingSourcePath + "\nname=deleted-before-restore.zia\n"
        + "recovery=" + Codec.Base64Encode("module Recovered;\n// unsaved\n") + "\n"
        + "recoveryEncoding=base64\nrecoveryModified=1\n");
    var missingRecoverySession = new session.SessionManager();
    missingRecoverySession.Setup(missingRecoveryPath);
    var missingRecoveryDocs = new document_manager.DocumentManager();
    var missingRecovered = missingRecoverySession.Restore(
        missingRecoveryDocs, new project_manager.ProjectManager(), null);
    var recoveredDraft = missingRecoveryDocs.GetActive();
    var missingRecoveryIni = Ini.Parse(File.ReadAllText(missingRecoveryPath));
    if assertTrue(missingRecovered == 1 and recoveredDraft != null
                  and recoveredDraft!.isNew and recoveredDraft!.isModified
                  and recoveredDraft!.filePath == ""
                  and Str.IndexOf(recoveredDraft!.content, "unsaved") != 0
                  and Ini.Get(missingRecoveryIni, "session.file.0", "path") == ""
                  and Ini.Get(missingRecoveryIni, "session.file.0", "recovery") != "",
                  "missing named files retain unsaved recovery as a draft") == false {
        return;
    }
    var previewOnlyDocs = new document_manager.DocumentManager();
    previewOnlyDocs.OpenFile(binaryPath);
    binarySession.Save(previewOnlyDocs, new project_manager.ProjectManager());
    var previewSaveIni = Ini.Parse(File.ReadAllText(binarySettingsPath));
    if assertTrue(Ini.Get(previewSaveIni, "session", "count") == "0"
                  and Ini.Get(previewSaveIni, "recentFiles", "count") == "1",
                  "session save excludes binary preview documents") == false { return; }

    sessionDocMgr.CloseDocument(0);
    if assertTrue(sessionDocMgr.RecentlyClosedCount() == 1
                  and sessionDocMgr.PopRecentlyClosedPath() == filePath,
                  "document manager tracks recently closed named files") == false { return; }

    var settingsOnlyPath = Path.Join(root, "settings-only.ini");
    File.WriteAllText(settingsOnlyPath, "[settings]\ntheme=dark\nfontSize=15\n");
    var settingsOnlySession = new session.SessionManager();
    settingsOnlySession.Setup(settingsOnlyPath);
    var emptyRestoreCount = settingsOnlySession.Restore(new document_manager.DocumentManager(),
                                                        new project_manager.ProjectManager(),
                                                        null);
    if assertTrue(emptyRestoreCount == 0,
                  "session restore tolerates settings file without session section") == false { return; }

    var docMgr = new document_manager.DocumentManager();
    var doc = docMgr.OpenFile(filePath);
    var workspaceRoots = new List();
    workspaceRoots.Push(root);

    var edits = Seq.New();
    AddEdit(edits, filePath, 4, 19, 4, 26, "newName");
    var preview = workspace_edits.PreviewRenameEdits(edits, 20);
    if assertTrue(Str.IndexOf(preview, "Apply 1 rename edits?") != 0
                  and Str.IndexOf(preview, "newName") != 0,
                  "workspace edit preview summarizes rename edits") == false { return; }
    var applyResult = workspace_edits.ApplyRenameEdits(edits, docMgr,
                                                       workspaceRoots);
    if assertTrue(applyResult.success and doc.content != File.ReadAllText(filePath),
                  "workspace edit updates open dirty document only") == false { return; }

    var closedEditPath = Path.Join(root, "closed_workspace_edit.zia");
    File.WriteAllText(closedEditPath, "oldName\n");
    var closedEdits = Seq.New();
    AddEdit(closedEdits, closedEditPath, 1, 1, 1, 8, "newName");
    var closedResult = workspace_edits.ApplyRenameEdits(
        closedEdits, new document_manager.DocumentManager(), workspaceRoots);
    if assertTrue(closedResult.success
                  and File.ReadAllText(closedEditPath) == "newName\n",
                  "closed workspace edits use opened roots instead of process cwd") == false {
        return;
    }

    var unsortedPath = Path.Join(root, "unsorted_open_edits.zia");
    File.WriteAllText(unsortedPath, "aa bb cc\n");
    var unsortedMgr = new document_manager.DocumentManager();
    var unsortedDoc = unsortedMgr.OpenFile(unsortedPath);
    var unsortedEdits = Seq.New();
    AddEdit(unsortedEdits, unsortedPath, 1, 7, 1, 9, "CCCC");
    AddEdit(unsortedEdits, unsortedPath, 1, 1, 1, 3, "AAAA");
    var unsortedResult = workspace_edits.ApplyRenameEdits(unsortedEdits,
                                                          unsortedMgr,
                                                          workspaceRoots);
    if assertTrue(unsortedResult.success
                  and unsortedDoc.content == "AAAA bb CCCC\n",
                  "workspace edits sort open-buffer edits by descending range") == false { return; }

    var rollbackPath = Path.Join(root, "rollback.zia");
    File.WriteAllText(rollbackPath, "module Rollback;\nfunc run() {\n    var oldName = 1;\n}\n");
    var rollbackMgr = new document_manager.DocumentManager();
    var rollbackDoc = rollbackMgr.OpenFile(rollbackPath);
    var beforeRollback = rollbackDoc.content;
    var badEdits = Seq.New();
    AddEdit(badEdits, rollbackPath, 3, 9, 3, 16, "newName");
    AddEdit(badEdits, Path.Join(root, "missing.zia"), 1, 1, 1, 2, "x");
    var badResult = workspace_edits.ApplyRenameEdits(badEdits, rollbackMgr,
                                                     workspaceRoots);
    if assertTrue(badResult.success == false
                  and rollbackDoc.content == beforeRollback
                  and rollbackDoc.isModified == false,
                  "workspace edit failure leaves open buffers unchanged") == false { return; }

    var overlapEdits = Seq.New();
    AddEdit(overlapEdits, rollbackPath, 3, 9, 3, 16, "firstName");
    AddEdit(overlapEdits, rollbackPath, 3, 12, 3, 16, "secondName");
    var overlapResult = workspace_edits.ApplyRenameEdits(overlapEdits,
                                                         rollbackMgr,
                                                         workspaceRoots);
    if assertTrue(overlapResult.success == false
                  and rollbackDoc.content == beforeRollback
                  and rollbackDoc.isModified == false
                  and Str.IndexOf(overlapResult.message, "Rename was canceled before changing files") != 0
                  and Str.IndexOf(overlapResult.message, "First edit") != 0
                  and Str.IndexOf(overlapResult.message, "Second edit") != 0
                  and Str.IndexOf(overlapResult.message, "3:9-3:16") != 0
                  and Str.IndexOf(overlapResult.message, "3:12-3:16") != 0,
                  "overlapping workspace edits are rejected with rich conflict ranges") == false { return; }

    var indexer = new project_index.ProjectIndexer();
    indexer.Open(root, docMgr);
    var refs = indexer.References(filePath, doc.content, 3, 8);
    if assertTrue(refs != null and Seq.get_Count(refs) >= 1,
                  "project index references from dirty buffer") == false { return; }
    indexer.Destroy();

    Dir.RemoveAll(root);
    Terminal.Say("RESULT: ok");
}
