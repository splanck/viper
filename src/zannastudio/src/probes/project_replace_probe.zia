//===----------------------------------------------------------------------===//
//
// File: zannastudio/src/probes/project_replace_probe.zia
// Purpose: Regress safe, generation-scoped, cooperative project replacement.
// Key invariants:
//   - Interactive replacement never performs file I/O in its start callback.
//   - Each pump changes at most the documented bounded file batch.
//   - Old/future search generations and pathological lines are never changed.
// Ownership/Lifetime: The probe owns all temporary files and controllers.
// Links: zannastudio/src/commands/replace_commands.zia,
//        zannastudio/src/commands/search_commands.zia
//
//===----------------------------------------------------------------------===//

module project_replace_probe;

// ============================================================================
// MODULE: project_replace_probe
// PURPOSE: Verify plan 07 project-wide replace — closed files rewrite on
//          disk from recorded search locations, matches re-verify at apply
//          time (drifted lines are safe), open buffers update in memory and
//          mark modified, and per-line multi-match replacement works.
// ============================================================================

bind "../commands/replace_commands";
bind "../core/document_manager";
bind "../services/locations";

bind File = Zanna.IO.File;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;
bind Terminal = Zanna.Terminal;
bind Str = Zanna.String;

func fail(reason: String) {
    Terminal.Say("RESULT: fail " + reason);
}

func main() {
    var root = TempFile.CreateDirWithPrefix("zannastudio_replace_");

    // Closed file: two matches on one line, one on another.
    var alpha = Path.Join(root, "alpha.zia");
    File.WriteAllText(alpha, "old plus old\nkeep\nvalue old here\n");
    // Closed file with a line that will DRIFT before apply (no match anymore).
    var beta = Path.Join(root, "beta.zia");
    File.WriteAllText(beta, "nothing matching anymore\n");

    var locStore = new locations.LocationStore();
    locStore.Add(alpha, 1, 1, 1, 4, locations.KIND_SEARCH, "old plus old");
    locStore.Add(alpha, 3, 7, 3, 10, locations.KIND_SEARCH, "value old here");
    locStore.Add(alpha, 3, 7, 3, 10, locations.KIND_SEARCH, "duplicate row");
    locStore.Add(beta, 1, 1, 1, 4, locations.KIND_SEARCH, "stale");

    var docMgr = new document_manager.DocumentManager();
    var summary = replace_commands.ReplaceAllFromResults(
        locStore, docMgr, null, "old", "new", true, false, false);

    var alphaText = File.ReadAllText(alpha);
    if alphaText != "new plus new\nkeep\nvalue new here\n" {
        fail("alpha content wrong: " + alphaText);
        return;
    }
    var betaText = File.ReadAllText(beta);
    if betaText != "nothing matching anymore\n" {
        fail("drifted beta must stay untouched");
        return;
    }
    if Str.Contains(summary, "3 match(es)") == false {
        fail("summary should report 3 replacements: " + summary);
        return;
    }

    // Open (inactive) document: buffer updates and marks modified; disk stays.
    var gamma = Path.Join(root, "gamma.zia");
    File.WriteAllText(gamma, "open old buffer\n");
    var doc = docMgr.OpenFile(gamma);
    if doc == null {
        fail("could not open gamma");
        return;
    }
    doc.isModified = false;
    var locStore2 = new locations.LocationStore();
    locStore2.Add(gamma, 1, 6, 1, 9, locations.KIND_SEARCH, "open old buffer");
    replace_commands.ReplaceAllFromResults(
        locStore2, docMgr, null, "old", "new", true, false, false);
    if Str.Contains(doc.content, "open new buffer") == false {
        fail("open buffer not updated: " + doc.content);
        return;
    }
    if doc.isModified == false {
        fail("open buffer should be marked modified");
        return;
    }
    if doc.hasPendingWorkspaceUndo == false
       or doc.pendingWorkspaceUndoContent != "open old buffer\n"
       or doc.pendingWorkspaceUndoLabel != "Replace All" {
        fail("inactive open buffer should retain one-step workspace undo");
        return;
    }
    if Str.Contains(File.ReadAllText(gamma), "open old buffer") == false {
        fail("disk copy of an open doc must not be rewritten");
        return;
    }

    // Whole-word option respected at apply time.
    var delta = Path.Join(root, "delta.zia");
    File.WriteAllText(delta, "scold old\n");
    var locStore3 = new locations.LocationStore();
    locStore3.Add(delta, 1, 7, 1, 10, locations.KIND_SEARCH, "scold old");
    replace_commands.ReplaceAllFromResults(
        locStore3, docMgr, null, "old", "new", true, true, false);
    if File.ReadAllText(delta) != "scold new\n" {
        fail("whole-word replace wrong: " + File.ReadAllText(delta));
        return;
    }

    // Interactive replacement snapshots only the completed search id range,
    // returns before touching disk, and applies no more than two files/pump.
    var slicedLocations = new locations.LocationStore();
    var oldGeneration = Path.Join(root, "old_generation.zia");
    File.WriteAllText(oldGeneration, "old\n");
    slicedLocations.Add(oldGeneration, 1, 1, 1, 4,
                        locations.KIND_SEARCH, "old");
    var firstCurrentId = slicedLocations.nextId;
    var slicePaths = new List();
    var sliceIndex = 0;
    while sliceIndex < 5 {
        var slicePath = Path.Join(root, "slice_" + sliceIndex + ".zia");
        File.WriteAllText(slicePath, "old\n");
        slicePaths.Push(slicePath);
        slicedLocations.Add(slicePath, 1, 1, 1, 4,
                            locations.KIND_SEARCH, "old");
        sliceIndex = sliceIndex + 1;
    }
    var lastCurrentId = slicedLocations.nextId - 1;
    var futureGeneration = Path.Join(root, "future_generation.zia");
    File.WriteAllText(futureGeneration, "old\n");
    slicedLocations.Add(futureGeneration, 1, 1, 1, 4,
                        locations.KIND_SEARCH, "old");

    var controller = new replace_commands.ProjectReplaceController();
    if controller.StartFromResults(slicedLocations, firstCurrentId,
                                   lastCurrentId, "old", "new",
                                   true, false, false) == false {
        fail("cooperative replace did not start: " + controller.lastSummary);
        return;
    }
    if File.ReadAllText(slicePaths.get(0) as String) != "old\n" {
        fail("replace start callback performed disk I/O");
        return;
    }
    controller.Pump(docMgr, null);
    if controller.active == false or controller.lastPumpFileCount <= 0
       or controller.lastPumpFileCount > 2 or controller.fileIndex > 2 {
        fail("cooperative replace exceeded one-frame file budget");
        return;
    }
    while controller.active {
        controller.Pump(docMgr, null);
        if controller.lastPumpFileCount > 2 {
            fail("cooperative replace exceeded later file budget");
            return;
        }
    }
    sliceIndex = 0;
    while sliceIndex < slicePaths.count() {
        if File.ReadAllText(slicePaths.get(sliceIndex) as String) != "new\n" {
            fail("cooperative replace missed a current result file");
            return;
        }
        sliceIndex = sliceIndex + 1;
    }
    if File.ReadAllText(oldGeneration) != "old\n"
       or File.ReadAllText(futureGeneration) != "old\n" {
        fail("replace crossed its completed search id range");
        return;
    }
    var slicedSummary = controller.TakeSummary();
    if Str.Contains(slicedSummary, "5 match(es)") == false {
        fail("cooperative replace summary wrong: " + slicedSummary);
        return;
    }

    // Stop is cooperative too: completed files remain explicit, while later
    // plans are never touched after cancellation.
    var cancelLocations = new locations.LocationStore();
    var cancelPaths = new List();
    sliceIndex = 0;
    while sliceIndex < 5 {
        var cancelPath = Path.Join(root, "cancel_" + sliceIndex + ".zia");
        File.WriteAllText(cancelPath, "old\n");
        cancelPaths.Push(cancelPath);
        cancelLocations.Add(cancelPath, 1, 1, 1, 4,
                            locations.KIND_SEARCH, "old");
        sliceIndex = sliceIndex + 1;
    }
    var cancelController = new replace_commands.ProjectReplaceController();
    cancelController.StartFromResults(cancelLocations, 1,
                                      cancelLocations.nextId - 1,
                                      "old", "new", true, false, false);
    cancelController.Pump(docMgr, null);
    var cancelSummary = cancelController.Cancel();
    cancelController.Pump(docMgr, null);
    if cancelController.active or Str.Contains(cancelSummary, "stopped") == false
       or File.ReadAllText(cancelPaths.get(4) as String) != "old\n" {
        fail("cooperative replacement cancellation did not stop later files");
        return;
    }

    // More than the per-line replacement ceiling cancels that whole file,
    // instead of silently writing a partially transformed line.
    var denseBuilder = new Zanna.Text.StringBuilder();
    sliceIndex = 0;
    while sliceIndex < 1001 {
        denseBuilder.Append("old ");
        sliceIndex = sliceIndex + 1;
    }
    var densePath = Path.Join(root, "dense.zia");
    var denseText = denseBuilder.ToString() + "\n";
    File.WriteAllText(densePath, denseText);
    var denseLocations = new locations.LocationStore();
    denseLocations.Add(densePath, 1, 1, 1, 4,
                       locations.KIND_SEARCH, "old");
    var denseSummary = replace_commands.ReplaceAllFromResults(
        denseLocations, docMgr, null, "old", "new", true, false, false);
    if File.ReadAllText(densePath) != denseText
       or Str.Contains(denseSummary, "1 unavailable") == false {
        fail("dense line should be skipped as one atomic file");
        return;
    }

    Terminal.Say("RESULT: ok");
}
