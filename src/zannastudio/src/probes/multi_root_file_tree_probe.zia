//
// File: zannastudio/src/probes/multi_root_file_tree_probe.zia
// Purpose: Exercise multi-root Explorer discovery and root-owned metadata.
// Key invariants:
//   - Every workspace root contributes files to the aggregate cache.
//   - Entry-file and rename updates are written to the owning root only.
//   - Added roots survive session save/restore and can be removed without disk I/O.
//   - Workspace transitions retarget Explorer, index, SCM, and terminal together.
// Ownership/Lifetime: The probe owns its temporary roots and AppShell.
// Links: zannastudio/src/core/project_manager.zia
//
//===----------------------------------------------------------------------===//

module multi_root_file_tree_probe;

// ============================================================================
// MODULE: multi_root_file_tree_probe
// PURPOSE: Headless probe for multi-root workspace file discovery.
//
// WHERE-THIS-FITS: ProjectManager owns the primary root, extra roots, ignore
//          checks, and aggregate Quick Open/search cache. This probe verifies
//          cache membership across multiple temporary roots.
//
// TEACHING-NOTE: Multi-root behavior should always check root ownership rather
//          than assuming the primary project owns every workspace path.
// ============================================================================

bind "../ui/app_shell";
bind "../commands/command_context";
bind "../commands/main_command_dispatcher";
bind "../commands/search_commands";
bind "../app/workspace_watcher";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../core/session";
bind "../editor/project_index";
bind "../services/locations";
bind "../scm/scm_view";
bind "../terminal/terminal_controller";

bind Zanna.GUI as GUI;
bind Terminal = Zanna.Terminal;
bind Dir = Zanna.IO.Dir;
bind File = Zanna.IO.File;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;
bind Ini = Zanna.Data.Ini;
bind Str = Zanna.String;

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

func cacheContains(projMgr: project_manager.ProjectManager, needle: String) -> Boolean {
    var n = projMgr.CachedFileCount();
    var i = 0;
    while i < n {
        var p = projMgr.CachedFileAt(i);
        if Str.EndsWith(p, needle) { return true; }
        i = i + 1;
    }
    return false;
}

func main() {
    var shell = new app_shell.AppShell();
    shell.Build("Zanna Studio Multi-Root Probe", 960, 640);

    var root1 = TempFile.CreateDirWithPrefix("zannastudio_mroot1_");
    var root2 = TempFile.CreateDirWithPrefix("zannastudio_mroot2_");
    File.WriteAllText(Path.Join(root1, "alpha.zia"), "module Alpha;\n");
    File.WriteAllText(Path.Join(root2, "beta.zia"), "module Beta;\n");

    var projMgr = new project_manager.ProjectManager();
    projMgr.Setup(shell.workbench.sidebarTree);
    var docMgr = new document_manager.DocumentManager();
    var indexer = new project_index.ProjectIndexer();
    var scm = new scm_view.ScmView();
    scm.Setup(shell.workbench.scmViewHost);
    var terminalCtrl = new terminal_controller.TerminalController();
    var searcher = new search_commands.SearchController();
    var locStore = new locations.LocationStore();
    var watcherState = new workspace_watcher.WorkspaceWatcherState();
    var commandContext = new command_context.CommandContext();
    commandContext.shell = shell;
    commandContext.docMgr = docMgr;
    commandContext.projMgr = projMgr;
    commandContext.indexer = indexer;
    commandContext.scmView = scm;
    commandContext.terminalCtrl = terminalCtrl;
    commandContext.searcher = searcher;
    commandContext.locStore = locStore;
    commandContext.workspaceWatcherState = watcherState;

    // Single root first.
    if projMgr.OpenFolder(root1) == false { fail(shell, "primary root open failed"); return; }
    shell.SetSidebarVisible(false);
    if main_command_dispatcher.ActivateOpenWorkspace(commandContext, true) == false {
        fail(shell, "primary workspace consumers not activated");
        return;
    }
    shell.Poll();
    shell.Render();
    if scm.repoPath != root1 or terminalCtrl.cwd != root1
       or indexer.workspaceSignature != projMgr.WorkspaceSignature()
       or shell.workbench.leftViewStack.GetWidth() <= 1 {
        fail(shell, "primary workspace consumers diverged");
        return;
    }
    if projMgr.extraRoots.count() != 0 { fail(shell, "extraRoots not empty after OpenFolder"); return; }
    if cacheContains(projMgr, "alpha.zia") == false { fail(shell, "alpha.zia missing from single-root cache"); return; }
    if cacheContains(projMgr, "beta.zia") { fail(shell, "beta.zia present before AddFolder"); return; }

    // Add a second root — both roots' files should now be cached.
    if projMgr.AddFolderToWorkspace(root2) == false {
        fail(shell, "second root add failed");
        return;
    }
    if projMgr.extraRoots.count() != 1 { fail(shell, "extraRoots count != 1 after AddFolder"); return; }
    if main_command_dispatcher.ActivateOpenWorkspace(commandContext, false) == false
       or indexer.workspaceSignature != projMgr.WorkspaceSignature()
       or scm.repoPath != root1 or terminalCtrl.cwd != root1 {
        fail(shell, "multi-root workspace consumers diverged");
        return;
    }
    if cacheContains(projMgr, "alpha.zia") == false { fail(shell, "alpha.zia missing from multi-root cache"); return; }
    if cacheContains(projMgr, "beta.zia") == false { fail(shell, "beta.zia missing from multi-root cache"); return; }

    // Session persistence must retain every root, not silently collapse the
    // workspace to its primary folder on the next launch.
    var sessionDir = TempFile.CreateDirWithPrefix("zannastudio_mroot_session_");
    var sessionPath = Path.Join(sessionDir, "settings.ini");
    File.WriteAllText(sessionPath,
                      "[settings]\nrestoreSession=1\nrestoreLastProject=1\n");
    var sessionMgr = new session.SessionManager();
    sessionMgr.Setup(sessionPath);
    if sessionMgr.Save(docMgr, projMgr) == false {
        fail(shell, "multi-root session save failed");
        return;
    }
    var savedSession = Ini.Parse(File.ReadAllText(sessionPath));
    if Ini.Get(savedSession, "session", "workspaceRootCount") != "2"
       or Ini.Get(savedSession, "session", "workspaceRoot.0") != root1
       or Ini.Get(savedSession, "session", "workspaceRoot.1") != root2
       or Ini.Get(savedSession, "recent", "count") != "2"
       or Ini.Get(savedSession, "recent", "path.0") != root1
       or Ini.Get(savedSession, "recent", "path.1") != root2 {
        fail(shell, "multi-root session did not serialize every root");
        return;
    }
    var restoredMgr = new project_manager.ProjectManager();
    restoredMgr.Setup(null);
    var restoredDocs = new document_manager.DocumentManager();
    if sessionMgr.Restore(restoredDocs, restoredMgr, null) != 0
       or restoredMgr.RootCount() != 2
       or restoredMgr.RootPathAt(0) != root1
       or restoredMgr.RootPathAt(1) != root2 {
        fail(shell, "multi-root session restore collapsed the workspace");
        return;
    }
    if restoredMgr.RemoveFolderFromWorkspace(root2) == false
       or sessionMgr.Save(restoredDocs, restoredMgr) == false {
        fail(shell, "shorter workspace session save failed");
        return;
    }
    var shorterSession = Ini.Parse(File.ReadAllText(sessionPath));
    if Ini.Get(shorterSession, "session", "workspaceRootCount") != "1"
       or Ini.Get(shorterSession, "session", "workspaceRoot.0") != root1
       or Ini.Get(shorterSession, "session", "workspaceRoot.1") != "" {
        fail(shell, "shorter workspace session retained a removed root");
        return;
    }

    // A missing saved primary must not prevent a still-valid extra root from
    // restoring; the first surviving folder becomes the primary root.
    var partialSessionPath = Path.Join(sessionDir, "partial-settings.ini");
    File.WriteAllText(partialSessionPath,
        "[settings]\nrestoreSession=1\nrestoreLastProject=1\n"
        + "[session]\nworkspaceRootCount=2\n"
        + "workspaceRoot.0=" + Path.Join(sessionDir, "missing-root") + "\n"
        + "workspaceRoot.1=" + root2 + "\ncount=0\n");
    var partialSession = new session.SessionManager();
    partialSession.Setup(partialSessionPath);
    var partialMgr = new project_manager.ProjectManager();
    partialMgr.Setup(null);
    if partialSession.Restore(new document_manager.DocumentManager(),
                              partialMgr, null) != 0
       or partialMgr.RootCount() != 1
       or partialMgr.RootPath() != root2 {
        fail(shell, "surviving workspace root was not promoted during restore");
        return;
    }

    // Adding a duplicate root is rejected honestly and does not change state.
    if projMgr.AddFolderToWorkspace(root2)
       or projMgr.extraRoots.count() != 1
       or projMgr.lastOperationError == "" {
        fail(shell, "duplicate AddFolder did not report an unchanged workspace");
        return;
    }

    // A folder-picker race must not close the current multi-root workspace.
    var missingRoot = Path.Join(root2, "removed-before-open");
    if projMgr.OpenFolder(missingRoot)
       or projMgr.RootPath() != root1
       or projMgr.RootCount() != 2 {
        fail(shell, "failed replacement destroyed the current workspace");
        return;
    }

    // OwningProject resolves a file to its own root (relative path strips that root).
    var betaAbs = Path.Join(root2, "beta.zia");
    if projMgr.RelativePath(betaAbs) != "beta.zia" { fail(shell, "RelativePath not root-aware for second root"); return; }

    // Entry metadata belongs to the file's owning root. The primary project
    // must remain untouched when an extra-root file is selected as that root's
    // entry point, and a later rename must follow the same owner.
    if projMgr.SetEntryFile(betaAbs) == false {
        fail(shell, "extra-root entry file rejected");
        return;
    }
    var secondRootProject = projMgr.extraRoots.get(0);
    if secondRootProject.entryFile != "beta.zia"
       or projMgr.project.entryFile != "main.zia"
       or Str.IndexOf(File.ReadAllText(Path.Join(root2, "zanna.project")),
                      "entry beta.zia") == 0 {
        fail(shell, "extra-root entry metadata used primary root");
        return;
    }
    var renamedBeta = projMgr.RenamePath(betaAbs, "beta-renamed.zia", null);
    if renamedBeta != Path.Join(root2, "beta-renamed.zia")
       or secondRootProject.entryFile != "beta-renamed.zia"
       or Str.IndexOf(File.ReadAllText(Path.Join(root2, "zanna.project")),
                      "entry beta-renamed.zia") == 0 {
        fail(shell, "extra-root entry metadata did not follow rename");
        return;
    }

    // Root removal is a full service transition, not merely a tree-row delete.
    // First remove an extra root, then re-add it and remove the primary so the
    // remaining root is promoted and every primary-root consumer follows it.
    if main_command_dispatcher.RemoveWorkspaceFolder(commandContext, root2) == false
       or projMgr.RootCount() != 1
       or projMgr.RootPath() != root1
       or indexer.workspaceSignature != projMgr.WorkspaceSignature()
       or scm.repoPath != root1 or terminalCtrl.cwd != root1
       or Dir.Exists(root2) == false
       or cacheContains(projMgr, "beta-renamed.zia") {
        fail(shell, "extra workspace root removal left stale state");
        return;
    }
    if projMgr.AddFolderToWorkspace(root2) == false
       or main_command_dispatcher.ActivateOpenWorkspace(commandContext, false) == false {
        fail(shell, "removed workspace root could not be re-added");
        return;
    }
    if main_command_dispatcher.RemoveWorkspaceFolder(commandContext, root1) == false
       or projMgr.RootCount() != 1
       or projMgr.RootPath() != root2
       or indexer.rootPath != root2
       or indexer.workspaceSignature != projMgr.WorkspaceSignature()
       or scm.repoPath != root2 or terminalCtrl.cwd != root2
       or Dir.Exists(root1) == false {
        fail(shell, "primary workspace root removal did not promote consumers");
        return;
    }

    // Replacing an existing workspace through File/Command Palette must move
    // every consumer off the old repository, not only rebuild the Explorer.
    var root3 = TempFile.CreateDirWithPrefix("zannastudio_mroot3_");
    File.WriteAllText(Path.Join(root3, "gamma.zia"), "module Gamma;\n");
    workspace_watcher.PumpWorkspaceWatcher(null, projMgr, docMgr, indexer,
                                            locStore, null, watcherState);
    searcher.active = true;
    searcher.discovering = true;
    locStore.Add(Path.Join(root2, "beta-renamed.zia"), 1, 1, 1, 1,
                 locations.KIND_SEARCH, "stale old-root result");
    if projMgr.OpenFolder(root3) == false
       or main_command_dispatcher.ActivateOpenWorkspace(commandContext, true) == false
       or projMgr.RootCount() != 1
       or scm.repoPath != root3
       or terminalCtrl.cwd != root3
       or indexer.rootPath != root3
       or indexer.workspaceSignature != projMgr.WorkspaceSignature()
       or searcher.active or searcher.discovering
       or locStore.items.count() != 0
       or watcherState.rootSignature != ""
       or watcherState.watchers.count() != 0 {
        fail(shell, "replacement workspace consumers retained stale root");
        return;
    }

    // Closing a workspace is a first-class transition: release the index and
    // detach SCM/terminal/sidebar state while leaving the filesystem and any
    // open editor documents alone.
    if main_command_dispatcher.RemoveWorkspaceFolder(commandContext, root3) == false {
        fail(shell, "removing the final root did not close the workspace");
        return;
    }
    shell.Poll();
    shell.Render();
    if projMgr.IsOpen() or projMgr.RootCount() != 0
       or indexer.valid or indexer.rootPath != ""
       or scm.repoPath != "" or terminalCtrl.cwd != ""
       or shell.workbench.leftViewStack.GetWidth() > 1 {
        fail(shell, "closed workspace retained attached consumers");
        return;
    }
    if Dir.Exists(root3) == false {
        fail(shell, "close workspace mutated the project directory");
        return;
    }
    scm.Refresh();
    if scm.activeJob != null or scm.activePtyJob != null {
        fail(shell, "closed workspace allowed an unscoped git refresh");
        return;
    }
    if main_command_dispatcher.RemoveWorkspaceFolder(commandContext, root3) {
        fail(shell, "removing a folder from a closed workspace reported success");
        return;
    }

    indexer.Destroy();
    shell.Destroy();
    Terminal.Say("RESULT: ok");
}
