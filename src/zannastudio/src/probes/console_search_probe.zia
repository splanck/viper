//
// File: zannastudio/src/probes/console_search_probe.zia
// Purpose: Regress Studio output, search, command chrome, and navigation.
// Key invariants:
//   - Visible menu shortcuts match the active platform command registry.
//   - Tool-panel state and structured search locations remain coherent.
//   - Workspace-symbol parsing remains bounded and honors dirty live buffers.
//   - Floating workbench forms stay inside the effective viewport at UI zoom.
//   - Focus-taking forms replace one another without stale-owner interference.
// Ownership/Lifetime: The probe owns and destroys its shell and temporary data.
// Links: zannastudio/src/ui/app_shell.zia,
//        zannastudio/src/commands/command_registry.zia
//
//===----------------------------------------------------------------------===//

module console_search_probe;

// ============================================================================
// MODULE: console_search_probe
// PURPOSE: Regression probe for output panels, console helpers, search, and
//          Quick Open scoring/navigation behavior.
//
// WHERE-THIS-FITS: This probe validates user-facing tool-panel behavior without
//          routing through the full main loop. It constructs focused controllers
//          and uses real temporary files where path behavior matters.
//
// TEACHING-NOTE: Search rows carry structured location ids. Probe assertions
//          should check both displayed rows and the data needed for navigation.
// ============================================================================

bind "../ui/app_shell";
bind "../ui/command_input";
bind "../ui/debug_breakpoint_overlay";
bind "../ui/diff_view";
bind "../ui/explorer_actions";
bind "../ui/ide_overlays";
bind "../ui/output_cache";
bind "../app/command_palette_controller";
bind "../commands/command_registry";
bind "../commands/quick_open_commands";
bind "../commands/search_commands";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../core/settings";
bind "../editor/diagnostics";
bind "../services/locations";

bind GUI = Zanna.GUI;
bind Obj = Zanna.Core.Object;
bind Convert = Zanna.Core.Convert;
bind Terminal = Zanna.Terminal;
bind File = Zanna.IO.File;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;
bind Str = Zanna.String;
bind Clock = Zanna.Time.Clock;
bind Env = Zanna.System.Environment;
bind Machine = Zanna.System.Machine;

final CLIPBOARD_RETRY_ATTEMPTS = 50;

func UiViewportWidth(app: GUI.App) -> Number {
    return app_shell.UiViewportWidth(app);
}

func UiViewportHeight(app: GUI.App) -> Number {
    return app_shell.UiViewportHeight(app);
}

func fail(shell: app_shell.AppShell, reason: String) {
    shell.Destroy();
    Terminal.Say("RESULT: fail " + reason);
}

func OverlayContainsAction(app: GUI.App,
                           panel: GUI.FloatingPanel,
                           action: GUI.Button) -> Boolean {
    if app == null or panel == null or action == null { return false; }
    var panelRight = panel.GetScreenX() + panel.GetScreenWidth();
    var panelBottom = panel.GetScreenY() + panel.GetScreenHeight();
    return panel.GetScreenX() >= 0.0 and panel.GetScreenY() >= 0.0
        and panelRight <= UiViewportWidth(app) + 1.0
        and panelBottom <= UiViewportHeight(app) + 1.0
        and action.GetScreenX() + action.GetScreenWidth() <= panelRight
        and action.GetScreenY() + action.GetScreenHeight() <= panelBottom;
}

func copySelectedClipboardContains(shell: app_shell.AppShell, needle: String) -> Boolean {
    var attempt = 0;
    while attempt < CLIPBOARD_RETRY_ATTEMPTS {
        if shell.toolPanels.CopySelectedToolRow() {
            if Str.IndexOf(GUI.ClipboardText.GetText(), needle) != 0 {
                return true;
            }
        }
        Clock.Sleep(2);
        attempt = attempt + 1;
    }
    return false;
}

func copySelectedClipboardEquals(shell: app_shell.AppShell, expected: String) -> Boolean {
    var attempt = 0;
    while attempt < CLIPBOARD_RETRY_ATTEMPTS {
        if shell.toolPanels.CopySelectedToolRow() {
            if GUI.ClipboardText.GetText() == expected {
                return true;
            }
        }
        Clock.Sleep(2);
        attempt = attempt + 1;
    }
    return false;
}

func copySelectedClipboardNonEmpty(shell: app_shell.AppShell) -> Boolean {
    var attempt = 0;
    while attempt < CLIPBOARD_RETRY_ATTEMPTS {
        if shell.toolPanels.CopySelectedToolRow() {
            if GUI.ClipboardText.GetText() != "" {
                return true;
            }
        }
        Clock.Sleep(2);
        attempt = attempt + 1;
    }
    return false;
}

func copyOutputClipboardContains(shell: app_shell.AppShell, needle: String) -> Boolean {
    var attempt = 0;
    while attempt < CLIPBOARD_RETRY_ATTEMPTS {
        if shell.toolPanels.CopyOutputText() {
            if Str.IndexOf(GUI.ClipboardText.GetText(), needle) != 0 {
                return true;
            }
        }
        Clock.Sleep(2);
        attempt = attempt + 1;
    }
    return false;
}

func main() {
    var shell = new app_shell.AppShell();
    shell.Build("Zanna Studio Console Search Probe", 800, 520);

    var chromeRegistry = new command_registry.CommandRegistry();
    shell.ApplyCommandShortcuts(chromeRegistry);
    var closeWorkspaceEntry = chromeRegistry.Find("closeworkspace");
    var addFolderEntry = chromeRegistry.Find("addfolder");
    var removeFolderEntry = chromeRegistry.Find("removefolder");
    if closeWorkspaceEntry == null or closeWorkspaceEntry.category != "File"
       or addFolderEntry == null or addFolderEntry.category != "File"
       or removeFolderEntry == null or removeFolderEntry.category != "File" {
        fail(shell, "workspace commands missing from the File catalog");
        return;
    }
    if shell.menuChrome.miOpenFolder.GetShortcut() != chromeRegistry.ShortcutFor("openfolder")
       or shell.menuChrome.miAddFolder == null
       or shell.menuChrome.miRemoveFolder == null
       or shell.menuChrome.miCloseWorkspace == null
       or shell.menuChrome.miQuickOpen.GetShortcut() != chromeRegistry.ShortcutFor("quickopen")
       or shell.menuChrome.miSaveAs.GetShortcut() != chromeRegistry.ShortcutFor("saveas")
       or shell.menuChrome.miSaveAll.GetShortcut() != chromeRegistry.ShortcutFor("saveall")
       or shell.menuChrome.miSearchProject.GetShortcut() != chromeRegistry.ShortcutFor("searchproject")
       or shell.menuChrome.miGoToDefinition.GetShortcut() != chromeRegistry.ShortcutFor("gotodef")
       or shell.menuChrome.miWorkspaceSymbols.GetShortcut() != chromeRegistry.ShortcutFor("workspacesymbols")
       or shell.menuChrome.miSymbolOutline.GetShortcut() != chromeRegistry.ShortcutFor("symboloutline")
       or shell.menuChrome.ctxRename.GetShortcut() != chromeRegistry.ShortcutFor("treerename")
       or shell.menuChrome.ctxRefresh.GetShortcut() != chromeRegistry.ShortcutFor("treerefresh") {
        fail(shell, "menu shortcut discoverability");
        return;
    }
    shell.SetCommandContextAvailable(false, false, false, false);
    if shell.menuChrome.miAddFolder.IsEnabled() == false
       or shell.menuChrome.miRemoveFolder.IsEnabled()
       or shell.menuChrome.miCloseWorkspace.IsEnabled() {
        fail(shell, "closed-workspace menu state");
        return;
    }
    shell.SetCommandContextAvailable(false, true, true, false);
    if shell.menuChrome.miRemoveFolder.IsEnabled() == false
       or shell.menuChrome.miCloseWorkspace.IsEnabled() == false {
        fail(shell, "open-workspace close command state");
        return;
    }
    shell.SetCommandContextAvailable(false, false, false, false);

    // Palette and shortcut dispatch must honor the same workspace/job/debug
    // policy as visible menu items.
    chromeRegistry.ApplyCommandContext(false, false, false, false,
                                       false, false, false, null);
    if chromeRegistry.IsExecutable("removefolder", null)
       or chromeRegistry.DisabledReason("removefolder", null) == "" {
        fail(shell, "closed-workspace remove command registry state");
        return;
    }
    chromeRegistry.ApplyCommandContext(false, true, true, false,
                                       true, false, false, null);
    if chromeRegistry.IsExecutable("removefolder", null)
       or chromeRegistry.DisabledReason("removefolder", null) == "" {
        fail(shell, "running-job remove command registry state");
        return;
    }
    chromeRegistry.ApplyCommandContext(false, true, true, false,
                                       false, false, false, null);
    if chromeRegistry.IsExecutable("removefolder", null) == false {
        fail(shell, "idle remove command registry state");
        return;
    }

    // Applying an override must replace visible chrome, including clearing a
    // binding altogether. Otherwise Settings reports the new keymap while the
    // menu continues advertising a stale shortcut until restart.
    var quickOpenEntry = chromeRegistry.Find("quickopen");
    quickOpenEntry.shortcut = "Alt+Q";
    shell.ApplyCommandShortcuts(chromeRegistry);
    if shell.menuChrome.miQuickOpen.GetShortcut() != "Alt+Q" {
        fail(shell, "live menu shortcut refresh");
        return;
    }
    quickOpenEntry.shortcut = "";
    shell.ApplyCommandShortcuts(chromeRegistry);
    if shell.menuChrome.miQuickOpen.GetShortcut() != "" {
        fail(shell, "live menu shortcut clearing");
        return;
    }
    quickOpenEntry.shortcut = chromeRegistry.DefaultShortcutFor("quickopen");
    shell.ApplyCommandShortcuts(chromeRegistry);

    // Exercise an actual catalog chord through the native event queue. The
    // capability pass between strokes mirrors main's per-frame reconciliation
    // and guards against accidentally clearing the runtime's pending prefix.
    chromeRegistry.InstallShortcuts();
    var shortcutHarness = GUI.TestHarness.New();
    if shortcutHarness.BindApp(shell.app) == false {
        fail(shell, "shortcut harness app binding");
        return;
    }
    var primaryModifier = 2; // VGFX_MOD_CTRL
    if Machine.Os == "macos" { primaryModifier = 8; } // VGFX_MOD_CMD
    shortcutHarness.SendKey("K", primaryModifier);
    shortcutHarness.DispatchPending();
    chromeRegistry.ApplyCapabilities(null);
    shortcutHarness.SendKey("R", primaryModifier);
    shortcutHarness.DispatchPending();
    if Shortcuts.WasTriggered("recentfiles") == false {
        shortcutHarness.UnbindApp();
        fail(shell, "two-stroke catalog shortcut dispatch");
        return;
    }
    shortcutHarness.UnbindApp();
    Shortcuts.Clear();

    if shell.statusShell.lastProjectStatus != "No project"
       or shell.statusShell.lastLanguageStatus != "Lang: text"
       or shell.statusShell.jobItem.GetText() != "Job: idle"
       or shell.statusShell.indexStatusVisible
       or shell.statusShell.jobStatusVisible
       or shell.statusShell.taskStatusVisible {
        fail(shell, "initial status chrome");
        return;
    }
    shell.SetWorkspaceStatus("Demo", "zia");
    if shell.statusShell.lastProjectStatus != "Project: Demo"
       or shell.statusShell.lastLanguageStatus != "Lang: Zia"
       or shell.statusShell.projectItem.GetText() != "Project: Demo"
       or shell.statusShell.languageItem.GetText() != "Lang: Zia" {
        fail(shell, "workspace status chrome");
        return;
    }
    shell.SetWorkspaceStatus("", "basic");
    if shell.statusShell.lastProjectStatus != "No project"
       or shell.statusShell.lastLanguageStatus != "Lang: BASIC" {
        fail(shell, "workspace status fallback");
        return;
    }
    shell.SetIndexStatus("Workspace index ready");
    if shell.statusShell.indexStatusVisible {
        fail(shell, "ready index status visibility");
        return;
    }
    shell.SetIndexStatus("Workspace index 12/40");
    if shell.statusShell.indexStatusVisible == false
       or shell.statusShell.indexItem.GetText() != "Workspace index 12/40" {
        fail(shell, "active index status visibility");
        return;
    }
    var incompleteIndex = "Workspace index skipped oversized file executor.zia";
    shell.SetIndexStatus(incompleteIndex);
    if shell.statusShell.indexStatusVisible == false
       or shell.statusShell.lastIndexStatus != incompleteIndex
       or shell.statusShell.indexItem.GetText() != "Index: incomplete" {
        fail(shell, "incomplete index status was not compacted");
        return;
    }
    shell.SetIndexStatus("");
    if shell.statusShell.indexStatusVisible {
        fail(shell, "idle index status visibility");
        return;
    }
    shell.SetSchedulerStatus("Tasks: diagnostics");
    if shell.statusShell.lastTaskStatus != "Tasks: diagnostics"
       or shell.statusShell.taskStatusVisible == false {
        fail(shell, "active task status visibility");
        return;
    }
    shell.SetSchedulerStatus("");
    if shell.statusShell.lastTaskStatus != "Tasks: idle"
       or shell.statusShell.taskStatusVisible {
        fail(shell, "idle task status visibility");
        return;
    }

    shell.toolPanels.SetBuildOutput("line one\n");
    if shell.toolPanels.outputPane.LineCount <= 0 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "initial raw output pane");
        return;
    }

    shell.toolPanels.SetBuildOutput("line one\nline two\n");
    if shell.toolPanels.outputPane.LineCount < 2 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "append raw output pane");
        return;
    }

    shell.toolPanels.SetBuildOutput("line one\nline two\n");
    if shell.toolPanels.outputPane.LineCount < 2 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "stable raw output pane");
        return;
    }

    shell.toolPanels.SetBuildOutput("partial");
    shell.toolPanels.SetBuildOutput("partial more");
    if shell.toolPanels.outputPane.LineCount <= 0 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "partial raw output rebuild");
        return;
    }

    shell.toolPanels.SetBuildOutput("");
    shell.toolPanels.AppendBuildOutput("one");
    if shell.toolPanels.outputPane.LineCount <= 0 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "append partial raw output");
        return;
    }
    shell.toolPanels.AppendBuildOutput(" two\nthree\n");
    if shell.toolPanels.outputPane.LineCount < 2 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "append completed raw output");
        return;
    }
    shell.toolPanels.outputPane.SelectAll();
    if copySelectedClipboardContains(shell, "one two") == false {
        fail(shell, "copy raw output selection");
        return;
    }

    shell.toolPanels.SetBuildOutput("");
    if shell.toolPanels.outputPane.LineCount != 0 or shell.toolPanels.outputListBox.Count != 0
       or shell.toolPanels.outputPane.IsVisible() or shell.toolPanels.outputListBox.IsVisible() {
        fail(shell, "clear output");
        return;
    }

    shell.toolPanels.SetBuildOutput("error one\nwarning two\ninfo three\n");
    shell.toolPanels.SetOutputFilter("warning");
    if shell.toolPanels.outputListBox.Count != 1 {
        fail(shell, "output filter rows");
        return;
    }
    shell.toolPanels.SetOutputFilter("");
    if shell.toolPanels.outputPane.LineCount < 3 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "output filter clear");
        return;
    }
    shell.toolPanels.SetBuildOutput("abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz\n");
    shell.toolPanels.ToggleOutputWrap();
    if shell.toolPanels.outputListBox.Count < 2 {
        fail(shell, "output wrap rows");
        return;
    }
    shell.toolPanels.outputListBox.SelectIndex(0);
    if copySelectedClipboardNonEmpty(shell) == false {
        fail(shell, "copy output row");
        return;
    }
    shell.toolPanels.BeginOutputRows();
    var rangeA = shell.toolPanels.AddOutputDisplayLine("range one");
    var rangeB = shell.toolPanels.AddOutputDisplayLine("range two");
    shell.toolPanels.outputListBox.Select(rangeA);
    shell.toolPanels.outputListBox.Select(rangeB);
    if copySelectedClipboardEquals(shell, "range one\nrange two") == false {
        fail(shell, "copy output selected range");
        return;
    }
    if copyOutputClipboardContains(shell, "abcdefghijklmnopqrstuvwxyz") == false {
        fail(shell, "copy full output text");
        return;
    }

    // Wrapped output uses the panel's effective logical width. Framebuffer
    // width would make rows wrap two to four times too late on Retina or when
    // whole-UI zoom is active, leaving long build messages clipped.
    shell.app.SetUiScale(2.0);
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    shell.Render();
    var zoomWrapLine = new Zanna.Text.StringBuilder();
    var zoomWrapIndex = 0;
    while zoomWrapIndex < 401 {
        zoomWrapLine.Append("x");
        zoomWrapIndex = zoomWrapIndex + 1;
    }
    shell.toolPanels.SetBuildOutput(zoomWrapLine.ToString() + "\n");
    shell.Render();
    var outputLogicalWidth = Convert.NumToInt(
        shell.toolPanels.outputListBox.GetLogicalWidth());
    var expectedWrapColumn = output_cache.WrapColumn(outputLogicalWidth);
    var expectedWrapRows = (401 + expectedWrapColumn - 1) / expectedWrapColumn;
    if shell.toolPanels.outputListBox.Count != expectedWrapRows {
        fail(shell, "output wrapping ignored the zoomed panel width");
        return;
    }
    shell.app.SetUiScale(1.0);
    shell.app.SetWindowSize(800, 520);
    shell.Poll();
    shell.Render();

    shell.toolPanels.SetOutputAutoScroll(false);
    if shell.toolPanels.ToggleOutputAutoScroll() == false {
        fail(shell, "output auto-scroll enable");
        return;
    }
    if shell.toolPanels.ToggleOutputAutoScroll() {
        fail(shell, "output auto-scroll lock");
        return;
    }
    shell.toolPanels.SetOutputAutoScroll(true);
    shell.toolPanels.SetBuildOutput("scroll one\nscroll two\n");
    if shell.toolPanels.outputListBox.SelectedIndex != -1 {
        fail(shell, "output auto-scroll does not force selection");
        return;
    }
    shell.toolPanels.SetOutputAutoScroll(false);
    shell.toolPanels.outputListBox.SelectIndex(0);
    shell.toolPanels.AppendBuildOutput("scroll three\n");
    if shell.toolPanels.outputListBox.SelectedIndex != 0 {
        fail(shell, "output auto-scroll lock preserves selection");
        return;
    }
    shell.toolPanels.ClearOutputPanel();
    if shell.toolPanels.outputPane.LineCount != 0 or shell.toolPanels.outputListBox.Count != 0 {
        fail(shell, "clear output helper");
        return;
    }
    // This focused probe has no DocumentManager-driven frame loop. Supply a
    // valid synthetic command target before exercising job-state transitions.
    shell.SetCommandContextAvailable(true, true, true, true);
    if shell.menuChrome.tbStop.IsEnabled() or !shell.menuChrome.tbBuild.IsEnabled() {
        fail(shell, "initial build toolbar state");
        return;
    }
    shell.SetBuildJobActive(true, "Build");
    if shell.menuChrome.tbBuild.IsEnabled() or shell.menuChrome.tbRun.IsEnabled()
       or !shell.menuChrome.tbStop.IsEnabled() or shell.menuChrome.miBuild.IsEnabled()
       or shell.menuChrome.miRemoveFolder.IsEnabled()
       or shell.menuChrome.miCloseWorkspace.IsEnabled()
       or !shell.menuChrome.miStop.IsEnabled() or shell.statusShell.lastBuildJobStatus != "Job: Build"
       or shell.statusShell.jobItem.GetText() != "Job: Build"
       or shell.statusShell.jobStatusVisible == false {
        fail(shell, "active build toolbar state");
        return;
    }
    shell.SetBuildJobActive(false, "");
    if !shell.menuChrome.tbBuild.IsEnabled() or !shell.menuChrome.tbRun.IsEnabled()
       or shell.menuChrome.tbStop.IsEnabled() or !shell.menuChrome.miBuild.IsEnabled()
       or shell.menuChrome.miRemoveFolder.IsEnabled() == false
       or shell.menuChrome.miCloseWorkspace.IsEnabled() == false
       or shell.menuChrome.miStop.IsEnabled() or shell.statusShell.lastBuildJobStatus != "Job: idle"
       or shell.statusShell.jobItem.GetText() != "Job: idle"
       or shell.statusShell.jobStatusVisible {
        fail(shell, "idle build toolbar state");
        return;
    }
    shell.SetDebugSessionState(true, false, false);
    if shell.menuChrome.miRemoveFolder.IsEnabled()
       or shell.menuChrome.miCloseWorkspace.IsEnabled() {
        fail(shell, "debug session allowed workspace close");
        return;
    }
    shell.SetDebugSessionState(false, false, false);
    if shell.menuChrome.miRemoveFolder.IsEnabled() == false
       or shell.menuChrome.miCloseWorkspace.IsEnabled() == false {
        fail(shell, "stopped debug session left workspace close disabled");
        return;
    }

    shell.toolPanels.BeginProblems();
    var prob = shell.toolPanels.AddProblem("error", "zia", "src/main.zia", 12, 4,
                                "V-ZIA", "expected token", "");
    GUI.ListBox.ItemSetData(prob, "loc|src/main.zia|12|4|12|5|diagnostic|expected token");
    shell.toolPanels.FinishProblems(1);
    if shell.toolPanels.diagListBox.Count != 2 or !shell.toolPanels.diagListBox.IsVisible() {
        fail(shell, "problems structured rows");
        return;
    }
    shell.toolPanels.diagListBox.SelectIndex(1);
    var problemText = GUI.ListBox.ItemGetText(shell.toolPanels.diagListBox.Selected);
    if Str.IndexOf(problemText, "ERROR") == 0
       or Str.IndexOf(problemText, "V-ZIA") == 0
       or Str.IndexOf(problemText, "-") == 0
       or Str.IndexOf(problemText, "No quick fix") != 0 {
        fail(shell, "problems compact code action placeholder");
        return;
    }
    if diagnostics.ProblemActionForDiagnostic(1, "W000") != "Suppress Warning" {
        fail(shell, "problems suppress warning action");
        return;
    }
    if diagnostics.ProblemActionForDiagnostic(0, "E000") != "No quick fix" {
        fail(shell, "problems no quick fix action");
        return;
    }
    shell.SetDiagnosticsSummary(1, 2, 0);
    if shell.statusShell.lastDiagnosticsStatus != "Diagnostics: 1 error, 2 warnings"
       or shell.statusShell.lastDiagnosticsColor != shell.DiagnosticsSummaryColor(1, 2, 0) {
        fail(shell, "diagnostics status summary");
        return;
    }
    shell.SetDiagnosticsSummary(0, 0, 0);
    if shell.statusShell.lastDiagnosticsStatus != "Diagnostics: clean"
       or shell.statusShell.lastDiagnosticsColor != shell.DiagnosticsSummaryColor(0, 0, 0) {
        fail(shell, "diagnostics clean status summary");
        return;
    }
    shell.toolPanels.ClearProblemsPanel();
    if shell.toolPanels.diagListBox.Count != 0 {
        fail(shell, "clear problems helper");
        return;
    }

    var overlays = new ide_overlays.IdeOverlays();
    overlays.Setup(shell);
    var prefs = new settings.SettingsManager();
    prefs.fontSize = 24;
    prefs.theme = "light";
    prefs.minimapVisible = true;
    prefs.wordWrap = true;
    prefs.insertSpaces = false;
    prefs.diagnosticsDelayMs = 1200;
    prefs.completionDelayMs = 700;
    prefs.restoreSession = false;
    overlays.OpenSettings(shell, prefs);
    overlays.ResetAppearanceDefaults();
    if overlays.ReadFontSize() != settings.DEFAULT_FONT_SIZE
       or overlays.ReadTheme() != "dark"
       or overlays.ReadMinimapVisible() {
        fail(shell, "preferences appearance defaults");
        return;
    }
    overlays.ResetEditingDefaults();
    if overlays.ReadTabWidth() != 4
	       or overlays.ReadWordWrap()
	       or overlays.ReadInsertSpaces() == false
	       or overlays.ReadAutoSave()
	       or overlays.ReadSaveAllBeforeBuild() == false {
	        fail(shell, "preferences editing defaults");
	        return;
	    }
    overlays.ResetIntelliSenseDefaults();
    if overlays.ReadDiagnosticsDelayMs() != 500 or overlays.ReadCompletionDelayMs() != 180 {
        fail(shell, "preferences intellisense defaults");
        return;
    }
    overlays.ResetStartupDefaults();
    if overlays.ReadRestoreSession() == false
       or overlays.ReadRestoreLastProject() == false
       or overlays.ReadConfirmClose() == false {
        fail(shell, "preferences startup defaults");
        return;
    }
    shell.app.SetWindowSize(620, 460);
    overlays.OpenSettings(shell, prefs);
    overlays.Pump(shell);
    shell.Render();
    if !overlays.settingsPanel.IsVisible()
       or overlays.settingsDockWidth != 420
       or overlays.settingsUsesDedicatedSurface == false
       or shell.workbench.editorArea.IsVisible()
       or overlays.settingsPanel.GetFlex() <= 0.0 {
        fail(shell, "preferences compact side panel");
        return;
    }
    var settingsRight = overlays.settingsPanel.GetScreenX()
        + overlays.settingsPanel.GetScreenWidth();
    if overlays.fontPathInput.GetScreenX() + overlays.fontPathInput.GetScreenWidth()
          > settingsRight + 1.0
       or overlays.applySettingsButton.GetScreenY()
              + overlays.applySettingsButton.GetScreenHeight()
          > overlays.settingsPanel.GetScreenY()
              + overlays.settingsPanel.GetScreenHeight() + 1.0 {
        fail(shell, "preferences compact controls escaped their surface: panel="
            + overlays.settingsPanel.GetScreenX() + "/"
            + overlays.settingsPanel.GetScreenWidth() + " input="
            + overlays.fontPathInput.GetScreenX() + "/"
            + overlays.fontPathInput.GetScreenWidth() + " scroll="
            + overlays.settingsBodyScroll.GetScreenX() + "/"
            + overlays.settingsBodyScroll.GetScreenWidth() + " inputRight="
            + (overlays.fontPathInput.GetScreenX()
                + overlays.fontPathInput.GetScreenWidth())
            + " panelRight=" + settingsRight
            + " footerBottom=" + (overlays.applySettingsButton.GetScreenY()
                + overlays.applySettingsButton.GetScreenHeight())
            + " panelBottom=" + (overlays.settingsPanel.GetScreenY()
                + overlays.settingsPanel.GetScreenHeight()));
        return;
    }
    overlays.settingsBodyScroll.SetScroll(100000.0, 100000.0);
    shell.Render();
    if overlays.settingsBodyScroll.GetScrollY() <= 0.0
       or overlays.settingsBodyScroll.GetScrollX() > 0.5 {
        fail(shell, "preferences body must scroll vertically without horizontal overflow");
        return;
    }
    shell.app.SetWindowSize(1280, 720);
    overlays.OpenSettings(shell, prefs);
    overlays.Pump(shell);
    if !overlays.settingsPanel.IsVisible()
       or overlays.settingsDockWidth != 560
       or overlays.settingsUsesDedicatedSurface
       or shell.workbench.editorArea.IsVisible() == false
       or overlays.settingsPanel.GetFlex() > 0.0 {
        fail(shell, "preferences wide side panel");
        return;
    }
    overlays.CloseSettings();
    if overlays.settingsPanel.IsVisible()
       or shell.workbench.editorArea.IsVisible() == false {
        fail(shell, "preferences side panel close");
        return;
    }

    // Short command forms must remain usable at the production workbench
    // minimum even when wrapped validation text is visible.
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    var commandOverlay = new command_input.CommandInputOverlay();
    commandOverlay.Setup(shell);
    commandOverlay.OpenGoToLine(shell, 12);
    commandOverlay.detailLabel.SetText(
        "Enter a valid line number from the active document before continuing.");
    shell.Render();
    if OverlayContainsAction(shell.app, commandOverlay.panel,
                             commandOverlay.applyButton) == false
       or commandOverlay.detailLabel.GetScreenY()
              + commandOverlay.detailLabel.GetScreenHeight()
          > commandOverlay.applyButton.GetScreenY() {
        fail(shell, "command input overlay overflowed at minimum size");
        return;
    }
    commandOverlay.Cancel();

    var explorerOverlay = new explorer_actions.ExplorerActionOverlay();
    explorerOverlay.Setup(shell);
    explorerOverlay.OpenRename(shell, "/workspace/example/old-name.zia");
    explorerOverlay.Reject(
        shell,
        "That destination already exists and cannot replace an open workspace item.");
    shell.Render();
    if OverlayContainsAction(shell.app, explorerOverlay.panel,
                             explorerOverlay.applyButton) == false
       or explorerOverlay.detailLabel.GetScreenY()
              + explorerOverlay.detailLabel.GetScreenHeight()
          > explorerOverlay.applyButton.GetScreenY() {
        fail(shell, "explorer action overlay overflowed at minimum size");
        return;
    }
    explorerOverlay.Cancel();

    var breakpointOverlay = new debug_breakpoint_overlay.DebugBreakpointOverlay();
    breakpointOverlay.Setup(shell);
    breakpointOverlay.OpenCondition(
        shell, "/workspace/example/main.zia", 42, "index > 3");
    breakpointOverlay.detailLabel.SetText(
        "The debugger will validate this expression when the session starts.");
    shell.Render();
    if OverlayContainsAction(shell.app, breakpointOverlay.panel,
                             breakpointOverlay.applyButton) == false
       or breakpointOverlay.detailLabel.GetScreenY()
              + breakpointOverlay.detailLabel.GetScreenHeight()
          > breakpointOverlay.applyButton.GetScreenY() {
        fail(shell, "breakpoint overlay overflowed at minimum size");
        return;
    }
    breakpointOverlay.Cancel();

    // All focus-taking workbench forms share one ownership slot. Exercise the
    // replacement chain as well as a late close from a superseded controller.
    commandOverlay.OpenGoToLine(shell, 18);
    explorerOverlay.OpenRename(shell, "/workspace/example/replacement.zia");
    commandOverlay.Pump(shell);
    commandOverlay.Cancel();
    if commandOverlay.IsVisible() or commandOverlay.panel.IsVisible()
       or explorerOverlay.IsVisible() == false
       or explorerOverlay.panel.IsVisible() == false
       or shell.OwnsTransientSurface(
           app_shell.TRANSIENT_SURFACE_EXPLORER_ACTION) == false {
        fail(shell, "explorer prompt did not replace command input");
        return;
    }
    breakpointOverlay.OpenCondition(
        shell, "/workspace/example/main.zia", 43, "ready");
    explorerOverlay.Pump(shell);
    if explorerOverlay.IsVisible() or explorerOverlay.panel.IsVisible()
       or breakpointOverlay.visible == false
       or breakpointOverlay.panel.IsVisible() == false {
        fail(shell, "breakpoint prompt did not replace explorer prompt");
        return;
    }
    overlays.OpenSettings(shell, prefs);
    breakpointOverlay.Pump(shell);
    overlays.Pump(shell);
    if breakpointOverlay.visible or breakpointOverlay.panel.IsVisible()
       or overlays.settingsVisible == false
       or overlays.settingsPanel.IsVisible() == false {
        fail(shell, "Preferences did not replace breakpoint prompt");
        return;
    }
    overlays.CloseSettings();

    // Floating panels and their children share effective UI units. At 200%
    // zoom the backing-scale-only App logical size is twice the usable layout
    // viewport; positioning against it sends otherwise centered forms offscreen.
    shell.app.SetUiScale(2.0);
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    commandOverlay.OpenGoToLine(shell, 24);
    commandOverlay.detailLabel.SetText("Enter a line from the active document.");
    shell.Render();
    if OverlayContainsAction(shell.app, commandOverlay.panel,
                             commandOverlay.applyButton) == false {
        fail(shell, "command input overlay escaped the zoomed viewport");
        return;
    }
    commandOverlay.Cancel();

    explorerOverlay.OpenRename(shell, "/workspace/example/zoomed-name.zia");
    explorerOverlay.Reject(shell, "Choose a different name.");
    shell.Render();
    if OverlayContainsAction(shell.app, explorerOverlay.panel,
                             explorerOverlay.applyButton) == false {
        fail(shell, "explorer action overlay escaped the zoomed viewport");
        return;
    }
    explorerOverlay.Cancel();

    breakpointOverlay.OpenCondition(
        shell, "/workspace/example/main.zia", 42, "index > 3");
    breakpointOverlay.detailLabel.SetText("Condition validation is deferred.");
    shell.Render();
    if OverlayContainsAction(shell.app, breakpointOverlay.panel,
                             breakpointOverlay.applyButton) == false {
        fail(shell, "breakpoint overlay escaped the zoomed viewport");
        return;
    }
    breakpointOverlay.Cancel();
    shell.app.SetUiScale(1.0);
    shell.app.SetWindowSize(1280, 720);
    shell.Poll();

    if search_commands.LineMatches("Alpha beta", "alpha", false, false) == false {
        fail(shell, "case-insensitive search");
        return;
    }
    if search_commands.LineMatches("alphabet", "alpha", false, true) {
        fail(shell, "whole-word search");
        return;
    }
    if search_commands.LineMatchesWithMode("var needle = 42;", "needle = [0-9]+", false, false, true) == false {
        fail(shell, "regex search match");
        return;
    }
    if search_commands.LineMatchesWithMode("var needle = x;", "needle = [0-9]+", false, false, true) {
        fail(shell, "regex search reject");
        return;
    }
    if search_commands.MatchColumnWithMode("abc needle42", "needle[0-9]+", false, true) != 5
       or search_commands.MatchLengthWithMode("abc needle42", "needle[0-9]+", false, true) != 8 {
        fail(shell, "regex search range");
        return;
    }
    if search_commands.LineMatchesWithMode("func main()", "^func [a-z]+\\(\\)$", false, false, true) == false {
        fail(shell, "regex anchors and escapes");
        return;
    }
    if search_commands.QuickOpenScore("src/main.zia", "main.zia") != 1 {
        fail(shell, "quick open exact file");
        return;
    }
    if search_commands.QuickOpenScore("src/main.zia", "mai") != 2 {
        fail(shell, "quick open file prefix");
        return;
    }
    if search_commands.QuickOpenScore("src/main.zia", "src/") != 3 {
        fail(shell, "quick open path prefix");
        return;
    }
    var quickOpenPath = "/tmp/project/src/main.zia";
    var quickOpenId = search_commands.QuickOpenCommandId(quickOpenPath);
    if search_commands.QuickOpenPathFromCommandId(quickOpenId) != quickOpenPath
       or search_commands.QuickOpenPathFromCommandId("build") != "" {
        fail(shell, "quick open palette command id");
        return;
    }
    if search_commands.SearchGlobMatches("src/main.zia", "src/*.zia") == false
       or search_commands.SearchGlobMatches("src/main.zia", "main.*") == false
       or search_commands.SearchGlobMatches("src/main.zia", "test*.zia") {
        fail(shell, "search glob matching");
        return;
    }

    var root = TempFile.CreateDirWithPrefix("zannastudio_search_probe_");
    var i = 0;
    while i < 40 {
        File.WriteAllText(Path.Join(root, "file" + i + ".zia"),
                          "module File" + i + ";\nfunc main() {\n    var needle = " + i + ";\n}\n");
        i = i + 1;
    }
    var symbolPath = Path.Join(root, "symbols.zia");
    File.WriteAllText(symbolPath,
                      "module Symbols;\nfunc alphaSymbol() -> Integer { return 1; }\n");

    var docMgr = new document_manager.DocumentManager();
    var locStore = new locations.LocationStore();

    // An unsaved open buffer is not exempt from the same size ceiling used
    // for disk sources. Otherwise one generated paste can monopolize search.
    var oversizedOpenPath = Path.Join(root, "oversized-open.txt");
    File.WriteAllText(oversizedOpenPath, "small on disk\n");
    var oversizedOpenDoc = docMgr.OpenFile(oversizedOpenPath);
    oversizedOpenDoc.content = Str.Repeat("x", 2000001);
    if search_commands.SearchDiskFileTooLarge(docMgr, oversizedOpenPath) == false {
        fail(shell, "oversized open search buffer was not bounded");
        return;
    }
    oversizedOpenDoc.content = "small on disk\n";

    // File-count slicing is insufficient when each candidate is large. The
    // aggregate source budget must yield before scanning all three in one pump.
    var byteBudgetRoot = TempFile.CreateDirWithPrefix("zannastudio_search_bytes_");
    var budgetSource = "needle\n" + Str.Repeat("x", 700000);
    i = 0;
    while i < 3 {
        File.WriteAllText(Path.Join(byteBudgetRoot, "budget" + i + ".txt"),
                          budgetSource);
        i = i + 1;
    }
    var byteBudgetSearch = new search_commands.SearchController();
    var byteBudgetLocs = new locations.LocationStore();
    if byteBudgetSearch.StartDirect(shell, byteBudgetRoot, "needle", ".txt",
                                    false, false) == false {
        fail(shell, "byte-budget search did not start");
        return;
    }
    byteBudgetSearch.Pump(shell, docMgr, byteBudgetLocs);
    if byteBudgetSearch.active == false
       or byteBudgetSearch.lastPumpFileCount <= 0
       or byteBudgetSearch.lastPumpFileCount >= 3
       or byteBudgetSearch.lastPumpByteCount > 2000000 {
        fail(shell, "search exceeded one-frame aggregate byte budget");
        return;
    }
    while byteBudgetSearch.active {
        byteBudgetSearch.Pump(shell, docMgr, byteBudgetLocs);
        if byteBudgetSearch.lastPumpByteCount > 2000000 {
            fail(shell, "search exceeded later aggregate byte budget");
            return;
        }
    }
    if byteBudgetSearch.resultCount != 3 {
        fail(shell, "byte-budget search lost results");
        return;
    }

    var searcher = new search_commands.SearchController();
    if searcher.StartDirect(shell, root, "needle", ".zia", false, false) == false {
        fail(shell, "start direct search");
        return;
    }
    searcher.Pump(shell, docMgr, locStore);
    if searcher.active == false {
        fail(shell, "search completed in one pump");
        return;
    }
    if searcher.resultCount <= 0 or searcher.resultCount >= 40 {
        fail(shell, "search slice result count");
        return;
    }
    while searcher.active {
        searcher.Pump(shell, docMgr, locStore);
    }
    if searcher.resultCount != 40 {
        fail(shell, "cooperative search final count");
        return;
    }
    if shell.toolPanels.searchListBox.Count != 80 or !shell.toolPanels.searchListBox.IsVisible() {
        fail(shell, "search panel rows");
        return;
    }
    shell.toolPanels.searchListBox.SelectIndex(1);
    var searchRowText = GUI.ListBox.ItemGetText(shell.toolPanels.searchListBox.Selected);
    if Str.IndexOf(searchRowText, "match") == 0
       or Str.IndexOf(searchRowText, "text") == 0
       or Str.IndexOf(searchRowText, "needle") == 0 {
        fail(shell, "search structured row");
        return;
    }
    if search_commands.SearchPathAllowed(root, Path.Join(root, "file11.zia"), "file1*.zia", "file10.zia") == false
       or search_commands.SearchPathAllowed(root, Path.Join(root, "file10.zia"), "file1*.zia", "file10.zia") {
        fail(shell, "search include exclude path filters");
        return;
    }
    var filteredSearcher = new search_commands.SearchController();
    if filteredSearcher.StartDirectWithOptions(shell, root, "needle", ".zia", false, false,
                                               "file1*.zia", "file10.zia") == false {
        fail(shell, "start filtered direct search");
        return;
    }
    while filteredSearcher.active {
        filteredSearcher.Pump(shell, docMgr, locStore);
    }
    if filteredSearcher.resultCount != 10 {
        fail(shell, "filtered direct search count");
        return;
    }
    var regexSearcher = new search_commands.SearchController();
    if regexSearcher.StartDirectWithSearchMode(shell, root, "needle = [1-3][0-9]", ".zia",
                                               false, false, true, "", "") == false {
        fail(shell, "start regex direct search");
        return;
    }
    while regexSearcher.active {
        regexSearcher.Pump(shell, docMgr, locStore);
    }
    if regexSearcher.resultCount != 30 {
        fail(shell, "regex direct search count");
        return;
    }

    var projMgr = new project_manager.ProjectManager();
    projMgr.Setup(shell.workbench.sidebarTree);
    projMgr.OpenFolder(root);

    // Quick Open must rank a warmed large cache over multiple frames instead
    // of allocating one command row per project file on the invoking frame.
    var quickProjMgr = new project_manager.ProjectManager();
    quickProjMgr.Setup(null);
    quickProjMgr.OpenFolder(root);
    quickProjMgr.fileCache = new List();
    quickProjMgr.fileCacheComplete = true;
    quickProjMgr.fileCacheRefreshing = false;
    i = 0;
    while i < 2048 {
        var quickName = "boring_entry_" + i + ".zia";
        if i == 2047 { quickName = "needle_target.zia"; }
        quickProjMgr.fileCache.Push(Path.Join(root, quickName));
        i = i + 1;
    }
    var quickPalette = new command_palette_controller.CommandPaletteController();
    if search_commands.ShowQuickOpenPalette(shell, quickProjMgr) == false {
        fail(shell, "large-cache quick open did not show");
        return;
    }
    quickPalette.BeginQuickOpen();
    shell.commandPalette.SetQuery("needle");
    quick_open_commands.PumpQuickOpenPalette(shell, quickProjMgr, quickPalette);
    if quickPalette.quickOpenLastPumpScanCount <= 0
       or quickPalette.quickOpenLastPumpScanCount > 512
       or quickPalette.quickOpenScanIndex > 512
       or quickPalette.quickOpenScanComplete
       or quickPalette.quickOpenPublishedCount > 100 {
        fail(shell, "quick open exceeded one-frame cache budget");
        return;
    }
    var quickPumps = 1;
    while quickPalette.quickOpenScanComplete == false and quickPumps < 10 {
        quick_open_commands.PumpQuickOpenPalette(shell, quickProjMgr, quickPalette);
        if quickPalette.quickOpenLastPumpScanCount > 512 {
            fail(shell, "quick open exceeded later cache budget");
            return;
        }
        quickPumps = quickPumps + 1;
    }
    if quickPalette.quickOpenScanComplete == false
       or quickPalette.quickOpenResultPaths.count() != 1
       or Obj.ToString(quickPalette.quickOpenResultPaths.get(0))
          != Path.Join(root, "needle_target.zia") {
        fail(shell, "quick open incremental ranking missed late cache result");
        return;
    }

    // A workspace refresh can replace the cache with the same number of files.
    // Query generation and count are therefore insufficient identities: the
    // old result must disappear and scanning must restart at entry zero.
    var quickCacheGeneration = quickProjMgr.FileCacheGeneration();
    quickProjMgr.RefreshTree();
    if quickProjMgr.FileCacheGeneration() == quickCacheGeneration {
        fail(shell, "headless project refresh retained file-cache identity");
        return;
    }
    quickProjMgr.fileCache = new List();
    quickProjMgr.fileCacheComplete = true;
    quickProjMgr.fileCacheRefreshing = false;
    i = 0;
    while i < 2048 {
        var refreshedName = "refreshed_entry_" + i + ".zia";
        if i == 0 { refreshedName = "refreshed_needle_target.zia"; }
        quickProjMgr.fileCache.Push(Path.Join(root, refreshedName));
        i = i + 1;
    }
    quick_open_commands.PumpQuickOpenPalette(shell, quickProjMgr, quickPalette);
    if quickPalette.quickOpenCacheGeneration != quickProjMgr.FileCacheGeneration()
       or quickPalette.quickOpenScanIndex <= 0
       or quickPalette.quickOpenScanIndex > 512
       or quickPalette.quickOpenResultPaths.count() != 1
       or Obj.ToString(quickPalette.quickOpenResultPaths.get(0))
          != Path.Join(root, "refreshed_needle_target.zia") {
        fail(shell, "quick open retained same-size stale cache results");
        return;
    }
    shell.commandPalette.Hide();
    quickPalette.ResetToCommands(shell, chromeRegistry, null);

    var panelSearcher = new search_commands.SearchController();
    panelSearcher.OpenPanel(shell, root, "");
    shell.toolPanels.searchQueryInput.SetText("needle");
    shell.toolPanels.searchKindsInput.SetText(".zia");
    shell.toolPanels.searchIncludeInput.SetText("file1*.zia");
    shell.toolPanels.searchExcludeInput.SetText("file10.zia");
    if !shell.toolPanels.searchPanel.IsVisible() or !shell.toolPanels.searchListBox.IsVisible() {
        fail(shell, "search panel opens docked controls");
        return;
    }
    if panelSearcher.RunPanel(shell, null, docMgr, null) == false {
        fail(shell, "search panel starts direct search");
        return;
    }
    while panelSearcher.active {
        panelSearcher.Pump(shell, docMgr, locStore);
    }
    if panelSearcher.resultCount != 10 {
        fail(shell, "search panel input filters");
        return;
    }
    if panelSearcher.resultLocationFirstId <= 1
       or panelSearcher.resultLocationLastId
          - panelSearcher.resultLocationFirstId + 1 != 10 {
        fail(shell, "search result generation range");
        return;
    }
    docMgr.OpenFile(symbolPath);
    docMgr.GetActive()!.content = "module Symbols;\nfunc betaSymbol() -> Integer { return 2; }\n";
    var symbolCount = search_commands.CollectWorkspaceSymbols(shell, projMgr, docMgr, locStore, "beta");
    if symbolCount != 1 or shell.toolPanels.searchListBox.Count != 2 {
        fail(shell, "workspace symbols use dirty open content");
        return;
    }
    shell.toolPanels.searchListBox.SelectIndex(1);
    if GUI.ListBox.ItemGetData(shell.toolPanels.searchListBox.Selected) == "" {
        fail(shell, "workspace symbols location data");
        return;
    }
    var symbolRowText = GUI.ListBox.ItemGetText(shell.toolPanels.searchListBox.Selected);
    if Str.IndexOf(symbolRowText, "symbol") == 0
       or Str.IndexOf(symbolRowText, "betaSymbol") == 0 {
        fail(shell, "workspace symbols structured row");
        return;
    }
    var uncachedSymbolPath = Path.Join(root, "uncached_symbol.zia");
    File.WriteAllText(uncachedSymbolPath,
                      "module UncachedSymbol;\nfunc uncachedSymbolProbe() -> Integer { return 3; }\n");
    var uncachedCount = search_commands.CollectWorkspaceSymbols(shell, projMgr,
                                                               docMgr, locStore,
                                                               "uncachedSymbolProbe");
    if uncachedCount != 1 {
        fail(shell, "workspace symbols enumerate uncached files");
        return;
    }

    // The user-facing workspace-symbol route must not enumerate and parse the
    // whole project in one UI frame. It shares FileIndex discovery with text
    // search, processes at most four source files per pump, and still prefers
    // the dirty open buffer when that file's turn arrives.
    var asyncSymbolLocs = new locations.LocationStore();
    var asyncSymbols = new search_commands.SearchController();
    if asyncSymbols.StartWorkspaceSymbols(shell, projMgr, docMgr, null, "beta") == false {
        fail(shell, "start cooperative workspace symbols");
        return;
    }
    asyncSymbols.Pump(shell, docMgr, asyncSymbolLocs);
    if asyncSymbols.active == false
       or asyncSymbols.lastPumpFileCount <= 0
       or asyncSymbols.lastPumpFileCount > 4
       or asyncSymbols.fileIndex > 4 {
        fail(shell, "workspace symbols exceeded one-frame file budget");
        return;
    }
    var symbolPumps = 1;
    while asyncSymbols.active and symbolPumps < 1000 {
        asyncSymbols.Pump(shell, docMgr, asyncSymbolLocs);
        if asyncSymbols.lastPumpFileCount > 4 {
            fail(shell, "workspace symbols exceeded later frame budget");
            return;
        }
        symbolPumps = symbolPumps + 1;
    }
    if asyncSymbols.active or asyncSymbols.resultCount != 1
       or asyncSymbolLocs.items.count() != 1 {
        fail(shell, "cooperative workspace symbols lost dirty-buffer result");
        return;
    }
    var cachedSearcher = new search_commands.SearchController();
    if cachedSearcher.StartCachedDirect(shell, projMgr, root, "needle", ".zia", false, false) == false {
        fail(shell, "start cached search");
        return;
    }
    while cachedSearcher.active {
        cachedSearcher.Pump(shell, docMgr, locStore);
    }
    if cachedSearcher.resultCount != 40 {
        fail(shell, "cached search final count");
        return;
    }
    var filteredCachedSearcher = new search_commands.SearchController();
    if filteredCachedSearcher.StartCachedDirectWithOptions(shell, projMgr, root, "needle", ".zia", false, false,
                                                           "file1*.zia", "file10.zia") == false {
        fail(shell, "start filtered cached search");
        return;
    }
    while filteredCachedSearcher.active {
        filteredCachedSearcher.Pump(shell, docMgr, locStore);
    }
    if filteredCachedSearcher.resultCount != 10 {
        fail(shell, "filtered cached search count");
        return;
    }
    var regexCachedSearcher = new search_commands.SearchController();
    if regexCachedSearcher.StartCachedDirectWithSearchMode(shell, projMgr, root, "needle = [12][0-9]", ".zia",
                                                           false, false, true, "", "") == false {
        fail(shell, "start regex cached search");
        return;
    }
    while regexCachedSearcher.active {
        regexCachedSearcher.Pump(shell, docMgr, locStore);
    }
    if regexCachedSearcher.resultCount != 20 {
        fail(shell, "regex cached search count");
        return;
    }
    shell.toolPanels.SetDebugOutput("debug one\ndebug two\n");
    if shell.toolPanels.debugListBox.Count != 2 or !shell.toolPanels.debugListBox.IsVisible() {
        fail(shell, "debug console rows");
        return;
    }
    shell.toolPanels.AddToolPlainRow(shell.toolPanels.referencesListBox, "main.zia", 0);
    shell.toolPanels.ShowReferencesPanel();
    if !shell.toolPanels.referencesListBox.IsVisible() or shell.toolPanels.toolTabBar.GetActiveIndex() != 3 {
        fail(shell, "references panel rows");
        return;
    }

    // Opening a diff shows a loading row immediately; worker completion and
    // widget creation are both pumped later in batches of at most 100 rows.
    var asyncDiff = new diff_view.DiffView();
    asyncDiff.Setup(shell);
    var diffLeft = new Zanna.Text.StringBuilder();
    var diffRight = new Zanna.Text.StringBuilder();
    i = 0;
    while i < 250 {
        if i > 0 {
            diffLeft.Append("\n");
            diffRight.Append("\n");
        }
        diffLeft.Append("before-" + i);
        diffRight.Append("after-" + i);
        i = i + 1;
    }
    shell.app.SetWindowSize(620, 460);
    shell.Poll();
    overlays.OpenAbout(shell);
    asyncDiff.Open(
        "/a/long/workspace/path/whose/title/must/not/collide/with/the/close/action/sample.zia",
        diffLeft.ToString(),
        diffRight.ToString());
    overlays.Pump(shell);
    if overlays.aboutVisible or overlays.aboutPanel.IsVisible()
       or asyncDiff.visible == false or asyncDiff.panel.IsVisible() == false {
        asyncDiff.Shutdown();
        fail(shell, "diff did not replace About");
        return;
    }
    shell.Render();
    var diffPanelRight = asyncDiff.panel.GetScreenX()
        + asyncDiff.panel.GetScreenWidth();
    var diffPanelBottom = asyncDiff.panel.GetScreenY()
        + asyncDiff.panel.GetScreenHeight();
    if asyncDiff.panel.GetScreenX() < 0.0
       or asyncDiff.panel.GetScreenY() < 0.0
       or diffPanelRight > UiViewportWidth(shell.app) + 1.0
       or diffPanelBottom > UiViewportHeight(shell.app) + 1.0
       or asyncDiff.closeButton.GetScreenX()
              + asyncDiff.closeButton.GetScreenWidth() > diffPanelRight
       or asyncDiff.closeButton.GetScreenY()
              + asyncDiff.closeButton.GetScreenHeight() > diffPanelBottom {
        asyncDiff.Shutdown();
        fail(shell, "diff overlay escaped the compact viewport");
        return;
    }
    if asyncDiff.rowsList.Count != 1 or asyncDiff.IsBusy() == false {
        asyncDiff.Shutdown();
        fail(shell, "diff open blocked instead of showing pending state");
        return;
    }

    shell.app.SetUiScale(2.0);
    shell.app.SetWindowSize(720, 520);
    shell.Poll();
    asyncDiff.Pump();
    shell.Render();
    if OverlayContainsAction(shell.app, asyncDiff.panel,
                             asyncDiff.closeButton) == false {
        asyncDiff.Shutdown();
        fail(shell, "diff overlay escaped the zoomed viewport");
        return;
    }
    shell.app.SetUiScale(1.0);
    shell.app.SetWindowSize(620, 460);
    shell.Poll();
    asyncDiff.Pump();
    shell.Render();
    var diffPumps = 0;
    while asyncDiff.IsBusy() and diffPumps < 5000 {
        asyncDiff.Pump();
        if asyncDiff.lastPumpRenderCount > 100 {
            asyncDiff.Shutdown();
            fail(shell, "diff renderer exceeded one-frame row budget");
            return;
        }
        Clock.Sleep(1);
        diffPumps = diffPumps + 1;
    }
    if asyncDiff.IsBusy() or asyncDiff.rowsList.Count != 250 {
        asyncDiff.Shutdown();
        fail(shell, "async diff did not finish bounded rendering");
        return;
    }
    asyncDiff.Close();
    if asyncDiff.Shutdown() == false {
        fail(shell, "diff worker did not drain at shutdown");
        return;
    }

    if searcher.StartDirect(shell, root, "needle", ".zia", false, false) == false {
        fail(shell, "restart direct search");
        return;
    }
    searcher.Cancel(shell);
    if searcher.active {
        fail(shell, "cancel search");
        return;
    }

    shell.Destroy();
    Terminal.Say("RESULT: ok");
    Env.Exit(0);
}
