//
// File: zannastudio/src/probes/scm_probe.zia
// Purpose: Exercise the Source Control Git command and status parser layer.
// Key invariants:
//   - Real paths, spaces, renames, and porcelain-v2 conflicts round-trip.
//   - Async jobs report the same structured status as blocking operations.
// Ownership/Lifetime: The probe owns one temporary repository and Git wrapper.
// Links: zannastudio/src/scm/scm_git.zia
//
//===----------------------------------------------------------------------===//

module scm_probe;

// ============================================================================
// MODULE: scm_probe
// PURPOSE: Headless probe for the lightweight Git command layer.
//
// WHERE-THIS-FITS: scm_git.zia wraps blocking Git commands while scm_view.zia
//          owns UI state. This probe covers command-layer behavior in a temporary
//          repository without constructing the Source Control view.
//
// TEACHING-NOTE: Source-control probes must use real Git paths because quoting,
//          status parsing, staging, and commits are external-process contracts.
// ============================================================================

bind "../scm/scm_git";

bind Terminal = Zanna.Terminal;
bind Exec = Zanna.System.Exec;
bind Seq = Zanna.Collections.Seq;
bind File = Zanna.IO.File;
bind Path = Zanna.IO.Path;
bind TempFile = Zanna.IO.TempFile;
bind Str = Zanna.String;
bind Time = Zanna.Time;

func pumpJob(job: scm_git.GitJob, budgetMs: Integer) -> Boolean {
    var waited = 0;
    while job.running and waited < budgetMs {
        job.Pump();
        if job.running {
            Time.Clock.Sleep(5);
            waited = waited + 5;
        }
    }
    job.Pump();
    return job.started and job.running == false;
}

func gitConfig(dir: String, key: String, val: String) {
    var a = Seq.New();
    Seq.Push(a, "-C");
    Seq.Push(a, dir);
    Seq.Push(a, "config");
    Seq.Push(a, key);
    Seq.Push(a, val);
    Exec.CaptureArgs("git", a);
}

func entryUntracked(st: scm_git.GitStatus, name: String) -> Boolean {
    var i = 0;
    while i < st.entries.count() {
        var e = st.entries.get(i);
        if Str.EndsWith(e.path, name) and e.untracked { return true; }
        i = i + 1;
    }
    return false;
}

func entryStaged(st: scm_git.GitStatus, name: String) -> Boolean {
    var i = 0;
    while i < st.entries.count() {
        var e = st.entries.get(i);
        if Str.EndsWith(e.path, name) and e.staged { return true; }
        i = i + 1;
    }
    return false;
}

func entryRenamed(st: scm_git.GitStatus, newName: String, oldName: String) -> Boolean {
    var i = 0;
    while i < st.entries.count() {
        var e = st.entries.get(i);
        if e.renamed and Str.EndsWith(e.path, newName) and Str.EndsWith(e.oldPath, oldName) {
            return true;
        }
        i = i + 1;
    }
    return false;
}

func entryConflicted(st: scm_git.GitStatus, name: String) -> Boolean {
    var i = 0;
    while i < st.entries.count() {
        var e = st.entries.get(i);
        if Str.EndsWith(e.path, name) and e.conflicted { return true; }
        i = i + 1;
    }
    return false;
}

func main() {
    var dir = TempFile.CreateDirWithPrefix("zannastudio_scm_");

    // Skip cleanly when git is unavailable. RunArgs returns the real exit code
    // (Exec.LastExitCode() is unreliable for the Args-style calls).
    var verArgs = Seq.New();
    Seq.Push(verArgs, "--version");
    if Exec.RunArgs("git", verArgs) != 0 {
        Terminal.Say("RESULT: ok (git unavailable, skipped)");
        return;
    }
    // git init
    var initArgs = Seq.New();
    Seq.Push(initArgs, "-C");
    Seq.Push(initArgs, dir);
    Seq.Push(initArgs, "init");
    if Exec.RunArgs("git", initArgs) != 0 {
        Terminal.Say("RESULT: fail git init");
        return;
    }
    gitConfig(dir, "user.email", "probe@example.com");
    gitConfig(dir, "user.name", "Probe");
    gitConfig(dir, "commit.gpgsign", "false");

    var git = new scm_git.Git();
    git.SetRepo(dir);

    if git.IsRepo() == false { Terminal.Say("RESULT: fail not a repo after init"); return; }

    // A new file shows as untracked.
    File.WriteAllText(Path.Join(dir, "hello.zia"), "module Hello;\n");
    var st1 = git.Status();
    if st1.isRepo == false { Terminal.Say("RESULT: fail status reports not-a-repo"); return; }
    if entryUntracked(st1, "hello.zia") == false { Terminal.Say("RESULT: fail hello.zia not untracked"); return; }

    // Staging moves it to the index.
    if git.Stage("hello.zia") == false { Terminal.Say("RESULT: fail git add"); return; }
    var st2 = git.Status();
    if entryStaged(st2, "hello.zia") == false { Terminal.Say("RESULT: fail hello.zia not staged after add"); return; }

    // Commit clears the working tree.
    if git.Commit("initial commit") == false { Terminal.Say("RESULT: fail git commit"); return; }
    var st3 = git.Status();
    if st3.entries.count() != 0 { Terminal.Say("RESULT: fail status not clean after commit"); return; }

    // Branch query returns something (master/main).
    if Str.get_Length(git.CurrentBranch()) == 0 { Terminal.Say("RESULT: fail empty branch name"); return; }

    // Paths with spaces must round-trip through process arguments and porcelain-v2 parsing.
    File.WriteAllText(Path.Join(dir, "space name.zia"), "module Spaced;\n");
    var st4 = git.Status();
    if entryUntracked(st4, "space name.zia") == false { Terminal.Say("RESULT: fail spaced file not untracked"); return; }
    if git.Stage("space name.zia") == false { Terminal.Say("RESULT: fail git add spaced file"); return; }
    var st5 = git.Status();
    if entryStaged(st5, "space name.zia") == false { Terminal.Say("RESULT: fail spaced file not staged"); return; }
    if git.Commit("add spaced file") == false { Terminal.Say("RESULT: fail commit spaced file"); return; }

    File.Move(Path.Join(dir, "space name.zia"), Path.Join(dir, "renamed space.zia"));
    if git.StageAll() == false { Terminal.Say("RESULT: fail stage rename"); return; }
    var st6 = git.Status();
    if entryRenamed(st6, "renamed space.zia", "space name.zia") == false {
        Terminal.Say("RESULT: fail staged rename not parsed");
        return;
    }
    if git.Commit("rename spaced file") == false { Terminal.Say("RESULT: fail commit rename"); return; }

    var conflictText = "# branch.head main\n";
    conflictText = conflictText
        + "u UU N... 100644 100644 100644 100644 "
        + "1111111111111111111111111111111111111111 "
        + "2222222222222222222222222222222222222222 "
        + "3333333333333333333333333333333333333333 conflict file.zia\n";
    var conflictStatus = git.StatusFromOutput(conflictText, "", 0);
    if entryConflicted(conflictStatus, "conflict file.zia") == false {
        Terminal.Say("RESULT: fail unmerged conflict row not parsed");
        return;
    }

    var asyncJob = git.StartStatus();
    if pumpJob(asyncJob, 8000) == false {
        Terminal.Say("RESULT: fail async status did not finish");
        return;
    }
    var asyncStatus = git.StatusFromOutput(asyncJob.stdoutText, asyncJob.stderrText, asyncJob.exitCode);
    if asyncStatus.isRepo == false or asyncStatus.entries.count() != 0 {
        Terminal.Say("RESULT: fail async clean status");
        return;
    }

    Terminal.Say("RESULT: ok");
}
