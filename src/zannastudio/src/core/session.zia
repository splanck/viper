//===----------------------------------------------------------------------===//
//
// File: zannastudio/src/core/session.zia
// Purpose: Persist and conservatively restore Studio workspace, document,
//          recovery, and recent-file state.
// Key invariants:
//   - Only editable documents and bounded dirty drafts survive a session.
//   - Invalid persisted paths are removed before they can pollute startup UI.
//   - Startup can restore workspace roots and tabs in caller-budgeted batches.
//   - Writers retain at most the restore limits and cap aggregate embedded
//     recovery text, prioritizing the active document when truncation is needed.
//   - Scene view state is fixed-point, versioned, and bounded before it reaches
//     a live canvas, hierarchy, split pane, or camera.
//   - Structured split panes map through validated durable slots; a rejected
//     pane owner never falls back to an unrelated open document.
//   - Visual surfaces and read-only previews never become split-pane owners.
// Ownership/Lifetime:
//   - SessionManager owns only its settings path and borrows live IDE models.
// Links: zannastudio/src/core/document_manager.zia,
//        zannastudio/src/core/settings.zia
//
//===----------------------------------------------------------------------===//

module session;

bind "document_manager";
bind "project_manager";
bind "document";
bind "../editor/editor_tabs";
bind "../services/file_utils";
bind "../services/safe_io";

bind Ini = Zanna.Data.Ini;
bind Codec = Zanna.Text.Codec;
bind IO = Zanna.IO;
bind Dir = Zanna.IO.Dir;
bind Path = Zanna.IO.Path;
bind Parse = Zanna.Core.Parse;
bind Convert = Zanna.Core.Convert;
bind Seq = Zanna.Collections.Seq;
bind Map = Zanna.Collections.Map;
bind Obj = Zanna.Core.Object;
bind Str = Zanna.String;

// ============================================================================
// MODULE: session
// PURPOSE: Persist and restore Zanna Studio workspace session state.
//
// WHERE-THIS-FITS: Settings chooses the INI path; DocumentManager, ProjectManager,
//          and EditorTabs own live state. SessionManager translates between those
//          models and durable `[session]`, `[recent]`, and recovery sections.
//
// TEACHING-NOTE: Session restore must be conservative because it runs at startup
//          and protects user work. Keep recovery text bounded, keep unknown INI
//          keys intact, and prefer explicit per-document fields over display text.
// ============================================================================

final MAX_RECENT_PROJECTS = 10;
final MAX_RECENT_FILES = 20;
final MAX_SESSION_WORKSPACE_ROOTS = 64;
final MAX_SESSION_FILES = 256;
final MAX_SESSION_RECOVERY_CHARS = 200000;
final MAX_SESSION_RECOVERY_ENCODED_CHARS = 300000;
final MAX_SESSION_RECOVERY_TOTAL_CHARS = 4000000;
final MAX_SESSION_STALE_SECTIONS = 4096;
final SCENE_WORKSPACE_STATE_VERSION = 1;
final MAX_SCENE_WORKSPACE_SCROLL = 1000000;
final MAX_SCENE_WORKSPACE_TARGET_MILLIS = 1000000000;

/// @brief Return whether a durable document may own a CodeEditor split pane.
hide func IsSplitDocumentEligible(doc: document.Document) -> Boolean {
    return doc != null and doc.isReadOnlyPreview == false
           and file_utils.IsVisualKind(doc.kind) == false;
}

/// @brief Resumable state for one bounded session-restore pass.
/// @details The parsed INI and borrowed live models remain valid until the job
///          completes or is canceled. No background thread touches GUI models;
///          main advances the job between event polls and renders.
class SessionRestoreJob {
    expose Any ini;
    expose document_manager.DocumentManager docMgr;
    expose project_manager.ProjectManager projMgr;
    expose editor_tabs.EditorTabs tabs;
    expose Boolean active;
    expose Boolean indexedWorkspaceRoots;
    expose Boolean restoredWorkspaceRoot;
    expose Boolean legacyRootProcessed;
    expose Integer workspaceRootCount;
    expose Integer workspaceRootIndex;
    expose String legacyProjectRoot;
    expose Integer fileCount;
    expose Integer fileIndex;
    expose String activePath;
    expose Boolean structuredSplitRequested;
    expose Integer splitFirstIndex;
    expose Integer splitSecondIndex;
    expose Boolean splitSecondFocused;
    expose document.Document splitFirstDocument;
    expose document.Document splitSecondDocument;
    expose Integer restoredCount;
    expose Boolean prunedSession;
    expose Integer totalWork;
    expose Integer completedWork;
    expose Integer lastPumpCount;

    expose func init() {
        ini = null;
        docMgr = null;
        projMgr = null;
        tabs = null;
        active = false;
        indexedWorkspaceRoots = false;
        restoredWorkspaceRoot = false;
        legacyRootProcessed = true;
        workspaceRootCount = 0;
        workspaceRootIndex = 0;
        legacyProjectRoot = "";
        fileCount = 0;
        fileIndex = 0;
        activePath = "";
        structuredSplitRequested = false;
        splitFirstIndex = -1;
        splitSecondIndex = -1;
        splitSecondFocused = false;
        splitFirstDocument = null;
        splitSecondDocument = null;
        restoredCount = 0;
        prunedSession = false;
        totalWork = 0;
        completedWork = 0;
        lastPumpCount = 0;
    }
}

class SessionManager {
    expose String settingsPath;
    expose Boolean splitActive;
    expose Boolean splitSecondFocused;
    hide document.Document capturedSplitFirstDocument;
    hide document.Document capturedSplitSecondDocument;
    hide document.Document restoredSplitFirstDocument;
    hide document.Document restoredSplitSecondDocument;

    expose func init() {
        splitActive = false;
        splitSecondFocused = false;
        capturedSplitFirstDocument = null;
        capturedSplitSecondDocument = null;
        restoredSplitFirstDocument = null;
        restoredSplitSecondDocument = null;
        settingsPath = "";
    }

    expose func Setup(path: String) {
        settingsPath = path;
        PruneRecentProjectHistory();
        PruneRecentFileHistory();
    }

    /// @brief Capture the physical editor-pane owners immediately before Save.
    /// @details SessionManager borrows the two Documents only until the next
    ///          Save call. The writer translates object identity to bounded
    ///          durable session slots, so filtered tabs cannot shift the mapping.
    expose func CaptureSplitState(first: document.Document,
                                  second: document.Document,
                                  secondFocused: Boolean) {
        capturedSplitFirstDocument = first;
        capturedSplitSecondDocument = second;
        splitActive = IsSplitDocumentEligible(first)
            and IsSplitDocumentEligible(second) and first != second;
        if splitActive == false {
            capturedSplitFirstDocument = null;
            capturedSplitSecondDocument = null;
        }
        splitSecondFocused = splitActive and secondFocused;
    }

    /// @brief Clear any borrowed pane owners for a single-pane shutdown.
    expose func ClearSplitState() {
        capturedSplitFirstDocument = null;
        capturedSplitSecondDocument = null;
        splitActive = false;
        splitSecondFocused = false;
    }

    /// @brief Restored owner of the physical primary (left) pane, if durable.
    expose func RestoredSplitFirstDocument() -> document.Document? {
        return restoredSplitFirstDocument;
    }

    /// @brief Restored owner of the physical secondary (right) pane, if durable.
    expose func RestoredSplitSecondDocument() -> document.Document? {
        return restoredSplitSecondDocument;
    }

    /// @brief Persist live session state, including bounded dirty-buffer recovery.
    /// @details This form is safe while the application is running or after an
    ///          unclean termination snapshot. Clean shutdown must use
    ///          `SaveCleanExit` so an explicit Discard decision cannot reappear
    ///          as recovered text on the next launch.
    expose func Save(docMgr: document_manager.DocumentManager,
                     projMgr: project_manager.ProjectManager) -> Boolean {
        return SaveInternal(docMgr, projMgr, true);
    }

    /// @brief Persist tabs and workspace state without unsaved buffer payloads.
    /// @details A confirmed clean exit has already resolved dirty documents via
    ///          Save or Discard. Named tabs remain restorable from disk, while
    ///          dirty untitled drafts and stale recovery fields are removed.
    expose func SaveCleanExit(docMgr: document_manager.DocumentManager,
                              projMgr: project_manager.ProjectManager) -> Boolean {
        return SaveInternal(docMgr, projMgr, false);
    }

    /// @brief Shared bounded session writer.
    /// @param persistRecovery True for crash-tolerant snapshots; false for a
    ///        confirmed clean exit whose discarded buffers must stay discarded.
    hide func SaveInternal(docMgr: document_manager.DocumentManager,
                           projMgr: project_manager.ProjectManager,
                           persistRecovery: Boolean) -> Boolean {
        if settingsPath == "" or docMgr == null { return false; }
        if safe_io.MakeAll(Path.Directory(settingsPath)) == false { return false; }

        var content = "";
        if IO.File.Exists(settingsPath) {
            var readResult = safe_io.ReadStudioState(settingsPath);
            if readResult.ok == false { return false; }
            content = readResult.text;
        }
        var ini = Ini.Parse(content);

        var previousCount = Parse.IntOr(Ini.Get(ini, "session", "count"), 0);
        if previousCount < 0 { previousCount = 0; }
        if previousCount > MAX_SESSION_STALE_SECTIONS {
            previousCount = MAX_SESSION_STALE_SECTIONS;
        }

        var previousWorkspaceRootCount = Parse.IntOr(
            Ini.Get(ini, "session", "workspaceRootCount"), 0);
        if previousWorkspaceRootCount < 0 { previousWorkspaceRootCount = 0; }
        if previousWorkspaceRootCount > MAX_SESSION_WORKSPACE_ROOTS {
            previousWorkspaceRootCount = MAX_SESSION_WORKSPACE_ROOTS;
        }
        var workspaceRootCount = 0;
        if projMgr != null {
            var rootIndex = 0;
            while rootIndex < projMgr.RootCount()
                  and workspaceRootCount < MAX_SESSION_WORKSPACE_ROOTS {
                var workspaceRoot = projMgr.RootPathAt(rootIndex);
                if workspaceRoot != "" {
                    Ini.Set(ini, "session", "workspaceRoot." + workspaceRootCount,
                            workspaceRoot);
                    workspaceRootCount = workspaceRootCount + 1;
                }
                rootIndex = rootIndex + 1;
            }
        }
        var staleRootIndex = workspaceRootCount;
        while staleRootIndex < previousWorkspaceRootCount {
            Ini.Remove(ini, "session", "workspaceRoot." + staleRootIndex);
            staleRootIndex = staleRootIndex + 1;
        }
        Ini.Set(ini, "session", "workspaceRootCount", "" + workspaceRootCount);

        // Keep the legacy scalar for backward compatibility with older Studio
        // builds while the indexed root list preserves complete multi-root state.
        var projectRoot = "";
        if workspaceRootCount > 0 {
            projectRoot = Ini.Get(ini, "session", "workspaceRoot.0");
        }
        var activePath = "";
        var active = docMgr.GetActive();
        var persistedActiveIndex = -1;
        var activeEligible = false;
        var activeRecoveryReserve = 0;
        if active != null {
            activeEligible = ShouldPersistDocument(active!, persistRecovery);
            if persistRecovery and ShouldPersistRecovery(active!) {
                activeRecoveryReserve = Str.get_Length(active!.content);
            }
        }
        var activeWritten = false;
        var recoveryCharsWritten = 0;
        var structuredSplitRequested = splitActive
            and capturedSplitFirstDocument != null
            and capturedSplitSecondDocument != null
            and capturedSplitFirstDocument != capturedSplitSecondDocument
            and docMgr.IndexOfDocument(capturedSplitFirstDocument) >= 0
            and docMgr.IndexOfDocument(capturedSplitSecondDocument) >= 0;
        var splitFirstEligible = structuredSplitRequested
            and ShouldPersistDocument(capturedSplitFirstDocument, persistRecovery);
        var splitSecondEligible = structuredSplitRequested
            and ShouldPersistDocument(capturedSplitSecondDocument, persistRecovery);
        var splitFirstWritten = false;
        var splitSecondWritten = false;
        var splitFirstWrittenIndex = -1;
        var splitSecondWrittenIndex = -1;
        Ini.Set(ini, "session", "projectRoot", projectRoot);

        var i = 0;
        var written = 0;
        while i < docMgr.GetCount() and written < MAX_SESSION_FILES {
            var doc = docMgr.documents.get(i);
            var shouldWrite = ShouldPersistDocument(doc, persistRecovery);

            // Reserve the final durable slots for the active tab and both split
            // pane owners. Filtering an earlier preview must not shift or evict
            // the user's visible editor arrangement at the 256-tab boundary.
            var reservedPrioritySlots = 0;
            if activeEligible and activeWritten == false and doc != active {
                reservedPrioritySlots = reservedPrioritySlots + 1;
            }
            if splitFirstEligible and splitFirstWritten == false
               and doc != capturedSplitFirstDocument
               and capturedSplitFirstDocument != active {
                reservedPrioritySlots = reservedPrioritySlots + 1;
            }
            if splitSecondEligible and splitSecondWritten == false
               and doc != capturedSplitSecondDocument
               and capturedSplitSecondDocument != active {
                reservedPrioritySlots = reservedPrioritySlots + 1;
            }
            if shouldWrite
               and written >= MAX_SESSION_FILES - reservedPrioritySlots {
                shouldWrite = false;
            }

            var writeRecovery = false;
            var recoveryChars = 0;
            if shouldWrite and persistRecovery and ShouldPersistRecovery(doc) {
                recoveryChars = Str.get_Length(doc.content);
                var remainingRecovery = MAX_SESSION_RECOVERY_TOTAL_CHARS
                    - recoveryCharsWritten;
                if activeEligible and activeWritten == false and doc != active {
                    remainingRecovery = remainingRecovery - activeRecoveryReserve;
                }
                writeRecovery = recoveryChars <= remainingRecovery;
                // Untitled tabs have no durable origin to reopen. If their
                // recovery payload does not fit, omit the whole tab instead of
                // writing an empty, unrecoverable session record.
                if writeRecovery == false and doc.filePath == "" {
                    shouldWrite = false;
                }
            }

            if shouldWrite {
                var section = "session.file." + written;
                Ini.Set(ini, section, "path", doc.filePath);
                Ini.Set(ini, section, "name", doc.fileName);
                Ini.Set(ini, section, "kind", file_utils.KindName(doc.kind));
                Ini.Set(ini, section, "cursorLine", "" + doc.cursorLine);
                Ini.Set(ini, section, "cursorCol", "" + doc.cursorCol);
                Ini.Set(ini, section, "scrollLine", "" + doc.scrollLine);
                WriteSceneWorkspaceState(ini, section, doc);
                if writeRecovery {
                    Ini.Set(ini, section, "recovery", EncodeRecoveryText(doc.content));
                    Ini.Set(ini, section, "recoveryEncoding", "base64");
                    Ini.Set(ini, section, "recoveryModified", "1");
                    recoveryCharsWritten = recoveryCharsWritten + recoveryChars;
                } else {
                    Ini.Set(ini, section, "recovery", "");
                    Ini.Set(ini, section, "recoveryEncoding", "");
                    Ini.Set(ini, section, "recoveryModified", "0");
                }
                if active != null and doc == active {
                    persistedActiveIndex = written;
                    activePath = doc.filePath;
                    activeWritten = true;
                }
                if structuredSplitRequested and doc == capturedSplitFirstDocument {
                    splitFirstWritten = true;
                    splitFirstWrittenIndex = written;
                }
                if structuredSplitRequested and doc == capturedSplitSecondDocument {
                    splitSecondWritten = true;
                    splitSecondWrittenIndex = written;
                }
                written = written + 1;
            }
            i = i + 1;
        }
        if persistedActiveIndex < 0 and written > 0 { persistedActiveIndex = 0; }

        var structuredSplitPersisted = structuredSplitRequested
            and splitFirstWritten and splitSecondWritten
            and splitFirstWrittenIndex != splitSecondWrittenIndex;
        // Preserve boolean-only sessions written by older callers, but never
        // degrade a failed structured capture into an arbitrary companion tab.
        var legacySplitPersisted = splitActive
            and capturedSplitFirstDocument == null
            and capturedSplitSecondDocument == null;
        var splitPersisted = structuredSplitPersisted or legacySplitPersisted;
        var splitFlag = "0";
        if splitPersisted { splitFlag = "1"; }
        Ini.Set(ini, "session", "splitActive", splitFlag);
        if structuredSplitPersisted {
            Ini.Set(ini, "session", "splitFirstIndex", "" + splitFirstWrittenIndex);
            Ini.Set(ini, "session", "splitSecondIndex", "" + splitSecondWrittenIndex);
            var splitFocus = "0";
            if splitSecondFocused { splitFocus = "1"; }
            Ini.Set(ini, "session", "splitSecondFocused", splitFocus);
        } else {
            Ini.Remove(ini, "session", "splitFirstIndex");
            Ini.Remove(ini, "session", "splitSecondIndex");
            Ini.Remove(ini, "session", "splitSecondFocused");
        }
        splitActive = splitPersisted;
        if splitActive == false { splitSecondFocused = false; }
        Ini.Set(ini, "session", "count", "" + written);
        Ini.Set(ini, "session", "activePath", activePath);
        Ini.Set(ini, "session", "activeIndex", "" + persistedActiveIndex);

        // A shorter clean session must not leave discarded text in unused INI
        // slots. Restore obeys `count`, but clearing the stale fields also keeps
        // sensitive untitled content out of the settings file itself.
        var staleIndex = written;
        while staleIndex < previousCount {
            Map.Remove(ini, "session.file." + staleIndex);
            staleIndex = staleIndex + 1;
        }

        SaveRecentProjects(ini, projMgr);
        SaveRecentFiles(ini, docMgr);

        return safe_io.WriteStudioState(settingsPath, Ini.Format(ini));
    }

    expose func RecordRecentFile(path: String) -> Boolean {
        if settingsPath == "" or !document_manager.IsEditableTextFile(path) { return false; }
        if safe_io.MakeAll(Path.Directory(settingsPath)) == false { return false; }

        var content = "";
        if IO.File.Exists(settingsPath) {
            var readResult = safe_io.ReadStudioState(settingsPath);
            if readResult.ok == false { return false; }
            content = readResult.text;
        }
        var ini = Ini.Parse(content);
        PrependRecentFile(ini, path);
        return safe_io.WriteStudioState(settingsPath, Ini.Format(ini));
    }

    /// @brief Put one valid workspace folder at the front of recent history.
    /// @param path Existing directory opened as a workspace root.
    /// @return True when the updated settings were persisted.
    expose func RecordRecentProject(path: String) -> Boolean {
        var canonicalPath = CanonicalRecentPath(path);
        if settingsPath == "" or canonicalPath == ""
           or Dir.Exists(canonicalPath) == false {
            return false;
        }
        if safe_io.MakeAll(Path.Directory(settingsPath)) == false { return false; }

        var content = "";
        if IO.File.Exists(settingsPath) {
            var readResult = safe_io.ReadStudioState(settingsPath);
            if readResult.ok == false { return false; }
            content = readResult.text;
        }
        var ini = Ini.Parse(content);
        PrependRecentProject(ini, canonicalPath);
        return safe_io.WriteStudioState(settingsPath, Ini.Format(ini));
    }

    /// @brief Remove missing and duplicate workspace folders from recent history.
    expose func PruneRecentProjects() {
        PruneRecentProjectHistory();
    }

    /// @brief Return the number of valid recent workspace folders.
    expose func RecentProjectCount() -> Integer {
        if settingsPath == "" or IO.File.Exists(settingsPath) == false { return 0; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return 0; }
        var ini = Ini.Parse(readResult.text);
        var count = Parse.IntOr(Ini.Get(ini, "recent", "count"), 0);
        if count < 0 { return 0; }
        if count > MAX_RECENT_PROJECTS { return MAX_RECENT_PROJECTS; }
        return count;
    }

    /// @brief Return one valid recent workspace folder by index.
    expose func RecentProjectAt(index: Integer) -> String {
        if index < 0 { return ""; }
        if settingsPath == "" or IO.File.Exists(settingsPath) == false { return ""; }
        if index >= RecentProjectCount() { return ""; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return ""; }
        var ini = Ini.Parse(readResult.text);
        var path = CanonicalRecentPath(Ini.Get(ini, "recent", "path." + index));
        if path == "" or Dir.Exists(path) == false { return ""; }
        return path;
    }

    /// @brief Remove missing, duplicate, and unsupported paths from recent files.
    /// @details Open commands call this after a cached path fails validation so
    ///          the same dead entry does not keep appearing for the rest of the
    ///          session. Setup also performs this repair on application launch.
    expose func PruneRecentFiles() {
        PruneRecentFileHistory();
    }

    expose func RecentFileCount() -> Integer {
        if settingsPath == "" or IO.File.Exists(settingsPath) == false { return 0; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return 0; }
        var ini = Ini.Parse(readResult.text);
        var count = Parse.IntOr(Ini.Get(ini, "recentFiles", "count"), 0);
        if count < 0 { return 0; }
        if count > MAX_RECENT_FILES { return MAX_RECENT_FILES; }
        return count;
    }

    expose func RecentFileAt(index: Integer) -> String {
        if index < 0 { return ""; }
        if settingsPath == "" or IO.File.Exists(settingsPath) == false { return ""; }
        if index >= RecentFileCount() { return ""; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return ""; }
        var ini = Ini.Parse(readResult.text);
        var path = Ini.Get(ini, "recentFiles", "path." + index);
        if !document_manager.IsEditableTextFile(path) { return ""; }
        return path;
    }

    /// @brief Restore a complete session through the compatibility blocking API.
    /// @details Main uses BeginRestore/PumpRestore so the native window can poll
    ///          and repaint between batches. Tests and non-UI callers retain the
    ///          original all-at-once result through this wrapper.
    expose func Restore(docMgr: document_manager.DocumentManager,
                        projMgr: project_manager.ProjectManager,
                        tabs: editor_tabs.EditorTabs) -> Integer {
        var job = BeginRestore(docMgr, projMgr, tabs);
        while job.active {
            PumpRestore(job, 64);
        }
        return job.restoredCount;
    }

    /// @brief Parse durable session state without opening roots or documents yet.
    /// @param docMgr Destination document model.
    /// @param projMgr Destination workspace model, or null to skip workspace roots.
    /// @param tabs Optional visual tab controller.
    /// @return A resumable job; inactive means there was nothing safe to restore.
    expose func BeginRestore(docMgr: document_manager.DocumentManager,
                             projMgr: project_manager.ProjectManager,
                             tabs: editor_tabs.EditorTabs) -> SessionRestoreJob {
        var job = new SessionRestoreJob();
        restoredSplitFirstDocument = null;
        restoredSplitSecondDocument = null;
        splitSecondFocused = false;
        if settingsPath == "" or docMgr == null { return job; }
        if IO.File.Exists(settingsPath) == false { return job; }

        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return job; }
        var ini = Ini.Parse(readResult.text);
        splitActive = Ini.Get(ini, "session", "splitActive") == "1";
        if Ini.Get(ini, "settings", "restoreSession") == "0" { return job; }

        job.ini = ini;
        job.docMgr = docMgr;
        job.projMgr = projMgr;
        job.tabs = tabs;
        job.activePath = Ini.Get(ini, "session", "activePath");

        var restoreProject = Ini.Get(ini, "settings", "restoreLastProject") != "0";
        var workspaceRootCountText = Ini.Get(ini, "session", "workspaceRootCount");
        if restoreProject and projMgr != null and workspaceRootCountText != "" {
            job.indexedWorkspaceRoots = true;
            job.workspaceRootCount = Parse.IntOr(workspaceRootCountText, 0);
            if job.workspaceRootCount < 0 { job.workspaceRootCount = 0; }
            if job.workspaceRootCount > MAX_SESSION_WORKSPACE_ROOTS {
                job.workspaceRootCount = MAX_SESSION_WORKSPACE_ROOTS;
            }
        } else if restoreProject and projMgr != null {
            job.legacyProjectRoot = Ini.Get(ini, "session", "projectRoot");
            job.legacyRootProcessed = job.legacyProjectRoot == "";
        }

        job.fileCount = Parse.IntOr(Ini.Get(ini, "session", "count"), 0);
        if job.fileCount < 0 { job.fileCount = 0; }
        if job.fileCount > MAX_SESSION_FILES { job.fileCount = MAX_SESSION_FILES; }

        var splitFirstIndexText = Ini.Get(ini, "session", "splitFirstIndex");
        var splitSecondIndexText = Ini.Get(ini, "session", "splitSecondIndex");
        job.structuredSplitRequested = splitActive
            and (splitFirstIndexText != "" or splitSecondIndexText != "");
        if job.structuredSplitRequested {
            job.splitFirstIndex = Parse.IntOr(splitFirstIndexText, -1);
            job.splitSecondIndex = Parse.IntOr(splitSecondIndexText, -1);
            job.splitSecondFocused =
                Ini.Get(ini, "session", "splitSecondFocused") == "1";
        }

        var rootWork = job.workspaceRootCount;
        if job.indexedWorkspaceRoots == false and job.legacyRootProcessed == false {
            rootWork = 1;
        }
        job.totalWork = rootWork + job.fileCount;
        job.active = job.totalWork > 0;
        if job.active == false {
            FinalizeRestore(job);
        }
        return job;
    }

    /// @brief Advance one restore job by no more than @p maxEntries roots/files.
    /// @return Number of durable entries examined during this call.
    expose func PumpRestore(job: SessionRestoreJob,
                            maxEntries: Integer) -> Integer {
        if job == null or job.active == false { return 0; }
        var limit = maxEntries;
        if limit <= 0 { limit = 1; }
        var processed = 0;

        while processed < limit
              and job.workspaceRootIndex < job.workspaceRootCount {
            var workspaceRoot = Ini.Get(job.ini, "session",
                                        "workspaceRoot." + job.workspaceRootIndex);
            job.workspaceRootIndex = job.workspaceRootIndex + 1;
            processed = processed + 1;
            job.completedWork = job.completedWork + 1;
            if workspaceRoot == "" or Dir.Exists(workspaceRoot) == false
               or job.projMgr == null {
                continue;
            }
            if job.restoredWorkspaceRoot == false {
                job.restoredWorkspaceRoot = job.projMgr.OpenFolder(workspaceRoot);
            } else {
                job.projMgr.AddFolderToWorkspace(workspaceRoot);
            }
        }

        if processed < limit and job.workspaceRootIndex >= job.workspaceRootCount
           and job.legacyRootProcessed == false {
            job.legacyRootProcessed = true;
            processed = processed + 1;
            job.completedWork = job.completedWork + 1;
            if job.projMgr != null and job.legacyProjectRoot != ""
               and Dir.Exists(job.legacyProjectRoot) {
                job.restoredWorkspaceRoot = job.projMgr.OpenFolder(job.legacyProjectRoot);
            }
        }

        while processed < limit and job.workspaceRootIndex >= job.workspaceRootCount
              and job.legacyRootProcessed and job.fileIndex < job.fileCount {
            RestoreOneSessionFile(job, job.fileIndex);
            job.fileIndex = job.fileIndex + 1;
            processed = processed + 1;
            job.completedWork = job.completedWork + 1;
        }
        job.lastPumpCount = processed;

        if job.workspaceRootIndex >= job.workspaceRootCount
           and job.legacyRootProcessed and job.fileIndex >= job.fileCount {
            FinalizeRestore(job);
        }
        return processed;
    }

    /// @brief Stop a partial restore without mutating any remaining entries.
    expose func CancelRestore(job: SessionRestoreJob) {
        if job == null { return; }
        job.active = false;
        job.lastPumpCount = 0;
        job.ini = null;
        job.docMgr = null;
        job.projMgr = null;
        job.tabs = null;
    }

    /// @brief Compact progress text for the painted startup surface.
    expose func RestoreProgressText(job: SessionRestoreJob) -> String {
        if job == null or job.totalWork <= 0 { return "Restoring your workspace..."; }
        return "Restoring your workspace: " + job.completedWork + "/" + job.totalWork;
    }

    /// @brief Restore one indexed document/recovery slot into live models.
    hide func RestoreOneSessionFile(job: SessionRestoreJob,
                                    index: Integer) {
        var section = "session.file." + index;
        var path = Ini.Get(job.ini, section, "path");
        var recovery = DecodeRecoveryText(Ini.Get(job.ini, section, "recovery"),
                                          Ini.Get(job.ini, section, "recoveryEncoding"));
        var recoveryModified = Ini.Get(job.ini, section, "recoveryModified") == "1";
        if path != "" and document_manager.IsEditableTextFile(path) {
            var documentCountBefore = job.docMgr.GetCount();
            var doc = job.docMgr.OpenFile(path);
            if job.docMgr.GetCount() == documentCountBefore {
                // Legacy settings may spell one file as both relative and
                // absolute. Keep only one canonical path owner.
                if recoveryModified
                   and RestoreRecoveryDraft(job.docMgr, job.tabs, job.ini,
                                            section, path, recovery) {
                    Ini.Set(job.ini, section, "path", "");
                    var duplicateDraft = job.docMgr.GetActive();
                    if duplicateDraft != null {
                        RecordRestoredSplitDocument(job, index, duplicateDraft!);
                    }
                    job.restoredCount = job.restoredCount + 1;
                } else {
                    ClearSessionFile(job.ini, section);
                }
                job.prunedSession = true;
            } else {
                doc.kind = file_utils.DetectKind(doc.filePath);
                if recoveryModified and recovery != "" {
                    doc.content = recovery;
                    doc.isModified = true;
                }
                doc.cursorLine = Parse.IntOr(Ini.Get(job.ini, section, "cursorLine"), 1);
                doc.cursorCol = Parse.IntOr(Ini.Get(job.ini, section, "cursorCol"), 1);
                doc.scrollLine = Parse.IntOr(Ini.Get(job.ini, section, "scrollLine"), 1);
                if doc.cursorLine <= 0 { doc.cursorLine = 1; }
                if doc.cursorCol <= 0 { doc.cursorCol = 1; }
                if doc.scrollLine <= 0 { doc.scrollLine = 1; }
                RestoreSceneWorkspaceState(job.ini, section, doc);
                if job.tabs != null {
                    job.tabs.AddTab(doc.fileName, 1);
                    job.tabs.SetTooltip(job.docMgr.activeIndex, doc.filePath);
                    if doc.isModified {
                        job.tabs.SetModified(job.docMgr.activeIndex, true);
                    }
                }
                RecordRestoredSplitDocument(job, index, doc);
                job.restoredCount = job.restoredCount + 1;
            }
        } else if path != "" {
            if recoveryModified
               and RestoreRecoveryDraft(job.docMgr, job.tabs, job.ini,
                                        section, path, recovery) {
                // Preserve recovery text but detach it from the unsafe origin.
                Ini.Set(job.ini, section, "path", "");
                var missingDraft = job.docMgr.GetActive();
                if missingDraft != null {
                    RecordRestoredSplitDocument(job, index, missingDraft!);
                }
                job.restoredCount = job.restoredCount + 1;
            } else {
                ClearSessionFile(job.ini, section);
            }
            if job.activePath == path {
                job.activePath = "";
                Ini.Set(job.ini, "session", "activePath", "");
            }
            job.prunedSession = true;
        } else if RestoreRecoveryDraft(job.docMgr, job.tabs, job.ini,
                                       section, path, recovery) {
            var untitledDraft = job.docMgr.GetActive();
            if untitledDraft != null {
                RecordRestoredSplitDocument(job, index, untitledDraft!);
            }
            job.restoredCount = job.restoredCount + 1;
        }
    }

    /// @brief Map one durable session slot to the actual Document it restored.
    /// @details Missing or rejected earlier slots cannot shift this association;
    ///          the saved slot number is matched before DocumentManager indices
    ///          are compacted by validation.
    hide func RecordRestoredSplitDocument(job: SessionRestoreJob,
                                          index: Integer,
                                          doc: document.Document) {
        if job == null or doc == null or job.structuredSplitRequested == false {
            return;
        }
        if index == job.splitFirstIndex {
            job.splitFirstDocument = doc;
        }
        if index == job.splitSecondIndex {
            job.splitSecondDocument = doc;
        }
    }

    /// @brief Apply active-tab selection and persist any rejected-slot cleanup.
    hide func FinalizeRestore(job: SessionRestoreJob) {
        if job == null { return; }
        if job.structuredSplitRequested {
            if job.splitFirstDocument != null
               and job.splitSecondDocument != null
               and job.splitFirstDocument != job.splitSecondDocument
               and IsSplitDocumentEligible(job.splitFirstDocument)
               and IsSplitDocumentEligible(job.splitSecondDocument) {
                restoredSplitFirstDocument = job.splitFirstDocument;
                restoredSplitSecondDocument = job.splitSecondDocument;
                splitSecondFocused = job.splitSecondFocused;
            } else {
                // A structured session is authoritative. If either pane owner
                // disappeared or was rejected, remain single-pane instead of
                // guessing an unrelated companion document.
                restoredSplitFirstDocument = null;
                restoredSplitSecondDocument = null;
                splitActive = false;
                splitSecondFocused = false;
            }
        }
        if job.restoredCount > 0 and job.docMgr != null {
            var activeIdx = -1;
            if job.activePath != "" {
                activeIdx = job.docMgr.FindByPath(job.activePath);
            }
            if activeIdx < 0 and job.ini != null {
                activeIdx = Parse.IntOr(Ini.Get(job.ini, "session", "activeIndex"), 0);
            }
            if activeIdx < 0 or activeIdx >= job.docMgr.GetCount() {
                activeIdx = 0;
            }
            job.docMgr.SetActive(activeIdx);
            if job.tabs != null { job.tabs.SetActive(activeIdx); }
        }
        if job.prunedSession and job.ini != null {
            safe_io.WriteStudioState(settingsPath, Ini.Format(job.ini));
        }
        job.active = false;
        job.lastPumpCount = 0;
        job.ini = null;
        job.docMgr = null;
        job.projMgr = null;
        job.tabs = null;
    }

    /// @brief Restore bounded recovery text as an unsaved draft document.
    /// @details Used for ordinary untitled recovery and as the data-preserving
    ///          fallback when a named file disappeared or became unsupported.
    /// @return True when a draft was added.
    hide func RestoreRecoveryDraft(docMgr: document_manager.DocumentManager,
                                   tabs: editor_tabs.EditorTabs,
                                   ini: Any,
                                   section: String,
                                   originalPath: String,
                                   recovery: String) -> Boolean {
        if recovery == "" { return false; }
        var draft = docMgr.NewDocument();
        var savedName = Ini.Get(ini, section, "name");
        if savedName == "" and originalPath != "" {
            savedName = Path.Name(originalPath) + " (Recovered)";
            Ini.Set(ini, section, "name", savedName);
        }
        if savedName != "" { draft.fileName = savedName; }
        draft.content = recovery;
        var savedKindName = Ini.Get(ini, section, "kind");
        if savedKindName == "" {
            draft.kind = file_utils.DOC_KIND_CODE;
        } else {
            draft.kind = file_utils.KindFromName(savedKindName);
            if draft.kind == file_utils.DOC_KIND_BINARY_UNSUPPORTED {
                draft.kind = file_utils.DOC_KIND_CODE;
            }
        }
        var languagePath = originalPath;
        if languagePath == "" { languagePath = savedName; }
        draft.language = file_utils.DetectLanguage(languagePath);
        if draft.kind == file_utils.DOC_KIND_SCENE_2D {
            draft.language = "scene";
        } else if draft.kind == file_utils.DOC_KIND_SCENE_3D {
            draft.language = "scene3d";
        } else if draft.kind == file_utils.DOC_KIND_CODE
                  and draft.language != "basic" {
            draft.language = "zia";
        }
        draft.isNew = true;
        draft.isModified = true;
        draft.cursorLine = Parse.IntOr(Ini.Get(ini, section, "cursorLine"), 1);
        draft.cursorCol = Parse.IntOr(Ini.Get(ini, section, "cursorCol"), 1);
        draft.scrollLine = Parse.IntOr(Ini.Get(ini, section, "scrollLine"), 1);
        if draft.cursorLine <= 0 { draft.cursorLine = 1; }
        if draft.cursorCol <= 0 { draft.cursorCol = 1; }
        if draft.scrollLine <= 0 { draft.scrollLine = 1; }
        RestoreSceneWorkspaceState(ini, section, draft);
        if tabs != null {
            tabs.AddTab(draft.fileName, 1);
            tabs.SetModified(docMgr.activeIndex, true);
        }
        return true;
    }

    /// @brief Persist bounded, versioned workspace state for a visual document.
    /// @details Removing both version markers makes stale fields inert when a
    ///          durable slot changes kind or a future controller declines state.
    hide func WriteSceneWorkspaceState(ini: Any,
                                       section: String,
                                       doc: document.Document) {
        Ini.Remove(ini, section, "scene2dVersion");
        Ini.Remove(ini, section, "scene3dVersion");
        if doc == null { return; }

        if doc.kind == file_utils.DOC_KIND_SCENE_2D
           and doc.scene2DWorkspace != null
           and doc.scene2DWorkspace.initialized {
            var state2D = doc.scene2DWorkspace;
            Ini.Set(ini, section, "scene2dVersion",
                    "" + SCENE_WORKSPACE_STATE_VERSION);
            Ini.Set(ini, section, "scene2dMode",
                    "" + ClampSessionInt(state2D.mode, 0, 3));
            Ini.Set(ini, section, "scene2dZoom",
                    "" + ClampSessionInt(state2D.zoomPercent, 25, 1600));
            Ini.Set(ini, section, "scene2dLayer",
                    "" + ClampSessionInt(state2D.activeLayer, 0, 1023));
            Ini.Set(ini, section, "scene2dObject",
                    "" + ClampSessionInt(
                        state2D.selectedObject, -1, 1000000));
            Ini.Set(ini, section, "scene2dProperty",
                    "" + ClampSessionInt(
                        state2D.selectedObjectProperty, -1, 511));
            Ini.Set(ini, section, "scene2dCellX",
                    "" + ClampSessionInt(state2D.selectedCellX, -1, 255));
            Ini.Set(ini, section, "scene2dCellY",
                    "" + ClampSessionInt(state2D.selectedCellY, -1, 255));
            Ini.Set(ini, section, "scene2dTile",
                    "" + ClampSessionInt(state2D.tileId, 0, 1000000));
            Ini.Set(ini, section, "scene2dSplit",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state2D.splitPosition * 10000.0),
                        2000, 8500));
            Ini.Set(ini, section, "scene2dScrollX",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state2D.canvasScrollX),
                        0, MAX_SCENE_WORKSPACE_SCROLL));
            Ini.Set(ini, section, "scene2dScrollY",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state2D.canvasScrollY),
                        0, MAX_SCENE_WORKSPACE_SCROLL));
            Ini.Set(ini, section, "scene2dInspectorScrollY",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state2D.inspectorScrollY),
                        0, MAX_SCENE_WORKSPACE_SCROLL));
            Ini.Set(ini, section, "scene2dInspectorVisible",
                    SessionBool(state2D.inspectorRequestedVisible));
            Ini.Set(ini, section, "scene2dCompactInspector",
                    SessionBool(state2D.compactInspectorShown));
            return;
        }

        if doc.kind == file_utils.DOC_KIND_SCENE_3D
           and doc.scene3DWorkspace != null
           and doc.scene3DWorkspace.initialized {
            var state3D = doc.scene3DWorkspace;
            Ini.Set(ini, section, "scene3dVersion",
                    "" + SCENE_WORKSPACE_STATE_VERSION);
            Ini.Set(ini, section, "scene3dSelection",
                    "" + ClampSessionInt(state3D.selectedIndex, -1, 1023));
            Ini.Set(ini, section, "scene3dTransformMode",
                    "" + ClampSessionInt(state3D.transformMode, 0, 2));
            Ini.Set(ini, section, "scene3dTransformSnap",
                    SessionBool(state3D.transformSnapEnabled));
            Ini.Set(ini, section, "scene3dYaw",
                    "" + ClampSessionInt(
                        state3D.viewYawDegrees, -180, 180));
            Ini.Set(ini, section, "scene3dPitch",
                    "" + ClampSessionInt(state3D.viewPitchDegrees, -80, 80));
            Ini.Set(ini, section, "scene3dScale",
                    "" + ClampSessionInt(state3D.viewScale, 4, 120));
            Ini.Set(ini, section, "scene3dTargetX",
                    ScaledSceneTarget(state3D.viewTargetX));
            Ini.Set(ini, section, "scene3dTargetY",
                    ScaledSceneTarget(state3D.viewTargetY));
            Ini.Set(ini, section, "scene3dTargetZ",
                    ScaledSceneTarget(state3D.viewTargetZ));
            Ini.Set(ini, section, "scene3dSplit",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state3D.splitPosition * 10000.0),
                        2000, 8500));
            Ini.Set(ini, section, "scene3dInspectorScrollY",
                    "" + ClampSessionInt(
                        Convert.NumToInt(state3D.inspectorScrollY),
                        0, MAX_SCENE_WORKSPACE_SCROLL));
            Ini.Set(ini, section, "scene3dInspectorVisible",
                    SessionBool(state3D.inspectorRequestedVisible));
            Ini.Set(ini, section, "scene3dCompactInspector",
                    SessionBool(state3D.compactInspectorShown));
        }
    }

    /// @brief Restore scene state only when its kind and schema both match.
    hide func RestoreSceneWorkspaceState(ini: Any,
                                         section: String,
                                         doc: document.Document) {
        if doc == null { return; }
        if doc.kind == file_utils.DOC_KIND_SCENE_2D
           and Parse.IntOr(
               Ini.Get(ini, section, "scene2dVersion"), 0)
               == SCENE_WORKSPACE_STATE_VERSION {
            var state2D = doc.scene2DWorkspace;
            state2D.initialized = true;
            state2D.mode = ReadSessionInt(
                ini, section, "scene2dMode", 0, 0, 3);
            state2D.zoomPercent = ReadSessionInt(
                ini, section, "scene2dZoom", 100, 25, 1600);
            state2D.activeLayer = ReadSessionInt(
                ini, section, "scene2dLayer", 0, 0, 1023);
            state2D.selectedObject = ReadSessionInt(
                ini, section, "scene2dObject", -1, -1, 1000000);
            state2D.selectedObjectProperty = ReadSessionInt(
                ini, section, "scene2dProperty", -1, -1, 511);
            state2D.selectedCellX = ReadSessionInt(
                ini, section, "scene2dCellX", -1, -1, 255);
            state2D.selectedCellY = ReadSessionInt(
                ini, section, "scene2dCellY", -1, -1, 255);
            state2D.tileId = ReadSessionInt(
                ini, section, "scene2dTile", 1, 0, 1000000);
            state2D.splitPosition = ReadSessionInt(
                ini, section, "scene2dSplit", 6800, 2000, 8500)
                / 10000.0;
            state2D.canvasScrollX = ReadSessionInt(
                ini, section, "scene2dScrollX", 0,
                0, MAX_SCENE_WORKSPACE_SCROLL) / 1.0;
            state2D.canvasScrollY = ReadSessionInt(
                ini, section, "scene2dScrollY", 0,
                0, MAX_SCENE_WORKSPACE_SCROLL) / 1.0;
            state2D.inspectorScrollY = ReadSessionInt(
                ini, section, "scene2dInspectorScrollY", 0,
                0, MAX_SCENE_WORKSPACE_SCROLL) / 1.0;
            state2D.inspectorRequestedVisible = ReadSessionInt(
                ini, section, "scene2dInspectorVisible", 1, 0, 1) != 0;
            state2D.compactInspectorShown = ReadSessionInt(
                ini, section, "scene2dCompactInspector", 0, 0, 1) != 0;
            state2D.undoStack = [];
            state2D.redoStack = [];
            state2D.cleanSerialized = "";
            state2D.historyContent = "";
            return;
        }

        if doc.kind == file_utils.DOC_KIND_SCENE_3D
           and Parse.IntOr(
               Ini.Get(ini, section, "scene3dVersion"), 0)
               == SCENE_WORKSPACE_STATE_VERSION {
            var state3D = doc.scene3DWorkspace;
            state3D.initialized = true;
            state3D.selectedIndex = ReadSessionInt(
                ini, section, "scene3dSelection", -1, -1, 1023);
            state3D.transformMode = ReadSessionInt(
                ini, section, "scene3dTransformMode", 0, 0, 2);
            state3D.transformSnapEnabled = ReadSessionInt(
                ini, section, "scene3dTransformSnap", 0, 0, 1) != 0;
            state3D.viewYawDegrees = ReadSessionInt(
                ini, section, "scene3dYaw", 35, -180, 180);
            state3D.viewPitchDegrees = ReadSessionInt(
                ini, section, "scene3dPitch", -25, -80, 80);
            state3D.viewScale = ReadSessionInt(
                ini, section, "scene3dScale", 28, 4, 120);
            state3D.viewTargetX = ReadSceneTarget(
                ini, section, "scene3dTargetX");
            state3D.viewTargetY = ReadSceneTarget(
                ini, section, "scene3dTargetY");
            state3D.viewTargetZ = ReadSceneTarget(
                ini, section, "scene3dTargetZ");
            state3D.splitPosition = ReadSessionInt(
                ini, section, "scene3dSplit", 6500, 2000, 8500)
                / 10000.0;
            state3D.inspectorScrollY = ReadSessionInt(
                ini, section, "scene3dInspectorScrollY", 0,
                0, MAX_SCENE_WORKSPACE_SCROLL) / 1.0;
            state3D.inspectorRequestedVisible = ReadSessionInt(
                ini, section, "scene3dInspectorVisible", 1, 0, 1) != 0;
            state3D.compactInspectorShown = ReadSessionInt(
                ini, section, "scene3dCompactInspector", 0, 0, 1) != 0;
            state3D.undoStack = [];
            state3D.redoStack = [];
            state3D.cleanSerialized = "";
            state3D.historyContent = "";
        }
    }

    /// @brief Encode one Boolean workspace field as a stable integer string.
    hide func SessionBool(value: Boolean) -> String {
        if value { return "1"; }
        return "0";
    }

    /// @brief Parse and clamp one untrusted integer workspace field.
    hide func ReadSessionInt(ini: Any,
                             section: String,
                             key: String,
                             fallback: Integer,
                             minimum: Integer,
                             maximum: Integer) -> Integer {
        return ClampSessionInt(
            Parse.IntOr(Ini.Get(ini, section, key), fallback),
            minimum, maximum);
    }

    /// @brief Clamp an integer without platform-specific helpers.
    hide func ClampSessionInt(value: Integer,
                              minimum: Integer,
                              maximum: Integer) -> Integer {
        if value < minimum { return minimum; }
        if value > maximum { return maximum; }
        return value;
    }

    /// @brief Serialize one camera target as bounded thousandths.
    hide func ScaledSceneTarget(value: Number) -> String {
        return "" + ClampSessionInt(
            Convert.NumToInt(value * 1000.0),
            0 - MAX_SCENE_WORKSPACE_TARGET_MILLIS,
            MAX_SCENE_WORKSPACE_TARGET_MILLIS);
    }

    /// @brief Read one bounded fixed-point camera target.
    hide func ReadSceneTarget(ini: Any,
                              section: String,
                              key: String) -> Number {
        return ReadSessionInt(
            ini, section, key, 0,
            0 - MAX_SCENE_WORKSPACE_TARGET_MILLIS,
            MAX_SCENE_WORKSPACE_TARGET_MILLIS) / 1000.0;
    }

    /// @brief Decide whether an open document belongs in durable tab state.
    /// @details Read-only previews and unsupported payloads are deliberately
    ///          ephemeral. Modified untitled drafts remain eligible through the
    ///          bounded recovery snapshot path.
    hide func ShouldPersistDocument(doc: document.Document,
                                    persistRecovery: Boolean) -> Boolean {
        if doc == null or doc.isReadOnlyPreview { return false; }
        if doc.filePath == "" {
            return persistRecovery and ShouldPersistRecovery(doc);
        }
        if doc.isNew { return false; }
        return document_manager.IsEditableTextFile(doc.filePath);
    }

    /// @brief Decide whether a document should carry a crash-recovery snapshot.
    /// @details Recovery is deliberately limited to modified, editable text buffers
    ///          under a bounded size cap. Existing files are included as well as
    ///          untitled drafts so a crash after editing a saved file restores the
    ///          unsaved buffer instead of silently reopening the older disk version.
    /// @param doc Open document being written into session state.
    /// @return True when the complete buffer should be persisted in settings.
    hide func ShouldPersistRecovery(doc: document.Document) -> Boolean {
        if doc == null { return false; }
        if doc.isModified == false { return false; }
        if doc.isReadOnlyPreview { return false; }
        return Str.get_Length(doc.content) <= MAX_SESSION_RECOVERY_CHARS;
    }

    /// @brief Encode crash-recovery text into an INI-safe scalar value.
    /// @details The project INI helper writes values verbatim and parses one
    ///          physical line at a time, so raw document buffers containing
    ///          newlines cannot be stored directly. Base64 keeps the complete
    ///          text reversible while staying within the existing runtime API.
    /// @param text Document buffer to persist.
    /// @return Base64-encoded representation suitable for `Ini.Set`.
    hide func EncodeRecoveryText(text: String) -> String {
        return Codec.Base64Encode(text);
    }

    /// @brief Decode session recovery text from current or legacy settings.
    /// @details New entries set `recoveryEncoding=base64`. Older Zanna Studio
    ///          sessions stored raw text under `recovery`; those values are
    ///          returned unchanged so restore keeps backward compatibility.
    /// @param encoded Value read from `session.file.N.recovery`.
    /// @param encoding Encoding marker read from `session.file.N.recoveryEncoding`.
    /// @return Decoded document buffer, or the raw value for legacy entries.
    hide func DecodeRecoveryText(encoded: String, encoding: String) -> String {
        if encoded == "" { return ""; }
        if Str.get_Length(encoded) > MAX_SESSION_RECOVERY_ENCODED_CHARS { return ""; }
        if encoding == "base64" {
            try {
                var decoded = Codec.Base64Decode(encoded);
                if Str.get_Length(decoded) > MAX_SESSION_RECOVERY_CHARS { return ""; }
                return decoded;
            } catch {
                return "";
            }
        }
        if Str.get_Length(encoded) > MAX_SESSION_RECOVERY_CHARS { return ""; }
        return encoded;
    }

    /// @brief Record every live workspace root with the primary root first.
    hide func SaveRecentProjects(ini: Any,
                                 projMgr: project_manager.ProjectManager) {
        if projMgr == null { return; }
        // Prepend extras in reverse, then primary, so root index 0 remains the
        // most prominent row while every multi-root folder stays discoverable.
        var i = projMgr.RootCount() - 1;
        while i >= 0 {
            PrependRecentProject(ini, projMgr.RootPathAt(i));
            i = i - 1;
        }
    }

    /// @brief Prepend a workspace folder while canonicalizing and de-duplicating.
    hide func PrependRecentProject(ini: Any, path: String) {
        var canonicalPath = CanonicalRecentPath(path);
        if canonicalPath == "" or Dir.Exists(canonicalPath) == false { return; }
        var oldCount = Parse.IntOr(Ini.Get(ini, "recent", "count"), 0);
        if oldCount < 0 { oldCount = 0; }
        if oldCount > MAX_RECENT_PROJECTS { oldCount = MAX_RECENT_PROJECTS; }
        var oldPaths = Seq.New();
        var i = 0;
        while i < oldCount {
            var oldPath = CanonicalRecentPath(Ini.Get(ini, "recent", "path." + i));
            if oldPath != "" and oldPath != canonicalPath and Dir.Exists(oldPath)
               and !StringSeqContains(oldPaths, oldPath) {
                Seq.Push(oldPaths, oldPath);
            }
            i = i + 1;
        }

        Ini.Set(ini, "recent", "path.0", canonicalPath);
        var written = 1;
        i = 0;
        while i < Seq.get_Count(oldPaths) and written < MAX_RECENT_PROJECTS {
            Ini.Set(ini, "recent", "path." + written,
                    Obj.ToString(Seq.Get(oldPaths, i)));
            written = written + 1;
            i = i + 1;
        }
        var persisted = written;
        while written < MAX_RECENT_PROJECTS {
            Ini.Set(ini, "recent", "path." + written, "");
            written = written + 1;
        }
        Ini.Set(ini, "recent", "count", "" + persisted);
    }

    hide func SaveRecentFiles(ini: Any, docMgr: document_manager.DocumentManager) {
        if docMgr == null { return; }
        var i = docMgr.GetCount() - 1;
        while i >= 0 {
            var doc = docMgr.documents.get(i);
            if doc.filePath != "" and !doc.isNew and !doc.isReadOnlyPreview
                and document_manager.IsEditableTextFile(doc.filePath) {
                PrependRecentFile(ini, doc.filePath);
            }
            i = i - 1;
        }
    }

    hide func PrependRecentFile(ini: Any, path: String) {
        var canonicalPath = CanonicalRecentPath(path);
        if !document_manager.IsEditableTextFile(canonicalPath) { return; }
        var oldCount = Parse.IntOr(Ini.Get(ini, "recentFiles", "count"), 0);
        if oldCount < 0 { oldCount = 0; }
        if oldCount > MAX_RECENT_FILES { oldCount = MAX_RECENT_FILES; }
        var oldPaths = Seq.New();
        var i = 0;
        while i < oldCount {
            var oldPath = CanonicalRecentPath(Ini.Get(ini, "recentFiles", "path." + i));
            if oldPath != "" and oldPath != canonicalPath
                and document_manager.IsEditableTextFile(oldPath)
                and !StringSeqContains(oldPaths, oldPath) {
                Seq.Push(oldPaths, oldPath);
            }
            i = i + 1;
        }

        Ini.Set(ini, "recentFiles", "path.0", canonicalPath);
        var written = 1;
        i = 0;
        while i < Seq.get_Count(oldPaths) and written < MAX_RECENT_FILES {
            Ini.Set(ini, "recentFiles", "path." + written, Obj.ToString(Seq.Get(oldPaths, i)));
            written = written + 1;
            i = i + 1;
        }
        Ini.Set(ini, "recentFiles", "count", "" + written);
    }

    /// @brief Remove invalid and duplicate workspace folders from recent history.
    hide func PruneRecentProjectHistory() {
        if settingsPath == "" or !IO.File.Exists(settingsPath) { return; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return; }
        var ini = Ini.Parse(readResult.text);
        if PruneRecentProjectsInIni(ini) {
            safe_io.WriteStudioState(settingsPath, Ini.Format(ini));
        }
    }

    /// @brief Compact valid recent workspace paths in-place.
    hide func PruneRecentProjectsInIni(ini: Any) -> Boolean {
        var oldCount = Parse.IntOr(Ini.Get(ini, "recent", "count"), 0);
        if oldCount < 0 { oldCount = 0; }
        var scanCount = oldCount;
        if scanCount > MAX_RECENT_PROJECTS { scanCount = MAX_RECENT_PROJECTS; }
        var paths = Seq.New();
        var i = 0;
        while i < scanCount {
            var path = CanonicalRecentPath(Ini.Get(ini, "recent", "path." + i));
            if path != "" and Dir.Exists(path) and !StringSeqContains(paths, path) {
                Seq.Push(paths, path);
            }
            i = i + 1;
        }

        var changed = oldCount != Seq.get_Count(paths);
        i = 0;
        while i < Seq.get_Count(paths) {
            var expected = Obj.ToString(Seq.Get(paths, i));
            if Ini.Get(ini, "recent", "path." + i) != expected { changed = true; }
            Ini.Set(ini, "recent", "path." + i, expected);
            i = i + 1;
        }
        while i < MAX_RECENT_PROJECTS {
            if Ini.Get(ini, "recent", "path." + i) != "" { changed = true; }
            Ini.Set(ini, "recent", "path." + i, "");
            i = i + 1;
        }
        Ini.Set(ini, "recent", "count", "" + Seq.get_Count(paths));
        return changed;
    }

    /// @brief Remove invalid and duplicate files from durable recent history.
    /// @details Setup calls this once so legacy settings are repaired before the
    ///          welcome view asks for rows. Unknown INI sections remain intact.
    hide func PruneRecentFileHistory() {
        if settingsPath == "" or !IO.File.Exists(settingsPath) { return; }
        var readResult = safe_io.ReadStudioState(settingsPath);
        if readResult.ok == false { return; }
        var ini = Ini.Parse(readResult.text);
        if PruneRecentFilesInIni(ini) {
            safe_io.WriteStudioState(settingsPath, Ini.Format(ini));
        }
    }

    /// @brief Compact valid recent paths in-place and report whether INI changed.
    hide func PruneRecentFilesInIni(ini: Any) -> Boolean {
        var oldCount = Parse.IntOr(Ini.Get(ini, "recentFiles", "count"), 0);
        if oldCount < 0 { oldCount = 0; }
        var scanCount = oldCount;
        if scanCount > MAX_RECENT_FILES { scanCount = MAX_RECENT_FILES; }
        var paths = Seq.New();
        var i = 0;
        while i < scanCount {
            var path = CanonicalRecentPath(Ini.Get(ini, "recentFiles", "path." + i));
            if document_manager.IsEditableTextFile(path) and !StringSeqContains(paths, path) {
                Seq.Push(paths, path);
            }
            i = i + 1;
        }

        var changed = oldCount != Seq.get_Count(paths);
        i = 0;
        while i < Seq.get_Count(paths) {
            var expected = Obj.ToString(Seq.Get(paths, i));
            if Ini.Get(ini, "recentFiles", "path." + i) != expected { changed = true; }
            Ini.Set(ini, "recentFiles", "path." + i, expected);
            i = i + 1;
        }
        while i < MAX_RECENT_FILES {
            if Ini.Get(ini, "recentFiles", "path." + i) != "" { changed = true; }
            Ini.Set(ini, "recentFiles", "path." + i, "");
            i = i + 1;
        }
        Ini.Set(ini, "recentFiles", "count", "" + Seq.get_Count(paths));
        return changed;
    }

    /// @brief Return whether an untyped sequence already contains a path.
    hide func StringSeqContains(items: Any, path: String) -> Boolean {
        var i = 0;
        while i < Seq.get_Count(items) {
            if Obj.ToString(Seq.Get(items, i)) == path { return true; }
            i = i + 1;
        }
        return false;
    }

    /// @brief Normalize recent-file identity before persistence or comparison.
    /// @param path Absolute or relative file path spelling.
    /// @return Absolute normalized path, or empty for an empty input.
    /// @details Studio can be launched from a terminal, Finder, or a file
    ///          association. Canonical storage prevents those working-directory
    ///          differences from creating duplicate welcome rows.
    hide func CanonicalRecentPath(path: String) -> String {
        if path == "" { return ""; }
        try {
            return Path.Normalize(Path.Absolute(path));
        } catch {
            return "";
        }
        return "";
    }

    /// @brief Clear a rejected session slot while preserving unrelated settings.
    hide func ClearSessionFile(ini: Any, section: String) {
        Ini.Set(ini, section, "path", "");
        Ini.Set(ini, section, "name", "");
        Ini.Set(ini, section, "recovery", "");
        Ini.Set(ini, section, "recoveryEncoding", "");
        Ini.Set(ini, section, "recoveryModified", "0");
    }
}
