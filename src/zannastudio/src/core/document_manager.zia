//
// File: zannastudio/src/core/document_manager.zia
// Purpose: Own open Studio documents and provide safe text-file load/save
//          operations, including binary and oversized-file rejection.
// Key invariants:
//   - One editable document exists per underlying filesystem file identity.
//   - Non-text payloads never flow into editable buffers or session restore.
// Ownership/Lifetime:
//   - DocumentManager owns every Document in its ordered documents list.
// Links: zannastudio/src/core/session.zia,
//        zannastudio/src/commands/file_commands.zia
//
//===----------------------------------------------------------------------===//

module document_manager;

bind "document";
bind "../services/file_utils";
bind "../services/safe_io";

bind Obj = Zanna.Core.Object;
bind IO = Zanna.IO;
bind BinFile = Zanna.IO.BinFile;
bind Path = Zanna.IO.Path;
bind Str = Zanna.String;
bind Map = Zanna.Collections.Map;
bind Seq = Zanna.Collections.Seq;
bind WorkspaceEdit = Zanna.Workspace.Edit;
bind Hash = Zanna.Crypto.Hash;

final MAX_TEXT_OPEN_BYTES = 4000000;
final TEXT_SNIFF_BYTES = 4096;

/// @brief Explain why a path cannot enter the Studio text editor.
/// @details File extensions catch known binary formats, while a bounded prefix
///          scan catches extensionless executables and other binary payloads.
///          NUL bytes also reject unsupported UTF-16 input rather than silently
///          corrupting it through the UTF-8 text pipeline.
/// @param path Candidate file path.
/// @return Empty string for editable text, otherwise a user-facing reason.
expose func TextOpenBlockReason(path: String) -> String {
    if path == "" or !IO.File.Exists(path) {
        return "The file no longer exists.";
    }
    if file_utils.DetectKind(path) == file_utils.DOC_KIND_BINARY_UNSUPPORTED {
        return "Binary files cannot be opened in the text editor.";
    }
    var size = safe_io.SizeBytes(path);
    if size < 0 {
        return "The file could not be read.";
    }
    if size > MAX_TEXT_OPEN_BYTES {
        return "Files larger than 4 MB cannot be opened in the text editor.";
    }
    if HasNulByteInPrefix(path) {
        return "Binary or unreadable files cannot be opened in the text editor.";
    }
    return "";
}

/// @brief Return whether a durable path is safe to edit and restore as text.
/// @param path Candidate file path.
/// @return True only for existing, bounded, non-binary files.
expose func IsEditableTextFile(path: String) -> Boolean {
    return TextOpenBlockReason(path) == "";
}

/// @brief Detect binary content without loading an entire file.
/// @param path Existing regular file path.
/// @return True when the first 4 KiB contains a NUL byte.
hide func HasNulByteInPrefix(path: String) -> Boolean {
    if path == "" or IO.File.Exists(path) == false { return false; }
    try {
        var stream = BinFile.Open(path, "rb");
        defer stream.Close();
        var remaining = safe_io.SizeBytes(path);
        if remaining < 0 { return true; }
        if remaining > TEXT_SNIFF_BYTES { remaining = TEXT_SNIFF_BYTES; }
        var found = false;
        var i = 0;
        while i < remaining and !found {
            if stream.ReadByte() == 0 { found = true; }
            i = i + 1;
        }
        return found;
    } catch {
        // A path that vanished or became unreadable during the bounded sniff is
        // not safe to admit into an editable buffer.
        return true;
    }
    return true;
}

// ============================================================================
// MODULE: document_manager
// PURPOSE: Owns the IDE's set of open documents and the index of the
//          currently active one. Provides the file-management API
//          (new / open / save / save-as / save-all / close) plus
//          lookup helpers (active getter, find-by-path).
//
// WHERE-THIS-FITS: Mid-tier coordinator. Sits between the file commands
//          (commands/file_commands.zia) and the underlying
//          `document.Document` records. The editor and editor_tabs
//          modules read from here to know what to display.
//
// KEY-DESIGN-CHOICES:
//   * SINGLE LIST + INDEX. `documents` is a flat List ordered by tab
//     position; `activeIndex` is the offset of the currently visible
//     document. `-1` means no document is active (used briefly between
//     close-last and open-new). Tab order in the UI mirrors list order
//     so users see "what they expect."
//   * UNTITLED COUNTER. `untitledCount` increments forever — never
//     resets. So opening N new tabs gives them "Untitled 1" through
//     "Untitled N" even after closes/reopens. This matches VS Code's
//     behaviour and avoids confusing the user with reused names.
//   * OpenFile DEDUPES. If a file is already open, OpenFile activates
//     the existing tab rather than creating a duplicate. Prevents the
//     "I have three tabs of foo.zia" anti-pattern.
//   * SaveAll RETURNS COUNT. Lets the caller render "Saved N files" in
//     the status bar without re-counting.
//   * CloseDocument FIXES UP activeIndex. If you close a tab left of the
//     active one, the active index shifts left to keep the same document
//     visible. If you close the active tab, the manager keeps the same
//     visual slot when possible or clamps to the last tab.
//   * lastModifiedOnDisk SET ON SAVE TOO. So the file watcher doesn't
//     see our own write as an external change.
//
// HOW-TO-READ: NewDocument (untitled spawn) -> OpenFile (open + dedupe)
//   -> SaveActive (save-in-place) / SaveAs (save-with-rename) -> SaveAll
//   (batch save) -> CloseDocument (with active-fixup) -> GetActive /
//   SetActive / FindByPath / GetCount.
// ============================================================================

/// @brief Owns the open-document list and the active-tab index.
class DocumentManager {
    expose List[document.Document] documents;  // All open documents, in tab order.
    expose Integer activeIndex;                // Index of active document (-1 = none).
    expose Integer untitledCount;              // Monotonic counter for "Untitled N" naming.
    expose List recentlyClosedPaths;           // Most-recently closed named files.

    /// @brief Initialize with no open documents.
    expose func init() {
        documents = [];
        activeIndex = -1;
        untitledCount = 0;
        recentlyClosedPaths = [];
    }

    /// @brief Create a new untitled document and activate it.
    /// @return The freshly created Document (also added to `documents`).
    /// @note Increments `untitledCount`; the new tab is named
    ///       "Untitled N" where N is the new counter value. Language
    ///       defaults to "zia" since untitled files are most often used
    ///       to draft new Zia code.
    expose func NewDocument() -> document.Document {
        untitledCount = untitledCount + 1;
        var doc = new document.Document();
        doc.fileName = "Untitled " + untitledCount;
        doc.language = "zia";
        doc.kind = file_utils.DOC_KIND_CODE;
        doc.isNew = true;
        // Pre-populate with a `module` skeleton so the Zia completion engine
        // can parse the buffer as the user types. Without this, every cursor
        // position in a bare-expression buffer makes CompleteForFile return
        // the empty string, which presents to users as a blank popup.
        doc.content = "module Untitled" + untitledCount + ";\n\n";

        documents.add(doc);
        activeIndex = documents.count() - 1;
        return doc;
    }

    /// @brief Open a file from disk, or activate it if already open.
    /// @param path Absolute file path.
    /// @return The Document (existing or freshly loaded).
    /// @note Dedupes by path: identical paths share a Document so edits
    ///       in one place don't fork the buffer.
    expose func OpenFile(path: String) -> document.Document {
        var canonicalPath = NormalizeDocumentPath(path);
        var existing = FindByPath(canonicalPath);
        if existing >= 0 {
            activeIndex = existing;
            return documents.get(existing);
        }

        var doc = new document.Document();
        doc.filePath = canonicalPath;
        doc.fileName = Path.Name(canonicalPath);
        doc.language = file_utils.DetectLanguage(canonicalPath);
        doc.kind = file_utils.DetectKind(canonicalPath);
        var blockReason = TextOpenBlockReason(canonicalPath);
        doc.isReadOnlyPreview = blockReason != "";
        if doc.isReadOnlyPreview {
            doc.content = BlockedPreviewText(canonicalPath, blockReason);
        } else {
            var readResult = safe_io.ReadAllTextBounded(canonicalPath,
                                                        MAX_TEXT_OPEN_BYTES);
            if readResult.ok {
                doc.content = readResult.text;
            } else {
                doc.isReadOnlyPreview = true;
                doc.content = BlockedPreviewText(canonicalPath, "The file could not be read.");
            }
        }
        doc.isNew = false;
        doc.isModified = false;
        RefreshDiskMetadataFromKnownText(doc, doc.content);
        ClearExternalState(doc);

        documents.add(doc);
        activeIndex = documents.count() - 1;
        return doc;
    }

    /// @brief Apply crash-recovered text without creating duplicate path owners.
    /// @details Existing editable files reuse their canonical document/tab. If
    ///          the origin disappeared or became unsupported, recovery becomes
    ///          an untitled draft so no unsafe path is read or overwritten.
    /// @param path Original named-file path, or empty for an untitled swap.
    /// @param content Last crash-safe buffer text.
    /// @return Existing/new named document or a fresh recovered draft.
    expose func ApplyRecoveredText(path: String, content: String) -> document.Document {
        var doc: document.Document = null;
        if path != "" and IsEditableTextFile(path) {
            doc = OpenFile(path);
        } else {
            doc = NewDocument();
            if path != "" {
                var recoveredName = Path.Name(path);
                if recoveredName != "" {
                    doc.fileName = recoveredName + " (Recovered)";
                }
            }
        }
        doc.content = content;
        doc.isModified = true;
        return doc;
    }

    /// @brief Save the active document to its existing path.
    /// @return false if no active document or it's untitled (no path
    ///         to save to — caller should fall back to SaveAs).
    expose func SaveActive() -> Boolean {
        if activeIndex < 0 { return false; }
        return SaveDocument(activeIndex);
    }

    /// @brief Save after the user explicitly accepted a known external state.
    /// @param observedState Strong disk state shown by the confirmation prompt.
    /// @return True only when that state can be resolved without a new conflict.
    expose func SaveActiveAfterExternalConfirmation(observedState: Integer) -> Boolean {
        if activeIndex < 0 { return false; }
        return SaveDocumentAfterExternalConfirmation(activeIndex, observedState);
    }

    expose func SaveDocument(index: Integer) -> Boolean {
        if index < 0 or index >= documents.count() { return false; }
        var doc = documents.get(index);
        if doc.isNew { return false; }
        if doc.isReadOnlyPreview { return false; }
        if IO.File.Exists(doc.filePath) == false { return false; }
        if WriteExistingTextAtomically(doc.filePath, doc.content,
                                       doc.lastModifiedOnDisk,
                                       doc.lastSizeOnDisk,
                                       doc.lastContentHashOnDisk) == false {
            return false;
        }
        doc.isModified = false;
        RefreshDiskMetadataFromKnownText(doc, doc.content);
        ClearExternalState(doc);
        return true;
    }

    /// @brief Resolve a save after an explicit external-change confirmation.
    /// @details Changed files are replaced from one stable current snapshot.
    ///          Missing/deleted/renamed paths are recreated only while still
    ///          absent; a file that appeared after the prompt is never clobbered.
    expose func SaveDocumentAfterExternalConfirmation(index: Integer,
                                                       observedState: Integer) -> Boolean {
        if observedState == document.EXTERNAL_STATE_CLEAN {
            return SaveDocument(index);
        }
        if index < 0 or index >= documents.count() { return false; }
        var doc = documents.get(index);
        if doc.isNew or doc.isReadOnlyPreview or doc.filePath == "" { return false; }

        var saved = false;
        if observedState == document.EXTERNAL_STATE_CHANGED {
            if IO.File.Exists(doc.filePath) == false { return false; }
            saved = WriteExistingTextAtomically(doc.filePath, doc.content, -1, -1, "");
        } else if observedState == document.EXTERNAL_STATE_MISSING
                  or observedState == document.EXTERNAL_STATE_DELETED
                  or observedState == document.EXTERNAL_STATE_RENAMED {
            if IO.File.Exists(doc.filePath) { return false; }
            saved = WriteNewTextAtomically(doc.filePath, doc.content);
        }
        if saved == false { return false; }
        doc.isModified = false;
        RefreshDiskMetadataFromKnownText(doc, doc.content);
        ClearExternalState(doc);
        return true;
    }

    /// @brief Save the active document to a specific path (Save As).
    /// @param path Destination path; the document's filePath/fileName
    ///        update to match. Language is re-detected from the new
    ///        extension.
    /// @return false if no active document.
    expose func SaveAs(path: String) -> Boolean {
        if activeIndex < 0 { return false; }
        var doc = documents.get(activeIndex);
        if doc.isReadOnlyPreview { return false; }
        var canonicalPath = NormalizeDocumentPath(path);
        if SaveAsBlockReason(activeIndex, canonicalPath) != "" { return false; }
        if WriteTextForSaveAs(canonicalPath, doc.content) == false {
            return false;
        }
        doc.filePath = canonicalPath;
        doc.fileName = Path.Name(canonicalPath);
        doc.language = file_utils.DetectLanguage(canonicalPath);
        doc.kind = file_utils.DetectKind(canonicalPath);
        doc.isReadOnlyPreview = false;
        doc.isNew = false;
        doc.isModified = false;
        RefreshDiskMetadataFromKnownText(doc, doc.content);
        ClearExternalState(doc);
        return true;
    }

    /// @brief Explain why a document cannot be retargeted to a Save As path.
    /// @details One path must continue to map to one open Document. Rejecting a
    ///          destination already owned by another tab prevents divergent
    ///          buffers and an invisible overwrite of that tab's disk content.
    ///          Known binary extensions are also rejected because the resulting
    ///          document could not be reopened by Studio's text editor.
    /// @param index Document that would receive the new path.
    /// @param path Proposed destination path.
    /// @return Empty when allowed, otherwise a user-facing reason.
    expose func SaveAsBlockReason(index: Integer, path: String) -> String {
        if index < 0 or index >= documents.count() {
            return "There is no document to save.";
        }
        if path == "" { return "Choose a destination path."; }
        if file_utils.DetectKind(path) == file_utils.DOC_KIND_BINARY_UNSUPPORTED {
            return "Choose a text or source-code file extension.";
        }
        var existing = FindByPath(path);
        if existing >= 0 and existing != index {
            return "That file is already open in another tab.";
        }
        return "";
    }

    expose func SaveDocumentAs(index: Integer, path: String) -> Boolean {
        if index < 0 or index >= documents.count() { return false; }
        var oldActive = activeIndex;
        activeIndex = index;
        var ok = SaveAs(path);
        activeIndex = oldActive;
        return ok;
    }

    /// @brief Save every modified, non-untitled document.
    /// @return Number of documents actually saved (lets the caller
    ///         render "Saved N files" without re-counting).
    expose func SaveAll() -> Integer {
        var count = 0;
        var i = 0;
        while i < documents.count() {
            var doc = documents.get(i);
            if doc.isModified and doc.isNew == false and doc.isReadOnlyPreview == false {
                if HasExternalChangeForSave(i) == false
                   and WriteExistingTextAtomically(doc.filePath, doc.content,
                                                   doc.lastModifiedOnDisk,
                                                   doc.lastSizeOnDisk,
                                                   doc.lastContentHashOnDisk) {
                    doc.isModified = false;
                    RefreshDiskMetadataFromKnownText(doc, doc.content);
                    ClearExternalState(doc);
                    count = count + 1;
                }
            }
            i = i + 1;
        }
        return count;
    }

    /// @brief Replace an existing file through the runtime transactional edit path.
    /// @details `Zanna.Workspace.Edit.ApplyInRoot` validates the current file,
    ///          stages a same-directory temporary file, commits with rename, and
    ///          rolls back if a later target fails. DocumentManager uses it for
    ///          ordinary saves so a failed write does not leave a truncated file.
    /// @param path Existing file to replace.
    /// @param content Complete new file contents.
    /// @return true when the runtime reports a successful replacement.
    hide func WriteExistingTextAtomically(path: String,
                                          content: String,
                                          expectedMtime: Integer,
                                          expectedSize: Integer,
                                          expectedHash: String) -> Boolean {
        if path == "" or IO.File.Exists(path) == false { return false; }
        var root = Path.Directory(path);
        if root == "" { return false; }
        var beforeMtime = safe_io.Modified(path);
        var beforeSize = safe_io.SizeBytes(path);
        if beforeMtime < 0 or beforeSize < 0 { return false; }
        if expectedMtime >= 0 and beforeMtime != expectedMtime { return false; }
        if expectedSize >= 0 and beforeSize != expectedSize { return false; }
        var readResult = safe_io.ReadAllTextBounded(path,
                                                    MAX_TEXT_OPEN_BYTES);
        if readResult.ok == false { return false; }
        var existingText = readResult.text;
        if IO.File.Exists(path) == false
           or safe_io.Modified(path) != beforeMtime
           or safe_io.SizeBytes(path) != beforeSize {
            return false;
        }
        if expectedHash != "" and Hash.Sha256(existingText) != expectedHash {
            return false;
        }

        var edit = Map.New();
        Map.SetStr(edit, "file", Path.Name(path));
        Map.SetInt(edit, "startLine", 1);
        Map.SetInt(edit, "startColumn", 1);
        Map.SetInt(edit, "endLine", EndLineForText(existingText));
        Map.SetInt(edit, "endColumn", EndColumnForText(existingText));
        Map.SetStr(edit, "newText", content);
        Map.SetInt(edit, "expectedMtime", beforeMtime);
        Map.SetInt(edit, "expectedSize", beforeSize);

        var edits = Seq.New();
        Seq.Push(edits, edit);
        var result = WorkspaceEdit.ApplyInRoot(edits, root);
        return Map.GetBool(result, "success");
    }

    /// @brief Persist Save As content without mutating document state first.
    /// @details Existing targets use the same transactional replacement path as
    ///          ordinary saves. New targets are written through a same-directory
    ///          temporary file and then moved into place so a failed write does
    ///          not leave the requested destination partially populated.
    /// @param path Destination path chosen by the user.
    /// @param content Complete text to save.
    /// @return True when the destination now contains @p content.
    hide func WriteTextForSaveAs(path: String, content: String) -> Boolean {
        if path == "" { return false; }
        if IO.File.Exists(path) {
            return WriteExistingTextAtomically(path, content, -1, -1, "");
        }
        return WriteNewTextAtomically(path, content);
    }

    /// @brief Atomically create a destination that is still absent.
    /// @details A final existence check avoids turning a Save As/create race
    ///          into an overwrite. `File.Move` itself is no-replace on every
    ///          supported platform.
    hide func WriteNewTextAtomically(path: String, content: String) -> Boolean {
        if path == "" or IO.File.Exists(path) { return false; }
        var dir = Path.Directory(path);
        if dir == "" { return false; }
        var tempPath = safe_io.SiblingTempPath(path, "save");
        if tempPath == "" { return false; }
        if safe_io.WriteAllText(tempPath, content) == false {
            safe_io.DeleteFile(tempPath);
            return false;
        }
        if IO.File.Exists(path) {
            safe_io.DeleteFile(tempPath);
            return false;
        }
        if safe_io.MoveFile(tempPath, path) == false or IO.File.Exists(path) == false {
            safe_io.DeleteFile(tempPath);
            return false;
        }
        return true;
    }

    /// @brief Refresh a document's saved on-disk metadata after load/save.
    /// @details External-change detection compares both timestamp and size, so
    ///          every successful disk synchronization must update both fields.
    /// @param doc Document whose `filePath` points at the synchronized file.
    hide func RefreshDiskMetadata(doc: document.Document) {
        if doc == null or doc.filePath == "" or IO.File.Exists(doc.filePath) == false {
            return;
        }
        var diskText = "";
        if doc.isReadOnlyPreview == false and IsEditableTextFile(doc.filePath) {
            var readResult = safe_io.ReadAllTextBounded(doc.filePath,
                                                        MAX_TEXT_OPEN_BYTES);
            if readResult.ok { diskText = readResult.text; }
        }
        RefreshDiskMetadataFromKnownText(doc, diskText);
    }

    /// @brief Refresh metadata from text already known to match the disk file.
    hide func RefreshDiskMetadataFromKnownText(doc: document.Document,
                                               diskText: String) {
        if doc == null or doc.filePath == "" or IO.File.Exists(doc.filePath) == false {
            return;
        }
        var modified = safe_io.Modified(doc.filePath);
        var size = safe_io.SizeBytes(doc.filePath);
        if modified < 0 or size < 0 {
            doc.lastModifiedOnDisk = 0;
            doc.lastSizeOnDisk = 0;
            doc.lastContentHashOnDisk = "";
            return;
        }
        doc.lastModifiedOnDisk = modified;
        doc.lastSizeOnDisk = size;
        doc.lastContentHashOnDisk = "";
        if doc.isReadOnlyPreview == false {
            doc.lastContentHashOnDisk = Hash.Sha256(diskText);
        }
    }

    /// @brief Clear all remembered external-disk conflict state for @p doc.
    /// @details Called after successful load, reload, save, and path retargeting.
    hide func ClearExternalState(doc: document.Document) {
        if doc == null { return; }
        doc.externalChangeNotified = false;
        doc.externalState = document.EXTERNAL_STATE_CLEAN;
        doc.externalMessage = "";
    }

    /// @brief Compute the last 1-based line number for a full-file edit range.
    /// @details This string-based form lets save operations read the old file
    ///          once and derive both end coordinates from the same snapshot.
    /// @param text Current file contents.
    /// @return Last line number in the runtime workspace-edit coordinate system.
    hide func EndLineForText(text: String) -> Integer {
        var lines = Str.Split(text, "\n");
        var count = Seq.get_Count(lines);
        if count <= 0 { return 1; }
        return count;
    }

    /// @brief Compute the exclusive end column for a full-file edit range.
    /// @details Uses the last line of an already-read file snapshot so callers
    ///          avoid a second full-file read during ordinary save operations.
    /// @param text Current file contents.
    /// @return Exclusive 1-based end column for the final line.
    hide func EndColumnForText(text: String) -> Integer {
        var lines = Str.Split(text, "\n");
        var count = Seq.get_Count(lines);
        if count <= 0 { return 1; }
        var last = Obj.ToString(Seq.Get(lines, count - 1));
        return Str.get_Length(last) + 1;
    }

    expose func HasExternalChange(index: Integer) -> Boolean {
        return ExternalState(index) != document.EXTERNAL_STATE_CLEAN;
    }

    /// @brief Strong save-time external-change check including content identity.
    /// @details Polling uses timestamp/size for responsiveness. A manual or
    ///          automatic save also hashes the current bounded text so same-size,
    ///          same-timestamp rewrites cannot be silently overwritten.
    expose func HasExternalChangeForSave(index: Integer) -> Boolean {
        return ExternalStateForSave(index) != document.EXTERNAL_STATE_CLEAN;
    }

    /// @brief Return the strong disk state used immediately before saving.
    expose func ExternalStateForSave(index: Integer) -> Integer {
        var state = ExternalState(index);
        if state != document.EXTERNAL_STATE_CLEAN { return state; }
        if index < 0 or index >= documents.count() { return state; }
        var doc = documents.get(index);
        if doc == null or doc.isNew or doc.filePath == ""
           or doc.lastContentHashOnDisk == "" {
            return state;
        }
        if IsEditableTextFile(doc.filePath) == false {
            return document.EXTERNAL_STATE_CHANGED;
        }
        var readResult = safe_io.ReadAllTextBounded(doc.filePath,
                                                    MAX_TEXT_OPEN_BYTES);
        if readResult.ok == false
           or Hash.Sha256(readResult.text) != doc.lastContentHashOnDisk {
            return document.EXTERNAL_STATE_CHANGED;
        }
        return state;
    }

    /// @brief Return the current disk state for an open document.
    /// @details The probe considers explicit watcher hints first, then verifies
    ///          whether the path exists and whether its timestamp or size changed.
    expose func ExternalState(index: Integer) -> Integer {
        if index < 0 or index >= documents.count() { return document.EXTERNAL_STATE_CLEAN; }
        var doc = documents.get(index);
        if doc == null or doc.isNew or doc.filePath == "" { return document.EXTERNAL_STATE_CLEAN; }
        if doc.externalState != document.EXTERNAL_STATE_CLEAN {
            return doc.externalState;
        }
        if IO.File.Exists(doc.filePath) == false {
            return document.EXTERNAL_STATE_MISSING;
        }
        if doc.lastModifiedOnDisk > 0 {
            var current = safe_io.Modified(doc.filePath);
            var currentSize = safe_io.SizeBytes(doc.filePath);
            if current < 0 or currentSize < 0 {
                return document.EXTERNAL_STATE_CHANGED;
            }
            if current != doc.lastModifiedOnDisk or currentSize != doc.lastSizeOnDisk {
                return document.EXTERNAL_STATE_CHANGED;
            }
        }
        return document.EXTERNAL_STATE_CLEAN;
    }

    /// @brief Mark an open document with a watcher-derived disk state.
    expose func MarkExternalState(index: Integer,
                                  state: Integer,
                                  message: String) {
        if index < 0 or index >= documents.count() { return; }
        var doc = documents.get(index);
        if doc == null { return; }
        doc.externalState = state;
        doc.externalMessage = message;
        doc.externalChangeNotified = true;
    }

    /// @brief Refresh and remember the current disk state for @p index.
    /// @return The state after probing.
    expose func RefreshExternalState(index: Integer,
                                     hintedState: Integer,
                                     message: String) -> Integer {
        if index < 0 or index >= documents.count() { return document.EXTERNAL_STATE_CLEAN; }
        var doc = documents.get(index);
        if doc == null or doc.isNew or doc.filePath == "" { return document.EXTERNAL_STATE_CLEAN; }
        if hintedState != document.EXTERNAL_STATE_CLEAN {
            MarkExternalState(index, hintedState, message);
            return hintedState;
        }
        var state = ExternalState(index);
        if state == document.EXTERNAL_STATE_CLEAN {
            ClearExternalState(doc);
        } else {
            MarkExternalState(index, state, message);
        }
        return state;
    }

    /// @brief User-facing label for the current external disk state.
    expose func ExternalStateMessage(index: Integer) -> String {
        if index < 0 or index >= documents.count() { return ""; }
        var doc = documents.get(index);
        if doc == null { return ""; }
        if doc.externalMessage != "" { return doc.externalMessage; }
        var state = ExternalState(index);
        if state == document.EXTERNAL_STATE_CHANGED {
            return doc.fileName + " changed on disk";
        }
        if state == document.EXTERNAL_STATE_DELETED {
            return doc.fileName + " was deleted on disk";
        }
        if state == document.EXTERNAL_STATE_RENAMED {
            return doc.fileName + " was renamed or moved on disk";
        }
        if state == document.EXTERNAL_STATE_MISSING {
            return doc.fileName + " is missing on disk";
        }
        return "";
    }

    /// @brief Reload an existing document through the same safety rules as OpenFile.
    /// @details Binary and oversized files remain read-only previews on reload
    ///          instead of bypassing the open guard and reading the full payload.
    /// @param index Document index to reload from disk.
    /// @return true when the document was refreshed; false for invalid, new, or missing files.
    expose func ReloadDocument(index: Integer) -> Boolean {
        if index < 0 or index >= documents.count() { return false; }
        var doc = documents.get(index);
        if doc.isNew { return false; }
        if IO.File.Exists(doc.filePath) == false { return false; }
        doc.language = file_utils.DetectLanguage(doc.filePath);
        doc.kind = file_utils.DetectKind(doc.filePath);
        var blockReason = TextOpenBlockReason(doc.filePath);
        if blockReason != "" {
            doc.isReadOnlyPreview = true;
            doc.content = BlockedPreviewText(doc.filePath, blockReason);
        } else {
            var readResult = safe_io.ReadAllTextBounded(doc.filePath,
                                                        MAX_TEXT_OPEN_BYTES);
            if readResult.ok == false { return false; }
            doc.isReadOnlyPreview = false;
            doc.content = readResult.text;
        }
        RefreshDiskMetadataFromKnownText(doc, doc.content);
        doc.isModified = false;
        ClearExternalState(doc);
        return true;
    }

    /// @brief Format a non-editable tab without embedding untrusted file bytes.
    hide func BlockedPreviewText(path: String, reason: String) -> String {
        var message = reason;
        if message == "" { message = "This file is not available in the text editor."; }
        if Str.StartsWith(reason, "Binary") {
            message = "Binary preview is not available for this file.";
        }
        if Str.StartsWith(reason, "Files larger") {
            message = "This file is too large to open in the text editor.";
        }
        var size = safe_io.SizeBytes(path);
        var details = message + "\n\nPath: " + path + "\n";
        if size > MAX_TEXT_OPEN_BYTES {
            details = details + "Size: " + size + " bytes\n"
                + "Limit: " + MAX_TEXT_OPEN_BYTES + " bytes\n";
        }
        return details;
    }

    expose func UpdatePath(oldPath: String, newPath: String) -> Boolean {
        if RetargetBlockReason(oldPath, newPath, false) != "" { return false; }
        var idx = FindByPath(oldPath);
        if idx >= 0 {
            RetargetDocument(documents.get(idx), newPath);
        }
        var recentChanged = UpdateRecentlyClosedPath(oldPath, newPath);
        return idx >= 0 or recentChanged;
    }

    expose func UpdatePathPrefix(oldPrefix: String, newPrefix: String) -> Integer {
        if oldPrefix == "" or newPrefix == "" { return 0; }
        if RetargetBlockReason(oldPrefix, newPrefix, true) != "" { return 0; }
        var normalizedOldPrefix = NormalizeDocumentPath(oldPrefix);
        var normalizedNewPrefix = NormalizeDocumentPath(newPrefix);
        var changed = 0;
        var prefix = normalizedOldPrefix + Path.Separator();
        var i = 0;
        while i < documents.count() {
            var doc = documents.get(i);
            if doc.filePath == normalizedOldPrefix {
                RetargetDocument(doc, normalizedNewPrefix);
                changed = changed + 1;
            } else if Str.StartsWith(doc.filePath, prefix) {
                var suffix = Str.Mid(doc.filePath, Str.get_Length(prefix) + 1);
                RetargetDocument(doc, Path.Join(normalizedNewPrefix, suffix));
                changed = changed + 1;
            }
            i = i + 1;
        }
        return changed + UpdateRecentlyClosedPrefix(normalizedOldPrefix, normalizedNewPrefix);
    }

    /// @brief Explain why an Explorer move/rename cannot safely retarget tabs.
    /// @details Physical destination checks are insufficient when another open
    ///          tab owns a path whose file is temporarily missing. File renames
    ///          to a known binary-only extension are also rejected while open so
    ///          an unsaved editable buffer cannot become stranded.
    /// @param oldPath Existing file or directory prefix being moved.
    /// @param newPath Proposed replacement path/prefix.
    /// @param isDirectory True when every open descendant would be retargeted.
    /// @return Empty when safe, otherwise a user-facing rejection reason.
    expose func RetargetBlockReason(oldPath: String,
                                    newPath: String,
                                    isDirectory: Boolean) -> String {
        if oldPath == "" or newPath == "" { return "Invalid rename path."; }
        var normalizedOld = NormalizeDocumentPath(oldPath);
        var normalizedNew = NormalizeDocumentPath(newPath);

        if isDirectory == false {
            var sourceIndex = FindByPath(normalizedOld);
            var destinationIndex = FindByPath(normalizedNew);
            if destinationIndex >= 0 and destinationIndex != sourceIndex {
                return "The destination is already open in another tab.";
            }
            if sourceIndex >= 0
               and file_utils.DetectKind(normalizedNew)
                   == file_utils.DOC_KIND_BINARY_UNSUPPORTED {
                return "Close the open file before renaming it to a binary extension.";
            }
            return "";
        }

        var oldPrefix = normalizedOld + Path.Separator();
        var i = 0;
        while i < documents.count() {
            var sourceDoc = documents.get(i);
            if sourceDoc.filePath == normalizedOld
               or Str.StartsWith(sourceDoc.filePath, oldPrefix) {
                var mappedPath = normalizedNew;
                if sourceDoc.filePath != normalizedOld {
                    var suffix = Str.Mid(sourceDoc.filePath, Str.get_Length(oldPrefix) + 1);
                    mappedPath = Path.Join(normalizedNew, suffix);
                }
                var destinationIndex = FindByPath(mappedPath);
                if destinationIndex >= 0 and destinationIndex != i {
                    var destinationDoc = documents.get(destinationIndex);
                    if destinationDoc.filePath != normalizedOld
                       and Str.StartsWith(destinationDoc.filePath, oldPrefix) == false {
                        return "A destination path is already open in another tab.";
                    }
                }
            }
            i = i + 1;
        }
        return "";
    }

    expose func ForgetPathsUnder(path: String) -> Integer {
        if path == "" { return 0; }
        var normalizedPath = NormalizeDocumentPath(path);
        var removed = 0;
        var prefix = normalizedPath + Path.Separator();
        var i = 0;
        while i < recentlyClosedPaths.count() {
            var recent = Obj.ToString(recentlyClosedPaths.get(i));
            if recent == normalizedPath or Str.StartsWith(recent, prefix) {
                recentlyClosedPaths.removeAt(i);
                removed = removed + 1;
            } else {
                i = i + 1;
            }
        }
        return removed;
    }

    /// @brief Close the document at the given index.
    /// @param index 0-based index into `documents`.
    /// @return true if closed, false if index was out of range.
    /// @note Keeps the same document active when closing tabs to its left.
    ///       If the closed document was active, keeps the same visual slot
    ///       when possible, or clamps to the last tab.
    expose func CloseDocument(index: Integer) -> Boolean {
        if index < 0 or index >= documents.count() { return false; }
        var wasActive = index == activeIndex;
        var closingDoc = documents.get(index);
        if closingDoc.filePath != "" {
            RecordRecentlyClosed(closingDoc.filePath);
        }
        documents.removeAt(index);
        if documents.count() == 0 {
            activeIndex = -1;
        } else if wasActive {
            if activeIndex >= documents.count() {
                activeIndex = documents.count() - 1;
            }
        } else if index < activeIndex {
            activeIndex = activeIndex - 1;
        } else if activeIndex >= documents.count() {
            activeIndex = documents.count() - 1;
        }
        return true;
    }

    /// @brief Get the active document or null if there is none.
    expose func GetActive() -> document.Document? {
        if activeIndex < 0 or activeIndex >= documents.count() { return null; }
        return documents.get(activeIndex);
    }

    /// @brief Get a document by index, or null if out of range.
    expose func GetDocument(index: Integer) -> document.Document? {
        if index < 0 or index >= documents.count() { return null; }
        return documents.get(index);
    }

    /// @brief Set the active document by index. Out-of-range is a no-op.
    /// @brief Move a document to a new position (tab drag-reorder; plan 07).
    /// @details Mirrors the TabBar's visual reorder so tab indexes and
    ///          document indexes stay aligned; the active document follows
    ///          its new position.
    /// @param from Source index.
    /// @param to Destination index.
    expose func MoveDocument(from: Integer, to: Integer) {
        var count = documents.count();
        if from < 0 or from >= count or to < 0 or to >= count or from == to {
            return;
        }
        var activeDoc = GetActive();
        var moved = documents.get(from);
        documents.removeAt(from);
        documents.insert(to, moved);
        if activeDoc != null {
            var i = 0;
            while i < documents.count() {
                if documents.get(i) == activeDoc {
                    activeIndex = i;
                    i = documents.count();
                } else {
                    i = i + 1;
                }
            }
        }
    }

    expose func SetActive(index: Integer) {
        if index >= 0 and index < documents.count() {
            activeIndex = index;
        }
    }

    /// @brief Return the tab index that owns `doc`, using object identity.
    /// @return Index in `documents`, or -1 when the document is not open.
    expose func IndexOfDocument(doc: document.Document) -> Integer {
        if doc == null { return -1; }
        var i = 0;
        while i < documents.count() {
            if documents.get(i) == doc { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Make an owned Document active without relying on a path.
    /// @details Object identity also supports untitled documents, whose empty
    ///          paths cannot be resolved through FindByPath.
    /// @return Activated index, or -1 when `doc` is not owned by this manager.
    expose func SetActiveDocument(doc: document.Document) -> Integer {
        var index = IndexOfDocument(doc);
        if index >= 0 { activeIndex = index; }
        return index;
    }

    /// @brief Linear search for a document by filePath.
    /// @return Index, or -1 if not found.
    expose func FindByPath(path: String) -> Integer {
        if path == "" { return -1; }
        var target = NormalizeDocumentPath(path);
        var i = 0;
        while i < documents.count() {
            var doc = documents.get(i);
            if PathsReferToSameFile(doc.filePath, target) { return i; }
            i = i + 1;
        }
        return -1;
    }

    /// @brief Compare lexical paths first, then stable identity for existing files.
    /// @details The identity fallback de-duplicates case-equivalent paths,
    ///          symlinks, and hard links without case-folding distinct files on
    ///          case-sensitive filesystems. Missing files retain lexical
    ///          behavior so externally deleted documents remain addressable.
    hide func PathsReferToSameFile(left: String, right: String) -> Boolean {
        if left == "" or right == "" { return false; }
        var normalizedLeft = NormalizeDocumentPath(left);
        var normalizedRight = NormalizeDocumentPath(right);
        if normalizedLeft == normalizedRight { return true; }
        return IO.File.SameFile(normalizedLeft, normalizedRight);
    }

    /// @brief Normalize document paths for tab de-duplication and lookup.
    /// @details The editor receives paths from dialogs, diagnostics, sessions,
    ///          and project search. Lexical normalization avoids duplicate tabs
    ///          for equivalent spellings of the same file.
    /// @param path Path spelling to normalize.
    /// @return Absolute normalized path or an empty string.
    hide func NormalizeDocumentPath(path: String) -> String {
        if path == "" { return ""; }
        return Path.Normalize(Path.Absolute(path));
    }

    /// @brief Number of open documents.
    expose func GetCount() -> Integer {
        return documents.count();
    }

    expose func RecentlyClosedCount() -> Integer {
        return recentlyClosedPaths.count();
    }

    expose func RecentlyClosedAt(index: Integer) -> String {
        if index < 0 or index >= recentlyClosedPaths.count() { return ""; }
        return Obj.ToString(recentlyClosedPaths.get(index));
    }

    expose func PopRecentlyClosedPath() -> String {
        while recentlyClosedPaths.count() > 0 {
            var path = Obj.ToString(recentlyClosedPaths.get(0));
            recentlyClosedPaths.removeAt(0);
            if path != "" and IO.File.Exists(path) {
                return path;
            }
        }
        return "";
    }

    hide func RecordRecentlyClosed(path: String) {
        if path == "" { return; }
        var normalizedPath = NormalizeDocumentPath(path);
        var i = 0;
        while i < recentlyClosedPaths.count() {
            if PathsReferToSameFile(
                   Obj.ToString(recentlyClosedPaths.get(i)), normalizedPath) {
                recentlyClosedPaths.removeAt(i);
            } else {
                i = i + 1;
            }
        }
        recentlyClosedPaths.insert(0, normalizedPath);
        while recentlyClosedPaths.count() > 20 {
            recentlyClosedPaths.removeAt(recentlyClosedPaths.count() - 1);
        }
    }

    hide func RetargetDocument(doc: document.Document, newPath: String) {
        var canonicalPath = NormalizeDocumentPath(newPath);
        doc.filePath = canonicalPath;
        doc.fileName = Path.Name(canonicalPath);
        doc.language = file_utils.DetectLanguage(canonicalPath);
        doc.kind = file_utils.DetectKind(canonicalPath);
        RefreshDiskMetadata(doc);
        ClearExternalState(doc);
    }

    hide func UpdateRecentlyClosedPath(oldPath: String, newPath: String) -> Boolean {
        if oldPath == "" or newPath == "" { return false; }
        var normalizedOldPath = NormalizeDocumentPath(oldPath);
        var normalizedNewPath = NormalizeDocumentPath(newPath);
        var changed = false;
        var i = 0;
        while i < recentlyClosedPaths.count() {
            if PathsReferToSameFile(
                   Obj.ToString(recentlyClosedPaths.get(i)), normalizedOldPath) {
                recentlyClosedPaths.removeAt(i);
                recentlyClosedPaths.insert(i, normalizedNewPath);
                changed = true;
            }
            i = i + 1;
        }
        return changed;
    }

    hide func UpdateRecentlyClosedPrefix(oldPrefix: String, newPrefix: String) -> Integer {
        var normalizedOldPrefix = NormalizeDocumentPath(oldPrefix);
        var normalizedNewPrefix = NormalizeDocumentPath(newPrefix);
        var changed = 0;
        var prefix = normalizedOldPrefix + Path.Separator();
        var i = 0;
        while i < recentlyClosedPaths.count() {
            var recent = Obj.ToString(recentlyClosedPaths.get(i));
            if recent == normalizedOldPrefix {
                recentlyClosedPaths.removeAt(i);
                recentlyClosedPaths.insert(i, normalizedNewPrefix);
                changed = changed + 1;
            } else if Str.StartsWith(recent, prefix) {
                var suffix = Str.Mid(recent, Str.get_Length(prefix) + 1);
                recentlyClosedPaths.removeAt(i);
                recentlyClosedPaths.insert(i, Path.Join(normalizedNewPrefix, suffix));
                changed = changed + 1;
            }
            i = i + 1;
        }
        return changed;
    }
}
