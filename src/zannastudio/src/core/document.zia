//
// File: zannastudio/src/core/document.zia
// Purpose: Store one Studio document, disk baseline, and per-surface view state.
// Key invariants:
//   - Named documents retain metadata and a content hash from one disk version.
//   - Untitled documents never claim an on-disk baseline.
//   - Editor and scene workspace state belongs to its document, never to the
//     shared widget controller that happens to display the active tab.
// Ownership/Lifetime:
//   - DocumentManager owns instances for the lifetime of their editor tabs.
// Links: zannastudio/src/core/document_manager.zia
//
//===----------------------------------------------------------------------===//

module document;

// ============================================================================
// MODULE: document
// PURPOSE: Plain-data record representing one open file and its tab-local
//          editor or visual-scene workspace state.
//
// WHERE-THIS-FITS: DocumentManager owns these records and synchronizes the
//          active one with shared editor/scene controllers.
//
// KEY-DESIGN-CHOICES:
//   * PUBLIC DATA RECORD. DocumentManager and controllers maintain invariants.
//   * EMPTY filePath SIGNALS UNTITLED. Named files always have disk metadata.
//   * VIEW STATE FOLLOWS THE TAB. Shared controllers cannot leak camera,
//     selection, transform-tool, or inspector state between documents.
//   * DISK BASELINES PROTECT SAVES. Metadata plus content hash detect changes.
// ============================================================================

bind "../services/file_utils";

bind Zanna.GUI as GUI;

final EXTERNAL_STATE_CLEAN = 0;
final EXTERNAL_STATE_CHANGED = 1;
final EXTERNAL_STATE_DELETED = 2;
final EXTERNAL_STATE_RENAMED = 3;
final EXTERNAL_STATE_MISSING = 4;

/// @brief Per-document 2D authoring state retained across tab switches.
/// @details Undo snapshots are intentionally process-local. The bounded scalar
///          view fields may be serialized by SessionManager.
class Scene2DWorkspaceState {
    expose Boolean initialized;
    expose Integer mode;
    expose Integer zoomPercent;
    expose Integer activeLayer;
    expose Integer selectedObject;
    expose List[Integer] selectedObjects;
    expose Integer selectedObjectProperty;
    expose Integer selectedCellX;
    expose Integer selectedCellY;
    expose Integer tileId;
    expose Number splitPosition;
    expose Number canvasScrollX;
    expose Number canvasScrollY;
    expose Number inspectorScrollY;
    expose Boolean inspectorRequestedVisible;
    expose Boolean compactInspectorShown;
    expose List[String] undoStack;
    expose List[String] redoStack;
    expose String cleanSerialized;
    expose String historyContent;

    expose func init() {
        initialized = false;
        mode = 0;
        zoomPercent = 100;
        activeLayer = 0;
        selectedObject = -1;
        selectedObjects = [];
        selectedObjectProperty = -1;
        selectedCellX = -1;
        selectedCellY = -1;
        tileId = 1;
        splitPosition = 0.68;
        canvasScrollX = 0.0;
        canvasScrollY = 0.0;
        inspectorScrollY = 0.0;
        inspectorRequestedVisible = true;
        compactInspectorShown = false;
        undoStack = [];
        redoStack = [];
        cleanSerialized = "";
        historyContent = "";
    }
}

/// @brief Per-document 3D hierarchy, camera, inspector, and history state.
/// @details Camera targets remain Numbers in memory; SessionManager stores them
///          as validated fixed-point integers to avoid locale-sensitive text.
class Scene3DWorkspaceState {
    expose Boolean initialized;
    expose Integer selectedIndex;
    expose List[Integer] selectedIndices;
    expose Integer transformMode;
    expose Boolean transformSnapEnabled;
    expose Integer viewYawDegrees;
    expose Integer viewPitchDegrees;
    expose Integer viewScale;
    expose Number viewTargetX;
    expose Number viewTargetY;
    expose Number viewTargetZ;
    expose Number splitPosition;
    expose Number inspectorScrollY;
    expose Boolean inspectorRequestedVisible;
    expose Boolean compactInspectorShown;
    expose List[String] undoStack;
    expose List[String] redoStack;
    expose String cleanSerialized;
    expose String historyContent;

    expose func init() {
        initialized = false;
        selectedIndex = -1;
        selectedIndices = [];
        transformMode = 0;
        transformSnapEnabled = false;
        viewYawDegrees = 35;
        viewPitchDegrees = -25;
        viewScale = 28;
        viewTargetX = 0.0;
        viewTargetY = 0.0;
        viewTargetZ = 0.0;
        splitPosition = 0.65;
        inspectorScrollY = 0.0;
        inspectorRequestedVisible = true;
        compactInspectorShown = false;
        undoStack = [];
        redoStack = [];
        cleanSerialized = "";
        historyContent = "";
    }
}

/// @brief Single open file in the editor. One per tab.
class Document {
    expose String filePath;            // Absolute path; "" for untitled.
    expose String fileName;            // Display name in the tab.
    expose String content;             // Full text snapshot (kept in sync on save/switch).
    expose GUI.EditorBuffer buffer;    // Detached editor state while inactive; null when active
                                       // (content lives in the shared editor widget) or unopened.
    expose String language;            // "zia", "basic", "text".
    expose Integer kind;               // file_utils.KIND_* document surface kind.
    expose Boolean isModified;         // Has unsaved changes.
    expose Boolean isNew;              // Never saved to disk.
    expose Boolean isReadOnlyPreview;  // True for binary/large-file preview tabs.
    expose Integer cursorLine;         // Last known cursor line (1-based).
    expose Integer cursorCol;          // Last known cursor column (1-based).
    expose Integer scrollLine;         // Last known top-of-viewport line.
    expose Integer lastModifiedOnDisk; // Timestamp from Zanna.IO.File.Modified.
    expose Integer lastSizeOnDisk;     // Size from Zanna.IO.File.Size.
    expose String lastContentHashOnDisk; // SHA-256 of the synchronized disk text.
    expose Boolean externalChangeNotified; // True after surfacing an on-disk change.
    expose Integer externalState;      // EXTERNAL_STATE_* disk state.
    expose String externalMessage;     // Last user-facing disk-state detail.
    expose Boolean hasPendingWorkspaceUndo; // Inactive workspace edit can be undone on activation.
    expose String pendingWorkspaceUndoContent; // Snapshot before the pending workspace edit.
    expose String pendingWorkspaceUndoLabel;   // User-facing name of the pending edit.
    expose Scene2DWorkspaceState scene2DWorkspace; // Per-tab 2D canvas/inspector state.
    expose Scene3DWorkspaceState scene3DWorkspace; // Per-tab 3D camera/inspector state.

    /// @brief Initialize as an untitled, empty, plain-text document.
    expose func init() {
        filePath = "";
        fileName = "Untitled";
        content = "";
        buffer = null;
        language = "text";
        kind = file_utils.DOC_KIND_TEXT;
        isModified = false;
        isNew = true;
        isReadOnlyPreview = false;
        cursorLine = 1;
        cursorCol = 1;
        scrollLine = 1;
        lastModifiedOnDisk = 0;
        lastSizeOnDisk = 0;
        lastContentHashOnDisk = "";
        externalChangeNotified = false;
        externalState = EXTERNAL_STATE_CLEAN;
        externalMessage = "";
        hasPendingWorkspaceUndo = false;
        pendingWorkspaceUndoContent = "";
        pendingWorkspaceUndoLabel = "";
        scene2DWorkspace = new Scene2DWorkspaceState();
        scene3DWorkspace = new Scene3DWorkspaceState();
    }
}
