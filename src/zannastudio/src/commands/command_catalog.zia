module command_catalog;

bind Str = Zanna.String;

// ============================================================================
// MODULE: command_catalog
// PURPOSE: Declarative command metadata for Zanna Studio. This module owns the
//          static list of command ids, labels, shortcuts, capabilities, and
//          palette visibility so CommandRegistry can focus on runtime behavior.
//
// WHERE-THIS-FITS: commands/command_registry.zia imports this file during
//          startup, converts each CommandSpec into a CommandEntry, and then
//          applies language-service capability checks and shortcut wiring.
//
// TEACHING-NOTE: Add new commands here first. Keeping command declarations in
//          one small data module makes it easy to review command ids and avoids
//          burying metadata inside palette or shortcut implementation code.
// ============================================================================

/// @brief Static metadata for a command known to Zanna Studio.
/// @details CommandSpec deliberately contains no runtime state. The registry
///          copies these fields into CommandEntry objects and applies runtime
///          language-service availability checks there. Category is stored here
///          because it is command metadata, not registry behavior.
class CommandSpec {
    expose String id;
    expose String label;
    expose String description;
    expose String category;
    expose String shortcut;
    expose String capability;
    expose Boolean showInPalette;

    /// @brief Initialize an empty command specification.
    /// @details Fields are populated by AddSpec so each catalog entry can be
    ///          read as a compact one-line declaration.
    expose func init() {
        id = "";
        label = "";
        description = "";
        category = "";
        shortcut = "";
        capability = "";
        showInPalette = true;
    }
}

/// @brief Return the full built-in command catalog in registration order.
/// @details Registration order is user visible in a few places: shortcut
///          conflict reporting, command palette ordering, and probe output.
///          Preserve the existing order unless there is a deliberate UI reason
