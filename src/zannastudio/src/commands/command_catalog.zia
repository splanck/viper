/// @brief Append one command specification to the catalog list.
/// @param specs Mutable list that receives the command specification.
/// @param id Stable command id used by shortcut dispatch and command handlers.
/// @param label Human-readable command name shown in the palette.
/// @param description Short explanatory text for future UI/help surfaces.
/// @param shortcut Default keyboard shortcut, or an empty string when unset.
/// @param capability Language-service capability required to enable the command.
/// @param showInPalette Whether the command should appear in the command palette.
/// @details This helper keeps each catalog row concise while still assigning
///          every field explicitly. That is easier to teach and review than
///          positional object construction sprinkled through registry code.
func AddSpec(specs: List[CommandSpec],
             id: String,
             label: String,
             description: String,
             shortcut: String,
             capability: String,
             showInPalette: Boolean) {
    var spec = new CommandSpec();
    spec.id = id;
    spec.label = label;
    spec.description = description;
    spec.category = CategoryForCommand(id);
    spec.shortcut = shortcut;
    spec.capability = capability;
    spec.showInPalette = showInPalette;
    specs.add(spec);
}

/// @brief Return the command-palette category for a command id.
/// @details Categories are part of the command catalog because they are static
///          command metadata. Keeping this classifier next to DefaultCommandSpecs
///          lets developers review ids, labels, shortcuts, capabilities, and
///          palette grouping in one place before they touch runtime dispatch.
/// @param id Stable command id from the catalog.
/// @return Palette category name such as File, Edit, Build, or Debug.
expose func CategoryForCommand(id: String) -> String {
    if id == "new" or id == "open" or id == "openfolder"
       or id == "save" or id == "saveas" or id == "saveall"
       or id == "close" or id == "reload" or id == "recentfiles"
       or id == "reopenclosed" {
        return "File";
    }
    if id == "find" or id == "searchproject" {
        return "Search";
    }
    if id == "quickopen" or id == "goto" or id == "gotodef"
       or id == "findrefs" or id == "incomingcalls" or id == "outgoingcalls"
       or id == "nexterror" or id == "preverror" or id == "workspacesymbols"
       or id == "symboloutline" or id == "signature_trigger"
       or id == "signaturenextoverload" or id == "signatureprevoverload" {
        return "Navigate";
    }
    if id == "rename" or id == "organizebinds" or id == "extractlocal"
       or id == "extractfunction" or id == "inlinelocal"
       or id == "suppressdiagnostic" or id == "applydiagnosticfix"
       or id == "createmissingbind" {
        return "Refactor";
    }
    if id == "build" or id == "buildrun" or id == "run" or id == "stopjob" {
        return "Build";
    }
    if Str.StartsWith(id, "debug") or id == "togglebreakpoint" {
        return "Debug";
    }
    if id == "togglesidebar" or id == "statusbar" or id == "zoomin"
       or id == "zoomout" or id == "zoomreset" or id == "uizoomin"
       or id == "uizoomout" or id == "uizoomreset"
       or id == "toggletheme" or id == "fullscreen" or id == "minimap"
       or id == "spliteditorright" or id == "focusotherpane" or id == "closesplit" {
        return "View";
    }
    if id == "settings" or id == "keybindings" {
        return "Settings";
    }
    if id == "copytoolrow" or id == "copyoutputtext" or id == "clearoutput"
       or id == "filteroutput" or id == "toggleoutputwrap"
       or id == "toggleoutputautoscroll" {
        return "Output";
    }
    if Str.StartsWith(id, "tree") {
        return "Explorer";
    }
    if id == "undo" or id == "redo" or id == "cut" or id == "copy"
       or id == "paste" or id == "selectall" or id == "completion_trigger"
       or id == "addnextoccurrence" or id == "skipoccurrence"
       or id == "selectalloccurrences" or id == "clearcursors"
       or id == "expandselection" or id == "shrinkselection"
       or id == "togglelinecomment" or id == "toggleblockcomment"
       or id == "duplicateline" or id == "movelineup" or id == "movelinedown"
       or id == "trimtrailingwhitespace" or id == "formatdocument"
       or id == "formatselection" {
        return "Edit";
    }
    return "Command";
}
