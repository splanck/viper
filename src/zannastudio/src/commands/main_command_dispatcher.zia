// ============================================================================
// MODULE: main_command_dispatcher
// PURPOSE: Route menu, toolbar, shortcut, and command-palette triggers.
//
// WHERE-THIS-FITS: main.zia owns frame sequencing and gathers the current
//          command-palette selection. This module owns the large command-routing
//          table that used to live inline in the entry point.
//
// TEACHING-NOTE: A command has three distinct pieces: catalog metadata,
//          handler implementation, and per-frame trigger routing. Keeping this
//          router separate makes it obvious where a command is registered,
//          where it runs, and how UI events reach it.
// ============================================================================

var currentDiagIdx = -1;
final PENDING_SEMANTIC_PUMP_FILES = 32;

var pendingSemanticCommand = "";
var pendingSemanticLabel = "";
var pendingSemanticPath = "";
var pendingSemanticLine = -1;
var pendingSemanticCol = -1;
var pendingSemanticRevision = -1;

/// @brief Dispatch all command triggers for one frame using legacy parameters.
/// @details This wrapper preserves existing probe and caller code while the
///          implementation moves toward the named CommandContext shape.
/// @param shell Workbench shell containing menu and toolbar widgets.
/// @param docMgr Open document manager.
/// @param projMgr Project/tree manager.
/// @param engine Active editor engine.
/// @param tabs Editor tab controller.
/// @param buildSys Build/run process controller.
/// @param dbgSession Active debug session.
/// @param terminalCtrl Integrated terminal controller.
/// @param fileWatchCtrl File-watch controller.
/// @param workspaceWatcherState Workspace watcher state passed to cleanup.
/// @param indexer Semantic project indexer.
/// @param breakpointStore Persistent breakpoint store.
/// @param sessionMgr Session persistence and recent-file manager.
/// @param locStore Structured location store.
/// @param commandRegistry Runtime command registry.
/// @param paletteCtrl Command-palette state controller.
/// @param explorerOverlay Non-modal explorer action overlay.
/// @param debugOverlay Non-modal breakpoint metadata overlay.
/// @param overlays Settings/About overlay controller.
/// @param liveDiag Live diagnostics controller.
/// @param symbolOutline Document symbol outline controller.
/// @param sigCtrl Signature help controller.
/// @param searcher Async project-search controller.
/// @param appSettings Current user settings.
/// @param cpSelected Normalized command-palette selection id for this frame.
/// @param suppressTreeOpen True when a tree right-click should not open a file.
/// @return True when cleanup has already run and the application should exit.
expose func DispatchCommands(shell: app_shell.AppShell,
                             docMgr: document_manager.DocumentManager,
                             projMgr: project_manager.ProjectManager,
                             engine: editor_engine.EditorEngine,
                             tabs: editor_tabs.EditorTabs,
                             buildSys: build_system.BuildSystem,
                             dbgSession: debug_session.DebugSession,
                             terminalCtrl: terminal_controller.TerminalController,
                             fileWatchCtrl: file_watch_controller.FileWatchController,
                             workspaceWatcherState: workspace_watcher.WorkspaceWatcherState,
                             indexer: project_index.ProjectIndexer,
                             breakpointStore: breakpoints.BreakpointStore,
                             sessionMgr: session.SessionManager,
                             locStore: locations.LocationStore,
                             commandRegistry: command_registry.CommandRegistry,
                             paletteCtrl: command_palette_controller.CommandPaletteController,
                             explorerOverlay: explorer_actions.ExplorerActionOverlay,
                             debugOverlay: debug_breakpoint_overlay.DebugBreakpointOverlay,
                             overlays: ide_overlays.IdeOverlays,
                             liveDiag: diagnostics.LiveDiagnostics,
                             symbolOutline: symbols.SymbolOutline,
                             sigCtrl: signature.SignatureController,
                             searcher: search_commands.SearchController,
                             appSettings: settings.SettingsManager,
                             cpSelected: String,
                             suppressTreeOpen: Boolean) -> Boolean {
    var ctx = new command_context.CommandContext();
    ctx.shell = shell;
    ctx.docMgr = docMgr;
    ctx.projMgr = projMgr;
    ctx.engine = engine;
    ctx.tabs = tabs;
    ctx.buildSys = buildSys;
    ctx.dbgSession = dbgSession;
    ctx.terminalCtrl = terminalCtrl;
    ctx.fileWatchCtrl = fileWatchCtrl;
    ctx.workspaceWatcherState = workspaceWatcherState;
    ctx.indexer = indexer;
    ctx.breakpointStore = breakpointStore;
    ctx.sessionMgr = sessionMgr;
    ctx.locStore = locStore;
    ctx.commandRegistry = commandRegistry;
    ctx.paletteCtrl = paletteCtrl;
    ctx.explorerOverlay = explorerOverlay;
    ctx.debugOverlay = debugOverlay;
    ctx.overlays = overlays;
    ctx.liveDiag = liveDiag;
    ctx.symbolOutline = symbolOutline;
    ctx.sigCtrl = sigCtrl;
    ctx.searcher = searcher;
    ctx.appSettings = appSettings;
    return DispatchCommandContext(ctx, cpSelected, suppressTreeOpen);
}

/// @brief Dispatch all command triggers for one frame.
/// @details Returns true only when the user confirmed application exit. The
///          entry point owns the one shared cleanup path so menu and native
///          window-close requests cannot diverge.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param cpSelected Normalized command-palette selection id for this frame.
/// @param suppressTreeOpen True when a tree right-click should not open a file.
/// @return True when clean shutdown should run and the application should exit.
expose func DispatchCommandContext(ctx: command_context.CommandContext,
                                   cpSelected: String,
                                   suppressTreeOpen: Boolean) -> Boolean {
    if command_context.IsReady(ctx) == false { return false; }

    if DispatchFileCommands(ctx, cpSelected) {
        return true;
    }

    PumpFileTreeOpen(ctx, suppressTreeOpen);
    PumpPendingSemanticCommand(ctx);
    if ctx.basicWorkspaceCommands != null {
        ctx.basicWorkspaceCommands.Pump(ctx.shell, ctx.docMgr, ctx.projMgr,
                                        ctx.engine, ctx.tabs, ctx.locStore);
    }
    DispatchEditCommands(ctx, cpSelected);
    DispatchViewSearchCommands(ctx, cpSelected);
    DispatchBuildDebugCommands(ctx, cpSelected);
    return false;
}

/// @brief Synchronize every workspace consumer after a folder-set change.
/// @details Folder opening is reachable from the welcome card, File menu,
///          command palette, multi-root command, session restore, and project
///          scaffolding. Keeping the fan-out here prevents one route from
///          leaving source control or the terminal attached to the old root.
/// @param ctx Application controllers to update.
/// @param rebuildIndex True after replacement; false may reuse an unchanged index.
/// @return True when an open workspace was applied.
expose func ActivateOpenWorkspace(ctx: command_context.CommandContext,
                                  rebuildIndex: Boolean) -> Boolean {
    if ctx == null or ctx.projMgr == null or ctx.projMgr.IsOpen() == false {
        return false;
    }
    var root = ctx.projMgr.RootPath();
    if root == "" { return false; }
    if ctx.basicWorkspaceCommands != null {
        ctx.basicWorkspaceCommands.Cancel();
    }
    if ctx.diagnosticActions != null {
        ctx.diagnosticActions.Cancel();
    }
    if ctx.ziaWorkspaceCommands != null {
        ctx.ziaWorkspaceCommands.Cancel();
    }
    // Workspace-derived work must never cross a root-set boundary. Explorer
    // mutation has already committed by this point; cancel the old cooperative
    // search, release old native watcher handles, and retire clickable rows
    // before any new-root service can publish state.
    if ctx.searcher != null and ctx.searcher.HasActiveWork() {
        ctx.searcher.CancelForWorkspaceChange();
    }
    workspace_watcher.StopWorkspaceWatcher(ctx.workspaceWatcherState);
    workspace_watcher.InvalidateWorkspaceLocations(ctx.shell, ctx.locStore, ctx.engine);
    if ctx.shell != null { ctx.shell.SetSidebarVisible(true); }
    if ctx.indexer != null {
        if rebuildIndex {
            ctx.indexer.OpenProject(ctx.projMgr, ctx.docMgr);
        } else {
            ctx.indexer.EnsureProject(ctx.projMgr, ctx.docMgr);
        }
    }
    if ctx.scmView != null { ctx.scmView.SetRepo(root); }
    if ctx.terminalCtrl != null { ctx.terminalCtrl.SetCwd(root); }
    return true;
}

/// @brief Detach every workspace-owned service without closing editor tabs.
/// @details A workspace is broader than ProjectManager's tree. Closing it must
///          also release native directory watchers, cancel project search,
///          destroy the semantic project index, clear stale locations, and
///          detach SCM/terminal roots. Open documents remain available and the
///          next language frame may build a lightweight single-file index for
///          the active tab.
/// @param ctx Application controllers to detach.
/// @return True when an open workspace was closed.
expose func CloseOpenWorkspace(ctx: command_context.CommandContext) -> Boolean {
    if ctx == null or ctx.projMgr == null or ctx.projMgr.IsOpen() == false {
        return false;
    }
    if ctx.searcher != null and ctx.searcher.HasActiveWork() {
        ctx.searcher.Cancel(ctx.shell);
    }
    if ctx.basicWorkspaceCommands != null {
        ctx.basicWorkspaceCommands.Cancel();
    }
    if ctx.diagnosticActions != null {
        ctx.diagnosticActions.Cancel();
    }
    if ctx.ziaWorkspaceCommands != null {
        ctx.ziaWorkspaceCommands.Cancel();
    }
    workspace_watcher.StopWorkspaceWatcher(ctx.workspaceWatcherState);
    if ctx.indexer != null { ctx.indexer.Destroy(); }
    if ctx.scmView != null { ctx.scmView.SetRepo(""); }
    if ctx.terminalCtrl != null { ctx.terminalCtrl.SetCwd(""); }
    ctx.projMgr.CloseProject();
    workspace_watcher.InvalidateWorkspaceLocations(ctx.shell, ctx.locStore, ctx.engine);
    if ctx.shell != null {
        ctx.shell.SetSidebarVisible(false);
        ctx.shell.SetIndexStatus("");
        ctx.shell.SetStatusLeft("Workspace closed");
    }
    return true;
}

/// @brief Detach one selected root, promoting another root when necessary.
/// @details This is the service-aware counterpart to ProjectManager's model
///          mutation. It cancels root-scoped work, releases old watchers,
///          rebuilds the semantic index, retargets SCM/terminal if the primary
///          root changed, and clears derived navigation rows. Open editor tabs
///          and every file on disk remain untouched.
/// @param ctx Application controllers to synchronize.
/// @param selectedPath Exact root or descendant used to identify its owner.
/// @return True when a workspace folder was detached.
expose func RemoveWorkspaceFolder(ctx: command_context.CommandContext,
                                  selectedPath: String) -> Boolean {
    if ctx == null or ctx.projMgr == null or ctx.projMgr.IsOpen() == false {
        return false;
    }
    if ctx.buildSys != null and ctx.buildSys.IsActive() {
        if ctx.shell != null {
            ctx.shell.SetStatusLeft("Stop the running job before changing workspace folders");
        }
        return false;
    }
    if ctx.dbgSession != null and ctx.dbgSession.IsActive() {
        if ctx.shell != null {
            ctx.shell.SetStatusLeft("Stop debugging before changing workspace folders");
        }
        return false;
    }

    var rootPath = ctx.projMgr.WorkspaceRootPathForPath(selectedPath);
    if rootPath == "" {
        if ctx.shell != null {
            ctx.shell.SetStatusLeft("Select a workspace folder to remove");
        }
        return false;
    }
    var rootName = Path.Name(rootPath);
    if rootName == "" { rootName = rootPath; }

    // Removing the final root is exactly Close Workspace, including teardown
    // of services that ProjectManager intentionally does not own.
    if ctx.projMgr.RootCount() == 1 {
        if CloseOpenWorkspace(ctx) == false { return false; }
        if ctx.shell != null {
            ctx.shell.SetStatusLeft("Removed workspace folder: " + rootName);
        }
        return true;
    }

    if ctx.searcher != null and ctx.searcher.HasActiveWork() {
        ctx.searcher.Cancel(ctx.shell);
    }
    if ctx.basicWorkspaceCommands != null {
        ctx.basicWorkspaceCommands.Cancel();
    }
    if ctx.diagnosticActions != null {
        ctx.diagnosticActions.Cancel();
    }
    if ctx.ziaWorkspaceCommands != null {
        ctx.ziaWorkspaceCommands.Cancel();
    }
    workspace_watcher.StopWorkspaceWatcher(ctx.workspaceWatcherState);
    if ctx.projMgr.RemoveFolderFromWorkspace(rootPath) == false {
        if ctx.shell != null {
            var reason = ctx.projMgr.lastOperationError;
            if reason == "" { reason = "The workspace folder could not be removed."; }
            ctx.shell.SetStatusLeft(reason);
            GUI.Toast.Warning(reason);
        }
        return false;
    }

    workspace_watcher.InvalidateWorkspaceLocations(ctx.shell, ctx.locStore, ctx.engine);
    ActivateOpenWorkspace(ctx, true);
    if ctx.shell != null {
        ctx.shell.SetStatusLeft("Removed workspace folder: " + rootName);
    }
    return true;
}

/// @brief Dispatch file, project, terminal, close, and exit commands.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param cpSelected Normalized command-palette selection id for this frame.
/// @return True when the user confirmed exit and the caller should clean up.
hide func DispatchFileCommands(ctx: command_context.CommandContext,
                               cpSelected: String) -> Boolean {
    if dispatch_helpers.Triggered("new", ctx.shell.menuChrome.miNew, ctx.shell.menuChrome.tbNew, cpSelected)      { file_commands.handleNew(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs); }
    if dispatch_helpers.Triggered("newscene2d", ctx.shell.menuChrome.miNewScene2D, null, cpSelected) {
        file_commands.handleNewScene2D(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs);
    }
    if dispatch_helpers.Triggered("newscene3d", ctx.shell.menuChrome.miNewScene3D, null, cpSelected) {
        file_commands.handleNewScene3D(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs);
    }
    if dispatch_helpers.Triggered("open", ctx.shell.menuChrome.miOpen, ctx.shell.menuChrome.tbOpen, cpSelected) {
        if file_commands.handleOpen(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs) {
            explorer_action_runner.RecordActiveFile(ctx.sessionMgr, ctx.docMgr);
            ctx.fileWatchCtrl.ResetPendingReload();
        }
    }
    if dispatch_helpers.Triggered("openfolder", ctx.shell.menuChrome.miOpenFolder, null, cpSelected) {
        // Replacing the workspace does not close editor tabs, so it must not
        // show a misleading dirty-document close prompt.
        if file_commands.handleOpenFolder(ctx.shell, ctx.projMgr) {
            ActivateOpenWorkspace(ctx, true);
            if ctx.sessionMgr != null {
                ctx.sessionMgr.RecordRecentProject(ctx.projMgr.RootPath());
            }
        }
    }
    if dispatch_helpers.TriggeredNoMenu("newprojectconsole", cpSelected) {
        ctx.commandInputOverlay.OpenNewProject(ctx.shell,
            command_input.COMMAND_INPUT_NEW_PROJECT_CONSOLE, "Console App");
    }
    if dispatch_helpers.TriggeredNoMenu("newprojectgui", cpSelected) {
        ctx.commandInputOverlay.OpenNewProject(ctx.shell,
            command_input.COMMAND_INPUT_NEW_PROJECT_GUI, "GUI App");
    }
    if dispatch_helpers.TriggeredNoMenu("newprojectlibrary", cpSelected) {
        ctx.commandInputOverlay.OpenNewProject(ctx.shell,
            command_input.COMMAND_INPUT_NEW_PROJECT_LIBRARY, "Library");
    }
    if dispatch_helpers.TriggeredNoMenu("comparewithsaved", cpSelected) {
        var activeDocOpt = ctx.docMgr.GetDocument(ctx.docMgr.activeIndex);
        if activeDocOpt != null and ctx.diffOverlay != null
           and ctx.engine != null and ctx.engine.editor != null {
            var activeDoc = activeDocOpt!;
            if activeDoc.filePath != "" {
                if IO.File.Exists(activeDoc.filePath) == false {
                    ctx.shell.SetStatusLeft("Saved file no longer exists");
                    GUI.Toast.Warning("Cannot compare: the saved file no longer exists");
                } else {
                    var readResult = safe_io.ReadAllTextBounded(
                        activeDoc.filePath,
                        document_manager.MAX_TEXT_OPEN_BYTES);
                    if readResult.ok == false {
                        ctx.shell.SetStatusLeft("Could not read saved file");
                        GUI.Toast.Error("Cannot compare: the saved file could not be read");
                    } else {
                        ctx.diffOverlay.Open(activeDoc.filePath + "  (saved → buffer)",
                                             readResult.text, ctx.engine.editor.Text);
                    }
                }
            }
        }
    }
    if dispatch_helpers.Triggered("addfolder", ctx.shell.menuChrome.miAddFolder, null, cpSelected) {
        if file_commands.handleAddFolderToWorkspace(ctx.shell, ctx.projMgr)
           and ctx.projMgr.IsOpen() {
            ActivateOpenWorkspace(ctx, false);
            if ctx.sessionMgr != null {
                var addedRootIndex = ctx.projMgr.RootCount() - 1;
                ctx.sessionMgr.RecordRecentProject(
                    ctx.projMgr.RootPathAt(addedRootIndex));
            }
        }
    }
    var removeFromContext = ctx.shell.menuChrome.ctxRemoveFolder != null
                            and ctx.shell.menuChrome.ctxRemoveFolder.WasClicked();
    if removeFromContext
       or dispatch_helpers.Triggered("removefolder", ctx.shell.menuChrome.miRemoveFolder,
                                    null, cpSelected) {
        var removePath = ctx.projMgr.SelectedPath();
        if removeFromContext {
            removePath = context_menus.CurrentContextPath(ctx.projMgr, ctx.shell);
        }
        if removePath == "" { removePath = ctx.projMgr.RootPath(); }
        RemoveWorkspaceFolder(ctx, removePath);
    }
    if dispatch_helpers.Triggered("closeworkspace", ctx.shell.menuChrome.miCloseWorkspace,
                                  null, cpSelected) {
        CloseOpenWorkspace(ctx);
    }
    if dispatch_helpers.Triggered("terminal", ctx.shell.menuChrome.miTerminal, null, cpSelected) {
        if ctx.projMgr.IsOpen() { ctx.terminalCtrl.SetCwd(ctx.projMgr.RootPath()); }
        ctx.shell.toolPanels.ToggleTerminalPanel();
    }
    if dispatch_helpers.Triggered("save", ctx.shell.menuChrome.miSave, ctx.shell.menuChrome.tbSave, cpSelected)   { file_commands.handleSave(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs); ctx.fileWatchCtrl.ResetPendingReload(); }
    if dispatch_helpers.Triggered("saveas", ctx.shell.menuChrome.miSaveAs, null, cpSelected)       { file_commands.handleSaveAs(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs); }
    if dispatch_helpers.Triggered("saveall", ctx.shell.menuChrome.miSaveAll, ctx.shell.menuChrome.tbSaveAll, cpSelected) { file_commands.handleSaveAll(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs); }
    if dispatch_helpers.Triggered("reload", ctx.shell.menuChrome.miReload, null, cpSelected)       { file_commands.handleReload(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs); ctx.fileWatchCtrl.ResetPendingReload(); }
    if dispatch_helpers.TriggeredMenu("recentfiles", ctx.shell.menuChrome.miRecentFiles, cpSelected) { view_commands.handleRecentFiles(ctx.shell, ctx.sessionMgr); }
    if dispatch_helpers.TriggeredMenu("reopenclosed", ctx.shell.menuChrome.miReopenClosed, cpSelected) { explorer_action_runner.ReopenClosedFile(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs, ctx.sessionMgr); ctx.fileWatchCtrl.ResetPendingReload(); }

    var closeIdx = -1;
    if dispatch_helpers.Triggered("close", ctx.shell.menuChrome.miClose, null, cpSelected) {
        closeIdx = ctx.docMgr.activeIndex;
    } else if ctx.shell.workbench.tabBar.WasCloseClicked() {
        closeIdx = ctx.shell.workbench.tabBar.GetCloseClickedIndex();
    }
    if closeIdx >= 0 {
        if file_commands.handleClose(ctx.shell, ctx.docMgr, ctx.engine, ctx.tabs, closeIdx) {
            ctx.fileWatchCtrl.ResetPendingReload();
        }
    }

    if ctx.shell.menuChrome.miExit.WasClicked() {
        if file_commands.handleExit(ctx.shell, ctx.docMgr, ctx.engine) {
            return true;
        }
    }
    return false;
}

/// @brief Open a selected file tree node unless a context menu consumed it.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param suppressTreeOpen True when a tree context menu owns the selection.
hide func PumpFileTreeOpen(ctx: command_context.CommandContext,
                           suppressTreeOpen: Boolean) {
    var treeSelectedPath = ctx.projMgr.HandleTreeClicks();
    if suppressTreeOpen {
        treeSelectedPath = "";
    }
    if treeSelectedPath != "" {
        if explorer_action_runner.OpenFileAndRecord(ctx.shell, ctx.docMgr,
                                                    ctx.engine, ctx.tabs,
                                                    ctx.sessionMgr,
                                                    treeSelectedPath) {
            ctx.fileWatchCtrl.ResetPendingReload();
        }
    }
}

/// @brief Dispatch edit, navigation, diagnostics, signature, and format commands.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param cpSelected Normalized command-palette selection id for this frame.
hide func DispatchEditCommands(ctx: command_context.CommandContext,
                               cpSelected: String) {
    if dispatch_helpers.Triggered("undo", ctx.shell.menuChrome.miUndo, null, cpSelected) {
        HandleSurfaceHistory(ctx, false);
    }
    if dispatch_helpers.Triggered("redo", ctx.shell.menuChrome.miRedo, null, cpSelected) {
        HandleSurfaceHistory(ctx, true);
    }
    if dispatch_helpers.Triggered("cut", ctx.shell.menuChrome.miCut, null, cpSelected) {
        HandleSurfaceCut(ctx);
    }
    if dispatch_helpers.Triggered("copy", ctx.shell.menuChrome.miCopy, null, cpSelected) {
        HandleSurfaceCopy(ctx);
    }
    if dispatch_helpers.Triggered("paste", ctx.shell.menuChrome.miPaste, null, cpSelected) {
        HandleSurfacePaste(ctx);
    }
    if dispatch_helpers.Triggered("selectall", ctx.shell.menuChrome.miSelectAll, null, cpSelected) {
        HandleSurfaceSelectAll(ctx);
    }
    if dispatch_helpers.Triggered("find", ctx.shell.menuChrome.miFind, ctx.shell.menuChrome.tbFind, cpSelected)    { edit_commands.handleFind(ctx.shell); }
    if dispatch_helpers.TriggeredMenu("goto", ctx.shell.menuChrome.miGoToLine, cpSelected) {
        if ctx.commandInputOverlay != null and ctx.engine != null and ctx.engine.editor != null {
            ctx.commandInputOverlay.OpenGoToLine(ctx.shell, ctx.engine.editor.CursorLine + 1);
        } else {
            ctx.shell.SetStatusLeft("Go To Line input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredMenu("gotodef", ctx.shell.menuChrome.miGoToDefinition, cpSelected)  { RunOrQueueSemanticCommand(ctx, "gotodef", "Go to definition"); }
    if dispatch_helpers.TriggeredMenu("findrefs", ctx.shell.menuChrome.miFindReferences, cpSelected) { RunOrQueueSemanticCommand(ctx, "findrefs", "Find references"); }
    if dispatch_helpers.TriggeredMenu("incomingcalls", ctx.shell.menuChrome.miIncomingCalls, cpSelected) { RunOrQueueSemanticCommand(ctx, "incomingcalls", "Incoming calls"); }
    if dispatch_helpers.TriggeredMenu("outgoingcalls", ctx.shell.menuChrome.miOutgoingCalls, cpSelected) { RunOrQueueSemanticCommand(ctx, "outgoingcalls", "Outgoing calls"); }
    if dispatch_helpers.TriggeredMenu("rename", ctx.shell.menuChrome.miRenameSymbol, cpSelected) {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenRenameSymbol(ctx.shell, edit_commands.IdentifierAtCursor(ctx.engine));
        } else {
            ctx.shell.SetStatusLeft("Rename input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("addnextoccurrence", cpSelected)              { edit_commands.handleAddNextOccurrence(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("skipoccurrence", cpSelected)                 { edit_commands.handleSkipOccurrence(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("selectalloccurrences", cpSelected)           { edit_commands.handleSelectAllOccurrences(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("clearcursors", cpSelected)                   { edit_commands.handleClearCursors(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("expandselection", cpSelected)                { edit_commands.handleExpandSelection(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("shrinkselection", cpSelected)                { edit_commands.handleShrinkSelection(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("togglelinecomment", cpSelected)              { edit_commands.handleToggleLineComment(ctx.shell, ctx.docMgr, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("toggleblockcomment", cpSelected)             { edit_commands.handleToggleBlockComment(ctx.shell, ctx.docMgr, ctx.engine); }
    var duplicateMenuClicked =
        ctx.shell.menuChrome.miDuplicateSelection.WasClicked();
    if duplicateMenuClicked or Shortcuts.WasTriggered("duplicateline")
       or cpSelected == "duplicateline" {
        HandleSurfaceDuplicate(
            ctx, duplicateMenuClicked or cpSelected == "duplicateline");
    }
    var deleteSceneMenuClicked =
        ctx.shell.menuChrome.miDeleteSceneSelection.WasClicked();
    if deleteSceneMenuClicked
       or Shortcuts.WasTriggered("deletesceneselection")
       or cpSelected == "deletesceneselection" {
        HandleSceneSelectionDelete(
            ctx, deleteSceneMenuClicked
                 or cpSelected == "deletesceneselection");
    }
    if dispatch_helpers.TriggeredNoMenu("movelineup", cpSelected)                     { edit_commands.handleMoveLineUp(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("movelinedown", cpSelected)                   { edit_commands.handleMoveLineDown(ctx.shell, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("organizebinds", cpSelected)                  { edit_commands.handleOrganizeBinds(ctx.shell, ctx.docMgr, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("extractlocal", cpSelected) {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenExtractLocal(ctx.shell);
        } else {
            ctx.shell.SetStatusLeft("Extract Local input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("extractfunction", cpSelected) {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenExtractFunction(ctx.shell);
        } else {
            ctx.shell.SetStatusLeft("Extract Function input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("inlinelocal", cpSelected)                    { edit_commands.handleInlineLocalVariable(ctx.shell, ctx.docMgr, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("suppressdiagnostic", cpSelected) {
        if ctx.diagnosticActions != null {
            ctx.diagnosticActions.Start(
                diagnostic_edit_commands.ACTION_SUPPRESS_DIAGNOSTIC,
                "Suppress Warning", ctx.shell, ctx.docMgr, ctx.engine,
                ctx.projMgr);
        } else {
            edit_commands.handleSuppressDiagnostic(ctx.shell, ctx.docMgr,
                                                   ctx.engine);
        }
    }
    if dispatch_helpers.TriggeredNoMenu("applydiagnosticfix", cpSelected) {
        if ctx.diagnosticActions != null {
            ctx.diagnosticActions.Start(
                diagnostic_edit_commands.ACTION_APPLY_FIX,
                "Apply Fix-It", ctx.shell, ctx.docMgr, ctx.engine,
                ctx.projMgr);
        } else {
            edit_commands.handleApplyDiagnosticFix(ctx.shell, ctx.docMgr,
                                                   ctx.engine);
        }
    }
    if dispatch_helpers.TriggeredNoMenu("createmissingbind", cpSelected) {
        if ctx.diagnosticActions != null {
            ctx.diagnosticActions.Start(
                diagnostic_edit_commands.ACTION_CREATE_MISSING_BIND,
                "Create Missing Bind", ctx.shell, ctx.docMgr, ctx.engine,
                ctx.projMgr);
        } else {
            edit_commands.handleCreateMissingBind(ctx.shell, ctx.docMgr,
                                                  ctx.engine, ctx.projMgr);
        }
    }
    if dispatch_helpers.TriggeredNoMenu("trimtrailingwhitespace", cpSelected)          { edit_commands.handleTrimTrailingWhitespace(ctx.shell, ctx.docMgr, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("formatdocument", cpSelected)                 { edit_commands.handleFormatDocument(ctx.shell, ctx.docMgr, ctx.engine); }
    if dispatch_helpers.TriggeredNoMenu("formatselection", cpSelected)                { edit_commands.handleFormatSelection(ctx.shell, ctx.docMgr, ctx.engine); }

    if dispatch_helpers.TriggeredMenu("nexterror", ctx.shell.menuChrome.miNextError, cpSelected) {
        NavigateDiagnostic(ctx, 1);
    }
    if dispatch_helpers.TriggeredMenu("preverror", ctx.shell.menuChrome.miPreviousError, cpSelected) {
        NavigateDiagnostic(ctx, -1);
    }
    if dispatch_helpers.TriggeredNoMenu("checknow", cpSelected) {
        file_commands.SaveEditorState(ctx.docMgr, ctx.engine);
        ctx.liveDiag.runNow(ctx.engine, ctx.shell);
    }
    if (ctx.shell.menuChrome.miSignatureHelp != null and ctx.shell.menuChrome.miSignatureHelp.WasClicked())
       or cpSelected == "signature_trigger" {
        ctx.sigCtrl.trigger(ctx.engine);
    }
    if dispatch_helpers.TriggeredNoMenu("signaturenextoverload", cpSelected) {
        ctx.sigCtrl.NextOverload();
    }
    if dispatch_helpers.TriggeredNoMenu("signatureprevoverload", cpSelected) {
        ctx.sigCtrl.PreviousOverload();
    }
}

/// @brief Route standard undo/redo to the visible editor surface.
hide func HandleSurfaceHistory(ctx: command_context.CommandContext,
                               redo: Boolean) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        var changed = false;
        if redo { changed = ctx.scene2DEditor.Redo(); }
        else { changed = ctx.scene2DEditor.Undo(); }
        if changed {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            var action = "undone";
            if redo { action = "redone"; }
            ctx.shell.SetStatusLeft("2D scene " + action);
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        var changed3D = false;
        if redo { changed3D = ctx.scene3DEditor.Redo(); }
        else { changed3D = ctx.scene3DEditor.Undo(); }
        if changed3D {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            var action3D = "undone";
            if redo { action3D = "redone"; }
            ctx.shell.SetStatusLeft("3D scene " + action3D);
        }
        return;
    }
    if redo {
        edit_commands.handleRedo(ctx.engine);
    } else {
        edit_commands.handleUndo(ctx.engine, ctx.docMgr);
    }
}

/// @brief Route standard Cut to the active editable surface.
hide func HandleSurfaceCut(ctx: command_context.CommandContext) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if ctx.scene2DEditor.CutSelectedSceneObjects() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Cut 2D scene selection");
        } else {
            ctx.shell.SetStatusLeft(
                "Select one or more 2D scene objects to cut");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if ctx.scene3DEditor.CutSelectedNodes() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Cut 3D scene selection");
        } else {
            ctx.shell.SetStatusLeft(
                "Select one or more 3D scene nodes to cut");
        }
        return;
    }
    if doc != null and doc!.isReadOnlyPreview {
        ctx.shell.SetStatusLeft("Cut is unavailable in read-only previews");
        return;
    }
    edit_commands.handleCut(ctx.engine);
}

/// @brief Route standard Copy to the active editable surface.
hide func HandleSurfaceCopy(ctx: command_context.CommandContext) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if ctx.scene2DEditor.CopySelectedSceneObjects() {
            ctx.shell.SetStatusLeft("Copied 2D scene selection");
        } else {
            ctx.shell.SetStatusLeft(
                "Select one or more 2D scene objects to copy");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if ctx.scene3DEditor.CopySelectedNodes() {
            ctx.shell.SetStatusLeft("Copied 3D scene selection");
        } else {
            ctx.shell.SetStatusLeft(
                "Select one or more 3D scene nodes to copy");
        }
        return;
    }
    if doc != null and doc!.isReadOnlyPreview {
        ctx.shell.SetStatusLeft("Copy is unavailable in read-only previews");
        return;
    }
    edit_commands.handleCopy(ctx.engine);
}

/// @brief Route standard Paste to the active editable surface.
hide func HandleSurfacePaste(ctx: command_context.CommandContext) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if ctx.scene2DEditor.PasteSceneObjectsFromClipboard() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Pasted into 2D scene");
        } else {
            ctx.shell.SetStatusLeft(
                "Clipboard has no compatible 2D scene objects");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if ctx.scene3DEditor.PasteSceneNodesFromClipboard() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Pasted into 3D scene");
        } else {
            ctx.shell.SetStatusLeft(
                "Clipboard has no compatible 3D scene nodes");
        }
        return;
    }
    if doc != null and doc!.isReadOnlyPreview {
        ctx.shell.SetStatusLeft("Paste is unavailable in read-only previews");
        return;
    }
    edit_commands.handlePaste(ctx.engine);
}

/// @brief Route standard Select All to the active editable surface.
hide func HandleSurfaceSelectAll(ctx: command_context.CommandContext) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if ctx.scene2DEditor.SelectAllSceneObjects() {
            ctx.shell.SetStatusLeft("Selected all 2D scene objects");
        } else {
            ctx.shell.SetStatusLeft("This 2D scene has no objects to select");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if ctx.scene3DEditor.SelectAllSceneNodes() {
            ctx.shell.SetStatusLeft("Selected all 3D scene nodes");
        } else {
            ctx.shell.SetStatusLeft("This 3D scene has no nodes to select");
        }
        return;
    }
    if doc != null and doc!.isReadOnlyPreview {
        ctx.shell.SetStatusLeft(
            "Select All is unavailable in read-only previews");
        return;
    }
    edit_commands.handleSelectAll(ctx.engine);
}

/// @brief Route Duplicate Selection without escaping scene-owned focus.
/// @param ctx Active command dependencies and visible document.
/// @param explicitInvocation True for command-palette invocation.
/// @details Palette selection is deliberate even though opening the palette
///          moves focus. Keyboard dispatch requires hierarchy or viewport
///          focus so an inspector input can never duplicate scene content.
hide func HandleSurfaceDuplicate(ctx: command_context.CommandContext,
                                 explicitInvocation: Boolean) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if explicitInvocation == false
           and ctx.scene2DEditor.SceneSelectionCommandsOwnFocus() == false {
            return;
        }
        var duplicated = ctx.scene2DEditor.DuplicateSelectedSceneObjects();
        if duplicated > 0 {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft(
                "Duplicated " + duplicated + " 2D scene object(s)");
        } else if explicitInvocation {
            ctx.shell.SetStatusLeft(
                "Select one or more 2D scene objects to duplicate");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if explicitInvocation == false
           and ctx.scene3DEditor.SceneSelectionCommandsOwnFocus() == false {
            return;
        }
        var duplicated3D = ctx.scene3DEditor.DuplicateSelectedNodes();
        if duplicated3D > 0 {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft(
                "Duplicated " + duplicated3D + " 3D scene node(s)");
        } else if explicitInvocation {
            ctx.shell.SetStatusLeft(
                "Select one or more 3D scene nodes to duplicate");
        }
        return;
    }
    edit_commands.handleDuplicateLine(ctx.shell, ctx.engine);
}

/// @brief Delete a visual-scene selection without hijacking text input Delete.
/// @param ctx Active command dependencies and visible document.
/// @param explicitInvocation True for command-palette invocation.
hide func HandleSceneSelectionDelete(
    ctx: command_context.CommandContext,
    explicitInvocation: Boolean) {
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_2D
       and ctx.scene2DEditor != null {
        if explicitInvocation == false
           and ctx.scene2DEditor.SceneSelectionCommandsOwnFocus() == false {
            return;
        }
        if ctx.scene2DEditor.RemoveSelectedSceneObjects() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Deleted 2D scene selection");
        } else if explicitInvocation {
            ctx.shell.SetStatusLeft(
                "Select one or more 2D scene objects to delete");
        }
        return;
    }
    if doc != null and doc!.kind == file_utils.DOC_KIND_SCENE_3D
       and ctx.scene3DEditor != null {
        if explicitInvocation == false
           and ctx.scene3DEditor.SceneSelectionCommandsOwnFocus() == false {
            return;
        }
        if ctx.scene3DEditor.DeleteSelectedNodes() {
            ctx.tabs.SetModified(ctx.docMgr.activeIndex, doc!.isModified);
            ctx.shell.SetStatusLeft("Deleted 3D scene selection");
        } else if explicitInvocation {
            ctx.shell.SetStatusLeft(
                "Select one or more 3D scene nodes to delete");
        }
    }
}

/// @brief Dispatch workbench, output, explorer-palette, quick-open, and search commands.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param cpSelected Normalized command-palette selection id for this frame.
hide func DispatchViewSearchCommands(ctx: command_context.CommandContext,
                                     cpSelected: String) {
    if dispatch_helpers.Triggered("togglesidebar", ctx.shell.menuChrome.miToggleSidebar, null, cpSelected) { view_commands.handleToggleSidebar(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("movesidebarleft", cpSelected) {
        if ctx.shell.workbench.GetSidebarPositionName() == "left" {
            ctx.shell.SetStatusLeft("Primary sidebar is already on the left");
        } else {
            ctx.shell.workbench.MoveSidebarTo(workspace_dock.DOCK_LEFT);
            ctx.shell.SetStatusLeft("Primary sidebar moved left");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("movesidebarright", cpSelected) {
        if ctx.shell.workbench.GetSidebarPositionName() == "right" {
            ctx.shell.SetStatusLeft("Primary sidebar is already on the right");
        } else {
            ctx.shell.workbench.MoveSidebarTo(workspace_dock.DOCK_RIGHT);
            ctx.shell.SetStatusLeft("Primary sidebar moved right");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("dockpanelsleft", cpSelected) {
        if ctx.shell.toolPanels.GetDockLocationName() == "left" {
            ctx.shell.SetStatusLeft(
                "Primary panel group is already on the left");
        } else {
            ctx.shell.toolPanels.MovePanelTo(workspace_dock.DOCK_LEFT);
            ctx.shell.SetStatusLeft("Primary panel group docked left");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("dockpanelsbottom", cpSelected) {
        if ctx.shell.toolPanels.GetDockLocationName() == "bottom" {
            ctx.shell.SetStatusLeft(
                "Primary panel group is already at the bottom");
        } else {
            ctx.shell.toolPanels.MovePanelTo(workspace_dock.DOCK_BOTTOM);
            ctx.shell.SetStatusLeft(
                "Primary panel group docked at bottom");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("dockpanelsright", cpSelected) {
        if ctx.shell.toolPanels.GetDockLocationName() == "right" {
            ctx.shell.SetStatusLeft(
                "Primary panel group is already on the right");
        } else {
            ctx.shell.toolPanels.MovePanelTo(workspace_dock.DOCK_RIGHT);
            ctx.shell.SetStatusLeft("Primary panel group docked right");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("floatpanelgroup", cpSelected) {
        if ctx.shell.toolPanels.FloatPrimaryToolPanelGroup() {
            ctx.shell.SetStatusLeft("Primary panel group is now floating");
        } else {
            ctx.shell.SetStatusLeft(
                "Open a tool in the primary panel group first");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("movetoolleft", cpSelected) {
        if ctx.shell.toolPanels.MoveActiveToolPanelTo(
               workspace_dock.DOCK_LEFT) {
            ctx.shell.SetStatusLeft("Active tool moved left");
        } else {
            ctx.shell.SetStatusLeft(
                "Select a tool outside the left group first");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("movetoolbottom", cpSelected) {
        if ctx.shell.toolPanels.MoveActiveToolPanelTo(
               workspace_dock.DOCK_BOTTOM) {
            ctx.shell.SetStatusLeft("Active tool moved to bottom");
        } else {
            ctx.shell.SetStatusLeft(
                "Select a tool outside the bottom group first");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("movetoolright", cpSelected) {
        if ctx.shell.toolPanels.MoveActiveToolPanelTo(
               workspace_dock.DOCK_RIGHT) {
            ctx.shell.SetStatusLeft("Active tool moved right");
        } else {
            ctx.shell.SetStatusLeft(
                "Select a tool outside the right group first");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("movetoolfloating", cpSelected) {
        if ctx.shell.toolPanels.MoveActiveToolPanelTo(
               workspace_dock.DOCK_FLOATING) {
            ctx.shell.SetStatusLeft("Active tool moved to floating window");
        } else {
            ctx.shell.SetStatusLeft(
                "Select a tool outside the floating group first");
        }
    }
    if dispatch_helpers.Triggered(
           "resetworkspacelayout",
           ctx.shell.menuChrome.miResetWorkspaceLayout,
           null,
           cpSelected) {
        view_commands.handleResetWorkspaceLayout(
            ctx.shell, ctx.engine, ctx.appSettings, ctx.activityBarCtrl,
            ctx.projMgr != null and ctx.projMgr.IsOpen());
    }
    if dispatch_helpers.TriggeredMenu("statusbar", ctx.shell.menuChrome.miToggleStatusBar, cpSelected)     { view_commands.handleToggleStatusBar(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("zoomin", ctx.shell.menuChrome.miZoomIn, null, cpSelected)               { view_commands.handleZoomIn(ctx.shell, ctx.engine, ctx.appSettings); }
    if dispatch_helpers.Triggered("zoomout", ctx.shell.menuChrome.miZoomOut, null, cpSelected)             { view_commands.handleZoomOut(ctx.shell, ctx.engine, ctx.appSettings); }
    if dispatch_helpers.Triggered("zoomreset", ctx.shell.menuChrome.miZoomReset, null, cpSelected)         { view_commands.handleZoomReset(ctx.shell, ctx.engine, ctx.appSettings); }
    if dispatch_helpers.Triggered("uizoomin", ctx.shell.menuChrome.miUiZoomIn, null, cpSelected)           { view_commands.handleUiZoomIn(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("uizoomout", ctx.shell.menuChrome.miUiZoomOut, null, cpSelected)         { view_commands.handleUiZoomOut(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("uizoomreset", ctx.shell.menuChrome.miUiZoomReset, null, cpSelected)     { view_commands.handleUiZoomReset(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("toggletheme", ctx.shell.menuChrome.miToggleTheme, null, cpSelected)     { view_commands.handleToggleTheme(ctx.shell, ctx.engine, ctx.liveDiag, ctx.appSettings); }
    if dispatch_helpers.Triggered("fullscreen", ctx.shell.menuChrome.miFullscreen, null, cpSelected)       { view_commands.handleFullscreen(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("minimap", ctx.shell.menuChrome.miToggleMinimap, null, cpSelected)       { view_commands.handleToggleMinimap(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.Triggered("settings", ctx.shell.menuChrome.miPreferences, null, cpSelected)        { ctx.overlays.OpenSettings(ctx.shell, ctx.appSettings); }
    if dispatch_helpers.TriggeredNoMenu("keybindings", cpSelected)                              { view_commands.handleKeybindings(ctx.shell, ctx.commandRegistry); }
    if dispatch_helpers.TriggeredNoMenu("copytoolrow", cpSelected)                              { view_commands.handleCopyToolSelection(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("copyoutputtext", cpSelected)                           { view_commands.handleCopyOutputText(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("clearoutput", cpSelected)                              { view_commands.handleClearOutput(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("filteroutput", cpSelected) {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenFilterOutput(ctx.shell, ctx.shell.toolPanels.outputFilterText);
        } else {
            ctx.shell.SetStatusLeft("Output filter input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredNoMenu("toggleoutputwrap", cpSelected)                         { view_commands.handleToggleOutputWrap(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("toggleoutputautoscroll", cpSelected)                   { view_commands.handleToggleOutputAutoScroll(ctx.shell); }
    if dispatch_helpers.TriggeredNoMenu("togglerenderwhitespace", cpSelected)                   { view_commands.handleToggleRenderWhitespace(ctx.shell, ctx.engine, ctx.appSettings); }
    if dispatch_helpers.TriggeredNoMenu("treenewfile", cpSelected) {
        var overlayNewFileDir = contextDirForSelectedProjectPath(ctx.projMgr);
        if overlayNewFileDir != "" { ctx.explorerOverlay.OpenNewFile(ctx.shell, overlayNewFileDir); }
    }
    if dispatch_helpers.TriggeredNoMenu("treenewfolder", cpSelected) {
        var overlayNewFolderDir = contextDirForSelectedProjectPath(ctx.projMgr);
        if overlayNewFolderDir != "" { ctx.explorerOverlay.OpenNewFolder(ctx.shell, overlayNewFolderDir); }
    }
    if dispatch_helpers.TriggeredNoMenu("treerename", cpSelected) {
        explorer_action_runner.TreeRename(ctx.shell, ctx.explorerOverlay, ctx.projMgr);
    }
    if dispatch_helpers.TriggeredNoMenu("treedelete", cpSelected) {
        explorer_action_runner.TreeDelete(ctx.shell, ctx.explorerOverlay, ctx.projMgr);
    }
    if dispatch_helpers.TriggeredNoMenu("treerefresh", cpSelected)                          { ctx.projMgr.RefreshTree(); ctx.indexer.EnsureProject(ctx.projMgr, ctx.docMgr); ctx.shell.SetStatusLeft("Project tree refreshed"); }
    if ctx.shell.menuChrome.miKeyboardShortcuts.WasClicked()                          { view_commands.handleKeybindings(ctx.shell, ctx.commandRegistry); }
    if ctx.shell.menuChrome.miAbout.WasClicked()                                      { ctx.overlays.OpenAbout(ctx.shell); }
    if dispatch_helpers.TriggeredMenu("quickopen", ctx.shell.menuChrome.miQuickOpen, cpSelected) {
        if search_commands.ShowQuickOpenPalette(ctx.shell, ctx.projMgr) {
            ctx.paletteCtrl.BeginQuickOpen();
        }
    }
    if dispatch_helpers.TriggeredMenu("searchproject", ctx.shell.menuChrome.miSearchProject, cpSelected) { search_commands.handleProjectSearchAsync(ctx.shell, ctx.projMgr, ctx.docMgr, ctx.engine, ctx.searcher); }
    if dispatch_helpers.TriggeredMenu("workspacesymbols", ctx.shell.menuChrome.miWorkspaceSymbols, cpSelected) {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenWorkspaceSymbols(ctx.shell, "");
        } else {
            ctx.shell.SetStatusLeft("Workspace Symbols input is unavailable");
        }
    }
    if dispatch_helpers.TriggeredMenu("symboloutline", ctx.shell.menuChrome.miSymbolOutline, cpSelected) { ctx.symbolOutline.toggle(); }
}

/// @brief Dispatch build, run, debug, and breakpoint metadata commands.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param cpSelected Normalized command-palette selection id for this frame.
hide func DispatchBuildDebugCommands(ctx: command_context.CommandContext,
                                     cpSelected: String) {
    if dispatch_helpers.Triggered("build", ctx.shell.menuChrome.miBuild, ctx.shell.menuChrome.tbBuild, cpSelected) {
        if dispatch_helpers.CanStartBuildCommand(ctx.shell, ctx.dbgSession, "Build") {
            build_commands.handleBuild(ctx.shell, ctx.docMgr, ctx.projMgr,
                                       ctx.engine, ctx.tabs, ctx.buildSys,
                                       ctx.locStore,
                                       ctx.appSettings.saveAllBeforeBuild);
        }
    }
    if dispatch_helpers.Triggered("buildrun", ctx.shell.menuChrome.miBuildAndRun, ctx.shell.menuChrome.tbRun, cpSelected) {
        if dispatch_helpers.CanStartBuildCommand(ctx.shell, ctx.dbgSession, "Build and Run") {
            build_commands.handleBuildAndRun(ctx.shell, ctx.docMgr, ctx.projMgr,
                                             ctx.engine, ctx.tabs, ctx.buildSys,
                                             ctx.locStore,
                                             ctx.appSettings.saveAllBeforeBuild);
        }
    }
    if dispatch_helpers.Triggered("run", ctx.shell.menuChrome.miRun, null, cpSelected) {
        if dispatch_helpers.CanStartBuildCommand(ctx.shell, ctx.dbgSession, "Run") {
            build_commands.handleRun(ctx.shell, ctx.docMgr, ctx.projMgr,
                                     ctx.engine, ctx.tabs, ctx.buildSys,
                                     ctx.locStore,
                                     ctx.appSettings.saveAllBeforeBuild);
        }
    }
    if dispatch_helpers.Triggered("stopjob", ctx.shell.menuChrome.miStop, ctx.shell.menuChrome.tbStop, cpSelected)         { build_commands.handleStop(ctx.shell, ctx.buildSys); }
    if dispatch_helpers.Triggered("debugstart", ctx.shell.menuChrome.miDebugStart, ctx.shell.menuChrome.tbDebug, cpSelected) {
        debug_commands.handleDebugStart(ctx.shell, ctx.docMgr, ctx.engine,
                                        ctx.tabs, ctx.buildSys,
                                        ctx.breakpointStore, ctx.dbgSession,
                                        ctx.appSettings.saveAllBeforeBuild);
    }
    if dispatch_helpers.Triggered("debugcontinue", ctx.shell.menuChrome.miDebugContinue, ctx.shell.menuChrome.tbDebugContinue, cpSelected) {
        debug_commands.handleDebugContinue(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("debugstepover", ctx.shell.menuChrome.miDebugStepOver, ctx.shell.menuChrome.tbDebugStep, cpSelected) {
        debug_commands.handleDebugStepOver(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("debugstepin", ctx.shell.menuChrome.miDebugStepIn, null, cpSelected) {
        debug_commands.handleDebugStepIn(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("debugstepout", ctx.shell.menuChrome.miDebugStepOut, null, cpSelected) {
        debug_commands.handleDebugStepOut(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("debugpause", ctx.shell.menuChrome.miDebugPause, null, cpSelected) {
        debug_commands.handleDebugPause(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("debugrestart", ctx.shell.menuChrome.miDebugRestart, null, cpSelected) {
        debug_commands.handleDebugRestart(ctx.shell, ctx.docMgr, ctx.engine,
                                          ctx.tabs, ctx.buildSys,
                                          ctx.breakpointStore, ctx.dbgSession,
                                          ctx.appSettings.saveAllBeforeBuild);
    }
    if dispatch_helpers.Triggered("debugstop", ctx.shell.menuChrome.miDebugStop, null, cpSelected) {
        debug_commands.handleDebugStop(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.Triggered("togglebreakpoint", ctx.shell.menuChrome.miToggleBreakpoint, null, cpSelected) {
        debug_commands.handleToggleBreakpoint(ctx.shell, ctx.docMgr,
                                              ctx.engine, ctx.breakpointStore);
    }
    if dispatch_helpers.TriggeredNoMenu("debugruntocursor", cpSelected) {
        debug_commands.handleRunToCursor(ctx.shell, ctx.docMgr,
                                         ctx.engine, ctx.dbgSession);
    }
    if dispatch_helpers.TriggeredNoMenu("debugaddwatch", cpSelected) {
        debug_commands.OpenWatchInput(
            ctx.shell, debug_commands.DebugExpressionFromEditor(ctx.engine));
    }
    if dispatch_helpers.TriggeredNoMenu("debugremovewatch", cpSelected) {
        debug_commands.handleRemoveSelectedWatch(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.TriggeredNoMenu("debugrefreshwatches", cpSelected) {
        debug_commands.handleRefreshWatches(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.TriggeredNoMenu("debugclearwatches", cpSelected) {
        debug_commands.handleClearWatches(ctx.shell, ctx.dbgSession);
    }
    if dispatch_helpers.TriggeredNoMenu("debugcondition", cpSelected) {
        lifecycle_controller.OpenDebugBreakpointOverlay(ctx.shell,
                                                        ctx.debugOverlay,
                                                        ctx.docMgr,
                                                        ctx.engine,
                                                        ctx.breakpointStore,
                                                        debug_breakpoint_overlay.DEBUG_BP_ACTION_CONDITION);
    }
    if dispatch_helpers.TriggeredNoMenu("debuglogpoint", cpSelected) {
        lifecycle_controller.OpenDebugBreakpointOverlay(ctx.shell,
                                                        ctx.debugOverlay,
                                                        ctx.docMgr,
                                                        ctx.engine,
                                                        ctx.breakpointStore,
                                                        debug_breakpoint_overlay.DEBUG_BP_ACTION_LOGPOINT);
    }
    var completedDebugOverlayAction = ctx.debugOverlay.Pump(ctx.shell);
    if completedDebugOverlayAction == debug_breakpoint_overlay.DEBUG_BP_ACTION_CONDITION
       or completedDebugOverlayAction == debug_breakpoint_overlay.DEBUG_BP_ACTION_LOGPOINT {
        lifecycle_controller.ApplyDebugBreakpointOverlay(ctx.shell,
                                                         ctx.debugOverlay,
                                                         ctx.docMgr,
                                                         ctx.engine,
                                                         ctx.breakpointStore,
                                                         ctx.dbgSession,
                                                         completedDebugOverlayAction);
    }
}

/// @brief Run a semantic navigation/refactor command, or defer it until indexing is ready.
/// @details Zia project-wide commands need a complete workspace index for
///          trustworthy results. Instead of showing a "retry later" toast, this
///          helper records the command and cursor anchor, advances the index
///          cooperatively, and lets PumpPendingSemanticCommand execute the same
///          command automatically once the index reports ready. BASIC commands
///          use their owned background workspace controller; other languages run
///          immediately to preserve their unavailable-state feedback.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param commandId Semantic command id handled by ExecuteSemanticCommand.
/// @param label User-facing command label for status text.
hide func RunOrQueueSemanticCommand(ctx: command_context.CommandContext,
                                    commandId: String,
                                    label: String) {
    if ctx == null or ctx.engine == null or ctx.engine.editor == null {
        return;
    }
    var doc = ctx.docMgr.GetActive();
    if doc != null and doc!.language == "basic" {
        StartBasicSemanticCommand(ctx, commandId, label);
        return;
    }
    if doc != null and doc!.language == "zia"
       and ctx.ziaWorkspaceCommands != null {
        if commandId == "rename" {
            ctx.shell.SetStatusLeft("Rename input is unavailable");
            return;
        }
        var kind = 0;
        if commandId == "gotodef" {
            kind = zia_workspace_query_job.ZIA_QUERY_DEFINITION;
        } else if commandId == "findrefs" {
            kind = zia_workspace_query_job.ZIA_QUERY_REFERENCES;
        } else if commandId == "incomingcalls" {
            kind = zia_workspace_query_job.ZIA_QUERY_INCOMING_CALLS;
        } else if commandId == "outgoingcalls" {
            kind = zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS;
        }
        if kind > 0 {
            ctx.ziaWorkspaceCommands.Start(
                kind, label, ctx.shell, ctx.docMgr, ctx.projMgr, ctx.engine,
                ctx.indexer);
        }
        return;
    }
    if doc == null or doc!.language != "zia" or ctx.indexer == null {
        ExecuteSemanticCommand(ctx, commandId);
        return;
    }

    file_commands.SaveEditorState(ctx.docMgr, ctx.engine);
    ctx.indexer.SyncActiveNow(ctx.docMgr, ctx.engine);
    ctx.indexer.SyncOpenDocuments(ctx.docMgr);
    if ctx.indexer.PrepareWorkspaceQuery(PENDING_SEMANTIC_PUMP_FILES) {
        ClearPendingSemanticCommand();
        ExecuteSemanticCommand(ctx, commandId);
        return;
    }

    QueuePendingSemanticCommand(ctx, commandId, label);
}

/// @brief Translate a semantic command id into an asynchronous BASIC query.
hide func StartBasicSemanticCommand(ctx: command_context.CommandContext,
                                    commandId: String,
                                    label: String) {
    if ctx.basicWorkspaceCommands == null {
        ctx.shell.SetStatusLeft(label + " is unavailable");
        return;
    }
    if commandId == "rename" {
        ctx.shell.SetStatusLeft("Rename input is unavailable");
        return;
    }
    var kind = 0;
    if commandId == "gotodef" {
        kind = basic_workspace_query_job.QUERY_DEFINITION;
    } else if commandId == "findrefs" {
        kind = basic_workspace_query_job.QUERY_REFERENCES;
    } else if commandId == "incomingcalls" {
        kind = basic_workspace_query_job.QUERY_INCOMING_CALLS;
    } else if commandId == "outgoingcalls" {
        kind = basic_workspace_query_job.QUERY_OUTGOING_CALLS;
    }
    if kind <= 0 { return; }
    ctx.basicWorkspaceCommands.Start(kind, label, ctx.shell, ctx.docMgr,
                                     ctx.projMgr, ctx.engine);
}

/// @brief Store a pending semantic command at the active document/cursor anchor.
/// @details The anchor prevents a delayed command from firing against a different
///          symbol after the user changes files or moves the caret while indexing
///          continues. Re-triggering a semantic command replaces any older pending
///          command so the most recent user intent wins.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param commandId Command id to execute when indexing completes.
/// @param label User-facing label used in status and toast text.
hide func QueuePendingSemanticCommand(ctx: command_context.CommandContext,
                                      commandId: String,
                                      label: String) {
    var doc = ctx.docMgr.GetActive();
    if doc == null { return; }
    pendingSemanticCommand = commandId;
    pendingSemanticLabel = label;
    pendingSemanticPath = doc!.filePath;
    pendingSemanticLine = ctx.engine.editor.CursorLine;
    pendingSemanticCol = ctx.engine.editor.CursorCol;
    pendingSemanticRevision = ctx.engine.GetRevision();
    var msg = label + " queued while indexing ("
              + ctx.indexer.WorkspaceIndexProgressText() + ")";
    ctx.shell.SetStatusLeft(msg);
}

/// @brief Advance a queued semantic command and execute it when the index is ready.
/// @details Called once per frame by DispatchCommandContext. It pumps the same
///          bounded amount of index work as an explicit semantic command, cancels
///          if the active document/cursor no longer matches the stored anchor, and
///          then dispatches through the normal command handler so behavior remains
///          centralized in edit_commands.
/// @param ctx Named dependency bundle assembled by main.zia.
hide func PumpPendingSemanticCommand(ctx: command_context.CommandContext) {
    if pendingSemanticCommand == "" { return; }
    if ctx == null or ctx.engine == null or ctx.engine.editor == null or ctx.indexer == null {
        ClearPendingSemanticCommand();
        return;
    }
    if PendingSemanticAnchorMatches(ctx) == false {
        ctx.shell.SetStatusLeft(pendingSemanticLabel + " canceled because the cursor changed");
        ClearPendingSemanticCommand();
        return;
    }

    file_commands.SaveEditorState(ctx.docMgr, ctx.engine);
    ctx.indexer.SyncActiveNow(ctx.docMgr, ctx.engine);
    ctx.indexer.SyncOpenDocuments(ctx.docMgr);
    if ctx.indexer.PrepareWorkspaceQuery(PENDING_SEMANTIC_PUMP_FILES) == false {
        ctx.shell.SetStatusLeft(pendingSemanticLabel + " pending ("
                                + ctx.indexer.WorkspaceIndexProgressText() + ")");
        return;
    }

    var commandId = pendingSemanticCommand;
    var label = pendingSemanticLabel;
    ClearPendingSemanticCommand();
    ctx.shell.SetStatusLeft(label + " ready");
    ExecuteSemanticCommand(ctx, commandId);
}

/// @brief Return true when the active document and cursor still match the pending command.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @return True when it is still safe to execute the queued semantic command.
hide func PendingSemanticAnchorMatches(ctx: command_context.CommandContext) -> Boolean {
    var doc = ctx.docMgr.GetActive();
    if doc == null { return false; }
    if doc!.language != "zia" { return false; }
    if doc!.filePath != pendingSemanticPath { return false; }
    if ctx.engine.editor.CursorLine != pendingSemanticLine { return false; }
    if ctx.engine.editor.CursorCol != pendingSemanticCol { return false; }
    if ctx.engine.GetRevision() != pendingSemanticRevision { return false; }
    return true;
}

/// @brief Clear all pending semantic command state.
hide func ClearPendingSemanticCommand() {
    pendingSemanticCommand = "";
    pendingSemanticLabel = "";
    pendingSemanticPath = "";
    pendingSemanticLine = -1;
    pendingSemanticCol = -1;
    pendingSemanticRevision = -1;
}

/// @brief Execute one semantic command through its existing command handler.
/// @details This keeps queued and immediately-run commands behaviorally identical:
///          all result rendering, prompts, workspace edits, and toasts still live in
///          edit_commands. Unknown command ids are ignored defensively.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param commandId Semantic command id to run.
hide func ExecuteSemanticCommand(ctx: command_context.CommandContext,
                                 commandId: String) {
    if commandId == "gotodef" {
        edit_commands.handleGoToDefinition(ctx.shell, ctx.docMgr, ctx.engine,
                                           ctx.tabs, ctx.indexer, ctx.locStore);
    } else if commandId == "findrefs" {
        edit_commands.handleFindReferences(ctx.shell, ctx.docMgr, ctx.engine,
                                           ctx.indexer, ctx.locStore);
    } else if commandId == "incomingcalls" {
        edit_commands.handleIncomingCalls(ctx.shell, ctx.docMgr, ctx.engine,
                                          ctx.indexer, ctx.locStore);
    } else if commandId == "outgoingcalls" {
        edit_commands.handleOutgoingCalls(ctx.shell, ctx.docMgr, ctx.engine,
                                          ctx.indexer, ctx.locStore);
    } else if commandId == "rename" {
        if ctx.commandInputOverlay != null {
            ctx.commandInputOverlay.OpenRenameSymbol(
                ctx.shell, edit_commands.IdentifierAtCursor(ctx.engine));
        } else {
            ctx.shell.SetStatusLeft("Rename input is unavailable");
        }
    }
}

/// @brief Navigate to the next or previous diagnostic row.
/// @details Problems row zero is a header, so navigation wraps between row 1 and
///          the final row. The LocationStore owns the actual target data.
/// @param ctx Named dependency bundle assembled by main.zia.
/// @param direction 1 for next, -1 for previous.
hide func NavigateDiagnostic(ctx: command_context.CommandContext,
                             direction: Integer) {
    var count = ctx.shell.toolPanels.diagListBox.Count;
    if count <= 1 {
        ctx.shell.SetStatusLeft("No diagnostics");
        return;
    }

    currentDiagIdx = currentDiagIdx + direction;
    if currentDiagIdx >= count { currentDiagIdx = 1; }
    if currentDiagIdx < 1 { currentDiagIdx = count - 1; }

    ctx.shell.toolPanels.diagListBox.SelectIndex(currentDiagIdx);
    var selItem = ctx.shell.toolPanels.diagListBox.Selected;
    if selItem != null {
        ctx.locStore.OpenLocation(ctx.shell, ctx.docMgr, ctx.engine,
                                  ctx.tabs, GUI.ListBox.ItemGetData(selItem));
    }
}

/// @brief Return a directory suitable for selected explorer create commands.
/// @param projMgr Project manager containing the current explorer selection.
/// @return Selected directory, selected file parent, or empty when unavailable.
hide func contextDirForSelectedProjectPath(projMgr: project_manager.ProjectManager) -> String {
    var selected = projMgr.SelectedPath();
    if selected == "" { return ""; }
    if Dir.Exists(selected) { return selected; }
    if IO.File.Exists(selected) { return Path.Directory(selected); }
    return "";
}
