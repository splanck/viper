//
// File: zannastudio/src/commands/diagnostic_edit_commands.zia
// Purpose: Apply diagnostic-driven fixes and missing-bind source edits.
// Key invariants:
//   - Diagnostic edits target validated source ranges and workspace files.
//   - Unavailable candidate files are skipped without terminating Studio.
// Ownership/Lifetime: DiagnosticActionController owns its semantic and project
//                     workers; compatibility handlers borrow editor state.
// Links: zannastudio/src/editor/quick_fixes.zia,
//        zannastudio/src/commands/edit_commands.zia
//
//===----------------------------------------------------------------------===//

module diagnostic_edit_commands;

bind "../commands/editor_document_edit";
bind "../commands/file_commands";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../editor/project_bind_query_job";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../editor/quick_fixes";
bind "../editor/zia_query";
bind "../services/locations";
bind "../services/text_utils";
bind "../services/safe_io";
bind "../ui/app_shell";
bind "../zia/bind_utils";

bind Zanna.GUI;
bind IO = Zanna.IO;
bind Path = Zanna.IO.Path;
bind Map = Zanna.Collections.Map;
bind Seq = Zanna.Collections.Seq;
bind Str = Zanna.String;
bind SemanticJob = Zanna.Zia.SemanticJob;
bind ZiaToolchain = Zanna.Zia.Toolchain;

final ACTION_SUPPRESS_DIAGNOSTIC = 1;
final ACTION_APPLY_FIX = 2;
final ACTION_CREATE_MISSING_BIND = 3;
final MAX_DIAGNOSTIC_ACTION_CHARS = 4000000;

/// @brief Map a Problems-row action label to the semantic edit operation.
/// @details Compiler-provided fix-it messages are intentionally open-ended; all
///          actionable labels other than the two specialized workflows route to
///          the generic fix-it resolver at the selected diagnostic location.
/// @return One ACTION_* value, or zero for a non-actionable placeholder.
expose func ActionKindForProblemLabel(label: String) -> Integer {
    if label == "" or label == "-" or label == "No quick fix" { return 0; }
    if label == "Suppress Warning" { return ACTION_SUPPRESS_DIAGNOSTIC; }
    if label == "Create Missing Bind" { return ACTION_CREATE_MISSING_BIND; }
    return ACTION_APPLY_FIX;
}

/// @brief Open and start the quick fix selected in the Problems toolbar.
/// @return True when a valid asynchronous diagnostic action was started.
expose func StartSelectedProblemAction(
    controller: DiagnosticActionController,
    shell: app_shell.AppShell,
    docMgr: document_manager.DocumentManager,
    engine: editor_engine.EditorEngine,
    tabs: editor_tabs.EditorTabs,
    projMgr: project_manager.ProjectManager,
    locStore: locations.LocationStore) -> Boolean {
    if controller == null or shell == null or locStore == null {
        return false;
    }
    var action = shell.toolPanels.GetSelectedProblemAction();
    var kind = ActionKindForProblemLabel(action);
    if kind == 0 {
        shell.SetStatusLeft("No quick fix is available for this problem");
        return false;
    }
    var locationData = shell.toolPanels.GetSelectedProblemLocationData();
    if locationData == ""
       or locStore.OpenLocation(shell, docMgr, engine, tabs,
                                locationData) == false {
        shell.SetStatusLeft("The selected problem location is no longer available");
        return false;
    }
    return controller.Start(kind, action, shell, docMgr, engine, projMgr);
}

/// @brief Non-blocking owner for compiler-backed diagnostic edit commands.
/// @details The semantic stage uses the runtime's existing background job API.
///          Missing project binds then use a second bounded owned worker to
///          prove that exactly one workspace file defines the identifier.
class DiagnosticActionController {
    expose Integer pendingKind;
    expose String pendingLabel;
    expose String pendingPath;
    expose Integer pendingRevision;
    expose Integer pendingLine;
    expose Integer pendingCol;
    expose Integer pendingLineOffset;
    expose String pendingWorkspaceSignature;
    expose Any pendingSemanticJob;
    expose project_bind_query_job.ProjectBindQueryJob bindJob;
    expose Integer pendingBindGeneration;

    expose func init() {
        pendingKind = 0;
        pendingLabel = "";
        pendingPath = "";
        pendingRevision = -1;
        pendingLine = 1;
        pendingCol = 0;
        pendingLineOffset = 0;
        pendingWorkspaceSignature = "";
        pendingSemanticJob = null;
        bindJob = new project_bind_query_job.ProjectBindQueryJob();
        pendingBindGeneration = 0;
    }

    /// @brief Start one semantic diagnostic action and return immediately.
    expose func Start(kind: Integer,
                      label: String,
                      shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine,
                      projMgr: project_manager.ProjectManager) -> Boolean {
        if shell == null or docMgr == null or engine == null
           or engine.editor == null {
            return false;
        }
        var doc = docMgr.GetActive();
        if doc == null or doc!.language != "zia" {
            shell.SetStatusLeft(label + " is only available for Zia files");
            return false;
        }

        Cancel();
        file_commands.SaveEditorState(docMgr, engine);
        var source = engine.GetTextSnapshot();
        if Str.get_Length(source) > MAX_DIAGNOSTIC_ACTION_CHARS {
            shell.SetStatusLeft(label + " supports files up to 4 MB");
            GUI.Toast.Warning(label + " input is too large");
            return false;
        }
        doc!.content = source;
        pendingKind = kind;
        pendingLabel = label;
        pendingPath = doc!.filePath;
        pendingRevision = engine.GetRevision();
        pendingLine = engine.editor.CursorLine + 1;
        pendingCol = engine.editor.CursorCol;
        pendingLineOffset = zia_query.LineOffset(source);
        pendingWorkspaceSignature = WorkspaceSignature(projMgr);

        var querySource = zia_query.WrapForQuery(source);
        pendingSemanticJob = ZiaToolchain.BeginCheckForFile(querySource,
                                                            pendingPath);
        if pendingSemanticJob == null {
            Fail(shell, label + " diagnostics are unavailable", true);
            return false;
        }
        shell.SetStatusLeft(label + " checking diagnostics...");
        return true;
    }

    /// @brief Poll semantic/project stages and apply only a current anchor.
    expose func Pump(shell: app_shell.AppShell,
                     docMgr: document_manager.DocumentManager,
                     engine: editor_engine.EditorEngine,
                     projMgr: project_manager.ProjectManager) {
        bindJob.Pump();
        if pendingKind == 0 {
            bindJob.TakeCompleted();
            return;
        }
        if AnchorMatches(docMgr, engine) == false {
            var label = pendingLabel;
            Cancel();
            if shell != null {
                shell.SetStatusLeft(label + " canceled because the editor changed");
            }
            return;
        }

        if pendingSemanticJob != null {
            if SemanticJob.IsDone(pendingSemanticJob) == false { return; }
            var semantic = pendingSemanticJob;
            pendingSemanticJob = null;
            if SemanticJob.IsError(semantic) {
                Fail(shell, pendingLabel + " diagnostics failed", true);
                return;
            }
            var records = SemanticJob.Diagnostics(semantic);
            if records == null {
                Fail(shell, pendingLabel + " diagnostics failed", true);
                return;
            }
            HandleDiagnosticRecords(records, shell, docMgr, engine, projMgr);
            return;
        }

        if pendingBindGeneration > 0 {
            var request = bindJob.TakeCompleted();
            if request == null { return; }
            if request!.generation != pendingBindGeneration { return; }
            pendingBindGeneration = 0;
            FinishProjectBind(request!, shell, docMgr, engine, projMgr);
        }
    }

    expose func Cancel() {
        if pendingSemanticJob != null {
            SemanticJob.Cancel(pendingSemanticJob);
            pendingSemanticJob = null;
        }
        bindJob.Cancel();
        ResetPending();
    }

    expose func Shutdown() -> Boolean {
        if pendingSemanticJob != null {
            SemanticJob.Cancel(pendingSemanticJob);
            pendingSemanticJob = null;
        }
        ResetPending();
        return bindJob.CancelAndWait();
    }

    expose func IsBusy() -> Boolean {
        return pendingKind != 0 or pendingSemanticJob != null
               or bindJob.IsBusy();
    }

    hide func HandleDiagnosticRecords(records: Any,
                                      shell: app_shell.AppShell,
                                      docMgr: document_manager.DocumentManager,
                                      engine: editor_engine.EditorEngine,
                                      projMgr: project_manager.ProjectManager) {
        var rawTargetLine = pendingLine + pendingLineOffset;
        if pendingKind == ACTION_SUPPRESS_DIAGNOSTIC {
            var code = SuppressibleDiagnosticCodeAt(records, rawTargetLine);
            if code == "" {
                Fail(shell, "No suppressible warning at cursor", false);
                return;
            }
            ApplySuppression(code, shell, docMgr, engine);
            return;
        }
        if pendingKind == ACTION_APPLY_FIX {
            var fix = DiagnosticFixItAt(records, rawTargetLine);
            if fix == null {
                Fail(shell, "No diagnostic fix-it at cursor", false);
                return;
            }
            ApplyFix(fix, shell, docMgr, engine);
            return;
        }

        var name = MissingRuntimeBindIdentifierAt(records, rawTargetLine);
        if name != "" {
            ApplyRuntimeBind(name, shell, docMgr, engine);
            return;
        }
        name = MissingUndefinedIdentifierAt(records, rawTargetLine);
        if name == "" or pendingPath == "" or projMgr == null
           or projMgr.IsOpen() == false {
            Fail(shell, "No safe missing bind at cursor", false);
            return;
        }

        var roots = new List();
        var ignores = new List();
        var rootIndex = 0;
        while rootIndex < projMgr.RootCount() {
            roots.Push(projMgr.RootPathAt(rootIndex));
            ignores.Push(projMgr.RootIgnorePatternsAt(rootIndex));
            rootIndex = rootIndex + 1;
        }
        var openPaths = new List();
        var openSources = new List();
        var docIndex = 0;
        while docIndex < docMgr.GetCount() {
            var openDoc = docMgr.documents.get(docIndex);
            if openDoc.language == "zia" and openDoc.filePath != "" {
                openPaths.Push(openDoc.filePath);
                openSources.Push(openDoc.content);
            }
            docIndex = docIndex + 1;
        }
        pendingBindGeneration = bindJob.Queue(
            name, pendingPath, pendingWorkspaceSignature,
            roots, ignores, openPaths, openSources);
        if pendingBindGeneration <= 0 {
            Fail(shell, "Project bind search could not start", true);
            return;
        }
        shell.SetStatusLeft("Finding a unique project bind for " + name + "...");
    }

    hide func ApplySuppression(code: String,
                               shell: app_shell.AppShell,
                               docMgr: document_manager.DocumentManager,
                               engine: editor_engine.EditorEngine) {
        var lineText = engine.editor.GetLine(pendingLine - 1);
        var indentLen = text_utils.LeadingWhitespaceLength(lineText);
        var indent = "";
        if indentLen > 0 { indent = Str.Left(lineText, indentLen); }
        engine.editor.SetCursor(pendingLine - 1, 0);
        engine.editor.InsertAtCursor(indent + "// @suppress(" + code + ")\n");
        engine.editor.SetCursor(pendingLine, pendingCol);
        file_commands.SaveEditorState(docMgr, engine);
        var doc = docMgr.GetActive();
        if doc != null { doc!.isModified = true; }
        Complete(shell, "Suppressed warning " + code);
    }

    hide func ApplyFix(fix: Any,
                       shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine) {
        var startLine = Map.GetInt(fix, "fixitStartLine")
                        - pendingLineOffset - 1;
        var startCol = Map.GetInt(fix, "fixitStartColumn") - 1;
        var endLine = Map.GetInt(fix, "fixitEndLine")
                      - pendingLineOffset - 1;
        var endCol = Map.GetInt(fix, "fixitEndColumn") - 1;
        if startLine < 0 { startLine = pendingLine - 1; }
        if endLine < startLine { endLine = startLine; }
        if startCol < 0 { startCol = 0; }
        if endCol < startCol { endCol = startCol; }
        engine.editor.SetCursorSelection(0, startLine, startCol,
                                         endLine, endCol);
        engine.editor.InsertAtCursor(Map.GetStr(fix, "fixitReplacement"));
        file_commands.SaveEditorState(docMgr, engine);
        var doc = docMgr.GetActive();
        if doc != null { doc!.isModified = true; }
        var label = Map.GetStr(fix, "fixitMessage");
        if label == "" { label = "Applied diagnostic fix-it"; }
        Complete(shell, label);
    }

    hide func ApplyRuntimeBind(name: String,
                               shell: app_shell.AppShell,
                               docMgr: document_manager.DocumentManager,
                               engine: editor_engine.EditorEngine) {
        var source = engine.GetTextSnapshot();
        var updated = CreateMissingRuntimeBindText(source, name);
        if updated == source {
            Fail(shell, "Runtime bind already exists", false);
            return;
        }
        ApplyInsertedBind(updated,
                          "Added " + quick_fixes.RuntimeBindLineForIdentifier(name),
                          shell, docMgr, engine);
    }

    hide func FinishProjectBind(
        request: project_bind_query_job.ProjectBindQueryRequest,
        shell: app_shell.AppShell,
        docMgr: document_manager.DocumentManager,
        engine: editor_engine.EditorEngine,
        projMgr: project_manager.ProjectManager) {
        if request.succeeded == false {
            var error = request.error;
            if error == "" { error = "Project bind search failed"; }
            Fail(shell, error, true);
            return;
        }
        if WorkspaceSignature(projMgr) != pendingWorkspaceSignature {
            Fail(shell, "Create Missing Bind canceled because the workspace changed",
                 false);
            return;
        }
        if request.reason != "" {
            var message = "No project file uniquely defines the identifier";
            if request.reason == "ambiguous" {
                message = "Multiple project files define the identifier";
            } else if request.reason == "workspace_limit" {
                message = "Project bind scan reached its safety limit";
            } else if request.reason == "workspace_unavailable" {
                message = "Project bind scan could not read the workspace";
            }
            Fail(shell, message, request.reason != "not_found");
            return;
        }
        if request.candidatePath == "" {
            Fail(shell, "No project bind candidate found", false);
            return;
        }
        if request.candidateMtime >= 0
           and safe_io.Modified(request.candidatePath)
               != request.candidateMtime {
            Fail(shell, "Project bind candidate changed during the scan", true);
            return;
        }
        if request.candidateMtime < 0 {
            var candidateIndex = docMgr.FindByPath(request.candidatePath);
            if candidateIndex < 0
               or docMgr.documents.get(candidateIndex).content
                  != request.candidateOpenSource {
                Fail(shell, "Open project bind candidate changed during the scan",
                     true);
                return;
            }
        }
        var bindPath = RelativeProjectBindPath(Path.Directory(pendingPath),
                                               request.candidatePath);
        var source = engine.GetTextSnapshot();
        var updated = CreateMissingProjectBindText(source, bindPath);
        if bindPath == "" or updated == source {
            Fail(shell, "Project bind is unavailable or already exists", false);
            return;
        }
        ApplyInsertedBind(updated, "Added bind \"" + bindPath + "\";",
                          shell, docMgr, engine);
    }

    hide func ApplyInsertedBind(updated: String,
                                status: String,
                                shell: app_shell.AppShell,
                                docMgr: document_manager.DocumentManager,
                                engine: editor_engine.EditorEngine) {
        if editor_document_edit.ReplaceWholeDocument(engine, updated) == false {
            Fail(shell, "Could not apply missing bind", true);
            return;
        }
        engine.editor.SetCursor(pendingLine, pendingCol);
        file_commands.SaveEditorState(docMgr, engine);
        var doc = docMgr.GetActive();
        if doc != null { doc!.isModified = true; }
        Complete(shell, status);
    }

    hide func AnchorMatches(docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine) -> Boolean {
        if docMgr == null or engine == null or engine.editor == null {
            return false;
        }
        var doc = docMgr.GetActive();
        return doc != null and doc!.language == "zia"
               and doc!.filePath == pendingPath
               and engine.GetRevision() == pendingRevision
               and engine.editor.CursorLine + 1 == pendingLine
               and engine.editor.CursorCol == pendingCol;
    }

    hide func Complete(shell: app_shell.AppShell,
                       status: String) {
        ResetPending();
        if shell != null { shell.SetStatusLeft(status); }
    }

    hide func Fail(shell: app_shell.AppShell,
                   status: String,
                   warning: Boolean) {
        ResetPending();
        if shell != null { shell.SetStatusLeft(status); }
        if warning { GUI.Toast.Warning(status); }
    }

    hide func ResetPending() {
        pendingKind = 0;
        pendingLabel = "";
        pendingPath = "";
        pendingRevision = -1;
        pendingLine = 1;
        pendingCol = 0;
        pendingLineOffset = 0;
        pendingWorkspaceSignature = "";
        pendingBindGeneration = 0;
    }
}

func WorkspaceSignature(projMgr: project_manager.ProjectManager) -> String {
    if projMgr == null or projMgr.IsOpen() == false { return ""; }
    return projMgr.WorkspaceSignature();
}

// ============================================================================
// MODULE: diagnostic_edit_commands
// PURPOSE: Command handlers and helpers for diagnostic-driven source edits.
//
// WHERE-THIS-FITS: edit_commands.zia keeps the public command surface and
//          compatibility wrappers used by probes. This module owns the
//          diagnostic-specific flows: suppress warning, apply fix-it, and create
//          missing bind.
//
// TEACHING-NOTE: Diagnostic commands are not general editor commands. They
//          query compiler diagnostics, interpret diagnostic records, and then
//          create targeted edits. Keeping that workflow separate makes the
//          command layer easier to audit.
// ============================================================================

/// @brief Insert a Zia suppression comment for the warning at the cursor.
/// @param shell Workbench shell used for contextual status feedback.
/// @param docMgr Open document manager.
/// @param engine Active editor engine.
func handleSuppressDiagnostic(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine) {
    if engine == null or engine.editor == null { return; }
    var doc = docMgr.GetActive();
    if doc == null or doc.language != "zia" {
        shell.SetStatusLeft("Suppress Warning is only available for Zia files");
        return;
    }

    var source = engine.GetTextSnapshot();
    var records = ZiaToolchain.CheckForFile(source, doc!.filePath);
    var targetLine = engine.editor.CursorLine + 1;
    var code = SuppressibleDiagnosticCodeAt(records, targetLine);
    if code == "" {
        shell.SetStatusLeft("No suppressible warning at cursor");
        return;
    }

    var lineText = engine.editor.GetLine(engine.editor.CursorLine);
    var indentLen = text_utils.LeadingWhitespaceLength(lineText);
    var indent = "";
    if indentLen > 0 {
        indent = Str.Left(lineText, indentLen);
    }
    engine.editor.SetCursor(engine.editor.CursorLine, 0);
    engine.editor.InsertAtCursor(indent + "// @suppress(" + code + ")\n");
    shell.SetStatusLeft("Suppressed warning " + code);
}

/// @brief Apply the compiler-provided fix-it at the cursor line.
/// @param shell Workbench shell used for contextual status feedback.
/// @param docMgr Open document manager.
/// @param engine Active editor engine.
func handleApplyDiagnosticFix(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine) {
    if engine == null or engine.editor == null { return; }
    var doc = docMgr.GetActive();
    if doc == null or doc.language != "zia" {
        shell.SetStatusLeft("Diagnostic fix-its are only available for Zia files");
        return;
    }

    var source = engine.GetTextSnapshot();
    var records = ZiaToolchain.CheckForFile(source, doc!.filePath);
    var targetLine = engine.editor.CursorLine + 1;
    var fix = DiagnosticFixItAt(records, targetLine);
    if fix == null {
        shell.SetStatusLeft("No diagnostic fix-it at cursor");
        return;
    }

    var startLine = Map.GetInt(fix, "fixitStartLine") - 1;
    var startCol = Map.GetInt(fix, "fixitStartColumn") - 1;
    var endLine = Map.GetInt(fix, "fixitEndLine") - 1;
    var endCol = Map.GetInt(fix, "fixitEndColumn") - 1;
    if startLine < 0 { startLine = targetLine - 1; }
    if endLine < startLine { endLine = startLine; }
    if startCol < 0 { startCol = 0; }
    if endCol < startCol { endCol = startCol; }

    engine.editor.SetCursorSelection(0, startLine, startCol, endLine, endCol);
    engine.editor.InsertAtCursor(Map.GetStr(fix, "fixitReplacement"));
    file_commands.SaveEditorState(docMgr, engine);
    doc!.isModified = true;

    var label = Map.GetStr(fix, "fixitMessage");
    if label == "" { label = "Applied diagnostic fix-it"; }
    shell.SetStatusLeft(label);
}

/// @brief Add a runtime or project bind suggested by diagnostics at the cursor.
/// @param shell Workbench shell used for contextual status feedback.
/// @param docMgr Open document manager.
/// @param engine Active editor engine.
/// @param projMgr Project manager used to locate unique project bind targets.
func handleCreateMissingBind(shell: app_shell.AppShell,
                             docMgr: document_manager.DocumentManager,
                             engine: editor_engine.EditorEngine,
                             projMgr: project_manager.ProjectManager) {
    if engine == null or engine.editor == null { return; }
    var doc = docMgr.GetActive();
    if doc == null or doc.language != "zia" {
        shell.SetStatusLeft("Create Missing Bind is only available for Zia files");
        return;
    }

    var source = engine.GetTextSnapshot();
    var records = ZiaToolchain.CheckForFile(source, doc!.filePath);
    var targetLine = engine.editor.CursorLine + 1;
    var name = MissingRuntimeBindIdentifierAt(records, targetLine);
    var updated = source;
    var status = "";

    if name != "" {
        updated = CreateMissingRuntimeBindText(source, name);
        if updated == source {
            shell.SetStatusLeft("Runtime bind already exists");
            return;
        }
        status = "Added " + quick_fixes.RuntimeBindLineForIdentifier(name);
    } else {
        name = MissingUndefinedIdentifierAt(records, targetLine);
        var bindPath = ProjectBindPathForIdentifier(name, doc!.filePath, projMgr, docMgr);
        if bindPath == "" {
            shell.SetStatusLeft("No safe missing bind at cursor");
            return;
        }
        updated = CreateMissingProjectBindText(source, bindPath);
        if updated == source {
            shell.SetStatusLeft("Project bind already exists");
            return;
        }
        status = "Added bind \"" + bindPath + "\";";
    }

    var cursorLine = engine.editor.CursorLine;
    var cursorCol = engine.editor.CursorCol;
    editor_document_edit.ReplaceWholeDocument(engine, updated);
    engine.editor.SetCursor(cursorLine + 1, cursorCol);
    file_commands.SaveEditorState(docMgr, engine);
    doc!.isModified = true;
    shell.SetStatusLeft(status);
}

/// @brief Find the diagnostic fix-it record that starts on a target line.
/// @param records Diagnostics returned by ZiaToolchain.CheckForFile.
/// @param targetLine One-based editor line.
/// @return Diagnostic record map, or null when no fix-it applies.
func DiagnosticFixItAt(records: Any,
                       targetLine: Integer) -> Any {
    if records == null { return null; }
    var i = 0;
    while i < Seq.get_Count(records) {
        var record = Seq.Get(records, i);
        i = i + 1;
        if Map.GetBool(record, "hasFixit") {
            if Map.GetInt(record, "line") == targetLine {
                return record;
            }
        }
    }
    return null;
}

/// @brief Return the missing runtime bind identifier at a target line.
/// @param records Diagnostics returned by ZiaToolchain.CheckForFile.
/// @param targetLine One-based editor line.
/// @return Runtime identifier that can be bound safely, or empty.
func MissingRuntimeBindIdentifierAt(records: Any,
                                    targetLine: Integer) -> String {
    if records == null { return ""; }
    var i = 0;
    while i < Seq.get_Count(records) {
        var record = Seq.Get(records, i);
        i = i + 1;
        var name = quick_fixes.MissingRuntimeBindIdentifierForRecord(record);
        if name != "" {
            if Map.GetInt(record, "line") == targetLine {
                return name;
            }
        }
    }
    return "";
}

/// @brief Return the missing project identifier at a target line.
/// @param records Diagnostics returned by ZiaToolchain.CheckForFile.
/// @param targetLine One-based editor line.
/// @return Undefined identifier text, or empty.
func MissingUndefinedIdentifierAt(records: Any,
                                  targetLine: Integer) -> String {
    if records == null { return ""; }
    var i = 0;
    while i < Seq.get_Count(records) {
        var record = Seq.Get(records, i);
        i = i + 1;
        var name = quick_fixes.UndefinedIdentifierForRecord(record);
        if name != "" {
            if Map.GetInt(record, "line") == targetLine {
                return name;
            }
        }
    }
    return "";
}

/// @brief Insert a runtime bind for a missing identifier.
/// @param source Full Zia source text.
/// @param identifier Runtime identifier to bind.
/// @return Updated source, or original source when no bind is needed.
func CreateMissingRuntimeBindText(source: String,
                                  identifier: String) -> String {
    var bindLine = quick_fixes.RuntimeBindLineForIdentifier(identifier);
    if bindLine == "" { return source; }
    if SourceHasBindAlias(source, identifier) { return source; }
    return InsertTopBindLineText(source, bindLine);
}

/// @brief Insert a project file bind for a missing identifier.
/// @param source Full Zia source text.
/// @param bindPath Relative bind path to insert.
/// @return Updated source, or original source when no bind is needed.
func CreateMissingProjectBindText(source: String,
                                  bindPath: String) -> String {
    if bindPath == "" { return source; }
    if SourceHasFileBind(source, bindPath) { return source; }
    return InsertTopBindLineText(source, "bind \"" + bindPath + "\";");
}

/// @brief Insert a bind line after the module declaration and existing binds.
/// @param source Full Zia source text.
/// @param bindLine Complete bind line to insert.
/// @return Updated source.
func InsertTopBindLineText(source: String,
                           bindLine: String) -> String {
    return bind_utils.InsertTopBindLineText(source, bindLine);
}

/// @brief Resolve an identifier to one unique project bind path.
/// @param identifier Undefined identifier text.
/// @param importingPath File that needs the bind.
/// @param projMgr Project manager with cached file paths.
/// @param docMgr Open document manager for unsaved source.
/// @return Relative bind path, or empty when ambiguous/unavailable.
func ProjectBindPathForIdentifier(identifier: String,
                                  importingPath: String,
                                  projMgr: project_manager.ProjectManager,
                                  docMgr: document_manager.DocumentManager) -> String {
    if identifier == "" or importingPath == "" { return ""; }
    if projMgr == null or projMgr.project == null or projMgr.project.isOpen == false {
        return "";
    }

    var candidatePath = "";
    var matches = 0;
    var i = 0;
    while i < projMgr.CachedFileCount() {
        var filePath = projMgr.CachedFileAt(i);
        i = i + 1;
        if IsProjectBindCandidate(filePath, importingPath, identifier, docMgr) {
            candidatePath = filePath;
            matches = matches + 1;
            if matches > 1 { return ""; }
        }
    }

    if docMgr != null {
        var d = 0;
        while d < docMgr.GetCount() {
            var doc = docMgr.documents.get(d);
            d = d + 1;
            if doc.filePath == "" or doc.filePath == importingPath { continue; }
            if Str.ToLower(Path.Extension(doc.filePath)) != ".zia" { continue; }
            if ProjectFileDefinesIdentifier(doc.content, identifier) {
                if candidatePath != doc.filePath {
                    candidatePath = doc.filePath;
                    matches = matches + 1;
                    if matches > 1 { return ""; }
                }
            }
        }
    }

    if matches != 1 { return ""; }
    return RelativeProjectBindPath(Path.Directory(importingPath), candidatePath);
}

/// @brief Test whether one file defines the identifier needed by another file.
/// @param filePath Candidate source file.
/// @param importingPath File that needs a bind.
/// @param identifier Identifier to find.
/// @param docMgr Open document manager for unsaved source.
/// @return True when the candidate defines the identifier.
func IsProjectBindCandidate(filePath: String,
                            importingPath: String,
                            identifier: String,
                            docMgr: document_manager.DocumentManager) -> Boolean {
    if filePath == "" or filePath == importingPath { return false; }
    if Str.ToLower(Path.Extension(filePath)) != ".zia" { return false; }
    var content = "";
    if docMgr != null {
        var idx = docMgr.FindByPath(filePath);
        if idx >= 0 {
            content = docMgr.documents.get(idx).content;
        }
    }
    if content == "" and IO.File.Exists(filePath) {
        var readResult = safe_io.ReadAllTextBounded(
            filePath, project_bind_query_job.MAX_BIND_FILE_CHARS);
        if readResult.ok { content = readResult.text; }
    }
    if content == "" { return false; }
    return ProjectFileDefinesIdentifier(content, identifier);
}

/// @brief Return true when source has a top-level declaration for an identifier.
/// @param source Full Zia source text.
/// @param identifier Identifier to find.
/// @return True when a bindable top-level declaration matches.
func ProjectFileDefinesIdentifier(source: String,
                                  identifier: String) -> Boolean {
    return bind_utils.ProjectFileDefinesIdentifier(source, identifier);
}

/// @brief Compute a relative bind path between two project files.
/// @param importingDir Directory containing the importer.
/// @param targetPath File that should be bound.
/// @return Zia bind path using normalized separators.
func RelativeProjectBindPath(importingDir: String,
                             targetPath: String) -> String {
    return bind_utils.RelativeBindPath(importingDir, targetPath, "./" + Path.Name(targetPath), true);
}

/// @brief Return true when source already binds an alias for an identifier.
/// @param source Full Zia source text.
/// @param identifier Runtime identifier alias.
/// @return True when a matching alias bind exists.
func SourceHasBindAlias(source: String,
                        identifier: String) -> Boolean {
    return bind_utils.SourceHasBindAlias(source, identifier);
}

/// @brief Return true when source already binds a file path.
/// @param source Full Zia source text.
/// @param bindPath Relative bind path.
/// @return True when a matching file bind exists.
func SourceHasFileBind(source: String,
                       bindPath: String) -> Boolean {
    return bind_utils.SourceHasFileBind(source, bindPath);
}

/// @brief Find a suppressible warning code at a target line.
/// @param records Diagnostics returned by ZiaToolchain.CheckForFile.
/// @param targetLine One-based editor line.
/// @return Warning code such as W008, or empty when none applies.
func SuppressibleDiagnosticCodeAt(records: Any, targetLine: Integer) -> String {
    if records == null { return ""; }
    var i = 0;
    while i < Seq.get_Count(records) {
        var record = Seq.Get(records, i);
        i = i + 1;
        if Map.GetInt(record, "severity") == 1
           and Map.GetInt(record, "line") == targetLine {
            var code = Map.GetStr(record, "code");
            if IsSuppressibleDiagnosticCode(code) {
                return code;
            }
        }
    }
    return "";
}

/// @brief Return true when a diagnostic code is warning-suppressible.
/// @param code Diagnostic code text.
/// @return True for warning codes that start with W.
func IsSuppressibleDiagnosticCode(code: String) -> Boolean {
    return Str.get_Length(code) >= 2 and Str.Left(code, 1) == "W";
}
