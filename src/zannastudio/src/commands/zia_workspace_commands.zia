//
// File: zannastudio/src/commands/zia_workspace_commands.zia
// Purpose: Schedule, validate, and incrementally publish Zia workspace queries.
// Key invariants:
//   - Project-index parsing never runs in a command or frame callback.
//   - Results apply only to their original path/revision/caret/index generation.
//   - Reference rows and preview source reads obey per-frame budgets.
// Ownership/Lifetime: Main owns one controller and drains its worker on exit.
// Links: zannastudio/src/editor/zia_workspace_query_job.zia,
//        zannastudio/src/commands/main_command_dispatcher.zia
//
//===----------------------------------------------------------------------===//

module zia_workspace_commands;

bind "../commands/edit_commands";
bind "../commands/file_commands";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../editor/project_index";
bind "../editor/zia_workspace_query_job";
bind "../services/locations";
bind "../services/safe_io";
bind "../services/workspace_edits";
bind "../ui/app_shell";
bind "../zia/identifier_utils";
bind "../zia/source_scan";

bind GUI = Zanna.GUI;
bind IO = Zanna.IO;
bind Map = Zanna.Collections.Map;
bind Path = Zanna.IO.Path;
bind Seq = Zanna.Collections.Seq;
bind Str = Zanna.String;

final RESULT_ITEMS_PER_FRAME = 100;
final RESULT_SOURCE_BYTES_PER_FRAME = 500000;
final INDEX_FILES_PER_WAITING_FRAME = 32;

/// @brief UI-side owner for asynchronous Zia navigation and rename commands.
class ZiaWorkspaceCommandController {
    expose zia_workspace_query_job.ZiaWorkspaceQueryJob job;
    expose Integer pendingGeneration;
    expose Any renderItems;
    expose Integer renderIndex;
    expose Integer renderLimit;
    expose Integer renderKind;
    expose String renderLabel;
    expose String renderLastGroup;
    expose Boolean renderTruncated;
    expose Integer renderedRows;
    expose String renderOriginPath;
    expose String renderOriginSource;
    expose String cachedSourcePath;
    expose String cachedSource;
    expose Integer lastPumpItems;
    expose Integer lastPumpSourceBytes;
    expose Integer waitingKind;
    expose String waitingLabel;
    expose String waitingNewName;
    expose String waitingPath;
    expose Integer waitingRevision;
    expose Integer waitingLine;
    expose Integer waitingCol;
    expose String waitingWorkspaceSignature;

    expose func init() {
        job = new zia_workspace_query_job.ZiaWorkspaceQueryJob();
        pendingGeneration = 0;
        renderItems = null;
        renderIndex = 0;
        renderLimit = 0;
        renderKind = 0;
        renderLabel = "";
        renderLastGroup = "";
        renderTruncated = false;
        renderedRows = 0;
        renderOriginPath = "";
        renderOriginSource = "";
        cachedSourcePath = "";
        cachedSource = "";
        lastPumpItems = 0;
        lastPumpSourceBytes = 0;
        waitingKind = 0;
        waitingLabel = "";
        waitingNewName = "";
        waitingPath = "";
        waitingRevision = -1;
        waitingLine = 1;
        waitingCol = 0;
        waitingWorkspaceSignature = "";
    }

    expose func Start(kind: Integer,
                      label: String,
                      shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      projMgr: project_manager.ProjectManager,
                      engine: editor_engine.EditorEngine,
                      indexer: project_index.ProjectIndexer) -> Boolean {
        return StartWithText(kind, label, "", shell, docMgr, projMgr,
                             engine, indexer);
    }

    expose func StartRename(newNameText: String,
                            shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            projMgr: project_manager.ProjectManager,
                            engine: editor_engine.EditorEngine,
                            indexer: project_index.ProjectIndexer) -> Boolean {
        var newName = Str.Trim(newNameText);
        if newName == "" { return false; }
        if identifier_utils.IsValidIdentifier(newName) == false {
            GUI.Toast.Warning("Invalid identifier");
            return false;
        }
        return StartWithText(zia_workspace_query_job.ZIA_QUERY_RENAME,
                             "Rename", newName, shell, docMgr, projMgr,
                             engine, indexer);
    }

    /// @brief Poll query completion and publish one bounded result-row batch.
    expose func Pump(shell: app_shell.AppShell,
                     docMgr: document_manager.DocumentManager,
                     projMgr: project_manager.ProjectManager,
                     engine: editor_engine.EditorEngine,
                     tabs: editor_tabs.EditorTabs,
                     indexer: project_index.ProjectIndexer,
                     locStore: locations.LocationStore) {
        PumpWaiting(shell, docMgr, projMgr, engine, indexer);
        if pendingGeneration > 0 and job.latestRequest != null
           and AnchorMatches(job.latestRequest, docMgr, projMgr, engine,
                             indexer) == false {
            var label = job.latestRequest.label;
            job.Cancel();
            pendingGeneration = 0;
            if shell != null {
                shell.SetStatusLeft(label
                                    + " canceled because the editor or index changed");
            }
        }

        job.Pump();
        var request = job.TakeCompleted();
        if request != null {
            FinishRequest(request!, shell, docMgr, projMgr, engine, tabs,
                          indexer, locStore);
        }
        PumpRenderRows(shell, docMgr, locStore);
    }

    expose func Cancel() {
        job.Cancel();
        pendingGeneration = 0;
        ResetWaiting();
        ResetRendering();
    }

    expose func Shutdown() -> Boolean {
        pendingGeneration = 0;
        ResetWaiting();
        ResetRendering();
        return job.CancelAndWait();
    }

    expose func IsBusy() -> Boolean {
        return waitingKind > 0 or pendingGeneration > 0
               or job.IsBusy() or renderItems != null;
    }

    hide func StartWithText(kind: Integer,
                            label: String,
                            newName: String,
                            shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            projMgr: project_manager.ProjectManager,
                            engine: editor_engine.EditorEngine,
                            indexer: project_index.ProjectIndexer) -> Boolean {
        if shell == null or docMgr == null or engine == null
           or engine.editor == null or indexer == null
           or indexer.valid == false {
            return false;
        }
        var doc = docMgr.GetActive();
        if doc == null or doc!.language != "zia" {
            return false;
        }
        if kind == zia_workspace_query_job.ZIA_QUERY_RENAME
           and doc!.filePath == "" {
            GUI.Toast.Info("Save the Zia file before renaming across the workspace");
            return false;
        }
        if indexer.workspaceIndexTruncated {
            Cancel();
            shell.SetStatusLeft(label + " is unavailable because the workspace index is incomplete");
            GUI.Toast.Warning("Workspace index limits prevent a complete "
                              + label + " result");
            return false;
        }

        Cancel();
        file_commands.SaveEditorState(docMgr, engine);
        indexer.SyncActiveNow(docMgr, engine);
        indexer.SyncOpenDocuments(docMgr);
        if indexer.workspaceIndexTruncated {
            shell.SetStatusLeft(label
                                + " is unavailable because the workspace index is incomplete");
            GUI.Toast.Warning("Workspace index limits prevent a complete "
                              + label + " result");
            return false;
        }
        var source = engine.GetTextSnapshot();
        if Str.get_Length(source)
           > zia_workspace_query_job.ZIA_MAX_QUERY_SOURCE_CHARS {
            shell.SetStatusLeft(label + " supports Zia files up to 200 KB");
            GUI.Toast.Warning(label + " input is too large");
            return false;
        }
        doc!.content = source;
        if kind != zia_workspace_query_job.ZIA_QUERY_RENAME {
            shell.toolPanels.ClearToolRows(shell.toolPanels.referencesListBox);
            shell.toolPanels.HideReferencesPanel();
        }
        if indexer.workspaceIndexComplete == false {
            waitingKind = kind;
            waitingLabel = label;
            waitingNewName = newName;
            waitingPath = doc!.filePath;
            waitingRevision = engine.GetRevision();
            waitingLine = engine.editor.CursorLine + 1;
            waitingCol = engine.editor.CursorCol;
            waitingWorkspaceSignature = WorkspaceSignature(projMgr, indexer);
            shell.SetStatusLeft(label + " queued while indexing ("
                                + indexer.WorkspaceIndexProgressText() + ")");
            return true;
        }
        return QueueReady(kind, label, newName, shell, docMgr, projMgr,
                          engine, indexer);
    }

    hide func QueueReady(kind: Integer,
                         label: String,
                         newName: String,
                         shell: app_shell.AppShell,
                         docMgr: document_manager.DocumentManager,
                         projMgr: project_manager.ProjectManager,
                         engine: editor_engine.EditorEngine,
                         indexer: project_index.ProjectIndexer) -> Boolean {
        var doc = docMgr.GetActive();
        if doc == null { return false; }
        file_commands.SaveEditorState(docMgr, engine);
        indexer.SyncActiveNow(docMgr, engine);
        indexer.SyncOpenDocuments(docMgr);
        if indexer.workspaceIndexTruncated {
            shell.SetStatusLeft(label
                                + " is unavailable because the workspace index is incomplete");
            GUI.Toast.Warning("Workspace index limits prevent a complete "
                              + label + " result");
            return false;
        }
        var source = engine.GetTextSnapshot();
        doc!.content = source;
        pendingGeneration = job.Queue(
            kind, label, indexer.handle, doc!.filePath, source,
            engine.editor.CursorLine + 1, engine.editor.CursorCol, newName,
            engine.GetRevision(), WorkspaceSignature(projMgr, indexer),
            indexer.contentGeneration);
        if pendingGeneration <= 0 {
            GUI.Toast.Error(label + " could not start");
            return false;
        }
        shell.SetStatusLeft(label + " running in background...");
        return true;
    }

    hide func PumpWaiting(shell: app_shell.AppShell,
                          docMgr: document_manager.DocumentManager,
                          projMgr: project_manager.ProjectManager,
                          engine: editor_engine.EditorEngine,
                          indexer: project_index.ProjectIndexer) {
        if waitingKind <= 0 { return; }
        if WaitingAnchorMatches(docMgr, projMgr, engine, indexer) == false {
            var label = waitingLabel;
            ResetWaiting();
            shell.SetStatusLeft(label + " canceled because the editor changed");
            return;
        }
        if indexer.PrepareWorkspaceQuery(INDEX_FILES_PER_WAITING_FRAME)
           == false {
            shell.SetStatusLeft(waitingLabel + " queued while indexing ("
                                + indexer.WorkspaceIndexProgressText() + ")");
            return;
        }
        if indexer.workspaceIndexTruncated {
            var unavailableLabel = waitingLabel;
            ResetWaiting();
            shell.SetStatusLeft(unavailableLabel
                                + " is unavailable because the workspace index is incomplete");
            GUI.Toast.Warning("Workspace index limits prevent a complete result");
            return;
        }
        var kind = waitingKind;
        var label2 = waitingLabel;
        var newName = waitingNewName;
        ResetWaiting();
        QueueReady(kind, label2, newName, shell, docMgr, projMgr, engine,
                   indexer);
    }

    hide func WaitingAnchorMatches(
        docMgr: document_manager.DocumentManager,
        projMgr: project_manager.ProjectManager,
        engine: editor_engine.EditorEngine,
        indexer: project_index.ProjectIndexer) -> Boolean {
        if docMgr == null or engine == null or engine.editor == null
           or indexer == null {
            return false;
        }
        var doc = docMgr.GetActive();
        return doc != null and doc!.language == "zia"
           and doc!.filePath == waitingPath
           and engine.GetRevision() == waitingRevision
           and engine.editor.CursorLine + 1 == waitingLine
           and engine.editor.CursorCol == waitingCol
           and WorkspaceSignature(projMgr, indexer)
               == waitingWorkspaceSignature;
    }

    hide func ResetWaiting() {
        waitingKind = 0;
        waitingLabel = "";
        waitingNewName = "";
        waitingPath = "";
        waitingRevision = -1;
        waitingLine = 1;
        waitingCol = 0;
        waitingWorkspaceSignature = "";
    }

    hide func FinishRequest(
        request: zia_workspace_query_job.ZiaWorkspaceQueryRequest,
        shell: app_shell.AppShell,
        docMgr: document_manager.DocumentManager,
        projMgr: project_manager.ProjectManager,
        engine: editor_engine.EditorEngine,
        tabs: editor_tabs.EditorTabs,
        indexer: project_index.ProjectIndexer,
        locStore: locations.LocationStore) {
        if request.generation != pendingGeneration { return; }
        pendingGeneration = 0;
        if AnchorMatches(request, docMgr, projMgr, engine, indexer) == false {
            shell.SetStatusLeft(request.label
                                + " canceled because the editor or index changed");
            return;
        }
        if request.succeeded == false or request.result == null {
            var message = request.label + " failed";
            if request.error != "" { message = message + ": " + request.error; }
            shell.SetStatusLeft(message);
            GUI.Toast.Error(message);
            return;
        }
        if request.kind == zia_workspace_query_job.ZIA_QUERY_DEFINITION {
            ApplyDefinition(shell, docMgr, engine, tabs, locStore,
                            request.result);
            return;
        }
        if request.kind == zia_workspace_query_job.ZIA_QUERY_RENAME {
            ApplyRename(shell, docMgr, engine, tabs, indexer, request);
            return;
        }
        BeginRendering(shell, request);
    }

    hide func ApplyDefinition(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine,
                              tabs: editor_tabs.EditorTabs,
                              locStore: locations.LocationStore,
                              definition: Any) {
        if Map.GetBool(definition, "found") == false {
            GUI.Toast.Info("Definition not found");
            return;
        }
        var line = Map.GetInt(definition, "line");
        var col = Map.GetInt(definition, "column");
        var id = locStore.Add(
            Map.GetStr(definition, "file"), line, col,
            Map.GetIntOr(definition, "endLine", line),
            Map.GetIntOr(definition, "endColumn", col + 1),
            locations.KIND_DEFINITION, Map.GetStr(definition, "name"));
        if locStore.OpenLocation(shell, docMgr, engine, tabs, id) {
            shell.SetStatusLeft("Definition: " + Map.GetStr(definition, "name"));
        }
    }

    hide func ApplyRename(
        shell: app_shell.AppShell,
        docMgr: document_manager.DocumentManager,
        engine: editor_engine.EditorEngine,
        tabs: editor_tabs.EditorTabs,
        indexer: project_index.ProjectIndexer,
        request: zia_workspace_query_job.ZiaWorkspaceQueryRequest) {
        var rename = request.result;
        if Map.GetBool(rename, "success") == false {
            var reason = Map.GetStr(rename, "reason");
            if reason == "" { reason = "not_found"; }
            GUI.Toast.Warning("Rename failed: " + reason);
            shell.SetStatusLeft("Rename failed: " + reason);
            return;
        }
        var edits = Map.Get(rename, "edits");
        if edits == null or Seq.get_Count(edits) == 0 {
            GUI.Toast.Warning("Rename failed: no references found");
            return;
        }
        var preview = workspace_edits.PreviewRenameEdits(edits, 20);
        if GUI.MessageBox.Confirm("Rename Preview", preview) == 0 {
            shell.SetStatusLeft("Rename canceled");
            return;
        }
        var result = workspace_edits.ApplyRenameEdits(edits, docMgr,
                                                      indexer.rootPaths);
        if result.success == false {
            shell.SetStatusLeft("Rename canceled: " + result.message);
            GUI.Toast.Error(result.message);
            return;
        }
        edit_commands.ApplyActiveDocumentContentToEditor(docMgr, engine, tabs);
        indexer.SyncActiveNow(docMgr, engine);
        shell.SetStatusLeft("Renamed to " + request.newName);
        GUI.Toast.Success("Rename complete");
    }

    hide func BeginRendering(
        shell: app_shell.AppShell,
        request: zia_workspace_query_job.ZiaWorkspaceQueryRequest) {
        renderItems = request.result;
        renderIndex = 0;
        renderLimit = request.resultCount;
        renderKind = request.kind;
        renderLabel = request.label;
        renderLastGroup = "";
        renderTruncated = request.truncated;
        renderedRows = 0;
        renderOriginPath = request.path;
        renderOriginSource = request.source;
        cachedSourcePath = request.path;
        cachedSource = request.source;
        shell.toolPanels.ClearToolRows(shell.toolPanels.referencesListBox);
        shell.toolPanels.HideReferencesPanel();
        if renderItems == null or renderLimit <= 0 {
            ResetRendering();
            ReportNoResults(shell, request.kind, request.reason);
            return;
        }
        shell.SetStatusLeft("Rendering " + renderLimit + " Zia results...");
    }

    hide func PumpRenderRows(shell: app_shell.AppShell,
                             docMgr: document_manager.DocumentManager,
                             locStore: locations.LocationStore) {
        lastPumpItems = 0;
        lastPumpSourceBytes = 0;
        if renderItems == null or shell == null or locStore == null { return; }
        while renderIndex < renderLimit
              and lastPumpItems < RESULT_ITEMS_PER_FRAME {
            var item = Seq.Get(renderItems, renderIndex);
            var sourcePath = Map.GetStr(item, "file");
            if renderKind
               == zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS {
                sourcePath = renderOriginPath;
            }
            if PrepareRenderSource(docMgr, sourcePath) == false { break; }
            AddRenderRow(shell, locStore, item);
            renderIndex = renderIndex + 1;
            lastPumpItems = lastPumpItems + 1;
        }
        if renderIndex < renderLimit {
            shell.SetStatusLeft("Rendering Zia results: " + renderIndex
                                + "/" + renderLimit);
            return;
        }
        if renderedRows <= 0 {
            var completedKind = renderKind;
            ResetRendering();
            ReportNoResults(shell, completedKind, "no_references");
            return;
        }
        shell.toolPanels.referencesListBox.SetVisible(true);
        shell.toolPanels.ShowReferencesPanel();
        var status = "Found " + renderedRows + " " + ResultNoun(renderKind);
        if renderTruncated { status = status + " (limited)"; }
        shell.SetStatusLeft(status);
        ResetRendering();
    }

    /// @brief Cache one bounded preview source without exceeding frame I/O budget.
    hide func PrepareRenderSource(docMgr: document_manager.DocumentManager,
                                  path: String) -> Boolean {
        if path == cachedSourcePath { return true; }
        cachedSourcePath = path;
        cachedSource = "";
        if path == "" { return true; }
        if docMgr != null {
            var index = docMgr.FindByPath(path);
            if index >= 0 {
                cachedSource = docMgr.documents.get(index).content;
                return true;
            }
        }
        if IO.File.Exists(path) == false { return true; }
        var size = safe_io.SizeBytes(path);
        if size < 0
           or size > zia_workspace_query_job.ZIA_MAX_QUERY_SOURCE_CHARS {
            return true;
        }
        if lastPumpSourceBytes > 0
           and lastPumpSourceBytes + size > RESULT_SOURCE_BYTES_PER_FRAME {
            cachedSourcePath = "";
            return false;
        }
        var read = safe_io.ReadAllTextBounded(
            path, zia_workspace_query_job.ZIA_MAX_QUERY_SOURCE_CHARS);
        if read.ok { cachedSource = read.text; }
        lastPumpSourceBytes = lastPumpSourceBytes + size;
        return true;
    }

    hide func AddRenderRow(shell: app_shell.AppShell,
                           locStore: locations.LocationStore,
                           item: Any) {
        if renderKind == zia_workspace_query_job.ZIA_QUERY_INCOMING_CALLS
           and Map.GetBool(item, "isDefinition") {
            return;
        }
        var file = Map.GetStr(item, "file");
        var line = Map.GetInt(item, "line");
        var col = Map.GetInt(item, "column");
        var rowLine = line;
        var rowCol = col;
        var groupTitle = Path.Name(file);
        var groupDetail = file;
        var groupKey = file;
        var rowKind = "ref";
        var marker = "";
        if renderKind == zia_workspace_query_job.ZIA_QUERY_INCOMING_CALLS {
            var caller = source_scan.EnclosingZiaFunctionName(cachedSource, line);
            if caller == "" { caller = "<top-level>"; }
            groupTitle = caller;
            groupDetail = Path.Name(file);
            groupKey = file + "|" + caller;
            rowKind = "call";
        } else if renderKind
                  == zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS {
            var targetName = Map.GetStr(item, "name");
            if targetName == "" { targetName = Map.GetStr(item, "callName"); }
            var callerName = Map.GetStr(item, "callerName");
            if callerName == "" { callerName = "<function>"; }
            groupTitle = callerName + " -> " + targetName;
            groupDetail = Path.Name(file);
            groupKey = file + "|" + groupTitle + "|" + line + "|" + col;
            rowKind = "call";
            marker = "definition";
            rowLine = Map.GetIntOr(item, "callLine", line);
            rowCol = Map.GetIntOr(item, "callColumn", col);
        } else if Map.GetBool(item, "isDefinition") {
            marker = "definition";
        }
        if groupKey != renderLastGroup {
            shell.toolPanels.AddToolGroupHeader(
                shell.toolPanels.referencesListBox, groupTitle, groupDetail);
            renderLastGroup = groupKey;
        }
        var locationKind = locations.KIND_REFERENCE;
        if renderKind == zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS {
            locationKind = locations.KIND_DEFINITION;
        }
        var id = locStore.Add(file, line, col,
                              Map.GetIntOr(item, "endLine", line),
                              Map.GetIntOr(item, "endColumn", col + 1),
                              locationKind, Map.GetStr(item, "name"));
        var preview = Str.Trim(source_scan.SourceLine(cachedSource, rowLine));
        var row = shell.toolPanels.AddToolLocationRow(
            shell.toolPanels.referencesListBox, rowKind, "zia",
            "" + rowLine + ":" + rowCol, marker, preview, "");
        GUI.ListBox.ItemSetData(row, id);
        renderedRows = renderedRows + 1;
    }

    hide func ResetRendering() {
        renderItems = null;
        renderIndex = 0;
        renderLimit = 0;
        renderKind = 0;
        renderLabel = "";
        renderLastGroup = "";
        renderTruncated = false;
        renderedRows = 0;
        renderOriginPath = "";
        renderOriginSource = "";
        cachedSourcePath = "";
        cachedSource = "";
    }
}

func WorkspaceSignature(projMgr: project_manager.ProjectManager,
                        indexer: project_index.ProjectIndexer) -> String {
    if projMgr != null and projMgr.IsOpen() {
        return projMgr.WorkspaceSignature();
    }
    if indexer != null { return indexer.workspaceSignature; }
    return "";
}

func AnchorMatches(
    request: zia_workspace_query_job.ZiaWorkspaceQueryRequest,
    docMgr: document_manager.DocumentManager,
    projMgr: project_manager.ProjectManager,
    engine: editor_engine.EditorEngine,
    indexer: project_index.ProjectIndexer) -> Boolean {
    if request == null or docMgr == null or engine == null
       or engine.editor == null or indexer == null {
        return false;
    }
    var doc = docMgr.GetActive();
    if doc == null or doc!.language != "zia" { return false; }
    return doc!.filePath == request.path
       and engine.GetRevision() == request.revision
       and engine.editor.CursorLine + 1 == request.line
       and engine.editor.CursorCol == request.col
       and WorkspaceSignature(projMgr, indexer) == request.workspaceSignature
       and indexer.contentGeneration == request.indexGeneration
       and indexer.workspaceIndexTruncated == false;
}

func ReportNoResults(shell: app_shell.AppShell,
                     kind: Integer,
                     reason: String) {
    var message = "No references found";
    if kind == zia_workspace_query_job.ZIA_QUERY_INCOMING_CALLS {
        message = "No incoming calls found";
    } else if kind == zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS {
        message = "No outgoing calls found";
        if reason == "no_enclosing_function" {
            message = "No enclosing function found";
        }
    }
    shell.SetStatusLeft(message);
    GUI.Toast.Info(message);
}

func ResultNoun(kind: Integer) -> String {
    if kind == zia_workspace_query_job.ZIA_QUERY_INCOMING_CALLS {
        return "incoming calls";
    }
    if kind == zia_workspace_query_job.ZIA_QUERY_OUTGOING_CALLS {
        return "outgoing calls";
    }
    return "references";
}
