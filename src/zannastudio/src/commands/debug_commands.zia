//
// File: zannastudio/src/commands/debug_commands.zia
// Purpose: Coordinate debugger commands, panels, breakpoints, and navigation.
// Key invariants:
//   - Debugger state changes are validated before adapter requests are sent.
//   - Unavailable frame sources never move or decorate an unrelated editor.
//   - Variable expansion requests render loading state and never wait in-frame.
//   - Watch entry and management stay inside the docked Variables surface.
//   - Run/Debug sidebar snapshots and action intent cross one command boundary.
// Ownership/Lifetime:
//   - DebugSession owns adapter state; AppShell and EditorEngine own UI state.
// Links: zannastudio/src/build/debug_session.zia,
//        zannastudio/src/commands/file_commands.zia
//
//===----------------------------------------------------------------------===//

module debug_commands;

bind "../ui/app_shell";
bind "../core/document_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../build/breakpoints";
bind "../build/debug_session";
bind "../build/var_model";
bind "../build/build_system";
bind "../commands/file_commands";
bind "../ui/debug_breakpoint_overlay";
bind "../ui/run_debug_support";
bind "../ui/run_debug_view";
bind "../services/file_utils";
bind "../services/theme_colors";

bind Zanna.GUI;
bind IO = Zanna.IO;
bind Path = Zanna.IO.Path;
bind Str = Zanna.String;
bind Seq = Zanna.Collections.Seq;
bind Map = Zanna.Collections.Map;
bind Obj = Zanna.Core.Object;
bind Convert = Zanna.Core.Convert;
bind Pixels = Zanna.Graphics.Pixels;

final DEBUG_STOP_SLOT = 1;

/// @brief Return whether the active document can be launched by the debugger.
/// @details The debug adapter launches a concrete source path, so an untitled
///          buffer or read-only preview is not yet a valid target.
/// @param docMgr Current document manager, if available.
/// @return True only for a saved editable active document.
expose func HasDebugTarget(docMgr: document_manager.DocumentManager) -> Boolean {
    if docMgr == null { return false; }
    var doc = docMgr.GetActive();
    return doc != null and doc!.isNew == false and doc!.filePath != ""
           and doc!.isReadOnlyPreview == false
           and file_utils.IsVisualKind(doc!.kind) == false;
}

// ============================================================================
// MODULE: debug_commands
// PURPOSE: Command handlers and per-frame UI sync for debugger features.
//
// WHERE-THIS-FITS: main_command_dispatcher routes menu, toolbar, shortcut, and
//          palette triggers here. DebugSession owns adapter process state, while
//          BreakpointStore owns persistent breakpoints. This module coordinates
//          those pieces with AppShell and the active editor.
//
// TEACHING-NOTE: Keep debugger commands idempotent and state-aware. A command
//          should validate saved paths, active sessions, stopped state, and
//          breakpoint sync before touching the adapter.
// ============================================================================

func handleToggleBreakpoint(shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            store: breakpoints.BreakpointStore) {
    file_commands.SaveEditorState(docMgr, engine);
    var maybeDoc = docMgr.GetActive();
    if maybeDoc == null {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }
    var doc = maybeDoc!;
    if doc.filePath == "" or doc.isNew {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }
    var line = engine.GetCursorLine();
    var added = store.Toggle(doc.filePath, line);
    var saved = store.Save();
    store.ApplyToEditor(engine, doc);
    if saved == false {
        shell.SetStatusLeft("Breakpoint changed, but could not be saved");
        GUI.Toast.Error("Could not save breakpoints");
    } else if added {
        shell.SetStatusLeft("Breakpoint set at line " + line);
    } else {
        shell.SetStatusLeft("Breakpoint cleared at line " + line);
    }
}

/// @brief Open the integrated conditional-breakpoint editor at the cursor line.
/// @details The non-modal overlay owns text entry and completion; the workbench
///          applies and live-syncs the condition when the overlay is submitted.
func handleSetCondition(shell: app_shell.AppShell,
                        docMgr: document_manager.DocumentManager,
                        engine: editor_engine.EditorEngine,
                        overlay: debug_breakpoint_overlay.DebugBreakpointOverlay,
                        store: breakpoints.BreakpointStore) {
    file_commands.SaveEditorState(docMgr, engine);
    var maybeDoc = docMgr.GetActive();
    if maybeDoc == null or maybeDoc!.filePath == "" or maybeDoc!.isNew {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }
    var doc = maybeDoc!;
    var line = engine.GetCursorLine();
    overlay.OpenCondition(shell, doc.filePath, line, store.ConditionAt(doc.filePath, line));
}

/// @brief Open the integrated logpoint editor at the cursor line.
/// @details A logpoint logs its message with {expr} interpolation and continues;
///          the workbench persists and live-syncs the value after overlay submit.
func handleAddLogpoint(shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine,
                       overlay: debug_breakpoint_overlay.DebugBreakpointOverlay,
                       store: breakpoints.BreakpointStore) {
    file_commands.SaveEditorState(docMgr, engine);
    var maybeDoc = docMgr.GetActive();
    if maybeDoc == null or maybeDoc!.filePath == "" or maybeDoc!.isNew {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }
    var doc = maybeDoc!;
    var line = engine.GetCursorLine();
    overlay.OpenLogpoint(shell, doc.filePath, line, store.LogMessageAt(doc.filePath, line));
}

/// @brief Navigate the editor to the source of the clicked Call Stack frame.
/// @details Each filtered row retains its original debugger frame index, so
///          selecting a lower frame jumps there without moving the execution
///          stop marker or depending on the current visible row order.
func handleCallStackSelect(shell: app_shell.AppShell,
                           docMgr: document_manager.DocumentManager,
                           engine: editor_engine.EditorEngine,
                           tabs: editor_tabs.EditorTabs,
                           session: debug_session.DebugSession) {
    if session == null { return; }
    var idx = shell.toolPanels.GetSelectedCallStackFrameIndex();
    if idx < 0 or idx >= session.FrameCount() { return; }
    var path = session.FramePath(idx);
    var line = session.FrameLine(idx);
    if path == "" or line <= 0 { return; }
    var maybeActive = docMgr.GetActive();
    var needsOpen = maybeActive == null;
    if maybeActive != null and SamePath(maybeActive!.filePath, path) == false {
        needsOpen = true;
    }
    if needsOpen {
        if IO.File.Exists(path) == false
           or file_commands.OpenFileAtPath(shell, docMgr, engine, tabs, path) == false {
            shell.SetStatusLeft("Frame source unavailable: " + path);
            return;
        }
    }
    engine.GoToLine(line);
    shell.SetStatusLeft("Frame: " + session.FrameLabel(idx));
}

/// @brief Open one durable breakpoint source location from the Run/Debug view.
func handleBreakpointLocation(shell: app_shell.AppShell,
                              docMgr: document_manager.DocumentManager,
                              engine: editor_engine.EditorEngine,
                              tabs: editor_tabs.EditorTabs,
                              path: String,
                              line: Integer) {
    if path == "" or line <= 0 { return; }
    if IO.File.Exists(path) == false {
        shell.SetStatusLeft("Breakpoint source unavailable: " + path);
        return;
    }
    var maybeActive = docMgr.GetActive();
    var needsOpen = maybeActive == null;
    if maybeActive != null
       and SamePath(maybeActive!.filePath, path) == false {
        needsOpen = true;
    }
    if needsOpen
       and file_commands.OpenFileAtPath(
               shell, docMgr, engine, tabs, path) == false {
        shell.SetStatusLeft("Breakpoint source unavailable: " + path);
        return;
    }
    engine.GoToLine(line);
    shell.SetStatusLeft("Breakpoint: " + Path.Name(path) + ":" + line);
}

/// @brief Remove one selected breakpoint and synchronize every live projection.
func handleRemoveBreakpoint(shell: app_shell.AppShell,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            store: breakpoints.BreakpointStore,
                            session: debug_session.DebugSession,
                            path: String,
                            line: Integer) {
    if store == null or store.RemoveAtLocation(path, line) == false {
        shell.SetStatusLeft("Breakpoint no longer exists");
        return;
    }
    var saved = store.Save();
    var active = docMgr.GetActive();
    if active != null { store.ApplyToEditor(engine, active!); }
    if session != null and session.IsActive() {
        session.SyncBreakpoints(path, store);
    }
    if saved {
        shell.SetStatusLeft(
            "Breakpoint removed at " + Path.Name(path) + ":" + line);
    } else {
        shell.SetStatusLeft(
            "Breakpoint removed, but could not be saved");
        GUI.Toast.Error("Could not save breakpoints");
    }
}

/// @brief Open metadata editing for one breakpoint selected outside the editor.
func handleBreakpointMetadata(shell: app_shell.AppShell,
                              overlay:
                                  debug_breakpoint_overlay.DebugBreakpointOverlay,
                              store: breakpoints.BreakpointStore,
                              path: String,
                              line: Integer,
                              action: Integer) {
    if overlay == null or store == null or path == "" or line <= 0 {
        return;
    }
    if action == debug_breakpoint_overlay.DEBUG_BP_ACTION_CONDITION {
        overlay.OpenCondition(
            shell, path, line, store.ConditionAt(path, line));
    } else if action
              == debug_breakpoint_overlay.DEBUG_BP_ACTION_LOGPOINT {
        overlay.OpenLogpoint(
            shell, path, line, store.LogMessageAt(path, line));
    }
}

func PumpGutter(shell: app_shell.AppShell,
                docMgr: document_manager.DocumentManager,
                engine: editor_engine.EditorEngine,
                store: breakpoints.BreakpointStore) {
    if engine == null or engine.editor == null { return; }
    var click = engine.editor.TakeGutterClick();
    if Map.GetBool(click, "clicked") == false { return; }
    var clickedLine0 = Map.GetInt(click, "line");
    if clickedLine0 < 0 { return; }

    var maybeDoc = docMgr.GetActive();
    if maybeDoc == null {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }
    var doc = maybeDoc!;
    if doc.filePath == "" or doc.isNew {
        shell.SetStatusLeft("Save file before setting breakpoints");
        return;
    }

    var line = clickedLine0 + 1;
    var added = store.Toggle(doc.filePath, line);
    var saved = store.Save();
    store.ApplyToEditor(engine, doc);
    if saved == false {
        shell.SetStatusLeft("Breakpoint changed, but could not be saved");
        GUI.Toast.Error("Could not save breakpoints");
    } else if added {
        shell.SetStatusLeft("Breakpoint set at line " + line);
    } else {
        shell.SetStatusLeft("Breakpoint cleared at line " + line);
    }
}

func handleDebugStart(shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine,
                      tabs: editor_tabs.EditorTabs,
                      buildSys: build_system.BuildSystem,
                      store: breakpoints.BreakpointStore,
                      session: debug_session.DebugSession,
                      saveAllBeforeBuild: Boolean) {
    if session.IsActive() {
        shell.SetStatusLeft("A debug session is already running");
        return;
    }
    var plan = PrepareDebugLaunch(shell, docMgr, engine, tabs, buildSys, saveAllBeforeBuild);
    if Map.GetBool(plan, "ok") == false { return; }
    LaunchPreparedDebug(shell, session, store, plan);
}

hide func PrepareDebugLaunch(shell: app_shell.AppShell,
                             docMgr: document_manager.DocumentManager,
                             engine: editor_engine.EditorEngine,
                             tabs: editor_tabs.EditorTabs,
                             buildSys: build_system.BuildSystem,
                             saveAllBeforeBuild: Boolean) -> Any {
    var result = Map.New();
    Map.SetBool(result, "ok", false);
    Map.SetStr(result, "zannaBin", "");
    Map.SetStr(result, "path", "");
    if buildSys == null {
        shell.SetStatusLeft("Debug failed: build system unavailable");
        return result;
    }
    if buildSys.IsActive() {
        shell.SetStatusLeft("Wait for the active job to finish before debugging");
        return result;
    }
    file_commands.SaveEditorState(docMgr, engine);
    var maybeDoc = docMgr.GetActive();
    if maybeDoc == null {
        shell.SetStatusLeft("No file to debug");
        return result;
    }
    var doc = maybeDoc!;
    if doc.isNew {
        shell.SetStatusLeft("Save file before debugging");
        return result;
    }

    var saveResult = file_commands.handleSaveForExecution(shell, docMgr, engine, tabs,
                                                          saveAllBeforeBuild);
    if saveResult.success == false {
        if saveResult.message != "" {
            shell.SetStatusLeft("Debug canceled: " + saveResult.message);
        } else {
            shell.SetStatusLeft("Debug canceled: files were not saved");
        }
        return result;
    }
    file_commands.SaveEditorState(docMgr, engine);
    maybeDoc = docMgr.GetActive();
    if maybeDoc == null { return result; }
    doc = maybeDoc!;
    if doc.isNew { return result; }

    var zannaBin = buildSys.ResolveCompiler("zanna");
    if zannaBin == "" {
        shell.toolPanels.SetDebugOutput("Cannot debug: the zanna compiler was not found.\n"
            + "Add zanna to your PATH or set ZANNA_BINARY=/full/path/to/zanna.");
        shell.SetStatusLeft("Debug failed: zanna not found");
        GUI.Toast.Error("zanna compiler not found");
        return result;
    }

    Map.SetBool(result, "ok", true);
    Map.SetStr(result, "zannaBin", zannaBin);
    Map.SetStr(result, "path", doc.filePath);
    return result;
}

hide func LaunchPreparedDebug(shell: app_shell.AppShell,
                              session: debug_session.DebugSession,
                              store: breakpoints.BreakpointStore,
                              plan: Any) -> Boolean {
    var zannaBin = Map.GetStr(plan, "zannaBin");
    var path = Map.GetStr(plan, "path");
    if session.Launch(zannaBin, path, store) {
        shell.toolPanels.SetDebugOutput("[debug] launched " + path
            + " — running to the first breakpoint...");
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Debugging " + path);
        return true;
    } else {
        shell.SetStatusLeft("Debug session did not start");
        GUI.Toast.Warning("Debug session did not start");
    }
    return false;
}

/// @brief Restart: terminate any active session, then relaunch the active file
///        with the current breakpoints.
func handleDebugRestart(shell: app_shell.AppShell,
                        docMgr: document_manager.DocumentManager,
                        engine: editor_engine.EditorEngine,
                        tabs: editor_tabs.EditorTabs,
                        buildSys: build_system.BuildSystem,
                        store: breakpoints.BreakpointStore,
                        session: debug_session.DebugSession,
                        saveAllBeforeBuild: Boolean) {
    var plan = PrepareDebugLaunch(shell, docMgr, engine, tabs, buildSys, saveAllBeforeBuild);
    if Map.GetBool(plan, "ok") == false { return; }
    if session.IsActive() {
        if session.RequestRestart(Map.GetStr(plan, "zannaBin"), Map.GetStr(plan, "path")) {
            shell.toolPanels.SetDebugOutput("[debug] restarting...");
            PopulateDebugPanels(shell, session);
            shell.SetStatusLeft("Restarting debugger...");
        } else {
            shell.SetStatusLeft("Debug restart did not start");
        }
        return;
    }
    LaunchPreparedDebug(shell, session, store, plan);
}

/// @brief Per-frame pump: drain adapter events and refresh the UI on change.
func DebugUpdate(shell: app_shell.AppShell,
                 docMgr: document_manager.DocumentManager,
                 engine: editor_engine.EditorEngine,
                 tabs: editor_tabs.EditorTabs,
                 store: breakpoints.BreakpointStore,
                 session: debug_session.DebugSession) {
    if session == null or session.processHandle == null { return; }
    if session.Poll() {
        if session.restartPending and session.IsActive() == false {
            var restartBin = session.restartZannaBin;
            var restartPath = session.restartPath;
            session.ClearRestartRequest();
            var plan = Map.New();
            Map.SetBool(plan, "ok", true);
            Map.SetStr(plan, "zannaBin", restartBin);
            Map.SetStr(plan, "path", restartPath);
            LaunchPreparedDebug(shell, session, store, plan);
        }
        Publish(shell, docMgr, engine, tabs, session);
        if session.evalJustArrived {
            session.evalJustArrived = false;
            var em = session.lastEvalExpr + " = ";
            if session.lastEvalOk {
                em = em + session.lastEvalValue + " : " + session.lastEvalType;
            } else {
                em = em + "(unavailable)";
            }
            shell.SetStatusLeft(em);
        }
    }
}

func handleDebugContinue(shell: app_shell.AppShell,
                         session: debug_session.DebugSession) {
    if session.Continue() {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Running...");
    } else {
        shell.SetStatusLeft("Not paused — nothing to continue");
    }
}

func handleDebugStepOver(shell: app_shell.AppShell,
                         session: debug_session.DebugSession) {
    if session.StepOver() {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Stepping...");
    } else {
        shell.SetStatusLeft("Not paused — nothing to step");
    }
}

/// @brief Step into the next debuggable call in a paused debug session.
func handleDebugStepIn(shell: app_shell.AppShell,
                       session: debug_session.DebugSession) {
    if session.StepIn() {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Stepping into...");
    } else {
        shell.SetStatusLeft("Not paused — nothing to step into");
    }
}

/// @brief Step out of the current function in a paused debug session.
func handleDebugStepOut(shell: app_shell.AppShell,
                        session: debug_session.DebugSession) {
    if session.StepOut() {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Stepping out...");
    } else {
        shell.SetStatusLeft("Not paused — nothing to step out of");
    }
}

func handleDebugPause(shell: app_shell.AppShell,
                      session: debug_session.DebugSession) {
    if session.Pause() {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Pausing...");
    } else {
        shell.SetStatusLeft("Nothing running to pause");
    }
}

func handleDebugStop(shell: app_shell.AppShell,
                     session: debug_session.DebugSession) {
    if session.RequestTerminate() {
        shell.toolPanels.SetDebugOutput("[debug] stopping...");
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Stopping debugger...");
    } else {
        shell.SetStatusLeft("No active debug session");
    }
}

hide func isIdentChar(ch: String) -> Boolean {
    return (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z")
        or (ch >= "0" and ch <= "9") or ch == "_";
}

/// @brief Extract the identifier spanning 0-based column `col0` of `lineText`.
hide func identifierAt(lineText: String, col0: Integer) -> String {
    var n = Str.get_Length(lineText);
    var p = col0 + 1; // 1-based for MidLen
    if p < 1 or p > n { return ""; }
    if isIdentChar(Str.MidLen(lineText, p, 1)) == false { return ""; }
    var start = p;
    while start > 1 and isIdentChar(Str.MidLen(lineText, start - 1, 1)) {
        start = start - 1;
    }
    var endp = p;
    while endp < n and isIdentChar(Str.MidLen(lineText, endp + 1, 1)) {
        endp = endp + 1;
    }
    return Str.MidLen(lineText, start, endp - start + 1);
}

/// @brief The identifier under the editor cursor, or "" if none.
hide func wordAtCursor(engine: editor_engine.EditorEngine) -> String {
    var idx = engine.GetCursorLine() - 1; // 0-based source line
    var col0 = engine.GetCursorCol() - 1; // 0-based column
    var source = engine.GetTextSnapshot();
    var lines = Str.Split(source, "\n");
    if idx < 0 or idx >= Seq.get_Count(lines) { return ""; }
    var lineText = Obj.ToString(Seq.Get(lines, idx));
    if Str.EndsWith(lineText, "\r") {
        lineText = Str.Left(lineText, Str.get_Length(lineText) - 1);
    }
    return identifierAt(lineText, col0);
}

/// @brief Editor context-menu "Evaluate": evaluate the identifier under the
///        cursor at the current debug stop. The result arrives asynchronously
///        and is surfaced by DebugUpdate.
func handleEvaluateAtCursor(shell: app_shell.AppShell,
                            engine: editor_engine.EditorEngine,
                            session: debug_session.DebugSession) {
    if session == null or session.IsActive() == false or session.stopped == false {
        shell.SetStatusLeft("Evaluate works while paused at a breakpoint");
        return;
    }
    var expr = DebugExpressionFromEditor(engine);
    if expr == "" {
        shell.SetStatusLeft("Evaluate: select an expression or place the cursor on a variable");
        return;
    }
    session.AddWatch(expr);
    if session.Evaluate(expr) {
        shell.SetStatusLeft("Evaluating and watching " + expr + "...");
    }
}

/// @brief Add a watch expression captured by command UI.
/// @param shell Workbench shell for status feedback.
/// @param session Debug session whose watch list should be updated.
/// @param expression User-entered expression text.
/// @return True when a new watch was added.
func handleAddWatchExpression(shell: app_shell.AppShell,
                              session: debug_session.DebugSession,
                              expression: String) -> Boolean {
    if session == null {
        shell.SetStatusLeft("Watch: debugger unavailable");
        return false;
    }
    var expr = Str.Trim(expression);
    if expr == "" {
        shell.SetStatusLeft("Watch not added");
        return false;
    }
    if session.AddWatch(expr) {
        if session.stopped {
            session.RefreshWatches();
            shell.SetStatusLeft("Watching " + expr);
        } else {
            shell.SetStatusLeft("Watching " + expr + " when the debugger stops");
        }
        PopulateDebugPanels(shell, session);
        shell.toolPanels.ShowVariablesPanel();
        return true;
    } else {
        shell.SetStatusLeft("Watch already exists: " + expr);
        shell.toolPanels.ShowVariablesPanel();
    }
    return false;
}

/// @brief Remove the selected watch row from the Variables panel.
/// @details The ListBox row data is populated from VirtualTree node IDs, so the
///          handler does not parse visible labels that may contain arbitrary
///          expression text.
/// @param shell Workbench shell containing the selected Variables row.
/// @param session Debug session whose watch list should be updated.
func handleRemoveSelectedWatch(shell: app_shell.AppShell,
                               session: debug_session.DebugSession) {
    if session == null {
        shell.SetStatusLeft("Watch: debugger unavailable");
        return;
    }
    var index = SelectedWatchIndex(shell);
    if index < 0 {
        shell.SetStatusLeft("Select a watch row to remove");
        shell.toolPanels.ShowVariablesPanel();
        return;
    }
    var expr = session.WatchExpression(index);
    if session.RemoveWatch(index) {
        PopulateDebugPanels(shell, session);
        shell.toolPanels.ShowVariablesPanel();
        if expr != "" {
            shell.SetStatusLeft("Removed watch " + expr);
        } else {
            shell.SetStatusLeft("Removed watch");
        }
    } else {
        shell.SetStatusLeft("Watch row is no longer available");
    }
}

/// @brief Refresh all watch expressions at the current debug stop.
/// @details Refresh is explicit for cases where locals changed through a manual
///          evaluate or an adapter event was missed; normal breakpoint stops
///          still refresh automatically.
/// @param shell Workbench shell for status feedback.
/// @param session Debug session whose watches should be refreshed.
func handleRefreshWatches(shell: app_shell.AppShell,
                          session: debug_session.DebugSession) {
    if session == null or session.WatchCount() == 0 {
        shell.SetStatusLeft("No watches to refresh");
        return;
    }
    if session.stopped == false {
        shell.SetStatusLeft("Pause at a breakpoint before refreshing watches");
        return;
    }
    session.RefreshWatches();
    PopulateDebugPanels(shell, session);
    shell.toolPanels.ShowVariablesPanel();
    shell.SetStatusLeft("Refreshing watches...");
}

/// @brief Clear every persistent watch expression from the debug session.
/// @details This does not terminate the adapter or clear locals/call stack rows;
///          it only removes the user-created Watches section.
/// @param shell Workbench shell for status feedback.
/// @param session Debug session whose watches should be cleared.
func handleClearWatches(shell: app_shell.AppShell,
                        session: debug_session.DebugSession) {
    if session == null {
        shell.SetStatusLeft("Watch: debugger unavailable");
        return;
    }
    if session.WatchCount() == 0 {
        shell.SetStatusLeft("No watches to clear");
        shell.toolPanels.ShowVariablesPanel();
        return;
    }
    session.ClearWatches();
    PopulateDebugPanels(shell, session);
    shell.toolPanels.ShowVariablesPanel();
    shell.SetStatusLeft("Cleared watches");
}

/// @brief Reveal the Variables watch field for an explicit Add Watch command.
/// @param shell Workbench shell that owns the Variables panel.
/// @param initialExpression Selected/cursor expression used as an optional seed.
/// @details An empty seed preserves in-progress watch text. A non-empty editor
///          expression intentionally replaces it because the user invoked Add
///          Watch from that source context.
expose func OpenWatchInput(shell: app_shell.AppShell,
                           initialExpression: String) {
    if shell == null { return; }
    var seed = Str.Trim(initialExpression);
    if seed != "" {
        shell.toolPanels.SetWatchExpressionText(seed);
    }
    shell.toolPanels.ShowVariablesPanel();
    shell.toolPanels.FocusWatchExpression();
    shell.SetStatusLeft("Enter a watch expression and press Enter");
}

/// @brief Pump inline Variables-panel watch controls once per UI frame.
/// @param shell Workbench shell containing the watch toolbar.
/// @param session Debug session owning persistent watch expressions.
/// @return True when one toolbar action was handled.
/// @details Availability is recomputed before and after input so typed text,
///          selected rows, pause state, and mutations stay synchronized without
///          waiting for a debugger event.
expose func HandleWatchToolbar(shell: app_shell.AppShell,
                               session: debug_session.DebugSession) -> Boolean {
    if shell == null { return false; }
    var count = 0;
    var stopped = false;
    if session != null {
        count = session.WatchCount();
        stopped = session.stopped;
    }
    shell.toolPanels.SetWatchToolbarState(
        session != null, SelectedWatchIndex(shell) >= 0, stopped, count);

    var handled = false;
    if shell.toolPanels.WatchAddWasRequested() {
        handled = true;
        if handleAddWatchExpression(
               shell, session, shell.toolPanels.GetWatchExpressionText()) {
            shell.toolPanels.ClearWatchExpression();
        }
        shell.toolPanels.FocusWatchExpression();
    } else if shell.toolPanels.WatchRemoveWasRequested() {
        handled = true;
        handleRemoveSelectedWatch(shell, session);
    } else if shell.toolPanels.WatchRefreshWasRequested() {
        handled = true;
        handleRefreshWatches(shell, session);
    } else if shell.toolPanels.WatchClearWasRequested() {
        handled = true;
        handleClearWatches(shell, session);
    }

    count = 0;
    stopped = false;
    if session != null {
        count = session.WatchCount();
        stopped = session.stopped;
    }
    shell.toolPanels.SetWatchToolbarState(
        session != null, SelectedWatchIndex(shell) >= 0, stopped, count);
    return handled;
}

/// @brief "Run to Cursor": continue execution until it reaches the cursor's line
///        in the active document, via a one-shot breakpoint. Only valid while
///        paused at a breakpoint (mirrors Evaluate's gating).
func handleRunToCursor(shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       engine: editor_engine.EditorEngine,
                       session: debug_session.DebugSession) {
    if session == null or session.IsActive() == false or session.stopped == false {
        shell.SetStatusLeft("Run to Cursor works while paused at a breakpoint");
        return;
    }
    var doc = docMgr.GetActive();
    if doc == null {
        shell.SetStatusLeft("Run to Cursor: no active file");
        return;
    }
    var line = engine.GetCursorLine();
    if session.RunToLine(doc!.filePath, line) {
        PopulateDebugPanels(shell, session);
        shell.SetStatusLeft("Running to line " + line + "...");
    }
}

/// @brief Choose the expression to send to the debug adapter evaluator.
/// @details A non-empty primary selection wins so users can evaluate compound
///          expressions. With no selection, the command falls back to the
///          identifier under the cursor for quick variable inspection.
/// @param engine Active editor engine.
/// @return Trimmed selected text or cursor identifier, empty if unavailable.
func DebugExpressionFromEditor(engine: editor_engine.EditorEngine) -> String {
    if engine == null or engine.editor == null { return ""; }
    if engine.editor.CursorHasSelection(0) {
        var selected = Str.Trim(engine.editor.GetSelectedText());
        if selected != "" { return selected; }
    }
    return wordAtCursor(engine);
}

func Publish(shell: app_shell.AppShell,
             docMgr: document_manager.DocumentManager,
             engine: editor_engine.EditorEngine,
             tabs: editor_tabs.EditorTabs,
             session: debug_session.DebugSession) {
    var stopInfo = session.FormatConsole();
    shell.toolPanels.UpdateDebugOutputParts(session.programOutput, stopInfo);
    PopulateDebugPanels(shell, session);
    if session.lastType == "stopped" {
        shell.SetStatusLeft("Stopped at " + session.activePath + ":" + session.lastLine
            + " (" + session.lastReason + ")");
        OpenStopLocation(shell, docMgr, engine, tabs, session);
    } else if session.lastType == "terminated" {
        ClearDebugStopMarker(engine);
        shell.SetStatusLeft("Program exited (" + session.lastReason + ", code "
            + session.exitCode + ")");
    }
}

/// @brief Return a concise state label for debugger-owned panel chrome.
func DebugPanelStateLabel(session: debug_session.DebugSession) -> String {
    if session == null { return "Idle"; }
    if session.restartPending { return "Restarting"; }
    if session.terminated { return "Terminated"; }
    if session.terminateRequested or session.lastType == "terminating" {
        return "Stopping";
    }
    if session.lastType == "pausing" { return "Pausing"; }
    if session.stopped { return "Paused"; }
    if session.IsActive() { return "Running"; }
    return "Idle";
}

/// @brief Build one concise, truthful Run/Debug sidebar state description.
hide func RunDebugStateDetail(
    state: String,
    session: debug_session.DebugSession,
    docMgr: document_manager.DocumentManager,
    hasTarget: Boolean,
    buildBusy: Boolean) -> String {
    var targetName = "";
    if docMgr != null {
        var activeDoc = docMgr.GetActive();
        if activeDoc != null {
            targetName = activeDoc!.fileName;
            if targetName == "" {
                targetName = Path.Name(activeDoc!.filePath);
            }
        }
    }
    var sessionName = targetName;
    if session != null and session.activePath != "" {
        sessionName = Path.Name(session.activePath);
    }
    if state == "Paused" {
        var detail = "Paused";
        if sessionName != "" {
            detail = detail + " at " + sessionName;
            if session != null and session.lastLine > 0 {
                detail = detail + ":" + session.lastLine;
            }
        }
        if session != null and session.lastReason != "" {
            detail = detail + " · " + session.lastReason;
        }
        return detail;
    }
    if state == "Running" {
        if sessionName != "" { return "Running " + sessionName; }
        return "Debugger is running";
    }
    if state == "Pausing" {
        if sessionName != "" { return "Pausing " + sessionName + "..."; }
        return "Waiting for the debugger to pause...";
    }
    if state == "Restarting" {
        if sessionName != "" { return "Restarting " + sessionName + "..."; }
        return "Restarting debugger...";
    }
    if state == "Stopping" { return "Stopping debugger..."; }
    if state == "Terminated" {
        var terminated = "Debug session ended";
        if session != null and session.exitCode >= 0 {
            terminated = terminated + " with code " + session.exitCode;
        }
        if session != null and session.lastReason != ""
           and session.lastReason != "exit" {
            terminated = terminated + " · " + session.lastReason;
        }
        return terminated;
    }
    if buildBusy {
        return "Wait for the active build or run job to finish";
    }
    if hasTarget == false {
        return "Open or save a source file to start debugging";
    }
    if targetName != "" { return "Ready to debug " + targetName; }
    return "Ready to debug the active source file";
}

/// @brief Publish debugger and breakpoint snapshots to the Run/Debug view.
func SyncRunDebugView(
    view: run_debug_view.RunDebugView,
    docMgr: document_manager.DocumentManager,
    buildSys: build_system.BuildSystem,
    store: breakpoints.BreakpointStore,
    session: debug_session.DebugSession) {
    if view == null { return; }
    var hasTarget = HasDebugTarget(docMgr);
    var buildBusy = buildSys != null and buildSys.IsActive();
    var state = DebugPanelStateLabel(session);
    var active = session != null and session.IsActive();
    var stopped = session != null and session.stopped;
    var stopping = session != null
        and (session.terminateRequested or session.restartPending);
    view.UpdateSession(
        hasTarget, buildBusy, state,
        RunDebugStateDetail(
            state, session, docMgr, hasTarget, buildBusy),
        active, stopped, stopping);

    if store == null {
        if view.breakpointModelVersion != -2 {
            view.BeginBreakpoints(-2);
            view.EndBreakpoints();
        }
        return;
    }
    if view.breakpointModelVersion == store.version { return; }
    view.BeginBreakpoints(store.version);
    var i = 0;
    while i < store.Count() {
        view.AddBreakpoint(
            i, store.GetPath(i), store.GetLine(i),
            store.GetCondition(i), store.GetLogMessage(i));
        i = i + 1;
    }
    view.EndBreakpoints();
}

/// @brief Poll and dispatch the state-aware Run/Debug activity view.
func PumpRunDebugView(
    shell: app_shell.AppShell,
    view: run_debug_view.RunDebugView,
    docMgr: document_manager.DocumentManager,
    engine: editor_engine.EditorEngine,
    tabs: editor_tabs.EditorTabs,
    buildSys: build_system.BuildSystem,
    store: breakpoints.BreakpointStore,
    session: debug_session.DebugSession,
    overlay: debug_breakpoint_overlay.DebugBreakpointOverlay,
    saveAllBeforeBuild: Boolean) {
    if view == null { return; }
    SyncRunDebugView(view, docMgr, buildSys, store, session);
    var action = view.Pump();
    if action == run_debug_support.RUN_DEBUG_ACTION_NONE { return; }

    var breakpointPath = view.SelectedBreakpointPath();
    var breakpointLine = view.SelectedBreakpointLine();
    if action == run_debug_support.RUN_DEBUG_ACTION_START {
        handleDebugStart(shell, docMgr, engine, tabs, buildSys, store,
                         session, saveAllBeforeBuild);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_CONTINUE {
        handleDebugContinue(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_PAUSE {
        handleDebugPause(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_RESTART {
        handleDebugRestart(shell, docMgr, engine, tabs, buildSys, store,
                           session, saveAllBeforeBuild);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_STOP {
        handleDebugStop(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_STEP_OVER {
        handleDebugStepOver(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_STEP_IN {
        handleDebugStepIn(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_STEP_OUT {
        handleDebugStepOut(shell, session);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_OPEN_VARIABLES {
        PopulateDebugPanels(shell, session);
        shell.toolPanels.ShowVariablesPanel();
    } else if action == run_debug_support.RUN_DEBUG_ACTION_OPEN_CALL_STACK {
        PopulateDebugPanels(shell, session);
        shell.toolPanels.ShowCallStackPanel();
    } else if action == run_debug_support.RUN_DEBUG_ACTION_OPEN_CONSOLE {
        shell.toolPanels.ShowDebugPanel();
    } else if action == run_debug_support.RUN_DEBUG_ACTION_OPEN_BREAKPOINT {
        handleBreakpointLocation(
            shell, docMgr, engine, tabs, breakpointPath, breakpointLine);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_REMOVE_BREAKPOINT {
        handleRemoveBreakpoint(
            shell, docMgr, engine, store, session,
            breakpointPath, breakpointLine);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_EDIT_CONDITION {
        handleBreakpointMetadata(
            shell, overlay, store, breakpointPath, breakpointLine,
            debug_breakpoint_overlay.DEBUG_BP_ACTION_CONDITION);
    } else if action == run_debug_support.RUN_DEBUG_ACTION_EDIT_LOGPOINT {
        handleBreakpointMetadata(
            shell, overlay, store, breakpointPath, breakpointLine,
            debug_breakpoint_overlay.DEBUG_BP_ACTION_LOGPOINT);
    }
    SyncRunDebugView(view, docMgr, buildSys, store, session);
}

/// @brief Fill the Variables and Call Stack panels from the session's structured
///        stop snapshot. Cleared when not stopped. Does not change the active tab,
///        so the user's panel choice (Debug Console etc.) is preserved; the rows
///        are ready the moment they click Variables or Call Stack.
func PopulateDebugPanels(shell: app_shell.AppShell,
                         session: debug_session.DebugSession) {
    shell.toolPanels.ClearToolRows(shell.toolPanels.variablesListBox);
    shell.toolPanels.BeginCallStack(DebugPanelStateLabel(session));
    if session == null { return; }

    var variableTree = GUI.VirtualTree.New();
    var wc = session.WatchCount();
    if session.stopped == false and wc == 0 { return; }
    if wc > 0 {
        variableTree.AddNode("", "watches", "Watches");
        var wi = 0;
        while wi < wc {
            variableTree.AddNode("watches", "watch:" + wi, session.WatchLabel(wi));
            wi = wi + 1;
        }
        variableTree.Expand("watches");
    }

    var lc = 0;
    if session.stopped {
        lc = session.LocalCount();
    }
    if lc == 0 {
        if session.stopped == false {
            variableTree.AddNode("", "locals", "Locals: pause debugger to inspect");
        } else if wc == 0 {
            variableTree.AddNode("", "locals-empty", "(no locals in scope)");
        } else {
            variableTree.AddNode("", "locals", "Locals: (none)");
        }
    } else {
        variableTree.AddNode("", "locals", "Locals");
        var i = 0;
        while i < lc {
            AddVarNode(session, variableTree, "locals", session.LocalName(i),
                       session.LocalName(i), session.LocalValue(i),
                       session.LocalType(i), session.LocalVarRef(i),
                       session.LocalChildCount(i));
            i = i + 1;
        }
        variableTree.Expand("locals");
    }
    RenderVariableTree(shell, variableTree);

    if session.stopped == false { return; }
    var fc = session.FrameCount();
    var j = 0;
    while j < fc {
        shell.toolPanels.AddCallStackFrame(j, session.FrameLabel(j));
        j = j + 1;
    }
}

/// @brief Clear only debugger-owned program output and retain session status.
func handleClearDebugConsole(shell: app_shell.AppShell,
                             session: debug_session.DebugSession) {
    if session == null {
        shell.toolPanels.UpdateDebugOutput("");
        shell.SetStatusLeft("Cleared debug output");
        return;
    }
    session.ClearProgramOutput();
    shell.toolPanels.UpdateDebugOutputParts("", session.FormatConsole());
    shell.SetStatusLeft("Cleared debug program output");
}

/// @brief Render the structured Variables tree into the existing tool ListBox.
hide func RenderVariableTree(shell: app_shell.AppShell,
                             tree: GUI.VirtualTree) {
    if shell == null or tree == null { return; }
    var rows = tree.VisibleRows();
    if rows == null { return; }
    var i = 0;
    while i < Seq.get_Count(rows) {
        var row = Seq.Get(rows, i);
        var depth = Map.GetInt(row, "depth");
        var text = Map.GetStr(row, "text");
        var id = Map.GetStr(row, "id");
        var item: Any = null;
        if depth <= 0 {
            item = shell.toolPanels.AddToolSectionRow(shell.toolPanels.variablesListBox, text);
        } else {
            item = shell.toolPanels.AddToolPlainRow(shell.toolPanels.variablesListBox, IndentForDepth(depth) + text, 0);
        }
        if item != null and id != "" {
            GUI.ListBox.ItemSetData(item, id);
        }
        i = i + 1;
    }
}

/// @brief Return the selected watch index from the Variables panel, or -1.
/// @details Only node IDs with the `watch:` prefix are accepted; section rows
///          and locals intentionally cannot be removed by watch commands.
/// @param shell Workbench shell containing the Variables list box.
/// @return Zero-based watch index, or -1 when no watch row is selected.
hide func SelectedWatchIndex(shell: app_shell.AppShell) -> Integer {
    if shell == null or shell.toolPanels.variablesListBox == null { return -1; }
    var item = shell.toolPanels.variablesListBox.Selected;
    if item == null { return -1; }
    var id = GUI.ListBox.ItemGetData(item);
    if Str.StartsWith(id, "watch:") == false { return -1; }
    return Convert.ToInt64(Str.Mid(id, 7));
}

/// @brief Add a variable row to @p tree and, when it is an expanded composite,
///        recurse into its (lazily fetched, cached) children.
/// @details Node ids are stable name-paths ("nums", "nums/[0]") so expansion
///          state survives steps. A leaf that somehow carries an expanded flag
///          (e.g. it was a composite before a step turned it scalar) is pruned so
///          the flag set stays clean.
hide func AddVarNode(session: debug_session.DebugSession, tree: GUI.VirtualTree,
                     parentId: String, path: String, name: String, value: String,
                     typeName: String, varRef: Integer, childCount: Integer) {
    var expandable = varRef > 0 and childCount > 0;
    var expanded = expandable and session.varTree.IsExpanded(path);
    if expandable == false and session.varTree.IsExpanded(path) {
        session.varTree.SetExpanded(path, false); // prune a now-scalar node
    }
    var twisty = "   ";
    if expandable {
        if expanded { twisty = " ▾ "; } else { twisty = " ▸ "; }
    }
    var label = twisty + name + " = " + value + " : " + typeName;
    tree.AddNode(parentId, path, label);
    if expanded == false { return; }

    if session.varTree.HasCache(path) == false {
        var statusLabel = "   Loading children...";
        if session.VariableChildrenRequestFailed(path) {
            statusLabel = "   Children unavailable — collapse and expand to retry";
        } else if session.VariableChildrenRequestPending(path) {
            statusLabel = "   Loading children...";
        } else if session.VariableChildrenRequestActive() {
            statusLabel = "   Waiting to load children...";
        } else if session.RequestVariableChildren(path, varRef) == false {
            statusLabel = "   Children unavailable";
        }
        tree.AddNode(path, "variable-status:" + path, statusLabel);
        tree.Expand(path);
        return;
    }
    var kids = session.varTree.GetCache(path);
    if kids == null { return; }
    tree.Expand(path);
    var k = 0;
    while k < kids.items.count() {
        var c = kids.items.get(k) as var_model.VarChildRec;
        AddVarNode(session, tree, path, path + "/" + c.name, c.name, c.value,
                   c.typeName, c.varRef, c.childCount);
        k = k + 1;
    }
}

/// @brief Toggle expand/collapse of the selected Variables row. Returns true when
///        a variable row was activated (so the caller re-renders).
/// @details Bound to the Variables list selection change. Expanding an unloaded
///          composite queues an adapter request and immediately renders a
///          loading row; a later DebugUpdate publishes the cached children.
func HandleVariableActivate(shell: app_shell.AppShell,
                            session: debug_session.DebugSession) -> Boolean {
    if shell == null or session == null or session.stopped == false { return false; }
    if shell.toolPanels.variablesListBox == null { return false; }
    var item = shell.toolPanels.variablesListBox.Selected;
    if item == null { return false; }
    var id = GUI.ListBox.ItemGetData(item);
    // Local variable rows use their name-path as the id; watch/section rows use
    // their own prefixes and are handled elsewhere.
    if id == "" or Str.StartsWith(id, "watch:")
        or Str.StartsWith(id, "variable-status:") or id == "locals"
        or id == "watches" or id == "locals-empty" { return false; }
    var expanded = session.varTree.Toggle(id);
    if expanded { session.ClearVariableChildrenFailure(id); }
    PopulateDebugPanels(shell, session);
    return true;
}

hide func IndentForDepth(depth: Integer) -> String {
    var text = "";
    var i = 0;
    while i < depth {
        text = text + "  ";
        i = i + 1;
    }
    return text;
}

/// @brief True if two paths denote the same source file after absolute
///        lexical normalization.
/// @details Debugger stop paths can differ from editor paths by relative
///          spelling or `.`/`..` segments. Normalized absolute equality covers
///          those cases without the false positives caused by suffix matching
///          similarly named files in different directories.
func SamePath(a: String, b: String) -> Boolean {
    if a == b { return true; }
    if a == "" or b == "" { return false; }
    var na = Path.Normalize(Path.Absolute(a));
    var nb = Path.Normalize(Path.Absolute(b));
    return na == nb;
}

func OpenStopLocation(shell: app_shell.AppShell,
                      docMgr: document_manager.DocumentManager,
                      engine: editor_engine.EditorEngine,
                      tabs: editor_tabs.EditorTabs,
                      session: debug_session.DebugSession) {
    if session.activePath == "" or session.lastLine <= 0 { return; }
    var maybeActive = docMgr.GetActive();
    var needsOpen = false;
    if maybeActive == null {
        needsOpen = true;
    } else {
        var active = maybeActive!;
        if SamePath(active.filePath, session.activePath) == false {
            needsOpen = true;
        }
    }
    if needsOpen {
        if IO.File.Exists(session.activePath) == false
           or file_commands.OpenFileAtPath(shell, docMgr, engine, tabs,
                                           session.activePath) == false {
            ClearDebugStopMarker(engine);
            shell.SetStatusLeft("Stopped source unavailable: " + session.activePath);
            return;
        }
    }
    engine.GoToLine(session.lastLine);
    MarkDebugStopLine(engine, session.lastLine);
}

/// @brief Draw the current debug stop line in the secondary gutter slot.
/// @details Breakpoints use slot 0, so this marker can be cleared/repainted
///          independently as the VM stops on different lines.
/// @param engine Editor containing the stopped source file.
/// @param line One-based source line reported by the debug adapter.
func MarkDebugStopLine(engine: editor_engine.EditorEngine,
                       line: Integer) {
    if engine == null or engine.editor == null or line <= 0 { return; }
    engine.editor.ClearGutterIcons(DEBUG_STOP_SLOT);
    engine.editor.SetGutterIcon(line - 1, DebugStopIcon(), DEBUG_STOP_SLOT);
}

/// @brief Clear the current debug stop marker from the editor gutter.
/// @param engine Editor whose secondary gutter slot should be cleared.
func ClearDebugStopMarker(engine: editor_engine.EditorEngine) {
    if engine == null or engine.editor == null { return; }
    engine.editor.ClearGutterIcons(DEBUG_STOP_SLOT);
}

/// @brief Build a compact arrow marker for the current debug execution line.
/// @details The icon is generated at runtime to keep Zanna Studio dependency-free
///          and avoid adding platform-specific image assets.
/// @return Pixels object suitable for CodeEditor.SetGutterIcon.
func DebugStopIcon() -> Any {
    var px = Pixels.New(8, 8);
    px.Clear();
    var stopColor = theme_colors.Rgba("accentInfo");
    px.SetRgba(2, 1, stopColor);
    px.SetRgba(2, 2, stopColor);
    px.SetRgba(3, 2, stopColor);
    px.SetRgba(2, 3, stopColor);
    px.SetRgba(3, 3, stopColor);
    px.SetRgba(4, 3, stopColor);
    px.SetRgba(2, 4, stopColor);
    px.SetRgba(3, 4, stopColor);
    px.SetRgba(4, 4, stopColor);
    px.SetRgba(5, 4, stopColor);
    px.SetRgba(2, 5, stopColor);
    px.SetRgba(3, 5, stopColor);
    px.SetRgba(4, 5, stopColor);
    px.SetRgba(2, 6, stopColor);
    px.SetRgba(3, 6, stopColor);
    px.SetRgba(2, 7, stopColor);
    return px;
}
