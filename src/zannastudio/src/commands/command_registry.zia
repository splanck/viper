//
// File: zannastudio/src/commands/command_registry.zia
// Purpose: Own Studio command metadata and reconcile language, document,
//          workspace, build-job, and debugger availability.
// Key invariants:
//   - Menu, palette, and shortcut entry points share the same availability.
//   - Invalid persisted or live shortcut spellings never replace a working binding.
//   - Runtime context is permissive until the application explicitly supplies
//     its first snapshot, preserving standalone registry use in tooling/tests.
// Ownership/Lifetime:
//   - Main owns one registry and refreshes its runtime context once per frame.
// Links: zannastudio/src/commands/command_catalog.zia,
//        zannastudio/src/ui/menu_chrome.zia
//
//===----------------------------------------------------------------------===//

module command_registry;

bind "../commands/command_catalog";
bind "../editor/language_service";

bind Zanna.GUI;
bind Str = Zanna.String;
bind Seq = Zanna.Collections.Seq;

// ============================================================================
// MODULE: command_registry
// PURPOSE: Runtime command table, shortcut installer, and capability gate.
//
// WHERE-THIS-FITS: command_catalog owns static command metadata. AppShell owns
//          menu/toolbar widgets. main_command_dispatcher owns handler routing.
//          This registry sits between them: it copies catalog entries into
//          runtime CommandEntry objects, installs shortcuts, populates the
//          palette, and explains capability-disabled commands.
//
// TEACHING-NOTE: Keep command metadata, trigger routing, and implementation
//          separate. When adding a command, update the catalog first, wire a
//          handler in the dispatcher, then let this registry handle palette and
//          shortcut visibility.
// ============================================================================

class CommandEntry {
    expose String id;
    expose String label;
    expose String description;
    expose String category;
    expose String shortcut;
    expose String capability;
    expose Boolean showInPalette;

    expose func init() {
        id = "";
        label = "";
        description = "";
        category = "";
        shortcut = "";
        capability = "";
        showInPalette = true;
    }
}

class CommandRegistry {
    expose List[CommandEntry] commands;
    expose Boolean runtimeContextInitialized;
    expose Boolean documentAvailable;
    expose Boolean projectAvailable;
    expose Boolean buildTargetAvailable;
    expose Boolean debugTargetAvailable;
    expose Boolean buildJobActive;
    expose Boolean debugSessionActive;
    expose Boolean debugSessionStopped;
    hide Boolean shortcutContextInitialized;
    hide language_service.LanguageService shortcutContextService;
    expose Integer shortcutStateRefreshCount;

    expose func init() {
        commands = [];
        runtimeContextInitialized = false;
        documentAvailable = false;
        projectAvailable = false;
        buildTargetAvailable = false;
        debugTargetAvailable = false;
        buildJobActive = false;
        debugSessionActive = false;
        debugSessionStopped = false;
        shortcutContextInitialized = false;
        shortcutContextService = null;
        shortcutStateRefreshCount = 0;
        RegisterDefaults();
    }

    expose func Add(id: String,
                    label: String,
                    description: String,
                    shortcut: String,
                    capability: String,
                    showInPalette: Boolean) {
        AddWithCategory(id, label, description, command_catalog.CategoryForCommand(id),
                        shortcut, capability, showInPalette);
    }

    /// @brief Register a command with an explicit palette category.
    /// @details Built-in commands pass the category stored in CommandSpec so
    ///          catalog metadata remains the source of truth. The older Add
    ///          overload still exists for runtime/test commands and falls back
    ///          to the catalog classifier.
    /// @param id Stable command id used by shortcuts and dispatch.
    /// @param label Human-readable label for menus and palettes.
    /// @param description Help text for shortcut/help surfaces.
    /// @param category Palette grouping name owned by command_catalog.
    /// @param shortcut Default keyboard shortcut text.
    /// @param capability Required language-service capability, or empty.
    /// @param showInPalette Whether the command appears in the palette.
    expose func AddWithCategory(id: String,
                                label: String,
                                description: String,
                                category: String,
                                shortcut: String,
                                capability: String,
                                showInPalette: Boolean) {
        var cmd = new CommandEntry();
        cmd.id = id;
        cmd.label = label;
        cmd.description = description;
        cmd.category = category;
        if cmd.category == "" {
            cmd.category = command_catalog.CategoryForCommand(id);
        }
        cmd.shortcut = shortcut;
        cmd.capability = capability;
        cmd.showInPalette = showInPalette;
        commands.add(cmd);
    }

    expose func RegisterDefaults() {
        var specs = command_catalog.DefaultCommandSpecs();
        var i = 0;
        while i < specs.count() {
            var spec = specs.get(i);
            AddWithCategory(spec.id,
                            spec.label,
                            spec.description,
                            spec.category,
                            spec.shortcut,
                            spec.capability,
                            spec.showInPalette);
            i = i + 1;
        }
    }

    /// @brief Apply user keybinding overrides (plan 08).
    /// @details @p encoded is "id=shortcut;;id2=shortcut2"; an empty shortcut
    ///          clears the binding. Unknown ids are ignored. Call before
    ///          InstallShortcuts.
    expose func ApplyOverrides(encoded: String) {
        if encoded == "" { return; }
        var pairs = Str.Split(encoded, ";;");
        var i = 0;
        while i < Seq.get_Count(pairs) {
            var pair = Seq.GetStr(pairs, i);
            var eq = Str.IndexOf(pair, "=");
            if eq > 0 {
                var id = Str.Left(pair, eq - 1);
                var shortcut = NormalizeShortcut(Str.Mid(pair, eq + 1));
                var entry = Find(id);
                if entry != null and IsValidShortcut(shortcut) {
                    entry.shortcut = shortcut;
                }
            }
            i = i + 1;
        }
    }

    /// @brief Normalize harmless whitespace in user-entered shortcut text.
    /// @details Spaces surrounding `+` are removed and runs between chord
    ///          strokes collapse to one. Modifier spelling/case remains under
    ///          the user's control, including a deliberate physical Ctrl on macOS.
    /// @param shortcut Raw Settings or persisted shortcut text.
    /// @return Trimmed single- or two-stroke spelling.
    expose func NormalizeShortcut(shortcut: String) -> String {
        var normalized = Str.Trim(Str.Replace(shortcut, "\t", " "));
        while Str.Contains(normalized, "  ") {
            normalized = Str.Replace(normalized, "  ", " ");
        }
        normalized = Str.Replace(normalized, " +", "+");
        normalized = Str.Replace(normalized, "+ ", "+");
        return normalized;
    }

    /// @brief Validate a shortcut against the runtime's supported grammar.
    /// @details Empty means intentionally unbound. Non-empty bindings contain
    ///          one or two whitespace-separated strokes, each with exactly one
    ///          key. Plain printable keys are rejected because global shortcut
    ///          dispatch deliberately leaves ordinary typing alone.
    /// @param shortcut Raw or normalized shortcut text.
    /// @return True when InstallShortcuts can register the binding faithfully.
    expose func IsValidShortcut(shortcut: String) -> Boolean {
        var normalized = NormalizeShortcut(shortcut);
        if normalized == "" { return true; }
        var strokes = Str.Split(normalized, " ");
        var count = Seq.get_Count(strokes);
        if count < 1 or count > 2 { return false; }
        var i = 0;
        while i < count {
            if ValidShortcutStroke(Seq.GetStr(strokes, i)) == false { return false; }
            i = i + 1;
        }
        return true;
    }

    /// @brief Validate one `+`-separated shortcut stroke.
    hide func ValidShortcutStroke(stroke: String) -> Boolean {
        if stroke == "" { return false; }
        var tokens = Str.Split(stroke, "+");
        var count = Seq.get_Count(tokens);
        var keyCount = 0;
        var printableKey = false;
        var dispatchModifier = false;
        var i = 0;
        while i < count {
            var token = Str.ToLower(Str.Trim(Seq.GetStr(tokens, i)));
            if token == "" { return false; }
            if token == "ctrl" or token == "control"
               or token == "alt" or token == "cmd" or token == "command" {
                dispatchModifier = true;
            } else if token == "shift" {
                // Shift modifies a key but intentionally does not make a plain
                // printable key safe as an application-global shortcut.
            } else {
                if keyCount != 0 or IsShortcutKeyToken(token) == false { return false; }
                keyCount = 1;
                printableKey = Str.get_Length(token) == 1 or token == "space";
            }
            i = i + 1;
        }
        return keyCount == 1 and (printableKey == false or dispatchModifier);
    }

    /// @brief Return whether a non-modifier token maps to a runtime key.
    hide func IsShortcutKeyToken(token: String) -> Boolean {
        if Str.get_Length(token) == 1 { return true; }
        if token == "f1" or token == "f2" or token == "f3" or token == "f4"
           or token == "f5" or token == "f6" or token == "f7" or token == "f8"
           or token == "f9" or token == "f10" or token == "f11" or token == "f12" {
            return true;
        }
        return token == "enter" or token == "return"
               or token == "escape" or token == "esc"
               or token == "space" or token == "tab" or token == "backspace"
               or token == "delete" or token == "del"
               or token == "home" or token == "end"
               or token == "pageup" or token == "pgup"
               or token == "pagedown" or token == "pgdn"
               or token == "left" or token == "right"
               or token == "up" or token == "down";
    }

    /// @brief Return the catalog-default shortcut for a command id.
    expose func DefaultShortcutFor(id: String) -> String {
        var specs = command_catalog.DefaultCommandSpecs();
        var i = 0;
        while i < specs.count() {
            var spec = specs.get(i);
            if spec.id == id { return spec.shortcut; }
            i = i + 1;
        }
        return "";
    }

    /// @brief Upsert one override into the encoded "id=sc;;..." string.
    expose func UpsertOverride(encoded: String, id: String, shortcut: String) -> String {
        var rebuilt = "";
        var pairs = Str.Split(encoded, ";;");
        var i = 0;
        while i < Seq.get_Count(pairs) {
            var pair = Seq.GetStr(pairs, i);
            var eq = Str.IndexOf(pair, "=");
            if eq > 0 and Str.Left(pair, eq - 1) != id and pair != "" {
                if rebuilt != "" { rebuilt = rebuilt + ";;"; }
                rebuilt = rebuilt + pair;
            }
            i = i + 1;
        }
        if rebuilt != "" { rebuilt = rebuilt + ";;"; }
        return rebuilt + id + "=" + shortcut;
    }

    /// @brief Remove one override from the encoded string.
    expose func RemoveOverride(encoded: String, id: String) -> String {
        var rebuilt = "";
        var pairs = Str.Split(encoded, ";;");
        var i = 0;
        while i < Seq.get_Count(pairs) {
            var pair = Seq.GetStr(pairs, i);
            var eq = Str.IndexOf(pair, "=");
            if pair != "" and (eq <= 0 or Str.Left(pair, eq - 1) != id) {
                if rebuilt != "" { rebuilt = rebuilt + ";;"; }
                rebuilt = rebuilt + pair;
            }
            i = i + 1;
        }
        return rebuilt;
    }

    expose func InstallShortcuts() {
        Shortcuts.Clear();
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.shortcut != "" {
                Shortcuts.Register(cmd.id, cmd.shortcut, cmd.label);
            }
            i = i + 1;
        }
        // A reinstall resets native enabled state. Reapply the last complete
        // runtime snapshot immediately when one exists; otherwise the first
        // ApplyCommandContext call will initialize it.
        shortcutContextInitialized = false;
        if runtimeContextInitialized {
            ApplyShortcutStates(shortcutContextService);
            shortcutContextInitialized = true;
        }
    }

    expose func PopulatePalette(palette: GUI.CommandPalette,
                                service: language_service.LanguageService) {
        if palette == null { return; }
        palette.Clear();
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.showInPalette {
                if IsSupported(cmd, service) {
                    palette.AddCommandWithShortcut(cmd.id, cmd.label, cmd.category, cmd.shortcut);
                } else {
                    palette.AddCommandWithShortcut(cmd.id,
                                                   cmd.label + " (Unavailable)",
                                                   cmd.category,
                                                   cmd.shortcut);
                }
            }
            i = i + 1;
        }
    }

    expose func ApplyCapabilities(service: language_service.LanguageService) {
        ApplyShortcutStates(service);
        shortcutContextService = service;
        shortcutContextInitialized = true;
    }

    /// @brief Apply the current document/workspace/execution context.
    /// @details This is the non-visual counterpart to MenuChrome's command
    ///          state. It prevents shortcuts and palette selections from
    ///          bypassing disabled toolbar/menu controls.
    /// @param hasDocument True when an editor document is open.
    /// @param hasProject True when a workspace root is open.
    /// @param hasBuildTarget True when a project or document can be built.
    /// @param hasDebugTarget True when a saved document can be debugged.
    /// @param jobActive True while a build/run process is active.
    /// @param debugActive True while a debug adapter session exists.
    /// @param debugStopped True while that session is paused.
    /// @param service Active language service for capability checks.
    expose func ApplyCommandContext(hasDocument: Boolean,
                                    hasProject: Boolean,
                                    hasBuildTarget: Boolean,
                                    hasDebugTarget: Boolean,
                                    jobActive: Boolean,
                                    debugActive: Boolean,
                                    debugStopped: Boolean,
                                    service: language_service.LanguageService) {
        var changed = runtimeContextInitialized == false
            or shortcutContextInitialized == false
            or documentAvailable != hasDocument
            or projectAvailable != hasProject
            or buildTargetAvailable != hasBuildTarget
            or debugTargetAvailable != hasDebugTarget
            or buildJobActive != jobActive
            or debugSessionActive != debugActive
            or debugSessionStopped != debugStopped
            or shortcutContextService != service;
        runtimeContextInitialized = true;
        documentAvailable = hasDocument;
        projectAvailable = hasProject;
        buildTargetAvailable = hasBuildTarget;
        debugTargetAvailable = hasDebugTarget;
        buildJobActive = jobActive;
        debugSessionActive = debugActive;
        debugSessionStopped = debugStopped;
        shortcutContextService = service;
        shortcutContextInitialized = true;
        if changed == false { return; }
        ApplyShortcutStates(service);
    }

    /// @brief Reconcile all registered shortcuts against current availability.
    /// @param service Active language service for capability checks.
    hide func ApplyShortcutStates(service: language_service.LanguageService) {
        shortcutStateRefreshCount = shortcutStateRefreshCount + 1;
        var i = 0;
        while i < commands.count() {
            var cmd = commands.get(i);
            if cmd.shortcut != "" {
                if IsSupported(cmd, service) {
                    Shortcuts.SetEnabled(cmd.id, true);
                } else {
                    Shortcuts.SetEnabled(cmd.id, false);
                }
            }
            i = i + 1;
        }
    }

    expose func NormalizeId(id: String) -> String {
        if id == "sidebar" { return "togglesidebar"; }
        return id;
    }

    expose func IsKnown(id: String) -> Boolean {
        var norm = NormalizeId(id);
        return Find(norm) != null;
    }

    expose func IsExecutable(id: String,
                             service: language_service.LanguageService) -> Boolean {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return false; }
        return IsSupported(cmd, service);
    }

    expose func DisabledReason(id: String,
                               service: language_service.LanguageService) -> String {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return "Command is not registered"; }
        if IsSupported(cmd, service) { return ""; }
        return DisabledReasonFor(cmd, service);
    }

    expose func Find(id: String) -> CommandEntry {
        var i = 0;
        while i < commands.count() {
            if commands.get(i).id == id { return commands.get(i); }
            i = i + 1;
        }
        return null;
    }

    /// @brief Look up the display label for a command id.
    /// @param id Command id, including aliases accepted by NormalizeId.
    /// @return Registered label, or empty when the id is unknown.
    expose func LabelFor(id: String) -> String {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return ""; }
        return cmd.label;
    }

    /// @brief Look up the default shortcut for a command id.
    /// @param id Command id, including aliases accepted by NormalizeId.
    /// @return Shortcut text such as `Ctrl+S`, or empty when unset/unknown.
    expose func ShortcutFor(id: String) -> String {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return ""; }
        return cmd.shortcut;
    }

    /// @brief Look up the teaching/help description for a command id.
    /// @param id Command id, including aliases accepted by NormalizeId.
    /// @return Registered description, or empty when the id is unknown.
    expose func DescriptionFor(id: String) -> String {
        var cmd = Find(NormalizeId(id));
        if cmd == null { return ""; }
        return cmd.description;
    }

    expose func ShortcutConflictCount() -> Integer {
        var count = 0;
        var i = 0;
        while i < commands.count() {
            var left = commands.get(i);
            if left.shortcut != "" {
                var j = i + 1;
                while j < commands.count() {
                    var right = commands.get(j);
                    if right.shortcut != "" and right.shortcut == left.shortcut {
                        count = count + 1;
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
        return count;
    }

    expose func ShortcutHasConflict(shortcut: String) -> Boolean {
        if shortcut == "" { return false; }
        var matches = 0;
        var i = 0;
        while i < commands.count() {
            if commands.get(i).shortcut == shortcut {
                matches = matches + 1;
            }
            i = i + 1;
        }
        return matches > 1;
    }

    expose func ShortcutConflictSummary() -> String {
        var summary = "";
        var i = 0;
        while i < commands.count() {
            var left = commands.get(i);
            if left.shortcut != "" {
                var j = i + 1;
                while j < commands.count() {
                    var right = commands.get(j);
                    if right.shortcut == left.shortcut {
                        if summary != "" { summary = summary + "\n"; }
                        summary = summary + left.shortcut + ": " + left.id + " / " + right.id;
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
        return summary;
    }

    expose func IsSupported(cmd: CommandEntry,
                            service: language_service.LanguageService) -> Boolean {
        if IsContextSupported(cmd) == false { return false; }
        return IsLanguageSupported(cmd, service);
    }

    /// @brief Test only language-service capability for one command.
    hide func IsLanguageSupported(cmd: CommandEntry,
                                  service: language_service.LanguageService) -> Boolean {
        if cmd.capability == "" { return true; }
        if service == null { return false; }
        if service.name == language_service.LANGUAGE_BASIC and IsZiaOnlyCommand(cmd.id) {
            return false;
        }
        if cmd.capability == "completion" { return service.canComplete; }
        if cmd.capability == "diagnostics" { return service.canDiagnose; }
        if cmd.capability == "definition" { return service.canGoToDefinition; }
        if cmd.capability == "references" { return service.canFindReferences; }
        if cmd.capability == "rename" { return service.canRename; }
        if cmd.capability == "signature" { return service.canSignatureHelp; }
        if cmd.capability == "symbols" { return service.canDocumentSymbols; }
        return true;
    }

    /// @brief Test document/workspace/job/debug availability for one command.
    hide func IsContextSupported(cmd: CommandEntry) -> Boolean {
        if runtimeContextInitialized == false { return true; }
        if RequiresDocument(cmd) and documentAvailable == false { return false; }
        if RequiresProject(cmd.id) and projectAvailable == false { return false; }

        if IsBuildCommand(cmd.id) {
            return buildTargetAvailable
                   and buildJobActive == false
                   and debugSessionActive == false;
        }
        if cmd.id == "debugstart" {
            return debugTargetAvailable
                   and buildJobActive == false
                   and debugSessionActive == false;
        }
        if cmd.id == "closeworkspace" or cmd.id == "removefolder" {
            return buildJobActive == false and debugSessionActive == false;
        }
        if cmd.id == "stopjob" { return buildJobActive; }
        if IsPausedDebugCommand(cmd.id) {
            return debugSessionActive and debugSessionStopped;
        }
        if cmd.id == "debugpause" {
            return debugSessionActive and debugSessionStopped == false;
        }
        if IsActiveDebugCommand(cmd.id) { return debugSessionActive; }
        return true;
    }

    /// @brief Whether a command needs an editor document.
    hide func RequiresDocument(cmd: CommandEntry) -> Boolean {
        if cmd.capability != "" { return true; }
        var id = cmd.id;
        return id == "comparewithsaved"
               or id == "save" or id == "saveas" or id == "saveall"
               or id == "close" or id == "reload"
               or id == "find" or id == "goto" or id == "minimap"
               or id == "spliteditorright"
               or id == "undo" or id == "redo" or id == "selectall"
               or id == "addnextoccurrence" or id == "skipoccurrence"
               or id == "selectalloccurrences" or id == "clearcursors"
               or id == "expandselection" or id == "shrinkselection"
               or id == "togglelinecomment" or id == "toggleblockcomment"
               or id == "duplicateline" or id == "movelineup"
               or id == "movelinedown" or id == "trimtrailingwhitespace"
               or id == "togglerenderwhitespace"
               or id == "formatdocument" or id == "formatselection"
               or id == "togglebreakpoint" or id == "debugcondition"
               or id == "debuglogpoint" or id == "debugruntocursor";
    }

    /// @brief Whether a command needs an open workspace root.
    hide func RequiresProject(id: String) -> Boolean {
        return id == "closeworkspace" or id == "removefolder"
               or id == "quickopen" or id == "searchproject"
               or id == "workspacesymbols"
               or Str.StartsWith(id, "tree");
    }

    /// @brief Whether a command starts build/run work.
    hide func IsBuildCommand(id: String) -> Boolean {
        return id == "build" or id == "buildrun" or id == "run";
    }

    /// @brief Whether a command requires a paused debug session.
    hide func IsPausedDebugCommand(id: String) -> Boolean {
        return id == "debugcontinue" or id == "debugstepover"
               or id == "debugstepin" or id == "debugstepout"
               or id == "debugruntocursor";
    }

    /// @brief Whether a command requires any active debug session.
    hide func IsActiveDebugCommand(id: String) -> Boolean {
        return id == "debugrestart" or id == "debugstop"
               or id == "debugaddwatch" or id == "debugremovewatch"
               or id == "debugrefreshwatches" or id == "debugclearwatches";
    }

    expose func ServerSupportsCapability(capability: String,
                                         service: language_service.LanguageService) -> Boolean {
        if capability == "" { return false; }
        if service == null { return false; }
        if capability == "completion" { return service.serverCanComplete; }
        if capability == "diagnostics" { return service.serverCanDiagnose; }
        if capability == "definition" { return service.serverCanGoToDefinition; }
        if capability == "references" { return service.serverCanFindReferences; }
        if capability == "rename" { return service.serverCanRename; }
        if capability == "signature" { return service.serverCanSignatureHelp; }
        if capability == "symbols" { return service.serverCanDocumentSymbols; }
        return false;
    }

    expose func DisabledReasonFor(cmd: CommandEntry,
                                  service: language_service.LanguageService) -> String {
        if cmd == null { return "Command is not registered"; }
        var contextReason = ContextDisabledReason(cmd);
        if contextReason != "" { return contextReason; }
        var language = "this file";
        if service != null and service.name != "" {
            language = Str.ToUpper(service.name);
        }
        if service != null
           and service.name == language_service.LANGUAGE_BASIC
           and IsZiaOnlyCommand(cmd.id) {
            return cmd.label + " is unavailable: this command rewrites Zia source syntax.";
        }
        if service != null
           and service.externalServerName != ""
           and ServerSupportsCapability(cmd.capability, service) {
            return cmd.label + " is unavailable: " + service.externalServerName
                   + " supports " + CapabilityLabel(cmd.capability)
                   + ", but Zanna Studio has not wired a " + language
                   + " adapter for this command.";
        }
        return cmd.label + " is unavailable: " + language
               + " does not support " + CapabilityLabel(cmd.capability) + ".";
    }

    /// @brief Explain the first unmet non-language command requirement.
    hide func ContextDisabledReason(cmd: CommandEntry) -> String {
        if runtimeContextInitialized == false { return ""; }
        if RequiresDocument(cmd) and documentAvailable == false {
            return "Open a document to use " + cmd.label + ".";
        }
        if RequiresProject(cmd.id) and projectAvailable == false {
            return "Open a project folder to use " + cmd.label + ".";
        }
        if IsBuildCommand(cmd.id) and buildTargetAvailable == false {
            return "Open a project or document to use " + cmd.label + ".";
        }
        if cmd.id == "debugstart" and debugTargetAvailable == false {
            return "Open or save a document before starting the debugger.";
        }
        if cmd.id == "closeworkspace" and buildJobActive {
            return "Stop the running build or run job before closing the workspace.";
        }
        if cmd.id == "closeworkspace" and debugSessionActive {
            return "Stop debugging before closing the workspace.";
        }
        if cmd.id == "removefolder" and buildJobActive {
            return "Stop the running build or run job before removing a workspace folder.";
        }
        if cmd.id == "removefolder" and debugSessionActive {
            return "Stop debugging before removing a workspace folder.";
        }
        if IsBuildCommand(cmd.id) and debugSessionActive {
            return cmd.label + " is unavailable while debugging.";
        }
        if (IsBuildCommand(cmd.id) or cmd.id == "debugstart") and buildJobActive {
            return cmd.label + " is unavailable while another job is running.";
        }
        if cmd.id == "debugstart" and debugSessionActive {
            return "A debug session is already running.";
        }
        if cmd.id == "stopjob" and buildJobActive == false {
            return "There is no running build or run job to stop.";
        }
        if IsPausedDebugCommand(cmd.id)
           and (debugSessionActive == false or debugSessionStopped == false) {
            return cmd.label + " is available while debugging is paused.";
        }
        if cmd.id == "debugpause"
           and (debugSessionActive == false or debugSessionStopped) {
            return "Pause is available while a debuggee is running.";
        }
        if IsActiveDebugCommand(cmd.id) and debugSessionActive == false {
            return "Start debugging before using " + cmd.label + ".";
        }
        return "";
    }

    expose func IsZiaOnlyCommand(id: String) -> Boolean {
        return id == "organizebinds"
               or id == "extractlocal"
               or id == "extractfunction"
               or id == "inlinelocal"
               or id == "suppressdiagnostic"
               or id == "createmissingbind";
    }

    expose func CapabilityLabel(capability: String) -> String {
        if capability == "completion" { return "completion"; }
        if capability == "diagnostics" { return "diagnostics"; }
        if capability == "definition" { return "go to definition"; }
        if capability == "references" { return "references"; }
        if capability == "rename" { return "rename"; }
        if capability == "signature" { return "signature help"; }
        if capability == "symbols" { return "document symbols"; }
        return "this language feature";
    }

    expose func CommandCategory(id: String) -> String {
        return command_catalog.CategoryForCommand(id);
    }
}
