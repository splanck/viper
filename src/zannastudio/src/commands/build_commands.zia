//
// File: zannastudio/src/commands/build_commands.zia
// Purpose: Save execution inputs, launch build/run jobs, and present their
//          streamed output and diagnostics in Zanna Studio.
// Key invariants:
//   - Project roots remain valid build/run targets without an open editor tab.
//   - Current-file targets must be saved, editable documents.
//   - At most one build/run job is active at a time.
//   - Completion remains on durable Build result surfaces without a popup.
// Ownership/Lifetime:
//   - This stateless module borrows shell, document, project, and job models.
// Links: zannastudio/src/build/build_system.zia,
//        zannastudio/src/build/run_config.zia
//
//===----------------------------------------------------------------------===//

module build_commands;

bind "../ui/app_shell";
bind "../ui/notification_policy";
bind "../core/document_manager";
bind "../core/project_manager";
bind "../editor/editor_engine";
bind "../editor/editor_tabs";
bind "../build/build_system";
bind "../build/diagnostic";
bind "../build/run_config";
bind "../commands/file_commands";
bind "../services/file_utils";
bind "../services/locations";
bind "../services/theme_colors";

bind Zanna.GUI;
bind Convert = Zanna.Core.Convert;
bind Seq = Zanna.Collections.Seq;
bind Obj = Zanna.Core.Object;

// ============================================================================
// MODULE: build_commands
// PURPOSE: Build / BuildAndRun / Run / Stop command handlers. Saves active
//          documents when present, starts argument-vector Process jobs through
//          BuildSystem, and routes streamed output + diagnostics to the output
//          panel, diagnostics panel, minimap, and status bar.
//
// WHERE-THIS-FITS: Command handlers wired into main.zia's command
//          dispatcher. Each handler receives the AppShell, document
//          manager, editor engine, and BuildSystem so it can update
//          every relevant surface.
//
// KEY-DESIGN-CHOICES:
//   * PROJECT-ONLY BUILDS. An open project remains executable with no editor
//     tabs; RunConfig targets the workspace root and its manifest entry.
//   * SAVE-BEFORE-BUILD. When a document is active, every handler calls
//     SaveEditorState + the execution-save workflow so disk matches the editor.
//     Untitled documents bail rather than silently inventing a filename.
//   * DURABLE COMPLETION. Every result persists in the status bar and panel.
//     Background warning/error completion never interrupts later work with a
//     duplicate toast; immediate start failures use notification policy.
//   * DIRECT ARGS, NOT SHELL STRINGS. RunConfig stores program + Seq args;
//     paths with spaces are passed as a single argument.
//   * IDE-OWNED JOBS. The frame loop calls UpdateJob so long-running
//     processes can stream output and be stopped without freezing the IDE.
//   * UpdateDiagnostics IS SHARED. Both Build and BuildAndRun call it
//     to refresh the panel/minimap/output. Keeping it in one place
//     prevents drift between the two paths.
// ============================================================================

/// @brief Diagnostic marker colors from the live theme palette.
func ErrorMarkerColor() -> Integer { return theme_colors.Rgb("accentDanger"); }
func WarningMarkerColor() -> Integer { return theme_colors.Rgb("accentWarning"); }
func InfoMarkerColor() -> Integer { return theme_colors.Rgb("fgTertiary"); }

/// @brief Return whether Build/Run has a truthful current target.
/// @details An open project targets its root even when no editor tab is open.
///          Outside a project, execution requires a saved editable document.
/// @param docMgr Current document manager, if available.
/// @param projMgr Current project manager, if available.
/// @return True when a project or saved document can produce a RunConfig.
expose func HasExecutionTarget(docMgr: document_manager.DocumentManager,
                               projMgr: project_manager.ProjectManager) -> Boolean {
    if projMgr != null and projMgr.IsOpen() { return true; }
    if docMgr == null { return false; }
    var doc = docMgr.GetActive();
    return doc != null and doc!.isNew == false and doc!.filePath != ""
           and doc!.isReadOnlyPreview == false
           and file_utils.IsVisualKind(doc!.kind) == false;
}

/// @brief Report a canceled save preflight using consistent Build/Run wording.
func ReportCanceledExecution(shell: app_shell.AppShell,
                             actionLabel: String,
                             result: file_commands.SaveAllResult) {
    if result != null and result.message != "" {
        shell.SetStatusLeft(actionLabel + " canceled: " + result.message);
    } else {
        shell.SetStatusLeft(actionLabel + " canceled: files were not saved");
    }
}

/// @brief Start a prepared build/run config and synchronize visible job state.
func StartExecutionConfig(shell: app_shell.AppShell,
                          buildSys: build_system.BuildSystem,
                          locStore: locations.LocationStore,
                          cfg: run_config.RunConfig) {
    var actionLabel = "Build";
    var progressLabel = "Building";
    if cfg != null and cfg.action == run_config.ACTION_RUN {
        actionLabel = "Run";
        progressLabel = "Running";
    }
    if buildSys.StartConfig(cfg) {
        shell.SetBuildJobActive(true, buildSys.activeName);
        shell.SetStatusLeft(progressLabel + ": " + cfg.targetPath);
        shell.toolPanels.SetBuildOutput("Started: " + FormatCommand(cfg));
    } else {
        shell.SetBuildJobActive(false, "");
        shell.SetStatusLeft(actionLabel + " failed to start");
        notification_policy.ActionError(actionLabel + " did not start");
        PopulateBuildOutput(shell, buildSys, locStore, true);
    }
}

/// @brief Build the active file, refresh diagnostics, report status.
func handleBuild(shell: app_shell.AppShell,
                 docMgr: document_manager.DocumentManager,
                 projMgr: project_manager.ProjectManager,
                 engine: editor_engine.EditorEngine,
                 tabs: editor_tabs.EditorTabs,
                 buildSys: build_system.BuildSystem,
                 locStore: locations.LocationStore,
                 saveAllBeforeBuild: Boolean) {
    if CanStartExecutionJob(shell, buildSys, "start a new build") == false { return; }
    file_commands.SaveEditorState(docMgr, engine);
    var buildDoc = docMgr.GetActive();
    var projectTarget = projMgr != null and projMgr.IsOpen();
    if projectTarget == false
       and (buildDoc == null or buildDoc!.isNew or buildDoc!.isReadOnlyPreview) {
        shell.SetStatusLeft("Open a project or saved file before building");
        return;
    }

    var saveResult = file_commands.handleSaveForExecution(shell, docMgr, engine, tabs,
                                                          saveAllBeforeBuild);
    if saveResult.success == false {
        ReportCanceledExecution(shell, "Build", saveResult);
        return;
    }
    file_commands.SaveEditorState(docMgr, engine);
    buildDoc = docMgr.GetActive();
    var cfg = run_config.ForDocument(run_config.ACTION_BUILD, null, projMgr);
    if buildDoc != null {
        cfg = run_config.ForDocument(run_config.ACTION_BUILD, buildDoc!, projMgr);
    }
    StartExecutionConfig(shell, buildSys, locStore, cfg);
}

/// @brief Build and run in one step; refresh diagnostics; report status.
func handleBuildAndRun(shell: app_shell.AppShell,
                       docMgr: document_manager.DocumentManager,
                       projMgr: project_manager.ProjectManager,
                       engine: editor_engine.EditorEngine,
                       tabs: editor_tabs.EditorTabs,
                       buildSys: build_system.BuildSystem,
                       locStore: locations.LocationStore,
                       saveAllBeforeBuild: Boolean) {
    if CanStartExecutionJob(shell, buildSys, "start a new run") == false { return; }
    file_commands.SaveEditorState(docMgr, engine);
    var runDoc = docMgr.GetActive();
    var projectTarget = projMgr != null and projMgr.IsOpen();
    if projectTarget == false
       and (runDoc == null or runDoc!.isNew or runDoc!.isReadOnlyPreview) {
        shell.SetStatusLeft("Open a project or saved file before running");
        return;
    }

    var saveResult = file_commands.handleSaveForExecution(shell, docMgr, engine, tabs,
                                                          saveAllBeforeBuild);
    if saveResult.success == false {
        ReportCanceledExecution(shell, "Run", saveResult);
        return;
    }
    file_commands.SaveEditorState(docMgr, engine);
    runDoc = docMgr.GetActive();
    var cfg = run_config.ForDocument(run_config.ACTION_RUN, null, projMgr);
    if runDoc != null {
        cfg = run_config.ForDocument(run_config.ACTION_RUN, runDoc!, projMgr);
    }
    StartExecutionConfig(shell, buildSys, locStore, cfg);
}

/// @brief Run the active file through the configured Zanna run pipeline.
/// @details The Zanna toolchain compiles before execution, so this command is
///          intentionally equivalent to Build and Run while keeping a separate
///          shortcut and call site for future cached-artifact workflows.
func handleRun(shell: app_shell.AppShell,
               docMgr: document_manager.DocumentManager,
               projMgr: project_manager.ProjectManager,
               engine: editor_engine.EditorEngine,
               tabs: editor_tabs.EditorTabs,
               buildSys: build_system.BuildSystem,
               locStore: locations.LocationStore,
               saveAllBeforeBuild: Boolean) {
    handleBuildAndRun(shell, docMgr, projMgr, engine, tabs, buildSys, locStore,
                      saveAllBeforeBuild);
}

func handleStop(shell: app_shell.AppShell,
                buildSys: build_system.BuildSystem) {
    if buildSys.Stop() {
        shell.SetBuildJobActive(false, "");
        shell.SetStatusLeft("Stopped job");
    } else {
        shell.SetBuildJobActive(false, "");
        shell.SetStatusLeft("No running job");
    }
}

func UpdateJob(shell: app_shell.AppShell,
               buildSys: build_system.BuildSystem,
               locStore: locations.LocationStore) {
    if buildSys == null { return; }
    var wasActive = buildSys.IsActive();
    if wasActive {
        buildSys.Update();
        var outputDelta = buildSys.TakeOutputDelta();
        if outputDelta != "" {
            shell.toolPanels.UpdateBuildOutput(outputDelta);
        }
        if buildSys.IsActive() == false {
            shell.SetBuildJobActive(false, "");
            var errs = buildSys.GetErrorCount();
            var warns = buildSys.GetWarningCount();
            if buildSys.lastBuildSuccess {
                var okMsg = buildSys.activeName + " succeeded in " + buildSys.GetBuildTime();
                if warns > 0 {
                    okMsg = okMsg + " — " + countLabel(warns, "warning");
                }
                shell.SetStatusLeft(okMsg);
            } else {
                var detail = problemSummary(errs, warns);
                var failMsg = buildSys.activeName + " failed in " + buildSys.GetBuildTime();
                if detail != "" {
                    failMsg = failMsg + " — " + detail;
                } else {
                    failMsg = failMsg + " (exit " + buildSys.exitCode + ")";
                }
                shell.SetStatusLeft(failMsg);
            }
            UpdateDiagnostics(shell, buildSys, locStore);
        }
    }
}

/// @brief Repopulate the diagnostics listbox + minimap markers + build
///        output panel from the most recent BuildSystem run.
/// @note Hides the diagnostics panel entirely when there are zero
///       diagnostics so it doesn't waste vertical space.
func UpdateDiagnostics(shell: app_shell.AppShell,
                       buildSys: build_system.BuildSystem,
                       locStore: locations.LocationStore) {
    var revealResult = shell.toolPanels.IsOutputPanelActive();
    shell.toolPanels.BeginProblems();
    shell.workbench.minimap.ClearMarkers();

    var diagCount = buildSys.diagnostics.count();
    if diagCount > 0 {
        var i = 0;
        while i < diagCount {
            var diag = buildSys.diagnostics.get(i);
            if diag == null {
                i = i + 1;
                continue;
            }
            var sevLabel = "error";
            var markerColor = ErrorMarkerColor();
            if diag.severity == 1 {
                sevLabel = "warning";
                markerColor = WarningMarkerColor();
            } else if diag.severity == 2 {
                sevLabel = "info";
                markerColor = InfoMarkerColor();
            }
            var action = "No quick fix";
            if diag.fixitCount > 0 {
                action = diag.fixitMessage;
                if action == "" { action = "Quick fix available"; }
            }
            var item = shell.toolPanels.AddProblem(sevLabel, "build", diag.filePath, diag.line, diag.column,
                                        diag.code, diag.message, action);
            var endLine = diag.endLine;
            var endColumn = diag.endColumn;
            if endLine <= 0 { endLine = diag.line; }
            if endColumn <= 0 { endColumn = diag.column + 1; }
            var locId = locStore.Add(diag.filePath, diag.line, diag.column,
                                     endLine, endColumn,
                                     locations.KIND_BUILD, diag.message);
            shell.toolPanels.SetAddedProblemLocationData(item, locId);
            shell.workbench.minimap.AddMarker(diag.line, 1, markerColor);
            i = i + 1;
        }
    }
    shell.toolPanels.UpdateProblems(diagCount);

    PopulateBuildOutput(shell, buildSys, locStore, revealResult);
    // Land on the Problems tab when there is something to triage — those rows are
    // click-to-navigate — while a clean build stays on the Output log.
    if diagCount > 0 and revealResult {
        shell.toolPanels.ShowProblemsPanel();
    }
}

func PopulateBuildOutput(shell: app_shell.AppShell,
                         buildSys: build_system.BuildSystem,
                         locStore: locations.LocationStore,
                         reveal: Boolean) {
    shell.toolPanels.BeginOutputRows();
    var output = buildSys.GetOutput();
    if output == "" {
        shell.toolPanels.HideOutputPanel();
        return;
    }
    shell.toolPanels.SetOutputRowSource(output);
    var lines = Zanna.String.Split(output, "\n");
    var i = 0;
    while i < Seq.get_Count(lines) {
        var line = Obj.ToString(Seq.Get(lines, i));
        if line != "" {
            var item = shell.toolPanels.AddOutputDisplayLine(line);
            var diag = buildSys.ParseDiagnosticLine(line);
            if item != null {
                if diag != null {
                    var d = diag!;
                    if d.severity == diagnostic.SEV_WARNING {
                        GUI.ListBox.ItemSetTextColor(item, WarningMarkerColor());
                    } else if d.severity == diagnostic.SEV_INFO {
                        GUI.ListBox.ItemSetTextColor(item, InfoMarkerColor());
                    } else {
                        GUI.ListBox.ItemSetTextColor(item, ErrorMarkerColor());
                    }
                    var locId = locStore.Add(d.filePath, d.line, d.column,
                                             d.line, d.column + 1,
                                             locations.KIND_BUILD, d.message);
                    GUI.ListBox.ItemSetData(item, locId);
                } else {
                    shell.toolPanels.ApplyOutputLineColor(item, line);
                }
            }
        }
        i = i + 1;
    }
    if shell.toolPanels.outputAutoScroll {
        shell.toolPanels.outputListBox.ScrollToBottom();
    }
    if reveal { shell.toolPanels.ShowOutputPanel(); }
}

func FormatCommand(cfg: run_config.RunConfig) -> String {
    if cfg == null { return ""; }
    var text = DisplayArg(cfg.program);
    var i = 0;
    while i < Seq.get_Count(cfg.args) {
        text = text + " " + DisplayArg(Obj.ToString(Seq.Get(cfg.args, i)));
        i = i + 1;
    }
    return text;
}

/// @brief Quote one argv item for display in build/output status text.
/// @details Build execution uses structured argv through Process.StartWithEnv;
///          this helper is only for human-readable output. It quotes whitespace
///          and embedded quotes so paths with spaces are not visually misleading.
/// @param arg Program path or argv element.
/// @return Display-safe token.
func DisplayArg(arg: String) -> String {
    if arg == "" { return "\"\""; }
    if Str.IndexOf(arg, " ") == 0
       and Str.IndexOf(arg, "\t") == 0
       and Str.IndexOf(arg, "\"") == 0 {
        return arg;
    }
    return "\"" + Str.Replace(arg, "\"", "\\\"") + "\"";
}

/// @brief Pluralize a count for status text ("1 error" / "3 errors").
func countLabel(n: Integer, noun: String) -> String {
    if n == 1 { return "1 " + noun; }
    return "" + n + " " + noun + "s";
}

/// @brief Combine error and warning counts into a readable summary, or "" when
///        the build produced no parsed diagnostics (a raw exit-code failure).
func problemSummary(errors: Integer, warnings: Integer) -> String {
    if errors > 0 and warnings > 0 {
        return countLabel(errors, "error") + ", " + countLabel(warnings, "warning");
    }
    if errors > 0 { return countLabel(errors, "error"); }
    if warnings > 0 { return countLabel(warnings, "warning"); }
    return "";
}

/// @brief Keep a second build/run request from interrupting the active job.
/// @param shell Workbench shell that owns status and Output surfaces.
/// @param buildSys Current build/run process controller.
/// @param nextAction Lowercase action phrase such as "start a new build".
/// @return True when no job blocks the requested action.
/// @details Visible command chrome is disabled during a job, but queued input
///          can race that state update. Reveal the durable Output/Stop controls
///          and preserve the process instead of showing a modal interruption.
expose func CanStartExecutionJob(shell: app_shell.AppShell,
                                 buildSys: build_system.BuildSystem,
                                 nextAction: String) -> Boolean {
    if buildSys == null or buildSys.IsActive() == false { return true; }
    if shell != null {
        var output = buildSys.GetOutput();
        if output != "" {
            shell.toolPanels.SetBuildOutput(output);
        }
        shell.toolPanels.ShowOutputPanel();
        var activeLabel = buildSys.activeName;
        if activeLabel == "" { activeLabel = "A build or run job"; }
        shell.SetStatusLeft(activeLabel + " is already running; use Stop before you "
                            + nextAction);
    }
    return false;
}
