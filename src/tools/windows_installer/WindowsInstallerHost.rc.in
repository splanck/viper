//===----------------------------------------------------------------------===//
//
// File: src/tools/windows_installer/WindowsInstallerHost.rc.in
// Purpose: Embed the native Windows installer manifest and complete version
//          metadata into the statically linked host executable.
//
// Key invariants:
//   - File/product versions come from the canonical CMake project version.
//   - The requested execution level remains asInvoker; machine elevation is a
//     runtime choice made only after the user selects all-users scope.
//
// Ownership/Lifetime:
//   - Configured by CMake into the build tree and compiled by the Windows RC tool.
//
// Links: WindowsInstallerHost.manifest.in, src/CMakeLists.txt
//
//===----------------------------------------------------------------------===//

#include <windows.h>
#include "tools/windows_installer/WindowsInstallerResources.h"

1 RT_MANIFEST "@VIPER_INSTALLER_MANIFEST_PATH@"
IDI_VIPER_INSTALLER ICON "@VIPER_INSTALLER_ICON_PATH@"

1 VERSIONINFO
 FILEVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS VS_FF_DEBUG
#else
 FILEFLAGS 0x0L
#endif
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"
    BEGIN
      VALUE "CompanyName", "Viper Project\0"
      VALUE "FileDescription", "Viper Tools Native Installer Host\0"
      VALUE "FileVersion", "@PROJECT_VERSION@\0"
      VALUE "InternalName", "viper-installer-host\0"
      VALUE "LegalCopyright", "Copyright (c) Viper Project contributors\0"
      VALUE "OriginalFilename", "viper-installer-host.exe\0"
      VALUE "ProductName", "Viper Tools\0"
      VALUE "ProductVersion", "@PROJECT_VERSION@\0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END
