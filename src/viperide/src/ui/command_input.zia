// File: viperide/src/ui/command_input.zia
// Purpose: Reusable non-modal single-value command input overlay for ViperIDE.
// Key invariants:
//   - The overlay captures command intent only; command modules perform effects.
//   - Completed actions retain their value until the main loop consumes them.
// Ownership/Lifetime:
//   - GUI widgets are owned by the AppShell application root.
//   - Entered values are copied into Zia strings before the panel hides.
// Links: viperide/src/main.zia, viperide/src/commands/main_command_dispatcher.zia
//
//===----------------------------------------------------------------------===//

module command_input;

bind "../ui/app_shell";

bind Viper.GUI as GUI;
bind Input = Viper.Input;
bind Str = Viper.String;

final COMMAND_INPUT_NONE: Integer = 0;
final COMMAND_INPUT_GOTO_LINE: Integer = 1;
final COMMAND_INPUT_ADD_WATCH: Integer = 2;
final COMMAND_INPUT_FILTER_OUTPUT: Integer = 3;
final COMMAND_INPUT_WORKSPACE_SYMBOLS: Integer = 4;
final COMMAND_INPUT_RENAME_SYMBOL: Integer = 5;
final COMMAND_INPUT_EXTRACT_LOCAL: Integer = 6;
final COMMAND_INPUT_EXTRACT_FUNCTION: Integer = 7;
final COMMAND_INPUT_CANCEL: Integer = 99;

final COMMAND_INPUT_WIDTH: Integer = 440;
final COMMAND_INPUT_HEIGHT: Integer = 190;
final COMMAND_INPUT_MARGIN: Integer = 24;

// ============================================================================
// MODULE: command_input
// PURPOSE: Non-modal replacement for short MessageBox.Prompt command workflows.
//
// WHERE-THIS-FITS: Command dispatch opens the overlay for workflows such as
//          Go To Line and Add Watch. main.zia pumps it once per frame and applies
//          the completed action through the existing command modules.
//
// TEACHING-NOTE: Reusing one overlay for short command values keeps prompt
//          behavior consistent and prevents every command from building its own
//          floating-panel lifecycle.
// ============================================================================

/// @brief Reusable floating input surface for one-value commands.
/// @details This class owns only UI state. It does not jump the editor, mutate
///          debugger watches, or filter output directly; callers inspect the
///          returned action and `ReadValue()` after `Pump()`.
class CommandInputOverlay {
    expose GUI.FloatingPanel panel;
    expose GUI.VBox root;
    expose GUI.Label titleLabel;
    expose GUI.Label descriptionLabel;
    expose GUI.TextInput input;
    expose GUI.Label detailLabel;
    expose GUI.Button cancelButton;
    expose GUI.Button applyButton;

    expose Boolean visible;
    expose Integer pendingAction;
    expose Integer completedAction;
    expose String value;
    expose String applyLabel;

    /// @brief Initialize the overlay with no pending command.
    expose func init() {
        visible = false;
        pendingAction = COMMAND_INPUT_NONE;
        completedAction = COMMAND_INPUT_NONE;
        value = "";
        applyLabel = "Apply";
    }

    /// @brief Construct the floating panel and child controls.
    /// @param shell Workbench shell whose app root owns floating overlays.
    expose func Setup(shell: app_shell.AppShell) {
        panel = GUI.FloatingPanel.New(shell.app);
        panel.SetSize(COMMAND_INPUT_WIDTH, COMMAND_INPUT_HEIGHT);
        panel.SetVisible(false);

        root = GUI.VBox.New();
        root.SetPadding(16.0);
        root.SetSpacing(10.0);
        panel.AddChild(root);

        titleLabel = GUI.Label.New(root, "Command Input");
        titleLabel.SetMargin(0);

        descriptionLabel = GUI.Label.New(root, "");
        descriptionLabel.SetWordWrap(true);
        descriptionLabel.SetMargin(0);

        input = GUI.TextInput.New(root);
        input.SetPlaceholder("Value");

        detailLabel = GUI.Label.New(root, "");
        detailLabel.SetWordWrap(true);
        detailLabel.SetMargin(0);

        var footer = GUI.HBox.New();
        footer.SetSpacing(10.0);
        root.AddChild(footer);
        var spacer = GUI.Label.New(footer, "");
        spacer.SetFlex(1.0);
        cancelButton = GUI.Button.New(footer, "Cancel");
        cancelButton.SetStyle(2);
        applyButton = GUI.Button.New(footer, "Apply");
        applyButton.SetStyle(1);
    }

    /// @brief Open the overlay for the Go To Line command.
    /// @param shell Workbench shell used for current viewport size.
    /// @param currentLine Initial line number shown in the input.
    expose func OpenGoToLine(shell: app_shell.AppShell,
                             currentLine: Integer) {
        var initial = "";
        if currentLine > 0 { initial = "" + currentLine; }
        Open(shell,
             COMMAND_INPUT_GOTO_LINE,
             "Go To Line",
             "Jump to a line in the active editor.",
             "Line number",
             initial,
             "Go");
    }

    /// @brief Open the overlay for adding a debugger watch expression.
    /// @param shell Workbench shell used for current viewport size.
    /// @param initialExpression Optional expression prefilled from selection/cursor.
    expose func OpenAddWatch(shell: app_shell.AppShell,
                             initialExpression: String) {
        Open(shell,
             COMMAND_INPUT_ADD_WATCH,
             "Add Watch",
             "Evaluate this expression whenever the debugger stops.",
             "Expression",
             initialExpression,
             "Watch");
    }

    /// @brief Open the overlay for filtering visible output rows.
    /// @param shell Workbench shell used for current viewport size.
    /// @param currentFilter Existing output filter text.
    expose func OpenFilterOutput(shell: app_shell.AppShell,
                                 currentFilter: String) {
        Open(shell,
             COMMAND_INPUT_FILTER_OUTPUT,
             "Filter Output",
             "Show output rows containing this text. Leave blank to clear the filter.",
             "Filter text",
             currentFilter,
             "Apply");
    }

    /// @brief Open the overlay for searching workspace symbols.
    /// @param shell Workbench shell used for current viewport size.
    /// @param initialQuery Optional query text, usually empty.
    expose func OpenWorkspaceSymbols(shell: app_shell.AppShell,
                                     initialQuery: String) {
        Open(shell,
             COMMAND_INPUT_WORKSPACE_SYMBOLS,
             "Workspace Symbols",
             "Find functions, classes, variables, and labels in the workspace.",
             "Symbol name",
             initialQuery,
             "Find");
    }

    /// @brief Open the overlay for renaming the symbol at the cursor.
    /// @param shell Workbench shell used for current viewport size.
    /// @param currentName Optional current identifier used as the initial value.
    expose func OpenRenameSymbol(shell: app_shell.AppShell,
                                 currentName: String) {
        Open(shell,
             COMMAND_INPUT_RENAME_SYMBOL,
             "Rename Symbol",
             "Rename the symbol at the cursor across supported references.",
             "New name",
             currentName,
             "Rename");
    }

    /// @brief Open the overlay for naming an extracted local variable.
    /// @param shell Workbench shell used for current viewport size.
    expose func OpenExtractLocal(shell: app_shell.AppShell) {
        Open(shell,
             COMMAND_INPUT_EXTRACT_LOCAL,
             "Extract Local Variable",
             "Extract the selected Zia expression into a new local variable.",
             "Variable name",
             "",
             "Extract");
    }

    /// @brief Open the overlay for naming an extracted function.
    /// @param shell Workbench shell used for current viewport size.
    expose func OpenExtractFunction(shell: app_shell.AppShell) {
        Open(shell,
             COMMAND_INPUT_EXTRACT_FUNCTION,
             "Extract Function",
             "Extract the selected Zia statements into a new function.",
             "Function name",
             "",
             "Extract");
    }

    /// @brief Hide the panel and mark the current command as canceled.
    expose func Cancel() {
        completedAction = COMMAND_INPUT_CANCEL;
        visible = false;
        pendingAction = COMMAND_INPUT_NONE;
        panel.SetVisible(false);
    }

    /// @brief Clear the completed action after the caller has consumed it.
    expose func Finish() {
        completedAction = COMMAND_INPUT_NONE;
        pendingAction = COMMAND_INPUT_NONE;
        value = "";
        detailLabel.SetText("");
    }

    /// @brief Poll buttons and keyboard shortcuts for one frame.
    /// @param shell Workbench shell used to keep the panel positioned.
    /// @return Completed command action, cancel, or COMMAND_INPUT_NONE.
    expose func Pump(shell: app_shell.AppShell) -> Integer {
        completedAction = COMMAND_INPUT_NONE;
        if visible == false { return COMMAND_INPUT_NONE; }
        Layout(shell);
        if Input.Keyboard.WasPressed(Viper.Input.Key.Escape) {
            Cancel();
            return COMMAND_INPUT_CANCEL;
        }
        if cancelButton.WasClicked() {
            Cancel();
            return COMMAND_INPUT_CANCEL;
        }
        if applyButton.WasClicked()
           or Input.Keyboard.WasPressed(Viper.Input.Key.Enter) {
            return Complete();
        }
        return COMMAND_INPUT_NONE;
    }

    /// @brief Return the trimmed value entered for the completed command.
    /// @return Last completed value, or empty string.
    expose func ReadValue() -> String {
        return value;
    }

    /// @brief Return whether the overlay is visible.
    expose func IsVisible() -> Boolean {
        return visible;
    }

    /// @brief Configure and show the floating input panel.
    /// @param shell Workbench shell used for layout.
    /// @param action Action returned when the user applies.
    /// @param title Overlay title.
    /// @param description Short body text.
    /// @param placeholder Input placeholder.
    /// @param initialValue Initial input text.
    /// @param buttonLabel Primary button label.
    hide func Open(shell: app_shell.AppShell,
                   action: Integer,
                   title: String,
                   description: String,
                   placeholder: String,
                   initialValue: String,
                   buttonLabel: String) {
        pendingAction = action;
        completedAction = COMMAND_INPUT_NONE;
        value = "";
        applyLabel = buttonLabel;
        titleLabel.SetText(title);
        descriptionLabel.SetText(description);
        detailLabel.SetText("");
        input.SetPlaceholder(placeholder);
        input.SetText(initialValue);
        applyButton.SetText(applyLabel);
        visible = true;
        panel.SetVisible(true);
        Layout(shell);
        input.Focus();
    }

    /// @brief Complete the pending action and return its action id.
    /// @return Pending action when valid, otherwise COMMAND_INPUT_NONE.
    hide func Complete() -> Integer {
        value = Str.Trim(input.Text);
        if value == "" and pendingAction != COMMAND_INPUT_FILTER_OUTPUT {
            detailLabel.SetText("Enter a value.");
            input.Focus();
            return COMMAND_INPUT_NONE;
        }
        var action = pendingAction;
        visible = false;
        pendingAction = COMMAND_INPUT_NONE;
        completedAction = action;
        panel.SetVisible(false);
        return action;
    }

    /// @brief Position the input panel near the top-center of the workbench.
    /// @param shell Workbench shell used for viewport dimensions.
    hide func Layout(shell: app_shell.AppShell) {
        if panel == null or shell == null or shell.app == null { return; }
        var rootW = shell.app.GetLogicalWidth();
        var rootH = shell.app.GetLogicalHeight();
        if rootW <= 0 { rootW = 1280; }
        if rootH <= 0 { rootH = 800; }
        var panelW = COMMAND_INPUT_WIDTH;
        var panelH = COMMAND_INPUT_HEIGHT;
        if panelW > rootW - (COMMAND_INPUT_MARGIN * 2) {
            panelW = rootW - (COMMAND_INPUT_MARGIN * 2);
        }
        if panelH > rootH - (COMMAND_INPUT_MARGIN * 2) {
            panelH = rootH - (COMMAND_INPUT_MARGIN * 2);
        }
        if panelW < 300 { panelW = 300; }
        if panelH < 170 { panelH = 170; }
        panel.SetSize(panelW, panelH);

        var x = (rootW - panelW) / 2;
        var y = 92;
        if y + panelH + COMMAND_INPUT_MARGIN > rootH {
            y = rootH - panelH - COMMAND_INPUT_MARGIN;
        }
        if x < COMMAND_INPUT_MARGIN { x = COMMAND_INPUT_MARGIN; }
        if y < COMMAND_INPUT_MARGIN { y = COMMAND_INPUT_MARGIN; }
        panel.SetPosition(x, y);
    }
}
