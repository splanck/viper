module search_prompt;

bind "../services/search_request";

bind Viper.GUI;

// ============================================================================
// MODULE: search_prompt
// PURPOSE: User-facing prompt flow for project and folder text search.
//
// WHERE-THIS-FITS: search_commands.zia owns search execution and result
//          rendering. This module owns the blocking dialog sequence that turns
//          user choices into a normalized SearchRequest.
//
// KEY-DESIGN-CHOICES:
//   * REQUEST OBJECT AT THE BOUNDARY. Prompt text is immediately normalized into
//     search_request.SearchRequest so downstream code never has to remember
//     defaults for file kinds, globs, or regex mode.
//   * NULL MEANS CANCELED. The only non-runnable prompt result is represented as
//     null. SearchController can therefore exit without partially resetting an
//     in-progress search.
//   * SAME PROMPTS FOR EVERY SCOPE. Project search and folder search differ only
//     by root path and ignore patterns; the UI questions stay identical.
// ============================================================================

/// @brief Prompt the user for all search options.
/// @param title Dialog title for the first query prompt.
/// @param rootPath Directory scope that will be searched.
/// @param ignorePatterns Project ignore patterns merged into discovery.
/// @return Normalized SearchRequest, or null when the user provides no query.
/// @details The prompt sequence is intentionally linear because the current GUI
///          runtime exposes simple modal message boxes. Future richer search UI
///          can keep this function as the compatibility entry point while moving
///          collection into a non-modal panel.
expose func PromptRequest(title: String,
                          rootPath: String,
                          ignorePatterns: String) -> search_request.SearchRequest? {
    if rootPath == "" { return null; }

    var requestedQuery = GUI.MessageBox.Prompt(title, "Search for:");
    if requestedQuery == "" { return null; }

    var requestedCase = GUI.MessageBox.Confirm(
        "Search Options",
        "Use case-sensitive matching?") != 0;
    var requestedWholeWord = GUI.MessageBox.Confirm(
        "Search Options",
        "Match whole words only?") != 0;
    var requestedRegex = GUI.MessageBox.Confirm(
        "Search Options",
        "Treat the search text as a regular expression?") != 0;
    var requestedKinds = GUI.MessageBox.Prompt(
        "Search File Kinds",
        "Comma-separated extensions to search.\nLeave blank for code, text, scene, and docs.");
    var requestedInclude = GUI.MessageBox.Prompt(
        "Search Include Paths",
        "Comma-separated include globs. Leave blank for all matching files.");
    var requestedExclude = GUI.MessageBox.Prompt(
        "Search Exclude Paths",
        "Comma-separated exclude globs. Leave blank for project defaults.");

    return search_request.Create(rootPath,
                                 requestedQuery,
                                 requestedKinds,
                                 requestedCase,
                                 requestedWholeWord,
                                 requestedRegex,
                                 requestedInclude,
                                 requestedExclude,
                                 ignorePatterns);
}
