                                                                                                                                                             "                                       obj,\n"
                                                                                                                                                             "                                       morphDeltas,\n"
                                                                                                                                                             "                                       obj.flags1.y != 0 ? prevMorphWeights : morphWeights,\n"
                                                                                                                                                             "                                       vid);\n"
