                                                                                                                                                                                                                                                               "\n"
                                                                                                                                                                                                                                                               /* Cascade blend band + distance fade: hard cascade cuts pop visibly as the
                                                                                                                                                                                                                                                                * camera moves, so the last ~12% of each cascade cross-fades into the next,
                                                                                                                                                                                                                                                                * and directional shadows fade out approaching the capped shadow distance
                                                                                                                                                                                                                                                                * instead of ending on a hard line. */
                                                                                                                                                                                                                                                               "float sample_shadow(constant Light &light,\n"
                                                                                                                                                                                                                                                               "                    float3 worldPos,\n"
                                                                                                                                                                                                                                                               "                    float3 N,\n"
                                                                                                                                                                                                                                                               "                    float3 L,\n"
                                                                                                                                                                                                                                                               "                    float2 fragXY,\n"
                                                                                                                                                                                                                                                               "                    constant PerScene &scene,\n"
                                                                                                                                                                                                                                                               "                    depth2d<float> shadowMap0,\n"
                                                                                                                                                                                                                                                               "                    depth2d<float> shadowMap1,\n"
                                                                                                                                                                                                                                                               "                    depth2d<float> shadowMap2,\n"
                                                                                                                                                                                                                                                               "                    depth2d<float> shadowMap3,\n"
                                                                                                                                                                                                                                                               "                    depth2d<float> shadowAtlas,\n"
                                                                                                                                                                                                                                                               "                    sampler shadowSampler) {\n"
                                                                                                                                                                                                                                                               "    int shadowIndex = resolve_shadow_cascade(light, worldPos, scene);\n"
                                                                                                                                                                                                                                                               "    if (shadowIndex < 0 || shadowIndex >= scene.counts.y)\n"
                                                                                                                                                                                                                                                               "        return 1.0;\n"
                                                                                                                                                                                                                                                               "    float lit = sample_shadow_cascade(light, shadowIndex, worldPos, N, L,\n"
                                                                                                                                                                                                                                                               "                                      fragXY, scene, shadowMap0, shadowMap1,\n"
                                                                                                                                                                                                                                                               "                                      shadowMap2, shadowMap3, shadowAtlas,\n"
                                                                                                                                                                                                                                                               "                                      shadowSampler);\n"
                                                                                                                                                                                                                                                               "    int cascadeCount = clamp(light.shadowCascadeCount, 1, " VGFX3D_STR(
                                                                                                                                                                                                                                                                   VGFX3D_MAX_SHADOW_LIGHTS) ");\n"
                                                                                                                                                                                                                                                               "    cascadeCount = min(cascadeCount, scene.counts.y - light.shadowIndex);\n"
                                                                                                                                                                                                                                                               "    if (light.shadowProjectionType == 0 && cascadeCount > 1 &&\n"
                                                                                                                                                                                                                                                               "        shadowIndex >= light.shadowIndex) {\n"
                                                                                                                                                                                                                                                               "        int cascade = shadowIndex - light.shadowIndex;\n"
                                                                                                                                                                                                                                                               "        float viewDepth =\n"
                                                                                                                                                                                                                                                               "            dot(worldPos - scene.cameraPosition.xyz, scene.cameraForward.xyz);\n"
                                                                                                                                                                                                                                                               "        float splitFar = light.shadowCascadeSplits[cascade];\n"
                                                                                                                                                                                                                                                               "        float splitNear = cascade > 0 ? light.shadowCascadeSplits[cascade - 1] : 0.0;\n"
                                                                                                                                                                                                                                                               "        float band = max(0.5, 0.12 * (splitFar - splitNear));\n"
                                                                                                                                                                                                                                                               "        if (cascade < cascadeCount - 1) {\n"
                                                                                                                                                                                                                                                               "            float blend = clamp((viewDepth - (splitFar - band)) / band, 0.0, 1.0);\n"
                                                                                                                                                                                                                                                               "            if (blend > 0.0) {\n"
                                                                                                                                                                                                                                                               "                float litNext = sample_shadow_cascade(\n"
                                                                                                                                                                                                                                                               "                    light, shadowIndex + 1, worldPos, N, L, fragXY, scene,\n"
                                                                                                                                                                                                                                                               "                    shadowMap0, shadowMap1, shadowMap2, shadowMap3, shadowAtlas,\n"
                                                                                                                                                                                                                                                               "                    shadowSampler);\n"
                                                                                                                                                                                                                                                               "                lit = mix(lit, litNext, blend);\n"
                                                                                                                                                                                                                                                               "            }\n"
                                                                                                                                                                                                                                                               "        } else {\n"
                                                                                                                                                                                                                                                               "            float shadowFar = light.shadowCascadeSplits[cascadeCount - 1];\n"
                                                                                                                                                                                                                                                               "            float fadeBand = max(2.0, 0.10 * shadowFar);\n"
                                                                                                                                                                                                                                                               "            float fade = clamp((shadowFar - viewDepth) / fadeBand, 0.0, 1.0);\n"
                                                                                                                                                                                                                                                               "            lit = mix(1.0, lit, fade);\n"
                                                                                                                                                                                                                                                               "        }\n"
                                                                                                                                                                                                                                                               "    }\n"
                                                                                                                                                                                                                                                               "    return lit;\n"
                                                                                                                                                                                                                                                               "}\n"
