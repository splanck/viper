                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float D = distribution_ggx(NdotH, roughness);\n"
    "            if (material.customParams[8] > 0.0) {\n"
    "                /* KHR_materials_anisotropy: elliptical GGX along the\n"
    "                   rotated tangent direction. */\n"
    "                float3 TnA = safe_normalize3(in.tangent.xyz - N * dot(N, in.tangent.xyz), float3(1.0, 0.0, 0.0));\n"
    "                float3 BnA = safe_normalize3(cross(N, TnA), float3(0.0, 1.0, 0.0)) * in.tangent.w;\n"
    "                float rotA = material.customParams[9];\n"
    "                float3 TaA = safe_normalize3(TnA * cos(rotA) + BnA * sin(rotA), float3(1.0, 0.0, 0.0));\n"
    "                float3 BaA = safe_normalize3(cross(N, TaA), float3(0.0, 1.0, 0.0)) * in.tangent.w;\n"
    "                float alphaGA = roughness * roughness;\n"
    "                float strA = clamp(material.customParams[8], 0.0, 1.0);\n"
    "                float atA = max(alphaGA * (1.0 + strA), 0.001);\n"
    "                float abA = max(alphaGA * (1.0 - strA), 0.001);\n"
    "                float TdotHA = dot(TaA, H);\n"
    "                float BdotHA = dot(BaA, H);\n"
    "                float qA = TdotHA * TdotHA / (atA * atA) +\n"
    "                           BdotHA * BdotHA / (abA * abA) + NdotH * NdotH;\n"
    "                D = 1.0 / (3.14159265 * atA * abA * qA * qA + 0.0001);\n"
    "            }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float G = geometry_smith(NdotV, NdotL, roughness);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 specular = (D * G * F) / max(4.0 * NdotV * NdotL, 0.0001);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 kS = F;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 kD = (1.0 - kS) * (1.0 - metallic);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 diffuse = kD * baseColor / 3.14159265;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 radiance = lights[i].color.rgb * lights[i].intensity * atten;\n"
    "            if (sheenCC > 0.0) {\n"
    "                float alphaS = sheenRoughCC * sheenRoughCC;\n"
    "                float invAlphaS = 1.0 / alphaS;\n"
    "                float sin2S = max(1.0 - NdotH * NdotH, 0.0);\n"
    "                float dCharlie = (2.0 + invAlphaS) * pow(sin2S, invAlphaS * 0.5) * 0.15915494;\n"
    "                float visSheen = 1.0 / (4.0 * (NdotL + NdotV - NdotL * NdotV) + 0.0001);\n"
    "                specular += float3(sheenCC * dCharlie * visSheen);\n"
    "            }\n"
    "            if (coatCC > 0.0) {\n"
    "                float coatD = distribution_ggx(NdotH, coatRoughCC);\n"
    "                float coatF = 0.04 + 0.96 * pow(clamp(1.0 - VdotH, 0.0, 1.0), 5.0);\n"
    "                float coatVis = 0.25 / max(VdotH * VdotH, 0.0001);\n"
    "                float coatSpec = coatCC * coatD * coatF * coatVis;\n"
    "                float coatKeep = 1.0 - coatCC * coatF;\n"
    "                diffuse *= coatKeep;\n"
    "                specular = specular * coatKeep + float3(coatSpec);\n"
    "            }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            result += (diffuse + specular) * radiance * NdotL;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    } else {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        result = scene.ambientColor.rgb * baseColor;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float3 specColor = material.specularColor.rgb;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        if (material.flags0.w != 0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            specColor *= specularTex.sample(specularSampler, material_uv(in, material, 2)).rgb;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        int lightLoopCount = scene.counts.x;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        int clusterStart = 0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        if (scene.counts.z >= 0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            int cidx = cluster_fragment_index(clusterTable, scene, in.position.xy,\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                                              in.worldPos);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            clusterStart = int(clusterTable.offsets[cidx]);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            lightLoopCount =\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                scene.counts.z + (int(clusterTable.offsets[cidx + 1]) - clusterStart);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        for (int k = 0; k < lightLoopCount; k++) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            int i = (scene.counts.z < 0 || k < scene.counts.z)\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                        ? k\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                        : int(clusterTable.indices[clusterStart + (k - scene.counts.z)]);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float3 L; float atten = 1.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            if (lights[i].type == 0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                L = safe_normalize3(-lights[i].direction.xyz, float3(0.0, -1.0, 0.0));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            } else if (lights[i].type == 1) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float3 tl = lights[i].position.xyz - in.worldPos;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float d = length(tl); L = safe_normalize3(tl, float3(0.0));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                atten = 1.0 / (1.0 + lights[i].attenuation * d * d);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            } else if (lights[i].type == 3) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float3 tl = lights[i].position.xyz - in.worldPos;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float d = length(tl); L = safe_normalize3(tl, float3(0.0));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                atten = 1.0 / (1.0 + lights[i].attenuation * d * d);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float spotDot = dot(-L, safe_normalize3(lights[i].direction.xyz, float3(0.0, -1.0, 0.0)));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                if (spotDot < lights[i].outer_cos) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                    atten = 0.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                } else if (spotDot < lights[i].inner_cos) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                    float coneRange = lights[i].inner_cos - lights[i].outer_cos;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                    float t = coneRange > 0.0001 ? clamp((spotDot - lights[i].outer_cos) / coneRange, 0.0, 1.0) : 0.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                    atten *= t * t * (3.0 - 2.0 * t);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            } else {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                result += lights[i].color.rgb * lights[i].intensity * baseColor;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                continue;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float NdotL = max(dot(N, L), 0.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            if ((lights[i].type == 0 || lights[i].type == 1 || lights[i].type == 3) && atten > 0.0)\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                atten *= mix(1.0 - scene.iblParams.z, 1.0, sample_shadow(lights[i], "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "in.worldPos, N, L, in.position.xy, "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "scene, shadowMap0, shadowMap1, shadowMap2, shadowMap3, shadowAtlas, shadowSampler));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            result += lights[i].color.rgb * lights[i].intensity * NdotL * "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "baseColor * atten;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            if (NdotL > 0.0 && material.specularColor.w > 0.0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float3 H = safe_normalize3(L + V, N);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                float spec = pow(max(dot(N, H), 0.0), material.specularColor.w);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "                result += lights[i].color.rgb * lights[i].intensity * spec * "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "specColor * atten;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    result += emissive;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    if (material.flags1.y != 0 && material.flags1.w == 0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float3 R = reflect(-V, N);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float3 envColor = env_sample(envTex, envSampler, R, envRoughness, "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "material.scalars.z);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        result = mix(result, envColor, clamp(material.scalars.y, 0.0, 1.0));\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    if (scene.fogColor.a > 0.5 || scene.heightFog.z > 0.0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float fogRange = scene.fogParams.y - scene.fogParams.x;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float fogFactor = clamp((viewDistance - scene.fogParams.x) / max(fogRange, 0.001), "
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "0.0, 1.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        if (scene.fogColor.a <= 0.5) fogFactor = 0.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        if (scene.heightFog.z > 0.0) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float hd = scene.heightFog.z * exp(-(in.worldPos.y - scene.heightFog.x) * scene.heightFog.y);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            float hf = clamp(1.0 - exp(-hd * viewDistance), 0.0, 1.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "            fogFactor = 1.0 - (1.0 - fogFactor) * (1.0 - hf);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float3 fogTint = scene.fogColor.rgb;\n"
"        if (scene.heightFog.z > 0.0 && scene.heightFogSun.w > 0.0) {\n"
"            float3 fogV = in.worldPos.xyz - scene.cameraPosition.xyz;\n"
"            float fogVLen = length(fogV);\n"
"            if (fogVLen > 1e-6) {\n"
"                float fogAlign = dot(fogV / fogVLen, scene.heightFogSunDir.xyz);\n"
"                if (fogAlign > 0.0) {\n"
"                    float fogSunW = min(scene.heightFogSun.w * pow(fogAlign, scene.heightFogSunDir.w), 1.0);\n"
"                    fogTint = mix(fogTint, scene.heightFogSun.xyz, fogSunW);\n"
"                }\n"
"            }\n"
"        }\n"
"        result = mix(result, fogTint, fogFactor);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    }\n"
    "    if (material.shadingModel != 1 && material.shadingModel != 5 &&\n"
    "        material.customParams[3] > 0.0 && material.customParams[5] > 0.0 &&\n"
    "        material.customParams[6] > 0.0) {\n"
    "        float absorbCC = exp(-material.customParams[6] * material.customParams[5]);\n"
    "        float tintCC = 1.0 + clamp(material.customParams[3], 0.0, 1.0) *\n"
    "                                 (absorbCC - 1.0);\n"
    "        result *= tintCC;\n"
    "    }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    if (material.shadingModel == 1) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float bands = material.customParams[0] > 0.5 ? material.customParams[0] : 4.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        result = floor(result * bands) / bands;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    } else if (material.shadingModel == 4) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float ndv = max(dot(N, V), 0.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float power = material.customParams[0] > 0.1 ? material.customParams[0] : 3.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float bias = material.customParams[1];\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float fresnel = pow(1.0 - ndv, power) + bias;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        finalAlpha *= clamp(fresnel, 0.0, 1.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    } else if (material.shadingModel == 5) {\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        float strength = material.customParams[0] > 0.0 ? material.customParams[0] : 2.0;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "        result += emissive * (strength - 1.0);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    }\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    out.color = float4(result, finalAlpha);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    out.motion = motion_output(in);\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    out.motion.w = material.pbrScalars1.w;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "    return out;\n"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "}\n";

#pragma clang diagnostic pop

//=============================================================================
// Uniform buffer structs (must match shader)
//=============================================================================

typedef struct {
    float m[16];
    float prev_m[16];
    float vp[16];
    float nm[16];
    int32_t flags0[4];
    int32_t flags1[4];
    /* x = per-instance bone-palette stride (R18); y/z/w spare */
    int32_t flags2[4];
} mtl_per_object_t;

typedef struct {
    float cp[4];
    float ac[4];
    float fc[4];
    float fog_params[4];
    int32_t counts[4];
    float camera_forward[4];
    float prev_vp[16];
    float shadow_vp[VGFX3D_MAX_SHADOW_LIGHTS][16];
    /* x = IBL intensity; Plan 06 shadow knobs ride the spare lanes:
     * y = slope-bias factor, z = shadow strength, w = Poisson tap count. */
    float ibl_params[4];
    float sh[9][4]; /* SH-9 RGB irradiance, one coefficient per float4 */
    /* Plan 07: x/y = viewport size for froxel lookup (z/w spare). counts[2]
     * carries the global-light prefix length, or -1 for the flat light loop. */
    float cluster_params[4];
    /* Track E doc 07: exponential height fog (x = base, y = falloff,
     * z = density*blend with 0 = off, w = pad). Appended so all earlier
     * offsets stay byte-identical to the MSL PerScene (BUG-E7 contract). */
    float height_fog[4];
    /* Height-fog sun inscattering (appended, same offset contract):
     * height_fog_sun = tint rgb + amount (w, 0 = off);
     * height_fog_sun_dir = direction toward the sun (xyz) + power (w). */
    float height_fog_sun[4];
    float height_fog_sun_dir[4];
} mtl_per_scene_t;

typedef struct {
    int32_t type;
    int32_t shadow_index;
    int32_t shadow_cascade_count;
    int32_t shadow_projection_type;
    float dir[4];
    float pos[4];
    float col[4];
    float intensity;
    float attenuation;
    float inner_cos;
    float outer_cos;
    float shadow_cascade_splits[4];
} mtl_light_t;

