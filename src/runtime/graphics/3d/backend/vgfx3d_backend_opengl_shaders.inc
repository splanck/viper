static const char *glsl_taa_fragment_src =
    "#version 330 core\n"
    "in vec2 vUV;\n"
    "out vec4 FragColor;\n"
    "uniform sampler2D uCurrTex;\n"
    "uniform sampler2D uHistTex;\n"
    "uniform sampler2D uMotionTex;\n"
    "uniform sampler2D uDepthTex;\n"
    "uniform vec2 uInvResolution;\n"
    "uniform vec2 uJitterDelta;\n"
    "uniform float uBlend;\n"
    "uniform int uHistoryValid;\n"
    "uniform mat4 uInvViewProjection;\n"
    "uniform mat4 uPrevViewProjection;\n"
    "void main() {\n"
    "    vec3 curr = texture(uCurrTex, vUV).rgb;\n"
    "    if (uHistoryValid == 0) {\n"
    "        FragColor = vec4(curr, 1.0);\n"
    "        return;\n"
    "    }\n"
    "    vec3 motionSample = texture(uMotionTex, vUV).rgb;\n"
    "    vec2 velocity = motionSample.xy * 2.0 - 1.0;\n"
    "    if (motionSample.z < 0.5) {\n"
    "        float depth = texture(uDepthTex, vUV).r;\n"
    "        vec4 clip = vec4(vUV * 2.0 - 1.0, VIPER_DEPTH_TO_NDC(depth), 1.0);\n"
    "        vec4 world = uInvViewProjection * clip;\n"
    "        world.xyz /= max(abs(world.w), 0.0001) * (world.w < 0.0 ? -1.0 : 1.0);\n"
    "        vec4 prevClip = uPrevViewProjection * vec4(world.xyz, 1.0);\n"
    "        float prevW = (prevClip.w < 0.0 ? -1.0 : 1.0) * max(abs(prevClip.w), 0.0001);\n"
    "        vec2 prevUv = prevClip.xy / prevW * 0.5 + 0.5;\n"
    "        velocity = vUV - prevUv;\n"
    "    }\n"
    "    velocity -= uJitterDelta;\n"
    "    vec2 histUv = vUV - velocity;\n"
    "    if (histUv.x < 0.0 || histUv.x > 1.0 || histUv.y < 0.0 || histUv.y > 1.0) {\n"
    "        FragColor = vec4(curr, 1.0);\n"
    "        return;\n"
    "    }\n"
    "    vec3 hist = texture(uHistTex, histUv).rgb;\n"
    "    vec3 cmin = curr;\n"
    "    vec3 cmax = curr;\n"
    "    for (int dy = -1; dy <= 1; dy++)\n"
    "        for (int dx = -1; dx <= 1; dx++) {\n"
    "            if (dx == 0 && dy == 0) continue;\n"
    "            vec3 n = texture(uCurrTex, vUV + vec2(dx, dy) * uInvResolution).rgb;\n"
    "            cmin = min(cmin, n);\n"
    "            cmax = max(cmax, n);\n"
    "        }\n"
    "    hist = clamp(hist, cmin, cmax);\n"
    "    float w = clamp(uBlend, 0.0, 0.98);\n"
    "    w *= 1.0 - clamp(length(velocity) * 8.0, 0.0, 0.85);\n"
    "    FragColor = vec4(mix(curr, hist, w), 1.0);\n"
    "}\n";

/* Plan 10: screen-space reflections — linear ray-march against the scene depth
 * buffer with binary refinement for pixels whose motion-target alpha carries an
 * SSR mask (Water3D / SsrEnabled materials). Misses keep the source pixel, whose
 * env-map reflection term acts as the fallback. */
static const char *glsl_ssr_fragment_src =
    "#version 330 core\n"
    "in vec2 vUV;\n"
    "out vec4 FragColor;\n"
    "uniform sampler2D uSceneTex;\n"
    "uniform sampler2D uDepthTex;\n"
    "uniform sampler2D uMotionTex;\n"
    "uniform vec2 uInvResolution;\n"
    "uniform vec4 uParams0;\n"
    "uniform vec3 uCamPos;\n"
    "uniform mat4 uInvViewProjection;\n"
    "uniform mat4 uViewProjection;\n"
    "vec3 ssrSafeNormalize3(vec3 v, vec3 fallback) {\n"
    "    float len2 = dot(v, v);\n"
    "    return (len2 > 1e-12 && len2 < 1e20) ? v * inversesqrt(len2) : fallback;\n"
    "}\n"
    "vec3 ssrWorldAt(vec2 uv, float depth) {\n"
    "    vec4 clip = vec4(uv * 2.0 - 1.0, VIPER_DEPTH_TO_NDC(depth), 1.0);\n"
    "    vec4 world = uInvViewProjection * clip;\n"
    "    float w = (world.w < 0.0 ? -1.0 : 1.0) * max(abs(world.w), 0.0001);\n"
    "    return world.xyz / w;\n"
    "}\n"
    "void main() {\n"
    "    vec3 base = texture(uSceneTex, vUV).rgb;\n"
    "    float mask = texture(uMotionTex, vUV).a;\n"
    "    float depth = texture(uDepthTex, vUV).r;\n"
    /* Reversed-Z: cleared/far depth is 0 and nearer is larger, so the sky guard and
     * every ray-vs-scene comparison below flip direction. */
    "    if (mask <= 0.004 || depth <= 0.0001) {\n"
    "        FragColor = vec4(base, 1.0);\n"
    "        return;\n"
    "    }\n"
    "    vec3 world = ssrWorldAt(vUV, depth);\n"
    "    vec2 du = vec2(uInvResolution.x, 0.0);\n"
    "    vec2 dv = vec2(0.0, uInvResolution.y);\n"
    "    vec3 wx = ssrWorldAt(vUV + du, texture(uDepthTex, vUV + du).r);\n"
    "    vec3 wy = ssrWorldAt(vUV + dv, texture(uDepthTex, vUV + dv).r);\n"
    "    vec3 N = ssrSafeNormalize3(cross(wx - world, wy - world), vec3(0.0, 1.0, 0.0));\n"
    "    vec3 V = ssrSafeNormalize3(world - uCamPos, vec3(0.0, 0.0, -1.0));\n"
    "    if (dot(N, V) > 0.0) N = -N;\n"
    "    vec3 R = reflect(V, N);\n"
    "    vec2 px = vUV / uInvResolution;\n"
    "    float ign = fract(52.9829189 * fract(0.06711056 * px.x + 0.00583715 * px.y));\n"
    "    int steps = clamp(int(uParams0.z), 8, 48);\n"
    "    float t = 0.05 + 0.08 * ign;\n"
    "    float prevT = 0.0;\n"
    "    vec2 hitUv = vec2(-1.0);\n"
    "    bool hit = false;\n"
    "    for (int i = 0; i < steps; i++) {\n"
    "        vec3 pos = world + R * t;\n"
    "        vec4 pc = uViewProjection * vec4(pos, 1.0);\n"
    "        if (pc.w <= 0.0001) break;\n"
    "        vec3 ndc = pc.xyz / pc.w;\n"
    "        vec2 uv2 = ndc.xy * 0.5 + 0.5;\n"
    "        if (uv2.x < 0.0 || uv2.x > 1.0 || uv2.y < 0.0 || uv2.y > 1.0) break;\n"
    "        float rayD = ndc.z * 0.5 + 0.5;\n"
    "        float sceneD = texture(uDepthTex, uv2).r;\n"
    "        if (rayD < sceneD - 0.0002) {\n"
    "            float lo = prevT;\n"
    "            float hi = t;\n"
    "            for (int r = 0; r < 4; r++) {\n"
    "                float mid = (lo + hi) * 0.5;\n"
    "                vec4 mc = uViewProjection * vec4(world + R * mid, 1.0);\n"
    "                vec3 mndc = mc.xyz / max(mc.w, 0.0001);\n"
    "                vec2 muv = mndc.xy * 0.5 + 0.5;\n"
    "                if (mndc.z * 0.5 + 0.5 < texture(uDepthTex, muv).r - 0.0002) hi = mid;\n"
    "                else lo = mid;\n"
    "            }\n"
    "            vec4 hc = uViewProjection * vec4(world + R * hi, 1.0);\n"
    "            vec3 hndc = hc.xyz / max(hc.w, 0.0001);\n"
    "            hitUv = hndc.xy * 0.5 + 0.5;\n"
    "            float hitRayD = hndc.z * 0.5 + 0.5;\n"
    "            float hitSceneD = texture(uDepthTex, hitUv).r;\n"
    "            hit = (hitSceneD - hitRayD) < 0.02;\n"
    "            break;\n"
    "        }\n"
    "        prevT = t;\n"
    "        t *= 1.35;\n"
    "    }\n"
    "    if (!hit || hitUv.x < 0.0) {\n"
    "        FragColor = vec4(base, 1.0);\n"
    "        return;\n"
    "    }\n"
    "    vec2 edge = min(hitUv, 1.0 - hitUv);\n"
    "    float edgeFade = clamp(min(edge.x, edge.y) * 8.0, 0.0, 1.0);\n"
    "    float ndv = clamp(dot(-V, N), 0.0, 1.0);\n"
    "    float fres = 0.2 + 0.8 * pow(1.0 - ndv, 2.0);\n"
    "    float amt = clamp(uParams0.x, 0.0, 1.0) * mask * edgeFade * fres;\n"
    "    vec3 refl = texture(uSceneTex, hitUv).rgb;\n"
    "    FragColor = vec4(mix(base, refl, amt), 1.0);\n"
    "}\n";
