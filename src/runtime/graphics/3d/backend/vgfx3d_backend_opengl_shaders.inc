/* Plan 05: mip-chain bloom passes — 13-tap downsample (Karis average + soft-knee
 * threshold on the first pass) and 3x3 tent upsample (accumulated additively via
 * GL_ONE/GL_ONE blending). Both draw the shared fullscreen triangle. */
static const char *glsl_bloom_down_fragment_src =
    "#version 330 core\n"
    "in vec2 vUV;\n"
    "out vec4 FragColor;\n"
    "uniform sampler2D uSrcTex;\n"
    "uniform vec2 uSrcInvSize;\n"
    "uniform float uThreshold;\n"
    "uniform int uFirstPass;\n"
    "float bloomLuma(vec3 c) { return dot(c, vec3(0.2126, 0.7152, 0.0722)); }\n"
    "vec3 bloomKaris(vec3 c) { return c / (1.0 + bloomLuma(c)); }\n"
    "void main() {\n"
    "    vec2 ts = uSrcInvSize;\n"
    "    vec3 a = texture(uSrcTex, vUV + ts * vec2(-2.0, -2.0)).rgb;\n"
    "    vec3 b = texture(uSrcTex, vUV + ts * vec2(0.0, -2.0)).rgb;\n"
    "    vec3 c = texture(uSrcTex, vUV + ts * vec2(2.0, -2.0)).rgb;\n"
    "    vec3 d = texture(uSrcTex, vUV + ts * vec2(-2.0, 0.0)).rgb;\n"
    "    vec3 e = texture(uSrcTex, vUV).rgb;\n"
    "    vec3 f = texture(uSrcTex, vUV + ts * vec2(2.0, 0.0)).rgb;\n"
    "    vec3 g = texture(uSrcTex, vUV + ts * vec2(-2.0, 2.0)).rgb;\n"
    "    vec3 h = texture(uSrcTex, vUV + ts * vec2(0.0, 2.0)).rgb;\n"
    "    vec3 i2 = texture(uSrcTex, vUV + ts * vec2(2.0, 2.0)).rgb;\n"
    "    vec3 j = texture(uSrcTex, vUV + ts * vec2(-1.0, -1.0)).rgb;\n"
    "    vec3 k = texture(uSrcTex, vUV + ts * vec2(1.0, -1.0)).rgb;\n"
    "    vec3 l = texture(uSrcTex, vUV + ts * vec2(-1.0, 1.0)).rgb;\n"
    "    vec3 m = texture(uSrcTex, vUV + ts * vec2(1.0, 1.0)).rgb;\n"
    "    vec3 col;\n"
    "    if (uFirstPass != 0) {\n"
    "        col = bloomKaris((j + k + l + m) * 0.25) * 0.5;\n"
    "        col += bloomKaris((a + b + d + e) * 0.25) * 0.125;\n"
    "        col += bloomKaris((b + c + e + f) * 0.25) * 0.125;\n"
    "        col += bloomKaris((d + e + g + h) * 0.25) * 0.125;\n"
    "        col += bloomKaris((e + f + h + i2) * 0.25) * 0.125;\n"
    "        float lum = bloomLuma(col);\n"
    "        float scale = (lum > uThreshold) ? (lum - uThreshold) / (lum + 1e-6) : 0.0;\n"
    "        col *= scale;\n"
    "    } else {\n"
    "        col = (j + k + l + m) * (0.5 * 0.25);\n"
    "        col += (a + b + d + e) * (0.125 * 0.25);\n"
    "        col += (b + c + e + f) * (0.125 * 0.25);\n"
    "        col += (d + e + g + h) * (0.125 * 0.25);\n"
    "        col += (e + f + h + i2) * (0.125 * 0.25);\n"
    "    }\n"
    "    FragColor = vec4(col, 1.0);\n"
    "}\n";

static const char *glsl_bloom_up_fragment_src =
    "#version 330 core\n"
    "in vec2 vUV;\n"
    "out vec4 FragColor;\n"
    "uniform sampler2D uSrcTex;\n"
    "uniform vec2 uSrcInvSize;\n"
    "void main() {\n"
    "    vec2 ts = uSrcInvSize;\n"
    "    vec3 col = texture(uSrcTex, vUV + ts * vec2(-1.0, -1.0)).rgb;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(0.0, -1.0)).rgb * 2.0;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(1.0, -1.0)).rgb;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(-1.0, 0.0)).rgb * 2.0;\n"
    "    col += texture(uSrcTex, vUV).rgb * 4.0;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(1.0, 0.0)).rgb * 2.0;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(-1.0, 1.0)).rgb;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(0.0, 1.0)).rgb * 2.0;\n"
    "    col += texture(uSrcTex, vUV + ts * vec2(1.0, 1.0)).rgb;\n"
    "    FragColor = vec4(col * (1.0 / 16.0), 1.0);\n"
    "}\n";

/* Plan 05: TAA resolve — reproject the persistent history through per-pixel velocity
