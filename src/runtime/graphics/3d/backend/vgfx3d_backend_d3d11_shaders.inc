/* Plan 05: TAA resolve — reproject the persistent history through per-pixel velocity
 * (rasterized motion when flagged, analytic camera reprojection otherwise), clamp it to
 * the current frame's 3x3 neighborhood, and blend. Motion vectors are rendered under
 * projection jitter, so the current-minus-previous jitter delta is subtracted first. */
static const char *const d3d11_taa_shader_source_chunks[] = {
    "cbuffer TAACB : register(b0) {\n"
    "    row_major float4x4 invViewProjection;\n"
    "    row_major float4x4 prevViewProjection;\n"
    "    float2 invResolution;\n"
    "    float2 jitterDelta;\n"
    "    float blendWeight;\n"
    "    int historyValid;\n"
    "    float2 _taaPad0;\n"
    "};\n"
    "Texture2D currTex : register(t0);\n"
    "Texture2D histTex : register(t1);\n"
    "Texture2D motionTex : register(t2);\n"
    "Texture2D depthTex : register(t3);\n"
    "SamplerState postSampler : register(s0);\n"
    "struct VS_OUTPUT {\n"
    "    float4 pos : SV_POSITION;\n"
    "    float2 uv : TEXCOORD0;\n"
    "};\n"
    "float2 uvToNdc(float2 uv) { return float2(uv.x * 2.0 - 1.0, 1.0 - uv.y * 2.0); }\n"
    "float2 ndcDeltaToUvDelta(float2 delta) { return float2(delta.x * 0.5, -delta.y * 0.5); }\n"
    "float4 PSTAAResolve(VS_OUTPUT input) : SV_Target {\n"
    "    float3 curr = currTex.Sample(postSampler, input.uv).rgb;\n"
    "    if (historyValid == 0)\n"
    "        return float4(curr, 1.0);\n"
    "    float4 motion = motionTex.Sample(postSampler, input.uv);\n"
    "    float2 velocity = motion.xy * 2.0 - 1.0;\n"
    "    if (motion.z < 0.5) {\n"
    "        float depth = depthTex.Sample(postSampler, input.uv).r;\n"
    "        float4 clip = float4(uvToNdc(input.uv), depth * 2.0 - 1.0, 1.0);\n"
    "        float4 world = mul(invViewProjection, clip);\n"
    "        world.xyz /= max(abs(world.w), 0.0001) * (world.w < 0.0 ? -1.0 : 1.0);\n"
    "        float4 prevClip = mul(prevViewProjection, float4(world.xyz, 1.0));\n"
    "        float prevW = (prevClip.w < 0.0 ? -1.0 : 1.0) * max(abs(prevClip.w), 0.0001);\n"
    "        velocity = ndcDeltaToUvDelta(uvToNdc(input.uv) - prevClip.xy / prevW);\n"
    "    }\n"
    "    velocity -= jitterDelta;\n"
    "    float2 histUv = input.uv - velocity;\n"
    "    if (histUv.x < 0.0 || histUv.x > 1.0 || histUv.y < 0.0 || histUv.y > 1.0)\n"
    "        return float4(curr, 1.0);\n"
    "    float3 hist = histTex.Sample(postSampler, histUv).rgb;\n"
    "    float3 cmin = curr;\n"
    "    float3 cmax = curr;\n"
    "    [unroll]\n"
    "    for (int dy = -1; dy <= 1; dy++) {\n"
    "        [unroll]\n"
    "        for (int dx = -1; dx <= 1; dx++) {\n"
    "            if (dx == 0 && dy == 0)\n"
    "                continue;\n"
    "            float3 n = currTex.Sample(postSampler, input.uv + float2(dx, dy) * "
    "invResolution).rgb;\n"
    "            cmin = min(cmin, n);\n"
    "            cmax = max(cmax, n);\n"
    "        }\n"
    "    }\n"
    "    hist = clamp(hist, cmin, cmax);\n"
    "    float w = clamp(blendWeight, 0.0, 0.98);\n"
    "    w *= 1.0 - saturate(length(velocity) * 8.0) * 0.85;\n"
    "    return float4(lerp(curr, hist, w), 1.0);\n"
    "}\n",
};

