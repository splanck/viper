    return d3d11_join_shader_chunks(&d3d11_bloom_shader_source_cache, d3d11_bloom_shader_source_chunks, sizeof(d3d11_bloom_shader_source_chunks) / sizeof(d3d11_bloom_shader_source_chunks[0]));
}
