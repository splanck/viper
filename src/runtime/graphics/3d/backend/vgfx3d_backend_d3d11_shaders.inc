/* Plan 05: mip-chain bloom passes — 13-tap downsample (Karis average + soft-knee
 * threshold on the first pass) and 3x3 tent upsample (accumulated additively via the
 * existing additive blend state). Shares vs_postfx's fullscreen triangle. */
static const char *const d3d11_bloom_shader_source_chunks[] = {
    "cbuffer BloomCB : register(b0) {\n"
    "    float2 srcInvSize;\n"
    "    float threshold;\n"
    "    int firstPass;\n"
    "};\n"
    "Texture2D srcTex : register(t0);\n"
    "SamplerState postSampler : register(s0);\n"
    "struct VS_OUTPUT {\n"
    "    float4 pos : SV_POSITION;\n"
    "    float2 uv : TEXCOORD0;\n"
    "};\n"
    "float bloomLuma(float3 c) { return dot(c, float3(0.2126, 0.7152, 0.0722)); }\n"
    "float3 bloomKaris(float3 c) { return c / (1.0 + bloomLuma(c)); }\n"
    "float3 srcAt(float2 uv) { return srcTex.Sample(postSampler, uv).rgb; }\n"
    "float4 PSBloomDown(VS_OUTPUT input) : SV_Target {\n"
    "    float2 uv = input.uv;\n"
    "    float2 ts = srcInvSize;\n"
    "    float3 a = srcAt(uv + ts * float2(-2.0, -2.0));\n"
    "    float3 b = srcAt(uv + ts * float2(0.0, -2.0));\n"
    "    float3 c = srcAt(uv + ts * float2(2.0, -2.0));\n"
    "    float3 d = srcAt(uv + ts * float2(-2.0, 0.0));\n"
    "    float3 e = srcAt(uv);\n"
    "    float3 f = srcAt(uv + ts * float2(2.0, 0.0));\n"
    "    float3 g = srcAt(uv + ts * float2(-2.0, 2.0));\n"
    "    float3 h = srcAt(uv + ts * float2(0.0, 2.0));\n"
    "    float3 i2 = srcAt(uv + ts * float2(2.0, 2.0));\n"
    "    float3 j = srcAt(uv + ts * float2(-1.0, -1.0));\n"
    "    float3 k = srcAt(uv + ts * float2(1.0, -1.0));\n"
    "    float3 l = srcAt(uv + ts * float2(-1.0, 1.0));\n"
    "    float3 m = srcAt(uv + ts * float2(1.0, 1.0));\n"
    "    float3 col;\n"
    "    if (firstPass != 0) {\n"
    "        col = bloomKaris((j + k + l + m) * 0.25) * 0.5;\n"
    "        col += bloomKaris((a + b + d + e) * 0.25) * 0.125;\n"
    "        col += bloomKaris((b + c + e + f) * 0.25) * 0.125;\n"
    "        col += bloomKaris((d + e + g + h) * 0.25) * 0.125;\n"
    "        col += bloomKaris((e + f + h + i2) * 0.25) * 0.125;\n"
    "        float lum = bloomLuma(col);\n"
    "        float scale = (lum > threshold) ? (lum - threshold) / (lum + 1e-6) : 0.0;\n"
    "        col *= scale;\n"
    "    } else {\n"
    "        col = (j + k + l + m) * (0.5 * 0.25);\n"
    "        col += (a + b + d + e) * (0.125 * 0.25);\n"
    "        col += (b + c + e + f) * (0.125 * 0.25);\n"
    "        col += (d + e + g + h) * (0.125 * 0.25);\n"
    "        col += (e + f + h + i2) * (0.125 * 0.25);\n"
    "    }\n"
    "    return float4(col, 1.0);\n"
    "}\n"
    "float4 PSBloomUp(VS_OUTPUT input) : SV_Target {\n"
    "    float2 uv = input.uv;\n"
    "    float2 ts = srcInvSize;\n"
    "    float3 col = srcAt(uv + ts * float2(-1.0, -1.0));\n"
    "    col += srcAt(uv + ts * float2(0.0, -1.0)) * 2.0;\n"
    "    col += srcAt(uv + ts * float2(1.0, -1.0));\n"
    "    col += srcAt(uv + ts * float2(-1.0, 0.0)) * 2.0;\n"
    "    col += srcAt(uv) * 4.0;\n"
    "    col += srcAt(uv + ts * float2(1.0, 0.0)) * 2.0;\n"
    "    col += srcAt(uv + ts * float2(-1.0, 1.0));\n"
    "    col += srcAt(uv + ts * float2(0.0, 1.0)) * 2.0;\n"
    "    col += srcAt(uv + ts * float2(1.0, 1.0));\n"
    "    return float4(col * (1.0 / 16.0), 1.0);\n"
    "}\n",
};

