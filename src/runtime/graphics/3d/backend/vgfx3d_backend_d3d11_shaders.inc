    "    float3 nrm = applyMorphNormal(input.normal, vid, 0);\n"
    "    float4 tan = input.tangent;\n"
    "    float4 skinnedPos = skinPosition(float4(pos, 1.0), input.boneIdx, input.boneWt, 0);\n"
    "    float4 prevSkinnedPos = skinPosition(float4(prevPos, 1.0), input.boneIdx, input.boneWt, "
    "1);\n"
    "    float3 skinnedNormal = safeNormalize3(skinVector(nrm, input.boneIdx, input.boneWt), "
    "float3(0.0, 1.0, 0.0));\n"
    "    float3 skinnedTangent = safeNormalize3(skinVector(tan.xyz, input.boneIdx, input.boneWt), "
    "float3(1.0, 0.0, 0.0));\n"
    "    if (hasSkinning == 0) {\n"
    "        skinnedPos = float4(pos, 1.0);\n"
    "        skinnedNormal = safeNormalize3(nrm, float3(0.0, 1.0, 0.0));\n"
    "        skinnedTangent = safeNormalize3(tan.xyz, float3(1.0, 0.0, 0.0));\n"
    "    }\n"
    "    if (hasPrevSkinning == 0)\n"
    "        prevSkinnedPos = float4(prevPos, 1.0);\n"
    "    return buildOutput(skinnedPos.xyz,\n"
    "                       prevSkinnedPos.xyz,\n"
    "                       skinnedNormal,\n"
    "                       float4(skinnedTangent, tan.w),\n"
    "                       input.uv,\n"
    "                       input.uv1,\n"
    "                       input.color,\n"
    "                       instModel,\n"
    "                       instNormal,\n"
    "                       hasPrevInstanceMatrices != 0 ? prevModel : instModel,\n"
    "                       (hasPrevInstanceMatrices != 0 || hasPrevSkinning != 0 || "
    "hasPrevMorphWeights != 0) ? 1.0 : 0.0);\n"
    "}\n"
    "\n"
    "int resolveShadowCascade(Light light, float3 worldPos) {\n"
    "    int shadowIndex = light.shadowIndex;\n"
    "    if (shadowIndex >= 0 && light.shadowProjectionType == 2) {\n"
    "        float3 d = worldPos - light.position.xyz;\n"
    "        float3 a = abs(d);\n"
    "        int face = (a.x >= a.y && a.x >= a.z) ? (d.x >= 0.0 ? 0 : 1)\n"
    "                   : (a.y >= a.z ? (d.y >= 0.0 ? 2 : 3) : (d.z >= 0.0 ? 4 : 5));\n"
    "        shadowIndex += face;\n"
    "    }\n"
    "    if (shadowIndex < 0 || shadowIndex >= shadowCount)\n"
    "        return -1;\n"
    "    int cascadeCount = clamp(light.shadowCascadeCount, 1, ",
    VGFX3D_STR(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       VGFX3D_MAX_SHADOW_LIGHTS)
    ");\n"
    "    cascadeCount = min(cascadeCount, shadowCount - shadowIndex);\n"
    "    if (cascadeCount <= 1)\n"
    "        return shadowIndex;\n"
    "    float viewDepth = dot(worldPos - cameraPosition.xyz, cameraForward.xyz);\n"
    "    if (viewDepth <= light.shadowCascadeSplits.x || cascadeCount == 1)\n"
    "        return shadowIndex;\n"
    "    if (viewDepth <= light.shadowCascadeSplits.y || cascadeCount == 2)\n"
    "        return shadowIndex + 1;\n"
    "    if (viewDepth <= light.shadowCascadeSplits.z || cascadeCount == 3)\n"
    "        return shadowIndex + 2;\n"
    "    return shadowIndex + 3;\n"
    "}\n"
    "\n"
    "float sampleShadowAt(int shadowIndex, float2 uv, float depth, float bias) {\n"
    "    if (shadowIndex >= 4) {\n"
    "        int tile = shadowIndex - 4;\n"
    "        float2 auv = float2(float(tile % 4) * 0.25, float(tile / 4) * 0.5) +\n"
    "                     clamp(uv, 0.0, 1.0) * float2(0.25, 0.5);\n"
    "        return shadowAtlas.SampleCmpLevelZero(shadowSampler, auv, depth - bias);\n"
    "    }\n"
    "    if (shadowIndex == 0)\n"
    "        return shadowTex0.SampleCmpLevelZero(shadowSampler, uv, depth - bias);\n"
    "    if (shadowIndex == 1)\n"
    "        return shadowTex1.SampleCmpLevelZero(shadowSampler, uv, depth - bias);\n"
    "    if (shadowIndex == 2)\n"
    "        return shadowTex2.SampleCmpLevelZero(shadowSampler, uv, depth - bias);\n"
    "    return shadowTex3.SampleCmpLevelZero(shadowSampler, uv, depth - bias);\n"
    "}\n"
    "\n"
    /* Plan 06: 16-point Poisson disk, deterministic dart-throwing (64-bit LCG,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * seed 80, min separation 0.4369) — matches the GLSL/MSL twins. Tap subsets
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * stride the table so 4/8-tap tiers stay well-distributed. */
    "static const float2 kShadowPoisson[16] = {\n"
    "    float2(0.482408, 0.345286), float2(0.079872, 0.641222),\n"
    "    float2(-0.211339, -0.305133), float2(0.485624, -0.638176),\n"
    "    float2(-0.197270, 0.252333), float2(-0.823845, 0.551135),\n"
    "    float2(-0.333578, 0.886038), float2(0.835697, 0.028104),\n"
    "    float2(-0.921729, -0.289255), float2(-0.184344, -0.769094),\n"
    "    float2(0.449912, -0.195238), float2(0.534685, 0.795828),\n"
    "    float2(-0.661694, -0.644587), float2(-0.599728, 0.062200),\n"
    "    float2(0.899330, -0.413558), float2(0.200012, -0.976846)};\n"
    "\n"
    /* Plan 06 sampling model: normal-offset the receiver ~1.5 shadow texels
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * (world units, ortho slots; derived from the shadow VP row lengths so far
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * cascades offset proportionally), add a slope-proportional per-texel
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * compare bias, and filter with a rotated-Poisson PCF over the hardware
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * comparison sampler. shadowFilter carries the knobs (x = slope-bias
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  * factor, y = strength, z = tap count). */
    "float sampleShadowCascade(Light light, int shadowIndex, float3 worldPos,\n"
    "                          float3 N, float3 L, float2 fragXY) {\n"
    "    row_major float4x4 shadowMatrix = shadowVP[shadowIndex];\n"
    "    float2 mapSize;\n"
    "    if (shadowIndex >= 4) {\n"
    "        shadowAtlas.GetDimensions(mapSize.x, mapSize.y);\n"
    "        mapSize *= float2(0.25, 0.5);\n"
    "    }\n"
    "    else if (shadowIndex == 0) shadowTex0.GetDimensions(mapSize.x, mapSize.y);\n"
    "    else if (shadowIndex == 1) shadowTex1.GetDimensions(mapSize.x, mapSize.y);\n",
    "    else if (shadowIndex == 2) shadowTex2.GetDimensions(mapSize.x, mapSize.y);\n"
    "    else shadowTex3.GetDimensions(mapSize.x, mapSize.y);\n"
    "    float2 texel = 1.0 / max(mapSize, float2(1.0, 1.0));\n"
    "    float texelWorld = 0.0;\n"
    "    float depthScale = 0.0;\n"
    "    if (light.shadowProjectionType == 0) {\n"
    "        float3 row0 = float3(shadowMatrix[0][0], shadowMatrix[0][1], shadowMatrix[0][2]);\n"
    "        float3 row2 = float3(shadowMatrix[2][0], shadowMatrix[2][1], shadowMatrix[2][2]);\n"
    "        float l0 = length(row0);\n"
    "        float l2 = length(row2);\n"
    "        texelWorld = (l0 > 1e-9) ? 2.0 * texel.x / l0 : 0.0;\n"
    "        depthScale = 0.5 * l2;\n"
    "    }\n"
    "    float3 samplePos = worldPos + N * (texelWorld * 1.5);\n"
    "    float4 lc = mul(shadowMatrix, float4(samplePos, 1.0));\n"
    "    if (light.shadowProjectionType != 0 && lc.w <= 0.0001)\n"
    "        return 1.0;\n"
    "    float3 ndc = light.shadowProjectionType != 0 ? lc.xyz / max(lc.w, 0.0001) : lc.xyz;\n"
    "    float2 uv = ndcToTextureUv(ndc.xy);\n"
    "    float depth = ndc.z * 0.5 + 0.5;\n"
    "    if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0 || depth < 0.0 || depth > 1.0)\n"
    "        return 1.0;\n"
    "    float ndl = clamp(dot(N, L), 0.05, 1.0);\n"
    "    float slope = sqrt(max(1.0 - ndl * ndl, 0.0)) / ndl;\n"
    "    float bias = shadowBias + shadowFilter.x * min(slope, 8.0) * texelWorld * depthScale;\n"
    "    float ign = frac(52.9829189 * frac(0.06711056 * fragXY.x + 0.00583715 * fragXY.y));\n"
    "    float ca = cos(6.2831853 * ign);\n"
    "    float sa = sin(6.2831853 * ign);\n"
    "    int taps = clamp((int)shadowFilter.z, 4, 16);\n"
    "    int stride = 16 / taps;\n"
    "    float lit = 0.0;\n"
    "    for (int i = 0; i < taps; i++) {\n"
    "        float2 p = kShadowPoisson[i * stride];\n"
    "        float2 o = float2(p.x * ca - p.y * sa, p.x * sa + p.y * ca) * texel * 1.5;\n"
    "        float s = sampleShadowAt(shadowIndex, uv + o, depth, bias);\n"
    "        lit += (s == s) ? saturate(s) : 1.0;\n"
    "    }\n"
    "    return lit / (float)taps;\n"
    "}\n"
    "\n"
    /* Cascade blend band + distance fade: hard cascade cuts pop visibly as the
     * camera moves, so the last ~12% of each cascade cross-fades into the next,
     * and directional shadows fade out approaching the capped shadow distance
     * instead of ending on a hard line. Mirrors the MSL/GLSL twins. */
    "float sampleShadow(Light light, float3 worldPos, float3 N, float3 L, float2 fragXY) {\n"
    "    int shadowIndex = resolveShadowCascade(light, worldPos);\n"
    "    if (shadowIndex < 0 || shadowIndex >= shadowCount)\n"
    "        return 1.0;\n"
    "    float lit = sampleShadowCascade(light, shadowIndex, worldPos, N, L, fragXY);\n"
    "    int cascadeCount = clamp(light.shadowCascadeCount, 1, ",
    VGFX3D_STR(VGFX3D_MAX_SHADOW_LIGHTS)
    ");\n"
    "    cascadeCount = min(cascadeCount, shadowCount - light.shadowIndex);\n"
    "    if (light.shadowProjectionType == 0 && cascadeCount > 1 &&\n"
    "        shadowIndex >= light.shadowIndex) {\n"
    "        int cascade = shadowIndex - light.shadowIndex;\n"
    "        float viewDepth = dot(worldPos - cameraPosition.xyz, cameraForward.xyz);\n"
    "        float splitFar = light.shadowCascadeSplits[cascade];\n"
    "        float splitNear = cascade > 0 ? light.shadowCascadeSplits[cascade - 1] : 0.0;\n"
    "        float band = max(0.5, 0.12 * (splitFar - splitNear));\n"
    "        if (cascade < cascadeCount - 1) {\n"
    "            float blend = saturate((viewDepth - (splitFar - band)) / band);\n"
    "            if (blend > 0.0) {\n"
    "                float litNext = sampleShadowCascade(light, shadowIndex + 1,\n"
    "                                                    worldPos, N, L, fragXY);\n"
    "                lit = lerp(lit, litNext, blend);\n"
    "            }\n"
    "        } else {\n"
    "            float shadowFar = light.shadowCascadeSplits[cascadeCount - 1];\n"
    "            float fadeBand = max(2.0, 0.10 * shadowFar);\n"
    "            float fade = saturate((shadowFar - viewDepth) / fadeBand);\n"
    "            lit = lerp(1.0, lit, fade);\n"
    "        }\n"
    "    }\n"
    "    return lit;\n"
    "}\n"
    "\n"
    "float distributionGGX(float NdotH, float roughness) {\n"
    "    float a = roughness * roughness;\n"
    "    float a2 = a * a;\n"
    "    float denom = NdotH * NdotH * (a2 - 1.0) + 1.0;\n"
    "    return a2 / (3.14159265 * denom * denom + 1e-6);\n"
    "}\n"
    "\n"
    "float geometrySchlickGGX(float NdotV, float roughness) {\n"
    "    float r = roughness + 1.0;\n"
    "    float k = (r * r) / 8.0;\n"
    "    return NdotV / (NdotV * (1.0 - k) + k + 1e-6);\n"
    "}\n"
    "\n"
    "float geometrySmith(float NdotV, float NdotL, float roughness) {\n"
    "    return geometrySchlickGGX(NdotV, roughness) * geometrySchlickGGX(NdotL, roughness);\n"
    "}\n"
    "\n"
    "float3 fresnelSchlick(float cosTheta, float3 F0) {\n"
    "    return F0 + (1.0 - F0) * pow(saturate(1.0 - cosTheta), 5.0);\n"
    "}\n"
    "\n"
    "float3 srgbToLinear(float3 c) {\n"
    "    float3 low = c / 12.92;\n"
    "    float3 high = pow((c + 0.055) / 1.055, float3(2.4, 2.4, 2.4));\n"
    "    return lerp(low, high, step(float3(0.04045, 0.04045, 0.04045), c));\n"
    "}\n"
    "\n"
    "float3 fresnelSchlickRoughness(float cosTheta, float3 F0, float roughness) {\n"
    "    return F0 + (max(float3(1.0 - roughness, 1.0 - roughness, 1.0 - roughness), F0) - F0)\n"
    "        * pow(saturate(1.0 - cosTheta), 5.0);\n"
    "}\n"
    "\n",
    "float2 envBRDFApprox(float roughness, float NdotV) {\n"
    "    float4 c0 = float4(-1.0, -0.0275, -0.572, 0.022);\n"
    "    float4 c1 = float4(1.0, 0.0425, 1.04, -0.04);\n"
    "    float4 r = roughness * c0 + c1;\n"
    "    float a004 = min(r.x * r.x, exp2(-9.28 * NdotV)) * r.x + r.y;\n"
    "    return float2(-1.04, 1.04) * a004 + r.zw;\n"
    "}\n"
    "\n"
    "float3 evalSH9(float3 n) {\n"
    "    float3 irr = shIrradiance[0].rgb * 0.282095\n"
    "        + shIrradiance[1].rgb * (0.488603 * n.y)\n"
    "        + shIrradiance[2].rgb * (0.488603 * n.z)\n"
    "        + shIrradiance[3].rgb * (0.488603 * n.x)\n"
    "        + shIrradiance[4].rgb * (1.092548 * n.x * n.y)\n"
    "        + shIrradiance[5].rgb * (1.092548 * n.y * n.z)\n"
    "        + shIrradiance[6].rgb * (0.315392 * (3.0 * n.z * n.z - 1.0))\n"
    "        + shIrradiance[7].rgb * (1.092548 * n.x * n.z)\n"
    "        + shIrradiance[8].rgb * (0.546274 * (n.x * n.x - n.y * n.y));\n"
    "    return max(irr, float3(0.0, 0.0, 0.0));\n"
    "}\n"
    "\n"
    "PS_OUTPUT PSMain(PS_INPUT input) {\n"
    "    PS_OUTPUT output;\n"
    "    float3 baseColor = diffuseColor.rgb * input.color.rgb;\n"
    "    float texAlpha = 1.0;\n"
    "    float materialAlpha = diffuseColor.a * scalars.x * input.color.a;\n"
    "    if (flags0.x != 0) {\n"
    "        float4 texSample = diffuseTex.Sample(diffuseSampler, materialUv(input, 0));\n"
    "        if (pbrFlags.x != 0) texSample.rgb = srgbToLinear(texSample.rgb);\n"
    "        baseColor *= texSample.rgb;\n"
    "        texAlpha = texSample.a;\n"
    "    }\n"
    "    if (flags1.z != 0) {\n"
    "        float4 sp = splatTex.Sample(diffuseSampler, input.uv);\n"
    "        float sum = sp.r + sp.g + sp.b + sp.a;\n"
    "        if (sum > 0.0001) {\n"
    "            sp /= sum;\n"
    "            float3 splatColor = splatLayer0.Sample(diffuseSampler, input.uv * splatScales.x).rgb "
    "* sp.r +\n"
    "                                splatLayer1.Sample(diffuseSampler, input.uv * splatScales.y).rgb "
    "* sp.g +\n"
    "                                splatLayer2.Sample(diffuseSampler, input.uv * splatScales.z).rgb "
    "* sp.b +\n"
    "                                splatLayer3.Sample(diffuseSampler, input.uv * splatScales.w).rgb "
    "* sp.a;\n"
    "            baseColor = splatColor * diffuseColor.rgb * input.color.rgb;\n"
    "        }\n"
    "    }\n"
    "    float3 N = safeNormalize3(input.normal, float3(0.0, 1.0, 0.0));\n"
    "    if (flags0.z != 0) {\n"
    "        float3 mapN = normalTex.Sample(normalSampler, materialUv(input, 1)).xyz * 2.0 - 1.0;\n"
    "        mapN.xy *= pbrScalars1.x;\n"
    "        float3 tangentProjected = input.tangent.xyz - N * dot(input.tangent.xyz, N);\n"
    "        float tangentLengthSq = dot(tangentProjected, tangentProjected);\n"
    "        if (tangentLengthSq > 0.0001 && tangentLengthSq < 1e20) {\n"
    "            float3 T = tangentProjected * rsqrt(tangentLengthSq);\n"
    "            float3 B = safeNormalize3(cross(N, T), float3(0.0, 0.0, 1.0)) * "
    "(input.tangent.w < 0.0 ? -1.0 : 1.0);\n"
    "            N = safeNormalize3(mapN.x * T + mapN.y * B + mapN.z * N, N);\n"
    "        }\n"
    "    }\n"
    "    float3 safeCameraForward = safeNormalize3(cameraForward, float3(0.0, 0.0, -1.0));\n"
    "    float3 cameraToWorld = cameraPosition.xyz - input.worldPos;\n"
    "    float3 V = cameraPosition.w > 0.5 ? -safeCameraForward : "
    "safeNormalize3(cameraToWorld, -safeCameraForward);\n"
    "    float viewDistance = cameraPosition.w > 0.5\n"
    "        ? abs(dot(input.worldPos - cameraPosition.xyz, safeCameraForward))\n",
    "        : length(cameraToWorld);\n"
    "    float3 emissive = emissiveColor.rgb * pbrScalars0.w;\n"
    "    if (flags1.x != 0) {\n"
    "        float3 emissiveSample = emissiveTex.Sample(emissiveSampler, materialUv(input, 3)).rgb;\n"
    "        if (pbrFlags.x != 0) emissiveSample = srgbToLinear(emissiveSample);\n"
    "        emissive *= emissiveSample;\n"
    "    }\n"
    "    float finalAlpha = materialAlpha * texAlpha;\n"
    "    if (pbrFlags.y != 0 && pbrFlags.y != 1 && pbrScalars1.z > 0.0 &&\n"
    "        clusterParams.z > 0.0 && clusterParams.w > clusterParams.z) {\n"
    "        float zn = clusterParams.z;\n"
    "        float zf = clusterParams.w;\n"
    /* Reversed-Z: the analytic linearization below expects standard window depth,
     * so flip the reversed buffer/fragment values (d_std = 1 - d_rev) first. */
    "        float sceneD = 1.0 - opaqueDepthTex.Load(int3(int2(input.pos.xy), 0));\n"
    "        float fragD = 1.0 - input.pos.z;\n"
    "        float linScene;\n"
    "        float linFrag;\n"
    "        if (cameraPosition.w > 0.5) {\n"
    "            linScene = zn + sceneD * (zf - zn);\n"
    "            linFrag = zn + fragD * (zf - zn);\n"
    "        } else {\n"
    "            linScene = (2.0 * zn * zf) / (zf + zn - (2.0 * sceneD - 1.0) * (zf - zn));\n"
    "            linFrag = (2.0 * zn * zf) / (zf + zn - (2.0 * fragD - 1.0) * (zf - zn));\n"
    "        }\n"
    "        finalAlpha *= saturate((linScene - linFrag) / pbrScalars1.z);\n"
    "    }\n"
    "    if (pbrFlags.y == 1) {\n"
    "        if (finalAlpha < pbrScalars1.y)\n"
    "            discard;\n"
    "        finalAlpha = 1.0;\n"
    "    } else if (pbrFlags.y == 0) {\n"
    "        finalAlpha = 1.0;\n"
    "    }\n"
    "    float envRoughness = saturate(pbrScalars0.y);\n"
    "    float3 result = ambientColor.rgb * baseColor;\n"
    "    if (flags0.y != 0) {\n"
    "        result = baseColor;\n"
    "    } else {\n"
    "        if (pbrFlags.x != 0) {\n"
    "            float metallic = saturate(pbrScalars0.x);\n"
    "            float roughness = clamp(pbrScalars0.y, 0.045, 1.0);\n"
    "            float ao = saturate(pbrScalars0.z);\n"
    "            if (pbrFlags.z != 0) {\n"
    "                float4 mr = metallicRoughnessTex.Sample(metallicRoughnessSampler, materialUv(input, 4));\n"
    "                roughness = clamp(roughness * mr.g, 0.045, 1.0);\n"
    "                metallic = saturate(metallic * mr.b);\n"
    "                envRoughness = roughness;\n"
    "            }\n"
    "            if (pbrFlags.w != 0) {\n"
    "                float4 aoSample = aoTex.Sample(aoSampler, materialUv(input, 5));\n"
    "                ao = saturate(ao * aoSample.r);\n"
    "            }\n"
    "            if (flags1.w != 0) {\n"
    "                float NdotVa = max(dot(N, V), 0.001);\n"
    "                float3 F0a = lerp(float3(0.04, 0.04, 0.04), baseColor, metallic);\n"
    "                float3 Fa = fresnelSchlickRoughness(NdotVa, F0a, roughness);\n"
    "                float3 kDa = (1.0 - Fa) * (1.0 - metallic);\n"
    "                float3 irradiance = evalSH9(N);\n"
    "                float3 Ra = reflect(-V, N);\n"
    "                float iblLod = scalars.w + saturate(roughness) * max(scalars.z, 0.0);\n"
    "                float3 prefiltered = envTex.SampleLevel(envSampler, Ra, iblLod).rgb;\n"
    "                float2 envAB = envBRDFApprox(roughness, NdotVa);\n"
    "                result = (kDa * irradiance * baseColor + prefiltered * (F0a * envAB.x + envAB.y)) * ao * iblIntensity;\n"
    "            } else {\n",
    "                result = ambientColor.rgb * baseColor * ao;\n"
    "            }\n"
    "            int lightLoopCount = lightCount;\n"
    "            int clusterStart = 0;\n"
    "            if (clusterGlobalCount >= 0) {\n"
    "                int cidx = clusterFragmentIndex(input.pos.xy, input.worldPos);\n"
    "                clusterStart = clamp(int(clusterOffsetAt(cidx)), 0, "
    VGFX3D_STR(VGFX3D_MAX_CLUSTER_LIGHT_INDICES)
    ");\n"
    "                int clusterEnd = clamp(int(clusterOffsetAt(cidx + 1)), clusterStart, "
    VGFX3D_STR(VGFX3D_MAX_CLUSTER_LIGHT_INDICES)
    ");\n"
    "                lightLoopCount = min(lightCount, clusterGlobalCount + clusterEnd - "
    "clusterStart);\n"
    "            }\n"
    "            for (int k = 0; k < lightLoopCount; k++) {\n"
    "                int i = (clusterGlobalCount < 0 || k < clusterGlobalCount)\n"
    "                            ? k\n"
    "                            : int(clusterIndexAt(clusterStart + (k - clusterGlobalCount)));\n"
    "                if (i < 0 || i >= lightCount)\n"
    "                    continue;\n"
    "                float3 L = float3(0.0, 0.0, 0.0);\n"
    "                float atten = 1.0;\n"
    "                if (lights[i].type == 0) {\n"
