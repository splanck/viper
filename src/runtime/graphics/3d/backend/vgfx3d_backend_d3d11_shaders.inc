                                                                                                                                                                                                                                                                                                                                                                                                "                                         input.instanceNormal2,\n"
                                                                                                                                                                                                                                                                                                                                                                                                "                                         input.instanceNormal3);\n"
                                                                                                                                                                                                                                                                                                                                                                                                "    float4x4 prevModel = makeMatrixRows(input.prevModel0,\n"
                                                                                                                                                                                                                                                                                                                                                                                                "                                        input.prevModel1,\n"
                                                                                                                                                                                                                                                                                                                                                                                                "                                        input.prevModel2,\n"
                                                                                                                                                                                                                                                                                                                                                                                                "                                        input.prevModel3);\n"
