#pragma once

// Shared request/response helpers used by both the plain HTTP and TLS-backed
// HTTP servers. This include is pulled in after the local server_req_t /
// server_res_t / chunk_parse_status_t definitions in each translation unit.

/**
 * @brief Locate the next HTTP line terminator within a length-bounded buffer.
 *
 * @details The scan does not require the input to be NUL-terminated and returns
 * a pointer to the `\r` byte of the first `\r\n` sequence. Callers use this
 * helper while parsing request lines, headers, and chunk extensions received
 * from sockets.
 *
 * @param buf Buffer to scan.
 * @param len Number of bytes available at @p buf.
 * @return Pointer to the first CRLF sequence, or NULL when none is present.
 */
static const char *find_crlf(const char *buf, size_t len) {
    if (len < 2)
        return NULL;
    for (size_t i = 0; i + 1 < len; i++) {
        if (buf[i] == '\r' && buf[i + 1] == '\n')
            return buf + i;
    }
    return NULL;
}

/**
 * @brief Locate the end of an HTTP request header section.
 *
 * @details The return value points one byte past the terminating `\r\n\r\n`
 * sequence, matching the start of the optional message body. The input can be
 * an arbitrary socket buffer and is therefore scanned by explicit length.
 *
 * @param buf Buffer containing partial or complete HTTP request bytes.
 * @param len Number of bytes available at @p buf.
 * @return Pointer to the body start, or NULL when the header terminator is not
 *         present.
 */
static const char *find_header_end(const char *buf, size_t len) {
    if (len < 4)
        return NULL;
    for (size_t i = 3; i < len; i++) {
        if (buf[i - 3] == '\r' && buf[i - 2] == '\n' && buf[i - 1] == '\r' && buf[i] == '\n')
            return buf + i + 1;
    }
    return NULL;
}

/**
 * @brief Find a byte in a length-bounded buffer.
 *
 * @details This local helper keeps request-target and header parsing free from
 * NUL-termination assumptions. It is equivalent to a typed `memchr` wrapper but
 * returns a const char pointer for parser arithmetic.
 *
 * @param buf Buffer to scan.
 * @param len Number of bytes available at @p buf.
 * @param needle Byte value to find.
 * @return Pointer to the first matching byte, or NULL when absent.
 */
static const char *find_char_bounded(const char *buf, size_t len, char needle) {
    for (size_t i = 0; i < len; i++) {
        if (buf[i] == needle)
            return buf + i;
    }
    return NULL;
}

/**
 * @brief Detect whether a NUL-terminated string contains CR or LF bytes.
 *
 * @details Header names and values generated by handlers must not inject
 * additional response lines. This helper centralizes the check used before
 * formatting outbound headers.
 *
 * @param text NUL-terminated text to validate.
 * @return Nonzero when @p text contains `\r` or `\n`; zero otherwise.
 */
#if defined(__GNUC__) || defined(__clang__)
#define HTTP_SERVER_SHARED_MAYBE_UNUSED __attribute__((unused))
#else
#define HTTP_SERVER_SHARED_MAYBE_UNUSED
#endif

static int HTTP_SERVER_SHARED_MAYBE_UNUSED contains_crlf(const char *text) {
    if (!text)
        return 0;
    for (; *text; text++) {
        if (*text == '\r' || *text == '\n')
            return 1;
    }
    return 0;
}

/**
 * @brief Test whether a byte is valid in an HTTP token.
 *
 * @details The predicate implements the RFC token character exclusions needed
 * for request methods and header field names: control bytes, spaces, DEL, and
 * separator punctuation are rejected.
 *
 * @param c Byte to classify.
 * @return Nonzero when @p c is accepted as an HTTP token character.
 */
static int http_token_char(unsigned char c) {
    if (c <= 0x20 || c >= 0x7f)
        return 0;
    switch (c) {
        case '(':
        case ')':
        case '<':
        case '>':
        case '@':
        case ',':
        case ';':
        case ':':
        case '\\':
        case '"':
        case '/':
        case '[':
        case ']':
        case '?':
        case '=':
        case '{':
        case '}':
            return 0;
        default:
            return 1;
    }
}

/**
 * @brief Validate a length-bounded HTTP method token.
 *
 * @details Methods must be non-empty HTTP tokens. The parser keeps the method
 * length separately from the buffer so invalid embedded NUL bytes are rejected
 * by the token predicate instead of truncating validation.
 *
 * @param method Pointer to the method bytes from the request line.
 * @param method_len Number of method bytes.
 * @return true when the method is syntactically valid.
 */
static bool http_method_is_valid(const char *method, size_t method_len) {
    if (!method || method_len == 0)
        return false;
    for (size_t i = 0; i < method_len; i++) {
        if (!http_token_char((unsigned char)method[i]))
            return false;
    }
    return true;
}

/**
 * @brief Validate raw request-target bytes before URI normalization.
 *
 * @details Zanna routes operate on origin-form paths or normalized absolute
 * URIs. This check rejects empty targets, whitespace/control bytes, DEL, and
 * fragments so downstream route matching receives only request-target forms
 * that the server intentionally supports.
 *
 * @param target Pointer to request-target bytes.
 * @param target_len Number of target bytes.
 * @return true when the raw target can be normalized.
 */
static bool http_request_target_bytes_are_valid(const char *target, size_t target_len) {
    if (!target || target_len == 0)
        return false;
    for (size_t i = 0; i < target_len; i++) {
        unsigned char c = (unsigned char)target[i];
        if (c <= 0x20 || c == 0x7f || c == '#')
            return false;
    }
    return true;
}

/**
 * @brief Normalize a request-target into request path and query strings.
 *
 * @details Supports origin-form targets, absolute `http://` and `https://`
 * targets, and the `*` target used by OPTIONS. Query text is copied without the
 * leading question mark. Ownership of allocated `path` and `query` strings is
 * transferred to @p req and released by the request cleanup path.
 *
 * @param req Request object whose `path` and optional `query` fields are set.
 * @param uri Raw request-target bytes from the request line.
 * @param uri_len Number of bytes in @p uri.
 * @return true when the target was accepted and copied into @p req.
 */
static bool set_request_target(server_req_t *req, const char *uri, size_t uri_len) {
    const char *target = uri;
    size_t target_len = uri_len;
    const char *qmark = NULL;
    size_t path_len = 0;

    if (!req || !http_request_target_bytes_are_valid(uri, uri_len))
        return false;

    if (uri_len == 1 && uri[0] == '*') {
        req->path = strdup("*");
        return req->path != NULL;
    }

    if (uri[0] == '/') {
        target = uri;
        target_len = uri_len;
    } else if ((uri_len >= 7 && strncasecmp(uri, "http://", 7) == 0) ||
               (uri_len >= 8 && strncasecmp(uri, "https://", 8) == 0)) {
        const char *authority = uri + (strncasecmp(uri, "https://", 8) == 0 ? 8 : 7);
        const char *end = uri + uri_len;
        const char *slash = find_char_bounded(authority, (size_t)(end - authority), '/');
        const char *query = find_char_bounded(authority, (size_t)(end - authority), '?');
        const char *host_end = slash ? slash : (query ? query : end);
        if (host_end == authority)
            return false;
        if (slash) {
            target = slash;
            target_len = (size_t)(end - slash);
        } else if (query) {
            target = query;
            target_len = (size_t)(end - query);
        } else {
            req->path = strdup("/");
            return req->path != NULL;
        }
    } else {
        return false;
    }

    qmark = find_char_bounded(target, target_len, '?');
    if (qmark) {
        path_len = (size_t)(qmark - target);
        req->query = (char *)malloc(target_len - path_len);
        if (!req->query)
            return false;
        memcpy(req->query, qmark + 1, target_len - path_len - 1);
        req->query[target_len - path_len - 1] = '\0';
    } else {
        path_len = target_len;
    }

    if (path_len == 0) {
        if (target[0] != '?')
            return false;
        req->path = strdup("/");
        return req->path != NULL;
    }

    req->path = (char *)malloc(path_len + 1);
    if (!req->path)
        return false;
    memcpy(req->path, target, path_len);
    req->path[path_len] = '\0';
    return true;
}

/**
 * @brief Test whether a response header name is controlled by the server core.
 *
 * @details Handler-provided values for framing headers are ignored because the
 * server computes content length, connection policy, and transfer encoding when
 * formatting the final response.
 *
 * @param name NUL-terminated header name.
 * @return Nonzero when the header should not be copied from handler output.
 */
static int is_server_managed_header_name(const char *name) {
    return name &&
           (strcasecmp(name, "Content-Length") == 0 || strcasecmp(name, "Connection") == 0 ||
            strcasecmp(name, "Transfer-Encoding") == 0);
}

/// @brief Validate a handler-supplied response header field name.
/// @details HTTP header names use the same token grammar as request methods.
///          The runtime validates against the explicit byte length so embedded
///          NULs cannot truncate validation; callers still perform their own
///          runtime-string NUL checks before reaching this helper.
/// @param name Header name bytes.
/// @param len Number of bytes in @p name.
/// @return Nonzero when every byte is a valid HTTP token character.
static int HTTP_SERVER_SHARED_MAYBE_UNUSED server_header_name_valid(const char *name, size_t len) {
    if (!name || len == 0)
        return 0;
    for (size_t i = 0; i < len; i++) {
        if (!http_token_char((unsigned char)name[i]))
            return 0;
    }
    return 1;
}

/// @brief Compute the byte length of a JSON-escaped C string.
/// @details Counts quote, reverse-solidus, short control escapes, and
///          `\u00XX` escapes for other C0 controls without writing output.
///          Returning @c SIZE_MAX signals that the escaped representation would
///          overflow @c size_t.
/// @param s Source string; NULL is treated as an empty string.
/// @return Escaped byte length excluding the terminating NUL, or @c SIZE_MAX.
static size_t json_escaped_len(const char *s) {
    size_t n = 0;
    if (!s)
        return 0;
    while (*s) {
        unsigned char c = (unsigned char)*s++;
        switch (c) {
            case '"':
            case '\\':
            case '\b':
            case '\f':
            case '\n':
            case '\r':
            case '\t':
                if (n > SIZE_MAX - 2)
                    return SIZE_MAX;
                n += 2;
                break;
            default:
                if (c < 0x20) {
                    if (n > SIZE_MAX - 6)
                        return SIZE_MAX;
                    n += 6;
                } else {
                    if (n == SIZE_MAX)
                        return SIZE_MAX;
                    n++;
                }
                break;
        }
    }
    return n;
}

/// @brief Copy a C string into an already-sized JSON string buffer.
/// @details Escapes characters exactly as counted by @ref json_escaped_len and
///          always writes a trailing NUL. The destination must provide
///          `json_escaped_len(s) + 1` bytes.
/// @param out Destination buffer.
/// @param s Source string; NULL is encoded as an empty string.
static void json_escape_into(char *out, const char *s) {
    static const char hex[] = "0123456789abcdef";
    if (!out)
        return;
    if (!s) {
        *out = '\0';
        return;
    }
    while (*s) {
        unsigned char c = (unsigned char)*s++;
        switch (c) {
            case '"':
                *out++ = '\\';
                *out++ = '"';
                break;
            case '\\':
                *out++ = '\\';
                *out++ = '\\';
                break;
            case '\b':
                *out++ = '\\';
                *out++ = 'b';
                break;
            case '\f':
                *out++ = '\\';
                *out++ = 'f';
                break;
            case '\n':
                *out++ = '\\';
                *out++ = 'n';
                break;
            case '\r':
                *out++ = '\\';
                *out++ = 'r';
                break;
            case '\t':
                *out++ = '\\';
                *out++ = 't';
                break;
            default:
                if (c < 0x20) {
                    *out++ = '\\';
                    *out++ = 'u';
                    *out++ = '0';
                    *out++ = '0';
                    *out++ = hex[(c >> 4) & 0x0F];
                    *out++ = hex[c & 0x0F];
                } else {
                    *out++ = (char)c;
                }
                break;
        }
    }
    *out = '\0';
}

/// @brief Replace the response body with a JSON error object.
///
/// Used when route lookup fails or a handler binding is missing so both the
/// plain HTTP and TLS-backed servers return the same structured error payload.
/// The body is `{"error":"<message>"}`; the `Content-Type` header is set to
/// `application/json`, creating the response header map if needed.
///
/// Idempotent: clears any pre-existing response body before writing the new
/// body. The status and `sent` marker are published first, so a caller that
/// recovers an allocation trap can still serialize a valid status-only
/// response rather than accidentally returning the previous success payload.
///
/// @param res         Response struct to overwrite.
/// @param status_code HTTP status code to set.
/// @param message     Human-readable error text embedded into the JSON body.
static void set_json_error_response(server_res_t *res, int status_code, const char *message) {
    if (!res)
        return;

    char *old_body = res->body;
    res->status_code = status_code;
    res->body = NULL;
    res->body_len = 0;
    res->sent = true;
    free(old_body);

    size_t escaped_len = message ? json_escaped_len(message) : 0;
    if (escaped_len == SIZE_MAX || escaped_len > SIZE_MAX - 13)
        return;

    char *volatile replacement = NULL;
    void *volatile headers = res->headers;
    rt_string volatile ct_key = NULL;
    rt_string volatile ct_val = NULL;
    volatile int created_headers = 0;
    jmp_buf recovery;
    rt_trap_set_recovery(&recovery);
    if (setjmp(recovery) != 0) {
        char saved_error[256];
        const char *error = rt_trap_get_error();
        snprintf(saved_error,
                 sizeof(saved_error),
                 "%s",
                 error && error[0] ? error : "HttpServer: JSON error allocation failed");
        rt_trap_clear_recovery();
        rt_string_unref((rt_string)ct_val);
        rt_string_unref((rt_string)ct_key);
        if (created_headers && headers && rt_obj_release_check0((void *)headers))
            rt_obj_free((void *)headers);
        free((void *)replacement);
        rt_trap(saved_error);
        return;
    }

    size_t replacement_len = 0;
    if (message) {
        replacement = (char *)malloc(escaped_len + 13);
        if (!replacement) {
            rt_trap_clear_recovery();
            return;
        }
        memcpy((void *)replacement, "{\"error\":\"", 10);
        json_escape_into((char *)replacement + 10, message);
        memcpy((char *)replacement + 10 + escaped_len, "\"}", 3);
        replacement_len = 12 + escaped_len;
    }

    if (!headers) {
        headers = rt_map_new();
        if (!headers) {
            rt_trap_clear_recovery();
            free((void *)replacement);
            return;
        }
        created_headers = 1;
    }

    ct_key = rt_const_cstr("Content-Type");
    ct_val = rt_const_cstr("application/json");
    int header_set = ct_key && ct_val &&
                     rt_http_header_map_set_ci((void *)headers, (rt_string)ct_key, (void *)ct_val);
    rt_string_unref((rt_string)ct_val);
    rt_string_unref((rt_string)ct_key);
    ct_val = NULL;
    ct_key = NULL;
    if (!header_set) {
        rt_trap_clear_recovery();
        if (created_headers && rt_obj_release_check0((void *)headers))
            rt_obj_free((void *)headers);
        free((void *)replacement);
        return;
    }

    res->headers = (void *)headers;
    res->body = (char *)replacement;
    res->body_len = replacement_len;
    rt_trap_clear_recovery();
}

/// @brief Dispatch a parsed request to its registered handler and populate the response.
///
/// Looks up the route via `rt_http_router_match`, records route parameters on
/// the request, resolves the handler binding by tag, and calls its dispatch
/// callback. The same implementation is used by HTTP and HTTPS so route-index
/// validation, missing-handler errors, default status, and `sent` bookkeeping
/// remain identical.
///
/// @param server Server impl owning the router, route table, and bindings.
/// @param req    Parsed request; `params` is populated on route match.
/// @param res    Response struct to populate.
static void build_route_response(rt_http_server_impl *server,
                                 server_req_t *req,
                                 server_res_t *res) {
    rt_string method_str = rt_string_from_bytes(req->method, strlen(req->method));
    rt_string path_str = rt_string_from_bytes(req->path, strlen(req->path));
    void *match = rt_http_router_match(server->router, method_str, path_str);
    rt_string_unref(method_str);
    rt_string_unref(path_str);

    res->headers = rt_map_new();

    if (match) {
        req->params = match; // Transfer ownership
        res->status_code = 200;

        int64_t route_idx = rt_route_match_index(match);
        if (route_idx < 0 || route_idx >= server->route_count) {
            set_json_error_response(res, 500, "Route metadata missing");
            return;
        }

        const char *tag = server->routes[route_idx].tag;
        handler_binding_t *binding = find_handler_binding(server, tag);
        if (!binding || !binding->dispatch) {
            set_json_error_response(res, 500, "Handler not registered");
            return;
        }

        binding->dispatch(binding->ctx, req, res);
        if (res->status_code <= 0)
            res->status_code = 200;
        if (res->body || res->body_len > 0)
            res->sent = true;
    } else {
        set_json_error_response(res, 404, "Not Found");
    }
}

/**
 * @brief Parse a decimal size value from a length-bounded substring.
 *
 * @details Leading and trailing spaces or tabs are accepted, but internal
 * whitespace and non-digits are rejected. Overflow is detected before updating
 * the accumulator, which keeps chunk-size parsing portable across 32-bit and
 * 64-bit size_t platforms.
 *
 * @param text Pointer to decimal text.
 * @param len Number of bytes available at @p text.
 * @param out Receives the parsed value on success.
 * @return true when parsing succeeds without overflow.
 */
static bool parse_size_decimal(const char *text, size_t len, size_t *out) {
    size_t value = 0;
    size_t i = 0;

    while (i < len && (text[i] == ' ' || text[i] == '\t'))
        i++;
    if (i == len)
        return false;

    for (; i < len; i++) {
        unsigned char c = (unsigned char)text[i];
        if (c >= '0' && c <= '9') {
            size_t digit = (size_t)(c - '0');
            if (value > (SIZE_MAX - digit) / 10)
                return false;
            value = value * 10 + digit;
            continue;
        }
        if (c == ' ' || c == '\t') {
            while (i < len && (text[i] == ' ' || text[i] == '\t'))
                i++;
            if (i != len)
                return false;
            *out = value;
            return true;
        }
        return false;
    }

    *out = value;
    return true;
}

/// @brief Return true if a comma-separated header value contains @p token.
static bool header_value_contains_token(const char *value,
                                        size_t value_len,
                                        const char *token,
                                        size_t token_len) {
    if (!value || !token)
        return false;
    const char *p = value;
    const char *end = value + value_len;

    while (p < end) {
        while (p < end && (*p == ' ' || *p == '\t' || *p == ','))
            p++;
        const char *token_start = p;
        while (p < end && *p != ',' && *p != ';')
            p++;
        const char *token_end = p;
        while (token_end > token_start && (token_end[-1] == ' ' || token_end[-1] == '\t'))
            token_end--;
        if ((size_t)(token_end - token_start) == token_len &&
            strncasecmp(token_start, token, token_len) == 0) {
            return true;
        }
        while (p < end && *p != ',')
            p++;
    }

    return false;
}

/// @brief Parse an HTTP chunk-size line (hex digits with optional extensions).
static bool parse_chunk_size_line(const char *line, size_t len, size_t *chunk_size_out) {
    size_t value = 0;
    size_t i = 0;
    bool saw_digit = false;

    while (i < len && (line[i] == ' ' || line[i] == '\t'))
        i++;
    for (; i < len; i++) {
        unsigned char c = (unsigned char)line[i];
        unsigned digit = 0;
        if (c == ';')
            break;
        if (c >= '0' && c <= '9')
            digit = (unsigned)(c - '0');
        else if (c >= 'a' && c <= 'f')
            digit = (unsigned)(c - 'a' + 10);
        else if (c >= 'A' && c <= 'F')
            digit = (unsigned)(c - 'A' + 10);
        else if (c == ' ' || c == '\t') {
            while (i < len && (line[i] == ' ' || line[i] == '\t'))
                i++;
            if (i < len && line[i] != ';')
                return false;
            break;
        } else {
            return false;
        }

        if (value > (SIZE_MAX - digit) / 16)
            return false;
        value = value * 16 + digit;
        saw_digit = true;
    }

    if (!saw_digit || value > HTTP_REQ_MAX_BODY)
        return false;
    *chunk_size_out = value;
    return true;
}

/// @brief Decode a chunked request body.
static chunk_parse_status_t decode_chunked_body(const char *encoded,
                                                size_t encoded_len,
                                                char **decoded_out,
                                                size_t *decoded_len_out,
                                                size_t *consumed_len_out) {
    size_t pos = 0;
    size_t decoded_len = 0;
    size_t decoded_cap = 0;
    char *decoded = NULL;

    while (1) {
        const char *line_end = find_crlf(encoded + pos, encoded_len - pos);
        size_t chunk_size = 0;
        if (!line_end) {
            free(decoded);
            return CHUNK_PARSE_INCOMPLETE;
        }
        if (!parse_chunk_size_line(
                encoded + pos, (size_t)(line_end - (encoded + pos)), &chunk_size)) {
            free(decoded);
            return CHUNK_PARSE_INVALID;
        }

        pos = (size_t)((line_end - encoded) + 2);
        if (decoded_len > HTTP_REQ_MAX_BODY || chunk_size > HTTP_REQ_MAX_BODY - decoded_len) {
            free(decoded);
            return CHUNK_PARSE_INVALID;
        }
        if (chunk_size == 0) {
            while (1) {
                const char *trailer_end = find_crlf(encoded + pos, encoded_len - pos);
                if (!trailer_end) {
                    free(decoded);
                    return CHUNK_PARSE_INCOMPLETE;
                }
                if (trailer_end == encoded + pos) {
                    pos += 2;
                    if (decoded_out) {
                        if (!decoded) {
                            decoded = (char *)malloc(1);
                            if (!decoded)
                                return CHUNK_PARSE_INVALID;
                        }
                        decoded[decoded_len] = '\0';
                        *decoded_out = decoded;
                    }
                    if (decoded_len_out)
                        *decoded_len_out = decoded_len;
                    if (consumed_len_out)
                        *consumed_len_out = pos;
                    return CHUNK_PARSE_OK;
                }
                pos = (size_t)((trailer_end - encoded) + 2);
            }
        }
        if (pos > encoded_len || chunk_size > encoded_len - pos ||
            encoded_len - pos - chunk_size < 2) {
            free(decoded);
            return CHUNK_PARSE_INCOMPLETE;
        }

        if (decoded_out && chunk_size > 0) {
            if (decoded_len > SIZE_MAX - chunk_size - 1) {
                free(decoded);
                return CHUNK_PARSE_INVALID;
            }
            size_t needed = decoded_len + chunk_size + 1;
            if (needed > decoded_cap) {
                size_t next_cap = decoded_cap ? decoded_cap : 256;
                while (next_cap < needed) {
                    if (next_cap > SIZE_MAX / 2) {
                        free(decoded);
                        return CHUNK_PARSE_INVALID;
                    }
                    next_cap *= 2;
                }
                char *grown = (char *)realloc(decoded, next_cap);
                if (!grown) {
                    free(decoded);
                    return CHUNK_PARSE_INVALID;
                }
                decoded = grown;
                decoded_cap = next_cap;
            }
            memcpy(decoded + decoded_len, encoded + pos, chunk_size);
        }
        decoded_len += chunk_size;
        pos += chunk_size;

        if (encoded[pos] != '\r' || encoded[pos + 1] != '\n') {
            free(decoded);
            return CHUNK_PARSE_INVALID;
        }
        pos += 2;
    }
}

/// @brief Scan a raw HTTP header block to extract framing hints.
static bool parse_transfer_encoding_value_strict(const char *value,
                                                 size_t value_len,
                                                 bool *chunked_out);

static bool parse_content_length_header_block(const char *headers,
                                              size_t headers_len,
                                              size_t *content_length_out,
                                              bool *chunked_out) {
    const char *p = headers;
    const char *end = headers + headers_len;
    size_t content_length = 0;
    bool saw_content_length = false;
    bool saw_chunked = false;

    while (p < end) {
        const char *line_end = find_crlf(p, (size_t)(end - p));
        if (!line_end)
            return false;
        if (line_end == p)
            break;

        const char *colon = find_char_bounded(p, (size_t)(line_end - p), ':');
        if (colon) {
            size_t name_len = (size_t)(colon - p);
            if (name_len == strlen("Content-Length") &&
                strncasecmp(p, "Content-Length", name_len) == 0) {
                const char *value = colon + 1;
                while (value < line_end && (*value == ' ' || *value == '\t'))
                    value++;
                if (saw_content_length)
                    return false;
                if (!parse_size_decimal(value, (size_t)(line_end - value), &content_length))
                    return false;
                saw_content_length = true;
            } else if (name_len == strlen("Transfer-Encoding") &&
                       strncasecmp(p, "Transfer-Encoding", name_len) == 0) {
                const char *value = colon + 1;
                while (value < line_end && (*value == ' ' || *value == '\t'))
                    value++;
                bool value_chunked = false;
                if (!parse_transfer_encoding_value_strict(
                        value, (size_t)(line_end - value), &value_chunked))
                    return false;
                if (value_chunked) {
                    if (saw_chunked)
                        return false;
                    saw_chunked = true;
                }
            }
        }

        p = line_end + 2;
    }

    if (saw_chunked && saw_content_length)
        return false;
    *content_length_out = saw_content_length ? content_length : 0;
    if (chunked_out)
        *chunked_out = saw_chunked;
    return true;
}

static bool parse_transfer_encoding_value_strict(const char *value,
                                                 size_t value_len,
                                                 bool *chunked_out) {
    bool saw_token = false;
    bool saw_chunked = false;

    if (chunked_out)
        *chunked_out = false;
    if (!value)
        return false;
    const char *p = value;
    const char *end = value + value_len;

    while (p < end) {
        const char *token_start;
        const char *token_end;
        bool token_is_chunked = false;

        while (p < end && (*p == ' ' || *p == '\t'))
            p++;
        if (p >= end)
            return false;
        if (*p == ',')
            return false;

        token_start = p;
        while (p < end && *p != ',')
            p++;
        token_end = p;
        while (token_end > token_start && (token_end[-1] == ' ' || token_end[-1] == '\t'))
            token_end--;

        if (token_end == token_start)
            return false;
        token_is_chunked =
            (size_t)(token_end - token_start) == 7 && strncasecmp(token_start, "chunked", 7) == 0;
        if (!token_is_chunked)
            return false;
        if (saw_chunked)
            return false;
        saw_token = true;
        saw_chunked = true;

        if (p < end) {
            p++;
            while (p < end && (*p == ' ' || *p == '\t'))
                p++;
            if (p >= end)
                return false;
        }
    }

    if (!saw_token)
        return false;
    if (chunked_out)
        *chunked_out = saw_chunked;
    return true;
}

typedef enum {
    HTTP_REQUEST_FRAME_INCOMPLETE = 0,
    HTTP_REQUEST_FRAME_COMPLETE = 1,
    HTTP_REQUEST_FRAME_INVALID = -1
} http_request_frame_status_t;

/// @brief Validate line lengths in a partial HTTP request buffer.
/// @details Scans all complete CRLF-delimited lines and the current trailing
///          partial line. Any line exceeding @c HTTP_REQ_MAX_LINE is rejected
///          before the aggregate header buffer grows to the full request cap.
///          The CRLF bytes themselves are not counted as part of the line.
/// @param buf Request bytes accumulated so far.
/// @param buf_len Number of valid bytes in @p buf.
/// @return @c true when every observed line is within the configured limit.
static bool http_request_lines_within_limit(const char *buf, size_t buf_len) {
    size_t line_start = 0;
    if (!buf)
        return false;
    for (size_t i = 0; i < buf_len; i++) {
        if (buf[i] == '\n') {
            size_t line_end = i;
            if (line_end > line_start && buf[line_end - 1] == '\r')
                line_end--;
            if (line_end < line_start || line_end - line_start > HTTP_REQ_MAX_LINE)
                return false;
            line_start = i + 1;
        } else if (i + 1 - line_start > HTTP_REQ_MAX_LINE) {
            return false;
        }
    }
    return buf_len - line_start <= HTTP_REQ_MAX_LINE;
}

static http_request_frame_status_t find_complete_http_request_frame(const char *buf,
                                                                    size_t buf_len,
                                                                    size_t *request_len_out,
                                                                    size_t *desired_cap_out) {
    const char *header_end = find_header_end(buf, buf_len);
    size_t header_end_pos = 0;
    size_t content_length = 0;
    bool chunked = false;

    if (request_len_out)
        *request_len_out = 0;
    if (desired_cap_out)
        *desired_cap_out = 0;
    if (!buf)
        return HTTP_REQUEST_FRAME_INVALID;
    if (!http_request_lines_within_limit(buf, buf_len))
        return HTTP_REQUEST_FRAME_INVALID;
    if (!header_end)
        return HTTP_REQUEST_FRAME_INCOMPLETE;

    header_end_pos = (size_t)(header_end - buf);
    if (!parse_content_length_header_block(buf, header_end_pos, &content_length, &chunked) ||
        content_length > HTTP_REQ_MAX_BODY) {
        return HTTP_REQUEST_FRAME_INVALID;
    }

    if (chunked) {
        size_t consumed_len = 0;
        chunk_parse_status_t status = decode_chunked_body(
            buf + header_end_pos, buf_len - header_end_pos, NULL, NULL, &consumed_len);
        if (status == CHUNK_PARSE_OK) {
            if (request_len_out)
                *request_len_out = header_end_pos + consumed_len;
            return HTTP_REQUEST_FRAME_COMPLETE;
        }
        if (status == CHUNK_PARSE_INVALID)
            return HTTP_REQUEST_FRAME_INVALID;
        if (desired_cap_out)
            *desired_cap_out = header_end_pos + HTTP_REQ_MAX_ENCODED_BODY + 1;
        return HTTP_REQUEST_FRAME_INCOMPLETE;
    }

    if (request_len_out)
        *request_len_out = header_end_pos + content_length;
    if (buf_len >= header_end_pos + content_length)
        return HTTP_REQUEST_FRAME_COMPLETE;
    if (desired_cap_out)
        *desired_cap_out = header_end_pos + content_length + 1;
    return HTTP_REQUEST_FRAME_INCOMPLETE;
}

/// @brief Parse an HTTP request from raw bytes.
static bool parse_http_request(const char *raw, size_t raw_len, server_req_t *req) {
    memset(req, 0, sizeof(*req));

    const char *line_end = find_crlf(raw, raw_len);
    if (!line_end)
        return false;
    if ((size_t)(line_end - raw) > HTTP_REQ_MAX_LINE)
        return false;

    const char *p = raw;
    const char *space = find_char_bounded(p, (size_t)(line_end - p), ' ');
    if (!space || space > line_end)
        return false;

    size_t method_len = (size_t)(space - p);
    req->method = (char *)malloc(method_len + 1);
    if (!req->method)
        return false;
    memcpy(req->method, p, method_len);
    req->method[method_len] = '\0';
    if (!http_method_is_valid(req->method, method_len))
        goto fail;

    p = space + 1;
    space = find_char_bounded(p, (size_t)(line_end - p), ' ');
    if (!space || space > line_end)
        goto fail;

    size_t uri_len = (size_t)(space - p);
    char *uri = (char *)malloc(uri_len + 1);
    if (!uri)
        goto fail;
    memcpy(uri, p, uri_len);
    uri[uri_len] = '\0';

    if (!set_request_target(req, uri, uri_len)) {
        free(uri);
        goto fail;
    }
    free(uri);

    p = space + 1;
    if ((size_t)(line_end - p) != strlen("HTTP/1.1") || strncmp(p, "HTTP/1.", 7) != 0 ||
        (p[7] != '0' && p[7] != '1')) {
        goto fail;
    }
    req->http_major = 1;
    req->http_minor = p[7] - '0';

    req->headers = rt_map_new();
    if (!req->headers)
        goto fail;
    p = line_end + 2;
    const char *headers_begin = p;
    size_t content_length = 0;
    const char *body_start = NULL;

    int header_count = 0;
    while (p < raw + raw_len && header_count < HTTP_REQ_MAX_HEADERS) {
        const char *next_end = find_crlf(p, (size_t)(raw + raw_len - p));
        if (!next_end)
            goto fail;
        if ((size_t)(next_end - p) > HTTP_REQ_MAX_LINE)
            goto fail;
        if (next_end == p) {
            body_start = next_end + 2;
            break;
        }

        const char *colon = find_char_bounded(p, (size_t)(next_end - p), ':');
        if (!colon || colon >= next_end)
            goto fail;

        size_t name_len = (size_t)(colon - p);
        if (name_len == 0)
            goto fail;
        for (size_t i = 0; i < name_len; i++) {
            if (!http_token_char((unsigned char)p[i]))
                goto fail;
        }

        char *name = (char *)malloc(name_len + 1);
        if (!name)
            goto fail;
        memcpy(name, p, name_len);
        name[name_len] = '\0';
        for (size_t i = 0; i < name_len; i++) {
            if (name[i] >= 'A' && name[i] <= 'Z')
                name[i] += 32;
        }

        const char *val = colon + 1;
        while (val < next_end && (*val == ' ' || *val == '\t'))
            val++;
        size_t val_len = (size_t)(next_end - val);

        rt_string key = rt_string_from_bytes(name, name_len);
        rt_string value = rt_string_from_bytes(val, val_len);
        free(name);
        if (!key || !value) {
            rt_string_unref(key);
            rt_string_unref(value);
            goto fail;
        }
        rt_map_set(req->headers, key, (void *)value);
        rt_string_unref(key);
        rt_string_unref(value);

        p = next_end + 2;
        header_count++;
    }
    if (!body_start && header_count >= HTTP_REQ_MAX_HEADERS)
        goto fail;
    if (!body_start)
        body_start = p;

    bool chunked = false;
    size_t headers_len = body_start > headers_begin ? (size_t)(body_start - headers_begin - 2) : 0;
    if (!parse_content_length_header_block(headers_begin, headers_len, &content_length, &chunked))
        goto fail;

    if (chunked) {
        size_t available = (size_t)(raw + raw_len - body_start);
        size_t consumed_len = 0;
        char *decoded_body = NULL;
        if (decode_chunked_body(
                body_start, available, &decoded_body, &req->body_len, &consumed_len) !=
            CHUNK_PARSE_OK)
            goto fail;
        req->body = decoded_body;
    } else if (content_length > HTTP_REQ_MAX_BODY) {
        goto fail;
    } else if (content_length > 0) {
        size_t available = (size_t)(raw + raw_len - body_start);
        if (available < content_length)
            goto fail;
        req->body = (char *)malloc(content_length + 1);
        if (!req->body)
            goto fail;
        memcpy(req->body, body_start, content_length);
        req->body[content_length] = '\0';
        req->body_len = content_length;
    }

    return true;

fail:
    free_server_req(req);
    memset(req, 0, sizeof(*req));
    return false;
}

/// @brief Look up a lower-case header map entry and verify it is an rt_string.
///
/// Header maps are populated internally with `rt_string` keys and values, but
/// native handler code can still mutate response maps through opaque handles.
/// This helper keeps every direct header-value cast guarded by the runtime
/// string registry before callers ask for the C string payload.
///
/// @param headers    Runtime map containing lower-case header names.
/// @param lower_name Lower-case header name to look up.
/// @return Header value handle, or NULL if absent or not a valid string.
static rt_string map_get_lower_header_string(void *headers, const char *lower_name) {
    if (!headers || !lower_name)
        return NULL;
    rt_string key = rt_const_cstr(lower_name);
    void *val = rt_map_get(headers, key);
    rt_string_unref(key);
    if (!val || !rt_string_is_handle(val))
        return NULL;
    return (rt_string)val;
}

/// @brief Look up a lower-case header value as a borrowed C string.
///
/// @param headers    Runtime map containing lower-case header names.
/// @param lower_name Lower-case header name to look up.
/// @return NUL-terminated header bytes, or NULL when absent/invalid.
static const char *map_get_lower_header_cstr(void *headers, const char *lower_name) {
    rt_string val = map_get_lower_header_string(headers, lower_name);
    return val ? rt_string_cstr(val) : NULL;
}

static int request_allows_keep_alive(const server_req_t *req) {
    const char *connection = req ? map_get_lower_header_cstr(req->headers, "connection") : NULL;
    if (!req)
        return 0;
    if (req->http_major > 1 || (req->http_major == 1 && req->http_minor >= 1)) {
        if (!connection)
            return 1;
        return !header_value_contains_token(connection, strlen(connection), "close", 5);
    }
    if (!connection)
        return 0;
    return header_value_contains_token(connection, strlen(connection), "keep-alive", 10);
}

static int response_forces_close(const server_res_t *res) {
    const char *connection = res ? map_get_lower_header_cstr(res->headers, "connection") : NULL;
    if (!connection)
        return 0;
    return header_value_contains_token(connection, strlen(connection), "close", 5);
}

/// @brief Decide whether a response status may carry a message body.
///
/// HTTP/1.1 forbids response bodies for `204 No Content` and
/// `304 Not Modified`. The runtime still lets handlers set those status codes
/// through the normal response API, so the shared formatter centralizes the
/// body-suppression rule before calculating `Content-Length` and copying bytes
/// to the wire buffer.
///
/// @param res Response being formatted.
/// @return Non-zero when the status code is allowed to include a body.
static int response_status_allows_body(const server_res_t *res) {
    if (!res)
        return 0;
    return res->status_code != 204 && res->status_code != 304;
}

/// @brief Return the number of response body bytes to emit on the wire.
///
/// The `sent` flag records that the public response API finalized the body.
/// Direct native handlers may still populate `body/body_len` themselves, so
/// this helper preserves that legacy path while making the finalized-body
/// signal observable in the shared HTTP and HTTPS response builder.
///
/// @param res Response being formatted.
/// @return Body byte count after HTTP status-body rules are applied.
static size_t response_wire_body_len(const server_res_t *res) {
    if (!res || !response_status_allows_body(res))
        return 0;
    if (res->sent || res->body)
        return res->body_len;
    return 0;
}

/// @brief Add one byte count to an accumulated response size safely.
/// @param total In/out accumulated size.
/// @param amount Number of bytes to add.
/// @return One on success; zero when the addition would overflow `size_t`.
static int response_size_add(size_t *total, size_t amount) {
    if (!total || *total > SIZE_MAX - amount)
        return 0;
    *total += amount;
    return 1;
}

/// @brief Validate a managed response-header String as length-bounded wire text.
/// @details The runtime identity and length are checked before payload access.
///          Embedded NUL, CR, and LF bytes are rejected so native handlers
///          cannot smuggle truncated or injected header lines into formatting.
/// @param text Candidate managed String.
/// @param bytes_out Receives borrowed payload bytes on success.
/// @param len_out Receives the exact byte length on success.
/// @return One for valid wire text; zero otherwise.
static int response_header_string_bytes(rt_string text, const char **bytes_out, size_t *len_out) {
    if (bytes_out)
        *bytes_out = NULL;
    if (len_out)
        *len_out = 0;
    if (!text || !rt_string_is_handle(text))
        return 0;
    const char *bytes = rt_string_cstr(text);
    int64_t len64 = rt_str_len(text);
    if (!bytes || len64 < 0 || (uint64_t)len64 > (uint64_t)SIZE_MAX)
        return 0;
    size_t len = (size_t)len64;
    if (memchr(bytes, '\0', len) || memchr(bytes, '\r', len) || memchr(bytes, '\n', len))
        return 0;
    if (bytes_out)
        *bytes_out = bytes;
    if (len_out)
        *len_out = len;
    return 1;
}

/// @brief Map an HTTP status code to its canonical reason-phrase.
static const char *status_text_for_code(int code) {
    switch (code) {
        case 200:
            return "OK";
        case 201:
            return "Created";
        case 204:
            return "No Content";
        case 301:
            return "Moved Permanently";
        case 302:
            return "Found";
        case 400:
            return "Bad Request";
        case 401:
            return "Unauthorized";
        case 403:
            return "Forbidden";
        case 404:
            return "Not Found";
        case 405:
            return "Method Not Allowed";
        case 500:
            return "Internal Server Error";
        default:
            return "Unknown";
    }
}

/// @brief Build an HTTP response string.
static char *build_response(server_res_t *res, int keep_alive, size_t *out_len) {
    void *volatile keys = NULL;
    char *volatile buffer = NULL;
    if (out_len)
        *out_len = 0;
    if (!res)
        return NULL;

    jmp_buf recovery;
    rt_trap_set_recovery(&recovery);
    if (setjmp(recovery) != 0) {
        char saved_error[256];
        const char *error = rt_trap_get_error();
        snprintf(saved_error,
                 sizeof(saved_error),
                 "%s",
                 error && error[0] ? error : "HttpServer: response serialization failed");
        rt_trap_clear_recovery();
        if (keys && rt_obj_release_check0((void *)keys))
            rt_obj_free((void *)keys);
        free((void *)buffer);
        rt_trap(saved_error);
        return NULL;
    }

    size_t body_len = response_wire_body_len(res);
    if (body_len > 0 && !res->body)
        goto fail;
    int status_len = snprintf(
        NULL, 0, "HTTP/1.1 %d %s\r\n", res->status_code, status_text_for_code(res->status_code));
    int length_len = snprintf(NULL, 0, "Content-Length: %zu\r\n", body_len);
    if (status_len < 0 || length_len < 0)
        goto fail;
    size_t cap = 0;
    if (!response_size_add(&cap, (size_t)status_len) ||
        !response_size_add(&cap, (size_t)length_len) ||
        !response_size_add(
            &cap, strlen(keep_alive ? "Connection: keep-alive\r\n" : "Connection: close\r\n"))) {
        goto fail;
    }

    int64_t header_count = 0;
    if (res->headers) {
        keys = rt_map_keys(res->headers);
        if (!keys)
            goto fail;
        header_count = rt_seq_len((void *)keys);
        if (header_count < 0)
            goto fail;
    }
    for (int64_t i = 0; i < header_count; i++) {
        rt_string key = (rt_string)rt_seq_get((void *)keys, i);
        rt_string value = (rt_string)rt_map_get(res->headers, key);
        const char *key_bytes = NULL;
        const char *value_bytes = NULL;
        size_t key_len = 0;
        size_t value_len = 0;
        if (!response_header_string_bytes(key, &key_bytes, &key_len) ||
            !response_header_string_bytes(value, &value_bytes, &value_len) ||
            !server_header_name_valid(key_bytes, key_len) ||
            is_server_managed_header_name(key_bytes)) {
            continue;
        }
        if (!response_size_add(&cap, key_len) || !response_size_add(&cap, value_len) ||
            !response_size_add(&cap, 4)) {
            goto fail;
        }
    }
    if (!response_size_add(&cap, 2) || !response_size_add(&cap, body_len) ||
        !response_size_add(&cap, 1)) {
        goto fail;
    }

    buffer = (char *)malloc(cap);
    if (!buffer)
        goto fail;
    char *cursor = (char *)buffer;
    size_t remaining = cap;
#define APPEND_FORMAT(...)                                                                         \
    do {                                                                                           \
        int written = snprintf(cursor, remaining, __VA_ARGS__);                                    \
        if (written < 0 || (size_t)written >= remaining)                                           \
            goto fail;                                                                             \
        cursor += written;                                                                         \
        remaining -= (size_t)written;                                                              \
    } while (0)

    APPEND_FORMAT("HTTP/1.1 %d %s\r\n", res->status_code, status_text_for_code(res->status_code));
    APPEND_FORMAT("Content-Length: %zu\r\n", body_len);
    APPEND_FORMAT("%s", keep_alive ? "Connection: keep-alive\r\n" : "Connection: close\r\n");

    for (int64_t i = 0; i < header_count; i++) {
        rt_string key = (rt_string)rt_seq_get((void *)keys, i);
        rt_string value = (rt_string)rt_map_get(res->headers, key);
        const char *key_bytes = NULL;
        const char *value_bytes = NULL;
        size_t key_len = 0;
        size_t value_len = 0;
        if (!response_header_string_bytes(key, &key_bytes, &key_len) ||
            !response_header_string_bytes(value, &value_bytes, &value_len) ||
            !server_header_name_valid(key_bytes, key_len) ||
            is_server_managed_header_name(key_bytes)) {
            continue;
        }
        if (key_len > remaining || value_len > remaining - key_len ||
            4 > remaining - key_len - value_len) {
            goto fail;
        }
        memcpy(cursor, key_bytes, key_len);
        cursor += key_len;
        memcpy(cursor, ": ", 2);
        cursor += 2;
        memcpy(cursor, value_bytes, value_len);
        cursor += value_len;
        memcpy(cursor, "\r\n", 2);
        cursor += 2;
        remaining -= key_len + value_len + 4;
    }

    APPEND_FORMAT("%s", "\r\n");
    if (body_len > 0) {
        if (body_len >= remaining)
            goto fail;
        memcpy(cursor, res->body, body_len);
        cursor += body_len;
        remaining -= body_len;
    }
    *cursor = '\0';
    if (out_len)
        *out_len = (size_t)(cursor - (char *)buffer);

    if (keys && rt_obj_release_check0((void *)keys))
        rt_obj_free((void *)keys);
    keys = NULL;
    rt_trap_clear_recovery();
    char *result = (char *)buffer;
    buffer = NULL;
#undef APPEND_FORMAT
    return result;

fail:
    rt_trap_clear_recovery();
    if (keys && rt_obj_release_check0((void *)keys))
        rt_obj_free((void *)keys);
    free((void *)buffer);
#undef APPEND_FORMAT
    return NULL;
}
