module RuntimeTest38;

bind Zanna.Terminal;
bind Zanna.Runtime.Unsafe;

var released: Boolean = false;

class Resource {
    deinit {
        released = true;
        Say("deinit");
    }
}

func makeResource() {    var r = new Resource();
    Zanna.Runtime.Unsafe.Release(r);
}

func start() {    makeResource();

    if (!released) {
        Zanna.Terminal.Say("FAIL: deinit_not_run");
        return;
    }

    Zanna.Terminal.Say("RESULT: ok");
}
