module RuntimeTest37;

bind Zanna.Terminal;

func start() {    var trimmed = "  hello  ".Trim();
    if (trimmed != "hello") {
        Zanna.Terminal.Say("FAIL: trim");
        return;
    }

    var upper = trimmed.ToUpper();
    if (upper != "HELLO") {
        Zanna.Terminal.Say("FAIL: upper");
        return;
    }

    var lower = upper.ToLower();
    if (lower != "hello") {
        Zanna.Terminal.Say("FAIL: lower");
        return;
    }

    var left = "  hi".TrimStart();
    if (left != "hi") {
        Zanna.Terminal.Say("FAIL: trim_start");
        return;
    }

    var right = "hi  ".TrimEnd();
    if (right != "hi") {
        Zanna.Terminal.Say("FAIL: trim_end");
        return;
    }

    var middle = "abcdef".Substring(1, 3);
    if (middle != "bcd") {
        Zanna.Terminal.Say("FAIL: substring");
        return;
    }

    Zanna.Terminal.Say("RESULT: ok");
}
