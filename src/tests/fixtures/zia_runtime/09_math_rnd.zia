module RuntimeTest09;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Math.Randomize
// COVER: Zanna.Math.Rnd

func start() {    Zanna.Math.Randomize(123);
    var a = Zanna.Math.Rnd();
    Zanna.Math.Randomize(123);
    var b = Zanna.Math.Rnd();
    assertApprox(a, b, 0.0000001, "rnd");
    report();
}
