module RuntimeTest45;

bind "./_support";
bind Zanna.Data.Json;
bind Zanna.Text.Fmt;
bind Zanna.Math.Easing;
bind Zanna.Collections.Map;
bind Zanna.Option as Option;

// EXPECT_OUT: RESULT: ok

func testCanonicalRuntimeSurface() {
    assertEqStr(Zanna.Text.Fmt.Int(42), "42", "fmt_int");
    assertTrue(Zanna.String.Contains(Zanna.Text.Fmt.Num(1.5), "1.5"), "fmt_num");

    var seq = new Zanna.Collections.Seq();
    assertEqInt(seq.Count, 0, "seq_new_count");
    seq.Push("x");
    assertEqStr(Zanna.Collections.Seq.GetStr(seq, 0), "x", "seq_new_sized_set");

    var list = Zanna.Collections.List.New();
    assertEqInt(Zanna.Collections.List.get_Count(list), 0, "list_count");
}

func testCollectionSnapshots() {
    var map = new Zanna.Collections.Map();
    map.SetStr("name", "zia");
    map.SetInt("version", 1);
    assertEqInt(map.Keys().Count, 2, "map_keys_count");
    assertEqInt(map.Values().Count, 2, "map_values_count");
}

func testConstructorsAndRandom() {
    var ring = new Zanna.Collections.Ring();
    assertGtInt(ring.Capacity, 0, "ring_default_ctor");

    var a = new Zanna.Math.Random(123);
    var b = new Zanna.Math.Random(123);
    assertEqInt(a.NextInt(1000), b.NextInt(1000), "random_same_seed_first");
    assertEqInt(a.NextInt(1000), b.NextInt(1000), "random_same_seed_second");
    assertInRange(a.NextDouble(), 0.0, 1.0, "random_next_double");
    var ranged = a.Range(10, 20);
    assertGteInt(ranged, 10, "random_range_min");
    assertLteInt(ranged, 20, "random_range_max");
}

func testJsonMachineVecAndEasing() {
    var obj = NewObject();
    Zanna.Collections.Map.SetStr(obj, "name", "zia");
    Zanna.Collections.Map.SetInt(obj, "version", 1);
    Zanna.Collections.Map.SetBool(obj, "ready", true);
    assertEqStr(Zanna.Collections.Map.GetStr(obj, "name"), "zia", "json_get_str");
    assertEqInt(Zanna.Collections.Map.GetInt(obj, "version"), 1, "json_get_int");
    assertTrue(Zanna.Collections.Map.GetBool(obj, "ready"), "json_get_bool");
    assertTrue(Zanna.Collections.Map.Has(obj, "name"), "json_has");
    assertTrue(Zanna.String.Contains(Zanna.Data.Json.Format(obj), "zia"), "json_format");

    assertNotEmpty(Zanna.System.Machine.get_Os(), "environment_platform");
    assertNotEmpty(Zanna.System.Machine.get_Arch(), "machine_arch");
    assertGtInt(Zanna.System.Machine.get_PageSize(), 0, "machine_page_size");
    assertGtInt(Zanna.System.Machine.get_PointerSize(), 0, "machine_pointer_size");

    var v = new Zanna.Math.Vec2(3.0, 4.0);
    assertApprox(v.Length(), 5.0, 0.0001, "vec2_length");
    assertApprox(Zanna.Math.Vec2.Dist(new Zanna.Math.Vec2(0.0, 0.0), v), 5.0, 0.0001, "vec2_distance");
    assertApprox(Zanna.Math.Easing.EaseInQuad(0.5), 0.25, 0.0001, "easing_in_quad");
}

var lazySupplierRuns: Integer = 0;

func buildLazySeq() -> Zanna.Collections.Seq {
    lazySupplierRuns = lazySupplierRuns + 1;
    var s = new Zanna.Collections.Seq();
    s.Push("computed");
    return s;
}

func testLazyDeferredFactory() {
    // Lazy.New defers: the supplier must not run until first access, must run
    // exactly once, and the result must be cached across accesses.
    var deferred = Zanna.Functional.Lazy.New(buildLazySeq);
    assertEqInt(lazySupplierRuns, 0, "lazy_new_not_evaluated_early");
    assertTrue(!deferred.get_IsEvaluated(), "lazy_new_is_evaluated_false");

    var first = deferred.Get();
    assertEqInt(lazySupplierRuns, 1, "lazy_new_supplier_ran_once");
    assertTrue(deferred.get_IsEvaluated(), "lazy_new_is_evaluated_true");
    assertEqStr(Zanna.Collections.Seq.GetStr(first, 0), "computed", "lazy_new_payload");

    deferred.Get();
    deferred.Force();
    assertEqInt(lazySupplierRuns, 1, "lazy_new_supplier_cached");

    // Of* factories stay eager.
    var eager = Zanna.Functional.Lazy.OfI64(9);
    assertTrue(eager.get_IsEvaluated(), "lazy_of_is_evaluated");
    assertEqInt(eager.GetI64(), 9, "lazy_of_payload");
}

func combinatorTag(x: Zanna.Collections.Seq) -> Zanna.Collections.Seq {
    x.Push("mapped");
    return x;
}

func combinatorNonEmpty(x: Zanna.Collections.Seq) -> Boolean {
    return x.Count > 0;
}

func combinatorFallback() -> Zanna.Option {
    var s = new Zanna.Collections.Seq();
    s.Push("fallback");
    return Option.Some(s);
}

func combinatorRecover(err: Zanna.Collections.Seq) -> Zanna.Result {
    var s = new Zanna.Collections.Seq();
    s.Push("recovered");
    return Zanna.Result.Ok(s);
}

func testOptionResultCombinatorCallbacks() {
    // Generic-payload combinator callbacks must execute on every engine
    // (VM bridges re-enter the interpreter; native calls the C pointer).
    var payload = new Zanna.Collections.Seq();
    payload.Push("original");

    var mapped = Option.Some(payload).Map(combinatorTag);
    assertEqInt(Zanna.Collections.Seq.get_Count(mapped.Unwrap()), 2, "option_map_callback_ran");
    assertTrue(Option.Some(payload).Filter(combinatorNonEmpty).IsSome, "option_filter_pred_ran");
    assertTrue(Option.None().OrElse(combinatorFallback).IsSome, "option_or_else_fallback_ran");

    var errPayload = new Zanna.Collections.Seq();
    assertTrue(Zanna.Result.Err(errPayload).OrElse(combinatorRecover).IsOk,
               "result_or_else_recovered");

    // Typed payloads keep the documented pass-through behavior.
    assertEqInt(Option.SomeI64(7).Map(combinatorTag).UnwrapI64(), 7, "option_map_typed_passthrough");
}

func testOptionToResultTyping() {
    // Option.OkOr/OkOrStr are registered as obj<Zanna.Result>, so the returned
    // Result's members must type-check without an explicit receiver.
    var none = Option.None();
    var failed = none.OkOrStr("missing");
    assertTrue(failed.IsErr, "option_ok_or_str_none_is_err");
    assertEqStr(failed.UnwrapErrStr(), "missing", "option_ok_or_str_err_payload");

    var some = Option.SomeI64(42);
    var ok = some.OkOrStr("unused");
    assertTrue(ok.IsOk, "option_ok_or_some_is_ok");
    assertEqInt(ok.UnwrapI64(), 42, "option_ok_or_some_payload");
}

func testTypedConcreteReturns() {
    // Registry rows for concrete collection results carry qualified types
    // (VDOC-020): natural chaining must type-check without explicit receivers.
    var rows = Zanna.Data.Csv.Parse("a,b\nc,d");
    assertEqInt(rows.Count, 2, "csv_parse_rows_count");

    var texts = Zanna.Text.Html.ExtractText("<p>hi</p>", "p");
    assertEqInt(texts.Count, 1, "html_extract_text_count");

    var bus = new Zanna.Core.MessageBus();
    assertEqInt(bus.Topics().Count, 0, "messagebus_topics_count");

    var key = Zanna.Crypto.Cipher.GenerateKey();
    assertEqInt(key.Length, 32, "cipher_generate_key_length");

    var router = new Zanna.Network.HttpRouter();
    assertTrue(router.Get("/x").Match("GET", "/x") != null, "http_router_chain_match");

    var heap = new Zanna.Collections.Heap();
    heap.Push(1, "only");
    assertEqInt(heap.ToSeq().Count, 1, "heap_to_seq_count");

    // DefaultPool is typed as Pool, so Pool members chain fluently (VDOC-131).
    assertGtInt(Zanna.Threads.Parallel.DefaultPool().Size, 0, "default_pool_typed_chain");

    // Queue/Stack expose SetOwnsElements on the class surface (VDOC-087).
    var q = new Zanna.Collections.Queue();
    q.SetOwnsElements(true);
    q.Push("kept");
    assertEqInt(q.Count, 1, "queue_owning_push");
    var st = new Zanna.Collections.Stack();
    st.SetOwnsElements(true);
    st.Push("kept");
    assertEqInt(st.Count, 1, "stack_owning_push");

    // FromSingle formats with single-precision semantics through a matched
    // f64 ABI on every dispatch path (VDOC-162; previously "0"/garbage).
    assertEqStr(Zanna.String.FromSingle(1.5), "1.5", "from_single_exact");
    assertEqStr(Zanna.String.FromSingle(3.14), "3.14000010490417", "from_single_narrowed");

    // Narrow-parameter runtime calls lower with checked narrowing (VDOC-163).
    assertEqStr(Zanna.String.FromI16(42), "42", "from_i16_narrowed_call");
    assertEqStr(Zanna.String.FromI32(70000), "70000", "from_i32_narrowed_call");

    // SplitFieldsResult enforces strict quoting (VDOC-164).
    var goodSplit = Zanna.String.SplitFieldsResult("a,\"b,c\",d");
    assertTrue(goodSplit.IsOk, "split_fields_result_ok");
    var badSplit = Zanna.String.SplitFieldsResult("\"a,b");
    assertTrue(badSplit.IsErr, "split_fields_result_err");

    // Template.Keys is a StringSet (deduplicated), typed as such (VDOC-044).
    var keys = Zanna.Text.Template.Keys("{{a}} {{b}} {{a}}");
    assertEqInt(keys.Count, 2, "template_keys_count");
    assertTrue(keys.Has("a"), "template_keys_has");
}

func start() {
    testTypedConcreteReturns();
    testCanonicalRuntimeSurface();
    testCollectionSnapshots();
    testConstructorsAndRandom();
    testJsonMachineVecAndEasing();
    testLazyDeferredFactory();
    testOptionResultCombinatorCallbacks();
    testOptionToResultTyping();
    report();
}
