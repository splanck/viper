module RuntimeTest07;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// EXPECT_TTY_INPUT: hello\nZ
// COVER: Zanna.Terminal.ReadLine
// COVER: Zanna.Terminal.GetKey

func start() {    var line = Zanna.Terminal.TryReadLine() ?? "";
    assertEqStr(line, "hello", "readline");

    var key = Zanna.Terminal.ReadKey();
    assertNotEmpty(key, "getkey");

    report();
}
