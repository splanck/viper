module RuntimeTest50;

bind "./_support";

// EXPECT_OUT: RESULT: ok

func start() {
    assertApprox(Zanna.Game.WorldToScreenProjection.LinearX(12.0, 2.0, 100.0, 4.0), 140.0, 0.0001, "linear_x");
    assertApprox(Zanna.Game.WorldToScreenProjection.LinearY(9.0, 1.0, 50.0, 5.0, true), 10.0, 0.0001, "linear_y_flipped");
    assertApprox(Zanna.Game.WorldToScreenProjection.LinearY(9.0, 1.0, 50.0, 5.0, false), 90.0, 0.0001, "linear_y_screen_down");

    assertApprox(Zanna.Game.WorldToScreenProjection.IsometricX(3.0, 1.0, 100.0, 64.0), 164.0, 0.0001, "isometric_x");
    assertApprox(Zanna.Game.WorldToScreenProjection.IsometricY(3.0, 1.0, 0.0, 32.0), 64.0, 0.0001, "isometric_y");

    assertApprox(Zanna.Game.WorldToScreenProjection.PerspectiveScale(5.0, 0.0, 10.0, 2.0, 1.0), 1.5, 0.0001, "perspective_scale_mid");
    assertApprox(Zanna.Game.WorldToScreenProjection.PerspectiveScale(20.0, 0.0, 10.0, 2.0, 1.0), 1.0, 0.0001, "perspective_scale_clamp");
    assertApprox(Zanna.Game.WorldToScreenProjection.PerspectiveX(4.0, 100.0, 2.0, 50.0), 200.0, 0.0001, "perspective_x");
    assertApprox(Zanna.Game.WorldToScreenProjection.PerspectiveY(6.0, 100.0, 2.0, 50.0, true), -50.0, 0.0001, "perspective_y_flipped");

    report();
}
