module Test;

// Test: Seq without size argument

func start() {
    Zanna.Terminal.Say("=== Seq No Arg Test ===");

    var s = Zanna.Collections.Seq.New();
    Zanna.Terminal.Say("Created seq");

    Zanna.Collections.Seq.Push(s, "hello");
    Zanna.Terminal.Say("Pushed element");

    var len = Zanna.Collections.Seq.get_Count(s);
    Zanna.Terminal.Say("Len: " + Zanna.String.FromInt(len));

    if (len == 1) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
