module TestEntitySimple;

// Test: Simple entity

class Point {
    expose Integer x;
    expose Integer y;

    expose func init(px: Integer, py: Integer) {
        x = px;
        y = py;
    }

    expose func getSum() -> Integer {
        return x + y;
    }
}

func start() {
    Zanna.Terminal.Say("=== Entity Simple Test ===");

    var p: Point = new Point(10, 20);
    Zanna.Terminal.Say("x = " + Zanna.String.FromInt(p.x));
    Zanna.Terminal.Say("y = " + Zanna.String.FromInt(p.y));
    Zanna.Terminal.Say("sum = " + Zanna.String.FromInt(p.getSum()));

    if (p.x == 10 && p.y == 20 && p.getSum() == 30) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
