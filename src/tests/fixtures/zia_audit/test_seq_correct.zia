module Test;

// Test: Seq with correct boxing

func start() {
    Zanna.Terminal.Say("=== Seq Correct Test ===");

    var arr = Zanna.Collections.Seq.New(5);
    Zanna.Terminal.Say("Created seq");

    Zanna.Collections.Seq.Set(arr, 0, Zanna.Core.Box.I64(10));
    Zanna.Collections.Seq.Set(arr, 1, Zanna.Core.Box.I64(20));

    var v0 = Zanna.Core.Box.ToI64(Zanna.Collections.Seq.Get(arr, 0));
    var v1 = Zanna.Core.Box.ToI64(Zanna.Collections.Seq.Get(arr, 1));

    Zanna.Terminal.Say("v0 = " + Zanna.String.FromInt(v0));
    Zanna.Terminal.Say("v1 = " + Zanna.String.FromInt(v1));

    if (v0 == 10 && v1 == 20) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
