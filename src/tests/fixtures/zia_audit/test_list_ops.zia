module TestListOps;

// Test: List operations

func start() {
    Zanna.Terminal.Say("=== List Operations Test ===");

    var list: Zanna.Collections.List = Zanna.Collections.List.New();
    Zanna.Collections.List.Push(list, 100);
    Zanna.Collections.List.Push(list, 200);

    var count: Integer = Zanna.Collections.List.get_Count(list);
    Zanna.Terminal.Say("Count: " + Zanna.String.FromInt(count));

    var v0: Integer = Zanna.Core.Box.ToI64(Zanna.Collections.List.Get(list, 0));
    var v1: Integer = Zanna.Core.Box.ToI64(Zanna.Collections.List.Get(list, 1));

    Zanna.Terminal.Say("v0 = " + Zanna.String.FromInt(v0));
    Zanna.Terminal.Say("v1 = " + Zanna.String.FromInt(v1));

    if (count == 2 && v0 == 100 && v1 == 200) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
