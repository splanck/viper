module TestSeq;

// Test: Seq collection

func start() {
    Zanna.Terminal.Say("=== Seq Collection Test ===");

    var arr: Zanna.Collections.Seq = Zanna.Collections.Seq.New(5);
    Zanna.Collections.Seq.Set(arr, 0, 10);
    Zanna.Collections.Seq.Set(arr, 1, 20);
    Zanna.Collections.Seq.Set(arr, 2, 30);

    var v0: Integer = Zanna.Core.Box.ToI64(Zanna.Collections.Seq.Get(arr, 0));
    var v1: Integer = Zanna.Core.Box.ToI64(Zanna.Collections.Seq.Get(arr, 1));
    var v2: Integer = Zanna.Core.Box.ToI64(Zanna.Collections.Seq.Get(arr, 2));

    Zanna.Terminal.Say("v0 = " + Zanna.String.FromInt(v0));
    Zanna.Terminal.Say("v1 = " + Zanna.String.FromInt(v1));
    Zanna.Terminal.Say("v2 = " + Zanna.String.FromInt(v2));

    if (v0 == 10 && v1 == 20 && v2 == 30) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
