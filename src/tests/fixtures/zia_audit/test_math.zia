module TestMath;

// Test: Zanna.Math runtime class

var passed: Integer = 0;
var failed: Integer = 0;

func checkNum(name: String, actual: Number, expected: Number, epsilon: Number) {
    var diff: Number = actual - expected;
    if (diff < 0.0) { diff = 0.0 - diff; }
    if (diff < epsilon) {
        passed = passed + 1;
    } else {
        failed = failed + 1;
        Zanna.Terminal.Say("FAIL: " + name);
    }
}

func check(name: String, actual: Integer, expected: Integer) {
    if (actual == expected) {
        passed = passed + 1;
    } else {
        failed = failed + 1;
        Zanna.Terminal.Say("FAIL: " + name + " - expected " + Zanna.String.FromInt(expected) + ", got " + Zanna.String.FromInt(actual));
    }
}

func start() {
    Zanna.Terminal.Say("=== Zanna.Math Tests ===");

    // Constants (use get_* for property getters)
    checkNum("Pi", Zanna.Math.get_Pi(), 3.14159265, 0.0001);
    checkNum("E", Zanna.Math.get_Euler(), 2.71828182, 0.0001);
    checkNum("Tau", Zanna.Math.get_Tau(), 6.28318530, 0.0001);

    // Absolute value
    checkNum("Abs positive", Zanna.Math.Abs(5.5), 5.5, 0.001);
    checkNum("Abs negative", Zanna.Math.Abs(-5.5), 5.5, 0.001);
    checkNum("Abs zero", Zanna.Math.Abs(0.0), 0.0, 0.001);

    // Integer absolute value
    check("AbsInt positive", Zanna.Math.AbsInt(42), 42);
    check("AbsInt negative", Zanna.Math.AbsInt(-42), 42);
    check("AbsInt zero", Zanna.Math.AbsInt(0), 0);

    // Square root
    checkNum("Sqrt 4", Zanna.Math.Sqrt(4.0), 2.0, 0.001);
    checkNum("Sqrt 2", Zanna.Math.Sqrt(2.0), 1.414, 0.001);
    checkNum("Sqrt 9", Zanna.Math.Sqrt(9.0), 3.0, 0.001);

    // Power
    checkNum("Pow 2^3", Zanna.Math.Pow(2.0, 3.0), 8.0, 0.001);
    checkNum("Pow 2^0", Zanna.Math.Pow(2.0, 0.0), 1.0, 0.001);
    checkNum("Pow 3^2", Zanna.Math.Pow(3.0, 2.0), 9.0, 0.001);

    // Trigonometry
    checkNum("Sin 0", Zanna.Math.Sin(0.0), 0.0, 0.001);
    checkNum("Cos 0", Zanna.Math.Cos(0.0), 1.0, 0.001);
    checkNum("Tan 0", Zanna.Math.Tan(0.0), 0.0, 0.001);

    // Sin/Cos of Pi/2
    checkNum("Sin Pi/2", Zanna.Math.Sin(Zanna.Math.get_Pi() / 2.0), 1.0, 0.001);
    checkNum("Cos Pi/2", Zanna.Math.Cos(Zanna.Math.get_Pi() / 2.0), 0.0, 0.001);

    // Floor and Ceil
    checkNum("Floor 3.7", Zanna.Math.Floor(3.7), 3.0, 0.001);
    checkNum("Floor -3.7", Zanna.Math.Floor(-3.7), -4.0, 0.001);
    checkNum("Ceil 3.2", Zanna.Math.Ceil(3.2), 4.0, 0.001);
    checkNum("Ceil -3.2", Zanna.Math.Ceil(-3.2), -3.0, 0.001);

    // Round
    checkNum("Round 3.4", Zanna.Math.Round(3.4), 3.0, 0.001);
    checkNum("Round 3.5", Zanna.Math.Round(3.5), 4.0, 0.001);
    checkNum("Round -3.5", Zanna.Math.Round(-3.5), -4.0, 0.001);

    // Min and Max
    checkNum("Min", Zanna.Math.Min(3.0, 7.0), 3.0, 0.001);
    checkNum("Max", Zanna.Math.Max(3.0, 7.0), 7.0, 0.001);
    check("MinInt", Zanna.Math.MinInt(3, 7), 3);
    check("MaxInt", Zanna.Math.MaxInt(3, 7), 7);

    // Clamp
    checkNum("Clamp in range", Zanna.Math.Clamp(5.0, 0.0, 10.0), 5.0, 0.001);
    checkNum("Clamp below", Zanna.Math.Clamp(-5.0, 0.0, 10.0), 0.0, 0.001);
    checkNum("Clamp above", Zanna.Math.Clamp(15.0, 0.0, 10.0), 10.0, 0.001);

    // Sign (Sgn returns Number, SgnInt returns Integer)
    check("SgnInt positive", Zanna.Math.SignInt(42), 1);
    check("SgnInt negative", Zanna.Math.SignInt(-42), -1);
    check("SgnInt zero", Zanna.Math.SignInt(0), 0);

    // Logarithms
    checkNum("Log e", Zanna.Math.Log(Zanna.Math.get_Euler()), 1.0, 0.001);
    checkNum("Log10 100", Zanna.Math.Log10(100.0), 2.0, 0.001);
    checkNum("Log2 8", Zanna.Math.Log2(8.0), 3.0, 0.001);

    // Exp
    checkNum("Exp 0", Zanna.Math.Exp(0.0), 1.0, 0.001);
    checkNum("Exp 1", Zanna.Math.Exp(1.0), 2.71828, 0.001);

    // Report results
    Zanna.Terminal.Say("=== Results ===");
    Zanna.Terminal.Say("Passed: " + Zanna.String.FromInt(passed));
    Zanna.Terminal.Say("Failed: " + Zanna.String.FromInt(failed));

    if (failed == 0) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
