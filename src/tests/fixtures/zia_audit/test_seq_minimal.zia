module TestSeqMinimal;

// Test: Minimal Seq

func start() {
    Zanna.Terminal.Say("=== Seq Minimal Test ===");

    var arr: Zanna.Collections.Seq = Zanna.Collections.Seq.New(5);
    Zanna.Terminal.Say("Created seq");

    Zanna.Collections.Seq.Set(arr, 0, 10);
    Zanna.Terminal.Say("Set element");

    Zanna.Terminal.Say("RESULT: ok");
}
