module TestEntityNested;

// Test: Nested entities

class Point {
    expose Integer x;
    expose Integer y;

    expose func init(px: Integer, py: Integer) {
        x = px;
        y = py;
    }

    expose func getSum() -> Integer {
        return x + y;
    }
}

class Container {
    expose Point point;
    expose Integer value;

    expose func init(px: Integer, py: Integer, v: Integer) {
        point = new Point(px, py);
        value = v;
    }
}

func start() {
    Zanna.Terminal.Say("=== Nested Entity Test ===");

    var c: Container = new Container(5, 10, 42);
    Zanna.Terminal.Say("point.x = " + Zanna.String.FromInt(c.point.x));
    Zanna.Terminal.Say("point.y = " + Zanna.String.FromInt(c.point.y));
    Zanna.Terminal.Say("value = " + Zanna.String.FromInt(c.value));
    Zanna.Terminal.Say("point.getSum() = " + Zanna.String.FromInt(c.point.getSum()));

    if (c.point.x == 5 && c.point.y == 10 && c.value == 42 && c.point.getSum() == 15) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
