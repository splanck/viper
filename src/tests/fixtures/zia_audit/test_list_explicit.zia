module Test;

// Test: List with explicit typing

func start() {
    Zanna.Terminal.Say("=== List Explicit Test ===");

    var list: Zanna.Collections.List = Zanna.Collections.List.New();
    Zanna.Collections.List.Push(list, Zanna.Core.Box.I64(100));

    var item: Any = Zanna.Collections.List.Get(list, 0);
    Zanna.Terminal.Say("Got item");

    var value: Integer = Zanna.Core.Box.ToI64(item);
    Zanna.Terminal.Say("Value: " + Zanna.String.FromInt(value));

    if (value == 100) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
