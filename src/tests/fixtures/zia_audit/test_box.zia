module TestBox;

// Test: Zanna.Box operations

func start() {
    Zanna.Terminal.Say("=== Box Test ===");

    // Box an integer
    var boxed: Any = Zanna.Core.Box.I64(42);
    Zanna.Terminal.Say("Boxed");

    // Unbox it
    var unboxed: Integer = Zanna.Core.Box.ToI64(boxed);
    Zanna.Terminal.Say("Unboxed: " + Zanna.String.FromInt(unboxed));

    if (unboxed == 42) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
