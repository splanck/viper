module TestMatchBinding;

// Test: Match with binding

func start() {
    Zanna.Terminal.Say("=== Match Binding Test ===");

    var x: Integer = 42;
    var result: Integer = 0;

    match x {
        0 => { result = 0; }
        n => { result = n + 1; }
    }

    Zanna.Terminal.Say("Result: " + Zanna.String.FromInt(result));

    if (result == 43) {
        Zanna.Terminal.Say("RESULT: ok");
    } else {
        Zanna.Terminal.Say("RESULT: fail");
    }
}
