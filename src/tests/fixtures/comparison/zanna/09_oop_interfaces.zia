// Test: OOP - Interfaces
// Tests: interface, implements
module Test;

// Define interface
interface IShape {
    func getArea() -> Number;
    func getName() -> String;
}

// Implement interface in Circle
class Circle implements IShape {
    expose Number radius;

    expose func init(r: Number) {
        radius = r;
    }

    expose func getArea() -> Number {
        return 3.14159 * radius * radius;
    }

    expose func getName() -> String {
        return "Circle";
    }

    expose func getRadius() -> Number {
        return radius;
    }
}

// Implement interface in Rectangle
class Rectangle implements IShape {
    expose Number width;
    expose Number height;

    expose func init(w: Number, h: Number) {
        width = w;
        height = h;
    }

    expose func getArea() -> Number {
        return width * height;
    }

    expose func getName() -> String {
        return "Rectangle";
    }
}

func main() {
    Zanna.Terminal.Say("=== OOP Interfaces Test ===");

    // Test Circle
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Circle ---");
    var c = new Circle(5.0);
    Zanna.Terminal.Say("Shape: " + c.getName());
    Zanna.Terminal.Print("Area: ");
    Zanna.Terminal.SayNum(c.getArea());
    Zanna.Terminal.Print("Radius: ");
    Zanna.Terminal.SayNum(c.getRadius());

    // Test Rectangle
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Rectangle ---");
    var r = new Rectangle(4.0, 6.0);
    Zanna.Terminal.Say("Shape: " + r.getName());
    Zanna.Terminal.Print("Area: ");
    Zanna.Terminal.SayNum(r.getArea());

    // Test polymorphism through interface
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Polymorphism via Interface ---");
    // var shape: IShape = c;  // May not work
    // Zanna.Terminal.Say("As IShape (circle): " + shape.getName());
    Zanna.Terminal.Say("Testing interface variable assignment...");

    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== OOP Interfaces test complete ===");
}
