// Test: Control Flow
// Tests: if, for, while, break, continue
// NOTE: String concat with Zanna.Text.Fmt.Int in loops causes crash (BUG)
module Test;

func main() {
    // IF statement
    Zanna.Terminal.Say("=== IF Statement ===");
    var x = 5;

    if (x > 10) {
        Zanna.Terminal.Say("x > 10");
    } else if (x > 3) {
        Zanna.Terminal.Say("x > 3 but <= 10");
    } else {
        Zanna.Terminal.Say("x <= 3");
    }

    // Simple if
    if (x == 5) {
        Zanna.Terminal.Say("x is 5");
    }

    // FOR loop (using SayInt to avoid concat bug)
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== FOR Loop ===");
    for (var i = 1; i <= 5; i = i + 1) {
        Zanna.Terminal.Print("  i = ");
        Zanna.Terminal.SayInt(i);
    }

    // FOR with decrement
    Zanna.Terminal.Say("FOR with decrement:");
    for (var i = 10; i >= 2; i = i - 2) {
        Zanna.Terminal.Print("  i = ");
        Zanna.Terminal.SayInt(i);
    }

    // WHILE loop
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== WHILE Loop ===");
    var n = 1;
    while (n <= 3) {
        Zanna.Terminal.Print("  n = ");
        Zanna.Terminal.SayInt(n);
        n = n + 1;
    }

    // BREAK
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== BREAK ===");
    for (var i = 1; i <= 10; i = i + 1) {
        if (i == 5) {
            break;
        }
        Zanna.Terminal.Print("  i = ");
        Zanna.Terminal.SayInt(i);
    }
    Zanna.Terminal.Say("Exited with break");

    // CONTINUE
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== CONTINUE ===");
    for (var i = 1; i <= 5; i = i + 1) {
        if (i == 3) {
            continue;
        }
        Zanna.Terminal.Print("  i = ");
        Zanna.Terminal.SayInt(i);
    }
    Zanna.Terminal.Say("Skipped i=3");

    // Nested loops
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== Nested Loops ===");
    for (var i = 1; i <= 2; i = i + 1) {
        for (var j = 1; j <= 2; j = j + 1) {
            Zanna.Terminal.Print("  (");
            Zanna.Terminal.Print(Zanna.Text.Fmt.Int(i));
            Zanna.Terminal.Print(",");
            Zanna.Terminal.Print(Zanna.Text.Fmt.Int(j));
            Zanna.Terminal.Say(")");
        }
    }

    Zanna.Terminal.Say("=== Control flow test complete ===");
}
