// Test: OOP - Entities (Classes)
// Tests: entity, fields, methods
// NOTE: ZannaLang uses init() method instead of explicit constructors
module Test;

// Simple entity with fields and methods
class Point {
    expose Number x;
    expose Number y;

    expose func init(px: Number, py: Number) {
        x = px;
        y = py;
    }

    expose func distance() -> Number {
        return Zanna.Math.Sqrt(x * x + y * y);
    }

    expose func move(dx: Number, dy: Number) {
        x = x + dx;
        y = y + dy;
    }

    expose func toString() -> String {
        return "(" + Zanna.Text.Fmt.Num(x) + ", " + Zanna.Text.Fmt.Num(y) + ")";
    }
}

// Entity with private fields
class Counter {
    hide Integer count;

    expose func init() {
        count = 0;
    }

    expose func increment() {
        count = count + 1;
    }

    expose func decrement() {
        count = count - 1;
    }

    expose func getCount() -> Integer {
        return count;
    }

    expose func reset() {
        count = 0;
    }
}

// Entity demonstrating field access
class Circle {
    expose Number radius;

    expose func init(r: Number) {
        radius = r;
    }

    expose func area() -> Number {
        return 3.14159 * radius * radius;
    }

    expose func circumference() -> Number {
        return 2.0 * 3.14159 * radius;
    }
}

func main() {
    Zanna.Terminal.Say("=== OOP Entities Test ===");

    // Test Point entity
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Point entity ---");
    var p = new Point(3.0, 4.0);
    Zanna.Terminal.Say("Point: " + p.toString());
    Zanna.Terminal.Print("Distance from origin: ");
    Zanna.Terminal.SayNum(p.distance());
    p.move(1.0, 1.0);
    Zanna.Terminal.Say("After move(1,1): " + p.toString());

    // Test Counter entity
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Counter entity ---");
    var c = new Counter();
    Zanna.Terminal.Print("Initial count: ");
    Zanna.Terminal.SayInt(c.getCount());
    c.increment();
    c.increment();
    c.increment();
    Zanna.Terminal.Print("After 3 increments: ");
    Zanna.Terminal.SayInt(c.getCount());
    c.decrement();
    Zanna.Terminal.Print("After decrement: ");
    Zanna.Terminal.SayInt(c.getCount());

    // Test Circle entity
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Circle entity ---");
    var circle = new Circle(5.0);
    Zanna.Terminal.Print("Circle radius: ");
    Zanna.Terminal.SayNum(circle.radius);
    Zanna.Terminal.Print("Area: ");
    Zanna.Terminal.SayNum(circle.area());
    Zanna.Terminal.Print("Circumference: ");
    Zanna.Terminal.SayNum(circle.circumference());

    // No destructor test - ZannaLang uses GC
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Destructor ---");
    Zanna.Terminal.Say("ZannaLang: No destructors (uses garbage collection)");

    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== OOP Entities test complete ===");
}
