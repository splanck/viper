// Test: Error Handling
// Tests: guard statement, optional types
module Test;

func divide(a: Number, b: Number) -> Number {
    guard (b != 0.0) else {
        Zanna.Terminal.Say("Error: Division by zero!");
        return 0.0;
    }
    return a / b;
}

func main() {
    Zanna.Terminal.Say("=== Error Handling Test ===");

    // Test guard statement
    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("--- Guard Statement ---");
    Zanna.Terminal.Print("10 / 2 = ");
    Zanna.Terminal.SayNum(divide(10.0, 2.0));
    Zanna.Terminal.Print("10 / 0 = ");
    Zanna.Terminal.SayNum(divide(10.0, 0.0));

    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("ZannaLang: No try/catch (use guard or Result types)");

    Zanna.Terminal.Say("");
    Zanna.Terminal.Say("=== Error Handling test complete ===");
}
