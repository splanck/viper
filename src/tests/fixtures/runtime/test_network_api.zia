// Test: Network API - URL parsing, DNS, TcpServer, RetryPolicy, RateLimiter
module TestNetworkApi;

bind Zanna.Terminal;

func start() {
    // === Test 1: URL parsing ===
    var url = Zanna.Network.Url.Parse("https://example.com:8080/path?q=1#frag");
    var scheme = Zanna.Network.Url.get_Scheme(url);
    var host = Zanna.Network.Url.get_Host(url);
    var port = Zanna.Network.Url.get_Port(url);
    var path = Zanna.Network.Url.get_Path(url);

    if (port != 8080) {
        Say("FAIL: URL port should be 8080");
        return;
    }

    // === Test 2: URL builder ===
    var url2 = Zanna.Network.Url.New();
    Zanna.Network.Url.set_Scheme(url2, "http");
    Zanna.Network.Url.set_Host(url2, "localhost");
    Zanna.Network.Url.set_Port(url2, 3000);
    Zanna.Network.Url.set_Path(url2, "/api");

    var s2 = Zanna.Network.Url.get_Scheme(url2);
    var h2 = Zanna.Network.Url.get_Host(url2);
    var p2 = Zanna.Network.Url.get_Port(url2);

    if (p2 != 3000) {
        Say("FAIL: built URL port should be 3000");
        return;
    }

    // === Test 3: DNS utilities (no network needed) ===
    var isIp = Zanna.Network.Dns.IsIpv4("192.168.1.1");
    if (isIp != true) {
        Say("FAIL: 192.168.1.1 should be valid IPv4");
        return;
    }

    var notIp = Zanna.Network.Dns.IsIpv4("not-an-ip");
    if (notIp != false) {
        Say("FAIL: 'not-an-ip' should not be IPv4");
        return;
    }

    var isIp6 = Zanna.Network.Dns.IsIpv6("::1");
    if (isIp6 != true) {
        Say("FAIL: ::1 should be valid IPv6");
        return;
    }

    var isIP = Zanna.Network.Dns.IsIP("10.0.0.1");
    if (isIP != true) {
        Say("FAIL: 10.0.0.1 should be a valid IP");
        return;
    }

    // === Test 4: RetryPolicy ===
    var retry = Zanna.Network.RetryPolicy.New(3, 100);
    var maxRetries = Zanna.Network.RetryPolicy.get_MaxRetries(retry);
    if (maxRetries != 3) {
        Say("FAIL: max retries should be 3");
        return;
    }

    var canRetry = Zanna.Network.RetryPolicy.get_CanRetry(retry);
    if (canRetry != true) {
        Say("FAIL: should be able to retry initially");
        return;
    }

    var attempt = Zanna.Network.RetryPolicy.get_Attempt(retry);
    if (attempt != 0) {
        Say("FAIL: initial attempt should be 0");
        return;
    }

    // Consume retries
    Zanna.Network.RetryPolicy.NextDelay(retry);
    Zanna.Network.RetryPolicy.NextDelay(retry);
    Zanna.Network.RetryPolicy.NextDelay(retry);

    var exhausted = Zanna.Network.RetryPolicy.get_IsExhausted(retry);
    if (exhausted != true) {
        Say("FAIL: should be exhausted after 3 retries");
        return;
    }

    // Reset
    Zanna.Network.RetryPolicy.Reset(retry);
    var canRetryAfterReset = Zanna.Network.RetryPolicy.get_CanRetry(retry);
    if (canRetryAfterReset != true) {
        Say("FAIL: should be able to retry after reset");
        return;
    }

    // === Test 5: RateLimiter ===
    var limiter = Zanna.Network.RateLimiter.New(2, 1.0);
    var maxLim = Zanna.Network.RateLimiter.get_Max(limiter);
    if (maxLim != 2) {
        Say("FAIL: rate limiter max should be 2");
        return;
    }

    // Acquire twice
    var a1 = Zanna.Network.RateLimiter.TryAcquire(limiter);
    var a2 = Zanna.Network.RateLimiter.TryAcquire(limiter);
    if (a1 != true) {
        Say("FAIL: first acquire should succeed");
        return;
    }
    if (a2 != true) {
        Say("FAIL: second acquire should succeed");
        return;
    }

    // Third should fail (exhausted)
    var a3 = Zanna.Network.RateLimiter.TryAcquire(limiter);
    if (a3 != false) {
        Say("FAIL: third acquire should fail");
        return;
    }

    Say("RESULT: ok");
}
