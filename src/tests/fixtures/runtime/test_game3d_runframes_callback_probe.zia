module test_game3d_runframes_callback_probe;

bind Zanna.Game3D as Game3D;
bind Zanna.Terminal as Terminal;

var frameCallbackCount: Integer = 0;
var frameCallbackDtMismatch: Boolean = false;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) {
        d = 0.0 - d;
    }
    return d <= eps;
}

func onFrame(dt: Float) {
    frameCallbackCount = frameCallbackCount + 1;
    if (near(dt, 0.016, 0.0001) == false) {
        frameCallbackDtMismatch = true;
    }
}

func start() {
    var world = Game3D.World3D.New("Game3D RunFrames Callback Probe", 32, 24);
    world.RunFrames(3, 0.016, &onFrame);

    if (frameCallbackCount != 3) {
        fail("runFrames callback count was " + toString(frameCallbackCount));
        return;
    }
    if (frameCallbackDtMismatch) {
        fail("runFrames callback received the wrong fixed dt");
        return;
    }
    if (world.Frame != 3) {
        fail("runFrames did not advance the frame counter");
        return;
    }

    world.Destroy();
    Terminal.Say("RESULT: ok");
    Terminal.Say("PASS");
}
