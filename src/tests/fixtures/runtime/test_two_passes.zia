// Test: Two Begin/End pairs without RTT — does Metal render in both?
module TestTwoPasses;

bind Zanna.Terminal;

func start() {
    var canvas = Zanna.Graphics3D.Canvas3D.New("Two Pass Test", 640, 480);
    var cam = Zanna.Graphics3D.Camera3D.New(60.0, 640.0 / 480.0, 0.1, 100.0);
    var eye = new Zanna.Math.Vec3(0.0, 2.0, 5.0);
    var target = new Zanna.Math.Vec3(0.0, 0.0, 0.0);
    var up = new Zanna.Math.Vec3(0.0, 1.0, 0.0);
    Zanna.Graphics3D.Camera3D.LookAt(cam, eye, target, up);

    var floor = Zanna.Graphics3D.Mesh3D.Plane(6.0, 6.0);
    var sphere = Zanna.Graphics3D.Mesh3D.Sphere(0.8, 16);
    var gray_mat = Zanna.Graphics3D.Material3D.FromColor(0.5, 0.5, 0.5);
    var red_mat = Zanna.Graphics3D.Material3D.FromColor(0.9, 0.2, 0.2);

    var sun_dir = new Zanna.Math.Vec3(-1.0, -1.0, -0.5);
    var sun = Zanna.Graphics3D.Light3D.Directional(sun_dir, 1.0, 1.0, 1.0);
    Zanna.Graphics3D.Canvas3D.SetLight(canvas, 0, sun);
    Zanna.Graphics3D.Canvas3D.SetAmbient(canvas, 0.2, 0.2, 0.2);

    var floor_xform = Zanna.Math.Mat4.Translate(0.0, -1.0, 0.0);

    while (Zanna.Graphics3D.(not canvas.ShouldClose) {
        Zanna.Graphics3D.Canvas3D.Poll(canvas);

        // Pass 1: render sphere (this will be overwritten by pass 2's clear)
        Zanna.Graphics3D.Canvas3D.Clear(canvas, 0.0, 0.0, 0.3);
        Zanna.Graphics3D.Canvas3D.Begin(canvas, cam);
        Zanna.Graphics3D.Canvas3D.DrawMesh(canvas, sphere, Zanna.Math.Mat4.Identity(), red_mat);
        Zanna.Graphics3D.Canvas3D.End(canvas);

        // Pass 2: render floor (should be visible — this is the final pass)
        Zanna.Graphics3D.Canvas3D.Clear(canvas, 0.1, 0.1, 0.15);
        Zanna.Graphics3D.Canvas3D.Begin(canvas, cam);
        Zanna.Graphics3D.Canvas3D.DrawMesh(canvas, floor, floor_xform, gray_mat);
        Zanna.Graphics3D.Canvas3D.End(canvas);

        Zanna.Graphics3D.Canvas3D.Flip(canvas);
    }
}
