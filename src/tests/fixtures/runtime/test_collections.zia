module TestCollections;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zia list and map literals
// COVER: Zanna.Collections.Map
// COVER: Zanna.Collections.Stack
// COVER: Zanna.Collections.Queue
// COVER: Zanna.Collections.Ring
// COVER: Zanna.Collections.StringSet

func testListWithValues() {
    setTest("ListWithValues");

    // Initialize list with values
    var items = [1, 2, 3];
    assertEqInt(items.count(), 3, "items count");
    assertEqInt(items[0], 1, "first item");
    assertEqInt(items[2], 3, "last item");

    // Modify
    items.set(1, 20);
    assertEqInt(items[1], 20, "after set");

    // Add more
    items.add(4);
    assertEqInt(items.count(), 4, "after add");

    // Remove
    items.removeAt(0);
    assertEqInt(items.count(), 3, "after remove");
    assertEqInt(items[0], 20, "new first");
}

func testEmptyList() {
    setTest("EmptyList");

    var items = [];
    assertEqInt(items.count(), 0, "empty list");

    items.add(1);
    items.add(2);
    items.add(3);
    assertEqInt(items.count(), 3, "after adds");

    // Clear
    items.clear();
    assertEqInt(items.count(), 0, "after clear");
}

func testMapAsCollection() {
    setTest("MapAsCollection");

    var data = {"a": 1, "b": 2, "c": 3};
    assertEqInt(data.count(), 3, "map count");

    // Access
    assertEqInt(data.get("a") ?? -1, 1, "get a");
    assertEqInt(data.get("b") ?? -1, 2, "get b");

    // Check existence
    assertTrue(data.has("a"), "has a");
    assertFalse(data.has("x"), "not has x");

    // GetOr with default
    assertEqInt(data.getOr("x", 99), 99, "getOr default");
    assertEqInt(data.getOr("a", 99), 1, "getOr existing");

    // Remove
    assertTrue(data.remove("b"), "remove existing");
    assertFalse(data.has("b"), "b removed");
    assertEqInt(data.count(), 2, "count after remove");
}

func testNestedLists() {
    setTest("NestedLists");

    // List of lists
    var matrix = [[1, 2], [3, 4], [5, 6]];
    assertEqInt(matrix.count(), 3, "matrix rows");
    assertEqInt(matrix[0][0], 1, "element [0][0]");
    assertEqInt(matrix[1][1], 4, "element [1][1]");
    assertEqInt(matrix[2][0], 5, "element [2][0]");
}

func testNestedMapList() {
    setTest("NestedMapList");

    // Map with list values
    var groups = {"evens": [2, 4, 6], "odds": [1, 3, 5]};
    assertEqInt((groups.get("evens") ?? [])[0], 2, "evens first");
    assertEqInt((groups.get("odds") ?? [])[2], 5, "odds third");
}

func testRuntimeCollections() {
    setTest("RuntimeCollections");

    var stack = new Zanna.Collections.Stack();
    assertTrue(stack.IsEmpty, "stack starts empty");
    stack.Push("a");
    stack.Push("b");
    assertEqInt(stack.Count, 2, "stack length");
    stack.Pop();
    assertEqInt(stack.Count, 1, "stack pop length");

    var queue = new Zanna.Collections.Queue();
    queue.Push("a");
    queue.Push("b");
    assertEqInt(queue.Count, 2, "queue length");
    queue.Pop();
    assertEqInt(queue.Count, 1, "queue pop length");

    var ring = new Zanna.Collections.Ring();
    assertGtInt(ring.Capacity, 0, "ring default cap");
    ring.Push("a");
    ring.Push("b");
    assertEqInt(ring.Count, 2, "ring length");

    var bag = new Zanna.Collections.StringSet();
    bag.Add("apple");
    bag.Add("banana");
    assertEqInt(bag.Count, 2, "bag length");
    assertTrue(bag.Has("apple"), "bag has item");
    assertEqInt(bag.ToSeq().Count, 2, "bag items length");

    var map = new Zanna.Collections.Map();
    map.SetStr("name", "zia");
    map.SetInt("version", 1);
    map.SetBool("ready", true);
    assertEqStr(map.GetStr("name"), "zia", "map typed string");
    assertEqInt(map.GetInt("version"), 1, "map typed int");
    assertTrue(map.GetBool("ready"), "map typed bool");
    assertEqInt(map.Keys().Count, 3, "map keys length");
}

func start() {
    testListWithValues();
    testEmptyList();
    testMapAsCollection();
    testNestedLists();
    testNestedMapList();
    testRuntimeCollections();

    report();
}
