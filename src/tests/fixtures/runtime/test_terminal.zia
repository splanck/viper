module TestTerminal;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Terminal.Say
// COVER: Zanna.Terminal.SayInt
// COVER: Zanna.Terminal.SayNum
// COVER: Zanna.Terminal.SayBool
// COVER: Zanna.Terminal.Print
// COVER: Zanna.Terminal.PrintInt
// COVER: Zanna.Terminal.PrintNum
// COVER: Zanna.Terminal.Clear
// COVER: Zanna.Terminal.SetColor
// COVER: Zanna.Terminal.SetPosition
// COVER: Zanna.Terminal.BeginBatch
// COVER: Zanna.Terminal.EndBatch
// COVER: Zanna.Terminal.Flush
// COVER: Zanna.Terminal.Bell
// COVER: Zanna.Terminal.SetCursorVisible
// COVER: Zanna.Terminal.SetAltScreen
// COVER: Zanna.Terminal.GetKeyTimeout
// COVER: Zanna.Terminal.InKey

func testBasicOutput() {
    setTest("BasicOutput");

    // Test Say (with newline)
    Zanna.Terminal.Say("Testing Say");
    pass();

    // Test SayInt
    Zanna.Terminal.SayInt(42);
    pass();

    // Test SayNum
    Zanna.Terminal.SayNum(3.14);
    pass();

    // Test SayBool
    Zanna.Terminal.SayBool(true);
    Zanna.Terminal.SayBool(false);
    pass();
}

func testPrint() {
    setTest("Print");

    // Test Print (no newline)
    Zanna.Terminal.Print("Hello ");
    Zanna.Terminal.Print("World");
    Zanna.Terminal.Say("");  // newline
    pass();

    // Test PrintInt
    Zanna.Terminal.PrintInt(123);
    Zanna.Terminal.Say("");
    pass();

    // Test PrintNum
    Zanna.Terminal.PrintNum(2.718);
    Zanna.Terminal.Say("");
    pass();
}

func testBatching() {
    setTest("Batching");

    // Batch operations should work without error
    Zanna.Terminal.BeginBatch();
    Zanna.Terminal.Say("Inside batch 1");
    Zanna.Terminal.Say("Inside batch 2");
    Zanna.Terminal.EndBatch();
    pass();
}

func testScreenControl() {
    setTest("ScreenControl");

    // These are visual operations, we just verify they don't crash
    Zanna.Terminal.BeginBatch();

    // Clear screen
    Zanna.Terminal.Clear();
    pass();

    // Set color (fg, bg)
    Zanna.Terminal.SetColor(7, 0);  // white on black
    pass();

    // Set cursor position
    Zanna.Terminal.SetPosition(1, 1);
    pass();

    // Flush output
    Zanna.Terminal.Flush();
    pass();

    Zanna.Terminal.EndBatch();
}

func testCursorControl() {
    setTest("CursorControl");

    // Show/hide cursor (just verify no crash)
    Zanna.Terminal.SetCursorVisible(false);  // hide
    Zanna.Terminal.SetCursorVisible(true);  // show
    pass();
}

func testAltScreen() {
    setTest("AltScreen");

    // Alt screen (0 = normal, 1 = alternate)
    Zanna.Terminal.SetAltScreen(false);  // ensure normal screen
    pass();
}

func testInputNonBlocking() {
    setTest("InputNonBlocking");

    // Non-blocking input test
    var key1 = Zanna.Terminal.ReadKeyFor(0);  // 0ms timeout
    assertTrue(key1 == "" || key1 == key1, "GetKeyTimeout returns string");

    var key2 = Zanna.Terminal.PollKey();  // returns immediately
    assertTrue(key2 == "" || key2 == key2, "InKey returns string");
}

func testBell() {
    setTest("Bell");

    // Bell (may or may not produce sound)
    Zanna.Terminal.Bell();
    pass();
}

func start() {
    testBasicOutput();
    testPrint();
    testBatching();
    testScreenControl();
    testCursorControl();
    testAltScreen();
    testInputNonBlocking();
    testBell();

    report();
}
