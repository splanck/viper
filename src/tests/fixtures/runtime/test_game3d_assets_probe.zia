module test_game3d_assets_probe;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D as G3D;
bind Zanna.Terminal as Terminal;
bind Zanna.Threads.Thread as Thread;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    var path = "src/tests/fixtures/runtime/assets/gltf/load_asset_triangle.gltf";
    Game3D.Assets3D.ClearCache();

    var entity: Game3D.Entity3D = Game3D.Assets3D.LoadEntity(path);
    if (entity == null || entity.IsGroup() == false ||
        entity.Node.ChildCount != 1) {
        fail("LoadEntity did not return an imported group entity");
        return;
    }

    var assetEntity: Game3D.Entity3D = Game3D.Assets3D.LoadEntityAsset(path);
    if (assetEntity == null ||
        assetEntity.Node.ChildCount != 1) {
        fail("LoadEntityAsset did not instantiate through asset resolver");
        return;
    }
    assetEntity.Name = "AssetProbeImport";
    var world = Game3D.World3D.New("Game3D Asset Lifetime Probe", 64, 48);
    var i = 0;
    while (i < 4) {
        var loopEntity: Game3D.Entity3D = Game3D.Assets3D.LoadEntityAsset(path);
        if (loopEntity == null ||
            loopEntity.Node.ChildCount != 1) {
            fail("LoadEntityAsset did not create a fresh asset group");
            return;
        }
        loopEntity.Name = "AssetProbeImport";
        world.Spawn(loopEntity);
        if (world.EntityCount != 1 ||
            world.FindEntity("AssetProbeImport").IsNone) {
            fail("imported asset group did not spawn/index cleanly");
            return;
        }
        world.Despawn(loopEntity);
        if (world.EntityCount != 0 ||
            world.FindEntity("AssetProbeImport").IsSome) {
            fail("imported asset group despawn leaked world registry state");
            return;
        }
        i = i + 1;
    }
    world.Destroy();

    var tpl1: Game3D.SceneTemplate = Zanna.Game3D.Prefab.Load(path);
    var tpl2: Game3D.SceneTemplate = Zanna.Game3D.Prefab.Load(path);
    if (tpl1 == null || tpl2 == null) {
        fail("LoadTemplate did not return cached templates");
        return;
    }
    if (G3D.SceneAsset.get_MeshCount(tpl1.Model) != 1 ||
        G3D.SceneAsset.get_MeshCount(tpl2.Model) != 1) {
        fail("SceneTemplate lost mesh data");
        return;
    }

    var inst: Game3D.Entity3D = tpl1.Instantiate();
    if (inst == null || inst.IsGroup() == false ||
        inst.Node.ChildCount != 1) {
        fail("SceneTemplate.instantiate did not clone the model subtree");
        return;
    }

    var assetTpl: Game3D.SceneTemplate = Zanna.Game3D.Prefab.LoadAsset(path);
    if (assetTpl == null || assetTpl.IsAsset == false) {
        fail("LoadTemplateAsset did not record asset path");
        return;
    }

    var missing: Game3D.AssetHandle3D = Zanna.Game3D.Prefab.LoadAssetAsync("zanna/missing/co3_missing.gltf");
    if (missing == null) {
        fail("missing package asset did not return a diagnostic handle");
        return;
    }
    var missingReady = missing.IsReady;
    var wait = 0;
    while (missingReady == false && wait < 40) {
        Thread.Sleep(5);
        missingReady = missing.IsReady;
        wait = wait + 1;
    }
    if (missingReady == false ||
        missing.Error != "failed to load model asset" ||
        missing.GetPrefab() != null) {
        fail("missing package asset did not produce a terminal diagnostic handle");
        return;
    }

    Game3D.Assets3D.Preload(path);
    Game3D.Assets3D.ClearCache();
    var tpl3: Game3D.SceneTemplate = Zanna.Game3D.Prefab.Load(path);
    if (tpl3 == null) {
        fail("LoadTemplate failed after ClearCache");
        return;
    }
    Game3D.Assets3D.ClearCache();
    Terminal.Say("PASS");
}
