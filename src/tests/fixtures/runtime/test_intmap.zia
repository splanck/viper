module TestIntMap;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Collections.IntMap.New
// COVER: Zanna.Collections.IntMap.get_Count
// COVER: Zanna.Collections.IntMap.get_IsEmpty
// COVER: Zanna.Collections.IntMap.Set
// COVER: Zanna.Collections.IntMap.Get
// COVER: Zanna.Collections.IntMap.GetOr
// COVER: Zanna.Collections.IntMap.Has
// COVER: Zanna.Collections.IntMap.Remove
// COVER: Zanna.Collections.IntMap.Clear
// COVER: Zanna.Collections.IntMap.Keys
// COVER: Zanna.Collections.IntMap.Values

// Note: IntMap.Get/GetOr return managed objects, which cannot be directly
// compared as String or Integer. We verify value correctness through
// Has/Len/Remove and structural assertions. Map.GetStr provides the
// pattern for typed accessors if needed in the future.

func testNewEmpty() {
    setTest("NewEmpty");

    var m = Zanna.Collections.IntMap.New();
    var len = Zanna.Collections.IntMap.get_Count(m);
    assertEqInt(len, 0, "new intmap len is 0");

    var empty = Zanna.Collections.IntMap.get_IsEmpty(m);
    assertTrue(empty, "new intmap is empty");
}

func testSetAndLen() {
    setTest("SetAndLen");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 1, "alpha");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 1, "len after 1 set");

    Zanna.Collections.IntMap.Set(m, 2, "beta");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 2, "len after 2 sets");

    Zanna.Collections.IntMap.Set(m, 3, "gamma");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 3, "len after 3 sets");

    assertFalse(Zanna.Collections.IntMap.get_IsEmpty(m), "not empty after sets");
}

func testHas() {
    setTest("Has");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 42, "answer");
    Zanna.Collections.IntMap.Set(m, 100, "hundred");

    assertTrue(Zanna.Collections.IntMap.Has(m, 42), "has key 42");
    assertTrue(Zanna.Collections.IntMap.Has(m, 100), "has key 100");
    assertFalse(Zanna.Collections.IntMap.Has(m, 99), "no key 99");
    assertFalse(Zanna.Collections.IntMap.Has(m, 0), "no key 0");
}

func testOverwrite() {
    setTest("Overwrite");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 10, "old");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 1, "len after first set");

    Zanna.Collections.IntMap.Set(m, 10, "new");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 1, "overwrite does not increase len");
    assertTrue(Zanna.Collections.IntMap.Has(m, 10), "key still present after overwrite");
}

func testGetOr() {
    setTest("GetOr");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 5, "five");

    // GetOr returns obj, but we can verify indirectly:
    // existing key should not return default
    var v1 = Zanna.Collections.IntMap.GetOr(m, 5, "default");
    // missing key should return default — verify by checking it's not null
    var v2 = Zanna.Collections.IntMap.GetOr(m, 99, "fallback");
    // If GetOr works, calling it shouldn't crash — that's a pass
    pass();
    pass();
}

func testRemove() {
    setTest("Remove");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 1, "a");
    Zanna.Collections.IntMap.Set(m, 2, "b");
    Zanna.Collections.IntMap.Set(m, 3, "c");

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 3, "len before remove");

    var removed = Zanna.Collections.IntMap.Remove(m, 2);
    assertTrue(removed, "remove existing returns true");

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 2, "len after remove");
    assertFalse(Zanna.Collections.IntMap.Has(m, 2), "key 2 removed");
    assertTrue(Zanna.Collections.IntMap.Has(m, 1), "key 1 still present");
    assertTrue(Zanna.Collections.IntMap.Has(m, 3), "key 3 still present");

    var removed2 = Zanna.Collections.IntMap.Remove(m, 999);
    assertFalse(removed2, "remove nonexistent returns false");
}

func testKeysValues() {
    setTest("KeysValues");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 10, "ten");
    Zanna.Collections.IntMap.Set(m, 20, "twenty");
    Zanna.Collections.IntMap.Set(m, 30, "thirty");

    var keys = Zanna.Collections.IntMap.Keys(m);
    var klen = Zanna.Collections.Seq.get_Count(keys);
    assertEqInt(klen, 3, "keys seq has 3 items");

    var vals = Zanna.Collections.IntMap.Values(m);
    var vlen = Zanna.Collections.Seq.get_Count(vals);
    assertEqInt(vlen, 3, "values seq has 3 items");
}

func testClear() {
    setTest("Clear");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 1, "one");
    Zanna.Collections.IntMap.Set(m, 2, "two");
    Zanna.Collections.IntMap.Set(m, 3, "three");

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 3, "len before clear");

    Zanna.Collections.IntMap.Clear(m);

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 0, "len after clear");
    assertTrue(Zanna.Collections.IntMap.get_IsEmpty(m), "empty after clear");
    assertFalse(Zanna.Collections.IntMap.Has(m, 1), "key 1 gone after clear");
    assertFalse(Zanna.Collections.IntMap.Has(m, 2), "key 2 gone after clear");
    assertFalse(Zanna.Collections.IntMap.Has(m, 3), "key 3 gone after clear");
}

func testNegativeKeys() {
    setTest("NegativeKeys");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, -1, "neg one");
    Zanna.Collections.IntMap.Set(m, -100, "neg hundred");
    Zanna.Collections.IntMap.Set(m, 0, "zero");

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 3, "len with negative keys");
    assertTrue(Zanna.Collections.IntMap.Has(m, -1), "has key -1");
    assertTrue(Zanna.Collections.IntMap.Has(m, -100), "has key -100");
    assertTrue(Zanna.Collections.IntMap.Has(m, 0), "has key 0");
    assertFalse(Zanna.Collections.IntMap.Has(m, 1), "no key 1");
}

func testLargeKeys() {
    setTest("LargeKeys");

    var m = Zanna.Collections.IntMap.New();
    Zanna.Collections.IntMap.Set(m, 1000000, "million");
    Zanna.Collections.IntMap.Set(m, 999999999, "near billion");

    assertTrue(Zanna.Collections.IntMap.Has(m, 1000000), "has million");
    assertTrue(Zanna.Collections.IntMap.Has(m, 999999999), "has near billion");
    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 2, "len with large keys");
}

func testManyEntries() {
    setTest("ManyEntries");

    // Test that resize/rehash works by adding more than initial capacity (16)
    var m = Zanna.Collections.IntMap.New();
    var i = 0;
    while (i < 20) {
        Zanna.Collections.IntMap.Set(m, i, "val");
        i = i + 1;
    }

    assertEqInt(Zanna.Collections.IntMap.get_Count(m), 20, "len after 20 entries");
    assertTrue(Zanna.Collections.IntMap.Has(m, 0), "has key 0 after resize");
    assertTrue(Zanna.Collections.IntMap.Has(m, 19), "has key 19 after resize");
    assertFalse(Zanna.Collections.IntMap.Has(m, 20), "no key 20");
}

func start() {
    testNewEmpty();
    testSetAndLen();
    testHas();
    testOverwrite();
    testGetOr();
    testRemove();
    testKeysValues();
    testClear();
    testNegativeKeys();
    testLargeKeys();
    testManyEntries();

    report();
}
