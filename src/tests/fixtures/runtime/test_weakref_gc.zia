// Test: WeakMap and GC cycle collection
module TestWeakRefGc;

bind Zanna.Terminal;

func start() {
    // === Test 1: GC stats ===
    var passes = Zanna.Runtime.GC.PassCount();
    if (passes < 0) { Say("FAIL: PassCount should be >= 0"); return; }

    var tracked = Zanna.Runtime.GC.TrackedCount();
    if (tracked < 0) { Say("FAIL: TrackedCount should be >= 0"); return; }

    var totalCollected = Zanna.Runtime.GC.TotalCollected();
    if (totalCollected < 0) { Say("FAIL: TotalCollected should be >= 0"); return; }

    // === Test 2: GC collect ===
    var freed = Zanna.Runtime.GC.Collect();
    if (freed < 0) { Say("FAIL: Collect should return >= 0"); return; }

    // PassCount should increment
    var passes2 = Zanna.Runtime.GC.PassCount();
    if (passes2 < passes + 1) { Say("FAIL: PassCount should increment after Collect"); return; }

    // === Test 3: WeakMap creation ===
    var wmap = Zanna.Collections.WeakMap.New();
    if (wmap == null) { Say("FAIL: WeakMap.New should return non-null"); return; }

    var isEmpty = Zanna.Collections.WeakMap.get_IsEmpty(wmap);
    if (isEmpty != true) { Say("FAIL: new WeakMap should be empty"); return; }

    // === Test 4: Set and Get ===
    var val = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(val, 99);
    Zanna.Collections.WeakMap.Set(wmap, "test_key", val);

    var wmLen = Zanna.Collections.WeakMap.get_Count(wmap);
    if (wmLen != 1) { Say("FAIL: WeakMap Len should be 1"); return; }

    var has = Zanna.Collections.WeakMap.Has(wmap, "test_key");
    if (has != true) { Say("FAIL: WeakMap should have test_key"); return; }

    var hasNot = Zanna.Collections.WeakMap.Has(wmap, "no_key");
    if (hasNot != false) { Say("FAIL: WeakMap should not have no_key"); return; }

    var gotVal = Zanna.Collections.WeakMap.Get(wmap, "test_key");
    if (gotVal == null) { Say("FAIL: WeakMap.Get should return value"); return; }

    // === Test 5: WeakMap keys ===
    var keys = Zanna.Collections.WeakMap.Keys(wmap);
    var kLen = Zanna.Collections.Seq.get_Count(keys);
    if (kLen != 1) { Say("FAIL: WeakMap Keys should have 1 entry"); return; }

    // === Test 6: Multiple entries ===
    Zanna.Collections.WeakMap.Set(wmap, "key2", Zanna.Collections.Seq.New());
    Zanna.Collections.WeakMap.Set(wmap, "key3", Zanna.Collections.Seq.New());
    wmLen = Zanna.Collections.WeakMap.get_Count(wmap);
    if (wmLen != 3) { Say("FAIL: WeakMap Len should be 3"); return; }

    // === Test 7: Remove ===
    var removed = Zanna.Collections.WeakMap.Remove(wmap, "test_key");
    if (removed != true) { Say("FAIL: WeakMap Remove should return true"); return; }

    wmLen = Zanna.Collections.WeakMap.get_Count(wmap);
    if (wmLen != 2) { Say("FAIL: WeakMap Len should be 2 after remove"); return; }

    // Remove non-existent
    var removedNone = Zanna.Collections.WeakMap.Remove(wmap, "nonexistent");
    if (removedNone != false) { Say("FAIL: Remove nonexistent should return false"); return; }

    // === Test 8: Compact ===
    var compacted = Zanna.Collections.WeakMap.Compact(wmap);
    if (compacted < 0) { Say("FAIL: Compact should return >= 0"); return; }

    // === Test 9: Clear ===
    Zanna.Collections.WeakMap.Clear(wmap);
    wmLen = Zanna.Collections.WeakMap.get_Count(wmap);
    if (wmLen != 0) { Say("FAIL: WeakMap should be empty after Clear"); return; }

    isEmpty = Zanna.Collections.WeakMap.get_IsEmpty(wmap);
    if (isEmpty != true) { Say("FAIL: WeakMap should be empty after Clear"); return; }

    // === Test 10: GC after creating objects ===
    // Create some objects and collect
    var freed2 = Zanna.Runtime.GC.Collect();
    if (freed2 < 0) { Say("FAIL: second Collect should return >= 0"); return; }

    var passes3 = Zanna.Runtime.GC.PassCount();
    if (passes3 < passes2 + 1) { Say("FAIL: PassCount should increment again"); return; }

    Say("RESULT: ok");
}
