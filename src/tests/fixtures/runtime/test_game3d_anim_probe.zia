module test_game3d_anim_probe;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D;
bind Zanna.Math as Math;
bind Zanna.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func makeController(distance: Float, eventTime: Float) -> AnimController3D {
    var skel = Skeleton3D.New();
    var rootBone = Skeleton3D.AddBone(skel, "root", -1, Math.Mat4.Identity());
    Skeleton3D.ComputeInverseBind(skel);

    var rot = Math.Quat.Identity();
    var scl = Math.Vec3.One();

    var idle = Animation3D.New("idle", 1.0);
    Animation3D.set_Looping(idle, true);
    Animation3D.AddKeyframe(idle, rootBone, 0.0, Math.Vec3.Zero(), rot, scl);
    Animation3D.AddKeyframe(idle, rootBone, 1.0, Math.Vec3.Zero(), rot, scl);

    var walk = Animation3D.New("walk", 1.0);
    Animation3D.set_Looping(walk, true);
    Animation3D.AddKeyframe(walk, rootBone, 0.0, Math.Vec3.Zero(), rot, scl);
    Animation3D.AddKeyframe(walk, rootBone, 1.0, Math.Vec3.New(distance, 0.0, 0.0), rot, scl);

    var controller = AnimController3D.New(skel);
    AnimController3D.AddState(controller, "idle", idle);
    AnimController3D.AddState(controller, "walk", walk);
    AnimController3D.AddEvent(controller, "walk", eventTime, "step");
    AnimController3D.SetRootMotionBone(controller, rootBone);
    return controller;
}

func start() {
    var controller = makeController(10.0, 0.5);
    var animator = Game3D.Animator3D.New(controller);
    if (animator.Controller != controller) {
        fail("Animator3D did not expose its controller");
        return;
    }
    if (animator.Play("walk") == false ||
        animator.IsPlaying("walk") == false) {
        fail("Animator3D did not play the walk state");
        return;
    }
    animator.Update(0.5);
    if (animator.StateTime() < 0.49 ||
        animator.StateTime() > 0.51) {
        fail("Animator3D.stateTime was not updated");
        return;
    }
    if (animator.EventCount() != 1 ||
        animator.EventName(0) != "step") {
        fail("Animator3D did not capture animation events");
        return;
    }
    if (animator.Crossfade("idle", 0.1) == false ||
        animator.IsPlaying("idle") == false) {
        fail("Animator3D.crossfade did not switch states");
        return;
    }

    var world = Game3D.World3D.New("Game3D Anim Probe", 80, 60);
    var entity = Game3D.Entity3D.New();
    var controller2 = makeController(10.0, 0.25);
    var animator2 = Game3D.Animator3D.New(controller2);
    entity.AttachAnimator(animator2);
    entity.Node.SyncMode = Game3D.SyncMode.get_NodeFromAnimRootMotion();
    animator2.Play("walk");
    world.Spawn(entity);
    world.RunFramesOnly(1, 0.25);

    var pos = entity.Position;
    if (Math.Vec3.get_X(pos) < 2.4 || Math.Vec3.get_X(pos) > 2.6) {
        fail("World3D did not advance root motion before scene sync");
        return;
    }
    if (animator2.EventCount() != 1 ||
        animator2.EventName(0) != "step") {
        fail("World3D did not expose animation frame events");
        return;
    }

    var rawEntity = Game3D.Entity3D.New();
    var rawController = makeController(4.0, 0.25);
    rawEntity.AttachAnimator(rawController);
    if (rawEntity.Anim == null ||
        rawEntity.Anim.Controller != rawController) {
        fail("Entity3D.attachAnimator did not wrap raw AnimController3D");
        return;
    }

    world.Destroy();
    Terminal.Say("PASS");
}
