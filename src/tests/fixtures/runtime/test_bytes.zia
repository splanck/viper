module TestBytes;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Collections.Bytes.New
// COVER: Zanna.Collections.Bytes.Get
// COVER: Zanna.Collections.Bytes.Set
// COVER: Zanna.Collections.Bytes.get_Length
// COVER: Zanna.Collections.Bytes.FromStr
// COVER: Zanna.Collections.Bytes.ToStr
// COVER: Zanna.Collections.Bytes.Slice
// COVER: Zanna.Collections.Bytes.Copy
// COVER: Zanna.Collections.Bytes.ToHex
// COVER: Zanna.Collections.Bytes.FromHex

func testBytesNew() {
    setTest("BytesNew");

    var bytes = Zanna.Collections.Bytes.New(16);
    var len = Zanna.Collections.Bytes.get_Length(bytes);
    assertEqInt(len, 16, "bytes created with length 16");

    var bytes2 = Zanna.Collections.Bytes.New(0);
    var len2 = Zanna.Collections.Bytes.get_Length(bytes2);
    assertEqInt(len2, 0, "empty bytes");
}

func testBytesGetSet() {
    setTest("BytesGetSet");

    var bytes = Zanna.Collections.Bytes.New(4);
    Zanna.Collections.Bytes.Set(bytes, 0, 65);  // 'A'
    Zanna.Collections.Bytes.Set(bytes, 1, 66);  // 'B'
    Zanna.Collections.Bytes.Set(bytes, 2, 67);  // 'C'
    Zanna.Collections.Bytes.Set(bytes, 3, 255); // max byte value

    var b0 = Zanna.Collections.Bytes.Get(bytes, 0);
    var b1 = Zanna.Collections.Bytes.Get(bytes, 1);
    var b2 = Zanna.Collections.Bytes.Get(bytes, 2);
    var b3 = Zanna.Collections.Bytes.Get(bytes, 3);

    assertEqInt(b0, 65, "byte 0 = A");
    assertEqInt(b1, 66, "byte 1 = B");
    assertEqInt(b2, 67, "byte 2 = C");
    assertEqInt(b3, 255, "byte 3 = 255");
}

func testBytesLen() {
    setTest("BytesLen");

    var bytes = Zanna.Collections.Bytes.New(100);
    var len = Zanna.Collections.Bytes.get_Length(bytes);
    assertEqInt(len, 100, "bytes length 100");

    var small = Zanna.Collections.Bytes.New(1);
    assertEqInt(Zanna.Collections.Bytes.get_Length(small), 1, "bytes length 1");
}

func testBytesFromStr() {
    setTest("BytesFromStr");

    var bytes = Zanna.Collections.Bytes.FromStr("Hello");
    var len = Zanna.Collections.Bytes.get_Length(bytes);
    assertEqInt(len, 5, "string bytes length");

    assertEqInt(Zanna.Collections.Bytes.Get(bytes, 0), 72, "H = 72");
    assertEqInt(Zanna.Collections.Bytes.Get(bytes, 1), 101, "e = 101");
    assertEqInt(Zanna.Collections.Bytes.Get(bytes, 2), 108, "l = 108");
    assertEqInt(Zanna.Collections.Bytes.Get(bytes, 3), 108, "l = 108");
    assertEqInt(Zanna.Collections.Bytes.Get(bytes, 4), 111, "o = 111");
}

func testBytesToStr() {
    setTest("BytesToStr");

    var bytes = Zanna.Collections.Bytes.New(5);
    Zanna.Collections.Bytes.Set(bytes, 0, 72);   // H
    Zanna.Collections.Bytes.Set(bytes, 1, 101);  // e
    Zanna.Collections.Bytes.Set(bytes, 2, 108);  // l
    Zanna.Collections.Bytes.Set(bytes, 3, 108);  // l
    Zanna.Collections.Bytes.Set(bytes, 4, 111);  // o

    var str = Zanna.Collections.Bytes.ToStr(bytes);
    assertEqStr(str, "Hello", "bytes to string");
}

func testBytesSlice() {
    setTest("BytesSlice");

    var bytes = Zanna.Collections.Bytes.FromStr("Hello World");
    // Slice(obj, start, end) - end is exclusive
    var slice = Zanna.Collections.Bytes.Slice(bytes, 0, 5);
    var str = Zanna.Collections.Bytes.ToStr(slice);
    assertEqStr(str, "Hello", "slice first 5 bytes");

    var slice2 = Zanna.Collections.Bytes.Slice(bytes, 6, 11);
    var str2 = Zanna.Collections.Bytes.ToStr(slice2);
    assertEqStr(str2, "World", "slice last 5 bytes");
}

func testBytesCopy() {
    setTest("BytesCopy");

    var src = Zanna.Collections.Bytes.FromStr("ABCD");
    var dst = Zanna.Collections.Bytes.New(10);

    // Copy(dst, dstIdx, src, srcIdx, count)
    Zanna.Collections.Bytes.Copy(dst, 3, src, 0, 4);

    assertEqInt(Zanna.Collections.Bytes.Get(dst, 0), 0, "dst[0] unchanged");
    assertEqInt(Zanna.Collections.Bytes.Get(dst, 3), 65, "dst[3] = A");
    assertEqInt(Zanna.Collections.Bytes.Get(dst, 4), 66, "dst[4] = B");
    assertEqInt(Zanna.Collections.Bytes.Get(dst, 5), 67, "dst[5] = C");
    assertEqInt(Zanna.Collections.Bytes.Get(dst, 6), 68, "dst[6] = D");
}

func testBytesHex() {
    setTest("BytesHex");

    var bytes = Zanna.Collections.Bytes.New(4);
    Zanna.Collections.Bytes.Set(bytes, 0, 0xde);
    Zanna.Collections.Bytes.Set(bytes, 1, 0xad);
    Zanna.Collections.Bytes.Set(bytes, 2, 0xbe);
    Zanna.Collections.Bytes.Set(bytes, 3, 0xef);

    var hex = Zanna.Collections.Bytes.ToHex(bytes);
    assertEqStr(hex, "deadbeef", "bytes to hex");

    var parsed = Zanna.Collections.Bytes.FromHex("cafebabe");
    assertEqInt(Zanna.Collections.Bytes.get_Length(parsed), 4, "hex parse length");
    assertEqInt(Zanna.Collections.Bytes.Get(parsed, 0), 0xca, "hex byte 0");
    assertEqInt(Zanna.Collections.Bytes.Get(parsed, 1), 0xfe, "hex byte 1");
    assertEqInt(Zanna.Collections.Bytes.Get(parsed, 2), 0xba, "hex byte 2");
    assertEqInt(Zanna.Collections.Bytes.Get(parsed, 3), 0xbe, "hex byte 3");
}

func testBytesRoundtrip() {
    setTest("BytesRoundtrip");

    var original = "The quick brown fox jumps over the lazy dog";
    var bytes = Zanna.Collections.Bytes.FromStr(original);
    var restored = Zanna.Collections.Bytes.ToStr(bytes);
    assertEqStr(restored, original, "string roundtrip");
}

func start() {
    testBytesNew();
    testBytesGetSet();
    testBytesLen();
    testBytesFromStr();
    testBytesToStr();
    testBytesSlice();
    testBytesCopy();
    testBytesHex();
    testBytesRoundtrip();

    report();
}
