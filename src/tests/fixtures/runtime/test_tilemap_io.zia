// Test: Tilemap I/O, auto-tiling, and tile properties
module TestTilemapIO;

bind Zanna.Terminal;
bind Zanna.Graphics2D.Tilemap as Tilemap;

func start() {
    // Test 1: Tile properties
    var tm = Tilemap.New(4, 4, 16, 16);
    Tilemap.SetTileProperty(tm, 5, "damage", 10);
    var dmg = Tilemap.GetTileProperty(tm, 5, "damage", 0);
    if (dmg != 10) {
        Say("FAIL: tile property damage should be 10");
        return;
    }
    var has = Tilemap.HasTileProperty(tm, 5, "damage");
    if (has != true) {
        Say("FAIL: should have damage property");
        return;
    }
    var no_prop = Tilemap.GetTileProperty(tm, 5, "speed", -1);
    if (no_prop != -1) {
        Say("FAIL: non-existent prop should return default");
        return;
    }

    // Test 2: JSON save/load round-trip
    var tm2 = Tilemap.New(3, 3, 16, 16);
    Tilemap.SetTile(tm2, 0, 0, 5);
    Tilemap.SetTile(tm2, 1, 1, 10);
    Tilemap.SetTile(tm2, 2, 2, 15);
    var saved = Tilemap.Save(tm2, "/tmp/zia_test_tm.json");
    if (saved != true) {
        Say("FAIL: save should succeed");
        return;
    }
    var loaded = Tilemap.Load("/tmp/zia_test_tm.json");
    var lw = Tilemap.get_Width(loaded);
    if (lw != 3) {
        Say("FAIL: loaded width should be 3");
        return;
    }
    var lt = Tilemap.GetTile(loaded, 1, 1);
    if (lt != 10) {
        Say("FAIL: loaded tile at (1,1) should be 10");
        return;
    }

    // Test 3: Auto-tiling
    var tm3 = Tilemap.New(5, 1, 16, 16);
    Tilemap.SetTile(tm3, 1, 0, 1);
    Tilemap.SetTile(tm3, 2, 0, 1);
    Tilemap.SetTile(tm3, 3, 0, 1);

    // Variants: 100 + mask
    Tilemap.SetAutoTileLo(tm3, 1, 100, 101, 102, 103, 104, 105, 106, 107);
    Tilemap.SetAutoTileHi(tm3, 1, 108, 109, 110, 111, 112, 113, 114, 115);
    Tilemap.ApplyAutoTile(tm3);

    // x=1: right neighbor → mask 2
    var at1 = Tilemap.GetTile(tm3, 1, 0);
    if (at1 != 102) {
        Say("FAIL: autotile x=1 should be 102 (right only)");
        return;
    }
    // x=2: left+right → mask 10
    var at2 = Tilemap.GetTile(tm3, 2, 0);
    if (at2 != 110) {
        Say("FAIL: autotile x=2 should be 110 (left+right)");
        return;
    }
    // x=3: left → mask 8
    var at3 = Tilemap.GetTile(tm3, 3, 0);
    if (at3 != 108) {
        Say("FAIL: autotile x=3 should be 108 (left only)");
        return;
    }

    Say("RESULT: ok");
}
