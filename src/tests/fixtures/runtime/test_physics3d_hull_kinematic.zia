module TestPhysics3DHullKinematic;

bind Zanna.Graphics3D;
bind Zanna.Math;
bind Zanna.Terminal;
bind Zanna.Core.Convert as Convert;

// Coverage for the doc-04 physics upgrades:
//   - Collider3D.NewConvexHullReduced: quickhull over a dense mesh, vertex
//     budget honored, collider usable on a dynamic body and raycastable.
//   - Kinematic triangle-mesh colliders: a script-driven mesh platform can
//     move (was static-only) and blocks/pushes dynamic bodies.
//   - PhysicsWorld3D.SetMaxQueryHits: query capacity is configurable and the
//     truncation contract holds.

func start() {
    // --- Reduced convex hull -------------------------------------------
    var dense = Mesh3D.Sphere(1.0, 24); // hundreds of vertices
    var hull = Collider3D.NewConvexHullReduced(dense, 32);
    if (hull == null) {
        Say("FAIL: NewConvexHullReduced returned null");
        return;
    }

    var world = PhysicsWorld3D.New(0.0, -9.81, 0.0);
    var floor = PhysicsBody3D.NewAABB(10.0, 0.5, 10.0, 0.0);
    PhysicsBody3D.SetPosition(floor, 0.0, -0.5, 0.0);
    PhysicsWorld3D.Add(world, floor);

    var ball = PhysicsBody3D.New(1.0);
    PhysicsBody3D.set_Collider(ball, hull);
    PhysicsBody3D.SetPosition(ball, 0.0, 3.0, 0.0);
    PhysicsWorld3D.Add(world, ball);

    var i = 0;
    while (i < 240) {
        PhysicsWorld3D.Step(world, 1.0 / 60.0);
        i = i + 1;
    }
    var rest = PhysicsBody3D.get_Position(ball);
    // A unit sphere hull resting on a floor at y=0 should sit near y=1.
    if (Vec3.get_Y(rest) < 0.7 || Vec3.get_Y(rest) > 1.3) {
        Say("FAIL: reduced-hull ball did not rest on the floor (y_x100="
            + toString(Convert.NumToInt(Vec3.get_Y(rest) * 100.0)) + ")");
        return;
    }

    // Raycast down at the resting hull must hit it (hull mesh has faces).
    var hit = PhysicsWorld3D.Raycast(
        world, Vec3.New(0.0, 5.0, 0.0), Vec3.New(0.0, -1.0, 0.0), 10.0, 1);
    if (hit == null) {
        Say("FAIL: raycast at the reduced hull found nothing");
        return;
    }
    if (PhysicsHit3D.get_Body(hit) != ball) {
        Say("FAIL: raycast should hit the hull ball first");
        return;
    }

    // --- Kinematic mesh platform ----------------------------------------
    var world2 = PhysicsWorld3D.New(0.0, -9.81, 0.0);
    var platMesh = Mesh3D.Box(4.0, 0.5, 4.0);
    var platCollider = Collider3D.NewMesh(platMesh);
    var platform = PhysicsBody3D.New(0.0);
    PhysicsBody3D.set_Collider(platform, platCollider);
    PhysicsBody3D.set_IsKinematic(platform, true);
    PhysicsBody3D.SetPosition(platform, 0.0, 0.0, 0.0);
    PhysicsWorld3D.Add(world2, platform);

    var crate = PhysicsBody3D.NewAABB(0.25, 0.25, 0.25, 1.0);
    PhysicsBody3D.SetPosition(crate, 0.0, 1.5, 0.0);
    PhysicsWorld3D.Add(world2, crate);

    // Let the crate settle onto the platform.
    i = 0;
    while (i < 120) {
        PhysicsWorld3D.Step(world2, 1.0 / 60.0);
        i = i + 1;
    }
    var settled = PhysicsBody3D.get_Position(crate);
    if (Vec3.get_Y(settled) < 0.3 || Vec3.get_Y(settled) > 0.8) {
        Say("FAIL: crate did not settle on the kinematic mesh platform (y_x100="
            + toString(Convert.NumToInt(Vec3.get_Y(settled) * 100.0)) + ")");
        return;
    }

    // Rise like an elevator: the platform must push the crate upward.
    var y = 0.0;
    i = 0;
    while (i < 120) {
        y = y + 0.01;
        PhysicsBody3D.SetPosition(platform, 0.0, y, 0.0);
        PhysicsWorld3D.Step(world2, 1.0 / 60.0);
        i = i + 1;
    }
    var lifted = PhysicsBody3D.get_Position(crate);
    if (Vec3.get_Y(lifted) < Vec3.get_Y(settled) + 0.8) {
        Say("FAIL: kinematic mesh elevator did not lift the crate (dy_x100="
            + toString(Convert.NumToInt((Vec3.get_Y(lifted) - Vec3.get_Y(settled)) * 100.0)) + ")");
        return;
    }

    // --- Configurable query capacity ------------------------------------
    var world3 = PhysicsWorld3D.New(0.0, 0.0, 0.0);
    var n = 0;
    while (n < 24) {
        var pellet = PhysicsBody3D.Sphere(0.1, 0.0);
        PhysicsBody3D.SetPosition(pellet, 0.0, 0.0, 0.2 * (0.0 + n));
        PhysicsWorld3D.Add(world3, pellet);
        n = n + 1;
    }
    PhysicsWorld3D.SetMaxQueryHits(world3, 16);
    if (PhysicsWorld3D.get_MaxQueryHits(world3) != 16) {
        Say("FAIL: MaxQueryHits should read back 16");
        return;
    }
    var clipped = PhysicsWorld3D.OverlapSphere(world3, Vec3.New(0.0, 0.0, 2.4), 10.0, 1);
    if (PhysicsHitList3D.get_Count(clipped) != 16) {
        Say("FAIL: capacity 16 should return 16 hits (got "
            + toString(PhysicsHitList3D.get_Count(clipped)) + ")");
        return;
    }
    if (PhysicsHitList3D.get_TotalCount(clipped) != 24) {
        Say("FAIL: TotalCount should still report 24");
        return;
    }
    if (!PhysicsHitList3D.get_Truncated(clipped)) {
        Say("FAIL: Truncated should be true at capacity 16");
        return;
    }
    PhysicsWorld3D.SetMaxQueryHits(world3, 64);
    var full = PhysicsWorld3D.OverlapSphere(world3, Vec3.New(0.0, 0.0, 2.4), 10.0, 1);
    if (PhysicsHitList3D.get_Count(full) != 24 || PhysicsHitList3D.get_Truncated(full)) {
        Say("FAIL: capacity 64 should return all 24 hits untruncated");
        return;
    }

    Say("PASS");
}
