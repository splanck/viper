// Test: Iterator protocol over Seq, List, Map, Set
module TestIterator;

bind Zanna.Terminal;

func start() {
    // === Test 1: Iterator over Seq ===
    var seq = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(seq, 10);
    Zanna.Collections.Seq.Push(seq, 20);
    Zanna.Collections.Seq.Push(seq, 30);

    var it = Zanna.Collections.Iterator.FromSeq(seq);

    // Count should be 3
    var cnt = Zanna.Collections.Iterator.get_Count(it);
    if (cnt != 3) {
        Say("FAIL: Seq iterator count should be 3");
        return;
    }

    // Index starts at 0
    var idx = Zanna.Collections.Iterator.get_Index(it);
    if (idx != 0) {
        Say("FAIL: Seq iterator index should start at 0");
        return;
    }

    // HasNext should be true
    var hn = Zanna.Collections.Iterator.HasNext(it);
    if (hn != true) {
        Say("FAIL: Seq iterator HasNext should be 1");
        return;
    }

    // Next should return something (not null) and advance index
    Zanna.Collections.Iterator.Next(it);
    idx = Zanna.Collections.Iterator.get_Index(it);
    if (idx != 1) {
        Say("FAIL: index should be 1 after first Next");
        return;
    }

    // Peek should not advance
    Zanna.Collections.Iterator.Peek(it);
    idx = Zanna.Collections.Iterator.get_Index(it);
    if (idx != 1) {
        Say("FAIL: index should still be 1 after Peek");
        return;
    }

    // Next again
    Zanna.Collections.Iterator.Next(it);
    idx = Zanna.Collections.Iterator.get_Index(it);
    if (idx != 2) {
        Say("FAIL: index should be 2 after second Next");
        return;
    }

    // Skip 1 — should skip the 3rd element
    var skipped = Zanna.Collections.Iterator.Skip(it, 1);
    if (skipped != 1) {
        Say("FAIL: Skip should return 1");
        return;
    }

    // HasNext should now be false (all 3 consumed)
    var hn2 = Zanna.Collections.Iterator.HasNext(it);
    if (hn2 != false) {
        Say("FAIL: Seq iterator HasNext should be 0 after exhaustion");
        return;
    }

    // Reset and iterate to Seq
    Zanna.Collections.Iterator.Reset(it);
    idx = Zanna.Collections.Iterator.get_Index(it);
    if (idx != 0) {
        Say("FAIL: index should be 0 after Reset");
        return;
    }

    var collected = Zanna.Collections.Iterator.ToSeq(it);
    var clen = Zanna.Collections.Seq.get_Count(collected);
    if (clen != 3) {
        Say("FAIL: ToSeq should produce 3 elements");
        return;
    }

    // === Test 2: Iterator over List ===
    var list = Zanna.Collections.List.New();
    Zanna.Collections.List.Push(list, 100);
    Zanna.Collections.List.Push(list, 200);

    var lit = Zanna.Collections.Iterator.FromList(list);
    var lcnt = Zanna.Collections.Iterator.get_Count(lit);
    if (lcnt != 2) {
        Say("FAIL: List iterator count should be 2");
        return;
    }

    Zanna.Collections.Iterator.Next(lit);
    Zanna.Collections.Iterator.Next(lit);
    var lhn = Zanna.Collections.Iterator.HasNext(lit);
    if (lhn != false) {
        Say("FAIL: List iterator should be exhausted");
        return;
    }

    // === Test 3: Iterator over Map keys ===
    var map = Zanna.Collections.Map.New();
    Zanna.Collections.Map.Set(map, "alpha", 1);
    Zanna.Collections.Map.Set(map, "beta", 2);

    var mit = Zanna.Collections.Iterator.FromMapKeys(map);
    var mcount = Zanna.Collections.Iterator.get_Count(mit);
    if (mcount != 2) {
        Say("FAIL: Map key iterator count should be 2");
        return;
    }
    // Iterate both keys without crash
    Zanna.Collections.Iterator.Next(mit);
    Zanna.Collections.Iterator.Next(mit);

    // === Test 4: Iterator over Map values ===
    var vit = Zanna.Collections.Iterator.FromMapValues(map);
    var vcount = Zanna.Collections.Iterator.get_Count(vit);
    if (vcount != 2) {
        Say("FAIL: Map value iterator count should be 2");
        return;
    }

    // === Test 5: Iterator over Set ===
    var set = Zanna.Collections.Set.New();
    Zanna.Collections.Set.Add(set, 42);
    Zanna.Collections.Set.Add(set, 99);

    var sit = Zanna.Collections.Iterator.FromSet(set);
    var scount = Zanna.Collections.Iterator.get_Count(sit);
    if (scount != 2) {
        Say("FAIL: Set iterator count should be 2");
        return;
    }

    // === Test 6: Iterator over Ring ===
    var ring = Zanna.Collections.Ring.New(8);
    Zanna.Collections.Ring.Push(ring, 1);
    Zanna.Collections.Ring.Push(ring, 2);
    Zanna.Collections.Ring.Push(ring, 3);

    var rit = Zanna.Collections.Iterator.FromRing(ring);
    var rcount = Zanna.Collections.Iterator.get_Count(rit);
    if (rcount != 3) {
        Say("FAIL: Ring iterator count should be 3");
        return;
    }

    // Iterate all 3
    Zanna.Collections.Iterator.Next(rit);
    Zanna.Collections.Iterator.Next(rit);
    Zanna.Collections.Iterator.Next(rit);
    var rhn = Zanna.Collections.Iterator.HasNext(rit);
    if (rhn != false) {
        Say("FAIL: Ring iterator should be exhausted");
        return;
    }

    Say("RESULT: ok");
}
