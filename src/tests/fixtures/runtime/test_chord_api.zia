// Test: Key chord/combo detection in action system
module TestChordApi;

bind Zanna.Terminal;

func start() {
    Zanna.Input.Action.Clear();

    // === Test 1: Define action and bind a chord ===
    var ok = Zanna.Input.Action.Define("save");
    if (ok != true) {
        Say("FAIL: Define save should succeed");
        return;
    }

    // Create a chord: Ctrl(341) + S(83)
    var chord = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(chord, 341);  // Left Ctrl
    Zanna.Collections.Seq.Push(chord, 83);   // S key

    var bindOk = Zanna.Input.Action.BindChord("save", chord);
    if (bindOk != true) {
        Say("FAIL: BindChord should succeed");
        return;
    }

    // === Test 2: ChordCount ===
    var cc = Zanna.Input.Action.ChordCount("save");
    if (cc != 1) {
        Say("FAIL: ChordCount should be 1");
        return;
    }

    // === Test 3: BindingCount includes chords ===
    var bc = Zanna.Input.Action.BindingCount("save");
    if (bc != 1) {
        Say("FAIL: BindingCount should be 1");
        return;
    }

    // === Test 4: Bind a second chord (Ctrl+Shift+S) ===
    var chord2 = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(chord2, 341);  // Left Ctrl
    Zanna.Collections.Seq.Push(chord2, 340);  // Left Shift
    Zanna.Collections.Seq.Push(chord2, 83);   // S key

    bindOk = Zanna.Input.Action.BindChord("save", chord2);
    if (bindOk != true) {
        Say("FAIL: BindChord second chord should succeed");
        return;
    }

    cc = Zanna.Input.Action.ChordCount("save");
    if (cc != 2) {
        Say("FAIL: ChordCount should be 2");
        return;
    }

    bc = Zanna.Input.Action.BindingCount("save");
    if (bc != 2) {
        Say("FAIL: BindingCount should be 2 after two chords");
        return;
    }

    // === Test 5: BindChord rejects axis actions ===
    Zanna.Input.Action.DefineAxis("move_x");
    var chord3 = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(chord3, 65);
    Zanna.Collections.Seq.Push(chord3, 68);
    var axisBind = Zanna.Input.Action.BindChord("move_x", chord3);
    if (axisBind != false) {
        Say("FAIL: BindChord should reject axis actions");
        return;
    }

    // === Test 6: BindChord rejects single-key chord ===
    var chord4 = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(chord4, 65);
    var singleBind = Zanna.Input.Action.BindChord("save", chord4);
    if (singleBind != false) {
        Say("FAIL: BindChord should reject single-key chord");
        return;
    }

    // === Test 7: UnbindChord ===
    var unbound = Zanna.Input.Action.UnbindChord("save", chord);
    if (unbound != true) {
        Say("FAIL: UnbindChord should succeed");
        return;
    }

    cc = Zanna.Input.Action.ChordCount("save");
    if (cc != 1) {
        Say("FAIL: ChordCount should be 1 after unbind");
        return;
    }

    // === Test 8: UnbindChord non-existent returns 0 ===
    var unbound2 = Zanna.Input.Action.UnbindChord("save", chord);
    if (unbound2 != false) {
        Say("FAIL: UnbindChord non-existent should return 0");
        return;
    }

    // === Test 9: Save/Load round-trip preserves chords ===
    var saved = Zanna.Input.Action.Save();

    Zanna.Input.Action.Clear();
    var afterClear = Zanna.Input.Action.Exists("save");
    if (afterClear != false) {
        Say("FAIL: save should not exist after clear");
        return;
    }

    var loadOk = Zanna.Input.Action.Load(saved);
    if (loadOk != true) {
        Say("FAIL: Load should succeed");
        return;
    }

    var restored = Zanna.Input.Action.Exists("save");
    if (restored != true) {
        Say("FAIL: save should exist after Load");
        return;
    }

    var restoredCC = Zanna.Input.Action.ChordCount("save");
    if (restoredCC != 1) {
        Say("FAIL: ChordCount should be 1 after Load");
        return;
    }

    // === Test 10: Mix chord and key bindings ===
    Zanna.Input.Action.Clear();
    Zanna.Input.Action.Define("action");
    Zanna.Input.Action.BindKey("action", 32);  // Space

    var mixChord = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(mixChord, 341);
    Zanna.Collections.Seq.Push(mixChord, 32);
    Zanna.Input.Action.BindChord("action", mixChord);

    bc = Zanna.Input.Action.BindingCount("action");
    if (bc != 2) {
        Say("FAIL: should have 2 bindings (1 key + 1 chord)");
        return;
    }

    cc = Zanna.Input.Action.ChordCount("action");
    if (cc != 1) {
        Say("FAIL: should have 1 chord binding");
        return;
    }

    // Cleanup
    Zanna.Input.Action.Clear();

    Say("RESULT: ok");
}
