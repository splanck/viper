module TestMapTyped;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Collections.Map.SetInt
// COVER: Zanna.Collections.Map.GetInt
// COVER: Zanna.Collections.Map.GetIntOr
// COVER: Zanna.Collections.Map.SetFloat
// COVER: Zanna.Collections.Map.GetFloat
// COVER: Zanna.Collections.Map.GetFloatOr
// COVER: Zanna.Collections.Map.SetStr
// COVER: Zanna.Collections.Map.GetStr

func testSetGetInt() {
    setTest("SetGetInt");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetInt(m, "age", 30);
    Zanna.Collections.Map.SetInt(m, "score", 100);
    Zanna.Collections.Map.SetInt(m, "count", 0);

    var age = Zanna.Collections.Map.GetInt(m, "age");
    assertEqInt(age, 30, "GetInt age");

    var score = Zanna.Collections.Map.GetInt(m, "score");
    assertEqInt(score, 100, "GetInt score");

    var count = Zanna.Collections.Map.GetInt(m, "count");
    assertEqInt(count, 0, "GetInt zero value");
}

func testGetIntMissing() {
    setTest("GetIntMissing");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetInt(m, "exists", 42);

    var missing = Zanna.Collections.Map.GetInt(m, "missing");
    assertEqInt(missing, 0, "GetInt missing returns 0");
}

func testGetIntOr() {
    setTest("GetIntOr");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetInt(m, "present", 99);

    var v1 = Zanna.Collections.Map.GetIntOr(m, "present", -1);
    assertEqInt(v1, 99, "GetIntOr existing key");

    var v2 = Zanna.Collections.Map.GetIntOr(m, "absent", -1);
    assertEqInt(v2, -1, "GetIntOr missing key returns default");

    var v3 = Zanna.Collections.Map.GetIntOr(m, "nope", 500);
    assertEqInt(v3, 500, "GetIntOr with custom default");
}

func testSetGetFloat() {
    setTest("SetGetFloat");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetFloat(m, "pi", 3.14);
    Zanna.Collections.Map.SetFloat(m, "e", 2.718);

    var pi = Zanna.Collections.Map.GetFloat(m, "pi");
    assertApprox(pi, 3.14, 0.001, "GetFloat pi");

    var e = Zanna.Collections.Map.GetFloat(m, "e");
    assertApprox(e, 2.718, 0.001, "GetFloat e");
}

func testGetFloatMissing() {
    setTest("GetFloatMissing");

    var m = Zanna.Collections.Map.New();
    var missing = Zanna.Collections.Map.GetFloat(m, "missing");
    assertApprox(missing, 0.0, 0.001, "GetFloat missing returns 0.0");
}

func testGetFloatOr() {
    setTest("GetFloatOr");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetFloat(m, "rate", 0.05);

    var v1 = Zanna.Collections.Map.GetFloatOr(m, "rate", -1.0);
    assertApprox(v1, 0.05, 0.001, "GetFloatOr existing key");

    var v2 = Zanna.Collections.Map.GetFloatOr(m, "absent", 9.99);
    assertApprox(v2, 9.99, 0.001, "GetFloatOr missing key returns default");
}

func testSetGetStr() {
    setTest("SetGetStr");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetStr(m, "name", "Alice");
    Zanna.Collections.Map.SetStr(m, "city", "Boston");

    var name = Zanna.Collections.Map.GetStr(m, "name");
    assertEqStr(name, "Alice", "GetStr name");

    var city = Zanna.Collections.Map.GetStr(m, "city");
    assertEqStr(city, "Boston", "GetStr city");
}

func testGetStrMissing() {
    setTest("GetStrMissing");

    var m = Zanna.Collections.Map.New();
    var missing = Zanna.Collections.Map.GetStr(m, "missing");
    assertEqStr(missing, "", "GetStr missing returns empty string");
}

func testMixedTypes() {
    setTest("MixedTypes");

    var m = Zanna.Collections.Map.New();
    Zanna.Collections.Map.SetInt(m, "count", 42);
    Zanna.Collections.Map.SetFloat(m, "ratio", 1.5);
    Zanna.Collections.Map.SetStr(m, "label", "test");

    assertEqInt(Zanna.Collections.Map.GetInt(m, "count"), 42, "mixed int");
    assertApprox(Zanna.Collections.Map.GetFloat(m, "ratio"), 1.5, 0.001, "mixed float");
    assertEqStr(Zanna.Collections.Map.GetStr(m, "label"), "test", "mixed str");
}

func start() {
    testSetGetInt();
    testGetIntMissing();
    testGetIntOr();
    testSetGetFloat();
    testGetFloatMissing();
    testGetFloatOr();
    testSetGetStr();
    testGetStrMissing();
    testMixedTypes();

    report();
}
