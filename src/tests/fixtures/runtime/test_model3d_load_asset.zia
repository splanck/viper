module TestSceneAssetLoadAsset;

bind Viper.Graphics3D;
bind Viper.Terminal;

func start() {
    var loaded = SceneAsset.LoadAssetResult("src/tests/fixtures/runtime/assets/gltf/load_asset_triangle.gltf");
    if (not loaded.IsOk) {
        Say("FAIL: SceneAsset.LoadAssetResult should load glTF assets through filesystem fallback");
        return;
    }
    var model = loaded.Unwrap();
    if (SceneAsset.get_MeshCount(model) != 1) {
        Say("FAIL: SceneAsset.LoadAsset should expose imported meshes");
        return;
    }
    var mesh = SceneAsset.GetMesh(model, 0);
    if (mesh == null) {
        Say("FAIL: SceneAsset.GetMesh should return the loaded mesh");
        return;
    }
    var root = SceneAsset.Instantiate(model);
    if (root == null || SceneNode.get_ChildCount(root) != 1) {
        Say("FAIL: SceneAsset.LoadAsset should instantiate imported glTF templates");
        return;
    }
    Say("PASS");
}
