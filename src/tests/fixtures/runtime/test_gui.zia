func start() {
    Zanna.Terminal.Say("GUI Runtime Tests");
    Zanna.Terminal.Say("==================");
    Zanna.Terminal.Say("Note: Full GUI testing requires a display environment.");
    Zanna.Terminal.Say("This test documents what should be manually verified.");
    Zanna.Terminal.Say("");

    testGuiStructures();
    testGuiWidgetTypes();
    testGuiEvents();
    testGuiTypedConstants();

    report();
}
