module TestGui;

bind "./_support";
bind Zanna.GUI.Align as Align;
bind Zanna.GUI.Justify as Justify;
bind Zanna.GUI.FlexDirection as FlexDirection;
bind Zanna.GUI.FlexWrap as FlexWrap;
bind Zanna.GUI.Dock as Dock;
bind Zanna.GUI.ThemeMode as ThemeMode;
bind Zanna.GUI.AccessibleRole as AccessibleRole;
bind Zanna.GUI.LiveRegionMode as LiveRegionMode;
bind Zanna.GUI.DialogButtonRole as DialogButtonRole;
bind Zanna.GUI.DialogStatus as DialogStatus;
bind Zanna.GUI.ImageFilter as ImageFilter;
bind Zanna.GUI.SortDirection as SortDirection;

// EXPECT_OUT: RESULT: ok
// NOTE: GUI tests are limited since they require display/window system
// These tests verify that non-windowed operations work correctly
// Full GUI testing requires manual verification or headless testing

// Window-backed behavior is covered by the display-locked C runtime tests. This
// fixture verifies GUI registry surfaces that are deliberately usable headlessly.

func testGuiTypedConstants() {
    setTest("GuiTypedConstants");

    assertEqInt(Align.Start, 0, "Align.Start");
    assertEqInt(Align.Stretch, 3, "Align.Stretch");
    assertEqInt(Justify.SpaceEvenly, 5, "Justify.SpaceEvenly");
    assertEqInt(FlexDirection.Column, 1, "FlexDirection.Column");
    assertEqInt(FlexWrap.WrapReverse, 2, "FlexWrap.WrapReverse");
    assertEqInt(Dock.Fill, 4, "Dock.Fill");
    assertEqInt(ThemeMode.Custom, 3, "ThemeMode.Custom");
    assertEqInt(AccessibleRole.Button, 5, "AccessibleRole.Button");
    assertEqInt(AccessibleRole.Link, 30, "AccessibleRole.Link");
    assertEqInt(LiveRegionMode.Assertive, 2, "LiveRegionMode.Assertive");
    assertEqInt(DialogButtonRole.Help, 6, "DialogButtonRole.Help");
    assertEqInt(DialogStatus.Failed, 4, "DialogStatus.Failed");
    assertEqInt(ImageFilter.Bilinear, 1, "ImageFilter.Bilinear");
    assertEqInt(SortDirection.Descending, -1, "SortDirection.Descending");
}

func testGuiStructures() {
    setTest("GuiStructures");

    // Document what GUI tests would cover:
    // - App creation and lifecycle
    // - Widget creation (Label, Button, TextInput, etc.)
    // - Widget properties (SetText, SetSize, SetPosition)
    // - Widget events (WasClicked, IsHovered, IsFocused)
    // - Layout and rendering

    // Since we can't create GUI without a display, we just pass
    Zanna.Terminal.Say("GUI tests require display - skipping window creation");
    pass();
}

