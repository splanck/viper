    setTest("GuiEvents");

    // Document events that would be tested:
    // - Widget.WasClicked() - click detection
    // - Widget.IsHovered() - mouse hover
    // - Widget.IsPressed() - mouse down
    // - Widget.IsFocused() - keyboard focus
