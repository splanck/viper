// Test: Spline interpolation (Catmull-Rom, Bezier, Linear)
module TestSpline;

bind Zanna.Terminal;

func start() {
    // === Test 1: Linear spline from points ===
    var points = Zanna.Collections.Seq.New();
    var p0 = Zanna.Math.Vec2.New(0.0, 0.0);
    var p1 = Zanna.Math.Vec2.New(10.0, 10.0);
    var p2 = Zanna.Math.Vec2.New(20.0, 0.0);
    Zanna.Collections.Seq.Push(points, p0);
    Zanna.Collections.Seq.Push(points, p1);
    Zanna.Collections.Seq.Push(points, p2);

    var linear = Zanna.Math.Spline.Linear(points);
    if (linear == null) { Say("FAIL: Linear should return non-null"); return; }

    // PointCount
    var pc = Zanna.Math.Spline.get_PointCount(linear);
    if (pc != 3) { Say("FAIL: Linear PointCount should be 3"); return; }

    // PointAt
    var pt0 = Zanna.Math.Spline.PointAt(linear, 0);
    if (pt0 == null) { Say("FAIL: PointAt(0) should be non-null"); return; }
    var pt0x = Zanna.Math.Vec2.get_X(pt0);
    if (pt0x != 0.0) { Say("FAIL: PointAt(0) X should be 0"); return; }

    // Eval at t=0 → first point
    var ev0 = Zanna.Math.Spline.Eval(linear, 0.0);
    var ev0x = Zanna.Math.Vec2.get_X(ev0);
    var ev0y = Zanna.Math.Vec2.get_Y(ev0);
    if (ev0x != 0.0) { Say("FAIL: Linear Eval(0) X should be 0"); return; }
    if (ev0y != 0.0) { Say("FAIL: Linear Eval(0) Y should be 0"); return; }

    // Eval at t=0.5 → midpoint = (10,10) for linear with 3 pts
    var evMid = Zanna.Math.Spline.Eval(linear, 0.5);
    var emx = Zanna.Math.Vec2.get_X(evMid);
    var emy = Zanna.Math.Vec2.get_Y(evMid);
    if (emx < 9.99) { Say("FAIL: Linear Eval(0.5) X should be ~10"); return; }
    if (emx > 10.01) { Say("FAIL: Linear Eval(0.5) X should be ~10"); return; }
    if (emy < 9.99) { Say("FAIL: Linear Eval(0.5) Y should be ~10"); return; }

    // Eval at t=1 → last point
    var ev1 = Zanna.Math.Spline.Eval(linear, 1.0);
    var ev1x = Zanna.Math.Vec2.get_X(ev1);
    if (ev1x < 19.99) { Say("FAIL: Linear Eval(1) X should be ~20"); return; }

    // === Test 2: Bezier cubic from 4 control points ===
    var c0 = Zanna.Math.Vec2.New(0.0, 0.0);
    var c1 = Zanna.Math.Vec2.New(5.0, 20.0);
    var c2 = Zanna.Math.Vec2.New(15.0, 20.0);
    var c3 = Zanna.Math.Vec2.New(20.0, 0.0);
    var bezier = Zanna.Math.Spline.Bezier(c0, c1, c2, c3);
    if (bezier == null) { Say("FAIL: Bezier should return non-null"); return; }

    // Bezier has 4 control points
    var bpc = Zanna.Math.Spline.get_PointCount(bezier);
    if (bpc != 4) { Say("FAIL: Bezier PointCount should be 4"); return; }

    // Eval at t=0 → c0
    var bev0 = Zanna.Math.Spline.Eval(bezier, 0.0);
    var bev0x = Zanna.Math.Vec2.get_X(bev0);
    if (bev0x != 0.0) { Say("FAIL: Bezier Eval(0) X should be 0"); return; }

    // Eval at t=1 → c3
    var bev1 = Zanna.Math.Spline.Eval(bezier, 1.0);
    var bev1x = Zanna.Math.Vec2.get_X(bev1);
    if (bev1x < 19.99) { Say("FAIL: Bezier Eval(1) X should be ~20"); return; }

    // Eval at t=0.5 → symmetric, should be midpoint X=10 and Y > 0
    var bevH = Zanna.Math.Spline.Eval(bezier, 0.5);
    var bevHx = Zanna.Math.Vec2.get_X(bevH);
    var bevHy = Zanna.Math.Vec2.get_Y(bevH);
    if (bevHx < 9.9) { Say("FAIL: Bezier Eval(0.5) X should be ~10"); return; }
    if (bevHx > 10.1) { Say("FAIL: Bezier Eval(0.5) X should be ~10"); return; }
    if (bevHy < 1.0) { Say("FAIL: Bezier Eval(0.5) Y should be > 0"); return; }

    // === Test 3: Tangent ===
    var tang = Zanna.Math.Spline.Tangent(bezier, 0.5);
    if (tang == null) { Say("FAIL: Tangent should return non-null"); return; }
    // At midpoint of symmetric bezier, tangent Y should be ~0 (peak)
    var tanX = Zanna.Math.Vec2.get_X(tang);
    // X component should be positive (moving right)
    if (tanX < 0.0) { Say("FAIL: Tangent X at midpoint should be > 0"); return; }

    // === Test 4: ArcLength ===
    var arcLen = Zanna.Math.Spline.ArcLength(linear, 0.0, 1.0, 100);
    // Linear path: (0,0)→(10,10)→(20,0), two segments each √200 ≈ 14.14, total ≈ 28.28
    if (arcLen < 28.0) { Say("FAIL: Linear arc length should be ~28.28"); return; }
    if (arcLen > 29.0) { Say("FAIL: Linear arc length should be ~28.28"); return; }

    // === Test 5: Sample ===
    var samples = Zanna.Math.Spline.Sample(linear, 5);
    var sLen = Zanna.Collections.Seq.get_Count(samples);
    if (sLen != 5) { Say("FAIL: Sample(5) should return 5 points"); return; }

    // === Test 6: Catmull-Rom ===
    var crPoints = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(crPoints, Zanna.Math.Vec2.New(0.0, 0.0));
    Zanna.Collections.Seq.Push(crPoints, Zanna.Math.Vec2.New(5.0, 10.0));
    Zanna.Collections.Seq.Push(crPoints, Zanna.Math.Vec2.New(10.0, 10.0));
    Zanna.Collections.Seq.Push(crPoints, Zanna.Math.Vec2.New(15.0, 0.0));

    var cr = Zanna.Math.Spline.CatmullRom(crPoints);
    if (cr == null) { Say("FAIL: CatmullRom should return non-null"); return; }

    var crpc = Zanna.Math.Spline.get_PointCount(cr);
    if (crpc != 4) { Say("FAIL: CatmullRom PointCount should be 4"); return; }

    // Eval at endpoints
    var crEv0 = Zanna.Math.Spline.Eval(cr, 0.0);
    if (crEv0 == null) { Say("FAIL: CatmullRom Eval(0) should be non-null"); return; }

    var crEv1 = Zanna.Math.Spline.Eval(cr, 1.0);
    if (crEv1 == null) { Say("FAIL: CatmullRom Eval(1) should be non-null"); return; }

    Say("RESULT: ok");
}
