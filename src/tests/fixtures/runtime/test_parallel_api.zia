// Test: Parallel API — DefaultWorkers, DefaultPool
module TestParallelApi;

bind Zanna.Terminal;

func start() {
    // DefaultWorkers should return at least 1
    var workers = Zanna.Threads.Parallel.DefaultWorkers();
    if (workers < 1) {
        Say("FAIL: DefaultWorkers should be >= 1");
        return;
    }

    // DefaultPool should return non-null
    var pool = Zanna.Threads.Parallel.DefaultPool();
    if (pool == null) {
        Say("FAIL: DefaultPool should return non-null");
        return;
    }

    // Verify the pool has the expected number of workers
    var poolSize = Zanna.Threads.Pool.get_Size(pool);
    if (poolSize < 1) {
        Say("FAIL: pool size should be >= 1");
        return;
    }

    Say("RESULT: ok");
}
