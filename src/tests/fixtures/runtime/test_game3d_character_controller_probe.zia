module test_game3d_character_controller_probe;

bind Viper.Game3D as Game3D;
bind Viper.Graphics3D as G3D;
bind Viper.Math as Math;
bind Viper.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) { d = 0.0 - d; }
    return d <= eps;
}

func start() {
    var world = Game3D.World3D.New("Game3D Character Controller Probe", 64, 48);
    var canvas = world.Canvas;
    var camera = world.Camera;

    var ground = Game3D.Entity3D.New();
    var groundBody = G3D.PhysicsBody3D.NewAABB(10.0, 0.5, 10.0, 0.0);
    ground.AttachBody(groundBody);
    ground.SetPosition(0.0, -0.5, 0.0);
    world.Spawn(ground);

    var player = Game3D.Entity3D.New();
    player.SetPosition(0.0, 1.0, 4.0);
    world.Spawn(player);

    var character = Game3D.CharacterController3D.New(world, player, 0.32, 1.8, 70.0);
    var fps = Game3D.FirstPersonController.New(world);
    fps.Character = character;
    fps.Speed = 5.0;
    world.SetCameraController(fps);

    var before = player.Position;
    G3D.Canvas3D.PushSyntheticKey(canvas, Viper.Input.Key.W, true);
    world.RunFramesOnly(1, 0.1);
    var after = player.Position;

    if (Math.Vec3.get_Z(after) >= Math.Vec3.get_Z(before) - 0.05) {
        fail("FirstPersonController did not move CharacterController3D in the same frame");
        return;
    }

    var cameraPos = camera.Position;
    if (near(Math.Vec3.get_Z(cameraPos), Math.Vec3.get_Z(after), 0.0001) == false ||
        Math.Vec3.get_Y(cameraPos) <= Math.Vec3.get_Y(after)) {
        fail("FirstPersonController lateUpdate did not align camera to character");
        return;
    }

    G3D.Canvas3D.ClearSyntheticInput(canvas);
    world.Destroy();
    Terminal.Say("PASS");
}
