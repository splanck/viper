module TestString;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.String.Asc
// COVER: Zanna.String.Chr
// COVER: Zanna.String.Concat
// COVER: Zanna.String.IndexOf
// COVER: Zanna.String.IndexOfFrom
// COVER: Zanna.String.ToLower
// COVER: Zanna.String.TrimStart
// COVER: Zanna.String.Left
// COVER: Zanna.String.get_Length
// COVER: Zanna.String.Mid
// COVER: Zanna.String.MidLen
// COVER: Zanna.String.TrimEnd
// COVER: Zanna.String.Right
// COVER: Zanna.String.Cmp
// COVER: Zanna.String.CmpNoCase
// COVER: Zanna.String.Count
// COVER: Zanna.String.EndsWith
// COVER: Zanna.String.Flip
// COVER: Zanna.String.Has
// COVER: Zanna.String.get_IsEmpty
// COVER: Zanna.String.PadLeft
// COVER: Zanna.String.PadRight
// COVER: Zanna.String.Repeat
// COVER: Zanna.String.Replace
// COVER: Zanna.String.Split
// COVER: Zanna.String.StartsWith
// COVER: Zanna.String.Substring
// COVER: Zanna.String.Trim
// COVER: Zanna.String.ToUpper

func testLength() {
    setTest("Length");

    assertEqInt(Zanna.String.get_Length(""), 0, "length empty");
    assertEqInt(Zanna.String.get_Length("a"), 1, "length 'a'");
    assertEqInt(Zanna.String.get_Length("hello"), 5, "length 'hello'");
    assertEqInt(Zanna.String.get_Length("hello world"), 11, "length 'hello world'");
}

func testIsEmpty() {
    setTest("IsEmpty");

    // Use Length == 0 since IsEmpty is a property getter
    assertTrue(Zanna.String.get_Length("") == 0, "empty string is empty");
    assertFalse(Zanna.String.get_Length("a") == 0, "'a' is not empty");
    assertFalse(Zanna.String.get_Length(" ") == 0, "' ' is not empty");
}

func testConcat() {
    setTest("Concat");

    assertEqStr(Zanna.String.Concat("hello", " world"), "hello world", "concat basic");
    assertEqStr(Zanna.String.Concat("", "hello"), "hello", "concat empty+str");
    assertEqStr(Zanna.String.Concat("hello", ""), "hello", "concat str+empty");
    assertEqStr(Zanna.String.Concat("", ""), "", "concat empty+empty");
}

func testSubstring() {
    setTest("Substring");

    // 0-indexed: position 0 is first char
    assertEqStr(Zanna.String.Substring("hello world", 0, 5), "hello", "substring(0,5)");
    assertEqStr(Zanna.String.Substring("hello world", 6, 5), "world", "substring(6,5)");
    assertEqStr(Zanna.String.Substring("hello", 2, 2), "ll", "substring middle");
}

func testLeftRightMid() {
    setTest("Left/Right/Mid");

    // Left - takes count from beginning
    assertEqStr(Zanna.String.Left("hello world", 5), "hello", "left 5");
    assertEqStr(Zanna.String.Left("hello", 10), "hello", "left overflow");

    // Right - takes count from end
    assertEqStr(Zanna.String.Right("hello world", 5), "world", "right 5");
    assertEqStr(Zanna.String.Right("hello", 10), "hello", "right overflow");

    // Mid (from 1-indexed position to end)
    assertEqStr(Zanna.String.Mid("hello world", 7), "world", "mid from 7");
    assertEqStr(Zanna.String.Mid("hello", 1), "hello", "mid from 1");

    // MidLen (from 1-indexed position, length chars)
    assertEqStr(Zanna.String.MidLen("hello world", 1, 5), "hello", "midlen(1,5)");
    assertEqStr(Zanna.String.MidLen("hello world", 7, 3), "wor", "midlen(7,3)");
}

func testCase() {
    setTest("Case");

    // ToUpper
    assertEqStr(Zanna.String.ToUpper("hello"), "HELLO", "toupper 'hello'");
    assertEqStr(Zanna.String.ToUpper("HELLO"), "HELLO", "toupper 'HELLO'");
    assertEqStr(Zanna.String.ToUpper("HeLLo"), "HELLO", "toupper mixed");
    assertEqStr(Zanna.String.ToUpper(""), "", "toupper empty");

    // ToLower
    assertEqStr(Zanna.String.ToLower("HELLO"), "hello", "tolower 'HELLO'");
    assertEqStr(Zanna.String.ToLower("hello"), "hello", "tolower 'hello'");
    assertEqStr(Zanna.String.ToLower("HeLLo"), "hello", "tolower mixed");
    assertEqStr(Zanna.String.ToLower(""), "", "tolower empty");
}

func testTrim() {
    setTest("Trim");

    // Trim (both ends)
    assertEqStr(Zanna.String.Trim("  hello  "), "hello", "trim both");
    assertEqStr(Zanna.String.Trim("hello"), "hello", "trim none");
    assertEqStr(Zanna.String.Trim("  "), "", "trim only spaces");
    assertEqStr(Zanna.String.Trim(""), "", "trim empty");

    // TrimStart
    assertEqStr(Zanna.String.TrimStart("  hello  "), "hello  ", "trimstart");
    assertEqStr(Zanna.String.TrimStart("hello"), "hello", "trimstart none");

    // TrimEnd
    assertEqStr(Zanna.String.TrimEnd("  hello  "), "  hello", "trimend");
    assertEqStr(Zanna.String.TrimEnd("hello"), "hello", "trimend none");
}

func testIndexOf() {
    setTest("IndexOf");

    // IndexOf - returns 1-indexed position, 0 if not found
    assertEqInt(Zanna.String.IndexOf("hello world", "world"), 7, "indexof 'world'");
    assertEqInt(Zanna.String.IndexOf("hello world", "hello"), 1, "indexof 'hello'");
    assertEqInt(Zanna.String.IndexOf("hello world", "xyz"), 0, "indexof not found");
    assertEqInt(Zanna.String.IndexOf("hello world", "o"), 5, "indexof 'o'");

    // IndexOfFrom - search from 1-indexed position
    assertEqInt(Zanna.String.IndexOfFrom("hello world", 6, "o"), 8, "indexoffrom(6,'o')");
    assertEqInt(Zanna.String.IndexOfFrom("hello world", 1, "l"), 3, "indexoffrom(1,'l')");
}

func testStartsEndsWith() {
    setTest("StartsWith/EndsWith");

    // StartsWith
    assertTrue(Zanna.String.StartsWith("hello world", "hello"), "startswith 'hello'");
    assertTrue(Zanna.String.StartsWith("hello", ""), "startswith empty");
    assertFalse(Zanna.String.StartsWith("hello world", "world"), "startswith 'world'");

    // EndsWith
    assertTrue(Zanna.String.EndsWith("hello world", "world"), "endswith 'world'");
    assertTrue(Zanna.String.EndsWith("hello", ""), "endswith empty");
    assertFalse(Zanna.String.EndsWith("hello world", "hello"), "endswith 'hello'");
}

func testHas() {
    setTest("Has (Contains)");

    assertTrue(Zanna.String.Contains("hello world", "world"), "has 'world'");
    assertTrue(Zanna.String.Contains("hello world", "o w"), "has 'o w'");
    assertTrue(Zanna.String.Contains("hello", ""), "has empty");
    assertFalse(Zanna.String.Contains("hello world", "xyz"), "has not found");
}

func testReplace() {
    setTest("Replace");

    assertEqStr(Zanna.String.Replace("hello world", "world", "there"), "hello there", "replace basic");
    assertEqStr(Zanna.String.Replace("aaa", "a", "b"), "bbb", "replace all");
    assertEqStr(Zanna.String.Replace("hello", "x", "y"), "hello", "replace not found");
    assertEqStr(Zanna.String.Replace("hello", "l", ""), "heo", "replace with empty");
}

func testPad() {
    setTest("Pad");

    // PadLeft
    assertEqStr(Zanna.String.PadLeft("42", 5, "0"), "00042", "padleft zeros");
    assertEqStr(Zanna.String.PadLeft("hello", 5, " "), "hello", "padleft no change");
    assertEqStr(Zanna.String.PadLeft("hi", 5, " "), "   hi", "padleft spaces");

    // PadRight
    assertEqStr(Zanna.String.PadRight("42", 5, "0"), "42000", "padright zeros");
    assertEqStr(Zanna.String.PadRight("hello", 5, " "), "hello", "padright no change");
    assertEqStr(Zanna.String.PadRight("hi", 5, " "), "hi   ", "padright spaces");
}

func testRepeat() {
    setTest("Repeat");

    assertEqStr(Zanna.String.Repeat("ab", 3), "ababab", "repeat 3x");
    assertEqStr(Zanna.String.Repeat("a", 5), "aaaaa", "repeat 5x");
    assertEqStr(Zanna.String.Repeat("hello", 1), "hello", "repeat 1x");
    assertEqStr(Zanna.String.Repeat("hello", 0), "", "repeat 0x");
}

func testCount() {
    setTest("Count");

    assertEqInt(Zanna.String.Count("hello world", "o"), 2, "count 'o'");
    assertEqInt(Zanna.String.Count("hello", "l"), 2, "count 'l'");
    assertEqInt(Zanna.String.Count("hello", "x"), 0, "count not found");
    assertEqInt(Zanna.String.Count("aaa", "a"), 3, "count all 'a'");
}

func testFlip() {
    setTest("Flip");

    assertEqStr(Zanna.String.Reverse("hello"), "olleh", "flip 'hello'");
    assertEqStr(Zanna.String.Reverse("a"), "a", "flip single");
    assertEqStr(Zanna.String.Reverse(""), "", "flip empty");
    assertEqStr(Zanna.String.Reverse("ab"), "ba", "flip 'ab'");
}

func testCompare() {
    setTest("Compare");

    // Cmp (case-sensitive)
    assertEqInt(Zanna.String.Compare("abc", "abc"), 0, "cmp equal");
    assertTrue(Zanna.String.Compare("abc", "abd") < 0, "cmp less");
    assertTrue(Zanna.String.Compare("abd", "abc") > 0, "cmp greater");

    // CmpNoCase (case-insensitive)
    assertEqInt(Zanna.String.CompareIgnoreCase("ABC", "abc"), 0, "cmpnocase equal");
    assertEqInt(Zanna.String.CompareIgnoreCase("Hello", "HELLO"), 0, "cmpnocase mixed");
}

func testAscChr() {
    setTest("Asc/Chr");

    // Asc (get ASCII code of first char)
    assertEqInt(Zanna.String.Asc("A"), 65, "asc 'A'");
    assertEqInt(Zanna.String.Asc("a"), 97, "asc 'a'");
    assertEqInt(Zanna.String.Asc("0"), 48, "asc '0'");

    // Chr (get character from ASCII code)
    assertEqStr(Zanna.String.Chr(65), "A", "chr 65");
    assertEqStr(Zanna.String.Chr(97), "a", "chr 97");
    assertEqStr(Zanna.String.Chr(48), "0", "chr 48");
}

func testSplit() {
    setTest("Split");

    // Split returns an object - just verify it doesn't crash
    var parts = Zanna.String.Split("a,b,c", ",");
    assertTrue(true, "split runs without crash");
}

func start() {
    testLength();
    testIsEmpty();
    testConcat();
    testSubstring();
    testLeftRightMid();
    testCase();
    testTrim();
    testIndexOf();
    testStartsEndsWith();
    testHas();
    testReplace();
    testPad();
    testRepeat();
    testCount();
    testFlip();
    testCompare();
    testAscChr();
    testSplit();

    report();
}
