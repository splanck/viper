module test_game3d_physics_probe;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D as G3D;
bind Zanna.Math as Math;
bind Zanna.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func start() {
    var world = Game3D.World3D.New("Game3D Physics Probe", 80, 60);
    world.SetGravity(0.0, -9.81, 0.0);

    var ground: Game3D.Entity3D = Game3D.Prefab.Ground(12.0, Game3D.Materials.Rubber(0.25, 0.35, 0.25));
    ground.AttachBody(Game3D.BodyDef.StaticPlane(12.0));
    world.Spawn(ground);

    var ball: Game3D.Entity3D = Game3D.Prefab.Sphere(0.5, 16, Game3D.Materials.Plastic(0.9, 0.2, 0.2));
    ball.SetPosition(0.0, 3.0, 0.0);
    var ballDef = Game3D.BodyDef.Sphere(0.5, 1.0);
    ballDef.Friction = 0.6;
    ballDef.Restitution = 0.0;
    ballDef.UseCcd = true;
    ballDef.WithMask(Game3D.LayerMask.Of(Game3D.Layers.get_World()));
    ball.AttachBody(ballDef);
    world.Spawn(ball);

    if (G3D.PhysicsBody3D.get_CollisionLayer(ground.Body) !=
        Game3D.Layers.get_World()) {
        fail("StaticPlane did not use world layer");
        return;
    }
    if (G3D.PhysicsBody3D.get_UseCcd(ball.Body) == false) {
        fail("BodyDef did not apply CCD flag");
        return;
    }

    var before = G3D.PhysicsBody3D.get_Position(ball.Body);
    world.RunFramesOnly(90, 0.016);
    var after = G3D.PhysicsBody3D.get_Position(ball.Body);
    if (Math.Vec3.get_Y(after) >= Math.Vec3.get_Y(before)) {
        fail("ball did not fall under gravity");
        return;
    }
    if (world.CollisionEventCount(Game3D.CollisionPhase.get_Any()) <= 0) {
        fail("physics probe produced no collision events");
        return;
    }

    world.RunFramesOnly(150, 0.016);
    var restPos = G3D.PhysicsBody3D.get_Position(ball.Body);
    var restVel = G3D.PhysicsBody3D.get_Velocity(ball.Body);
    if (Math.Vec3.get_Y(restPos) < 0.45 || Math.Vec3.get_Y(restPos) > 0.85 ||
        Math.Vec3.get_Y(restVel) < -0.20 || Math.Vec3.get_Y(restVel) > 0.20) {
        fail("ball did not settle on the ground body");
        return;
    }

    world.Destroy();
    Terminal.Say("PASS");
}
