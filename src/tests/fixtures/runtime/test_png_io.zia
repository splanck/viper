// Test: PNG load and save round-trip
module TestPngIO;

bind Zanna.Terminal;

func start() {
    // Create a 4x4 pixel buffer with known colors
    var px = Zanna.Graphics.Pixels.New(4, 4);
    // Set some pixels: RGBA format 0xRRGGBBAA
    Zanna.Graphics.Pixels.Set(px, 0, 0, 0xFF0000FF);  // Red
    Zanna.Graphics.Pixels.Set(px, 1, 0, 0x00FF00FF);  // Green
    Zanna.Graphics.Pixels.Set(px, 2, 0, 0x0000FFFF);  // Blue
    Zanna.Graphics.Pixels.Set(px, 3, 0, 0xFFFFFFFF);  // White
    Zanna.Graphics.Pixels.Set(px, 0, 1, 0x000000FF);  // Black
    Zanna.Graphics.Pixels.Set(px, 1, 1, 0x808080FF);  // Gray

    // Save as PNG
    var ok = Zanna.Graphics.Pixels.SavePng(px, "test_round_trip.png");
    if (ok != 1) {
        Say("FAIL: SavePng failed");
        return;
    }

    // Load back
    var loaded = Zanna.Graphics.Pixels.LoadPng("test_round_trip.png");
    if (loaded == null) {
        Say("FAIL: LoadPng returned null");
        return;
    }

    // Verify dimensions
    var w = Zanna.Graphics.Pixels.get_Width(loaded);
    var h = Zanna.Graphics.Pixels.get_Height(loaded);
    if (w != 4) {
        Say("FAIL: width mismatch");
        return;
    }
    if (h != 4) {
        Say("FAIL: height mismatch");
        return;
    }

    // Verify pixels
    var p00 = Zanna.Graphics.Pixels.Get(loaded, 0, 0);
    var p10 = Zanna.Graphics.Pixels.Get(loaded, 1, 0);
    var p20 = Zanna.Graphics.Pixels.Get(loaded, 2, 0);

    if (p00 != 0xFF0000FF) {
        Say("FAIL: pixel (0,0) mismatch");
        return;
    }
    if (p10 != 0x00FF00FF) {
        Say("FAIL: pixel (1,0) mismatch");
        return;
    }
    if (p20 != 0x0000FFFF) {
        Say("FAIL: pixel (2,0) mismatch");
        return;
    }

    Say("RESULT: ok");
}
