// Test: OBJ loader + ScreenToRay
module TestCanvas3DOBJ;

bind Zanna.Terminal;

func start() {
    // Test OBJ loading
    var mesh = Zanna.Graphics3D.Mesh3D.FromObj("src/tests/fixtures/runtime/test_cube.obj");
    var vc = Zanna.Graphics3D.Mesh3D.get_VertexCount(mesh);
    var tc = Zanna.Graphics3D.Mesh3D.get_TriangleCount(mesh);

    // 6 quad faces with shared v/vt/vn tuples → 8 deduplicated vertices
    // 6 quads → 12 triangles (fan triangulation)
    if (vc != 8) {
        Say("FAIL: OBJ VertexCount expected 8, got " + vc);
        return;
    }
    if (tc != 12) {
        Say("FAIL: OBJ TriangleCount expected 12, got " + tc);
        return;
    }

    // Test ScreenToRay — center of screen should point roughly along -Z
    var cam = Zanna.Graphics3D.Camera3D.New(60.0, 1.333, 0.1, 100.0);
    var eye = new Zanna.Math.Vec3(0.0, 0.0, 5.0);
    var target = new Zanna.Math.Vec3(0.0, 0.0, 0.0);
    var up = new Zanna.Math.Vec3(0.0, 1.0, 0.0);
    Zanna.Graphics3D.Camera3D.LookAt(cam, eye, target, up);

    var ray = Zanna.Graphics3D.Camera3D.ScreenToRay(cam, 320, 240, 640, 480);
    var rz = Zanna.Math.Vec3.get_Z(ray);

    // Center ray should point roughly toward -Z (the direction camera is looking)
    if (rz > -0.5) {
        Say("FAIL: ScreenToRay center Z expected < -0.5, got " + rz);
        return;
    }

    Say("PASS");
}
