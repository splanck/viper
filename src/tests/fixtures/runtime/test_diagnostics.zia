module TestDiagnostics;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Viper.Time.Stopwatch

func testStopwatch() {
    setTest("Stopwatch");

    var sw = new Viper.Time.Stopwatch();
    assertFalse(sw.IsRunning, "new stopwatch is stopped");

    sw.Start();
    assertTrue(sw.IsRunning, "stopwatch starts");
    Viper.Time.Clock.Sleep(1);
    sw.Stop();
    assertFalse(sw.IsRunning, "stopwatch stops");
    assertGteInt(sw.ElapsedNs, 0, "elapsed ns non-negative");
    assertGteInt(sw.ElapsedUs, 0, "elapsed us non-negative");
    assertGteInt(sw.ElapsedMs, 0, "elapsed ms non-negative");

    sw.Reset();
    assertFalse(sw.IsRunning, "reset leaves stopwatch stopped");
    assertEqInt(sw.ElapsedMs, 0, "reset clears elapsed ms");
}

func start() {
    testStopwatch();

    report();
}
