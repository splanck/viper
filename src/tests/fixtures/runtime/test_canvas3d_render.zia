// Test: Canvas3D visual rendering — opens window, renders colored box, auto-closes
// Label: display_required
module TestCanvas3DRender;

bind Zanna.Terminal;

func start() {
    var canvas = Zanna.Graphics3D.Canvas3D.New("3D Render Test", 400, 300);
    var cam = Zanna.Graphics3D.Camera3D.New(60.0, 400.0 / 300.0, 0.1, 100.0);
    var eye = new Zanna.Math.Vec3(0.0, 1.5, 4.0);
    var target = new Zanna.Math.Vec3(0.0, 0.0, 0.0);
    var up = new Zanna.Math.Vec3(0.0, 1.0, 0.0);
    Zanna.Graphics3D.Camera3D.LookAt(cam, eye, target, up);

    var box = Zanna.Graphics3D.Mesh3D.Box(1.0, 1.0, 1.0);
    var mat = Zanna.Graphics3D.Material3D.FromColor(0.8, 0.2, 0.2);
    var transform = Zanna.Math.Mat4.Identity();

    var w = canvas.Width;
    var h = canvas.Height;
    var backend = canvas.Backend;

    // Render 3 frames then exit
    var frame = 0;
    while (frame < 3) {
        Zanna.Graphics3D.Canvas3D.Poll(canvas);
        Zanna.Graphics3D.Canvas3D.Clear(canvas, 0.1, 0.1, 0.2);
        Zanna.Graphics3D.Canvas3D.Begin(canvas, cam);
        Zanna.Graphics3D.Canvas3D.DrawMesh(canvas, box, transform, mat);
        Zanna.Graphics3D.Canvas3D.End(canvas);
        Zanna.Graphics3D.Canvas3D.Flip(canvas);
        frame = frame + 1;
    }

    Say("width=" + w);
    Say("height=" + h);
    Say("backend=" + backend);
    Say("PASS");
}
