// File: src/tests/fixtures/runtime/test_graphics3d_scalar_set_aliases.zia
// Purpose: Regression coverage for Graphics3D scalar property setter accessors.
//
//===----------------------------------------------------------------------===//

module TestGraphics3DScalarSetAliases;

bind Zanna.Graphics3D;
bind Zanna.Terminal;

/// @brief Exercise canonical static `set_*` functions for scalar Graphics3D properties.
/// @details These are the ABI-shaped property setter functions used by static calls.
func start() {
    var mat = Material3D.PBR(0.4, 0.5, 0.6);

    mat.Metallic = 0.72;
    mat.Roughness = 0.31;
    mat.AmbientOcclusion = 0.83;
    mat.EmissiveIntensity = 1.45;
    mat.NormalScale = 0.62;
    mat.Reflectivity = 0.27;

    if (mat.Metallic < 0.71 || mat.Metallic > 0.73) {
        Say("FAIL: set_Metallic should update Metallic");
        return;
    }
    if (mat.Roughness < 0.30 || mat.Roughness > 0.32) {
        Say("FAIL: set_Roughness should update Roughness");
        return;
    }
    if (mat.AmbientOcclusion < 0.82 || mat.AmbientOcclusion > 0.84) {
        Say("FAIL: set_AmbientOcclusion should update AO");
        return;
    }
    if (mat.EmissiveIntensity < 1.44 ||
        mat.EmissiveIntensity > 1.46) {
        Say("FAIL: set_EmissiveIntensity should update EmissiveIntensity");
        return;
    }
    if (mat.NormalScale < 0.61 || mat.NormalScale > 0.63) {
        Say("FAIL: set_NormalScale should update NormalScale");
        return;
    }
    if (mat.Reflectivity < 0.26 || mat.Reflectivity > 0.28) {
        Say("FAIL: set_Reflectivity should update Reflectivity");
        return;
    }

    var light = Light3D.Ambient(0.1, 0.2, 0.3);
    Light3D.set_IsEnabled(light, false);
    Light3D.set_CastsShadows(light, true);

    if (Light3D.get_IsEnabled(light) != false) {
        Say("FAIL: set_Enabled should update Enabled");
        return;
    }
    if (Light3D.get_CastsShadows(light) != true) {
        Say("FAIL: set_CastsShadows should update CastsShadows");
        return;
    }

    Say("PASS");
}
