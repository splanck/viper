module TestDateTimeParse;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Time.DateTime.ParseISO
// COVER: Zanna.Time.DateTime.ParseDate
// COVER: Zanna.Time.DateTime.ParseTime
// COVER: Zanna.Time.DateTime.TryParse
// COVER: Zanna.Time.DateTime.Year
// COVER: Zanna.Time.DateTime.Month
// COVER: Zanna.Time.DateTime.Day

func testParseISO() {
    setTest("ParseISO");

    var ts = Zanna.Time.DateTime.ParseIso8601("2024-01-15T10:30:00Z");
    assertNeqInt(ts, 0, "ParseISO returns non-zero timestamp");

    var year = Zanna.Time.DateTime.Year(ts);
    assertEqInt(year, 2024, "parsed year");

    var month = Zanna.Time.DateTime.Month(ts);
    assertEqInt(month, 1, "parsed month");

    var day = Zanna.Time.DateTime.Day(ts);
    assertEqInt(day, 15, "parsed day");
}

func testParseISOComponents() {
    setTest("ParseISOComponents");

    var ts = Zanna.Time.DateTime.ParseIso8601("2024-06-20T14:45:30Z");
    var year = Zanna.Time.DateTime.Year(ts);
    assertEqInt(year, 2024, "ISO year");

    var month = Zanna.Time.DateTime.Month(ts);
    assertEqInt(month, 6, "ISO month");

    var day = Zanna.Time.DateTime.Day(ts);
    assertEqInt(day, 20, "ISO day");
}

func testParseDate() {
    setTest("ParseDate");

    var ts = Zanna.Time.DateTime.ParseDate("2024-01-15");
    assertNeqInt(ts, 0, "ParseDate returns non-zero");

    var year = Zanna.Time.DateTime.Year(ts);
    assertEqInt(year, 2024, "date year");

    var month = Zanna.Time.DateTime.Month(ts);
    assertEqInt(month, 1, "date month");

    var day = Zanna.Time.DateTime.Day(ts);
    assertEqInt(day, 15, "date day");
}

func testParseTime() {
    setTest("ParseTime");

    // 10:30:00 = 10*3600 + 30*60 = 37800 seconds
    var secs = Zanna.Time.DateTime.ParseTime("10:30:00");
    assertEqInt(secs, 37800, "ParseTime 10:30:00 = 37800s");

    // 10:30 (no seconds) should also be 37800
    var secs2 = Zanna.Time.DateTime.ParseTime("10:30");
    assertEqInt(secs2, 37800, "ParseTime 10:30 = 37800s");
}

func testParseTimeMidnight() {
    setTest("ParseTimeMidnight");

    var secs = Zanna.Time.DateTime.ParseTime("00:00:00");
    assertEqInt(secs, 0, "midnight = 0 seconds");

    var secs2 = Zanna.Time.DateTime.ParseTime("23:59:59");
    // 23*3600 + 59*60 + 59 = 82800 + 3540 + 59 = 86399
    assertEqInt(secs2, 86399, "23:59:59 = 86399 seconds");
}

func testTryParseISO() {
    setTest("TryParseISO");

    var parsed = Zanna.Time.DateTime.TryParse("2024-01-15T10:30:00Z");
    assertTrue(parsed.IsSome, "TryParse ISO string returns Some");
    var ts = parsed.UnwrapI64();

    var year = Zanna.Time.DateTime.Year(ts);
    assertEqInt(year, 2024, "TryParse year");
}

func testTryParseDateOnly() {
    setTest("TryParseDateOnly");

    var parsedDate = Zanna.Time.DateTime.TryParse("2024-03-25");
    assertTrue(parsedDate.IsSome, "TryParse date-only returns Some");
    var ts = parsedDate.UnwrapI64();

    var month = Zanna.Time.DateTime.Month(ts);
    assertEqInt(month, 3, "TryParse date-only month");
}

func testTryParseInvalid() {
    setTest("TryParseInvalid");

    var parsedBad = Zanna.Time.DateTime.TryParse("not-a-date");
    assertTrue(parsedBad.IsNone, "TryParse invalid returns None");

    var parsedEmpty = Zanna.Time.DateTime.TryParse("");
    assertTrue(parsedEmpty.IsNone, "TryParse empty returns None");
}

func start() {
    testParseISO();
    testParseISOComponents();
    testParseDate();
    testParseTime();
    testParseTimeMidnight();
    testTryParseISO();
    testTryParseDateOnly();
    testTryParseInvalid();

    report();
}
