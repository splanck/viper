module TestFile;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.IO.File.Exists
// COVER: Zanna.IO.File.WriteAllText
// COVER: Zanna.IO.File.ReadAllText
// COVER: Zanna.IO.File.Append
// COVER: Zanna.IO.File.Size
// COVER: Zanna.IO.File.Delete
// COVER: Zanna.IO.TempFile.PathWithPrefix

func testTextFileRoundtrip() {
    setTest("TextFileRoundtrip");

    var path = Zanna.IO.TempFile.PathWithPrefix("zia_file_");
    if (Zanna.IO.File.Exists(path)) {
        Zanna.IO.File.Delete(path);
    }

    Zanna.IO.File.WriteAllText(path, "alpha");
    assertTrue(Zanna.IO.File.Exists(path), "created file exists");
    assertEqStr(Zanna.IO.File.ReadAllText(path), "alpha", "read all text");
    assertGtInt(Zanna.IO.File.SizeBytes(path), 0, "file size after write");

    Zanna.IO.File.Append(path, " beta");
    assertEqStr(Zanna.IO.File.ReadAllText(path), "alpha beta", "append text");

    Zanna.IO.File.Delete(path);
    assertFalse(Zanna.IO.File.Exists(path), "deleted file missing");
}

func start() {
    testTextFileRoundtrip();

    report();
}
