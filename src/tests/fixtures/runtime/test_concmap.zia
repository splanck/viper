// Test: ConcurrentMap thread-safe hash map
module TestConcMap;

bind Zanna.Terminal;

func start() {
    var cm = Zanna.Threads.ConcurrentMap.New();

    // Empty initially
    var len = Zanna.Threads.ConcurrentMap.get_Count(cm);
    if (len != 0) {
        Say("FAIL: initial len should be 0");
        return;
    }

    var empty = Zanna.Threads.ConcurrentMap.get_IsEmpty(cm);
    if (empty != true) {
        Say("FAIL: should be empty initially");
        return;
    }

    // Set some values
    Zanna.Threads.ConcurrentMap.Set(cm, "alpha", 1);
    Zanna.Threads.ConcurrentMap.Set(cm, "beta", 2);
    Zanna.Threads.ConcurrentMap.Set(cm, "gamma", 3);

    len = Zanna.Threads.ConcurrentMap.get_Count(cm);
    if (len != 3) {
        Say("FAIL: len should be 3");
        return;
    }

    // Has
    var hasAlpha = Zanna.Threads.ConcurrentMap.Has(cm, "alpha");
    if (hasAlpha != true) {
        Say("FAIL: should have alpha");
        return;
    }

    var hasDelta = Zanna.Threads.ConcurrentMap.Has(cm, "delta");
    if (hasDelta != false) {
        Say("FAIL: should not have delta");
        return;
    }

    // SetIfMissing — alpha exists, so should fail
    var inserted = Zanna.Threads.ConcurrentMap.SetIfMissing(cm, "alpha", 99);
    if (inserted != false) {
        Say("FAIL: SetIfMissing should return 0 for existing key");
        return;
    }

    // SetIfMissing — delta doesn't exist, should succeed
    var inserted2 = Zanna.Threads.ConcurrentMap.SetIfMissing(cm, "delta", 4);
    if (inserted2 != true) {
        Say("FAIL: SetIfMissing should return 1 for new key");
        return;
    }

    len = Zanna.Threads.ConcurrentMap.get_Count(cm);
    if (len != 4) {
        Say("FAIL: len should be 4 after SetIfMissing");
        return;
    }

    // Remove
    var removed = Zanna.Threads.ConcurrentMap.Remove(cm, "beta");
    if (removed != true) {
        Say("FAIL: Remove should return 1");
        return;
    }

    len = Zanna.Threads.ConcurrentMap.get_Count(cm);
    if (len != 3) {
        Say("FAIL: len should be 3 after Remove");
        return;
    }

    // Keys snapshot
    var keys = Zanna.Threads.ConcurrentMap.Keys(cm);
    var klen = Zanna.Collections.Seq.get_Count(keys);
    if (klen != 3) {
        Say("FAIL: Keys seq should have 3 items");
        return;
    }

    // Values snapshot
    var vals = Zanna.Threads.ConcurrentMap.Values(cm);
    var vlen = Zanna.Collections.Seq.get_Count(vals);
    if (vlen != 3) {
        Say("FAIL: Values seq should have 3 items");
        return;
    }

    // Clear
    Zanna.Threads.ConcurrentMap.Clear(cm);
    len = Zanna.Threads.ConcurrentMap.get_Count(cm);
    if (len != 0) {
        Say("FAIL: len should be 0 after Clear");
        return;
    }

    Say("RESULT: ok");
}
