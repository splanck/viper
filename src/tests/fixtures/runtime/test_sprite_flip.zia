// Test: Sprite FlipX/FlipY properties
module TestSpriteFlip;

bind Zanna.Terminal;

func start() {
    // Create a small pixel buffer
    var px = new Zanna.Graphics.Pixels(4, 4);

    // Create sprite from pixels
    var sprite = new Zanna.Graphics.Sprite(px);

    // Default: no flip
    var fx = Zanna.Graphics.Sprite.get_FlipX(sprite);
    var fy = Zanna.Graphics.Sprite.get_FlipY(sprite);

    if (fx != false) {
        Say("FAIL: FlipX default should be 0");
        return;
    }
    if (fy != false) {
        Say("FAIL: FlipY default should be 0");
        return;
    }

    // Set FlipX
    Zanna.Graphics.Sprite.set_FlipX(sprite, true);
    fx = Zanna.Graphics.Sprite.get_FlipX(sprite);
    if (fx != true) {
        Say("FAIL: FlipX should be 1 after set");
        return;
    }

    // Set FlipY
    Zanna.Graphics.Sprite.set_FlipY(sprite, true);
    fy = Zanna.Graphics.Sprite.get_FlipY(sprite);
    if (fy != true) {
        Say("FAIL: FlipY should be 1 after set");
        return;
    }

    // Unset FlipX
    Zanna.Graphics.Sprite.set_FlipX(sprite, false);
    fx = Zanna.Graphics.Sprite.get_FlipX(sprite);
    if (fx != false) {
        Say("FAIL: FlipX should be 0 after unset");
        return;
    }

    Say("RESULT: ok");
}
