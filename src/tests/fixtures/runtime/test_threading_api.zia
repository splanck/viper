// Test: Threading API - SafeI64, Channel, Gate, CancelToken, RwLock, Barrier
module TestThreadingApi;

bind Zanna.Terminal;

func start() {
    // === Test 1: SafeI64 ===
    var si = Zanna.Threads.SafeI64.New(42);
    var val = Zanna.Threads.SafeI64.Get(si);
    if (val != 42) {
        Say("FAIL: SafeI64 initial value should be 42");
        return;
    }

    Zanna.Threads.SafeI64.Set(si, 100);
    val = Zanna.Threads.SafeI64.Get(si);
    if (val != 100) {
        Say("FAIL: SafeI64 value should be 100 after Set");
        return;
    }

    var added = Zanna.Threads.SafeI64.Add(si, 5);
    if (added != 105) {
        Say("FAIL: SafeI64.Add(5) should return 105");
        return;
    }

    val = Zanna.Threads.SafeI64.Get(si);
    if (val != 105) {
        Say("FAIL: SafeI64 value should be 105 after Add");
        return;
    }

    // CompareExchange: expect 105, set 200
    var prev = Zanna.Threads.SafeI64.CompareExchange(si, 105, 200);
    if (prev != 105) {
        Say("FAIL: CAS should return old value 105");
        return;
    }
    val = Zanna.Threads.SafeI64.Get(si);
    if (val != 200) {
        Say("FAIL: value should be 200 after CAS");
        return;
    }

    // CAS with wrong expected: should not change
    prev = Zanna.Threads.SafeI64.CompareExchange(si, 999, 300);
    if (prev != 200) {
        Say("FAIL: CAS with wrong expected should return current value 200");
        return;
    }
    val = Zanna.Threads.SafeI64.Get(si);
    if (val != 200) {
        Say("FAIL: value should still be 200 after failed CAS");
        return;
    }

    // === Test 2: Channel ===
    var ch = Zanna.Threads.Channel.New(5);
    var cap = Zanna.Threads.Channel.get_Capacity(ch);
    if (cap != 5) {
        Say("FAIL: channel capacity should be 5");
        return;
    }

    var empty = Zanna.Threads.Channel.get_IsEmpty(ch);
    if (empty != true) {
        Say("FAIL: channel should be empty initially");
        return;
    }

    // Send actual heap objects (Seq instances) through the channel
    var msg1 = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(msg1, 10);
    var msg2 = Zanna.Collections.Seq.New();
    Zanna.Collections.Seq.Push(msg2, 20);
    Zanna.Collections.Seq.Push(msg2, 30);

    Zanna.Threads.Channel.Send(ch, msg1);
    Zanna.Threads.Channel.Send(ch, msg2);

    var chlen = Zanna.Threads.Channel.get_Count(ch);
    if (chlen != 2) {
        Say("FAIL: channel len should be 2");
        return;
    }

    var full = Zanna.Threads.Channel.get_IsFull(ch);
    if (full != false) {
        Say("FAIL: channel should not be full (2/5)");
        return;
    }

    // Receive and verify by checking Seq length
    var r1 = Zanna.Threads.Channel.Recv(ch);
    var r1len = Zanna.Collections.Seq.get_Count(r1);
    if (r1len != 1) {
        Say("FAIL: first recv Seq should have len 1");
        return;
    }

    var r2 = Zanna.Threads.Channel.Recv(ch);
    var r2len = Zanna.Collections.Seq.get_Count(r2);
    if (r2len != 2) {
        Say("FAIL: second recv Seq should have len 2");
        return;
    }

    // Close
    Zanna.Threads.Channel.Close(ch);
    var closed = Zanna.Threads.Channel.get_IsClosed(ch);
    if (closed != true) {
        Say("FAIL: channel should be closed");
        return;
    }

    // === Test 3: Gate (counting semaphore) ===
    var gate = Zanna.Threads.Gate.New(3);
    var permits = Zanna.Threads.Gate.get_Permits(gate);
    if (permits != 3) {
        Say("FAIL: gate should have 3 permits");
        return;
    }

    // TryEnter should succeed 3 times
    var g1 = Zanna.Threads.Gate.TryEnter(gate);
    var g2 = Zanna.Threads.Gate.TryEnter(gate);
    var g3 = Zanna.Threads.Gate.TryEnter(gate);
    if (g1 != true) {
        Say("FAIL: first gate enter should succeed");
        return;
    }
    if (g3 != true) {
        Say("FAIL: third gate enter should succeed");
        return;
    }

    // Fourth should fail
    var g4 = Zanna.Threads.Gate.TryEnter(gate);
    if (g4 != false) {
        Say("FAIL: fourth gate enter should fail");
        return;
    }

    // Leave 2 permits
    Zanna.Threads.Gate.LeaveMany(gate, 2);
    permits = Zanna.Threads.Gate.get_Permits(gate);
    if (permits != 2) {
        Say("FAIL: gate should have 2 permits after LeaveMany");
        return;
    }

    // Leave remaining 1
    Zanna.Threads.Gate.Leave(gate);
    permits = Zanna.Threads.Gate.get_Permits(gate);
    if (permits != 3) {
        Say("FAIL: gate should be back to 3 permits");
        return;
    }

    // === Test 4: CancelToken ===
    var token = Zanna.Threads.CancelToken.New();
    var isCancelled = Zanna.Threads.CancelToken.get_IsCancelled(token);
    if (isCancelled != false) {
        Say("FAIL: token should not be cancelled initially");
        return;
    }

    Zanna.Threads.CancelToken.Cancel(token);
    isCancelled = Zanna.Threads.CancelToken.get_IsCancelled(token);
    if (isCancelled != true) {
        Say("FAIL: token should be cancelled after Cancel");
        return;
    }

    Zanna.Threads.CancelToken.Reset(token);
    isCancelled = Zanna.Threads.CancelToken.get_IsCancelled(token);
    if (isCancelled != false) {
        Say("FAIL: token should not be cancelled after Reset");
        return;
    }

    // === Test 5: RwLock ===
    var lock = Zanna.Threads.RwLock.New();
    var readers = Zanna.Threads.RwLock.get_Readers(lock);
    if (readers != 0) {
        Say("FAIL: no readers initially");
        return;
    }

    // Acquire read lock
    Zanna.Threads.RwLock.ReadEnter(lock);
    readers = Zanna.Threads.RwLock.get_Readers(lock);
    if (readers != 1) {
        Say("FAIL: should have 1 reader");
        return;
    }

    Zanna.Threads.RwLock.ReadExit(lock);
    readers = Zanna.Threads.RwLock.get_Readers(lock);
    if (readers != 0) {
        Say("FAIL: should have 0 readers after exit");
        return;
    }

    // Write lock
    Zanna.Threads.RwLock.WriteEnter(lock);
    var isWriteLocked = Zanna.Threads.RwLock.get_IsWriteLocked(lock);
    if (isWriteLocked != true) {
        Say("FAIL: should be write locked");
        return;
    }
    Zanna.Threads.RwLock.WriteExit(lock);

    // === Test 6: Barrier ===
    var barrier = Zanna.Threads.Barrier.New(1);
    var parties = Zanna.Threads.Barrier.get_Parties(barrier);
    if (parties != 1) {
        Say("FAIL: barrier should have 1 party");
        return;
    }

    var waiting = Zanna.Threads.Barrier.get_Waiting(barrier);
    if (waiting != 0) {
        Say("FAIL: no one waiting initially");
        return;
    }

    // Single-party barrier: arrive immediately releases
    Zanna.Threads.Barrier.Arrive(barrier);

    Say("RESULT: ok");
}
