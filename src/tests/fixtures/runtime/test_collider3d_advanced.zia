module TestCollider3DAdvanced;

bind Viper.Graphics;
bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func heightColor(hi: Integer, lo: Integer) -> Integer {
    return hi * 16777216 + lo * 65536 + 255;
}

func start() {
    var world = PhysicsWorld3D.New(0.0, 0.0, 0.0);

    var mesh = Mesh3D.Box(2.0, 2.0, 2.0);
    var hull = Collider3D.NewConvexHull(mesh);
    var compound = Collider3D.NewCompound();
    var xf = Transform3D.New();
    Transform3D.SetPosition(xf, 2.0, 0.0, 0.0);
    Collider3D.AddChild(compound, hull, xf);

    var staticBody = PhysicsBody3D.New(0.0);
    staticBody.Collider = compound;
    PhysicsWorld3D.Add(world, staticBody);

    var sphere = PhysicsBody3D.Sphere(0.45, 1.0);
    PhysicsBody3D.SetPosition(sphere, 1.2, 0.0, 0.0);
    PhysicsWorld3D.Add(world, sphere);
    PhysicsWorld3D.Step(world, 0.016);

    if (PhysicsWorld3D.get_CollisionCount(world) <= 0) {
        Say("FAIL: compound convex collider should collide with sphere");
        return;
    }

    var boundsMax = Collider3D.GetLocalBoundsMax(compound);
    if (Vec3.get_X(boundsMax) <= 2.5) {
        Say("FAIL: compound bounds should include child offset");
        return;
    }

    var pixels = Pixels.New(4, 4);
    var row = 0;
    while (row < 4) {
        var col = 0;
        while (col < 4) {
            var h = 128 + col * 16;
            Pixels.Set(pixels, col, row, heightColor(h, h / 2));
            col = col + 1;
        }
        row = row + 1;
    }

    var heightfield = Collider3D.NewHeightfield(pixels, 1.0, 2.0, 1.0);
    var terrainBody = PhysicsBody3D.New(0.0);
    terrainBody.Collider = heightfield;
    PhysicsBody3D.SetPosition(terrainBody, 0.0, 0.0, 0.0);
    PhysicsWorld3D.Remove(world, sphere);
    sphere = PhysicsBody3D.Sphere(0.35, 1.0);
    PhysicsBody3D.SetPosition(sphere, 0.8, 0.9, 0.0);
    PhysicsWorld3D.Add(world, terrainBody);
    PhysicsWorld3D.Add(world, sphere);
    PhysicsWorld3D.Step(world, 0.016);

    if (PhysicsWorld3D.get_CollisionCount(world) <= 0) {
        Say("FAIL: heightfield collider should collide with sphere");
        return;
    }

    Say("PASS");
}
