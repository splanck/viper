// BUG-011 regression test: Zanna.Math.Random should be constructible via `new`
// and should keep per-instance RNG state.
module TestBugfixRandomNew;

bind Zanna.Terminal;

func start() {
    var passed = true;

    // Test: NEW should work for Random with a seed argument.
    var rng = new Zanna.Math.Random(42);
    var val1 = rng.NextInt(100);
    var val2 = rng.NextInt(100);

    // Values should be in range [0, 100)
    if (val1 < 0) {
        Say("FAIL: val1 < 0");
        passed = false;
    }
    if (val1 >= 100) {
        Say("FAIL: val1 >= 100");
        passed = false;
    }
    if (val2 < 0) {
        Say("FAIL: val2 < 0");
        passed = false;
    }
    if (val2 >= 100) {
        Say("FAIL: val2 >= 100");
        passed = false;
    }

    // Same seed should produce the same instance sequence.
    var rng2 = new Zanna.Math.Random(42);
    var val1b = rng2.NextInt(100);
    var val2b = rng2.NextInt(100);

    if (val1 != val1b) {
        Say("FAIL: determinism broken (val1)");
        passed = false;
    }
    if (val2 != val2b) {
        Say("FAIL: determinism broken (val2)");
        passed = false;
    }

    var ranged = rng.Range(10, 20);
    if (ranged < 10 || ranged > 20) {
        Say("FAIL: Range(min,max) out of range");
        passed = false;
    }

    rng.Seed(99);
    var reseed1 = rng.NextInt(1000);
    rng.Seed(99);
    var reseed2 = rng.NextInt(1000);
    if (reseed1 != reseed2) {
        Say("FAIL: instance Seed did not reset sequence");
        passed = false;
    }

    // Constructing an instance must not mutate the global/static RNG sequence.
    Zanna.Math.Random.Seed(7);
    var globalExpected = Zanna.Math.Random.NextInt(1000);
    Zanna.Math.Random.Seed(7);
    var unused = new Zanna.Math.Random(123);
    var globalActual = Zanna.Math.Random.NextInt(1000);
    if (globalActual != globalExpected) {
        Say("FAIL: Random constructor mutated global RNG state");
        passed = false;
    }

    if (passed) {
        Say("RESULT: ok");
    }
}
