// Test: Verify GPU backend selection and rendering
module TestCanvas3DBackend;

bind Zanna.Terminal;

func start() {
    var canvas = Zanna.Graphics3D.Canvas3D.New("Backend Test", 320, 240);
    var backend = canvas.Backend;
    Say("Backend: " + backend);

    var cam = Zanna.Graphics3D.Camera3D.New(60.0, 320.0 / 240.0, 0.1, 100.0);
    var eye = new Zanna.Math.Vec3(0.0, 2.0, 5.0);
    var target = new Zanna.Math.Vec3(0.0, 0.0, 0.0);
    var up = new Zanna.Math.Vec3(0.0, 1.0, 0.0);
    Zanna.Graphics3D.Camera3D.LookAt(cam, eye, target, up);

    var box = Zanna.Graphics3D.Mesh3D.Box(1.0, 1.0, 1.0);
    var mat = Zanna.Graphics3D.Material3D.FromColor(0.8, 0.3, 0.2);

    var light_dir = new Zanna.Math.Vec3(-1.0, -1.0, -0.5);
    var light = Zanna.Graphics3D.Light3D.Directional(light_dir, 1.0, 1.0, 1.0);
    Zanna.Graphics3D.Canvas3D.SetLight(canvas, 0, light);
    Zanna.Graphics3D.Canvas3D.SetAmbient(canvas, 0.15, 0.15, 0.15);

    // Render 3 frames
    var frame = 0;
    while (frame < 3) {
        Zanna.Graphics3D.Canvas3D.Poll(canvas);
        Zanna.Graphics3D.Canvas3D.Clear(canvas, 0.1, 0.1, 0.2);
        Zanna.Graphics3D.Canvas3D.Begin(canvas, cam);
        Zanna.Graphics3D.Canvas3D.DrawMesh(canvas, box, Zanna.Math.Mat4.Identity(), mat);
        Zanna.Graphics3D.Canvas3D.End(canvas);
        Zanna.Graphics3D.Canvas3D.Flip(canvas);
        frame = frame + 1;
    }

    Say("PASS");
}
