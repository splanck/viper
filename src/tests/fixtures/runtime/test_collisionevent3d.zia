module TestCollisionEvent3D;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) { d = 0.0 - d; }
    return d <= eps;
}

func start() {
    var world = PhysicsWorld3D.New(0.0, 0.0, 0.0);
    var floor = PhysicsBody3D.NewAABB(1.0, 1.0, 1.0, 0.0);
    var box = PhysicsBody3D.NewAABB(1.0, 1.0, 1.0, 1.0);
    PhysicsBody3D.SetPosition(floor, 0.0, 0.0, 0.0);
    PhysicsBody3D.SetPosition(box, 0.5, 0.0, 0.0);
    PhysicsWorld3D.Add(world, floor);
    PhysicsWorld3D.Add(world, box);

    PhysicsWorld3D.Step(world, 0.016);
    if (PhysicsWorld3D.get_EnterEventCount(world) != 1) {
        Say("FAIL: first overlap should create one enter event");
        return;
    }
    var enterEvt = PhysicsWorld3D.GetEnterEvent(world, 0);
    if (CollisionEvent3D.get_ContactCount(enterEvt) < 1) {
        Say("FAIL: enter event should expose at least one contact");
        return;
    }
    if (CollisionEvent3D.get_RelativeSpeed(enterEvt) < 0.0) {
        Say("FAIL: enter event should expose relative speed");
        return;
    }
    var cp = CollisionEvent3D.GetContact(enterEvt, 0);
    if (ContactPoint3D.get_Separation(cp) >= 0.0) {
        Say("FAIL: penetrating contact separation should be negative");
        return;
    }

    PhysicsWorld3D.Step(world, 0.016);
    if (PhysicsWorld3D.get_StayEventCount(world) != 1) {
        Say("FAIL: persistent overlap should create one stay event");
        return;
    }

    PhysicsBody3D.SetPosition(box, 5.0, 0.0, 0.0);
    PhysicsBody3D.SetVelocity(box, 0.0, 0.0, 0.0);
    PhysicsWorld3D.Step(world, 0.016);
    if (PhysicsWorld3D.get_ExitEventCount(world) != 1) {
        Say("FAIL: separation should create one exit event");
        return;
    }

    var triggerWorld = PhysicsWorld3D.New(0.0, 0.0, 0.0);
    var trigger = PhysicsBody3D.NewAABB(1.0, 1.0, 1.0, 0.0);
    var body = PhysicsBody3D.NewAABB(1.0, 1.0, 1.0, 1.0);
    PhysicsBody3D.set_IsTrigger(trigger, true);
    PhysicsBody3D.SetPosition(trigger, 0.0, 0.0, 0.0);
    PhysicsBody3D.SetPosition(body, 0.5, 0.0, 0.0);
    PhysicsWorld3D.Add(triggerWorld, trigger);
    PhysicsWorld3D.Add(triggerWorld, body);
    PhysicsWorld3D.Step(triggerWorld, 0.016);

    var evt = PhysicsWorld3D.GetCollisionEvent(triggerWorld, 0);
    if (CollisionEvent3D.get_IsTrigger(evt) == false) {
        Say("FAIL: trigger overlap should set IsTrigger");
        return;
    }
    if (near(CollisionEvent3D.get_NormalImpulse(evt), 0.0, 0.0001) == false) {
        Say("FAIL: trigger overlap should not produce solver impulse");
        return;
    }

    Say("PASS");
}
