module TestSceneNodeBindings;

bind Viper.Graphics3D;
bind Viper.Math;
bind Viper.Terminal;

func start() {
    var scene = SceneGraph.New();
    var parent = SceneNode.New();
    var child = SceneNode.New();
    var body = PhysicsBody3D.Sphere(0.5, 1.0);

    SceneNode.SetPosition(parent, 5.0, 0.0, 0.0);
    SceneNode.AddChild(parent, child);
    SceneGraph.Add(scene, parent);

    SceneNode.BindBody(child, body);
    child.SyncMode = 0;
    PhysicsBody3D.SetPosition(body, 6.0, 2.0, -3.0);
    SceneGraph.SyncBindings(scene, 0.016);

    var pos = child.Position;
    if (Vec3.get_X(pos) < 0.99 || Vec3.get_X(pos) > 1.01) {
        Say("FAIL: NodeFromBody should compute child local x");
        return;
    }
    if (child.Body != body) {
        Say("FAIL: Body property should return the bound body");
        return;
    }

    var skel = Skeleton3D.New();
    var rootBone = Skeleton3D.AddBone(skel, "root", -1, Mat4.Identity());
    Skeleton3D.ComputeInverseBind(skel);
    var walk = Animation3D.New("walk", 1.0);
    Animation3D.set_Looping(walk, true);
    var rot = Quat.Identity();
    var scl = Vec3.One();
    Animation3D.AddKeyframe(walk, rootBone, 0.0, Vec3.Zero(), rot, scl);
    Animation3D.AddKeyframe(walk, rootBone, 1.0, Vec3.New(6.0, 0.0, 0.0), rot, scl);

    var controller = AnimController3D.New(skel);
    AnimController3D.AddState(controller, "walk", walk);
    AnimController3D.SetRootMotionBone(controller, rootBone);
    AnimController3D.Play(controller, "walk");
    AnimController3D.Update(controller, 0.5);

    var animNode = SceneNode.New();
    SceneGraph.Add(scene, animNode);
    SceneNode.BindAnimator(animNode, controller);
    animNode.SyncMode = 2;
    SceneGraph.SyncBindings(scene, 0.016);

    pos = animNode.Position;
    if (Vec3.get_X(pos) < 2.9 || Vec3.get_X(pos) > 3.1) {
        Say("FAIL: SyncMode=NodeFromAnimatorRootMotion should consume root motion");
        return;
    }
    if (animNode.Animator != controller) {
        Say("FAIL: Animator property should return the bound controller");
        return;
    }

    Say("PASS");
}
