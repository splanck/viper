module TestCanvas3DRenderScale;

bind Zanna.Graphics3D;
bind Zanna.Graphics;
bind Zanna.Math;
bind Zanna.Terminal;

// Render-scale coverage (software backend):
//   - TrySetRenderScale succeeds where BackendSupports("render-scale") is true.
//   - A scaled frame still fills the full-size framebuffer (upscale at present)
//     and the drawn geometry remains visible at the same screen location.
//   - Restoring scale 1.0 always succeeds.

func redAt(canvas: Canvas3D, gx: Integer, gy: Integer) -> Integer {
    var shot = Canvas3D.Screenshot(canvas);
    return (Pixels.Get(shot, gx, gy) / 16777216) % 256;
}

func drawIt(canvas: Canvas3D, cam: Camera3D, box: Mesh3D, mat: Material3D) {
    Canvas3D.Clear(canvas, 0.0, 0.0, 0.0);
    Canvas3D.Begin(canvas, cam);
    Canvas3D.DrawMesh(canvas, box, Mat4.Translate(0.0, 0.0, 0.0), mat);
    Canvas3D.End(canvas);
    Canvas3D.Flip(canvas);
}

func start() {
    var canvas = Canvas3D.New("Render Scale", 96, 64);
    if (!Canvas3D.BackendSupports(canvas, "render-scale")) {
        Say("PASS"); // backend without render-scale support
        return;
    }
    var cam = Camera3D.New(60.0, 1.5, 0.1, 50.0);
    Camera3D.LookAt(cam,
                    new Vec3(0.0, 0.0, 4.0),
                    new Vec3(0.0, 0.0, 0.0),
                    new Vec3(0.0, 1.0, 0.0));
    var box = Mesh3D.Box(2.0, 2.0, 2.0);
    var mat = Material3D.FromColor(1.0, 0.1, 0.1);
    Canvas3D.SetAmbient(canvas, 1.0, 1.0, 1.0);

    drawIt(canvas, cam, box, mat);
    var fullRed = redAt(canvas, 48, 32);
    if (fullRed < 64) {
        Say("FAIL: native-scale frame should show the red box at screen center");
        return;
    }

    if (!Canvas3D.TrySetRenderScale(canvas, 0.5)) {
        Say("FAIL: TrySetRenderScale(0.5) should succeed when the capability is advertised");
        return;
    }
    if (canvas.RenderScale > 0.51 || canvas.RenderScale < 0.49) {
        Say("FAIL: RenderScale should report the applied scale");
        return;
    }
    drawIt(canvas, cam, box, mat);
    var scaledRed = redAt(canvas, 48, 32);
    if (scaledRed < 64) {
        Say("FAIL: half-scale frame should still show the red box at screen center");
        return;
    }
    var corner = redAt(canvas, 2, 2);
    if (corner > 32) {
        Say("FAIL: half-scale frame corners should stay background-colored");
        return;
    }

    if (!Canvas3D.TrySetRenderScale(canvas, 1.0)) {
        Say("FAIL: restoring native scale must always succeed");
        return;
    }
    drawIt(canvas, cam, box, mat);
    if (redAt(canvas, 48, 32) < 64) {
        Say("FAIL: native-scale rendering should work after restoring the scale");
        return;
    }

    Say("PASS");
}
