// BUG-007 regression: Ring constructors should work with default and explicit capacity.
module TestBugfixRing;

bind Zanna.Terminal;

func start() {
    var passed = true;

    // Test Ring with explicit capacity
    var ring = new Zanna.Collections.Ring(16);
    if (ring.Capacity != 16) {
        Say("FAIL: Ring(16).Cap should be 16");
        passed = false;
    }
    if (!ring.IsEmpty) {
        Say("FAIL: new Ring should be empty");
        passed = false;
    }

    var defaultRing = new Zanna.Collections.Ring();
    if (defaultRing.Capacity <= 0) {
        Say("FAIL: default Ring capacity should be positive");
        passed = false;
    }
    defaultRing.Push("a");
    defaultRing.Push("b");
    if (defaultRing.Count != 2) {
        Say("FAIL: default Ring should accept pushed values");
        passed = false;
    }

    if (passed) {
        Say("RESULT: ok");
    }
}
