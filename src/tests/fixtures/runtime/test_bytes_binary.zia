module TestBytesBinary;

bind "./_support";

// EXPECT_OUT: RESULT: ok
// COVER: Zanna.Collections.Bytes.WriteI16LE
// COVER: Zanna.Collections.Bytes.ReadI16LE
// COVER: Zanna.Collections.Bytes.WriteI16BE
// COVER: Zanna.Collections.Bytes.ReadI16BE
// COVER: Zanna.Collections.Bytes.WriteI32LE
// COVER: Zanna.Collections.Bytes.ReadI32LE
// COVER: Zanna.Collections.Bytes.WriteI32BE
// COVER: Zanna.Collections.Bytes.ReadI32BE
// COVER: Zanna.Collections.Bytes.WriteI64LE
// COVER: Zanna.Collections.Bytes.ReadI64LE
// COVER: Zanna.Collections.Bytes.WriteI64BE
// COVER: Zanna.Collections.Bytes.ReadI64BE

func testI16LEWriteRead() {
    setTest("I16LEWriteRead");

    var b = Zanna.Collections.Bytes.New(8);
    Zanna.Collections.Bytes.WriteI16LittleEndian(b, 0, 0x1234);

    var v = Zanna.Collections.Bytes.ReadI16LittleEndian(b, 0);
    assertEqInt(v, 0x1234, "i16le roundtrip");

    // Verify endianness: LE means low byte first
    var lo = Zanna.Collections.Bytes.Get(b, 0);
    var hi = Zanna.Collections.Bytes.Get(b, 1);
    assertEqInt(lo, 0x34, "i16le low byte");
    assertEqInt(hi, 0x12, "i16le high byte");
}

func testI16BEWriteRead() {
    setTest("I16BEWriteRead");

    var b = Zanna.Collections.Bytes.New(8);
    Zanna.Collections.Bytes.WriteI16BigEndian(b, 0, 0x1234);

    var v = Zanna.Collections.Bytes.ReadI16BigEndian(b, 0);
    assertEqInt(v, 0x1234, "i16be roundtrip");

    // Verify endianness: BE means high byte first
    var hi = Zanna.Collections.Bytes.Get(b, 0);
    var lo = Zanna.Collections.Bytes.Get(b, 1);
    assertEqInt(hi, 0x12, "i16be high byte first");
    assertEqInt(lo, 0x34, "i16be low byte second");
}

func testI32LEWriteRead() {
    setTest("I32LEWriteRead");

    var b = Zanna.Collections.Bytes.New(8);
    Zanna.Collections.Bytes.WriteI32LittleEndian(b, 0, 0x12345678);

    var v = Zanna.Collections.Bytes.ReadI32LittleEndian(b, 0);
    assertEqInt(v, 0x12345678, "i32le roundtrip");

    // Verify endianness: LE means lowest byte first
    assertEqInt(Zanna.Collections.Bytes.Get(b, 0), 0x78, "i32le byte 0");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 1), 0x56, "i32le byte 1");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 2), 0x34, "i32le byte 2");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 3), 0x12, "i32le byte 3");
}

func testI32BEWriteRead() {
    setTest("I32BEWriteRead");

    var b = Zanna.Collections.Bytes.New(8);
    Zanna.Collections.Bytes.WriteI32BigEndian(b, 0, 0x12345678);

    var v = Zanna.Collections.Bytes.ReadI32BigEndian(b, 0);
    assertEqInt(v, 0x12345678, "i32be roundtrip");

    // Verify endianness: BE means highest byte first
    assertEqInt(Zanna.Collections.Bytes.Get(b, 0), 0x12, "i32be byte 0");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 1), 0x34, "i32be byte 1");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 2), 0x56, "i32be byte 2");
    assertEqInt(Zanna.Collections.Bytes.Get(b, 3), 0x78, "i32be byte 3");
}

func testI64LEWriteRead() {
    setTest("I64LEWriteRead");

    var b = Zanna.Collections.Bytes.New(16);
    Zanna.Collections.Bytes.WriteI64LittleEndian(b, 0, 1234567890123);

    var v = Zanna.Collections.Bytes.ReadI64LittleEndian(b, 0);
    assertEqInt(v, 1234567890123, "i64le roundtrip");
}

func testI64BEWriteRead() {
    setTest("I64BEWriteRead");

    var b = Zanna.Collections.Bytes.New(16);
    Zanna.Collections.Bytes.WriteI64BigEndian(b, 0, 9876543210987);

    var v = Zanna.Collections.Bytes.ReadI64BigEndian(b, 0);
    assertEqInt(v, 9876543210987, "i64be roundtrip");
}

func testOffsetWrites() {
    setTest("OffsetWrites");

    var b = Zanna.Collections.Bytes.New(16);

    // Write i16le at offset 2
    Zanna.Collections.Bytes.WriteI16LittleEndian(b, 2, 0x1234);
    var v1 = Zanna.Collections.Bytes.ReadI16LittleEndian(b, 2);
    assertEqInt(v1, 0x1234, "i16le at offset 2");

    // Write i32be at offset 8
    Zanna.Collections.Bytes.WriteI32BigEndian(b, 8, 0x11223344);
    var v2 = Zanna.Collections.Bytes.ReadI32BigEndian(b, 8);
    assertEqInt(v2, 0x11223344, "i32be at offset 8");

    // Original i16 at offset 2 should be undisturbed
    var v3 = Zanna.Collections.Bytes.ReadI16LittleEndian(b, 2);
    assertEqInt(v3, 0x1234, "i16le at offset 2 still intact");
}

func testSignedReads() {
    setTest("SignedReads");

    var b = Zanna.Collections.Bytes.New(16);
    Zanna.Collections.Bytes.WriteI16LittleEndian(b, 0, -1);
    Zanna.Collections.Bytes.WriteI16BigEndian(b, 2, -2);
    Zanna.Collections.Bytes.WriteI32LittleEndian(b, 4, -1);
    Zanna.Collections.Bytes.WriteI32BigEndian(b, 8, -2);

    assertEqInt(Zanna.Collections.Bytes.ReadI16LittleEndian(b, 0), -1, "i16le sign extension");
    assertEqInt(Zanna.Collections.Bytes.ReadI16BigEndian(b, 2), -2, "i16be sign extension");
    assertEqInt(Zanna.Collections.Bytes.ReadI32LittleEndian(b, 4), -1, "i32le sign extension");
    assertEqInt(Zanna.Collections.Bytes.ReadI32BigEndian(b, 8), -2, "i32be sign extension");
}

func start() {
    testI16LEWriteRead();
    testI16BEWriteRead();
    testI32LEWriteRead();
    testI32BEWriteRead();
    testI64LEWriteRead();
    testI64BEWriteRead();
    testOffsetWrites();
    testSignedReads();

    report();
}
