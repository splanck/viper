module test_game3d_sound_probe;

bind Zanna.Game3D as Game3D;
bind Zanna.Graphics3D as G3D;
bind Zanna.Math as Math;
bind Zanna.Audio as Sound;
bind Zanna.Terminal as Terminal;

func fail(message: String) {
    Terminal.Say("FAIL: " + message);
}

func near(a: Float, b: Float, eps: Float) -> Boolean {
    var d = a - b;
    if (d < 0.0) {
        d = 0.0 - d;
    }
    return d <= eps;
}

func start() {
    var world = Game3D.World3D.New("Game3D Audio Probe", 80, 60);
    var audio = world.Audio;
    var camera = world.Camera;
    var listener = audio.Listener;
    if (audio == null || listener == null) {
        fail("world did not create Sound3D/listener");
        return;
    }
    if (audio.ListenerFollowsCamera == false) {
        fail("listener should follow camera by default");
        return;
    }

    G3D.Camera3D.LookAt(
        camera,
        Math.Vec3.New(3.0, 2.0, 6.0),
        Math.Vec3.New(3.0, 2.0, 5.0),
        Math.Vec3.New(0.0, 1.0, 0.0));
    world.StepSimulation(0.1);
    var listenerPos = G3D.SoundListener3D.get_Position(listener);
    if (near(Math.Vec3.get_X(listenerPos), 3.0, 0.01) == false) {
        fail("listener did not follow camera");
        return;
    }

    audio.ListenerFollowCamera(false);
    G3D.Camera3D.LookAt(
        camera,
        Math.Vec3.New(8.0, 2.0, 6.0),
        Math.Vec3.New(8.0, 2.0, 5.0),
        Math.Vec3.New(0.0, 1.0, 0.0));
    world.StepSimulation(0.1);
    listenerPos = G3D.SoundListener3D.get_Position(listener);
    if (near(Math.Vec3.get_X(listenerPos), 3.0, 0.01) == false) {
        fail("listenerFollowCamera(false) did not freeze listener");
        return;
    }

    audio.SetListenerPose(Math.Vec3.New(9.0, 1.0, 2.0), Math.Vec3.New(0.0, 0.0, -1.0), Math.Vec3.New(0.0, 1.0, 0.0));
    listenerPos = G3D.SoundListener3D.get_Position(listener);
    if (near(Math.Vec3.get_X(listenerPos), 9.0, 0.01) == false) {
        fail("setListenerPose did not update listener position");
        return;
    }

    audio.SetAttenuation(2.0, 8.0);
    audio.Volume = 65;
    if (near(audio.MaxDistance, 8.0, 0.01) == false ||
        audio.Volume != 65) {
        fail("attenuation/volume settings did not stick");
        return;
    }

    var clip = Sound.Synth.Tone(440, 1000, 0);
    if (clip != null) {
        var oneShot = audio.PlayAt(clip, Math.Vec3.New(1.0, 0.0, 0.0));
        if (oneShot == null) {
            fail("playAt did not return an SoundSource3D");
            return;
        }
        if (near(G3D.SoundSource3D.get_MaxDistance(oneShot), 8.0, 0.01) == false) {
            fail("playAt did not apply attenuation");
            return;
        }

        var entity = Game3D.Entity3D.New();
        entity.SetPosition(1.0, 0.0, 0.0);
        world.Spawn(entity);
        var attached = audio.PlayAttached(clip, entity);
        if (attached == null) {
            fail("playAttached did not return an SoundSource3D");
            return;
        }
        entity.SetPosition(4.0, 0.0, 0.0);
        world.StepSimulation(0.1);
        var sourcePos = G3D.SoundSource3D.get_Position(attached);
        if (near(Math.Vec3.get_X(sourcePos), 4.0, 0.01) == false) {
            fail("attached source did not follow entity");
            return;
        }

        audio.Play2D(clip);
        if (audio.SourceCount < 2) {
            fail("Sound3D did not track created sources");
            return;
        }
        audio.ClearSources();
        if (audio.SourceCount != 0) {
            fail("clearSources did not clear source tracking");
            return;
        }
    }

    world.Destroy();
    Terminal.Say("PASS");
}
