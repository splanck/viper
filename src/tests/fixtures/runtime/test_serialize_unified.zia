// Test: Unified serialization interface
module TestSerializeUnified;

bind Zanna.Terminal;

func start() {
    // Format constants: JSON=0, XML=1, YAML=2, TOML=3, CSV=4

    // === Test 1: FormatName ===
    var jsonName = Zanna.Data.Serialize.FormatName(0);
    var xmlName = Zanna.Data.Serialize.FormatName(1);
    var yamlName = Zanna.Data.Serialize.FormatName(2);
    var tomlName = Zanna.Data.Serialize.FormatName(3);
    var csvName = Zanna.Data.Serialize.FormatName(4);
    // Just verify they return non-empty
    if (Zanna.String.get_Length(jsonName) < 1) { Say("FAIL: JSON format name should be non-empty"); return; }
    if (Zanna.String.get_Length(xmlName) < 1) { Say("FAIL: XML format name should be non-empty"); return; }

    // === Test 2: MimeType ===
    var jsonMime = Zanna.Data.Serialize.MimeType(0);
    if (Zanna.String.get_Length(jsonMime) < 1) { Say("FAIL: JSON MIME should be non-empty"); return; }

    // === Test 3: FormatFromName ===
    var jsonFmt = Zanna.Data.Serialize.FormatFromName("json");
    if (jsonFmt != 0) { Say("FAIL: FormatFromName(json) should be 0"); return; }

    var xmlFmt = Zanna.Data.Serialize.FormatFromName("xml");
    if (xmlFmt != 1) { Say("FAIL: FormatFromName(xml) should be 1"); return; }

    var unknownFmt = Zanna.Data.Serialize.FormatFromName("unknown");
    if (unknownFmt != -1) { Say("FAIL: FormatFromName(unknown) should be -1"); return; }

    // === Test 4: Parse JSON ===
    var json = "{\"name\":\"Alice\",\"age\":30}";
    var parsed = Zanna.Data.Serialize.Parse(json, 0);
    if (parsed == null) { Say("FAIL: JSON parse should return non-null"); return; }

    // === Test 5: Format back to JSON ===
    var formatted = Zanna.Data.Serialize.Format(parsed, 0);
    if (Zanna.String.get_Length(formatted) < 5) { Say("FAIL: formatted JSON should be non-empty"); return; }

    // === Test 6: FormatPretty ===
    var pretty = Zanna.Data.Serialize.FormatPretty(parsed, 0, 2);
    if (Zanna.String.get_Length(pretty) < 5) { Say("FAIL: pretty JSON should be non-empty"); return; }

    // === Test 7: IsValid ===
    var isValidJson = Zanna.Data.Serialize.IsValid(json, 0);
    if (isValidJson != true) { Say("FAIL: valid JSON should return true"); return; }

    // IsValid for clearly non-JSON text
    var invalidJson = "hello world";
    var isInvalid = Zanna.Data.Serialize.IsValid(invalidJson, 0);
    // Note: some validators may be lenient; just verify it doesn't crash
    // Skip strict check since validator may interpret plain text as valid string

    // === Test 8: Detect ===
    var detectedJson = Zanna.Data.Serialize.Detect(json);
    if (detectedJson != 0) { Say("FAIL: Detect should return 0 (JSON) for object"); return; }

    var xmlText = "<root><item>test</item></root>";
    var detectedXml = Zanna.Data.Serialize.Detect(xmlText);
    if (detectedXml != 1) { Say("FAIL: Detect should return 1 (XML) for xml"); return; }

    // === Test 9: AutoParse ===
    var autoParsed = Zanna.Data.Serialize.AutoParse(json);
    if (autoParsed == null) { Say("FAIL: AutoParse should return non-null"); return; }

    // === Test 10: Convert JSON → YAML ===
    var simpleJson = "{\"key\":\"value\"}";
    var asYaml = Zanna.Data.Serialize.Convert(simpleJson, 0, 2);
    if (Zanna.String.get_Length(asYaml) < 3) { Say("FAIL: Convert JSON→YAML should produce output"); return; }

    // === Test 11: ParseResult reports success as a structured Result ===
    var parseCheck = Zanna.Data.Serialize.ParseResult(simpleJson, 0);
    if (not parseCheck.IsOk) { Say("FAIL: ParseResult should succeed for valid JSON"); return; }

    Say("RESULT: ok");
}
