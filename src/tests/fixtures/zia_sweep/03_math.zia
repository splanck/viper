module TestMath;

bind "./_support";

// Comprehensive math tests

func start() {
    Zanna.Terminal.Say("=== Math Tests ===");

    testBasicArithmetic();
    testTrigonometry();
    testExponential();
    testRounding();
    testMinMax();
    testClamp();
    testLerp();

    report();
}

func testBasicArithmetic() {
    // Abs
    assertApprox(Zanna.Math.Abs(-5.5), 5.5, 0.001, "abs negative");
    assertApprox(Zanna.Math.Abs(3.3), 3.3, 0.001, "abs positive");
    assertApprox(Zanna.Math.Abs(0.0), 0.0, 0.001, "abs zero");

    // AbsInt
    assertEqInt(Zanna.Math.AbsInt(-10), 10, "absint negative");
    assertEqInt(Zanna.Math.AbsInt(7), 7, "absint positive");
    assertEqInt(Zanna.Math.AbsInt(0), 0, "absint zero");

    // Sqrt
    assertApprox(Zanna.Math.Sqrt(4.0), 2.0, 0.001, "sqrt 4");
    assertApprox(Zanna.Math.Sqrt(9.0), 3.0, 0.001, "sqrt 9");
    assertApprox(Zanna.Math.Sqrt(2.0), 1.414, 0.01, "sqrt 2");

    // Pow
    assertApprox(Zanna.Math.Pow(2.0, 3.0), 8.0, 0.001, "pow 2^3");
    assertApprox(Zanna.Math.Pow(10.0, 2.0), 100.0, 0.001, "pow 10^2");
    assertApprox(Zanna.Math.Pow(2.0, 0.5), 1.414, 0.01, "pow 2^0.5");
}

func testTrigonometry() {
    // Sin - 0, pi/2, pi
    assertApprox(Zanna.Math.Sin(0.0), 0.0, 0.001, "sin 0");
    assertApprox(Zanna.Math.Sin(1.5707963), 1.0, 0.001, "sin pi/2");

    // Cos
    assertApprox(Zanna.Math.Cos(0.0), 1.0, 0.001, "cos 0");
    assertApprox(Zanna.Math.Cos(3.1415926), -1.0, 0.001, "cos pi");

    // Tan
    assertApprox(Zanna.Math.Tan(0.0), 0.0, 0.001, "tan 0");
    assertApprox(Zanna.Math.Tan(0.785398), 1.0, 0.01, "tan pi/4");

    // Asin, Acos, Atan
    assertApprox(Zanna.Math.Asin(0.0), 0.0, 0.001, "asin 0");
    assertApprox(Zanna.Math.Acos(1.0), 0.0, 0.001, "acos 1");
    assertApprox(Zanna.Math.Atan(0.0), 0.0, 0.001, "atan 0");

    // Atan2
    assertApprox(Zanna.Math.Atan2(1.0, 1.0), 0.785398, 0.001, "atan2 1,1");

    // Hyperbolic
    assertApprox(Zanna.Math.Sinh(0.0), 0.0, 0.001, "sinh 0");
    assertApprox(Zanna.Math.Cosh(0.0), 1.0, 0.001, "cosh 0");
    assertApprox(Zanna.Math.Tanh(0.0), 0.0, 0.001, "tanh 0");
}

func testExponential() {
    // Exp
    assertApprox(Zanna.Math.Exp(0.0), 1.0, 0.001, "exp 0");
    assertApprox(Zanna.Math.Exp(1.0), 2.718, 0.01, "exp 1");

    // Log (natural)
    assertApprox(Zanna.Math.Log(1.0), 0.0, 0.001, "log 1");
    assertApprox(Zanna.Math.Log(2.718281828), 1.0, 0.001, "log e");

    // Log10
    assertApprox(Zanna.Math.Log10(10.0), 1.0, 0.001, "log10 10");
    assertApprox(Zanna.Math.Log10(100.0), 2.0, 0.001, "log10 100");
}

func testRounding() {
    // Floor
    assertApprox(Zanna.Math.Floor(3.7), 3.0, 0.001, "floor 3.7");
    assertApprox(Zanna.Math.Floor(-3.7), -4.0, 0.001, "floor -3.7");
    assertApprox(Zanna.Math.Floor(3.0), 3.0, 0.001, "floor exact");

    // Ceil
    assertApprox(Zanna.Math.Ceil(3.2), 4.0, 0.001, "ceil 3.2");
    assertApprox(Zanna.Math.Ceil(-3.2), -3.0, 0.001, "ceil -3.2");
    assertApprox(Zanna.Math.Ceil(3.0), 3.0, 0.001, "ceil exact");

    // Round
    assertApprox(Zanna.Math.Round(3.4), 3.0, 0.001, "round down");
    assertApprox(Zanna.Math.Round(3.6), 4.0, 0.001, "round up");
    assertApprox(Zanna.Math.Round(3.5), 4.0, 0.001, "round half");

    // Trunc
    assertApprox(Zanna.Math.Truncate(3.7), 3.0, 0.001, "trunc positive");
    assertApprox(Zanna.Math.Truncate(-3.7), -3.0, 0.001, "trunc negative");
}

func testMinMax() {
    // Min
    assertApprox(Zanna.Math.Min(3.0, 5.0), 3.0, 0.001, "min first smaller");
    assertApprox(Zanna.Math.Min(7.0, 2.0), 2.0, 0.001, "min second smaller");
    assertApprox(Zanna.Math.Min(4.0, 4.0), 4.0, 0.001, "min equal");

    // Max
    assertApprox(Zanna.Math.Max(3.0, 5.0), 5.0, 0.001, "max second larger");
    assertApprox(Zanna.Math.Max(7.0, 2.0), 7.0, 0.001, "max first larger");
    assertApprox(Zanna.Math.Max(4.0, 4.0), 4.0, 0.001, "max equal");

    // MinInt/MaxInt
    assertEqInt(Zanna.Math.MinInt(3, 5), 3, "minint");
    assertEqInt(Zanna.Math.MaxInt(3, 5), 5, "maxint");
}

func testClamp() {
    // Normal clamping
    assertApprox(Zanna.Math.Clamp(5.0, 0.0, 10.0), 5.0, 0.001, "clamp in range");
    assertApprox(Zanna.Math.Clamp(-5.0, 0.0, 10.0), 0.0, 0.001, "clamp below");
    assertApprox(Zanna.Math.Clamp(15.0, 0.0, 10.0), 10.0, 0.001, "clamp above");

    // ClampInt
    assertEqInt(Zanna.Math.ClampInt(5, 0, 10), 5, "clampint in range");
    assertEqInt(Zanna.Math.ClampInt(-5, 0, 10), 0, "clampint below");
    assertEqInt(Zanna.Math.ClampInt(15, 0, 10), 10, "clampint above");

    // Inverted bounds (should swap)
    assertApprox(Zanna.Math.Clamp(5.0, 10.0, 0.0), 5.0, 0.001, "clamp inverted in range");
    assertEqInt(Zanna.Math.ClampInt(5, 10, 0), 5, "clampint inverted in range");
}

func testLerp() {
    // Linear interpolation
    assertApprox(Zanna.Math.Lerp(0.0, 10.0, 0.0), 0.0, 0.001, "lerp t=0");
    assertApprox(Zanna.Math.Lerp(0.0, 10.0, 1.0), 10.0, 0.001, "lerp t=1");
    assertApprox(Zanna.Math.Lerp(0.0, 10.0, 0.5), 5.0, 0.001, "lerp t=0.5");
    assertApprox(Zanna.Math.Lerp(10.0, 20.0, 0.25), 12.5, 0.001, "lerp t=0.25");
}
