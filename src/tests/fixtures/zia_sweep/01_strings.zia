module TestStrings;

bind "./_support";

// Comprehensive string operations tests
// Tests functions now aligned between sema and runtime

func start() {
    Zanna.Terminal.Say("=== String Operations Tests ===");

    testBasicOps();
    testTrimOps();
    testCaseOps();
    testSearchOps();
    testSubstringOps();
    testCharOps();
    testReplaceOps();
    testSplitOps();
    testFlipOps();
    testEdgeCases();

    report();
}

func testBasicOps() {
    // Concat
    assertEqStr(Zanna.String.Concat("Hello", " World"), "Hello World", "concat basic");
    assertEqStr(Zanna.String.Concat("", "test"), "test", "concat empty left");
    assertEqStr(Zanna.String.Concat("test", ""), "test", "concat empty right");
    assertEqStr(Zanna.String.Concat("", ""), "", "concat both empty");

    // Length
    assertEqInt(Zanna.String.get_Length("hello"), 5, "length basic");
    assertEqInt(Zanna.String.get_Length(""), 0, "length empty");
    assertEqInt(Zanna.String.get_Length("a"), 1, "length single");

    // Repeat
    assertEqStr(Zanna.String.Repeat("ab", 3), "ababab", "repeat basic");
    assertEqStr(Zanna.String.Repeat("x", 0), "", "repeat zero");
    assertEqStr(Zanna.String.Repeat("x", 1), "x", "repeat one");
    assertEqStr(Zanna.String.Repeat("", 5), "", "repeat empty");
}

func testTrimOps() {
    assertEqStr(Zanna.String.Trim("  hello  "), "hello", "trim both");
    assertEqStr(Zanna.String.Trim("hello"), "hello", "trim none");
    assertEqStr(Zanna.String.Trim("   "), "", "trim all spaces");
    assertEqStr(Zanna.String.Trim(""), "", "trim empty");

    // TrimStart/TrimEnd (fixed from TrimLeft/TrimRight)
    assertEqStr(Zanna.String.TrimStart("  hello"), "hello", "trimstart");
    assertEqStr(Zanna.String.TrimEnd("hello  "), "hello", "trimend");
}

func testCaseOps() {
    assertEqStr(Zanna.String.ToUpper("hello"), "HELLO", "upper basic");
    assertEqStr(Zanna.String.ToLower("HELLO"), "hello", "lower basic");
    assertEqStr(Zanna.String.ToUpper("HeLLo"), "HELLO", "upper mixed");
    assertEqStr(Zanna.String.ToLower("HeLLo"), "hello", "lower mixed");
    assertEqStr(Zanna.String.ToUpper(""), "", "upper empty");
    assertEqStr(Zanna.String.ToLower(""), "", "lower empty");
    assertEqStr(Zanna.String.ToUpper("123"), "123", "upper digits");
}

func testSearchOps() {
    // IndexOf (1-based, 0 = not found)
    assertEqInt(Zanna.String.IndexOf("hello", "l"), 3, "indexof found");
    assertEqInt(Zanna.String.IndexOf("hello", "z"), 0, "indexof not found");
    assertEqInt(Zanna.String.IndexOf("hello", ""), 1, "indexof empty needle");
    assertEqInt(Zanna.String.IndexOf("", "a"), 0, "indexof empty haystack");
    assertEqInt(Zanna.String.IndexOf("hello", "lo"), 4, "indexof substring");

    // StartsWith/EndsWith
    assertTrue(Zanna.String.StartsWith("hello", "hel"), "startswith true");
    assertFalse(Zanna.String.StartsWith("hello", "ell"), "startswith false");
    assertTrue(Zanna.String.EndsWith("hello", "llo"), "endswith true");
    assertFalse(Zanna.String.EndsWith("hello", "hel"), "endswith false");
    assertTrue(Zanna.String.StartsWith("hello", ""), "startswith empty");
    assertTrue(Zanna.String.EndsWith("hello", ""), "endswith empty");

    // Has (fixed from Contains)
    assertTrue(Zanna.String.Contains("hello", "ell"), "has found");
    assertFalse(Zanna.String.Contains("hello", "xyz"), "has not found");
    assertTrue(Zanna.String.Contains("hello", ""), "has empty");
}

func testSubstringOps() {
    // Left
    assertEqStr(Zanna.String.Left("hello", 3), "hel", "left basic");
    assertEqStr(Zanna.String.Left("hello", 0), "", "left zero");
    assertEqStr(Zanna.String.Left("hello", 10), "hello", "left overflow");

    // Right
    assertEqStr(Zanna.String.Right("hello", 3), "llo", "right basic");
    assertEqStr(Zanna.String.Right("hello", 0), "", "right zero");
    assertEqStr(Zanna.String.Right("hello", 10), "hello", "right overflow");

    // Mid (1-based start)
    assertEqStr(Zanna.String.Mid("hello", 2), "ello", "mid from 2");
    assertEqStr(Zanna.String.Mid("hello", 1), "hello", "mid from 1");
    assertEqStr(Zanna.String.Mid("hello", 5), "o", "mid from 5");

    // Substring (0-based start, length)
    assertEqStr(Zanna.String.Substring("hello", 1, 3), "ell", "substring basic");
    assertEqStr(Zanna.String.Substring("hello", 0, 5), "hello", "substring full");
}

func testCharOps() {
    // Chr (char from code)
    assertEqStr(Zanna.String.Chr(65), "A", "chr A");
    assertEqStr(Zanna.String.Chr(97), "a", "chr a");
    assertEqStr(Zanna.String.Chr(48), "0", "chr 0");

    // Asc (code from char)
    assertEqInt(Zanna.String.Asc("A"), 65, "asc A");
    assertEqInt(Zanna.String.Asc("a"), 97, "asc a");
    assertEqInt(Zanna.String.Asc("0"), 48, "asc 0");
}

func testReplaceOps() {
    assertEqStr(Zanna.String.Replace("hello", "l", "L"), "heLLo", "replace basic");
    assertEqStr(Zanna.String.Replace("hello", "ll", "LL"), "heLLo", "replace pair");
    assertEqStr(Zanna.String.Replace("hello", "z", "Z"), "hello", "replace not found");
    assertEqStr(Zanna.String.Replace("aaa", "a", "b"), "bbb", "replace all");
}

func testSplitOps() {
    // Split returns Seq - use Zanna.Collections.Seq.get_Count to get count
    var parts = Zanna.String.Split("a,b,c", ",");
    assertEqInt(Zanna.Collections.Seq.get_Count(parts), 3, "split count");

    // Split with no delimiter
    var noSplit = Zanna.String.Split("abc", ",");
    assertEqInt(Zanna.Collections.Seq.get_Count(noSplit), 1, "split no match count");

    // Split empty string
    var emptySplit = Zanna.String.Split("", ",");
    assertEqInt(Zanna.Collections.Seq.get_Count(emptySplit), 1, "split empty count");
}

func testFlipOps() {
    // Flip (fixed from Reverse)
    assertEqStr(Zanna.String.Reverse("hello"), "olleh", "flip basic");
    assertEqStr(Zanna.String.Reverse(""), "", "flip empty");
    assertEqStr(Zanna.String.Reverse("a"), "a", "flip single");
    assertEqStr(Zanna.String.Reverse("ab"), "ba", "flip two");
}

func testEdgeCases() {
    // Very long string
    var long = Zanna.String.Repeat("x", 10000);
    assertEqInt(Zanna.String.get_Length(long), 10000, "long string length");

    // Cmp (fixed from Compare)
    assertEqInt(Zanna.String.Compare("a", "b"), -1, "cmp less");
    assertEqInt(Zanna.String.Compare("b", "a"), 1, "cmp greater");
    assertEqInt(Zanna.String.Compare("a", "a"), 0, "cmp equal");
}
