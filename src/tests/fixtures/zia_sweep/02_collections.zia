module TestCollections;

bind "./_support";

// Comprehensive collections tests
// Tests Seq, Map, Bag, Stack, Queue, Ring, Heap, TreeMap, Bytes, List

func start() {
    Zanna.Terminal.Say("=== Collections Tests ===");

    testSeq();
    testMap();
    testBag();
    testStack();
    testQueue();
    testRing();
    testHeap();
    testTreeMap();
    testBytes();
    testList();

    report();
}

func testSeq() {
    // Create and basic ops
    var s = Zanna.Collections.Seq.New();
    assertEqInt(Zanna.Collections.Seq.get_Count(s), 0, "seq new empty");

    // Push elements (fixed from Add)
    Zanna.Collections.Seq.Push(s, "first");
    Zanna.Collections.Seq.Push(s, "second");
    Zanna.Collections.Seq.Push(s, "third");
    assertEqInt(Zanna.Collections.Seq.get_Count(s), 3, "seq push len");

    // Pop
    var popped = Zanna.Collections.Seq.Pop(s);
    assertEqInt(Zanna.Collections.Seq.get_Count(s), 2, "seq pop len");

    // Clear
    Zanna.Collections.Seq.Clear(s);
    assertEqInt(Zanna.Collections.Seq.get_Count(s), 0, "seq clear");
}

func testMap() {
    var m = Zanna.Collections.Map.New();
    assertEqInt(Zanna.Collections.Map.get_Count(m), 0, "map new empty");

    // Set/Get (values must be objects, using strings)
    Zanna.Collections.Map.Set(m, "a", "val1");
    Zanna.Collections.Map.Set(m, "b", "val2");
    assertEqInt(Zanna.Collections.Map.get_Count(m), 2, "map set len");

    // Has
    assertTrue(Zanna.Collections.Map.Has(m, "a"), "map has existing");
    assertFalse(Zanna.Collections.Map.Has(m, "z"), "map has missing");

    // Remove
    assertTrue(Zanna.Collections.Map.Remove(m, "a"), "map remove existing");
    assertFalse(Zanna.Collections.Map.Has(m, "a"), "map remove confirmed");
    assertEqInt(Zanna.Collections.Map.get_Count(m), 1, "map remove len");

    // SetIfMissing
    assertTrue(Zanna.Collections.Map.SetIfMissing(m, "c", "val3"), "map setifmissing new");
    assertFalse(Zanna.Collections.Map.SetIfMissing(m, "b", "val99"), "map setifmissing existing");

    // Clear
    Zanna.Collections.Map.Clear(m);
    assertEqInt(Zanna.Collections.Map.get_Count(m), 0, "map clear");
}

func testBag() {
    var b = Zanna.Collections.StringSet.New();
    assertEqInt(Zanna.Collections.StringSet.get_Count(b), 0, "bag new empty");

    // Put/Has
    assertTrue(Zanna.Collections.StringSet.Add(b, "x"), "bag put new");
    assertFalse(Zanna.Collections.StringSet.Add(b, "x"), "bag put duplicate");
    assertTrue(Zanna.Collections.StringSet.Has(b, "x"), "bag has");
    assertEqInt(Zanna.Collections.StringSet.get_Count(b), 1, "bag put len");

    // Add more
    Zanna.Collections.StringSet.Add(b, "y");
    Zanna.Collections.StringSet.Add(b, "z");
    assertEqInt(Zanna.Collections.StringSet.get_Count(b), 3, "bag multi len");

    // Drop
    assertTrue(Zanna.Collections.StringSet.Remove(b, "y"), "bag drop existing");
    assertFalse(Zanna.Collections.StringSet.Remove(b, "missing"), "bag drop missing");
    assertEqInt(Zanna.Collections.StringSet.get_Count(b), 2, "bag drop len");

    // Clear
    Zanna.Collections.StringSet.Clear(b);
    assertEqInt(Zanna.Collections.StringSet.get_Count(b), 0, "bag clear");
}

func testStack() {
    var st = Zanna.Collections.Stack.New();
    assertEqInt(Zanna.Collections.Stack.get_Count(st), 0, "stack new empty");

    // Push/Pop LIFO (values must be objects)
    Zanna.Collections.Stack.Push(st, "first");
    Zanna.Collections.Stack.Push(st, "second");
    Zanna.Collections.Stack.Push(st, "third");
    assertEqInt(Zanna.Collections.Stack.get_Count(st), 3, "stack push len");

    var top = Zanna.Collections.Stack.Pop(st);
    assertEqInt(Zanna.Collections.Stack.get_Count(st), 2, "stack pop len");

    // Clear
    Zanna.Collections.Stack.Clear(st);
    assertEqInt(Zanna.Collections.Stack.get_Count(st), 0, "stack clear");
}

func testQueue() {
    var q = Zanna.Collections.Queue.New();
    assertEqInt(Zanna.Collections.Queue.get_Count(q), 0, "queue new empty");

    // Add/Take FIFO
    Zanna.Collections.Queue.Push(q, "first");
    Zanna.Collections.Queue.Push(q, "second");
    assertEqInt(Zanna.Collections.Queue.get_Count(q), 2, "queue add len");

    var taken = Zanna.Collections.Queue.Pop(q);
    assertEqInt(Zanna.Collections.Queue.get_Count(q), 1, "queue take len");

    // Clear
    Zanna.Collections.Queue.Clear(q);
    assertEqInt(Zanna.Collections.Queue.get_Count(q), 0, "queue clear");
}

func testRing() {
    // Ring buffer with fixed capacity
    var r = Zanna.Collections.Ring.New(3);
    assertEqInt(Zanna.Collections.Ring.get_Count(r), 0, "ring new empty");

    // Push elements (values must be objects)
    Zanna.Collections.Ring.Push(r, "a");
    Zanna.Collections.Ring.Push(r, "b");
    assertEqInt(Zanna.Collections.Ring.get_Count(r), 2, "ring push len");

    // Pop
    var popped = Zanna.Collections.Ring.Pop(r);
    assertEqInt(Zanna.Collections.Ring.get_Count(r), 1, "ring pop len");

    // Clear
    Zanna.Collections.Ring.Clear(r);
    assertEqInt(Zanna.Collections.Ring.get_Count(r), 0, "ring clear");
}

func testHeap() {
    // Min heap by default
    var h = Zanna.Collections.Heap.New();
    assertEqInt(Zanna.Collections.Heap.get_Count(h), 0, "heap new empty");

    // Push (priority, value)
    Zanna.Collections.Heap.Push(h, 30, "thirty");
    Zanna.Collections.Heap.Push(h, 10, "ten");
    Zanna.Collections.Heap.Push(h, 20, "twenty");
    assertEqInt(Zanna.Collections.Heap.get_Count(h), 3, "heap push len");

    // Pop (min heap - should get smallest priority)
    var popped = Zanna.Collections.Heap.Pop(h);
    assertEqInt(Zanna.Collections.Heap.get_Count(h), 2, "heap pop len");

    // Clear
    Zanna.Collections.Heap.Clear(h);
    assertEqInt(Zanna.Collections.Heap.get_Count(h), 0, "heap clear");
}

func testTreeMap() {
    var tm = Zanna.Collections.SortedMap.New();
    assertEqInt(Zanna.Collections.SortedMap.get_Count(tm), 0, "treemap new empty");

    // Set/Has (values must be objects)
    Zanna.Collections.SortedMap.Set(tm, "b", "two");
    Zanna.Collections.SortedMap.Set(tm, "a", "one");
    Zanna.Collections.SortedMap.Set(tm, "c", "three");
    assertEqInt(Zanna.Collections.SortedMap.get_Count(tm), 3, "treemap set len");
    assertTrue(Zanna.Collections.SortedMap.Has(tm, "a"), "treemap has");

    // Remove
    assertTrue(Zanna.Collections.SortedMap.Remove(tm, "b"), "treemap remove");
    assertEqInt(Zanna.Collections.SortedMap.get_Count(tm), 2, "treemap remove len");

    // Clear
    Zanna.Collections.SortedMap.Clear(tm);
    assertEqInt(Zanna.Collections.SortedMap.get_Count(tm), 0, "treemap clear");
}

func testBytes() {
    // Create byte buffer
    var b = Zanna.Collections.Bytes.New(10);
    assertEqInt(Zanna.Collections.Bytes.get_Length(b), 10, "bytes new len");

    // Set/Get
    Zanna.Collections.Bytes.Set(b, 0, 65);
    Zanna.Collections.Bytes.Set(b, 1, 66);
    assertEqInt(Zanna.Collections.Bytes.Get(b, 0), 65, "bytes get");

    // Fill
    Zanna.Collections.Bytes.Fill(b, 0);
    assertEqInt(Zanna.Collections.Bytes.Get(b, 0), 0, "bytes fill");

    // FromStr/ToStr
    var strBytes = Zanna.Collections.Bytes.FromStr("Hello");
    assertEqInt(Zanna.Collections.Bytes.get_Length(strBytes), 5, "bytes fromstr len");
    assertEqStr(Zanna.Collections.Bytes.ToStr(strBytes), "Hello", "bytes tostr");

    // Hex encoding
    Zanna.Collections.Bytes.Set(strBytes, 0, 72);  // 'H'
    var hexStr = Zanna.Collections.Bytes.ToHex(strBytes);
    assertNotEmpty(hexStr, "bytes tohex");

    // Base64 encoding
    var b64Str = Zanna.Collections.Bytes.ToBase64(strBytes);
    assertNotEmpty(b64Str, "bytes tobase64");

    // Clone
    var cloned = Zanna.Collections.Bytes.Clone(strBytes);
    assertEqInt(Zanna.Collections.Bytes.get_Length(cloned), 5, "bytes clone len");

    // Find
    var smallBuf = Zanna.Collections.Bytes.FromStr("abcabc");
    assertGt(Zanna.Collections.Bytes.Find(smallBuf, 98).UnwrapOrI64(0 - 1), -1, "bytes find");  // 98 = 'b'
}

func testList() {
    var lst = Zanna.Collections.List.New();
    assertEqInt(Zanna.Collections.List.get_Count(lst), 0, "list new empty");

    // Add
    Zanna.Collections.List.Push(lst, "a");
    Zanna.Collections.List.Push(lst, "b");
    Zanna.Collections.List.Push(lst, "c");
    assertEqInt(Zanna.Collections.List.get_Count(lst), 3, "list add count");

    // Has
    assertTrue(Zanna.Collections.List.Has(lst, "b"), "list has");
    assertFalse(Zanna.Collections.List.Has(lst, "z"), "list has not");

    // Find
    assertEqInt(Zanna.Collections.List.Find(lst, "b"), 1, "list find");
    assertEqInt(Zanna.Collections.List.Find(lst, "z"), -1, "list find not");

    // Insert
    Zanna.Collections.List.Insert(lst, 1, "x");
    assertEqInt(Zanna.Collections.List.get_Count(lst), 4, "list insert count");

    // RemoveAt
    Zanna.Collections.List.RemoveAt(lst, 1);
    assertEqInt(Zanna.Collections.List.get_Count(lst), 3, "list removeat count");

    // Remove
    assertTrue(Zanna.Collections.List.Remove(lst, "a"), "list remove");
    assertEqInt(Zanna.Collections.List.get_Count(lst), 2, "list remove count");

    // Clear
    Zanna.Collections.List.Clear(lst);
    assertEqInt(Zanna.Collections.List.get_Count(lst), 0, "list clear");
}
