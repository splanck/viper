// test_text_formats.zia — Csv, Ini, Toml, Markdown, Html, Template
module TestTextFormats;

bind Zanna.Terminal;
bind Zanna.Data.Csv;
bind Zanna.Text.Html;
bind Zanna.Text.Markdown;
bind Zanna.Data.Toml;

func start() {
    var s = new Zanna.Collections.Seq();
    s.Push("name");
    s.Push("age");
    s.Push("city");
    Say(FormatLine(s));

    var parsed = ParseLine("alice,30,nyc");
    Say("csv parseline done");

    Say(Escape("<b>hello</b>"));
    Say(Unescape("&lt;b&gt;hello&lt;/b&gt;"));
    Say(StripTags("<p>hello <b>world</b></p>"));
    Say(ToText("<p>hello</p><p>world</p>"));

    Say(Zanna.Text.Markdown.ToText("# Hello\n\nWorld"));
    Say(Zanna.Text.Markdown.ToHtml("**bold**"));

    SayBool(Zanna.Data.Toml.IsValid("[section]\nkey = \"value\""));

    Say("done");
}
