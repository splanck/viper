// test_frozen_default.zia — FrozenSet, FrozenMap, DefaultMap
module TestFrozenDefault;

bind Zanna.Terminal;

func start() {
    var dm = Zanna.Collections.DefaultMap.New(Zanna.Core.Box.Str("N/A"));
    SayInt(dm.Count);
    dm.Set("name", "zanna");
    dm.Set("lang", "zia");
    SayInt(dm.Count);
    SayBool(dm.Has("name"));
    SayBool(dm.Has("missing"));
    dm.Remove("lang");
    SayInt(dm.Count);
    dm.Clear();
    SayInt(dm.Count);

    var emptySet = Zanna.Collections.FrozenSet.Empty();
    SayInt(emptySet.Count);

    var emptyMap = Zanna.Collections.FrozenMap.Empty();
    SayInt(emptyMap.Count);

    Say("done");
}
