module TestColor;
bind Zanna.Graphics.Color;
bind Zanna.Terminal;

func start() {
    var c = Rgb(255, 128, 0);
    SayInt(GetRed(c));
    SayInt(GetGreen(c));
    SayInt(GetBlue(c));
    SayInt(GetAlpha(c));
    Say(ToHex(c));

    var c2 = FromHex("#ff8000");
    SayInt(GetRed(c2));

    var c3 = Rgba(100, 200, 50, 128);
    SayInt(GetAlpha(c3));

    var c4 = Grayscale(c);
    SayInt(GetRed(c4));

    var c5 = Invert(Rgb(0, 0, 0));
    SayInt(GetRed(c5));

    var c6 = Complement(c);
    SayInt(GetRed(c6));

    var c7 = Lerp(Rgb(0,0,0), Rgb(255,255,255), 50);
    SayInt(GetRed(c7));

    var c8 = Brighten(c, 50);
    SayInt(GetRed(c8));

    var c9 = Darken(c, 50);
    SayInt(GetRed(c9));

    Say("done");
}
