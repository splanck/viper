// test_set_deque.zia — Set, Deque, DefaultMap, SparseArray, WeakMap
module TestSetDeque;

bind Zanna.Terminal;

func start() {
    var s = new Zanna.Collections.Set();
    SayBool(s.IsEmpty);
    s.Add("apple");
    s.Add("banana");
    s.Add("cherry");
    SayInt(s.Count);
    SayBool(s.Has("apple"));
    SayBool(s.Has("mango"));
    s.Remove("banana");
    SayInt(s.Count);

    var dq = new Zanna.Collections.Deque();
    SayBool(dq.IsEmpty);
    dq.PushBack("a");
    dq.PushBack("b");
    dq.PushFront("z");
    SayInt(dq.Count);
    dq.PopFront();
    SayInt(dq.Count);
    dq.PopBack();
    SayInt(dq.Count);
    dq.PushBack("x");
    dq.PushBack("y");
    dq.Reverse();
    SayInt(dq.Count);
    dq.Clear();
    SayBool(dq.IsEmpty);

    var sa = new Zanna.Collections.SparseArray();
    sa.Set(0, "zero");
    sa.Set(100, "hundred");
    sa.Set(999, "big");
    SayInt(sa.Count);
    SayBool(sa.Has(100));
    SayBool(sa.Has(50));
    sa.Remove(100);
    SayInt(sa.Count);

    var wm = new Zanna.Collections.WeakMap();
    SayBool(wm.IsEmpty);
    wm.Set("key1", "val1");
    wm.Set("key2", "val2");
    SayInt(wm.Count);
    SayBool(wm.Has("key1"));
    wm.Remove("key1");
    SayInt(wm.Count);
    wm.Clear();
    SayBool(wm.IsEmpty);

    Say("done");
}
