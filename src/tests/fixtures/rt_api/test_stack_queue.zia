module TestStackQueue;
bind Viper.Terminal;

func start() {
    var st = new Viper.Collections.Stack();
    SayBool(st.IsEmpty);
    st.Push("a");
    st.Push("b");
    st.Push("c");
    SayInt(st.Count);
    Say(st.Peek());
    Say(st.Pop());
    Say(st.Pop());
    SayInt(st.Count);
    st.Clear();
    SayBool(st.IsEmpty);

    var q = new Viper.Collections.Queue();
    SayBool(q.IsEmpty);
    q.Push("x");
    q.Push("y");
    q.Push("z");
    SayInt(q.Count);
    Say(q.Peek());
    Say(q.Pop());
    Say(q.Pop());
    SayInt(q.Count);
    q.Clear();
    SayBool(q.IsEmpty);

    var r = new Viper.Collections.Ring();
    SayBool(r.IsEmpty);
    r.Push("1");
    r.Push("2");
    r.Push("3");
    SayInt(r.Count);
    Say(r.Peek());
    Say(r.Pop());
    SayInt(r.Count);
    Say(r.Get(0));
    r.Clear();
    SayBool(r.IsEmpty);

    var h = new Viper.Collections.Heap();
    SayBool(h.IsEmpty);
    h.Push(3, "three");
    h.Push(1, "one");
    h.Push(2, "two");
    SayInt(h.Count);
    Say(h.Peek());
    Say(h.Pop());
    Say(h.Pop());
    SayInt(h.Count);
    h.Clear();
    SayBool(h.IsEmpty);

    Say("done");
}
