module TestIoPath;
bind Zanna.IO.Path;
bind Zanna.IO.File;
bind Zanna.IO.Dir;
bind Zanna.Terminal;

func start() {
    Say(Join("a", "b"));
    Say(Extension("file.txt"));
    Say(Name("dir/file.txt"));
    Say(Stem("dir/file.txt"));
    Say(Directory("dir/file.txt"));
    SayBool(Extension("file.txt") != "");
    SayBool(Extension("file") != "");
    Say(WithExtension("file.txt", ".md"));
    SayBool(IsAbsolute("C:\\foo"));
    SayBool(IsAbsolute("foo"));
    Say(Normalize("a/b/../c"));

    // File write/read round-trip
    var tmp = "_rt_api_test_tmp.txt";
    WriteAllText(tmp, "hello from zanna");
    SayBool(Exists(tmp));
    Say(ReadAllText(tmp));
    SayInt(SizeBytes(tmp));
    Append(tmp, "!");
    Say(ReadAllText(tmp));
    Delete(tmp);
    SayBool(Zanna.IO.File.Exists(tmp));

    // Dir
    SayBool(Zanna.IO.Dir.Exists("."));
    Say("done");
}
