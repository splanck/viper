module TestIoPath;
bind Viper.IO.Path;
bind Viper.IO.File;
bind Viper.IO.Dir;
bind Viper.Terminal;

func start() {
    Say(Join("a", "b"));
    Say(Ext("file.txt"));
    Say(Name("dir/file.txt"));
    Say(Stem("dir/file.txt"));
    Say(Dir("dir/file.txt"));
    SayBool(Ext("file.txt") != "");
    SayBool(Ext("file") != "");
    Say(WithExt("file.txt", ".md"));
    SayBool(IsAbs("C:\\foo"));
    SayBool(IsAbs("foo"));
    Say(Norm("a/b/../c"));

    // File write/read round-trip
    var tmp = "_rt_api_test_tmp.txt";
    WriteAllText(tmp, "hello from viper");
    SayBool(Exists(tmp));
    Say(ReadAllText(tmp));
    SayInt(Size(tmp));
    Append(tmp, "!");
    Say(ReadAllText(tmp));
    Delete(tmp);
    SayBool(Viper.IO.File.Exists(tmp));

    // Dir
    SayBool(Viper.IO.Dir.Exists("."));
    Say("done");
}
