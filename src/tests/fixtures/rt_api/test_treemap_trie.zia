module TestTreemapTrie;
bind Zanna.Terminal;

func start() {
    var tm = new Zanna.Collections.SortedMap();
    SayBool(tm.IsEmpty);
    tm.Set("banana", "yellow");
    tm.Set("apple", "red");
    tm.Set("cherry", "dark");
    SayInt(tm.Count);
    Say(tm.Get("apple"));
    SayBool(tm.Has("banana"));
    Say(tm.First());
    Say(tm.Last());
    Say(tm.Floor("blueberry"));
    Say(tm.Ceiling("blueberry"));
    tm.Remove("apple");
    SayInt(tm.Count);
    SayInt(tm.Keys().Count);

    var tr = new Zanna.Collections.Trie();
    SayBool(tr.IsEmpty);
    tr.Set("hello", "1");
    tr.Set("help", "2");
    tr.Set("world", "3");
    SayInt(tr.Count);
    Say(tr.Get("hello"));
    SayBool(tr.Has("help"));
    SayBool(tr.HasPrefix("hel"));
    SayBool(tr.HasPrefix("xyz"));
    Say(tr.LongestPrefix("helping"));
    SayInt(tr.WithPrefix("hel").Count);
    tr.Remove("help");
    SayInt(tr.Count);

    var ss = new Zanna.Collections.SortedSet();
    SayBool(ss.IsEmpty);
    ss.Add("cherry");
    ss.Add("apple");
    ss.Add("banana");
    SayInt(ss.Count);
    Say(ss.First());
    Say(ss.Last());
    SayBool(ss.Has("apple"));
    Say(ss.At(1));
    SayInt(ss.IndexOf("banana"));
    Say(ss.Floor("blueberry"));
    Say(ss.Ceiling("blueberry"));
    ss.Remove("apple");
    SayInt(ss.Count);

    var bm = new Zanna.Collections.BiMap();
    SayBool(bm.IsEmpty);
    bm.Set("one", "1");
    bm.Set("two", "2");
    SayInt(bm.Count);
    Say(bm.GetByKey("one"));
    Say(bm.GetByValue("2"));
    SayBool(bm.HasKey("one"));
    SayBool(bm.HasValue("2"));
    bm.RemoveByKey("one");
    SayInt(bm.Count);

    Say("done");
}
