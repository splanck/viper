// test_special_collections.zia — BitSet, BloomFilter, UnionFind, Bytes, LruCache, MultiMap
module TestSpecialCollections;

bind Viper.Terminal;

func start() {
    var bs = new Viper.Collections.BitSet(64);
    SayBool(bs.IsEmpty);
    SayInt(bs.Length);
    bs.SetBit(3);
    bs.SetBit(7);
    bs.SetBit(15);
    SayInt(bs.Count);
    SayBool(bs.GetBit(3));
    SayBool(bs.GetBit(4));
    bs.ToggleBit(3);
    SayBool(bs.GetBit(3));
    bs.ClearBit(7);
    SayInt(bs.Count);
    Say(bs.ToString());
    bs.Clear();
    SayInt(bs.Count);

    var bf = new Viper.Collections.BloomFilter(1000, 0.01);
    bf.Add("hello");
    bf.Add("world");
    SayInt(bf.Count);
    SayBool(bf.MightContain("hello"));
    SayBool(bf.MightContain("xyz"));

    var uf = new Viper.Collections.UnionFind(10);
    SayInt(uf.Count);
    uf.Union(1, 2);
    uf.Union(3, 4);
    uf.Union(2, 3);
    SayBool(uf.IsConnected(1, 4));
    SayBool(uf.IsConnected(1, 5));
    SayInt(uf.ComponentSize(1));

    var by = new Viper.Collections.Bytes(8);
    SayInt(by.Length);
    by.Set(0, 65);
    by.Set(1, 66);
    SayInt(by.Get(0));
    SayInt(by.Get(1));
    by.Fill(0);
    SayInt(by.Get(0));
    Say(by.ToHex());

    var lru = new Viper.Collections.LruCache(3);
    SayBool(lru.IsEmpty);
    SayInt(lru.Capacity);
    lru.Set("a", "1");
    lru.Set("b", "2");
    lru.Set("c", "3");
    SayInt(lru.Count);
    SayBool(lru.Has("a"));
    lru.Set("d", "4");
    SayInt(lru.Count);
    lru.Remove("d");
    SayInt(lru.Count);

    var mm = new Viper.Collections.MultiMap();
    SayBool(mm.IsEmpty);
    mm.Add("color", "red");
    mm.Add("color", "blue");
    mm.Add("size", "large");
    SayInt(mm.Count);
    SayInt(mm.KeyCount);
    SayInt(mm.CountFor("color"));
    SayBool(mm.Has("color"));
    mm.RemoveAll("color");
    SayInt(mm.Count);

    Say("done");
}
