// test_memstream.zia — IO.MemStream, IO.BinFile, IO.LineReader, IO.LineWriter, IO.Compress
module TestMemStream;

bind Zanna.Terminal;

func start() {
    // --- MemStream: integer read/write ---
    var ms = new Zanna.IO.MemStream();
    SayInt(ms.Position);
    SayInt(ms.Length);

    ms.WriteI8(42);
    ms.WriteI16(1000);
    ms.WriteI32(100000);
    ms.WriteI64(9999999999);
    SayInt(ms.Length);

    ms.Seek(0);
    SayInt(ms.ReadI8());
    SayInt(ms.ReadI16());
    SayInt(ms.ReadI32());
    SayInt(ms.ReadI64());

    // --- MemStream: string read/write ---
    ms.Clear();
    ms.WriteStr("hello world");
    SayInt(ms.Length);
    ms.Seek(0);
    Say(ms.ReadStr(11));

    // --- MemStream: unsigned types ---
    ms.Clear();
    ms.WriteU8(200);
    ms.WriteU16(60000);
    ms.WriteU32(3000000000);
    ms.Seek(0);
    SayInt(ms.ReadU8());
    SayInt(ms.ReadU16());
    SayInt(ms.ReadU32());

    // --- MemStream: capacity and skip ---
    SayInt(ms.Capacity);
    ms.Clear();
    ms.WriteI8(1);
    ms.WriteI8(2);
    ms.WriteI8(3);
    ms.Seek(0);
    ms.Skip(1);
    SayInt(ms.Position);

    // --- Text streams via explicit open factories ---
    var textPath = "/tmp/zanna_rt_api_memstream_lines.txt";
    var writer = Zanna.IO.LineWriter.Open(textPath);
    writer.Write("alpha");
    writer.WriteLine("beta");
    writer.Close();

    var reader = Zanna.IO.LineReader.Open(textPath);
    SayInt(reader.PeekChar());
    Say(reader.Read());
    Say(reader.Read());
    SayBool(reader.Eof);
    reader.Close();

    // --- Binary file via explicit open factory ---
    var binPath = "/tmp/zanna_rt_api_memstream.bin";
    var wf = Zanna.IO.BinFile.Open(binPath, "w");
    wf.WriteByte(65);
    wf.WriteByte(66);
    wf.Close();

    var rf = Zanna.IO.BinFile.Open(binPath, "r");
    SayInt(rf.ReadByte());
    SayInt(rf.ReadByte());
    SayBool(rf.Eof);
    rf.Close();

    // --- Compress ---
    var compressed = Zanna.IO.Compress.DeflateStr("hello world hello world hello world");
    Say("compressed ok");
    var decompressed = Zanna.IO.Compress.InflateStr(compressed);
    Say(decompressed);

    var gzipped = Zanna.IO.Compress.GzipStr("test data for gzip");
    var gunzipped = Zanna.IO.Compress.GunzipStr(gzipped);
    Say(gunzipped);

    Say("done");
}
