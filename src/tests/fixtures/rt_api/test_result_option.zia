// test_result_option.zia — Result, Option functional types
module TestResultOption;

bind Viper.Terminal;
bind Viper.Result;
bind Viper.Option;

func start() {
    var ok = Viper.Result.OkI64(42);
    var err = Viper.Result.ErrStr("boom");
    var some = Viper.Option.SomeStr("hi");
    var none = Viper.Option.None();

    SayInt(Viper.Result.UnwrapI64(ok));
    Say(Viper.Result.UnwrapErrStr(err));
    Say(Viper.Option.UnwrapStr(some));
    SayBool(ok.IsOk);
    SayBool(none.IsNone);
    Say("done");
}
