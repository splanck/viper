// test_result_option.zia — Result, Option functional types
module TestResultOption;

bind Zanna.Terminal;
bind Zanna.Result;
bind Zanna.Option;

func start() {
    var ok = Zanna.Result.OkI64(42);
    var err = Zanna.Result.ErrStr("boom");
    var some = Zanna.Option.SomeStr("hi");
    var none = Zanna.Option.None();

    SayInt(Zanna.Result.UnwrapI64(ok));
    Say(Zanna.Result.UnwrapErrStr(err));
    Say(Zanna.Option.UnwrapStr(some));
    SayBool(ok.IsOk);
    SayBool(none.IsNone);
    Say("done");
}
