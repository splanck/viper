// test_screenfx_color.zia — ScreenFX.Rgba / ScreenFX.Rgb color constructors (VDOC-267)
// ScreenFX overlay colors are 0xRRGGBBAA and transition colors are 0x00RRGGBB —
// both distinct from the canonical Viper.Graphics.Color byte order (0xAARRGGBB).
// The Rgba/Rgb static constructors let callers build the correct encoding in the
// ScreenFX namespace instead of hand-packing or passing an incompatible Color.
module TestScreenFXColor;

bind Viper.Terminal;
bind Viper.Game.ScreenFX as FX;

func start() {
    // Static constructors resolve on the class and return packed i64 colors.
    var overlay = FX.Rgba(255, 0, 0, 255); // opaque red overlay → 0xFF0000FF
    var wipe = FX.Rgb(0, 0, 0);            // black transition   → 0x000000
    SayInt(overlay); // 4278190335 == 0xFF0000FF
    SayInt(wipe);    // 0

    // The overlay constructor feeds Flash/FadeOut; the transition constructor
    // feeds Wipe and friends. A Flash built from Rgba shows a real overlay.
    var fx = FX.New();
    fx.Flash(overlay, 200);
    fx.Update(16);
    SayBool(fx.OverlayAlpha > 0); // true — alpha survived, not channel-shifted

    fx.Wipe(0, wipe, 200);
    SayBool(fx.IsActive); // true

    Say("done");
}
