// test_pathfinder_typed.zia — Pathfinder factories and PathResult.Path carry
// their concrete collection types (VDOC-262). Before the registry typed these
// returns, the `obj`/Any results could not be assigned to typed locals.
module TestPathfinderTyped;

bind Zanna.Terminal;
bind Zanna.Game.Pathfinder as Pathfinder;
bind Zanna.Game.Grid2D as Grid2D;

func start() {
    var g = Grid2D.New(4, 4, 0);

    // FromGrid2D returns a concrete Pathfinder, assignable to a typed local.
    var pf: Zanna.Game.Pathfinder = Pathfinder.FromGrid2D(g);
    pf.SetWalkable(1, 1, false);
    SayBool(pf.IsWalkable(1, 1)); // false

    // PathResult.Path is a concrete Zanna.Collections.List, assignable directly.
    var result = pf.FindPath(0, 0, 3, 3);
    SayBool(result.Found);
    var path: Zanna.Collections.List = result.Path;
    SayInt(path.Count); // number of waypoints
}
