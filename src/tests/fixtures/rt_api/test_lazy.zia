// test_lazy.zia — Lazy, LazySeq
module TestLazy;

bind Zanna.Terminal;
bind Zanna.Functional.Lazy;
bind Zanna.Functional.LazySeq;

func start() {
    var lazy = Zanna.Functional.Lazy.OfI64(42);
    SayInt(Zanna.Functional.Lazy.GetI64(lazy));

    var seq = Zanna.Functional.LazySeq.Range(1, 5, 1);
    var out = Zanna.Functional.LazySeq.ToSeqLimited(seq, 3);
    SayInt(out.Count);

    Say("done");
}
