// test_math_extra.zia — Quat, Scanner, CompiledPattern
module TestMathExtra;

bind Zanna.Terminal;

func start() {
    var q = Zanna.Math.Quat.Identity();
    SayNum(q.W);

    var sc = new Zanna.Text.Scanner("hello world");
    Say(sc.ReadIdent());

    var pat = new Zanna.Text.CompiledPattern("[0-9]+");
    var matches = pat.FindAll("a1b22c333");
    SayInt(matches.Count);

    Say("done");
}
