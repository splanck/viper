module TestRandomVec;
bind Zanna.Math.Random;
bind Zanna.Math.Vec2;
bind Zanna.Math.Vec3;
bind Zanna.Math.Easing;
bind Zanna.Math.PerlinNoise;
bind Zanna.Terminal;

func start() {
    var rng = new Zanna.Math.Random(42);
    SayNum(rng.NextDouble());
    SayInt(rng.Range(1, 10));
    SayNum(rng.NextDouble());

    var rng2 = new Zanna.Math.Random(42);
    SayNum(rng2.NextDouble());

    // Vec2
    var v = new Zanna.Math.Vec2(3.0, 4.0);
    SayNum(v.X);
    SayNum(v.Y);
    SayNum(v.Length());
    SayNum(v.Dot(v));
    var vn = v.Normalize();
    SayNum(vn.Length());
    var va = v.Add(new Zanna.Math.Vec2(1.0, 1.0));
    SayNum(va.X);
    var vs = v.Mul(2.0);
    SayNum(vs.X);
    SayNum(Zanna.Math.Vec2.Dist(new Zanna.Math.Vec2(0.0,0.0), new Zanna.Math.Vec2(3.0,4.0)));

    // Vec3
    var v3 = new Zanna.Math.Vec3(1.0, 2.0, 3.0);
    SayNum(v3.X);
    SayNum(v3.Y);
    SayNum(v3.Z);
    SayNum(v3.Length());
    var v3n = v3.Normalize();
    var v3c = v3.Cross(new Zanna.Math.Vec3(0.0, 0.0, 1.0));
    SayNum(v3c.X);

    // Easing
    SayNum(Linear(0.5));
    SayNum(Zanna.Math.Easing.EaseInQuad(0.5));
    SayNum(Zanna.Math.Easing.EaseOutQuad(0.5));
    SayNum(Zanna.Math.Easing.EaseInOutQuad(0.5));

    // PerlinNoise
    var pn = new Zanna.Math.PerlinNoise(42);
    var noise = pn.Noise2D(1.0, 1.0);
    SayBool(noise > -1.0);
    SayBool(noise < 1.0);

    Say("done");
}
