// test_log_exec.zia — Log, Exec, NumberFormat
module TestLogExec;

bind Zanna.Terminal;
bind Zanna.Diagnostics.Log;
bind Zanna.System.Exec;
bind Zanna.Text.Fmt;

func start() {
    SayInt(Zanna.Diagnostics.Log.LevelDebug);
    SayInt(Zanna.Diagnostics.Log.LevelInfo);
    SayInt(Zanna.Diagnostics.Log.LevelWarn);
    SayInt(Zanna.Diagnostics.Log.LevelError);
    SayInt(Zanna.Diagnostics.Log.LevelOff);
    SayInt(Zanna.Diagnostics.Log.Level);
    SayBool(Zanna.Diagnostics.Log.Enabled(Zanna.Diagnostics.Log.LevelDebug));
    Zanna.Diagnostics.Log.Info("test info message");
    Zanna.Diagnostics.Log.Warn("test warn message");
    Zanna.Diagnostics.Log.Error("test error message");

    Say(ShellCapture("echo hello"));

    Say(Zanna.Text.Fmt.SizeBytes(1048576));
    Say(Zanna.Text.Fmt.Ordinal(1));
    Say(Zanna.Text.Fmt.Ordinal(2));
    Say(Zanna.Text.Fmt.Ordinal(3));
    Say(Zanna.Text.Fmt.Ordinal(11));
    Say(Zanna.Text.Fmt.IntPad(42, 5, " "));
    Say(Zanna.Text.Fmt.Percent(0.756, 1));
    Say(Zanna.Text.Fmt.IntGrouped(1234567, ","));
    Say(Zanna.Text.Fmt.ToWords(42));
    Say(Zanna.Text.Fmt.NumFixed(3.14159, 2));
    Say(Zanna.Text.Fmt.Currency(1234.56, 2, "$"));

    Say("done");
}
