// test_safe_thread.zia — Test Thread.StartSafe error boundaries
module TestSafeThread;

bind Zanna.Terminal;

func worker_ok(arg: Any) {
    Say("worker running");
}

func worker_trap(arg: Any) {
    // Trigger a trap via out-of-bounds access
    var list = new Zanna.Collections.List();
    var x = list.Get(999);
}

func start() {
    Say("test1: normal Thread.Start");
    var t0 = Zanna.Threads.Thread.Start(&worker_ok, 0);
    t0.Join();
    Say("test1 done");

    Say("test2: Thread.StartSafe with OK worker");
    var t1 = Zanna.Threads.Thread.StartSafe(&worker_ok, 0);
    Zanna.Threads.Thread.Sleep(500);
    Say("test2 done");

    Say("test3: Thread.StartSafe with trapping worker");
    var t2 = Zanna.Threads.Thread.StartSafe(&worker_trap, 0);
    Zanna.Threads.Thread.Sleep(500);
    Say("test3: checking error...");
    if (t2.HasError) {
        Say("test3: caught error: " + t2.Error);
    } else {
        Say("test3: no error (thread completed normally)");
    }
    Say("test3 done");

    Say("ALL TESTS PASSED");
}
