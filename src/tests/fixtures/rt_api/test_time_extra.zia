// test_time_extra.zia — Stopwatch, Countdown
module TestTimeExtra;

bind Zanna.Terminal;

func start() {
    var sw = new Zanna.Time.Stopwatch();
    SayBool(sw.IsRunning);
    sw.Start();
    SayBool(sw.IsRunning);
    sw.Stop();
    SayBool(sw.IsRunning);
    SayInt(sw.ElapsedMs);
    sw.Reset();
    SayInt(sw.ElapsedMs);

    var cd = new Zanna.Time.Countdown(5000);
    SayInt(cd.Interval);
    SayBool(cd.IsExpired);
    SayBool(cd.IsRunning);

    Say("done");
}
