module TestEnvMachine;
bind Zanna.System.Environment;
bind Zanna.System.Machine;
bind Zanna.IO.Dir;
bind Zanna.Terminal;

func start() {
    Say(Zanna.System.Machine.get_Os());
    Say(Zanna.System.Machine.get_OsVersion());
    Say(Zanna.System.Machine.get_User());
    Say(Zanna.System.Machine.get_Home());
    SayInt(Zanna.System.Machine.get_Cores());
    SayInt(Zanna.System.Machine.get_Cores());
    SayInt(Zanna.System.Machine.get_PageSize());
    Say(Zanna.System.Machine.get_Arch());
    Say(Zanna.System.Machine.get_Os());
    Say(Zanna.System.Machine.get_Endian());
    SayInt(Zanna.System.Machine.get_PointerSize());
    Say(Zanna.IO.Dir.Current());
    Say("done");
}
