// test_ini_template.zia — Text.Ini, Text.Template
module TestIniTemplate;

bind Zanna.Terminal;

func start() {
    // --- Ini: Parse and query ---
    var ini_text = "[server]\nhost=localhost\nport=8080\n[db]\nname=mydb";

    var ini = Zanna.Data.Ini.Parse(ini_text);
    SayBool(Zanna.Data.Ini.HasSection(ini, "server"));
    SayBool(Zanna.Data.Ini.HasSection(ini, "missing"));
    Say(Zanna.Data.Ini.Get(ini, "server", "host"));
    Say(Zanna.Data.Ini.Get(ini, "server", "port"));
    Say(Zanna.Data.Ini.Get(ini, "db", "name"));

    // --- Ini: Set and Format ---
    Zanna.Data.Ini.Set(ini, "server", "debug", "true");
    Say(Zanna.Data.Ini.Get(ini, "server", "debug"));

    var formatted = Zanna.Data.Ini.Format(ini);
    SayBool(formatted.Length > 0);

    // --- Ini: Remove ---
    Zanna.Data.Ini.Remove(ini, "server", "debug");

    // --- Template: Render ---
    var tmap = new Zanna.Collections.Map();
    tmap.Set("name", "World");
    tmap.Set("lang", "Zia");

    Say(Zanna.Text.Template.Render("Hello {{name}}, welcome to {{lang}}!", tmap));

    // --- Template: Has ---
    SayBool(Zanna.Text.Template.Has("Hello {{name}}!", "name"));
    SayBool(Zanna.Text.Template.Has("Hello {{name}}!", "missing"));

    // --- Template: Escape ---
    var escaped = Zanna.Text.Template.Escape("use {{braces}}");
    SayBool(escaped.Length > 0);

    Say("done");
}
