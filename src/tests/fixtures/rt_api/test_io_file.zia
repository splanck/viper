// test_io_file.zia — IO.File, IO.TempFile, IO.Dir, IO.Glob
// Tests actual file operations
module TestIoFile;

bind Zanna.Terminal;

func start() {
    // --- TempFile ---
    var tmpdir = Zanna.IO.TempFile.Dir();
    Say(tmpdir);

    var tmppath = Zanna.IO.TempFile.Path();
    Say(tmppath);

    var tmppfx = Zanna.IO.TempFile.PathWithPrefix("vtest");
    Say(tmppfx);

    var tmpext = Zanna.IO.TempFile.PathWithExt("vtest", ".txt");
    Say(tmpext);

    // --- File: write, read, exists, size ---
    var testfile = Zanna.IO.TempFile.PathWithExt("vtest_io", ".txt");
    Zanna.IO.File.WriteAllText(testfile, "hello world");
    SayBool(Zanna.IO.File.Exists(testfile));
    SayInt(Zanna.IO.File.SizeBytes(testfile));
    Say(Zanna.IO.File.ReadAllText(testfile));

    // --- File: append ---
    Zanna.IO.File.Append(testfile, " appended");
    Say(Zanna.IO.File.ReadAllText(testfile));

    // --- File: copy ---
    var copyfile = Zanna.IO.TempFile.PathWithExt("vtest_copy", ".txt");
    Zanna.IO.File.Copy(testfile, copyfile);
    SayBool(Zanna.IO.File.Exists(copyfile));

    // --- File: move ---
    var movefile = Zanna.IO.TempFile.PathWithExt("vtest_moved", ".txt");
    Zanna.IO.File.Move(copyfile, movefile);
    SayBool(Zanna.IO.File.Exists(movefile));

    // --- File: delete ---
    Zanna.IO.File.Delete(movefile);
    SayBool(Zanna.IO.File.Exists(movefile));

    // --- File: touch ---
    var touchfile = Zanna.IO.TempFile.PathWithExt("vtest_touch", ".txt");
    Zanna.IO.File.Touch(touchfile);
    SayBool(Zanna.IO.File.Exists(touchfile));
    Zanna.IO.File.Delete(touchfile);

    // --- File: modified ---
    SayInt(Zanna.IO.File.Modified(testfile));

    // --- Dir ---
    var testdir = Zanna.IO.TempFile.PathWithPrefix("vtest_dir");
    Zanna.IO.Dir.Make(testdir);
    SayBool(Zanna.IO.Dir.Exists(testdir));
    Zanna.IO.Dir.Remove(testdir);
    SayBool(Zanna.IO.Dir.Exists(testdir));

    // --- Dir: current ---
    Say(Zanna.IO.Dir.Current());

    // --- Glob ---
    SayBool(Zanna.IO.Glob.Match("hello.txt", "*.txt"));
    SayBool(Zanna.IO.Glob.Match("hello.txt", "*.bas"));

    // --- Cleanup ---
    Zanna.IO.File.Delete(testfile);

    Say("done");
}
