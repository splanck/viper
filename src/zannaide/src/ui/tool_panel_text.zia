module tool_panel_text;

bind Str = Zanna.String;
bind TextWrap = Zanna.Text.TextWrapper;

// ============================================================================
// MODULE: tool_panel_text
// PURPOSE: Pure text and color policy for ZannaIDE's bottom tool panels.
//          AppShell owns widgets; this module owns formatting rules that do not
//          need access to GUI state.
//
// WHERE-THIS-FITS: ui/app_shell.zia delegates diagnostics summaries, fixed-width
//          columns, severity labels, language labels, and output-line colors to
//          this module while retaining its public shell methods for callers.
//
// TEACHING-NOTE: Tool panels are shared by diagnostics, search, references,
//          output, and debug views. Centralizing the string/column rules keeps
//          those panels visually consistent as more tools are added.
// ============================================================================

/// @brief Color used for error rows and summaries.
/// @return RGB integer color value.
expose func ErrorColor() -> Integer { return 14707829; }

/// @brief Color used for warning rows and summaries.
/// @return RGB integer color value.
expose func WarningColor() -> Integer { return 15911349; }

/// @brief Color used for informational rows and summaries.
/// @return RGB integer color value.
expose func InfoColor() -> Integer { return 6662382; }

/// @brief Color used for successful or clean-state rows.
/// @return RGB integer color value.
expose func SuccessColor() -> Integer { return 10264905; }

/// @brief Color used for muted headers and inactive state rows.
/// @return RGB integer color value.
expose func MutedColor() -> Integer { return 10066329; }

/// @brief Width of the tool row kind column.
/// @return Fixed character width for the kind column.
expose func KindColumnWidth() -> Integer { return 10; }

/// @brief Width of the tool row source column.
/// @return Fixed character width for the source column.
expose func SourceColumnWidth() -> Integer { return 10; }

/// @brief Width of the tool row location column.
/// @return Fixed character width for file:line:column text.
expose func LocationColumnWidth() -> Integer { return 24; }

/// @brief Width of the tool row diagnostic code column.
/// @return Fixed character width for diagnostic/build codes.
expose func CodeColumnWidth() -> Integer { return 10; }

/// @brief Width of the tool row action column.
/// @return Fixed character width for quick-fix/action text.
expose func ActionColumnWidth() -> Integer { return 18; }

/// @brief Convert raw diagnostic severity to a compact row label.
/// @param severity Raw severity string from diagnostics or build output.
/// @return ERROR, WARN, or INFO.
expose func ProblemSeverityLabel(severity: String) -> String {
    var sev = Str.ToLower(severity);
    if sev == "error" { return "ERROR"; }
    if sev == "warning" or sev == "warn" { return "WARN"; }
    return "INFO";
}

/// @brief Pad a tool-panel column to a fixed width.
/// @param text Raw column text.
/// @param width Target fixed width in characters.
/// @return Trimmed text padded with spaces to exactly width characters.
expose func PadToolColumn(text: String, width: Integer) -> String {
    return Str.PadRight(TrimToolText(text, width), width, " ");
}

/// @brief Trim a tool-panel field to fit a fixed-width column.
/// @param text Raw text to display.
/// @param width Maximum field width.
/// @return Text that fits width, using a trailing tilde to show truncation.
expose func TrimToolText(text: String, width: Integer) -> String {
    if width <= 0 { return ""; }
    return TextWrap.TruncateWith(text, width, "~");
}

/// @brief Choose a color for a diagnostic severity.
/// @param severity Raw severity string.
/// @return RGB integer for error, warning, or info text.
expose func ProblemSeverityColor(severity: String) -> Integer {
    var sev = Str.ToLower(severity);
    if sev == "error" { return ErrorColor(); }
    if sev == "warning" or sev == "warn" { return WarningColor(); }
    return InfoColor();
}

/// @brief Choose a color for a build/output row.
/// @param line Raw output line.
/// @return RGB integer color, or 0 when the default color should be kept.
/// @details This is intentionally heuristic: build tools do not share one
///          structured schema, so the output panel highlights common words.
expose func OutputLineColor(line: String) -> Integer {
    var lower = Str.ToLower(line);
    if Str.Contains(lower, "error") or Str.Contains(lower, "failed") {
        return ErrorColor();
    }
    if Str.Contains(lower, "warning") or Str.Contains(lower, "warn") {
        return WarningColor();
    }
    if Str.Contains(lower, "success") or Str.Contains(lower, "passed") {
        return SuccessColor();
    }
    return 0;
}

/// @brief Format the diagnostics status-bar summary.
/// @param errors Number of error diagnostics.
/// @param warnings Number of warning diagnostics.
/// @param notes Number of informational diagnostics.
/// @return Human-readable summary with correct pluralization.
expose func FormatDiagnosticsSummary(errors: Integer,
                                     warnings: Integer,
                                     notes: Integer) -> String {
    if errors <= 0 and warnings <= 0 and notes <= 0 {
        return "Diagnostics: clean";
    }

    var text = "Diagnostics:";
    if errors > 0 {
        text = text + " " + errors + " error";
        if errors != 1 { text = text + "s"; }
    }
    if warnings > 0 {
        if text != "Diagnostics:" { text = text + ","; }
        text = text + " " + warnings + " warning";
        if warnings != 1 { text = text + "s"; }
    }
    if notes > 0 {
        if text != "Diagnostics:" { text = text + ","; }
        text = text + " " + notes + " note";
        if notes != 1 { text = text + "s"; }
    }
    return text;
}

/// @brief Choose the status-bar color for a diagnostics summary.
/// @param errors Number of error diagnostics.
/// @param warnings Number of warning diagnostics.
/// @param notes Number of informational diagnostics.
/// @return Error color first, then warning, info, or success for clean.
expose func DiagnosticsSummaryColor(errors: Integer,
                                    warnings: Integer,
                                    notes: Integer) -> Integer {
    if errors > 0 { return ErrorColor(); }
    if warnings > 0 { return WarningColor(); }
    if notes > 0 { return InfoColor(); }
    return SuccessColor();
}

/// @brief Normalize a language-service name for status-bar display.
/// @param languageName Internal language-service name.
/// @return User-facing language label.
expose func FormatLanguageName(languageName: String) -> String {
    var lang = Str.ToLower(languageName);
    if lang == "zia" { return "Zia"; }
    if lang == "basic" { return "BASIC"; }
    if lang == "scene" { return "Scene"; }
    if lang == "" { return "text"; }
    return lang;
}
