module workspace_file_index;

bind FileIndex = Zanna.Workspace.FileIndex;
bind Map = Zanna.Collections.Map;
bind Obj = Zanna.Core.Object;
bind Path = Zanna.IO.Path;
bind Seq = Zanna.Collections.Seq;
bind Str = Zanna.String;

final WORKSPACE_FILE_INDEX_PAGE_SIZE = 512;

// ============================================================================
// MODULE: workspace_file_index
// PURPOSE: Shared workspace-file discovery and path-containment policy.
//
// WHERE-THIS-FITS: ProjectManager owns the visible tree and project metadata.
//          Search, Quick Open, workspace symbols, and project rename support all
//          need the same "which files belong to this workspace?" answer. This
//          leaf service keeps that answer independent of GUI widgets and command
//          handlers.
//
// KEY-DESIGN-CHOICES:
//   * RUNTIME FILEINDEX IS THE AUTHORITY. Zanna.Workspace.FileIndex already
//     knows hard excludes, .gitignore, and project ignore patterns. ZannaIDE
//     should not grow separate recursive enumeration rules in each feature.
//   * PATHS ARE ABSOLUTE AT THE BOUNDARY. Callers pass absolute root/candidate
//     paths, then render relative labels themselves. That keeps this service
//     focused on membership rather than UI presentation.
//   * NO GUI DEPENDENCIES. This module is safe to use from core, commands,
//     editor controllers, and probes without dragging AppShell into leaf code.
// ============================================================================

/// @brief Test whether a path equals or lives under a workspace root.
/// @param fullPath Absolute path to test.
/// @param rootPath Absolute workspace root path.
/// @return True when @p fullPath is exactly @p rootPath or has it as a parent.
/// @details The comparison is lexical and separator-aware. It does not hit the
///          filesystem, so callers may use it while checking paths that have
///          just been renamed or paths discovered from a cache.
expose func IsWithinRoot(fullPath: String,
                         rootPath: String) -> Boolean {
    if fullPath == "" or rootPath == "" { return false; }
    if fullPath == rootPath { return true; }
    var prefix = rootPath;
    if Str.EndsWith(prefix, Path.Separator()) == false {
        prefix = prefix + Path.Separator();
    }
    return Str.StartsWith(fullPath, prefix);
}

/// @brief Compute a workspace-relative path using platform separators.
/// @param rootPath Absolute workspace root.
/// @param fullPath Absolute candidate path.
/// @return Relative path when @p fullPath is inside @p rootPath; otherwise the
///         original path.
/// @details Presentation layers usually normalize separators after this step.
///          Keeping platform separators here matches the runtime FileIndex
///          relative path convention.
expose func RelativePath(rootPath: String,
                         fullPath: String) -> String {
    if rootPath == "" or fullPath == "" { return fullPath; }
    var prefix = rootPath;
    if Str.EndsWith(prefix, Path.Separator()) == false {
        prefix = prefix + Path.Separator();
    }
    if Str.StartsWith(fullPath, prefix) {
        return Str.Mid(fullPath, Str.get_Length(prefix) + 1);
    }
    return fullPath;
}

/// @brief Return true for default-hidden directory names.
/// @param name Directory basename, not a full path.
/// @return True when ZannaIDE should skip the directory without consulting
///         project ignore rules.
/// @details This fallback is used only when no owning project root is available.
///          Normal workspace enumeration should use FileIndex.ShouldIgnore.
expose func IsDefaultExcludedDirectoryName(name: String) -> Boolean {
    if Str.Left(name, 1) == "." { return true; }
    if name == "build" or name == "node_modules" or name == "__pycache__" {
        return true;
    }
    return false;
}

/// @brief Return true for default-hidden file names.
/// @param name File basename, not a full path.
/// @return True when ZannaIDE should skip the file without project context.
/// @details This intentionally remains conservative. Project-specific patterns
///          are handled by FileIndex.ShouldIgnore when a root is known.
expose func IsDefaultExcludedFileName(name: String) -> Boolean {
    return Str.Left(name, 1) == ".";
}

/// @brief Ask the runtime workspace index whether a path should be ignored.
/// @param rootPath Absolute workspace root.
/// @param fullPath Absolute file or directory path being considered.
/// @param isDir True when @p fullPath is a directory.
/// @param ignorePatterns Project-specific ignore pattern list.
/// @return True when the runtime workspace policy says to skip the path.
/// @details Directory relative paths receive a trailing slash because ignore
///          matchers often distinguish directory patterns from file patterns.
expose func ShouldIgnorePath(rootPath: String,
                             fullPath: String,
                             isDir: Boolean,
                             ignorePatterns: String) -> Boolean {
    if rootPath == "" or fullPath == "" {
        if isDir { return IsDefaultExcludedDirectoryName(Path.Name(fullPath)); }
        return IsDefaultExcludedFileName(Path.Name(fullPath));
    }

    var rel = RelativePath(rootPath, fullPath);
    if isDir and Str.EndsWith(rel, "/") == false {
        rel = rel + "/";
    }
    return FileIndex.ShouldIgnore(rootPath, rel, ignorePatterns);
}

/// @brief Enumerate files under one workspace root through FileIndex.
/// @param rootPath Absolute workspace root.
/// @param fileKinds Comma-separated extension allow-list, or empty for all files.
/// @param ignorePatterns Project-specific ignore pattern list.
/// @return List of absolute file paths.
/// @details The returned List contains only file entries. Directory entries from
///          the runtime index are filtered here so callers share one simple shape.
///          The implementation consumes FileIndex.Page rather than Enumerate so
///          compatibility callers do not force the runtime to allocate a complete
///          workspace entry sequence in one call.
expose func EnumerateFiles(rootPath: String,
                           fileKinds: String,
                           ignorePatterns: String) -> List {
    var result = new List();
    if rootPath == "" { return result; }
    var seen = Map.New();
    var offset = 0;
    var done = false;
    while done == false {
        var page = FileIndex.Page(rootPath,
                                  fileKinds,
                                  ignorePatterns,
                                  false,
                                  offset,
                                  WORKSPACE_FILE_INDEX_PAGE_SIZE);
        if Map.GetBool(page, "valid") == false {
            return result;
        }
        var entries = Map.Get(page, "entries");
        var emitted = 0;
        if entries != null {
            var i = 0;
            while i < Seq.get_Count(entries) {
                var entry = Seq.Get(entries, i);
                emitted = emitted + 1;
                if Map.GetBool(entry, "isDirectory") == false {
                    var filePath = Map.GetStr(entry, "path");
                    AddUniquePath(result, seen, filePath);
                }
                i = i + 1;
            }
        }
        offset = Map.GetInt(page, "nextOffset");
        done = Map.GetBool(page, "done");
        if emitted == 0 and done == false {
            return result;
        }
    }
    return result;
}

/// @brief Append enumerated workspace files into an existing list.
/// @param target Mutable list receiving absolute file paths.
/// @param rootPath Absolute workspace root.
/// @param fileKinds Comma-separated extension allow-list, or empty for all files.
/// @param ignorePatterns Project-specific ignore pattern list.
/// @return Number of newly-added file paths.
/// @details This helper preserves caller-owned lists, which is useful when
///          merging FileIndex output with open unsaved documents.
expose func AddEnumeratedFiles(target: List,
                               rootPath: String,
                               fileKinds: String,
                               ignorePatterns: String) -> Integer {
    var added = 0;
    var seen = BuildStringSetFromList(target);
    var files = EnumerateFiles(rootPath, fileKinds, ignorePatterns);
    var i = 0;
    while i < files.count() {
        var filePath = Obj.ToString(files.get(i));
        if AddUniquePath(target, seen, filePath) {
            added = added + 1;
        }
        i = i + 1;
    }
    return added;
}

/// @brief Build a map-backed set from a list of string-like path values.
/// @param items List whose entries should be recorded; may be empty.
/// @return Runtime Map where each path string is present with a boolean true value.
/// @details Several IDE features merge FileIndex pages with existing open-document
///          lists. Using a Map keeps those merges linear instead of repeatedly
///          scanning the accumulated List for every discovered file.
expose func BuildStringSetFromList(items: List) -> Any {
    var seen = Map.New();
    var i = 0;
    while i < items.count() {
        var value = Obj.ToString(items.get(i));
        if value != "" {
            Map.SetBool(seen, PathKey(value), true);
        }
        i = i + 1;
    }
    return seen;
}

/// @brief Append a path to a list only when a companion string set has not seen it.
/// @param target Mutable list receiving unique path values.
/// @param seen Map-backed set produced by BuildStringSetFromList or Map.New.
/// @param path Absolute path candidate to append.
/// @return True when @p path was appended; false for empty or duplicate paths.
/// @details The helper updates @p seen before returning so callers can process
///          large FileIndex pages without O(n^2) duplicate checks.
expose func AddUniquePath(target: List,
                          seen: Any,
                          path: String) -> Boolean {
    if seen == null or path == "" { return false; }
    var key = PathKey(path);
    if Map.Has(seen, key) { return false; }
    Map.SetBool(seen, key, true);
    target.Push(path);
    return true;
}

/// @brief Return true when a List already contains a string value.
/// @param items List with string-like entries.
/// @param value Value to find.
/// @return True when any entry's string representation equals @p value.
/// @details The runtime List can hold boxed values; normalizing through
///          Obj.ToString keeps comparisons stable for all current callers.
expose func ListContains(items: List,
                         value: String) -> Boolean {
    var target = PathKey(value);
    var i = 0;
    while i < items.count() {
        if PathKey(Obj.ToString(items.get(i))) == target {
            return true;
        }
        i = i + 1;
    }
    return false;
}

/// @brief Normalize a path for membership checks without changing displayed values.
/// @param path Absolute or relative file path spelling.
/// @return Absolute normalized key suitable for path de-duplication.
func PathKey(path: String) -> String {
    if path == "" { return ""; }
    return Path.Normalize(Path.Absolute(path));
}
