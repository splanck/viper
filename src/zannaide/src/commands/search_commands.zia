func handleWorkspaceSymbols(shell: app_shell.AppShell,
                            projMgr: project_manager.ProjectManager,
                            docMgr: document_manager.DocumentManager,
                            engine: editor_engine.EditorEngine,
                            locStore: locations.LocationStore) {
    var query = Str.Trim(GUI.MessageBox.Prompt("Workspace Symbols", "Symbol name:"));
    handleWorkspaceSymbolsText(shell, projMgr, docMgr, engine, locStore, query);
}

/// @brief Collect and display workspace symbols for an already-entered query.
/// @param shell Workbench shell that owns the Search panel and status bar.
/// @param projMgr Project manager providing workspace root and file cache.
/// @param docMgr Open document manager used to prefer live unsaved buffers.
/// @param engine Active editor engine whose state is saved before scanning.
/// @param locStore Location store receiving structured result locations.
/// @param queryText User-entered symbol search text.
/// @return True when one or more symbol rows were produced.
func handleWorkspaceSymbolsText(shell: app_shell.AppShell,
                                projMgr: project_manager.ProjectManager,
                                docMgr: document_manager.DocumentManager,
                                engine: editor_engine.EditorEngine,
                                locStore: locations.LocationStore,
                                queryText: String) -> Boolean {
    if projMgr.IsOpen() == false {
        GUI.Toast.Warning("Open a project folder first");
        return false;
    }

    var query = Str.Trim(queryText);
    if query == "" { return false; }

    file_commands.SaveEditorState(docMgr, engine);
    var count = CollectWorkspaceSymbols(shell, projMgr, docMgr, locStore, query);
    if count > 0 {
        shell.toolPanels.ShowSearchPanel();
        shell.SetStatusLeft("Found " + count + " workspace symbols for '" + query + "'");
        return true;
    } else {
        shell.toolPanels.ClearToolRows(shell.toolPanels.searchListBox);
        shell.toolPanels.AddToolInfoRow(shell.toolPanels.searchListBox, "symbol",
                             "No workspace symbols matched '" + query + "'");
        shell.toolPanels.ShowSearchPanel();
        GUI.Toast.Info("No workspace symbols matched '" + query + "'");
    }
    return false;
}

func CollectWorkspaceSymbols(shell: app_shell.AppShell,
                             projMgr: project_manager.ProjectManager,
                             docMgr: document_manager.DocumentManager,
                             locStore: locations.LocationStore,
                             query: String) -> Integer {
    if shell == null or projMgr == null or locStore == null { return 0; }
    if projMgr.IsOpen() == false { return 0; }

    var needle = Str.ToLower(Str.Trim(query));
    if needle == "" { return 0; }

    shell.toolPanels.ClearToolRows(shell.toolPanels.searchListBox);
    var resultCount = 0;
    var files = WorkspaceSymbolFiles(projMgr, docMgr);
    var i = 0;
    while i < files.count() {
        var filePath = Obj.ToString(files.get(i));
        i = i + 1;
        var language = file_utils.DetectLanguage(filePath);
        if language != "zia" and language != "basic" { continue; }

        var content = contentForPath(docMgr, filePath);
        if content == "" { continue; }

        if language == "basic" {
            resultCount = resultCount + AddBasicWorkspaceSymbols(shell,
                                                                 locStore,
                                                                 filePath,
                                                                 content,
                                                                 needle);
            continue;
        }

        var qsource = zia_query.WrapForQuery(content);
        var lineOff = zia_query.LineOffset(content);
        var raw = ZiaCompletion.SymbolsForFile(qsource, filePath);
        if raw == "" { continue; }

        var addedHeader = false;
        var rows = Str.Split(raw, "\n");
        var r = 0;
        while r < Seq.get_Count(rows) {
            var row = Obj.ToString(Seq.Get(rows, r));
            r = r + 1;
            if row == "" { continue; }

            var parts = Str.Split(row, "\t");
            if Seq.get_Count(parts) < 4 { continue; }

            var name = Obj.ToString(Seq.Get(parts, 0));
            var kind = Obj.ToString(Seq.Get(parts, 1));
            var typeText = Obj.ToString(Seq.Get(parts, 2));
            var lineText = Obj.ToString(Seq.Get(parts, 3));
            if lineText == "0" { continue; }

            var symbolLine = Convert.ToInt64(lineText) - lineOff;
            if symbolLine < 1 { continue; }
            if WorkspaceSymbolMatches(name, kind, filePath, needle) == false { continue; }

            if addedHeader == false {
                shell.toolPanels.AddToolGroupHeader(shell.toolPanels.searchListBox, Path.Name(filePath), filePath);
                addedHeader = true;
            }

            var detail = "";
            if typeText != "" { detail = " : " + typeText; }
            var item = shell.toolPanels.AddToolLocationRow(shell.toolPanels.searchListBox, kind, "symbol",
                                                "line " + symbolLine, typeText,
                                                name + detail, "");
            var locId = locStore.Add(filePath, symbolLine, 1,
                                     symbolLine, 1 + Str.get_Length(name),
                                     locations.KIND_SYMBOL, name);
            GUI.ListBox.ItemSetData(item, locId);
            resultCount = resultCount + 1;
        }
    }

    if resultCount > 0 {
        shell.toolPanels.ShowSearchPanel();
    }
    return resultCount;
}

/// @brief Build the complete candidate file list for workspace symbol search.
/// @param projMgr Project manager providing root and ignore patterns.
/// @param docMgr Open document manager whose live files must be included.
/// @return List of absolute Zia/BASIC file paths without duplicates.
/// @details The project file cache is intentionally not used as the authority
///          here because symbol search should not silently miss files while
///          Quick Open or explorer caches are still warming. Runtime FileIndex
///          performs the workspace traversal and ignore filtering.
func WorkspaceSymbolFiles(projMgr: project_manager.ProjectManager,
                          docMgr: document_manager.DocumentManager) -> List {
    var files = new List();
    if projMgr != null and projMgr.IsOpen() {
        var rootIndex = 0;
        while rootIndex < projMgr.RootCount() {
            workspace_file_index.AddEnumeratedFiles(files, projMgr.RootPathAt(rootIndex),
                                                    ".zia,.bas,.vb",
                                                    projMgr.RootIgnorePatternsAt(rootIndex));
            rootIndex = rootIndex + 1;
        }
    }
    if docMgr != null {
        var i = 0;
        while i < docMgr.GetCount() {
            var doc = docMgr.documents.get(i);
            if (doc.language == "zia" or doc.language == "basic")
               and doc.filePath != ""
               and workspace_file_index.ListContains(files, doc.filePath) == false {
                files.Push(doc.filePath);
            }
            i = i + 1;
        }
    }
    return files;
}

func AddBasicWorkspaceSymbols(shell: app_shell.AppShell,
                              locStore: locations.LocationStore,
                              filePath: String,
                              content: String,
                              needle: String) -> Integer {
    var decls = semantic_scan.DeclarationsForFile(filePath, content);
    var count = 0;
    var addedHeader = false;
    var i = 0;
    while i < Seq.get_Count(decls) {
        var decl = Seq.Get(decls, i);
        i = i + 1;
        var kind = Map.GetStr(decl, "kind");
        if Map.GetBool(decl, "local") { continue; }
        if kind == "parameter" or kind == "label" { continue; }
        if semantic_scan.WorkspaceSymbolMatchesDecl(decl, needle) == false { continue; }

        if addedHeader == false {
            shell.toolPanels.AddToolGroupHeader(shell.toolPanels.searchListBox, Path.Name(filePath), filePath);
            addedHeader = true;
        }
        var name = Map.GetStr(decl, "name");
        var typeText = Map.GetStr(decl, "returnType");
        if typeText == "" { typeText = Map.GetStr(decl, "signature"); }
        var line = Map.GetInt(decl, "line");
        var detail = "";
        if typeText != "" { detail = " : " + typeText; }
        var item = shell.toolPanels.AddToolLocationRow(shell.toolPanels.searchListBox, kind, "symbol",
                                            "line " + line, typeText,
                                            name + detail, "");
        var locId = locStore.Add(filePath, line, Map.GetInt(decl, "column"),
                                 Map.GetIntOr(decl, "endLine", line),
                                 Map.GetIntOr(decl, "endColumn",
                                              Map.GetInt(decl, "column") + Str.get_Length(name)),
                                 locations.KIND_SYMBOL, name);
        GUI.ListBox.ItemSetData(item, locId);
        count = count + 1;
    }
    return count;
}

func WorkspaceSymbolMatches(name: String,
                            kind: String,
                            filePath: String,
                            needle: String) -> Boolean {
    var lowerName = Str.ToLower(name);
    if Str.IndexOf(lowerName, needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(kind), needle) != 0 { return true; }
    if Str.IndexOf(Str.ToLower(filePath), needle) != 0 { return true; }
    return false;
}

func RunSearch(shell: app_shell.AppShell,
               root: String,
               title: String,
               docMgr: document_manager.DocumentManager,
               engine: editor_engine.EditorEngine,
               locStore: locations.LocationStore) {
    var request = search_prompt.PromptRequest(title, root, "");
    if request == null { return; }
    var activeRequest = request!;
    file_commands.SaveEditorState(docMgr, engine);

    var files = workspace_file_index.EnumerateFiles(activeRequest.rootPath,
                                                    activeRequest.fileKinds,
                                                    activeRequest.excludeGlobs);

    var resultCount = 0;
    shell.toolPanels.ClearToolRows(shell.toolPanels.searchListBox);

    resultCount = resultCount + searchFiles(shell,
                                            activeRequest.rootPath,
                                            files,
                                            activeRequest.query,
                                            activeRequest.caseSensitive,
                                            activeRequest.wholeWord,
                                            activeRequest.regexMode,
                                            activeRequest.includeGlobs,
                                            activeRequest.excludeGlobs,
                                            docMgr,
                                            locStore);

    if resultCount > 0 {
        shell.toolPanels.ShowSearchPanel();
        shell.SetStatusLeft("Found " + resultCount + " matches for '" + activeRequest.query + "'");
    } else {
        shell.toolPanels.ClearToolRows(shell.toolPanels.searchListBox);
        shell.toolPanels.AddToolInfoRow(shell.toolPanels.searchListBox, "search",
                             "No matches found for '" + activeRequest.query + "'");
        shell.toolPanels.ShowSearchPanel();
        GUI.Toast.Info("No matches found for '" + activeRequest.query + "'");
    }
}

/// @brief Search every file path in `files` for `query`.
/// @return Match count (rows added to the output panel).
/// @details `files` is a List of absolute paths rather than raw FileIndex
///          maps. Normalizing this boundary keeps FileIndex details inside the
///          workspace_file_index service and makes probes easier to read.
func searchFiles(shell: app_shell.AppShell,
                 rootPath: String,
                 files: List,
                 query: String,
                 caseSensitive: Boolean,
                 wholeWord: Boolean,
                 regexMode: Boolean,
                 includeGlobs: String,
                 excludeGlobs: String,
                 docMgr: document_manager.DocumentManager,
                 locStore: locations.LocationStore) -> Integer {
    var count = 0;
    var fileIdx = 0;
    while fileIdx < files.count() {
        var filePath = Obj.ToString(files.get(fileIdx));
        fileIdx = fileIdx + 1;

        if IO.File.Exists(filePath) == false { continue; }
        if SearchPathAllowed(rootPath, filePath, includeGlobs, excludeGlobs) == false { continue; }
        if SearchDiskFileTooLarge(docMgr, filePath) { continue; }
        count = count + searchOneFile(shell, filePath, query, caseSensitive, wholeWord,
                                      regexMode, docMgr, locStore,
                                      MAX_SEARCH_RESULTS - count);
        if count >= MAX_SEARCH_RESULTS { return count; }
    }
    return count;
}

/// @brief Return true when a disk-backed file should be skipped by project search.
/// @param docMgr Open document manager used to detect edited in-memory buffers.
/// @param filePath Absolute candidate path.
/// @return True when the file is not open in the editor and exceeds the search
///         size guard.
/// @details Open documents are searched from their current buffer even when the
///          backing file is large, because that is the text the user is editing.
///          Closed disk files are capped before ReadAllText so a workspace search
///          cannot freeze the IDE by copying very large generated files.
func SearchDiskFileTooLarge(docMgr: document_manager.DocumentManager,
                            filePath: String) -> Boolean {
    if filePath == "" or IO.File.Exists(filePath) == false { return false; }
    if docMgr != null and docMgr.FindByPath(filePath) >= 0 { return false; }
    return IO.File.SizeBytes(filePath) > MAX_SEARCH_FILE_BYTES;
}

func searchOneFile(shell: app_shell.AppShell,
                   filePath: String,
                   query: String,
                   caseSensitive: Boolean,
                   wholeWord: Boolean,
                   regexMode: Boolean,
                   docMgr: document_manager.DocumentManager,
                   locStore: locations.LocationStore,
                   maxResults: Integer) -> Integer {
    var count = 0;
    if maxResults <= 0 { return 0; }
    var content = contentForPath(docMgr, filePath);
    var contentLines = Str.Split(content, "\n");
    var lineNum = 0;
    var addedHeader = false;
    while lineNum < Seq.get_Count(contentLines) {
        var line = Obj.ToString(Seq.Get(contentLines, lineNum));
        lineNum = lineNum + 1;
        var match = FindLineMatch(line, query, caseSensitive, wholeWord, regexMode);
        if match.matched and count < maxResults {
            if addedHeader == false {
                shell.toolPanels.AddToolGroupHeader(shell.toolPanels.searchListBox, Path.Name(filePath), filePath);
                addedHeader = true;
            }
            var resultText = Str.Trim(line);
            var item = shell.toolPanels.AddToolLocationRow(shell.toolPanels.searchListBox, "match", "text",
                                                "" + lineNum + ":" + match.startCol,
                                                "", resultText, "");
            var locId = locStore.Add(filePath, lineNum, match.startCol,
                                     lineNum, match.startCol + match.length,
                                     locations.KIND_SEARCH, Str.Trim(line));
            GUI.ListBox.ItemSetData(item, locId);
            count = count + 1;
        }
    }
    return count;
}

func QuickOpenScore(relativePath: String, query: String) -> Integer {
    return quick_open_commands.QuickOpenScore(relativePath, query);
}

func contentForPath(docMgr: document_manager.DocumentManager, filePath: String) -> String {
    if docMgr == null {
        return IO.File.ReadAllText(filePath);
    }
    var idx = docMgr.FindByPath(filePath);
    if idx >= 0 {
        return docMgr.documents.get(idx).content;
    }
    return IO.File.ReadAllText(filePath);
}

