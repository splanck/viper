//
// File: src/il/runtime/runtime.def
// Purpose: Ordered manifest and grammar for the modular runtime registry.
// Key invariants:
//   - Quoted definition fragments are included exactly once in declaration order.
//   - Every public runtime class has authored summary and details documentation.
// Ownership/Lifetime:
//   - Declarative rows are consumed by rtgen and X-macro tests.
//   - Generated registry strings have process lifetime.
// Links: src/il/runtime/defs, src/tools/rtgen/rtgen.cpp, docs/adr/0101-modular-runtime-definitions-and-documentation.md
//
// TABLE OF CONTENTS
//
// This file defines all Viper runtime functions and classes.
// Sections are organized alphabetically by namespace.
//
//   BIGINT
//   BITS
//   BLOOM FILTER
//   BOX (BOXING/UNBOXING PRIMITIVES)
//   COLLECTIONS - BAG
//   COLLECTIONS - BIMAP
//   COLLECTIONS - BITSET
//   COLLECTIONS - BYTES
//   COLLECTIONS - COUNTMAP
//   COLLECTIONS - FROZENMAP
//   COLLECTIONS - FROZENSET
//   COLLECTIONS - HEAP (Priority Queue)
//   COLLECTIONS - INTMAP
//   COLLECTIONS - ITERATOR
//   COLLECTIONS - LIST
//   COLLECTIONS - LRUCACHE
//   COLLECTIONS - MAP
//   COLLECTIONS - MULTIMAP
//   COLLECTIONS - QUEUE
//   COLLECTIONS - RING
//   COLLECTIONS - SEQ
//   COLLECTIONS - SET (Generic)
//   COLLECTIONS - SPARSEARRAY
//   COLLECTIONS - STACK
//   COLLECTIONS - TREEMAP
//   COLLECTIONS - TRIE
//   COLLECTIONS - WEAKMAP
//   CONCURRENT MAP
//   CORE - MESSAGEBUS
//   CRYPTO - AES ENCRYPTION
//   CRYPTO - CIPHER (HIGH-LEVEL ENCRYPTION)
//   CRYPTO - HASH
//   CRYPTO - KEY DERIVATION
//   CRYPTO - PASSWORD HASHING
//   CRYPTO - SECURE RANDOM
//   CRYPTO - TLS (Secure Connections)
//   DATA - UNIFIED SERIALIZATION
//   DATA - YAML
//   DATE RANGE
//   DATETIME
//   DEFAULT MAP
//   DIAGNOSTICS - ASSERT
//   DIAGNOSTICS - STOPWATCH
//   DIAGNOSTICS - TRAP
//   DIFF
//   DURATION / TIMESPAN
//   EASING FUNCTIONS
//   ENVIRONMENT
//   EXEC
//   FMT (value formatting)
//   GRAPHICS - CAMERA
//   GRAPHICS - CANVAS
//   GRAPHICS - COLOR
//   GRAPHICS - PIXELS
//   GRAPHICS - SCENE GRAPH
//   GRAPHICS - SPRITE
//   GRAPHICS - SPRITE BATCH
//   GRAPHICS - SPRITESHEET
//   GRAPHICS - TILEMAP
//   GRAPHICS 3D - CANVAS3D
//   GRAPHICS 3D - MESH3D
//   GRAPHICS 3D - CAMERA3D
//   GRAPHICS 3D - MATERIAL3D
//   GRAPHICS 3D - LIGHT3D
//   GRAPHICS 3D - PHYSICS3D (World, Body, Character, Trigger3D)
//   GUI - APPLICATION (+ FONT, WIDGET BASE, LABEL, BUTTON, ...)
//   GAME ENGINE (Grid2D, Timer, StateMachine, Tween, ...)
//   INPUT (Action, Manager, KeyChord)
//   IO - BINARYBUFFER
//   IO - BINFILE
//   IO - COMPRESS
//   IO - DIRECTORY
//   IO - FILE
//   IO - GLOB
//   IO - LINEREADER
//   IO - LINEWRITER
//   IO - MEMSTREAM
//   IO - PATH
//   IO - SAVEDATA
//   IO - STREAM (UNIFIED INTERFACE)
//   IO - TEMPFILE
//   IO - WATCHER
//   LOG
//   MACHINE
//   MATH - PERLIN NOISE
//   MATH FUNCTIONS
//   MEMORY - GC Cycle Collection
//   MEMORY - Reference Counting
//   NETWORK - RATELIMITER (+ HTTP, DNS, WebSocket, ...)
//   NUMBER FORMAT
//   OBJECT (BASE CLASS)
//   ORDERED MAP
//   PHYSICS 2D
//   RANDOM
//   RELATIVE TIME
//   AUDIO (Mixer, Sound, Voice, Music)
//   SPLINE
//   STRING FUNCTIONS
//   TERMINAL I/O
//   TEXT - CODEC
//   TEXT - CSV
//   TEXT - GUID
//   TEXT - HTML
//   TEXT - INI
//   TEXT - JSON
//   TEXT - JSON STREAM
//   TEXT - JSONPATH
//   TEXT - MARKDOWN
//   TEXT - PATTERN (Regex)
//   TEXT - STRINGBUILDER
//   TEXT - TEXTWRAPPER
//   TEXT - TOML
//   TEXT - XML
//   THREADS (+ SCHEDULER, POOL, CHANNEL)
//   TIME - CLOCK
//   TIME - COUNTDOWN
//   TYPE CONVERSION
//   UNION FIND
//   VEC2
//   VEC3
//   MAT3
//   MAT4
//   QUAT
//
//   RUNTIME CLASSES (RT_CLASS definitions)
//   LAZYSEQ
//
//===----------------------------------------------------------------------===//
//
// Syntax:
//   #include "relative/definition.def"
//   RT_FUNC(id, c_symbol, "canonical", "signature")
//   RT_INTERNAL_FUNC(id, c_symbol, "canonical", "signature")
//   RT_BRIDGE(target_id, "role0,role1,...")
//   RT_CLASS_BEGIN("name", type_id, "layout", ctor_id)
//     RT_PROP("name", "type", getter_id, setter_id_or_none)
//     RT_METHOD("name", "signature", target_id)
//   RT_CLASS_END()
//
// Class documentation syntax:
//   /// @summary One-line plain-text description.
//   /// @details
//   /// Long-form Markdown description.
//   RT_CLASS_BEGIN(...)
//
// Type abbreviations (the only tokens accepted by every signature parser —
// RuntimeSignatureParser.cpp, RuntimeClasses.cpp, and the frontend adapters):
//   void - no return value
//   i1   - boolean (1-bit integer)
//   i16  - 16-bit signed integer
//   i32  - 32-bit signed integer
//   i64  - 64-bit signed integer
//   f64  - 64-bit float (double)
//   str  - string
//   obj  - object reference (optionally qualified: obj<Viper.Class>)
//   seq  - runtime sequence (optionally typed: seq<str>)
//   list - runtime list (optionally typed: list<i64>)
//   ptr  - raw pointer (runtime-internal only; do not expose in RT_FUNC/RT_METHOD signatures)
// There are no i8 or f32 IL types; use i64/f64 and widen at the C boundary.
//
// Notes:
//   - id must be unique C++ identifier
//   - c_symbol is the C runtime function name (rt_*)
//   - canonical is the Viper.* namespace name
//   - RT_INTERNAL_FUNC emits a callable descriptor for class metadata/lowering
//     targets but hides it from standalone frontend runtime function catalogs
//   - RT_BRIDGE marks safe Zia callback bridge parameters as none, callback, or payload
//   - For class methods, signature omits the receiver (arg0)
//
//===----------------------------------------------------------------------===//

