RT_FUNC(UnboxF64,   rt_unbox_f64,   "Viper.Core.Box.ToF64",   "f64(obj)")
RT_FUNC(UnboxI1,    rt_unbox_i1,    "Viper.Core.Box.ToI1",    "i1(obj)")
RT_FUNC(UnboxStr,   rt_unbox_str,   "Viper.Core.Box.ToStr",   "str(obj)")
