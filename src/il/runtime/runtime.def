RT_FUNC(BoxEqI64,   rt_box_eq_i64,  "Viper.Core.Box.EqI64",   "i1(obj,i64)")
RT_FUNC(BoxEqF64,   rt_box_eq_f64,  "Viper.Core.Box.EqF64",   "i1(obj,f64)")
RT_FUNC(BoxEqStr,   rt_box_eq_str,  "Viper.Core.Box.EqStr",   "i1(obj,str)")
RT_FUNC(BoxValueType, rt_box_value_type, "Viper.Core.Box.ValueType", "obj(i64)")
RT_FUNC(BoxValueTypeAddField, rt_box_value_type_add_field, "Viper.Core.Box.ValueTypeAddField", "void(obj,i64,i64,i1)")

RT_CLASS_BEGIN("Viper.Core.Box", CoreBox, "obj", none)
    RT_METHOD("I64",       "obj(i64)",     BoxI64)
    RT_METHOD("F64",       "obj(f64)",     BoxF64)
    RT_METHOD("I1",        "obj(i1)",      BoxI1)
    RT_METHOD("Str",       "obj(str)",     BoxStr)
    RT_METHOD("ToI64",     "i64(obj)",     UnboxI64)
    RT_METHOD("ToF64",     "f64(obj)",     UnboxF64)
    RT_METHOD("ToI1",      "i1(obj)",      UnboxI1)
    RT_METHOD("ToStr",     "str(obj)",     UnboxStr)
    RT_METHOD("ToI64Option", "obj<Viper.Option>(obj)", BoxToI64Option)
    RT_METHOD("ToF64Option", "obj<Viper.Option>(obj)", BoxToF64Option)
    RT_METHOD("ToI1Option",  "obj<Viper.Option>(obj)", BoxToI1Option)
    RT_METHOD("ToStrOption", "obj<Viper.Option>(obj)", BoxToStrOption)
    RT_METHOD("Type",      "i64(obj)",     BoxType)
    RT_METHOD("EqI64",     "i1(obj,i64)",  BoxEqI64)
    RT_METHOD("EqF64",     "i1(obj,f64)",  BoxEqF64)
    RT_METHOD("EqStr",     "i1(obj,str)",  BoxEqStr)
    RT_METHOD("ValueType", "obj(i64)",     BoxValueType)
    RT_METHOD("ValueTypeAddField", "void(obj,i64,i64,i1)", BoxValueTypeAddField)
RT_CLASS_END()

RT_CLASS_BEGIN("Viper.Core.ValueType", CoreValueType, "obj", none)
    RT_METHOD("AddField", "void(i64,i64,i1)", BoxValueTypeAddField)
RT_CLASS_END()

