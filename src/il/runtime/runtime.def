RT_FUNC(BoxToF64Option, rt_box_to_f64_option, "Viper.Core.Box.ToF64Option", "obj<Viper.Option>(obj)")
RT_FUNC(BoxToI1Option,  rt_box_to_i1_option,  "Viper.Core.Box.ToI1Option",  "obj<Viper.Option>(obj)")
RT_FUNC(BoxToStrOption, rt_box_to_str_option, "Viper.Core.Box.ToStrOption", "obj<Viper.Option>(obj)")
