RT_CLASS_BEGIN("Viper.Math.BigInt", MathBigInt, "obj", none)
    RT_METHOD("FromInt",    "obj(i64)",        BigIntFromI64)
    RT_METHOD("FromStr",    "obj(str)",        BigIntFromStr)
    RT_METHOD("FromBytes",  "obj(obj)",        BigIntFromBytes)
    RT_PROP("Zero",         "obj",             BigIntZero,     none)
    RT_PROP("One",          "obj",             BigIntOne,      none)
    RT_METHOD("ToInt",      "i64(obj)",        BigIntToI64)
    RT_METHOD("ToString",   "str(obj)",        BigIntToStr)
    RT_METHOD("ToStrBase",  "str(obj,i64)",    BigIntToStrBase)
    RT_METHOD("ToBytes",    "obj(obj)",        BigIntToBytes)
    RT_METHOD("FitsInt",    "i1(obj)",         BigIntFitsI64)
    RT_METHOD("Add",        "obj(obj,obj)",    BigIntAdd)
    RT_METHOD("Sub",        "obj(obj,obj)",    BigIntSub)
    RT_METHOD("Mul",        "obj(obj,obj)",    BigIntMul)
    RT_METHOD("Div",        "obj(obj,obj)",    BigIntDiv)
    RT_METHOD("Mod",        "obj(obj,obj)",    BigIntMod)
    RT_METHOD("Neg",        "obj(obj)",        BigIntNeg)
    RT_METHOD("Abs",        "obj(obj)",        BigIntAbs)
    RT_METHOD("Cmp",        "i64(obj,obj)",    BigIntCmp)
    RT_METHOD("Eq",         "i1(obj,obj)",     BigIntEq)
    RT_METHOD("IsZero",     "i1(obj)",         BigIntIsZero)
    RT_METHOD("IsNegative", "i1(obj)",         BigIntIsNegative)
    RT_METHOD("Sign",       "i64(obj)",        BigIntSign)
    RT_METHOD("And",        "obj(obj,obj)",    BigIntAnd)
    RT_METHOD("Or",         "obj(obj,obj)",    BigIntOr)
    RT_METHOD("Xor",        "obj(obj,obj)",    BigIntXor)
    RT_METHOD("Not",        "obj(obj)",        BigIntNot)
    RT_METHOD("Shl",        "obj(obj,i64)",    BigIntShl)
    RT_METHOD("Shr",        "obj(obj,i64)",    BigIntShr)
    RT_METHOD("Pow",        "obj(obj,i64)",    BigIntPow)
    RT_METHOD("PowMod",     "obj(obj,obj,obj)",BigIntPowMod)
    RT_METHOD("Gcd",        "obj(obj,obj)",    BigIntGcd)
    RT_METHOD("Lcm",        "obj(obj,obj)",    BigIntLcm)
    RT_METHOD("BitLength",  "i64(obj)",        BigIntBitLen)
    RT_METHOD("TestBit",    "i1(obj,i64)",     BigIntTestBit)
    RT_METHOD("SetBit",     "obj(obj,i64)",    BigIntSetBit)
    RT_METHOD("ClearBit",   "obj(obj,i64)",    BigIntClearBit)
    RT_METHOD("Sqrt",       "obj(obj)",        BigIntSqrt)
RT_CLASS_END()

