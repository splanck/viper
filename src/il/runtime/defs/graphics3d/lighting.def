/// @summary Provides Physics 3D Body functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Physics3DBody` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `UserData`, `Collider`, `Position` and operations including `NewAABB`, `NewSphere`,
/// `NewCapsule`, `SetPosition`.
RT_CLASS_BEGIN("Zanna.Graphics3D.PhysicsBody3D", Physics3DBody, "obj", Body3DNew)
    RT_PROP("UserData", "i64", Body3DGetUserData, Body3DSetUserData)
    RT_PROP("Collider", "obj<Zanna.Graphics3D.Collider3D>", Body3DGetCollider, Body3DSetCollider)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", Body3DGetPosition, none)
    RT_PROP("Scale", "obj<Zanna.Math.Vec3>", Body3DGetScale, none)
    RT_PROP("Orientation", "obj<Zanna.Math.Quat>", Body3DGetOrientation, none)
    RT_PROP("Velocity", "obj<Zanna.Math.Vec3>", Body3DGetVelocity, none)
    RT_PROP("AngularVelocity", "obj<Zanna.Math.Vec3>", Body3DGetAngularVelocity, none)
    RT_PROP("Restitution", "f64", Body3DGetRestitution, Body3DSetRestitution)
    RT_PROP("Friction", "f64", Body3DGetFriction, Body3DSetFriction)
    RT_PROP("LinearDamping", "f64", Body3DGetLinearDamping, Body3DSetLinearDamping)
    RT_PROP("AngularDamping", "f64", Body3DGetAngularDamping, Body3DSetAngularDamping)
    RT_PROP("CollisionLayer", "i64", Body3DGetCollisionLayer, Body3DSetCollisionLayer)
    RT_PROP("CollisionMask", "i64", Body3DGetCollisionMask, Body3DSetCollisionMask)
    RT_PROP("IsStatic", "i1", Body3DIsStatic, Body3DSetStatic)
    RT_PROP("IsKinematic", "i1", Body3DIsKinematic, Body3DSetKinematic)
    RT_PROP("IsTrigger", "i1", Body3DIsTrigger, Body3DSetTrigger)
    RT_PROP("CanSleep", "i1", Body3DCanSleep, Body3DSetCanSleep)
    RT_PROP("IsSleeping", "i1", Body3DIsSleeping, none)
    RT_PROP("UseCcd", "i1", Body3DGetUseCcd, Body3DSetUseCcd)
    RT_PROP("IsGrounded", "i1", Body3DIsGrounded, none)
    RT_PROP("GroundNormal", "obj<Zanna.Math.Vec3>", Body3DGetGroundNormal, none)
    RT_PROP("Mass", "f64", Body3DGetMass, none)
    RT_METHOD("NewAABB", "obj(f64,f64,f64,f64)", Body3DNewAABB)
    RT_METHOD("Sphere", "obj(f64,f64)", Body3DNewSphere)
    RT_METHOD("NewCapsule", "obj(f64,f64,f64)", Body3DNewCapsule)
    RT_METHOD("SetPosition", "void(f64,f64,f64)", Body3DSetPosition)
