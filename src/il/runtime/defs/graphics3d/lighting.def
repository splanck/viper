/// @summary Provides Collider 3D functionality for 3D rendering and scene applications.
/// @details
/// `Zanna.Graphics3D.Collider3D` exposes a registry-backed runtime surface without requiring
/// callers to construct the class directly. Its public surface exposes properties such as
/// `Friction`, `Restitution`, `SurfaceType` and operations including `Box`, `Sphere`, `Capsule`,
/// `NewConvexHull`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Collider3D", Collider3D, "obj", none)
    RT_PROP("Friction", "f64", Collider3DGetFriction, Collider3DSetFriction)
    RT_PROP("Restitution", "f64", Collider3DGetRestitution, Collider3DSetRestitution)
    RT_PROP("SurfaceType", "i64", Collider3DGetSurfaceType, Collider3DSetSurfaceType)
    RT_PROP("Type", "i64", Collider3DGetType, none)
    RT_METHOD("Box", "obj(f64,f64,f64)", Collider3DBox)
    RT_METHOD("Sphere", "obj(f64)", Collider3DSphere)
    RT_METHOD("Capsule", "obj(f64,f64)", Collider3DCapsule)
    RT_METHOD("NewConvexHull", "obj(obj)", Collider3DNewConvexHull)
    // Quickhull-reduced hull: interior vertices removed, vertex budget 8-255.
    RT_METHOD("NewConvexHullReduced", "obj(obj,i64)", Collider3DNewConvexHullReduced)
    RT_METHOD("NewMesh", "obj(obj)", Collider3DNewMesh)
    RT_METHOD("NewHeightfield", "obj(obj,f64,f64,f64)", Collider3DNewHeightfield)
    RT_METHOD("NewCompound", "obj()", Collider3DNewCompound)
    RT_METHOD("AddChild", "void(obj,obj)", Collider3DAddChild)
    RT_METHOD("GetLocalBoundsMin", "obj()", Collider3DGetBoundsMin)
    RT_METHOD("GetLocalBoundsMax", "obj()", Collider3DGetBoundsMax)
RT_CLASS_END()

