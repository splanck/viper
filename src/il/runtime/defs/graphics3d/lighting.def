    RT_METHOD("SetOrientation", "void(obj)", Body3DSetOrientation)
    RT_METHOD("SetVelocity", "void(f64,f64,f64)", Body3DSetVelocity)
    RT_METHOD("SetAngularVelocity", "void(f64,f64,f64)", Body3DSetAngularVelocity)
    RT_METHOD("ApplyForce", "void(f64,f64,f64)", Body3DApplyForce)
    RT_METHOD("ApplyForceAtPoint", "void(f64,f64,f64,f64,f64,f64)", Body3DApplyForceAtPoint)
    RT_METHOD("ApplyImpulse", "void(f64,f64,f64)", Body3DApplyImpulse)
