/// @summary Provides Scene Graph functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.SceneGraph` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Root`, `NodeCount`, `CulledCount` and operations including `Add`, `TryAdd`, `Remove`, `Find`.
RT_CLASS_BEGIN("Zanna.Graphics3D.SceneGraph", Scene3D, "obj", Scene3DNew)
    RT_PROP("Root", "obj<Zanna.Graphics3D.SceneNode>", Scene3DGetRoot, none)
    RT_PROP("NodeCount", "i64", Scene3DNodeCount, none)
    RT_PROP("CulledCount", "i64", Scene3DCulledCount, none)
    RT_PROP("VisibleNodeCount", "i64", Scene3DVisibleNodeCount, none)
    RT_PROP("PvsCulledCount", "i64", Scene3DPvsCulledCount, none)
    RT_PROP("VisibilityZoneCount", "i64", Scene3DVisibilityZoneCount, none)
    RT_PROP("VisibilityPortalCount", "i64", Scene3DVisibilityPortalCount, none)
    // Portal-frustum PVS: portals propagate only through their projected screen
    // windows (default). false = legacy any-portal reachability flood-fill.
    RT_PROP("PortalClipping", "i1", Scene3DGetPortalClipping, Scene3DSetPortalClipping)
    RT_PROP("PortalTraversalCount", "i64", Scene3DPortalTraversalCount, none)
    RT_METHOD("Add", "void(obj)", Scene3DAdd)
    RT_METHOD("TryAdd", "i1(obj)", Scene3DTryAdd)
    RT_METHOD("Remove", "void(obj)", Scene3DRemove)
    RT_METHOD("Find", "obj<Zanna.Option>(str)", Scene3DFindOption)
    RT_METHOD("QueryAABB", "obj<Zanna.Collections.Seq>(obj,obj)", Scene3DQueryAABB)
    RT_METHOD("QuerySphere", "obj<Zanna.Collections.Seq>(obj,f64)", Scene3DQuerySphere)
    RT_METHOD("RaycastNodes", "obj<Zanna.Graphics3D.SceneNode>(obj,obj,f64)", Scene3DRaycastNodes)
    RT_METHOD("SetNodeTransforms", "void(obj,obj)", Scene3DSetNodeTransforms)
    RT_METHOD("AddVisibilityZone", "i64(str,obj,obj)", Scene3DAddVisibilityZone)
    RT_METHOD("AddVisibilityPortal", "i64(i64,i64,i1)", Scene3DAddVisibilityPortal)
    RT_METHOD("Draw", "void(obj,obj)", Scene3DDraw)
    RT_METHOD("Clear", "void()", Scene3DClear)
    RT_METHOD("Save", "i64(str)", Scene3DSave)
    RT_METHOD("Load", "obj<Zanna.Graphics3D.SceneGraph>(str)", Scene3DLoad)
    RT_METHOD("SyncBindings", "void(f64)", Scene3DSyncBindings)
    RT_METHOD("RebaseOrigin", "void(f64,f64,f64)", Scene3DRebaseOrigin)
RT_CLASS_END()

