/// @summary Provides Light 3D functionality for 3D rendering and scene applications.
/// @details
/// `Zanna.Graphics3D.Light3D` exposes a registry-backed runtime surface without requiring callers
/// to construct the class directly. Its public surface exposes properties such as `Type`,
/// `Color`, `Intensity` and operations including `Directional`, `Point`, `Ambient`, `Spot`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Light3D", Light3D, "obj", none)
    RT_PROP("Type", "i64", Light3DGetType, none)
    RT_PROP("Color", "obj<Zanna.Math.Vec3>", Light3DGetColor, none)
    RT_PROP("Intensity", "f64", Light3DGetIntensity, none)
    RT_PROP("IsEnabled", "i1", Light3DGetEnabled, Light3DSetEnabled)
    RT_PROP("CastsShadows", "i1", Light3DGetCastsShadows, Light3DSetCastsShadows)
    RT_PROP("Direction", "obj<Zanna.Math.Vec3>", Light3DGetDirection, Light3DSetDirection)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", Light3DGetPosition, Light3DSetPosition)
    RT_METHOD("Directional", "obj(obj,f64,f64,f64)", Light3DDirectional)
    RT_METHOD("Point", "obj(obj,f64,f64,f64,f64)", Light3DPoint)
    RT_METHOD("Ambient", "obj(f64,f64,f64)", Light3DAmbient)
    RT_METHOD("Spot", "obj(obj,obj,f64,f64,f64,f64,f64,f64)", Light3DSpot)
    RT_METHOD("SetIntensity", "void(f64)", Light3DSetIntensity)
    // Distance falloff for point/spot lights; no-op on other types. Lets pooled
    // lights be retuned per effect instead of being recreated.
    RT_METHOD("SetAttenuation", "void(f64)", Light3DSetAttenuation)
    RT_PROP("Attenuation", "f64", Light3DGetAttenuation, none)
    RT_METHOD("SetColor", "void(f64,f64,f64)", Light3DSetColor)
RT_CLASS_END()

