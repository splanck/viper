/// @summary Provides Particles 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Particles3D` values through its registered constructor and use the
/// returned object with the instance members below. `Update` advances deterministic 60 Hz steps,
/// retains ordinary fractional time in `ResidualTime`, and exposes safety-budget overflow through
/// `DroppedTime` and `LastDroppedTime`. `Count` contains live particles only; when
/// `RenderFinalFrame` is enabled, an expired endpoint remains drawable until the next valid update
/// without remaining live. Call `ResetDroppedTime` after consuming cumulative timing telemetry.
RT_CLASS_BEGIN("Zanna.Graphics3D.Particles3D", Particles3D, "obj", Particles3DNew)
    RT_PROP("Count", "i64", Particles3DGetCount, none)
    RT_PROP("IsEmitting", "i1", Particles3DGetEmitting, none)
    RT_PROP("Additive", "i1", none, Particles3DSetAdditive)
    // Live PRNG state: set for reproducible spawn streams (determinism/replay),
    // read to checkpoint the stream. Emitters otherwise seed from a process
    // counter, so streams depend on global construction order.
    RT_PROP("Seed", "i64", Particles3DGetSeed, Particles3DSetSeed)
    // Expired particles leave Count immediately. This compatibility option retains their exact
    // endpoint in a non-live draw snapshot until the next valid Update.
    RT_PROP("RenderFinalFrame", "i1", Particles3DGetRenderFinalFrame, Particles3DSetRenderFinalFrame)
    // Fixed-step observability: normal fractional time is residual, while safety-budget overflow is
    // reported rather than silently consumed.
    RT_PROP("DroppedTime", "f64", Particles3DGetDroppedTime, none)
    RT_PROP("LastDroppedTime", "f64", Particles3DGetLastDroppedTime, none)
    RT_PROP("ResidualTime", "f64", Particles3DGetResidualTime, none)
    // Velocity-aligned stretch + ribbon trails (tracers, rivets, EMP ribbons).
    RT_METHOD("SetStretch", "void(f64)", Particles3DSetStretch)
    RT_METHOD("SetTrail", "void(f64,i64)", Particles3DSetTrail)
    RT_METHOD("SetSoftness", "void(f64)", Particles3DSetSoftness)
    RT_METHOD("SetPosition", "void(f64,f64,f64)", Particles3DSetPosition)
    RT_METHOD("SetDirection", "void(f64,f64,f64,f64)", Particles3DSetDirection)
    RT_METHOD("SetSpeed", "void(f64,f64)", Particles3DSetSpeed)
    RT_METHOD("SetLifetime", "void(f64,f64)", Particles3DSetLifetime)
    RT_METHOD("SetSize", "void(f64,f64)", Particles3DSetSize)
    RT_METHOD("SetGravity", "void(f64,f64,f64)", Particles3DSetGravity)
    RT_METHOD("SetColor", "void(i64,i64)", Particles3DSetColor)
    RT_METHOD("SetAlpha", "void(f64,f64)", Particles3DSetAlpha)
    RT_METHOD("SetRate", "void(f64)", Particles3DSetRate)
    RT_METHOD("SetTexture", "void(obj)", Particles3DSetTexture)
    RT_METHOD("SetEmitterShape", "void(i64)", Particles3DSetEmitterShape)
    RT_METHOD("SetEmitterSize", "void(f64,f64,f64)", Particles3DSetEmitterSize)
    RT_METHOD("Start", "void()", Particles3DStart)
    RT_METHOD("Stop", "void()", Particles3DStop)
    RT_METHOD("Burst", "void(i64)", Particles3DBurst)
    RT_METHOD("Clear", "void()", Particles3DClear)
    RT_METHOD("ResetDroppedTime", "void()", Particles3DResetDroppedTime)
    RT_METHOD("RebaseOrigin", "void(f64,f64,f64)", Particles3DRebaseOrigin)
    RT_METHOD("Update", "void(f64)", Particles3DUpdate)
    RT_METHOD("Draw", "void(obj,obj)", Particles3DDraw)
RT_CLASS_END()

