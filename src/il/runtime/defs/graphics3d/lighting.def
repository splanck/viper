    RT_METHOD("AddVignette", "void(f64,f64)", PostFX3DAddVignette)
    RT_METHOD("Clear", "void()", PostFX3DClear)
    RT_METHOD("NewQuality", "obj(obj,i64)", PostFX3DNewQuality)
    RT_METHOD("AddSsao", "void(f64,f64,i64)", PostFX3DAddSSAO)
    RT_METHOD("AddDof", "void(f64,f64,f64)", PostFX3DAddDOF)
    RT_METHOD("SetDofFocus", "i1(f64)", PostFX3DSetDofFocus)
