/// @summary Provides Sound Source 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.SoundSource3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Position`, `Velocity`, `DopplerFactor` and operations including `Play`, `Stop`, `BindNode`,
/// `ClearNodeBinding`.
RT_CLASS_BEGIN("Zanna.Graphics3D.SoundSource3D", SoundSource3D, "obj", SoundSource3DNew)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", SoundSource3DGetPosition, SoundSource3DSetPosition)
    RT_PROP("Velocity", "obj<Zanna.Math.Vec3>", SoundSource3DGetVelocity, SoundSource3DSetVelocity)
    RT_PROP("DopplerFactor", "f64", SoundSource3DGetDopplerFactor, none)
    RT_PROP("ReferenceDistance", "f64", SoundSource3DGetRefDistance, SoundSource3DSetRefDistance)
    RT_PROP("MaxDistance", "f64", SoundSource3DGetMaxDistance, SoundSource3DSetMaxDistance)
    RT_PROP("Volume", "i64", SoundSource3DGetVolume, SoundSource3DSetVolume)
    // User playback-rate multiplier; composes with the (now applied) Doppler
    // factor. The mixer clamps the combined rate to 0.25–4.0.
    RT_PROP("Pitch", "f64", SoundSource3DGetPitch, SoundSource3DSetPitch)
    RT_PROP("MixGroup", "i64", SoundSource3DGetMixGroup, SoundSource3DSetMixGroup)
    // Occlusion 0 (open) .. 1 (occluded): smoothed lowpass sweep + attenuation.
    RT_PROP("Occlusion", "f64", SoundSource3DGetOcclusion, SoundSource3DSetOcclusion)
    RT_PROP("Looping", "i1", SoundSource3DGetLooping, SoundSource3DSetLooping)
    RT_PROP("IsPlaying", "i1", SoundSource3DGetIsPlaying, none)
    RT_PROP("VoiceId", "i64", SoundSource3DGetVoiceId, none)
    RT_METHOD("Play", "i64()", SoundSource3DPlay)
    RT_METHOD("Stop", "void()", SoundSource3DStop)
    RT_METHOD("BindNode", "void(obj)", SoundSource3DBindNode)
    RT_METHOD("ClearNodeBinding", "void()", SoundSource3DClearNodeBinding)
RT_CLASS_END()

