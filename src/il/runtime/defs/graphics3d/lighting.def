/// @summary Raycast vehicle simulation: suspension, tire grip, drive and brake forces on a rigid chassis.
/// @details
/// Create a `Zanna.Graphics3D.Vehicle3D` with `New(world, chassisBody)` around a dynamic
/// `Physics3DBody`, add suspension wheels with `AddWheel` (chassis-local anchor, wheel radius,
/// suspension rest length, spring stiffness, damping, steering/driven flags), feed controls with
/// `SetInput(throttle, brake, steer)`, and call `Step(dt)` once per frame BEFORE
/// `Physics3DWorld.Step(dt)` so the wheel forces are integrated by that step. Tuning:
/// `SetDriveForce`, `SetBrakeForce`, `SetMaxSteer`, `SetGrip`, `SetCollisionMask`. Telemetry:
/// `Speed`, `WheelCount`, `WheelInContact`, `WheelTravel`, `WheelLoad`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Vehicle3D", Vehicle3D, "obj", Vehicle3DNew)
    RT_PROP("Speed", "f64", Vehicle3DGetSpeed, none)
    RT_PROP("WheelCount", "i64", Vehicle3DGetWheelCount, none)
    RT_METHOD("AddWheel", "i64(f64,f64,f64,f64,f64,f64,f64,i1,i1)", Vehicle3DAddWheel)
    RT_METHOD("SetInput", "void(f64,f64,f64)", Vehicle3DSetInput)
    RT_METHOD("SetDriveForce", "void(f64)", Vehicle3DSetDriveForce)
    RT_METHOD("SetBrakeForce", "void(f64)", Vehicle3DSetBrakeForce)
    RT_METHOD("SetMaxSteer", "void(f64)", Vehicle3DSetMaxSteer)
    RT_METHOD("SetGrip", "void(f64,f64)", Vehicle3DSetGrip)
    RT_METHOD("SetCollisionMask", "void(i64)", Vehicle3DSetCollisionMask)
    RT_METHOD("Step", "void(f64)", Vehicle3DStep)
    RT_METHOD("WheelInContact", "i1(i64)", Vehicle3DWheelInContact)
    RT_METHOD("WheelTravel", "f64(i64)", Vehicle3DWheelTravel)
    RT_METHOD("WheelLoad", "f64(i64)", Vehicle3DWheelLoad)
RT_CLASS_END()

