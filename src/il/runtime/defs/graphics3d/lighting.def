/// `Position`, `Forward`, `Up` and operations including `BindNode`, `ClearNodeBinding`,
/// `BindCamera`, `ClearCameraBinding`.
RT_CLASS_BEGIN("Zanna.Graphics3D.SoundListener3D", SoundListener3D, "obj", SoundListener3DNew)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", SoundListener3DGetPosition, SoundListener3DSetPosition)
    RT_PROP("Forward", "obj<Zanna.Math.Vec3>", SoundListener3DGetForward, SoundListener3DSetForward)
    RT_PROP("Up", "obj<Zanna.Math.Vec3>", SoundListener3DGetUp, SoundListener3DSetUp)
    RT_PROP("Velocity", "obj<Zanna.Math.Vec3>", SoundListener3DGetVelocity, SoundListener3DSetVelocity)
    RT_PROP("IsActive", "i1", SoundListener3DGetIsActive, SoundListener3DSetIsActive)
    RT_METHOD("BindNode", "void(obj)", SoundListener3DBindNode)
    RT_METHOD("ClearNodeBinding", "void()", SoundListener3DClearNodeBinding)
    RT_METHOD("BindCamera", "void(obj)", SoundListener3DBindCamera)
    RT_METHOD("ClearCameraBinding", "void()", SoundListener3DClearCameraBinding)
RT_CLASS_END()

