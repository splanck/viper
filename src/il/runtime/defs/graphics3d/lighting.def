/// @summary Provides Character 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Character3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `StepHeight`, `World`, `IsGrounded` and operations including `Move`, `SetSlopeLimit`,
/// `SetPosition`, `TrySetHeight`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Character3D", Character3D, "obj", Character3DNew)
    RT_PROP("StepHeight", "f64", Character3DGetStepHeight, Character3DSetStepHeight)
    RT_PROP("World", "obj", Character3DGetWorld, Character3DSetWorld)
    RT_PROP("IsGrounded", "i1", Character3DIsGrounded, none)
    RT_PROP("JustLanded", "i1", Character3DJustLanded, none)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", Character3DGetPosition, none)
    RT_PROP("Height", "f64", Character3DGetHeight, Character3DSetHeight)
    RT_PROP("PushStrength", "f64", Character3DGetPushStrength, Character3DSetPushStrength)
    RT_PROP("CollideDynamic", "i1", Character3DGetCollideDynamic, Character3DSetCollideDynamic)
    RT_PROP("RidePlatforms", "i1", Character3DGetRidePlatforms, Character3DSetRidePlatforms)
    RT_METHOD("Move", "void(obj,f64)", Character3DMove)
    RT_METHOD("SetSlopeLimit", "void(f64)", Character3DSetSlopeLimit)
    RT_METHOD("SetPosition", "void(f64,f64,f64)", Character3DSetPosition)
    RT_METHOD("TrySetHeight", "i1(f64)", Character3DTrySetHeight)
    RT_METHOD("IsSliding", "i1()", Character3DIsSliding)
    RT_METHOD("GetGroundBody", "obj<Zanna.Graphics3D.PhysicsBody3D>()", Character3DGetGroundBody)
RT_CLASS_END()

