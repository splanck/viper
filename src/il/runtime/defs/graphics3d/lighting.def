/// @summary Provides Asset Diagnostics 3D constants and static operations for 3D rendering and scene applications.
/// @details
/// `Zanna.Graphics3D.AssetDiagnostics3D` is a static runtime surface and does not require an
/// instance. Its public surface exposes properties such as `LoadWarningCount` and operations
/// including `GetLoadWarning`, `GetLoadWarnings`, `GetImportReport`.
RT_CLASS_BEGIN("Zanna.Graphics3D.AssetDiagnostics3D", AssetDiagnostics3D, "none", none)
