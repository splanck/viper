    RT_METHOD("InstantiateSceneAt", "obj<Zanna.Graphics3D.SceneGraph>(i64)", Model3DInstantiateSceneAt)
    RT_METHOD("LoadAnimationResult", "obj<Zanna.Result>(str,i64)", Model3DLoadAnimationResult)
    RT_METHOD("LoadAnimationAssetResult", "obj<Zanna.Result>(str,i64)", Model3DLoadAnimationAssetResult)
    RT_METHOD("LoadNodeAnimationResult", "obj<Zanna.Result>(str,i64)", Model3DLoadNodeAnimationResult)
