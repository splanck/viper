/// @summary Provides Physics 3D World functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Physics3DWorld` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `BodyCount`, `CollisionCount`, `CollisionEventCount` and operations including
/// `SetMaxQueryHits`, `Step`, `StepFixed`, `Add`.
RT_CLASS_BEGIN("Zanna.Graphics3D.PhysicsWorld3D", Physics3DWorld, "obj", World3DNew)
    RT_PROP("BodyCount", "i64", World3DBodyCount, none)
    RT_PROP("CollisionCount", "i64", World3DCollisionCount, none)
    RT_PROP("CollisionEventCount", "i64", World3DCollisionEventCount, none)
    RT_PROP("EnterEventCount", "i64", World3DEnterEventCount, none)
    RT_PROP("StayEventCount", "i64", World3DStayEventCount, none)
    RT_PROP("ExitEventCount", "i64", World3DExitEventCount, none)
    RT_PROP("JointCount", "i64", World3DJointCount, none)
    RT_PROP("LastCcdRequestedSubsteps", "i64", World3DLastCcdRequestedSubsteps, none)
    RT_PROP("LastCcdSubsteps", "i64", World3DLastCcdSubsteps, none)
    RT_PROP("CcdSubstepClampedCount", "i64", World3DCcdSubstepClampedCount, none)
    RT_PROP("LastCcdClampedBodyCount", "i64", World3DLastCcdClampedBodyCount, none)
    RT_PROP("CcdSubstepClampedBodyCount", "i64", World3DCcdSubstepClampedBodyCount, none)
    RT_PROP("CcdToiCount", "i64", World3DCcdToiCount, none)
    // Query result capacity for RaycastAll/Overlap* (16-4096, default 256).
    RT_METHOD("SetMaxQueryHits", "void(i64)", World3DSetMaxQueryHits)
    RT_PROP("MaxQueryHits", "i64", World3DGetMaxQueryHits, none)
    RT_PROP("BroadphaseFallbackCount", "i64", World3DBroadphaseFallbackCount, none)
    // Total spatial-query broadphase rebuilds; flat while bodies move within the fat-AABB margin.
    RT_PROP("QueryBroadphaseRebuildCount", "i64", World3DQueryBroadphaseRebuildCount, none)
    RT_PROP("SolverIterations", "i64", World3DGetSolverIterations, World3DSetSolverIterations)
    RT_PROP("PositionIterations", "i64", World3DGetPositionIterations, World3DSetPositionIterations)
    RT_PROP("ContactBeta", "f64", World3DGetContactBeta, World3DSetContactBeta)
    RT_PROP("RestitutionThreshold", "f64", World3DGetRestitutionThreshold, World3DSetRestitutionThreshold)
    RT_PROP("FixedStepAlpha", "f64", World3DGetFixedStepAlpha, none)
    RT_PROP("DroppedFixedSteps", "i64", World3DGetDroppedFixedSteps, none)
    RT_PROP("LastSolverIslandCount", "i64", World3DLastSolverIslandCount, none)
    RT_PROP("LastSolverActiveBodyCount", "i64", World3DLastSolverActiveBodyCount, none)
    RT_PROP("LastSolverContactCount", "i64", World3DLastSolverContactCount, none)
    RT_METHOD("Step", "void(f64)", World3DStep)
    RT_METHOD("StepFixed", "i64(f64,f64,i64)", World3DStepFixed)
    RT_METHOD("Add", "void(obj)", World3DAdd)
    RT_METHOD("TryAdd", "i1(obj)", World3DTryAdd)
    RT_METHOD("Remove", "void(obj)", World3DRemove)
    RT_METHOD("ContainsBody", "i1(obj)", World3DContainsBody)
    RT_METHOD("SetGravity", "void(f64,f64,f64)", World3DSetGravity)
    RT_METHOD("AddJoint", "void(obj,i64)", World3DAddJoint)
    RT_METHOD("RemoveJoint", "void(obj)", World3DRemoveJoint)
    RT_METHOD("Raycast", "obj<Zanna.Graphics3D.PhysicsHit3D>(obj,obj,f64,i64)", World3DRaycast)
    RT_METHOD("RaycastAll", "obj<Zanna.Graphics3D.PhysicsHitList3D>(obj,obj,f64,i64)", World3DRaycastAll)
    RT_METHOD("SweepSphere", "obj<Zanna.Graphics3D.PhysicsHit3D>(obj,f64,obj,i64)", World3DSweepSphere)
    RT_METHOD("SweepCapsule", "obj(obj,obj,f64,obj,i64)", World3DSweepCapsule)
    RT_METHOD("OverlapSphere", "obj<Zanna.Graphics3D.PhysicsHitList3D>(obj,f64,i64)", World3DOverlapSphere)
    RT_METHOD("OverlapAABB", "obj(obj,obj,i64)", World3DOverlapAABB)
    RT_METHOD("RebaseOrigin", "void(f64,f64,f64)", World3DRebaseOrigin)
    RT_METHOD("ProbeClearance", "i1(obj<Zanna.Math.Vec3>,f64,f64,i64)", World3DProbeClearance)
    RT_METHOD("ProbeLedge", "obj<Zanna.Graphics3D.LedgeHit3D>(obj<Zanna.Math.Vec3>,obj<Zanna.Math.Vec3>,f64,f64,f64,i64)", World3DProbeLedge)
    RT_METHOD("ProbeVault", "obj<Zanna.Graphics3D.LedgeHit3D>(obj<Zanna.Math.Vec3>,obj<Zanna.Math.Vec3>,f64,f64,f64,i64)", World3DProbeVault)
    RT_METHOD("GetCollisionBodyA", "obj(i64)", World3DCollisionBodyA)
    RT_METHOD("GetCollisionBodyB", "obj(i64)", World3DCollisionBodyB)
    RT_METHOD("GetCollisionNormal", "obj(i64)", World3DCollisionNormal)
    RT_METHOD("GetCollisionDepth", "f64(i64)", World3DCollisionDepth)
    RT_METHOD("GetCollisionEvent", "obj(i64)", World3DGetCollisionEvent)
    RT_METHOD("GetEnterEvent", "obj(i64)", World3DGetEnterEvent)
    RT_METHOD("GetStayEvent", "obj(i64)", World3DGetStayEvent)
    RT_METHOD("GetExitEvent", "obj(i64)", World3DGetExitEvent)
    RT_METHOD("ClearCollisionEvents", "void()", World3DClearCollisionEvents)
RT_CLASS_END()

