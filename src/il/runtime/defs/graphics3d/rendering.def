/// @summary Provides Mesh 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Mesh3D` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as
/// `VertexCount`, `TriangleCount`, `Resident` and operations including `Simplify`, `Box`,
/// `Sphere`, `Plane`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Mesh3D", Mesh3D, "obj", Mesh3DNew)
    RT_PROP("VertexCount", "i64", Mesh3DGetVertexCount, none)
    RT_PROP("TriangleCount", "i64", Mesh3DGetTriangleCount, none)
    RT_PROP("Resident", "i1", Mesh3DGetResident, Mesh3DSetResident)
    RT_PROP("ResidentBytes", "i64", Mesh3DGetResidentBytes, none)
    RT_PROP("CompactStreams", "i1", Mesh3DGetCompactStreams, Mesh3DSetCompactStreams)
    RT_PROP("RetainedBytes", "i64", Mesh3DGetRetainedBytes, none)
    // Simplification diagnostics: status 0=not-run, 1=complete, 2=valid partial result.
    RT_PROP("SimplifyRequestedTriangles", "i64", Mesh3DGetSimplifyRequestedTriangles, none)
    RT_PROP("SimplifyAchievedTriangles", "i64", Mesh3DGetSimplifyAchievedTriangles, none)
    RT_PROP("SimplifyStatus", "i64", Mesh3DGetSimplifyStatus, none)
    // QEM decimation: returns a NEW mesh; attributes never interpolated.
    RT_METHOD("Simplify", "obj<Zanna.Graphics3D.Mesh3D>(i64)", Mesh3DSimplify)
    RT_METHOD("Box", "obj(f64,f64,f64)", Mesh3DBox)
    RT_METHOD("Sphere", "obj(f64,i64)", Mesh3DSphere)
    RT_METHOD("Plane", "obj(f64,f64)", Mesh3DPlane)
    RT_METHOD("Cylinder", "obj(f64,f64,i64)", Mesh3DCylinder)
    RT_METHOD("FromObj", "obj(str)", Mesh3DFromOBJ)
    RT_METHOD("FromStl", "obj(str)", Mesh3DFromSTL)
    RT_METHOD("Reserve", "void(i64,i64)", Mesh3DReserve)
    RT_METHOD("AddVertex", "void(f64,f64,f64,f64,f64,f64,f64,f64)", Mesh3DAddVertex)
    RT_METHOD("AddTriangle", "void(i64,i64,i64)", Mesh3DAddTriangle)
    RT_METHOD("Clear", "void()", Mesh3DClear)
    RT_METHOD("RecalculateNormals", "void()", Mesh3DRecalcNormals)
    RT_METHOD("Clone", "obj()", Mesh3DClone)
    RT_METHOD("Transform", "void(obj)", Mesh3DTransform)
    // Frees auxiliary CPU geometry (double positions, build scratch) a
    // finished static mesh no longer needs; returns bytes released.
    RT_METHOD("ReleaseCpuScratch", "i64()", Mesh3DReleaseCpuScratch)
    RT_METHOD("CalculateTangents", "void()", Mesh3DCalcTangents)
    RT_METHOD("SetSkeleton", "void(obj)", Mesh3DSetSkeleton)
    RT_METHOD("SetBoneWeights", "void(i64,i64,f64,i64,f64,i64,f64,i64,f64)", Mesh3DSetBoneWeights)
    RT_METHOD("SetMorphTargets", "void(obj)", Mesh3DSetMorphTargets)
RT_CLASS_END()

