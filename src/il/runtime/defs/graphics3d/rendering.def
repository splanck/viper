/// @summary Provides Cube Map 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.CubeMap3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes operations
/// including `LoadHdrPanorama`.
RT_CLASS_BEGIN("Zanna.Graphics3D.CubeMap3D", CubeMap3D, "obj", CubeMap3DNew)
    RT_METHOD("LoadHdrPanorama", "obj<Zanna.Graphics3D.CubeMap3D>(str,f64)", CubeMap3DLoadHdrPanorama)
RT_CLASS_END()

