/// @summary Owns a 3D rendering canvas, frame lifecycle, resources, and renderer diagnostics.
/// @details
/// Create `Zanna.Graphics3D.Canvas3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `ShouldClose`, `Width`, `Height` and operations including `IsAvailable`, `NewFullscreen`,
/// `SetForceCpuSkinning`, `SetShadowBudget`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Canvas3D", Canvas3D, "obj", Canvas3DNew)
    RT_METHOD("IsAvailable", "i1()", Canvas3DIsAvailable)
    // Fullscreen-at-creation: desktop resolution, no windowed flash.
    RT_METHOD("NewFullscreen", "obj(str)", Canvas3DNewFullscreen)
    RT_PROP("ShouldClose", "i1", Canvas3DShouldClose, none)
    RT_PROP("Width", "i64", Canvas3DGetWidth, none)
    RT_PROP("Height", "i64", Canvas3DGetHeight, none)
    RT_PROP("WindowWidth", "i64", Canvas3DGetWindowWidth, none)
    RT_PROP("WindowHeight", "i64", Canvas3DGetWindowHeight, none)
    RT_PROP("ActiveOutputWidth", "i64", Canvas3DGetActiveOutputWidth, none)
    RT_PROP("ActiveOutputHeight", "i64", Canvas3DGetActiveOutputHeight, none)
    RT_PROP("Fps", "i64", Canvas3DGetFps, none)
    RT_PROP("DeltaTime", "i64", Canvas3DGetDeltaTime, none)
    RT_PROP("DeltaTimeSec", "f64", Canvas3DGetDeltaTimeSec, none)
    RT_PROP("Backend", "str", Canvas3DGetBackend, none)
    RT_PROP("BackendFallback", "i1", Canvas3DGetBackendFallback, none)
    RT_PROP("BackendFallbackReason", "str", Canvas3DGetBackendFallbackReason, none)
    RT_PROP("BackendCapabilities", "i64", Canvas3DGetBackendCapabilities, none)
    RT_PROP("DrawCount", "i64", Canvas3DGetDrawCount, none)
    RT_PROP("GpuSkinnedDrawCount", "i64", Canvas3DGetGpuSkinnedDrawCount, none)
    RT_PROP("SkinningUploadBytes", "i64", Canvas3DGetSkinningUploadBytes, none)
    RT_METHOD("SetForceCpuSkinning", "void(i1)", Canvas3DSetForceCpuSkinning)
    RT_PROP("OccludedDrawCount", "i64", Canvas3DGetOccludedDrawCount, none)
    // Instances that took the per-draw fallback (blend/rebase); opaque
    // instanced batches use the backend hook on every backend and report 0.
    RT_PROP("InstancedFallbackCount", "i64", Canvas3DGetInstancedFallbackCount, none)
    RT_PROP("InstancedFallbackDroppedCount", "i64", Canvas3DGetInstancedFallbackDroppedCount, none)
    // Sticky failure status plus a resettable saturating count preserve evidence
    // from legacy void submissions without changing their signatures.
    RT_PROP("LastSubmissionStatus", "i64", Canvas3DGetLastSubmissionStatus, none)
    RT_PROP("SubmissionFailureCount", "i64", Canvas3DGetSubmissionFailureCount, none)
    RT_METHOD("ResetSubmissionDiagnostics", "void()", Canvas3DResetSubmissionDiagnostics)
    RT_PROP("EventDropCount", "i64", Canvas3DGetEventDropCount, none)
    RT_PROP("MeshSnapshotBytes", "i64", Canvas3DGetMeshSnapshotBytes, none)
    RT_PROP("MeshSnapshotDropCount", "i64", Canvas3DGetMeshSnapshotDropCount, none)
    RT_PROP("MeshSnapshotDroppedBytes", "i64", Canvas3DGetMeshSnapshotDroppedBytes, none)
    RT_PROP("MeshSnapshotBudgetBytes", "i64", Canvas3DGetMeshSnapshotBudgetBytes, none)
    // Shadow budget: general slot cap plus per-frame usage/drop telemetry.
    RT_METHOD("SetShadowBudget", "void(i64)", Canvas3DSetShadowBudget)
    RT_PROP("ShadowSlotsUsed", "i64", Canvas3DGetShadowSlotsUsed, none)
    RT_PROP("ShadowRequestsDropped", "i64", Canvas3DGetShadowRequestsDropped, none)
    // Light budget observability: per-cluster index capacity (8..64), lifetime
    // cluster truncations, and forward-path lights dropped this frame.
    RT_METHOD("SetClusterLightBudget", "void(i64)", Canvas3DSetClusterLightBudget)
    RT_PROP("ClusterOverflowCount", "i64", Canvas3DGetClusterOverflowCount, none)
    RT_PROP("DroppedLightCount", "i64", Canvas3DGetDroppedLightCount, none)
    RT_PROP("FrustumCulledDrawCount", "i64", Canvas3DGetFrustumCulledDrawCount, none)
    RT_PROP("CpuOccludedDrawCount", "i64", Canvas3DGetCpuOccludedDrawCount, none)
    RT_PROP("OcclusionCandidateCount", "i64", Canvas3DGetOcclusionCandidateCount, none)
    RT_PROP("TextureUploadBytes", "i64", Canvas3DGetTextureUploadBytes, none)
    RT_PROP("FrameGpuTimeUs", "i64", Canvas3DGetFrameGpuTimeUs, none)
    RT_PROP("DrawsSubmitted", "i64", Canvas3DGetDrawsSubmitted, none)
    RT_PROP("AabbTransforms", "i64", Canvas3DGetAabbTransforms, none)
    RT_PROP("SortPasses", "i64", Canvas3DGetSortPasses, none)
    RT_PROP("BackendStateChanges", "i64", Canvas3DGetBackendStateChanges, none)
    RT_PROP("TextureUploadPendingBytes", "i64", Canvas3DGetTextureUploadPendingBytes, none)
    RT_PROP("TextureStreamingDemotions", "i64", Canvas3DGetTextureStreamingDemotions, none)
    RT_PROP("BackendDrawCalls", "i64", Canvas3DGetBackendDrawCalls, none)
    // Per-pass CPU ms of the last flushed frame: 0=shadow, 1=main,
    // 2=overlay, 3=backend end-of-frame. See also FrameGpuTimeUs.
    RT_PROP("PassCount", "i64", Canvas3DGetPassCount, none)
    RT_METHOD("PassCpuMs", "f64(i64)", Canvas3DGetPassCpuMs)
    RT_PROP("BackendDroppedDraws", "i64", Canvas3DGetBackendDroppedDraws, none)
    RT_PROP("BackendMeshCacheHits", "i64", Canvas3DGetBackendMeshCacheHits, none)
    RT_PROP("BackendMeshCacheMisses", "i64", Canvas3DGetBackendMeshCacheMisses, none)
    RT_PROP("BackendMeshStreamUploads", "i64", Canvas3DGetBackendMeshStreamUploads, none)
    RT_PROP("BackendTextureFallbackBinds", "i64", Canvas3DGetBackendTextureFallbackBinds, none)
    RT_PROP("BackendPresentPath", "i64", Canvas3DGetBackendPresentPath, none)
    RT_PROP("FrameFinalized", "i1", Canvas3DGetFrameFinalized, none)
    RT_PROP("LightCount", "i64", Canvas3DGetLightCount, none)
    RT_PROP("MaxActiveLights", "i64", Canvas3DGetMaxActiveLights, none)
    RT_PROP("QualityRequested", "i64", Canvas3DGetQualityRequested, none)
    RT_PROP("QualityActive", "i64", Canvas3DGetQualityActive, none)
    RT_PROP("QualityFallback", "i1", Canvas3DGetQualityFallback, none)
    RT_PROP("QualityFallbackReason", "str", Canvas3DGetQualityFallbackReason, none)
    RT_PROP("Wireframe", "i1", none, Canvas3DSetWireframe)
    RT_PROP("IsFullscreen", "i1", Canvas3DIsFullscreen, none)
    RT_METHOD("Clear", "void(f64,f64,f64)", Canvas3DClear)
    RT_METHOD("Resize", "void(i64,i64)", Canvas3DResize)
    RT_METHOD("SetFullscreen", "void(i1)", Canvas3DSetFullscreen)
    RT_METHOD("ToggleFullscreen", "void()", Canvas3DToggleFullscreen)
    RT_METHOD("Begin", "void(obj)", Canvas3DBegin)
    // Secondary camera-space pass for weapon view models: keeps scene color,
    // clears depth, independent FOV (<= 0 keeps the camera FOV). Close with End.
    RT_METHOD("BeginViewModel", "void(obj,f64)", Canvas3DBeginViewModel)
    RT_METHOD("Begin2D", "void()", Canvas3DBegin2D)
    RT_METHOD("BeginOverlay", "void()", Canvas3DBeginOverlay)
    RT_METHOD("EndOverlay", "void()", Canvas3DEndOverlay)
    RT_METHOD("ClearOverlay", "void()", Canvas3DClearOverlay)
    RT_METHOD("DrawRect3D", "void(i64,i64,i64,i64,i64)", Canvas3DDrawRect3D)
    RT_METHOD("DrawText3D", "void(i64,i64,str,i64)", Canvas3DDrawText3D)
    RT_METHOD("DrawImage2D", "void(i64,i64,i64,i64,obj)", Canvas3DDrawImage2D)
    RT_METHOD("PassDrawCount", "i64(i64)", Canvas3DPassDrawCount)
    RT_METHOD("PassInstanceCount", "i64(i64)", Canvas3DPassInstCount)
    RT_METHOD("DrawMesh", "void(obj,obj,obj)", Canvas3DDrawMesh)
    RT_METHOD("DrawMeshWind", "void(obj,obj,obj,f64,f64,f64,f64)", Canvas3DDrawMeshWind)
    RT_METHOD("DrawMeshSkinned", "void(obj,obj,obj,obj)", Canvas3DDrawMeshSkinned)
    RT_METHOD("DrawMeshMorphed", "void(obj,obj,obj,obj)", Canvas3DDrawMeshMorphed)
    RT_METHOD("DrawMeshBlended", "void(obj,obj,obj,obj)", Canvas3DDrawBlended)
    RT_METHOD("End", "void()", Canvas3DEnd)
    RT_METHOD("Flip", "void()", Canvas3DFlip)
    RT_METHOD("Poll", "i64()", Canvas3DPoll)
    RT_METHOD("PollEvent", "i64()", Canvas3DPollEvent)
    RT_METHOD("SetBackfaceCull", "void(i1)", Canvas3DSetBackfaceCull)
    RT_METHOD("SetMaxDeltaTime", "void(i64)", Canvas3DSetMaxDeltaTime)
    RT_METHOD("SetQuality", "void(i64)", Canvas3DSetQuality)
    RT_METHOD("SetInputSource", "void(i64)", Canvas3DSetInputSource)
    RT_METHOD("PushSyntheticKey", "void(i64,i1)", Canvas3DPushSyntheticKey)
    RT_METHOD("PushSyntheticMouse", "void(f64,f64,i64,f64)", Canvas3DPushSyntheticMouse)
    RT_METHOD("ClearSyntheticInput", "void()", Canvas3DClearSyntheticInput)
    RT_METHOD("SetClockSource", "void(i64)", Canvas3DSetClockSource)
    RT_METHOD("SetSyntheticDeltaTimeSec", "void(f64)", Canvas3DSetSyntheticDeltaTimeSec)
    RT_METHOD("AdvanceSyntheticFrame", "void()", Canvas3DAdvanceSyntheticFrame)
    RT_METHOD("SetLight", "void(i64,obj)", Canvas3DSetLight)
    RT_METHOD("ClearLights", "void()", Canvas3DClearLights)
    RT_METHOD("SetDefaultLighting", "void()", Canvas3DSetDefaultLighting)
    RT_METHOD("TrySetClusteredLighting", "i1(i1)", Canvas3DTrySetClusteredLighting)
    RT_PROP("ClusteredLighting", "i1", Canvas3DGetClusteredLighting, Canvas3DSetClusteredLightingProp)
    RT_METHOD("SetAmbient", "void(f64,f64,f64)", Canvas3DSetAmbient)
    RT_PROP("IblEnabled", "i1", Canvas3DGetIblEnabled, Canvas3DSetIblEnabled)
    RT_PROP("IblIntensity", "f64", Canvas3DGetIblIntensity, Canvas3DSetIblIntensity)
    RT_METHOD("DrawLine3D", "void(obj,obj,i64)", Canvas3DDrawLine3D)
    RT_METHOD("DrawPoint3D", "void(obj,i64,i64)", Canvas3DDrawPoint3D)
    RT_METHOD("BackendSupports", "i1(str)", Canvas3DBackendSupports)
    RT_METHOD("SetTextureUploadBudget", "void(i64)", Canvas3DSetTextureUploadBudget)
    RT_METHOD("SetTextureStreaming", "void(i1)", Canvas3DSetTextureStreaming)
    RT_METHOD("SetTextureStreamingBias", "void(f64)", Canvas3DSetTextureStreamingBias)
    RT_METHOD("Screenshot", "obj()", Canvas3DScreenshot)
    RT_METHOD("ScreenshotFinal", "obj()", Canvas3DScreenshotFinal)
    // Allocation-free after the canvas-owned GPU staging buffer has warmed to this size.
    RT_METHOD("TryCopyScreenshotTo", "i1(obj)", Canvas3DTryCopyScreenshotTo)
    RT_METHOD("TryCopyScreenshotFinalTo", "i1(obj)", Canvas3DTryCopyScreenshotFinalTo)
    RT_METHOD("FinalizeFrame", "void()", Canvas3DFinalizeFrame)
    RT_METHOD("SetSkybox", "void(obj)", Canvas3DSetSkybox)
    RT_METHOD("ClearSkybox", "void()", Canvas3DClearSkybox)
    RT_METHOD("SetRenderTarget", "void(obj)", Canvas3DSetRenderTarget)
    RT_METHOD("ResetRenderTarget", "void()", Canvas3DResetRenderTarget)
    RT_METHOD("DrawAABBWire", "void(obj,obj,i64)", Canvas3DDrawAABBWire)
    RT_METHOD("DrawSphereWire", "void(obj,f64,i64)", Canvas3DDrawSphereWire)
    RT_METHOD("DrawDebugRay", "void(obj,obj,f64,i64)", Canvas3DDrawDebugRay)
    RT_METHOD("DrawAxis", "void(obj,f64)", Canvas3DDrawAxis)
    RT_METHOD("SetFog", "void(f64,f64,f64,f64,f64)", Canvas3DSetFog)
    RT_METHOD("ClearFog", "void()", Canvas3DClearFog)
    RT_METHOD("EnableShadows", "void(i64)", Canvas3DEnableShadows)
    RT_METHOD("DisableShadows", "void()", Canvas3DDisableShadows)
    RT_METHOD("SetShadowBias", "void(f64)", Canvas3DSetShadowBias)
    RT_METHOD("SetShadowSlopeBias", "void(f64)", Canvas3DSetShadowSlopeBias)
    RT_METHOD("SetShadowStrength", "void(f64)", Canvas3DSetShadowStrength)
    RT_METHOD("SetShadowQuality", "void(i64)", Canvas3DSetShadowQuality)
    RT_METHOD("SetShadowCascades", "void(i64)", Canvas3DSetShadowCascades)
    // Cap the camera distance covered by directional shadows (<= 0 restores the
    // automatic min(camera far, 300) default). Concentrates shadow-map texels near
    // the camera instead of spreading them across the whole clip range.
    RT_METHOD("SetShadowDistance", "void(f64)", Canvas3DSetShadowDistance)
    RT_PROP("ShadowDistance", "f64", Canvas3DGetShadowDistance, none)
    // Present pacing: vsync defaults on; disabling presents immediately for lowest
    // latency where the backend supports it (BackendSupports("vsync-control")).
    RT_METHOD("SetVSync", "void(i1)", Canvas3DSetVSync)
    RT_PROP("VSync", "i1", Canvas3DGetVSync, none)
    // Render the 3D scene at a reduced resolution and upscale at presentation —
    // the most effective performance lever on fill-rate/CPU-bound scenes. Values
    // >= 1 restore native rendering; reduced scales require
    // BackendSupports("render-scale").
    RT_METHOD("TrySetRenderScale", "i1(f64)", Canvas3DTrySetRenderScale)
    RT_PROP("RenderScale", "f64", Canvas3DGetRenderScale, none)
    RT_METHOD("DrawInstanced", "void(obj)", Canvas3DDrawInstanced)
    RT_METHOD("DrawInstancedSkinned", "void(obj,obj)", Canvas3DDrawInstancedSkinned)
    RT_METHOD("DrawTerrain", "void(obj)", Canvas3DDrawTerrain)
    RT_METHOD("DrawTerrainAt", "void(obj,f64,f64,f64)", Canvas3DDrawTerrainAt)
    RT_METHOD("DrawDecal", "void(obj)", Canvas3DDrawDecal)
    RT_METHOD("DrawSprite3D", "void(obj,obj)", Canvas3DDrawSprite3D)
    RT_METHOD("DrawLensFlare", "void(obj)", Canvas3DDrawLensFlare)
    RT_METHOD("DrawWater", "void(obj,obj)", Canvas3DDrawWater)
    RT_METHOD("DrawVegetation", "void(obj)", Canvas3DDrawVeg)
    RT_METHOD("SetPostFX", "void(obj)", Canvas3DSetPostFX)
    RT_METHOD("DrawRect2D", "void(i64,i64,i64,i64,i64)", Canvas3DDrawRect2D)
    RT_METHOD("DrawRect2DAlpha", "void(i64,i64,i64,i64,i64,f64)", Canvas3DDrawRect2DAlpha)
    RT_METHOD("DrawLine2D", "void(i64,i64,i64,i64,i64,f64)", Canvas3DDrawLine2D)
    RT_METHOD("DrawFrame2D", "void(i64,i64,i64,i64,i64,f64)", Canvas3DDrawFrame2D)
    RT_METHOD("DrawRoundRect2D", "void(i64,i64,i64,i64,i64,i64,f64)", Canvas3DDrawRoundRect2D)
    RT_METHOD("DrawRoundFrame2D", "void(i64,i64,i64,i64,i64,i64,f64)", Canvas3DDrawRoundFrame2D)
    RT_METHOD("DrawText2DScaled", "void(i64,i64,str,i64,f64)", Canvas3DDrawText2DScaled)
    // Anti-aliased text at arbitrary scale (4x box-filtered bitmap font) and
    // 9-slice image draws for HUD chrome.
    // Exponential height fog: pools below baseHeight, combines with distance
    // fog via combined transmittance; ClearFog clears both.
    RT_METHOD("SetHeightFog", "void(f64,f64,f64,f64)", Canvas3DSetHeightFog)
    RT_METHOD("SetHeightFogSun", "void(f64,f64,f64,f64,f64)", Canvas3DSetHeightFogSun)
    RT_METHOD("ClearHeightFog", "void()", Canvas3DClearHeightFog)
    RT_PROP("HeightFogEnabled", "i1", Canvas3DGetHeightFogEnabled, none)
    RT_METHOD("DrawText2DAA", "void(i64,i64,str,i64,f64)", Canvas3DDrawText2DAA)
    RT_METHOD("MeasureText2DAA", "i64(str,f64)", Canvas3DMeasureText2DAA)
    RT_METHOD("DrawImage2DNineSlice", "void(i64,i64,i64,i64,obj,i64,i64,i64,i64)", Canvas3DDrawImage2DNineSlice)
    RT_METHOD("DrawImage2DRegion", "void(i64,i64,i64,i64,obj,i64,i64,i64,i64)", Canvas3DDrawImage2DRegion)
    RT_METHOD("SetClipRect2D", "void(i64,i64,i64,i64)", Canvas3DSetClipRect2D)
    RT_METHOD("ClearClipRect2D", "void()", Canvas3DClearClipRect2D)
    RT_METHOD("MeasureText2D", "i64(str,f64)", Canvas3DMeasureText2D)
    RT_METHOD("DrawCrosshair", "void(i64,i64)", Canvas3DDrawCrosshair)
    RT_METHOD("DrawText2D", "void(i64,i64,str,i64)", Canvas3DDrawText2D)
    RT_METHOD("SetFrustumCulling", "void(i1)", Canvas3DSetFrustumCulling)
    RT_METHOD("SetOcclusionCulling", "void(i1)", Canvas3DSetOcclusionCulling)
RT_CLASS_END()

