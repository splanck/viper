/// @summary Provides Camera 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Camera3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Fov`, `NearPlane`, `EffectiveNearPlane` and operations including `WithHorizontalFov`,
/// `NewOrtho`, `SetHorizontalFov`, `LookAt`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Camera3D", Camera3D, "obj", Camera3DNew)
    RT_PROP("Fov", "f64", Camera3DGetFov, Camera3DSetFov)
    RT_PROP("NearPlane", "f64", Camera3DGetNear, Camera3DSetNear)
    RT_PROP("EffectiveNearPlane", "f64", Camera3DGetEffectiveNear, none)
    RT_PROP("FarPlane", "f64", Camera3DGetFar, Camera3DSetFar)
    RT_PROP("EffectiveFarPlane", "f64", Camera3DGetEffectiveFar, none)
    RT_PROP("Position", "obj<Zanna.Math.Vec3>", Camera3DGetPosition, Camera3DSetPosition)
    RT_PROP("Forward", "obj<Zanna.Math.Vec3>", Camera3DGetForward, none)
    RT_PROP("Right", "obj<Zanna.Math.Vec3>", Camera3DGetRight, none)
    RT_METHOD("WithHorizontalFov", "obj(f64,f64,f64,f64)", Camera3DNewHorizontalFov)
    RT_METHOD("NewOrtho", "obj(f64,f64,f64,f64)", Camera3DNewOrtho)
    RT_METHOD("SetHorizontalFov", "void(f64)", Camera3DSetHorizontalFov)
    RT_METHOD("LookAt", "void(obj,obj,obj)", Camera3DLookAt)
    RT_METHOD("Orbit", "void(obj,f64,f64,f64)", Camera3DOrbit)
    RT_METHOD("ScreenToRay", "obj(i64,i64,i64,i64)", Camera3DScreenToRay)
    RT_METHOD("WorldToScreen", "obj(obj<Zanna.Math.Vec3>,i64,i64)", Camera3DWorldToScreen)
    RT_METHOD("ScreenToRayOrigin", "obj(i64,i64,i64,i64)", Camera3DScreenToRayOrigin)
    RT_METHOD("Shake", "void(f64,f64,f64)", Camera3DShake)
    RT_METHOD("SmoothFollow", "void(obj,f64,f64,f64,f64)", Camera3DSmoothFollow)
    RT_METHOD("SmoothLookAt", "void(obj,f64,f64)", Camera3DSmoothLookAt)
    RT_PROP("IsOrtho", "i1", Camera3DIsOrtho, none)
    RT_METHOD("FirstPersonInit", "void()", Camera3DFPSInit)
    RT_METHOD("FirstPersonUpdate", "void(f64,f64,f64,f64,f64,f64,f64)", Camera3DFPSUpdate)
    RT_PROP("Yaw", "f64", Camera3DGetYaw, Camera3DSetYaw)
    RT_PROP("Pitch", "f64", Camera3DGetPitch, Camera3DSetPitch)
RT_CLASS_END()

