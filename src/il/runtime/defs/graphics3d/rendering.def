RT_FUNC(Material3DSetDepthBias,    rt_material3d_set_depth_bias,    "Zanna.Graphics3D.Material3D.SetDepthBias",    "void(obj,f64,f64)")
RT_FUNC(Mesh3DCalcTangents,       rt_mesh3d_calc_tangents,         "Zanna.Graphics3D.Mesh3D.CalculateTangents",        "void(obj)")

/// @summary Provides Material 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.Material3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Alpha`, `Metallic`, `Roughness` and operations including `FromColor`, `Textured`, `PBR`,
/// `SetColor`.
RT_CLASS_BEGIN("Zanna.Graphics3D.Material3D", Material3D, "obj", Material3DNew)
    RT_PROP("Alpha", "f64", Material3DGetAlpha, Material3DSetAlpha)
    RT_PROP("Metallic", "f64", Material3DGetMetallic, Material3DSetMetallic)
    RT_PROP("Roughness", "f64", Material3DGetRoughness, Material3DSetRoughness)
    RT_PROP("AmbientOcclusion", "f64", Material3DGetAO, Material3DSetAO)
    RT_PROP("EmissiveIntensity", "f64", Material3DGetEmissiveIntensity, Material3DSetEmissiveIntensity)
    RT_PROP("NormalScale", "f64", Material3DGetNormalScale, Material3DSetNormalScale)
    RT_PROP("Anisotropy", "i64", Material3DGetAnisotropy, Material3DSetAnisotropy)
    RT_PROP("AlphaMode", "i64", Material3DGetAlphaMode, Material3DSetAlphaMode)
    RT_PROP("ShadowMode", "i64", Material3DGetShadowMode, Material3DSetShadowMode)
    RT_PROP("DoubleSided", "i1", Material3DGetDoubleSided, Material3DSetDoubleSided)
    RT_PROP("Color", "obj<Zanna.Math.Vec3>", Material3DGetColor, none)
    RT_PROP("Unlit", "i1", Material3DGetUnlit, none)
    RT_PROP("ShadingModel", "i64", Material3DGetShading, none)
    RT_PROP("HasTexture", "i1", Material3DGetHasTexture, none)
    RT_PROP("HasNormalMap", "i1", Material3DGetHasNormalMap, none)
    RT_PROP("HasSpecularMap", "i1", Material3DGetHasSpecularMap, none)
    RT_PROP("HasEmissiveMap", "i1", Material3DGetHasEmissiveMap, none)
    RT_PROP("HasMetallicRoughnessMap", "i1", Material3DGetHasMetallicRoughnessMap, none)
    RT_PROP("HasAmbientOcclusionMap", "i1", Material3DGetHasAmbientOcclusionMap, none)
    RT_PROP("HasEnvMap", "i1", Material3DGetHasEnvMap, none)
    RT_METHOD("FromColor", "obj(f64,f64,f64)", Material3DFromColor)
    RT_METHOD("Textured", "obj(obj)", Material3DTextured)
    RT_METHOD("PBR", "obj(f64,f64,f64)", Material3DPBR)
    RT_METHOD("SetColor", "void(f64,f64,f64)", Material3DSetColor)
    RT_METHOD("SetTexture", "void(obj)", Material3DSetTexture)
    // Live render-target binding: the material samples the target's last
    // completed frame; refreshes automatically when a frame into it ends.
    RT_METHOD("SetAlbedoRenderTarget", "void(obj)", Material3DSetAlbedoRenderTarget)
    RT_METHOD("ClearAlbedoRenderTarget", "void()", Material3DClearAlbedoRenderTarget)
    RT_METHOD("SetEmissiveRenderTarget", "void(obj)", Material3DSetEmissiveRenderTarget)
    RT_METHOD("SetAlbedoMap", "void(obj)", Material3DSetAlbedoMap)
    RT_METHOD("SetShininess", "void(f64)", Material3DSetShininess)
    RT_METHOD("SetUnlit", "void(i1)", Material3DSetUnlit)
    RT_METHOD("Clone", "obj()", Material3DClone)
    RT_METHOD("MakeInstance", "obj()", Material3DMakeInstance)
    RT_METHOD("SetNormalMap", "void(obj)", Material3DSetNormalMap)
    RT_METHOD("SetMetallicRoughnessMap", "void(obj)", Material3DSetMetallicRoughnessMap)
    RT_METHOD("SetAmbientOcclusionMap", "void(obj)", Material3DSetAOMap)
    RT_METHOD("SetLightmap", "void(obj)", Material3DSetLightmap)
    RT_PROP("HasLightmap", "i1", Material3DGetHasLightmap, none)
    RT_METHOD("SetSpecularMap", "void(obj)", Material3DSetSpecularMap)
    RT_METHOD("SetEmissiveMap", "void(obj)", Material3DSetEmissiveMap)
    RT_METHOD("SetEmissiveColor", "void(f64,f64,f64)", Material3DSetEmissiveColor)
    RT_METHOD("SetShadingModel", "void(i64)", Material3DSetShading)
    RT_METHOD("SetCustomParam", "void(i64,f64)", Material3DSetCustom)
    RT_METHOD("SetEnvMap", "void(obj)", Material3DSetEnvMap)
    RT_METHOD("SetDepthBias", "void(f64,f64)", Material3DSetDepthBias)
    RT_PROP("Reflectivity", "f64", Material3DGetReflectivity, Material3DSetReflectivity)
    RT_PROP("SsrEnabled", "i1", Material3DGetSsrEnabled, Material3DSetSsrEnabled)
RT_CLASS_END()

