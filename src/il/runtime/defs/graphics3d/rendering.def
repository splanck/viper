/// @summary Provides Texture Asset 3D functionality for 3D rendering and scene applications.
/// @details
/// `Zanna.Graphics3D.TextureAsset3D` exposes a registry-backed runtime surface without requiring
/// callers to construct the class directly. Its public surface exposes properties such as
/// `Width`, `Height`, `MipCount`, degradation and residency telemetry, and permissive/strict KTX2
/// load operations. Strict loaders reject inputs that would require checker substitution.
RT_CLASS_BEGIN("Zanna.Graphics3D.TextureAsset3D", TextureAsset3D, "obj", none)
    RT_PROP("Width", "i64", TextureAsset3DGetWidth, none)
    RT_PROP("Height", "i64", TextureAsset3DGetHeight, none)
    RT_PROP("MipCount", "i64", TextureAsset3DGetMipCount, none)
    RT_PROP("Format", "str", TextureAsset3DGetFormat, none)
    RT_PROP("Compressed", "i1", TextureAsset3DGetCompressed, none)
    RT_PROP("Degraded", "i1", TextureAsset3DGetDegraded, none)
    RT_PROP("DegradedReason", "str", TextureAsset3DGetDegradedReason, none)
    RT_PROP("ResidentMipStart", "i64", TextureAsset3DGetResidentMipStart, none)
    RT_PROP("ResidentMipCount", "i64", TextureAsset3DGetResidentMipCount, none)
    RT_PROP("ResidentBytes", "i64", TextureAsset3DGetResidentBytes, none)
    RT_PROP("RetainedBytes", "i64", TextureAsset3DGetRetainedBytes, none)
    RT_METHOD("LoadKtx2", "obj<Zanna.Graphics3D.TextureAsset3D>(str)", TextureAsset3DLoadKTX2)
    RT_METHOD("LoadKtx2Asset", "obj<Zanna.Graphics3D.TextureAsset3D>(str)", TextureAsset3DLoadKTX2Asset)
    RT_METHOD("LoadKtx2Strict", "obj<Zanna.Graphics3D.TextureAsset3D>(str)", TextureAsset3DLoadKTX2Strict)
    RT_METHOD("LoadKtx2AssetStrict", "obj<Zanna.Graphics3D.TextureAsset3D>(str)", TextureAsset3DLoadKTX2AssetStrict)
    RT_METHOD("SetResidentMipRange", "void(i64,i64)", TextureAsset3DSetResidentMipRange)
RT_CLASS_END()

