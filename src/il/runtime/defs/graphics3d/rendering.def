/// @summary Provides Render Target 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Zanna.Graphics3D.RenderTarget3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `IsHdr`, `Width`, `Height` and operations including `NewHdr`, `AsPixels`, `CopyTo`.
RT_CLASS_BEGIN("Zanna.Graphics3D.RenderTarget3D", RenderTarget3D, "obj", RenderTarget3DNew)
    RT_PROP("IsHdr", "i1", RenderTarget3DGetIsHdr, none)
    RT_PROP("Width", "i64", RenderTarget3DGetWidth, none)
    RT_PROP("Height", "i64", RenderTarget3DGetHeight, none)
    RT_METHOD("NewHdr", "obj(i64,i64)", RenderTarget3DNewHdr)
    RT_METHOD("AsPixels", "obj()", RenderTarget3DAsPixels)
    // Allocation-free readback into an existing same-size Pixels.
    RT_METHOD("CopyTo", "void(obj)", RenderTarget3DCopyTo)
RT_CLASS_END()

