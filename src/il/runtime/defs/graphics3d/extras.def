/// @summary Provides Transform 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Viper.Graphics3D.Transform3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Position`, `Rotation`, `Scale` and operations including `SetPosition`, `SetEuler`, `SetScale`,
/// `Translate`.
RT_CLASS_BEGIN("Viper.Graphics3D.Transform3D", Transform3D, "obj", Transform3DNew)
    RT_PROP("Position", "obj<Viper.Math.Vec3>", Transform3DGetPosition, none)
    RT_PROP("Rotation", "obj<Viper.Math.Quat>", Transform3DGetRotation, Transform3DSetRotation)
    RT_PROP("Scale", "obj<Viper.Math.Vec3>", Transform3DGetScale, none)
    RT_PROP("Matrix", "obj<Viper.Math.Mat4>", Transform3DGetMatrix, none)
    RT_METHOD("SetPosition", "void(f64,f64,f64)", Transform3DSetPosition)
    RT_METHOD("SetEuler", "void(f64,f64,f64)", Transform3DSetEuler)
    RT_METHOD("SetScale", "void(f64,f64,f64)", Transform3DSetScale)
    RT_METHOD("Translate", "void(obj)", Transform3DTranslate)
    RT_METHOD("Rotate", "void(obj,f64)", Transform3DRotate)
    RT_METHOD("LookAt", "void(obj,obj)", Transform3DLookAt)
RT_CLASS_END()

