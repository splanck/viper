/// @summary Provides Anim Controller 3D functionality for 3D rendering and scene applications.
/// @details
/// Create `Viper.Graphics3D.AnimController3D` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `CurrentState`, `PreviousState`, `IsTransitioning` and operations including `AddState`,
/// `AddTransition`, `Play`, `Crossfade`.
RT_CLASS_BEGIN("Viper.Graphics3D.AnimController3D", AnimController3D, "obj", AnimController3DNew)
    RT_PROP("CurrentState", "str", AnimController3DCurrentState, none)
    RT_PROP("PreviousState", "str", AnimController3DPreviousState, none)
    RT_PROP("IsTransitioning", "i1", AnimController3DIsTransitioning, none)
    RT_PROP("StateCount", "i64", AnimController3DStateCount, none)
    RT_PROP("StateTime", "f64", AnimController3DStateTime, none)
    RT_PROP("RootMotionDelta", "obj<Viper.Math.Vec3>", AnimController3DGetRootMotion, none)
    RT_METHOD("AddState", "i64(str,obj)", AnimController3DAddState)
    RT_METHOD("AddTransition", "i1(str,str,f64)", AnimController3DAddTransition)
    RT_METHOD("Play", "i1(str)", AnimController3DPlay)
    RT_METHOD("Crossfade", "i1(str,f64)", AnimController3DCrossfade)
    RT_METHOD("Stop", "void()", AnimController3DStop)
    RT_METHOD("Update", "void(f64)", AnimController3DUpdate)
    RT_METHOD("IsStatePlaying", "i1(str)", AnimController3DIsStatePlaying)
    RT_METHOD("SetStateSpeed", "void(str,f64)", AnimController3DSetStateSpeed)
    RT_METHOD("SetStateLooping", "void(str,i1)", AnimController3DSetStateLooping)
    RT_METHOD("SetAnimationLOD", "void(f64,f64)", AnimController3DSetAnimationLOD)
    RT_METHOD("SetBoneLOD", "void(i64)", AnimController3DSetBoneLOD)
    RT_METHOD("SetBlendTree", "i1(obj)", AnimController3DSetBlendTree)
    RT_METHOD("SetIKSolver", "i1(obj)", AnimController3DSetIKSolver)
    RT_METHOD("AddEvent", "void(str,f64,str)", AnimController3DAddEvent)
    RT_METHOD("PollEvent", "str()", AnimController3DPollEvent)
    RT_METHOD("SetRootMotionBone", "void(i64)", AnimController3DSetRootMotionBone)
    RT_METHOD("ConsumeRootMotion", "obj<Viper.Math.Vec3>()", AnimController3DConsumeRootMotion)
    RT_METHOD("SetLayerWeight", "void(i64,f64)", AnimController3DSetLayerWeight)
    RT_METHOD("SetLayerMask", "void(i64,i64)", AnimController3DSetLayerMask)
    RT_METHOD("PlayLayer", "i1(i64,str)", AnimController3DPlayLayer)
    RT_METHOD("PlayLayerAdditive", "i1(i64,str)", AnimController3DPlayLayerAdditive)
    RT_METHOD("CrossfadeLayer", "i1(i64,str,f64)", AnimController3DCrossfadeLayer)
    RT_METHOD("CrossfadeLayerAdditive", "i1(i64,str,f64)", AnimController3DCrossfadeLayerAdditive)
    RT_METHOD("StopLayer", "void(i64)", AnimController3DStopLayer)
    RT_METHOD("GetBoneMatrix", "obj<Viper.Math.Mat4>(i64)", AnimController3DGetBoneMatrix)
RT_CLASS_END()

