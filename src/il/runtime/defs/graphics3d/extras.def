/// @summary Provides IK Solver 3D functionality for 3D rendering and scene applications.
/// @details
/// `Viper.Graphics3D.IKSolver3D` exposes a registry-backed runtime surface without requiring
/// callers to construct the class directly. Its public surface exposes operations including
/// `TwoBone`, `LookAt`, `FABRIK`, `SetTarget`.
RT_CLASS_BEGIN("Viper.Graphics3D.IKSolver3D", IKSolver3D, "obj", none)
    RT_METHOD("TwoBone", "obj<Viper.Graphics3D.IKSolver3D>(obj,i64,i64,i64)", IKSolver3DTwoBone)
    RT_METHOD("LookAt", "obj<Viper.Graphics3D.IKSolver3D>(obj,i64)", IKSolver3DLookAt)
    RT_METHOD("FABRIK", "obj<Viper.Graphics3D.IKSolver3D>(obj,obj)", IKSolver3DFABRIK)
    RT_METHOD("SetTarget", "void(obj)", IKSolver3DSetTarget)
    RT_METHOD("SetWeight", "void(f64)", IKSolver3DSetWeight)
    RT_METHOD("SetPole", "void(obj)", IKSolver3DSetPole)
    RT_METHOD("SetGroundNormal", "void(obj)", IKSolver3DSetGroundNormal)
    RT_METHOD("Solve", "void()", IKSolver3DSolve)
RT_CLASS_END()

/// @summary Provides Blend Tree 3D functionality for 3D rendering and scene applications.
/// @details
/// `Viper.Graphics3D.BlendTree3D` exposes a registry-backed runtime surface without requiring
/// callers to construct the class directly. Its public surface exposes properties such as
/// `SampleCount`, `BlendMode`, `Blend` and operations including `New1D`, `New2D`, `AddSample`,
/// `SetParam`.
RT_CLASS_BEGIN("Viper.Graphics3D.BlendTree3D", BlendTree3D, "obj", none)
    RT_PROP("SampleCount", "i64", BlendTree3DSampleCount, none)
    RT_METHOD("New1D", "obj<Viper.Graphics3D.BlendTree3D>(obj)", BlendTree3DNew1D)
    RT_METHOD("New2D", "obj<Viper.Graphics3D.BlendTree3D>(obj)", BlendTree3DNew2D)
    RT_METHOD("AddSample", "i64(obj,f64,f64)", BlendTree3DAddSample)
    RT_METHOD("SetParam", "void(f64,f64)", BlendTree3DSetParam)
    RT_METHOD("Update", "void(f64)", BlendTree3DUpdate)
    // 2D weighting mode: 0 = freeform-directional (Delaunay + barycentric,
    // default), 1 = legacy inverse-distance-squared.
    RT_PROP("BlendMode", "i64", BlendTree3DGetBlendMode, BlendTree3DSetBlendMode)
    // Internal AnimBlend3D driven by Update(); exposes per-sample weights.
    RT_PROP("Blend", "obj<Viper.Graphics3D.AnimBlend3D>", BlendTree3DGetBlend, none)
RT_CLASS_END()

