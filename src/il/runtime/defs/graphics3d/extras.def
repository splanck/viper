/// @summary Provides Nav Mesh 3D constants and static operations for 3D rendering and scene applications.
/// @details
/// `Viper.Graphics3D.NavMesh3D` is a static runtime surface and does not require an instance. Its
/// public surface exposes properties such as `TriangleCount`, `OffMeshLinkCount`, `ObstacleCount`
/// and operations including `FindPath`, `FindPathOption`, `SamplePosition`, `IsWalkable`.
RT_CLASS_BEGIN("Viper.Graphics3D.NavMesh3D", NavMesh3D, "none", none)
    RT_PROP("TriangleCount", "i64", NavMesh3DTriCount, none)
    RT_PROP("OffMeshLinkCount", "i64", NavMesh3DOffMeshLinkCount, none)
    RT_PROP("ObstacleCount", "i64", NavMesh3DObstacleCount, none)
    RT_PROP("LastPathCost", "f64", NavMesh3DLastPathCost, none)
    RT_METHOD("FindPath", "obj(obj,obj)", NavMesh3DFindPath)
    RT_METHOD("FindPathOption", "obj<Viper.Option>(obj,obj)", NavMesh3DFindPathOption)
    RT_METHOD("SamplePosition", "obj(obj)", NavMesh3DSamplePosition)
    RT_METHOD("IsWalkable", "i1(obj)", NavMesh3DIsWalkable)
    RT_METHOD("Build", "obj(obj,f64,f64)", NavMesh3DBuild)
    RT_METHOD("Bake", "obj(obj,f64,f64,f64,f64)", NavMesh3DBake)
    RT_METHOD("BakeTiled", "obj(obj,f64,f64,f64,f64,f64)", NavMesh3DBakeTiled)
    RT_METHOD("Export", "i1(obj,str)", NavMesh3DExport)
    RT_METHOD("Import", "obj(str)", NavMesh3DImport)
    RT_METHOD("AddOffMeshLink", "i1(obj,obj,i1)", NavMesh3DAddOffMeshLink)
    RT_METHOD("SetOffMeshLinkMetadata", "i1(i64,str,f64,i64)", NavMesh3DSetOffMeshLinkMetadata)
    RT_METHOD("GetOffMeshLinkKind", "str(i64)", NavMesh3DGetOffMeshLinkKind)
    RT_METHOD("GetOffMeshLinkTraversalCost", "f64(i64)", NavMesh3DGetOffMeshLinkTraversalCost)
    RT_METHOD("GetOffMeshLinkState", "i64(i64)", NavMesh3DGetOffMeshLinkState)
    RT_METHOD("AddObstacle", "i1(obj,obj)", NavMesh3DAddObstacle)
    RT_METHOD("RemoveObstacle", "i1(i64)", NavMesh3DRemoveObstacle)
    RT_METHOD("UpdateObstacle", "i1(i64,obj,obj)", NavMesh3DUpdateObstacle)
    RT_METHOD("SetArea", "i1(obj,obj,str,f64)", NavMesh3DSetArea)
    RT_METHOD("GetArea", "str(obj)", NavMesh3DGetArea)
    RT_METHOD("GetTraversalCost", "f64(obj)", NavMesh3DGetTraversalCost)
    RT_METHOD("RebuildTile", "i1(i64,i64)", NavMesh3DRebuildTile)
    RT_METHOD("SetMaxSlope", "void(f64)", NavMesh3DSetMaxSlope)
    RT_METHOD("SetHeuristicMode", "void(i64)", NavMesh3DSetHeuristicMode)
    RT_PROP("HeuristicMode", "i64", NavMesh3DGetHeuristicMode, none)
    RT_METHOD("DebugDraw", "void(obj)", NavMesh3DDebugDraw)
    // Tile edge length used by O(tile) rebuilds; every Bake auto-tiles.
    RT_PROP("TileSize", "f64", NavMesh3DTileSize, none)
RT_CLASS_END()

