/// @summary Provides Input 3D functionality for Game3D worlds and gameplay systems.
/// @details
/// Create `Viper.Game3D.Input3D` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as
/// `LookSensitivity`, `PadBound`, `PadLookSensitivity` and operations including `Update`, `IsDown`,
/// `Pressed`, `Released`.
RT_CLASS_BEGIN("Viper.Game3D.Input3D", Game3DInput3D, "obj", Game3DInputNew)
    RT_PROP("LookSensitivity", "f64", Game3DInputGetLookSensitivity, Game3DInputSetLookSensitivity)
    RT_METHOD("Update", "void()", Game3DInputUpdate)
    RT_METHOD("IsDown", "i1(i64)", Game3DInputIsDown)
    RT_METHOD("Pressed", "i1(i64)", Game3DInputPressed)
    RT_METHOD("Released", "i1(i64)", Game3DInputReleased)
    RT_METHOD("MouseDelta", "obj()", Game3DInputMouseDelta)
    RT_METHOD("MouseButton", "i1(i64)", Game3DInputMouseButton)
    RT_METHOD("MousePressed", "i1(i64)", Game3DInputMousePressed)
    RT_METHOD("WheelY", "f64()", Game3DInputWheelY)
    RT_METHOD("MoveAxis", "obj()", Game3DInputMoveAxis)
    RT_METHOD("LookAxis", "obj()", Game3DInputLookAxis)
    RT_METHOD("CaptureMouse", "void()", Game3DInputCaptureMouse)
    RT_METHOD("ReleaseMouse", "void()", Game3DInputReleaseMouse)
    // Raw relative mouse-look (capture + unbounded sub-pixel deltas).
    RT_METHOD("SetRelativeLook", "void(i1)", Game3DInputSetRelativeLook)
    // Gamepad merge: bound pad's sticks feed MoveAxis/LookAxis (-1 unbinds).
    RT_METHOD("BindPad", "void(i64)", Game3DInputBindPad)
    RT_PROP("PadBound", "i64", Game3DInputGetPadBound, none)
    RT_PROP("PadLookSensitivity", "f64", Game3DInputGetPadLookSens, Game3DInputSetPadLookSens)
RT_CLASS_END()

