/// @summary Provides Body Def functionality for Game3D worlds and gameplay systems.
/// @details
/// `Viper.Game3D.BodyDef` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes properties such as `Shape`, `Mass`,
/// `Friction` and operations including `Box`, `Sphere`, `Capsule`, `StaticBox`.
RT_CLASS_BEGIN("Viper.Game3D.BodyDef", Game3DBodyDef, "obj", none)
    RT_PROP("Shape", "i64", Game3DBodyDefGetShape, Game3DBodyDefSetShape)
    RT_PROP("Mass", "f64", Game3DBodyDefGetMass, Game3DBodyDefSetMass)
    RT_PROP("Friction", "f64", Game3DBodyDefGetFriction, Game3DBodyDefSetFriction)
    RT_PROP("Restitution", "f64", Game3DBodyDefGetRestitution, Game3DBodyDefSetRestitution)
    RT_PROP("IsStatic", "i1", Game3DBodyDefGetStatic, Game3DBodyDefSetStatic)
    RT_PROP("IsKinematic", "i1", Game3DBodyDefGetKinematic, Game3DBodyDefSetKinematic)
    RT_PROP("IsTrigger", "i1", Game3DBodyDefGetTrigger, Game3DBodyDefSetTrigger)
    RT_PROP("UseCcd", "i1", Game3DBodyDefGetUseCcd, Game3DBodyDefSetUseCcd)
    RT_PROP("Layer", "i64", Game3DBodyDefGetLayer, Game3DBodyDefSetLayer)
    RT_PROP("Mask", "obj<Viper.Game3D.LayerMask>", Game3DBodyDefGetMask, Game3DBodyDefSetMask)
    RT_PROP("SyncMode", "i64", Game3DBodyDefGetSync, Game3DBodyDefSetSync)
    RT_METHOD("Box", "obj(f64,f64,f64,f64)", Game3DBodyDefBox)
    RT_METHOD("Sphere", "obj(f64,f64)", Game3DBodyDefSphere)
    RT_METHOD("Capsule", "obj(f64,f64,f64)", Game3DBodyDefCapsule)
    RT_METHOD("StaticBox", "obj(f64,f64,f64)", Game3DBodyDefStaticBox)
    RT_METHOD("StaticPlane", "obj(f64)", Game3DBodyDefStaticPlane)
    RT_METHOD("WithLayer", "obj(i64)", Game3DBodyDefWithLayer)
    RT_METHOD("WithMask", "obj(obj)", Game3DBodyDefWithMask)
    RT_METHOD("AsTrigger", "obj()", Game3DBodyDefAsTrigger)
    RT_METHOD("WithSync", "obj(i64)", Game3DBodyDefWithSync)
RT_CLASS_END()

