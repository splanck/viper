/// @summary Coordinates a Game3D world, scene, camera, physics, streaming, and gameplay systems.
/// @details
/// Create `Zanna.Game3D.World3D` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as
/// `Canvas`, `Camera`, `Scene` and operations including `AddCloth`, `RemoveCloth`, `SaveState`,
/// `LoadState`.
RT_CLASS_BEGIN("Zanna.Game3D.World3D", Game3DWorld3D, "obj", Game3DWorldNew)
    RT_PROP("Canvas", "obj<Zanna.Graphics3D.Canvas3D>", Game3DWorldGetCanvas, none)
    RT_PROP("Camera", "obj<Zanna.Graphics3D.Camera3D>", Game3DWorldGetCamera, none)
    RT_PROP("Scene", "obj<Zanna.Graphics3D.SceneGraph>", Game3DWorldGetScene, none)
    RT_PROP("Physics", "obj<Zanna.Graphics3D.PhysicsWorld3D>", Game3DWorldGetPhysics, none)
    RT_PROP("Input", "obj<Zanna.Game3D.Input3D>", Game3DWorldGetInput, none)
    RT_PROP("Audio", "obj<Zanna.Game3D.Sound3D>", Game3DWorldGetAudio, none)
    RT_METHOD("AddCloth", "void(obj<Zanna.Graphics3D.Cloth3D>)", Game3DWorldAddCloth)
    RT_METHOD("RemoveCloth", "void(obj<Zanna.Graphics3D.Cloth3D>)", Game3DWorldRemoveCloth)
    RT_METHOD("SaveState", "i1(str,str)", Game3DWorldSaveState)
    RT_METHOD("LoadState", "i1(str,str)", Game3DWorldLoadState)
    RT_METHOD("GetPersistentAlive", "i1(str)", Game3DWorldPersistAlive)
    RT_METHOD("GetPersistentPosition", "obj<Zanna.Math.Vec3>(str)", Game3DWorldPersistPosition)
    RT_METHOD("ReportSound", "void(obj<Zanna.Math.Vec3>,f64,i64)", Game3DWorldReportSound)
    RT_METHOD("SetHitchThresholdMs", "void(f64)", Game3DWorldSetHitchThresh)
    RT_METHOD("HitchCount", "i64()", Game3DWorldHitchCount)
    RT_METHOD("HitchFrame", "i64(i64)", Game3DWorldHitchFrame)
    RT_METHOD("HitchSource", "i64(i64)", Game3DWorldHitchSource)
    RT_METHOD("HitchMs", "f64(i64)", Game3DWorldHitchMs)
    RT_METHOD("ClearHitches", "void()", Game3DWorldClearHitches)
    RT_PROP("Effects", "obj<Zanna.Game3D.EffectRegistry3D>", Game3DWorldGetEffects, none)
    RT_PROP("Stream", "obj<Zanna.Game3D.WorldStream3D>", Game3DWorldGetStream, none)
    RT_PROP("DeltaTime", "f64", Game3DWorldGetDt, none)
    RT_PROP("Elapsed", "f64", Game3DWorldGetElapsed, none)
    RT_PROP("Frame", "i64", Game3DWorldGetFrame, none)
    RT_PROP("DroppedFixedSteps", "i64", Game3DWorldGetDroppedFixedSteps, none)
    RT_PROP("FixedInterpolationAlpha", "f64", Game3DWorldGetFixedInterpolationAlpha, none)
    // Built-in fixed-step render interpolation: entity poses blend between the previous
    // and current fixed steps during rendering (restored afterward), so 60 Hz physics
    // renders smoothly on faster displays without per-entity manual blending.
    RT_PROP("RenderInterpolation", "i1", Game3DWorldGetRenderInterpolation, Game3DWorldSetRenderInterpolation)
    RT_PROP("EntityCount", "i64", Game3DWorldGetEntityCount, none)
    RT_PROP("BodyCount", "i64", Game3DWorldGetBodyCount, none)
    RT_PROP("DrawCount", "i64", Game3DWorldGetDrawCount, none)
    RT_PROP("VisibleNodeCount", "i64", Game3DWorldGetVisibleNodeCount, none)
    RT_PROP("OccludedDrawCount", "i64", Game3DWorldGetOccludedDrawCount, none)
    RT_PROP("FrustumCulledDrawCount", "i64", Game3DWorldGetFrustumCulledDrawCount, none)
    RT_PROP("CpuOccludedDrawCount", "i64", Game3DWorldGetCpuOccludedDrawCount, none)
    RT_PROP("StreamResidentBytes", "i64", Game3DWorldGetStreamResidentBytes, none)
    RT_PROP("WorkerCount", "i64", Game3DWorldGetWorkerCount, none)
    RT_PROP("JobsEnabled", "i1", Game3DWorldGetJobsEnabled, none)
    RT_PROP("FloatingOrigin", "i1", Game3DWorldGetFloatingOrigin, Game3DWorldSetFloatingOrigin)
    RT_PROP("WorldOrigin", "obj<Zanna.Math.Vec3>", Game3DWorldGetWorldOrigin, none)
    RT_METHOD("NewWithCamera", "obj(str,i64,i64,f64,f64,f64)", Game3DWorldNewWithCamera)
    RT_METHOD("NewWithHorizontalCamera", "obj(str,i64,i64,f64,f64,f64)", Game3DWorldNewWithHorizontalCamera)
    RT_METHOD("WithCamera", "obj(str,i64,i64,f64,f64,f64)", Game3DWorldWithCamera)
    RT_METHOD("WithHorizontalCamera", "obj(str,i64,i64,f64,f64,f64)", Game3DWorldWithHorizontalCamera)
    // Fullscreen-at-creation: desktop resolution, no windowed flash.
    RT_METHOD("NewFullscreen", "obj(str)", Game3DWorldNewFullscreen)
    RT_METHOD("NewFullscreenWithHorizontalCamera", "obj(str,f64,f64,f64)", Game3DWorldNewFullscreenHorizontal)
    RT_METHOD("Destroy", "void()", Game3DWorldDestroy)
    RT_METHOD("IsDestroyed", "i1()", Game3DWorldIsDestroyed)
    RT_METHOD("SetWorkerCount", "void(i64)", Game3DWorldSetWorkerCount)
    RT_METHOD("SetOriginRebaseThreshold", "void(f64)", Game3DWorldSetOriginRebaseThreshold)
    RT_METHOD("RebaseOrigin", "void(f64,f64,f64)", Game3DWorldRebaseOrigin)
    RT_METHOD("Spawn", "obj(obj)", Game3DWorldSpawn)
    RT_METHOD("SpawnHeightfieldCollider", "obj(obj,f64,f64,f64,f64,f64,f64)", Game3DWorldSpawnHeightfieldCollider)
    RT_METHOD("Despawn", "void(obj)", Game3DWorldDespawn)
    RT_METHOD("FindNode", "obj<Zanna.Option>(str)", Game3DWorldFindNodeOption)
    RT_METHOD("FindEntity", "obj<Zanna.Option>(str)", Game3DWorldFindEntityOption)
    RT_METHOD("SetCameraController", "void(obj)", Game3DWorldSetCameraCtrl)
    RT_METHOD("LookAt", "void(obj)", Game3DWorldLookAt)
    RT_METHOD("OnResize", "void(i64,i64)", Game3DWorldOnResize)
    RT_METHOD("SetAmbient", "void(f64,f64,f64)", Game3DWorldSetAmbient)
    RT_PROP("IblEnabled", "i1", Game3DWorldGetIblEnabled, Game3DWorldSetIblEnabled)
    RT_PROP("IblIntensity", "f64", Game3DWorldGetIblIntensity, Game3DWorldSetIblIntensity)
    RT_METHOD("AddLight", "void(i64,obj)", Game3DWorldAddLight)
    RT_METHOD("ClearLights", "void()", Game3DWorldClearLights)
    RT_METHOD("SetSkybox", "void(obj)", Game3DWorldSetSkybox)
    RT_METHOD("SetFog", "void(f64,f64,f64,f64,f64)", Game3DWorldSetFog)
    RT_METHOD("SetQuality", "void(i64)", Game3DWorldSetQuality)
    RT_METHOD("BakeNavMesh", "obj<Zanna.Graphics3D.NavMesh3D>(f64,f64,f64,f64)", Game3DWorldBakeNavMesh)
    RT_METHOD("BakeTiledNavMesh", "obj<Zanna.Graphics3D.NavMesh3D>(f64,f64,f64,f64,f64)", Game3DWorldBakeTiledNavMesh)
    RT_METHOD("CollisionEventCount", "i64(i64)", Game3DWorldCollisionCount)
    RT_METHOD("CollisionEvent", "obj<Zanna.Game3D.Collision3DEvent>(i64,i64)", Game3DWorldCollisionEvent)
    RT_PROP("TimeScale", "f64", Game3DWorldGetTimeScale, Game3DWorldSetTimeScale)
    RT_PROP("IsPaused", "i1", Game3DWorldGetPaused, Game3DWorldSetPaused)
    RT_PROP("UnscaledDeltaTime", "f64", Game3DWorldGetUnscaledDt, none)
    RT_PROP("UnscaledElapsed", "f64", Game3DWorldGetUnscaledElapsed, none)
    RT_METHOD("HitStop", "void(f64)", Game3DWorldHitStop)
    RT_METHOD("SetDofFocus", "i1(f64)", Game3DWorldSetDofFocus)
    RT_METHOD("PlayTimeline", "void(obj<Zanna.Game3D.Timeline3D>)", Game3DWorldPlayTimeline)
    RT_PROP("ActiveTimeline", "obj<Zanna.Game3D.Timeline3D>", Game3DWorldActiveTimeline, none)
    RT_METHOD("StopTimeline", "void()", Game3DWorldStopTimeline)
    RT_METHOD("HitEventCount", "i64()", Game3DWorldHitEventCount)
    RT_METHOD("HitEvent", "obj<Zanna.Game3D.HitEvent3D>(i64)", Game3DWorldHitEvent)
    RT_METHOD("ClearHitEvents", "void()", Game3DWorldClearHitEvents)
    RT_METHOD("DamageEventCount", "i64()", Game3DWorldDamageEventCount)
    RT_METHOD("DamageEvent", "obj<Zanna.Game3D.DamageEvent3D>(i64)", Game3DWorldDamageEvent)
    RT_METHOD("ClearCollisionEvents", "void()", Game3DWorldClearCollisions)
    RT_METHOD("SetGravity", "void(f64,f64,f64)", Game3DWorldSetGravity)
    RT_METHOD("Run", "void(obj)", Game3DWorldRun)
    RT_METHOD("RunWithOverlay", "void(obj,obj)", Game3DWorldRunWithOverlay)
    RT_METHOD("RunFixed", "void(f64,obj)", Game3DWorldRunFixed)
    RT_METHOD("RunFixedWithOverlay", "void(f64,obj,obj)", Game3DWorldRunFixedWithOverlay)
    RT_METHOD("RunFrames", "void(i64,f64,obj)", Game3DWorldRunFrames)
    RT_METHOD("RunFramesOnly", "void(i64,f64)", Game3DWorldRunFramesOnly)
    RT_METHOD("Update", "i1()", Game3DWorldTick)
    RT_METHOD("StepSimulation", "void(f64)", Game3DWorldStepSimulation)
    RT_METHOD("BeginFrame", "void()", Game3DWorldBeginFrame)
    RT_METHOD("DrawScene", "void()", Game3DWorldDrawScene)
    RT_METHOD("DrawEffects", "void()", Game3DWorldDrawEffects)
    RT_METHOD("EndScene", "void()", Game3DWorldEndScene)
    RT_METHOD("DrawOverlay", "void(obj)", Game3DWorldDrawOverlay)
    RT_METHOD("CaptureFinalFrame", "obj()", Game3DWorldCaptureFinal)
    RT_METHOD("Present", "void()", Game3DWorldPresent)
RT_CLASS_END()

