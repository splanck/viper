// Zanna.GUI.Font - font loading
/// @summary Provides font loading.
/// @details
/// `Zanna.GUI.Font` exposes managed file fonts plus zero-dependency regular and bold system UI
/// roles. System-role construction returns `Zanna.Result`, preserves the requested logical-point
/// size across DPI changes, and falls back to Zanna's embedded font when host faces are absent.
/// `Destroy` is idempotent and uses presentation-generation retirement while retained GUI
/// surfaces still reference the backing face. Legacy path loading remains available.
RT_CLASS_BEGIN("Zanna.GUI.Font", GuiFont, "obj", none)
    RT_METHOD("Load", "obj(str)", GuiFontLoad)
    RT_METHOD("LoadSystemUi", "obj<Zanna.Result>(f64)", GuiFontLoadSystemUi)
    RT_METHOD("LoadSystemUiBold", "obj<Zanna.Result>(f64)", GuiFontLoadSystemUiBold)
    RT_METHOD("GetLogicalSize", "f64(obj)", GuiFontGetLogicalSize)
    RT_METHOD("Destroy", "void()", GuiFontDestroy)
RT_CLASS_END()

// Zanna.GUI.Widget - base widget class
/// @summary Provides safe widget geometry, hierarchy, identity, state, and accessibility APIs.
/// @details
/// `Zanna.GUI.Widget` is the common borrowed handle for controls created by concrete GUI classes.
/// New layout and bounds operations use logical units while legacy integer getters retain their
/// framebuffer-unit compatibility contract. Hierarchy lookup returns explicit `Zanna.Option`
/// values; removing or clearing children detaches without destroying them and transfers ownership
/// back to the caller. IDs are stable for the live widget, names are copied UTF-8, and invalid or
/// stale handles follow the documented empty/no-op contract.
RT_CLASS_BEGIN("Zanna.GUI.Widget", GuiWidget, "obj", none)
    RT_METHOD("Destroy", "void()", GuiWidgetDestroy)
    RT_METHOD("SetVisible", "void(i1)", GuiWidgetSetVisible)
    RT_METHOD("SetEnabled", "void(i1)", GuiWidgetSetEnabled)
    RT_METHOD("SetSize", "void(i64,i64)", GuiWidgetSetSize)
    RT_METHOD("SetPreferredSize", "void(f64,f64)", GuiWidgetSetPreferredSize)
    RT_METHOD("SetMaxSize", "void(f64,f64)", GuiWidgetSetMaxSize)
    RT_METHOD("SetMinSize", "void(f64,f64)", GuiWidgetSetMinSize)
    RT_METHOD("GetMinWidth", "f64()", GuiWidgetGetMinWidth)
    RT_METHOD("GetMinHeight", "f64()", GuiWidgetGetMinHeight)
    RT_METHOD("SetFlex", "void(f64)", GuiWidgetSetFlex)
    RT_METHOD("SetPosition", "void(i64,i64)", GuiWidgetSetPosition)
    RT_METHOD("AddChild", "void(obj)", GuiWidgetAddChild)
    RT_METHOD("GetParentOption", "obj<Zanna.Option>()", GuiWidgetGetParentOption)
    RT_METHOD("GetChildCount", "i64()", GuiWidgetGetChildCount)
    RT_METHOD("GetChildAtOption", "obj<Zanna.Option>(i64)", GuiWidgetGetChildAtOption)
    RT_METHOD("RemoveChild", "i1(obj)", GuiWidgetRemoveChild)
    RT_METHOD("ClearChildren", "void()", GuiWidgetClearChildren)
    RT_METHOD("IsHovered", "i1()", GuiWidgetIsHovered)
    RT_METHOD("IsPressed", "i1()", GuiWidgetIsPressed)
    RT_METHOD("IsFocused", "i1()", GuiWidgetIsFocused)
    RT_METHOD("Focus", "void()", GuiWidgetFocus)
    RT_METHOD("WasClicked", "i1()", GuiWidgetWasClicked)
// BINDING-003: read accessors
    RT_METHOD("IsVisible", "i1()", GuiWidgetIsVisible)
    RT_METHOD("IsEnabled", "i1()", GuiWidgetIsEnabled)
    RT_METHOD("GetWidth", "i64()", GuiWidgetGetWidth)
    RT_METHOD("GetHeight", "i64()", GuiWidgetGetHeight)
    RT_METHOD("GetX", "i64()", GuiWidgetGetX)
    RT_METHOD("GetY", "i64()", GuiWidgetGetY)
    RT_METHOD("GetFlex", "f64()", GuiWidgetGetFlex)
    RT_METHOD("GetLogicalX", "f64()", GuiWidgetGetLogicalX)
    RT_METHOD("GetLogicalY", "f64()", GuiWidgetGetLogicalY)
    RT_METHOD("GetLogicalWidth", "f64()", GuiWidgetGetLogicalWidth)
    RT_METHOD("GetLogicalHeight", "f64()", GuiWidgetGetLogicalHeight)
    RT_METHOD("GetScreenX", "f64()", GuiWidgetGetScreenX)
    RT_METHOD("GetScreenY", "f64()", GuiWidgetGetScreenY)
    RT_METHOD("GetScreenWidth", "f64()", GuiWidgetGetScreenWidth)
    RT_METHOD("GetScreenHeight", "f64()", GuiWidgetGetScreenHeight)
    RT_METHOD("SetMargin", "void(i64)", GuiWidgetSetMargin)
    RT_METHOD("SetPadding", "void(f64)", GuiWidgetSetPadding)
    RT_METHOD("SetPaddingEdges", "void(f64,f64,f64,f64)", GuiWidgetSetPaddingEdges)
    RT_METHOD("SetMarginEdges", "void(f64,f64,f64,f64)", GuiWidgetSetMarginEdges)
    RT_METHOD("SetTabIndex", "void(i64)", GuiWidgetSetTabIndex)
    RT_METHOD("SetCursor", "void(i64)", GuiWidgetSetCursor)
    RT_METHOD("ResetCursor", "void()", GuiWidgetResetCursor)
    RT_METHOD("SetName", "void(str)", GuiWidgetSetName)
    RT_METHOD("GetName", "str()", GuiWidgetGetName)
