// Zanna.GUI.ScrollView - scrollable container widget
/// @summary Provides scrollable container widget.
/// @details
/// Create `Zanna.GUI.ScrollView` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes operations including
/// `SetScroll`, `SetContentSize`, descendant `ScrollTo`, `GetScrollX`, and `GetScrollY`.
/// `ScrollTo` retains one live-ID-guarded request through the next layout pass,
/// allowing an enclosing pane to be restored and its descendant revealed by one command.
RT_CLASS_BEGIN("Zanna.GUI.ScrollView", GuiScrollView, "obj", GuiScrollViewNew, "Zanna.GUI.Widget")
    RT_METHOD("SetScroll", "void(f64,f64)", GuiScrollViewSetScroll)
    RT_METHOD("SetContentSize", "void(f64,f64)", GuiScrollViewSetContentSize)
    RT_METHOD("ScrollTo", "void(obj)", GuiScrollViewScrollTo)
    RT_METHOD("GetScrollX", "f64()", GuiScrollViewGetScrollX)
    RT_METHOD("GetScrollY", "f64()", GuiScrollViewGetScrollY)
RT_CLASS_END()

// Zanna.GUI.TreeView - tree view widget
/// @summary Provides tree view widget.
/// @details
/// Create `Zanna.GUI.TreeView` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes operations including
/// retained-node Ctrl/Command and Shift multi-selection, byte-exact selected data in structural
/// preorder, `AddNode`, `RemoveNode`, `Toggle`, `ScrollTo`, lazy-child request polling, and
/// activation payload lookup. `SetDragDropMode(1)` preserves container-only INTO drops;
/// `SetDragDropMode(2)` exposes application-directed BEFORE/INTO/AFTER row regions whose numeric
/// values are 0/1/2. Node-returning event payloads use `Zanna.Option`, remain independent from
/// their compatibility `Was*` edges, and preserve the tree-owned lifetime contract.
RT_CLASS_BEGIN("Zanna.GUI.TreeView", GuiTreeView, "obj", GuiTreeViewNew, "Zanna.GUI.Widget")
    RT_METHOD("AddNode", "obj(obj,str)", GuiTreeViewAddNode)
    RT_METHOD("RemoveNode", "void(obj)", GuiTreeViewRemoveNode)
    RT_METHOD("Clear", "void()", GuiTreeViewClear)
    RT_METHOD("PruneRetiredNodes", "void()", GuiTreeViewPruneRetiredNodes)
    RT_METHOD("Expand", "void(obj)", GuiTreeViewExpand)
    RT_METHOD("Collapse", "void(obj)", GuiTreeViewCollapse)
    RT_METHOD("Toggle", "void(obj)", GuiTreeViewToggle)
    RT_METHOD("Select", "void(obj)", GuiTreeViewSelect)
    RT_METHOD("SetMultiSelect", "void(i1)", GuiTreeViewSetMultiSelect)
    RT_METHOD("ScrollTo", "void(obj)", GuiTreeViewScrollTo)
    RT_METHOD("SetFont", "void(obj,f64)", GuiTreeViewSetFont)
    RT_METHOD("GetSelected", "obj()", GuiTreeViewGetSelected)
    RT_METHOD("GetSelectedData", "seq<str>()", GuiTreeViewGetSelectedData)
    RT_METHOD("GetNodeAt", "obj(i64,i64)", GuiTreeViewGetNodeAt)
    RT_METHOD("WasSelectionChanged", "i1()", GuiTreeViewWasSelectionChanged)
    RT_METHOD("WasChanged", "i1()", GuiTreeViewWasChanged)
    RT_METHOD("WasActivated", "i1()", GuiTreeViewWasActivated)
    RT_METHOD("WasLoadChildrenRequested", "i1()", GuiTreeViewWasLoadChildrenRequested)
    RT_METHOD("GetLoadRequestedNodeOption", "obj<Zanna.Option>()", GuiTreeViewGetLoadRequestedNodeOption)
    RT_METHOD("GetActivatedNodeOption", "obj<Zanna.Option>()", GuiTreeViewGetActivatedNodeOption)
    RT_METHOD("GetRevision", "i64()", GuiTreeViewGetRevision)
    RT_METHOD("SetDragDropEnabled", "void(i1)", GuiTreeViewSetDragDropEnabled)
    RT_METHOD("SetDragDropMode", "void(i64)", GuiTreeViewSetDragDropMode)
    RT_METHOD("WasDropReceived", "i1()", GuiTreeViewWasDropReceived)
    RT_METHOD("GetDropSourceData", "str()", GuiTreeViewGetDropSourceData)
