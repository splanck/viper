/// `Viper.Sound.Audio` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes properties such as `RenderCalls`,
/// `MixerLockMisses`, `BackendWriteCalls` and operations including `IsAvailable`, `Init`,
/// `Shutdown`, `SetMasterVolume`.
RT_CLASS_BEGIN("Viper.Audio.Mixer", Audio, "obj", none)
    RT_METHOD("IsAvailable", "i1()", AudioIsAvailable)
    RT_METHOD("Init", "i64()", AudioInit)
    RT_METHOD("Shutdown", "void()", AudioShutdown)
    RT_METHOD("SetMasterVolume", "void(i64)", AudioSetMasterVolume)
    RT_METHOD("GetMasterVolume", "i64()", AudioGetMasterVolume)
    RT_METHOD("PauseAll", "void()", AudioPauseAll)
    RT_METHOD("ResumeAll", "void()", AudioResumeAll)
    RT_METHOD("Update", "void()", AudioUpdate)
    RT_METHOD("StopAllSounds", "void()", AudioStopAllSounds)
    RT_PROP("RenderCalls", "i64", AudioGetRenderCalls, none)
    RT_PROP("MixerLockMisses", "i64", AudioGetMixerLockMisses, none)
    RT_PROP("BackendWriteCalls", "i64", AudioGetBackendWriteCalls, none)
    RT_PROP("BackendPartialWrites", "i64", AudioGetBackendPartialWrites, none)
    RT_PROP("BackendWaits", "i64", AudioGetBackendWaits, none)
    RT_PROP("BackendXruns", "i64", AudioGetBackendXruns, none)
    RT_PROP("BackendRecoveries", "i64", AudioGetBackendRecoveries, none)
    RT_PROP("BackendWriteFailures", "i64", AudioGetBackendWriteFailures, none)
    // Mix groups
    RT_METHOD("SetGroupVolume", "void(i64,i64)", AudioSetGroupVolume)
    RT_METHOD("GetGroupVolume", "i64(i64)", AudioGetGroupVolume)
    RT_METHOD("RegisterGroup", "i64(str)", AudioRegisterGroup)
    RT_METHOD("FindGroup", "obj<Viper.Option>(str)", AudioFindGroupOption)
    RT_METHOD("SetGroupVolumeNamed", "void(str,i64)", AudioSetGroupNamed)
    RT_METHOD("GetGroupVolumeNamed", "i64(str)", AudioGetGroupNamed)
    RT_METHOD("GroupName", "str(i64)", AudioGroupName)
    RT_METHOD("GroupAddLowpass", "i64(i64,f64,f64)", SndGroupAddLowpass)
    RT_METHOD("GroupAddHighpass", "i64(i64,f64,f64)", SndGroupAddHighpass)
    RT_METHOD("GroupAddPeaking", "i64(i64,f64,f64,f64)", SndGroupAddPeaking)
    RT_METHOD("GroupAddDelay", "i64(i64,f64,f64,f64)", SndGroupAddDelay)
    RT_METHOD("GroupAddReverb", "i64(i64,f64,f64,f64)", SndGroupAddReverb)
    RT_METHOD("GroupSetReverb", "void(i64,i64,f64,f64,f64)", SndGroupSetReverb)
    RT_METHOD("GroupSetFxBypass", "void(i64,i64,i1)", SndGroupFxBypass)
    RT_METHOD("GroupRemoveFx", "void(i64,i64)", SndGroupRemoveFx)
    RT_METHOD("GroupClearFx", "void(i64)", SndGroupClearFx)
    // Sidechain ducking: while triggerGroup is audible, targetGroup's gain
    // eases toward (1 - amount) over attackSec and recovers over releaseSec.
    // amount <= 0 removes the rule. Groups are resolved/registered by name.
    RT_METHOD("SetGroupDucking", "void(str,str,f64,f64,f64)", AudioSetGroupDucking)
    RT_PROP("IsCrossfading", "i1", MusicIsCrossfading, none)
RT_CLASS_END()

// Viper.Sound.Sound - sound effect playback
/// @summary Provides sound effect playback.
/// @details
/// `Viper.Sound.Sound` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `LoadAsset`,
/// `Play`, `Play`, `Play`.
RT_CLASS_BEGIN("Viper.Audio.Sound", Sound, "obj", none)
    RT_METHOD("LoadAsset", "obj<Viper.Audio.Sound>(str)", SoundLoadAsset)
    RT_METHOD("Play", "i64()", SoundPlay)
    RT_METHOD("Play", "i64(i64,i64)", SoundPlayEx)
    // PlayEx plus a playback-rate (pitch) multiplier (0.25–4.0; 1.0 = native).
    RT_METHOD("Play", "i64(i64,i64,f64)", SoundPlayEx2)
    RT_METHOD("PlayLoop", "i64(i64,i64)", SoundPlayLoop)
    RT_METHOD("Destroy", "void()", SoundDestroy)
    // Group-aware playback
    RT_METHOD("PlayGroup", "i64(i64)", SoundPlayGroup)
    RT_METHOD("PlayGroup", "i64(i64,i64,i64)", SoundPlayExGroup)
    RT_METHOD("PlayLoopGroup", "i64(i64,i64,i64)", SoundPlayLoopGroup)
RT_CLASS_END()

// Viper.Sound.Voice - voice control for playing sounds (static class)
/// @summary Provides voice control for playing sounds.
/// @details
/// `Viper.Sound.Voice` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Stop`,
/// `SetVolume`, `SetPan`, `IsPlaying`.
RT_CLASS_BEGIN("Viper.Audio.Voice", Voice, "obj", none)
    RT_METHOD("Stop", "void(i64)", VoiceStop)
    RT_METHOD("SetVolume", "void(i64,i64)", VoiceSetVolume)
    RT_METHOD("SetPan", "void(i64,i64)", VoiceSetPan)
    RT_METHOD("IsPlaying", "i1(i64)", VoiceIsPlaying)
    // Playback-rate multiplier (0.25–4.0; 1.0 = native). Resampled with a
    // fractional cursor, so pitch and duration both scale.
    RT_METHOD("SetPitch", "void(i64,f64)", VoiceSetPitch)
    RT_METHOD("GetPitch", "f64(i64)", VoiceGetPitch)
    // Direct lowpass cutoff in Hz (<= 0 disables); composes with occlusion.
    RT_METHOD("SetLowpass", "void(i64,f64)", VoiceSetLowpass)
    // Occlusion 0 (open) .. 1 (fully occluded): perceptual lowpass sweep plus
    // up to -6 dB attenuation, smoothed ~80 ms in the mixer.
    RT_METHOD("SetOcclusion", "void(i64,f64)", VoiceSetOcclusion)
    RT_METHOD("EnableMetering", "void(i64,i1)", VoiceEnableMetering)
    RT_METHOD("GetLevel", "f64(i64)", VoiceGetLevel)
RT_CLASS_END()

// Viper.Sound.Music - music streaming playback
/// @summary Provides music streaming playback.
/// @details
/// `Viper.Sound.Music` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes properties such as `Volume`,
/// `Position`, `Duration` and operations including `Play`, `Stop`, `Pause`, `Resume`.
RT_CLASS_BEGIN("Viper.Audio.Music", Music, "obj", none)
    RT_PROP("Volume", "i64", MusicGetVolume, MusicSetVolume)
    RT_PROP("Position", "i64", MusicGetPosition, none)
    RT_PROP("Duration", "i64", MusicGetDuration, none)
    RT_METHOD("Play", "void(i64)", MusicPlay)
    RT_METHOD("Stop", "void()", MusicStop)
    RT_METHOD("Pause", "void()", MusicPause)
    RT_METHOD("Resume", "void()", MusicResume)
    RT_METHOD("SetLoop", "void(i1)", MusicSetLoop)
    RT_METHOD("IsPlaying", "i1()", MusicIsPlaying)
    RT_METHOD("Seek", "void(i64)", MusicSeek)
    RT_METHOD("Destroy", "void()", MusicDestroy)
    RT_METHOD("CrossfadeTo", "void(obj<Viper.Audio.Music>,i64)", MusicCrossfadeTo)
RT_CLASS_END()

