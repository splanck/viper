// Viper.GUI.App - application framework
/// @summary Owns a GUI application window, event loop, root widget, and rendering lifecycle.
/// @details
/// Create `Viper.GUI.App` values through its registered constructor and use the returned object
/// with the instance members below. Its public surface exposes properties such as `ShouldClose`,
/// `Root` and operations including `Poll`, `PollWait`, `Render`, `SetFont`.
RT_CLASS_BEGIN("Viper.GUI.App", GuiApp, "obj", GuiAppNew)
    RT_PROP("ShouldClose", "i1", GuiAppShouldClose, none)
    RT_PROP("Root", "obj<Viper.GUI.Widget>", GuiAppGetRoot, none)
    RT_METHOD("Poll",             "void()",         GuiAppPoll)
    RT_METHOD("PollWait",         "i1(i64)",        GuiAppPollWait)
    RT_METHOD("Render",           "void()",         GuiAppRender)
