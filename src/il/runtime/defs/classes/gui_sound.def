// File: src/il/runtime/defs/classes/gui_sound.def
// Purpose: GUI and sound runtime class declarations.
// Key invariants:
//   - Included in declaration order by src/il/runtime/runtime.def.
//   - Class blocks remain balanced within this fragment.
// Ownership/Lifetime:
//   - Declarative registry data is consumed by rtgen and X-macro tests.
//   - Generated string storage has process lifetime.
// Links: src/il/runtime/runtime.def,
//        src/tools/rtgen/rtgen.cpp,
//        docs/adr/0163-stable-multiselect-and-row-aware-treeview-editing.md,
//        docs/adr/0165-scrollview-descendant-reveal.md,
//        docs/adr/0167-spinner-mixed-value-state.md
//
//===----------------------------------------------------------------------===//

// GUI WIDGET CLASSES
//=============================================================================

// Zanna.GUI.System - GUI capability discovery
/// @summary Reports whether GUI support is available in the current runtime build.
/// @details
/// `Zanna.GUI.System` is a side-effect-free static capability surface. Querying it never opens a
/// display connection or creates a window; use `Zanna.GUI.App.TryNew` to report backend-specific
/// construction failure.
RT_CLASS_BEGIN("Zanna.GUI.System", GuiSystem, "none", none)
    RT_METHOD("IsAvailable", "i1()", GuiSystemIsAvailable)
    RT_METHOD("GetUnavailableReason", "str()", GuiSystemGetUnavailableReason)
RT_CLASS_END()

// Zanna.GUI.App - application framework
/// @summary Owns a GUI application window, event loop, root widget, and rendering lifecycle.
/// @details
/// Create `Zanna.GUI.App` values through its registered constructor and use the returned object
/// with the instance members below. `RunFrame` integrates polling, scheduling, damage rendering,
/// and presentation; `RunFrameWithDelta` supplies deterministic test time. `GetNextDeadlineMs`
/// allows efficient waits, while the legacy `Poll`, `PollWait`, and `Render` calls remain intact.
RT_CLASS_BEGIN("Zanna.GUI.App", GuiApp, "obj", GuiAppNew)
    RT_METHOD("TryNew", "obj<Zanna.Result>(str,i64,i64)", GuiAppTryNew)
    RT_PROP("ShouldClose", "i1", GuiAppShouldClose, none)
    RT_PROP("Root", "obj<Zanna.GUI.Widget>", GuiAppGetRoot, none)
