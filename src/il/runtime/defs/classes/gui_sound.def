    RT_METHOD("GetTitle",         "str()",          GuiAppGetTitle)
    RT_METHOD("SetSize",          "void(i64,i64)",  GuiAppSetSize)
    RT_METHOD("WasCloseRequested","i1()",          GuiAppWasCloseRequested)
    RT_METHOD("IsFocused",        "i1()",          GuiAppIsFocused)
