    RT_METHOD("WasDropped", "i1()", WidgetWasDropped)
    RT_METHOD("GetDropType", "str()", WidgetGetDropType)
    RT_METHOD("GetDropData", "str()", WidgetGetDropData)
RT_CLASS_END()

