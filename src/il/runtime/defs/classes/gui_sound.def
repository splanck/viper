    RT_METHOD("FindByIdOption", "obj<Zanna.Option>(i64)", GuiWidgetFindByIdOption)
    RT_METHOD("FindByNameOption", "obj<Zanna.Option>(str)", GuiWidgetFindByNameOption)
    RT_METHOD("HitTest", "i1(f64,f64)", GuiWidgetHitTest)
    RT_METHOD("InvalidatePaint", "void()", GuiWidgetInvalidatePaint)
    RT_METHOD("InvalidateLayout", "void()", GuiWidgetInvalidateLayout)
    RT_METHOD("SetAccessibleRole", "void(i64)", GuiWidgetSetAccessibleRole)
    RT_METHOD("GetAccessibleRole", "i64()", GuiWidgetGetAccessibleRole)
    RT_METHOD("SetAccessibleName", "void(str)", GuiWidgetSetAccessibleName)
    RT_METHOD("GetAccessibleName", "str()", GuiWidgetGetAccessibleName)
    RT_METHOD("SetAccessibleDescription", "void(str)", GuiWidgetSetAccessibleDescription)
    RT_METHOD("GetAccessibleDescription", "str()", GuiWidgetGetAccessibleDescription)
