/// @summary Provides Playlist functionality for audio playback and synthesis.
/// @details
/// Create `Viper.Sound.Playlist` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as `Count`,
/// `Current`, `IsPlaying` and operations including `Add`, `Insert`, `Remove`, `Clear`.
RT_CLASS_BEGIN("Viper.Audio.Playlist", Playlist, "obj", PlaylistNew)
    // Track management
    RT_METHOD("Add", "void(str)", PlaylistAdd)
    RT_METHOD("Insert", "void(i64,str)", PlaylistInsert)
    RT_METHOD("Remove", "void(i64)", PlaylistRemove)
    RT_METHOD("Clear", "void()", PlaylistClear)
    RT_METHOD("Get", "str(i64)", PlaylistGet)
    RT_PROP("Count", "i64", PlaylistLen, none)
    // Playback control
    RT_METHOD("Play", "void()", PlaylistPlay)
    RT_METHOD("Pause", "void()", PlaylistPause)
    RT_METHOD("Stop", "void()", PlaylistStop)
    RT_METHOD("Next", "void()", PlaylistNext)
    RT_METHOD("Previous", "void()", PlaylistPrev)
    RT_METHOD("Jump", "void(i64)", PlaylistJump)
    RT_METHOD("Update", "void()", PlaylistUpdate)
    // State properties
    RT_PROP("Current", "i64", PlaylistGetCurrent, none)
    RT_PROP("IsPlaying", "i1", PlaylistIsPlaying, none)
    RT_PROP("IsPaused", "i1", PlaylistIsPaused, none)
    RT_PROP("Volume", "i64", PlaylistGetVolume, PlaylistSetVolume)
    // Mode settings
    RT_PROP("Shuffle", "i1", PlaylistGetShuffle, PlaylistSetShuffle)
    RT_PROP("Repeat", "i64", PlaylistGetRepeat, PlaylistSetRepeat)
    RT_PROP("Crossfade", "i64", PlaylistGetCrossfade, PlaylistSetCrossfade)
RT_CLASS_END()

