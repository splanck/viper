    RT_METHOD("PollWait", "i1(i64)", GuiAppPollWait)
    RT_METHOD("Render", "void()", GuiAppRender)
    RT_METHOD("RunFrame", "i1()", GuiAppRunFrame)
    RT_METHOD("RunFrameWithDelta", "i1(f64)", GuiAppRunFrameWithDelta)
    RT_METHOD("GetNextDeadlineMs", "i64()", GuiAppGetNextDeadlineMs)
    RT_METHOD("MakeCurrent", "void()", GuiAppMakeCurrent)
    RT_METHOD("SetFont", "void(obj,f64)", GuiAppSetFont)
    RT_METHOD("Destroy", "void()", GuiAppDestroy)
    RT_METHOD("GetWidth", "i64()", GuiAppGetWidth)
    RT_METHOD("GetHeight", "i64()", GuiAppGetHeight)
    RT_METHOD("GetScale", "f64()", GuiAppGetScale)
    RT_METHOD("GetLogicalWidth", "i64()", GuiAppGetLogicalWidth)
    RT_METHOD("GetLogicalHeight", "i64()", GuiAppGetLogicalHeight)
    RT_METHOD("ToLogical", "i64(i64)", GuiAppToLogical)
    RT_METHOD("ToPhysical", "i64(i64)", GuiAppToPhysical)
    RT_METHOD("SetUiScale", "void(f64)", GuiAppSetUiScale)
    RT_METHOD("SetSmoothScroll", "void(i1)", GuiAppSetSmoothScroll)
    RT_METHOD("GetSmoothScroll", "i1()", GuiAppGetSmoothScroll)
    RT_METHOD("GetUiScale", "f64()", GuiAppGetUiScale)
    RT_METHOD("GetEffectiveScale", "f64()", GuiAppGetEffectiveScale)
    RT_METHOD("SetWheelSpeed", "void(f64)", GuiAppSetWheelSpeed)
    RT_METHOD("GetWheelSpeed", "f64()", GuiAppGetWheelSpeed)
    RT_METHOD("GetX", "i64()", GuiAppGetX)
