// Zanna.GUI.TextInput - text input field widget
/// @summary Provides text input field widget.
/// @details
/// Create `Zanna.GUI.TextInput` values through its registered constructor and use the returned
/// object with the instance members below. Text positions and limits use Unicode extended
/// grapheme clusters so user-perceived characters are never split. The editor supports selection,
/// one-step-per-edit undo/redo, password/read-only/multiline modes, independent change and submit
/// edges, monotonic revisions, and observable native IME preedit without exposing mutable buffers.
RT_CLASS_BEGIN("Zanna.GUI.TextInput", GuiTextInput, "obj", GuiTextInputNew, "Zanna.GUI.Widget")
    RT_PROP("Text", "str", GuiTextInputGetText, none)
    RT_METHOD("SetText", "void(str)", GuiTextInputSetText)
    RT_METHOD("SetPlaceholder", "void(str)", GuiTextInputSetPlaceholder)
    RT_METHOD("SetFont", "void(obj,f64)", GuiTextInputSetFont)
    RT_METHOD("SetMaxLength", "void(i64)", GuiTextInputSetMaxLength)
    RT_METHOD("GetMaxLength", "i64()", GuiTextInputGetMaxLength)
    RT_METHOD("SetPassword", "void(i1)", GuiTextInputSetPassword)
    RT_METHOD("IsPassword", "i1()", GuiTextInputIsPassword)
    RT_METHOD("SetReadOnly", "void(i1)", GuiTextInputSetReadOnly)
    RT_METHOD("IsReadOnly", "i1()", GuiTextInputIsReadOnly)
    RT_METHOD("SetMultiline", "void(i1)", GuiTextInputSetMultiline)
    RT_METHOD("IsMultiline", "i1()", GuiTextInputIsMultiline)
    RT_METHOD("SetCursor", "void(i64)", GuiTextInputSetCursor)
    RT_METHOD("GetCursor", "i64()", GuiTextInputGetCursor)
    RT_METHOD("SelectRange", "void(i64,i64)", GuiTextInputSelectRange)
    RT_METHOD("ClearSelection", "void()", GuiTextInputClearSelection)
    RT_METHOD("GetSelectionStart", "i64()", GuiTextInputGetSelectionStart)
    RT_METHOD("GetSelectionEnd", "i64()", GuiTextInputGetSelectionEnd)
    RT_METHOD("GetSelectedText", "str()", GuiTextInputGetSelectedText)
    RT_METHOD("InsertText", "i1(str)", GuiTextInputInsertText)
    RT_METHOD("DeleteSelection", "i1()", GuiTextInputDeleteSelection)
    RT_METHOD("Undo", "i1()", GuiTextInputUndo)
