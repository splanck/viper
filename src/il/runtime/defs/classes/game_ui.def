// Viper.ObjectPool - Efficient object reuse via free list
/// @summary Provides Object Pool functionality for game applications.
/// @details
/// Create `Viper.Game.ObjectPool` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as
/// `Capacity`, `ActiveCount`, `FreeCount` and operations including `Acquire`, `Release`,
/// `IsActive`, `Clear`.
RT_CLASS_BEGIN("Viper.Game.ObjectPool", ObjectPool, "obj", ObjPoolNew)
    RT_PROP("Capacity", "i64", ObjPoolCapacity, none)
    RT_PROP("ActiveCount", "i64", ObjPoolActiveCount, none)
    RT_PROP("FreeCount", "i64", ObjPoolFreeCount, none)
    RT_PROP("IsFull", "i1", ObjPoolIsFull, none)
    RT_PROP("IsEmpty", "i1", ObjPoolIsEmpty, none)
    RT_METHOD("Acquire", "i64()", ObjPoolAcquire)
    RT_METHOD("Release", "i1(i64)", ObjPoolRelease)
    RT_METHOD("IsActive", "i1(i64)", ObjPoolIsActive)
    RT_METHOD("Clear", "void()", ObjPoolClear)
    RT_METHOD("FirstActive", "i64()", ObjPoolFirstActive)
    RT_METHOD("NextActive", "i64(i64)", ObjPoolNextActive)
    RT_METHOD("SetData", "i1(i64,i64)", ObjPoolSetData)
    RT_METHOD("GetData", "i64(i64)", ObjPoolGetData)
RT_CLASS_END()

