RT_FUNC(ResultErrStr,       rt_result_err_str,         "Viper.Result.ErrStr",       "obj(str)")
RT_FUNC(ResultIsOk,         rt_result_is_ok,           "Viper.Result.get_IsOk",     "i1(obj)")
RT_FUNC(ResultIsErr,        rt_result_is_err,          "Viper.Result.get_IsErr",    "i1(obj)")
