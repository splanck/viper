// Zanna.Threads.ConcurrentQueue - thread-safe FIFO queue
/// @summary Provides thread-safe FIFO queue.
/// @details
/// Create `Zanna.Threads.ConcurrentQueue` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `IsEmpty`, `IsClosed`, `Count` and operations including `Clear`, `Close`, `Pop`, `PopFor`.
RT_CLASS_BEGIN("Zanna.Threads.ConcurrentQueue", ConcurrentQueue, "obj", ConcQueueNew)
    RT_PROP("IsEmpty", "i1", ConcQueueIsEmpty, none)
    RT_PROP("IsClosed", "i1", ConcQueueIsClosed, none)
    RT_PROP("Count", "i64", ConcQueueLen, none)
    RT_METHOD("Clear", "void()", ConcQueueClear)
    RT_METHOD("Close", "void()", ConcQueueClose)
    RT_METHOD("Pop", "obj()", ConcQueueDequeue)
    RT_METHOD("PopFor", "obj(i64)", ConcQueueDequeueTimeout)
    RT_METHOD("Push", "void(obj)", ConcQueueEnqueue)
    RT_METHOD("Peek", "obj()", ConcQueuePeek)
    RT_METHOD("TryPop", "obj<Zanna.Option>()", ConcQueueTryDequeueOption)
RT_CLASS_END()

