// Zanna.Time.Clock - basic timing utilities (sleep, ticks)
/// @summary Provides blocking sleep and elapsed-time clock readings.
/// @details Sleep clamps negative values to zero and values above the 32-bit millisecond limit.
/// Tick epochs and physical resolution are unspecified. POSIX prefers a monotonic clock but falls
/// back to adjustable realtime if that query fails; all-source failure returns zero.
RT_CLASS_BEGIN("Zanna.Time.Clock", Clock, "obj", none)
    RT_METHOD("Sleep", "void(i64)", ClockSleep)
    RT_METHOD("NowMs", "i64()", ClockTicks)
    RT_METHOD("NowMicros", "i64()", ClockTicksUs)
RT_CLASS_END()

// Zanna.Time.Countdown - interval timing with expiration
/// @summary Tracks a pausable millisecond interval until expiration.
/// @details New instances start stopped; non-positive intervals clamp to zero. Elapsed time keeps
/// increasing after expiration while running. `Wait` starts a stopped instance, sleeps in bounded
/// chunks until expiration, and leaves it running. Instances are not thread-safe.
RT_CLASS_BEGIN("Zanna.Time.Countdown", Countdown, "obj", CountdownNew)
    RT_PROP("Elapsed", "i64", CountdownElapsed, none)
    RT_PROP("Remaining", "i64", CountdownRemaining, none)
    RT_PROP("IsExpired", "i1", CountdownExpired, none)
    RT_PROP("Interval", "i64", CountdownInterval, CountdownSetInterval)
    RT_PROP("IsRunning", "i1", CountdownIsRunning, none)
    RT_METHOD("Start", "void()", CountdownStart)
    RT_METHOD("Stop", "void()", CountdownStop)
    RT_METHOD("Reset", "void()", CountdownReset)
    RT_METHOD("Wait", "void()", CountdownWait)
RT_CLASS_END()

