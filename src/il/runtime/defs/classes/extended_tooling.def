RT_FUNC(LazySeqDropWhile,      rt_lazyseq_w_drop_while,   "Viper.Functional.LazySeq.DropWhile",       "obj<Viper.Functional.LazySeq>(obj,obj)")
RT_FUNC(LazySeqFind,           rt_lazyseq_w_find,         "Viper.Functional.LazySeq.Find",            "obj(obj,obj)")
RT_FUNC(LazySeqFindOption,     rt_lazyseq_w_find_option,  "Viper.Functional.LazySeq.FindOption",      "obj<Viper.Option>(obj,obj)")
RT_FUNC(LazySeqAny,            rt_lazyseq_w_any,          "Viper.Functional.LazySeq.Any",             "i1(obj,obj)")
