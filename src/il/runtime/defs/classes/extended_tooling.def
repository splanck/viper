// Deque aliases

/// @summary Provides Deque functionality for collection-oriented programs.
/// @details
/// Create `Viper.Collections.Deque` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as `Count`,
/// `Cap`, `Capacity` and operations including `PushFront`, `PopFront`, `PeekFront`, `PushBack`.
RT_CLASS_BEGIN("Viper.Collections.Deque", Deque, "obj", DequeNew)
    RT_PROP("Count", "i64", DequeLen, none)
    RT_PROP("Cap", "i64", DequeCap, none)
    RT_PROP("Capacity", "i64", DequeCapacity, none)
    RT_PROP("IsEmpty", "i1", DequeIsEmpty, none)
    RT_METHOD("PushFront", "void(obj)", DequePushFront)
    RT_METHOD("PopFront", "obj()", DequePopFront)
    RT_METHOD("PeekFront", "obj()", DequePeekFront)
    RT_METHOD("PushBack", "void(obj)", DequePushBack)
    RT_METHOD("PopBack", "obj()", DequePopBack)
    RT_METHOD("PeekBack", "obj()", DequePeekBack)
    RT_METHOD("Get", "obj(i64)", DequeGet)
    RT_METHOD("Set", "void(i64,obj)", DequeSet)
    RT_METHOD("Clear", "void()", DequeClear)
    RT_METHOD("Has", "i1(obj)", DequeHas)
    RT_METHOD("Reverse", "void()", DequeReverse)
    RT_METHOD("Clone", "obj<Viper.Collections.Deque>()", DequeClone)
    RT_METHOD("ToSeq", "obj<Viper.Collections.Seq>()", DequeToSeq)
    RT_METHOD("TryPopFront", "obj()", DequeTryPopFront)
    RT_METHOD("TryPopBack", "obj()", DequeTryPopBack)
    RT_METHOD("TryPopFrontOption", "obj<Viper.Option>()", DequeTryPopFrontOption)
    RT_METHOD("TryPopBackOption", "obj<Viper.Option>()", DequeTryPopBackOption)
    RT_METHOD("ToList", "obj<Viper.Collections.List>()", DequeToList)
RT_CLASS_END()

