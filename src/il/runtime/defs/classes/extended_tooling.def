RT_FUNC(LazySeqToSeq,          rt_lazyseq_w_to_seq,       "Viper.Functional.LazySeq.ToSeq",           "seq<obj>(obj)")
RT_FUNC(LazySeqToSeqN,         rt_lazyseq_w_to_seq_n,     "Viper.Functional.LazySeq.ToSeqN",          "seq<obj>(obj,i64)")
