RT_CLASS_BEGIN("Zanna.Crypto.SecureRandom", CryptoRand, "obj", none)
    RT_METHOD("Bytes", "obj<Zanna.Collections.Bytes>(i64)", CryptoRandBytes)
    RT_METHOD("Int", "i64(i64,i64)", CryptoRandInt)
RT_CLASS_END()

// Zanna.Crypto.Module - validation-readiness mode and self-test status
/// @summary Provides validation-readiness mode and self-test status.
/// @details
/// `Zanna.Crypto.Module` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including
/// `EnableApprovedModeForProcess`, `DisableApprovedModeForProcess`, `IsApprovedModeForProcess`,
/// `Status`.
RT_CLASS_BEGIN("Zanna.Crypto.Compliance", CryptoModule, "obj", none)
    RT_METHOD("EnableApprovedModeForProcess", "i1()", CryptoModuleEnableApprovedModeForProcess)
    RT_METHOD("DisableApprovedModeForProcess", "void()", CryptoModuleDisableApprovedModeForProcess)
    RT_METHOD("IsApprovedModeForProcess", "i1()", CryptoModuleIsApprovedModeForProcess)
    RT_METHOD("Status", "str()", CryptoModuleStatus)
RT_CLASS_END()

// Zanna.Crypto.Cipher - high-level authenticated encryption
/// @summary Provides high-level authenticated encryption.
/// @details
/// `Zanna.Crypto.Cipher` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Encrypt`,
/// `Decrypt`, `DecryptResult`, `TryDecrypt`.
RT_CLASS_BEGIN("Zanna.Crypto.Cipher", Cipher, "obj", none)
    // Password-based encryption (key derived from password)
    RT_METHOD("Encrypt", "obj<Zanna.Collections.Bytes>(obj,str)", CipherEncrypt)
    RT_METHOD("Decrypt", "obj(obj,str)", CipherDecrypt)
    RT_METHOD("DecryptResult", "obj<Zanna.Result>(obj,str)", CipherDecryptResult)
    RT_METHOD("TryDecrypt", "obj<Zanna.Option>(obj,str)", CipherTryDecrypt)
    RT_METHOD("EncryptAad", "obj<Zanna.Collections.Bytes>(obj,str,obj)", CipherEncryptAAD)
    RT_METHOD("DecryptAad", "obj(obj,str,obj)", CipherDecryptAAD)
    RT_METHOD("DecryptAadResult", "obj<Zanna.Result>(obj,str,obj)", CipherDecryptAADResult)
    RT_METHOD("TryDecryptAad", "obj<Zanna.Option>(obj,str,obj)", CipherTryDecryptAAD)
    // Key-based encryption (uses raw 32-byte key)
    RT_METHOD("EncryptWithKey", "obj<Zanna.Collections.Bytes>(obj,obj)", CipherEncryptWithKey)
    RT_METHOD("DecryptWithKey", "obj(obj,obj)", CipherDecryptWithKey)
    RT_METHOD("DecryptWithKeyResult", "obj<Zanna.Result>(obj,obj)", CipherDecryptWithKeyResult)
    RT_METHOD("TryDecryptWithKey", "obj<Zanna.Option>(obj,obj)", CipherTryDecryptWithKey)
    RT_METHOD("EncryptWithKeyAad", "obj<Zanna.Collections.Bytes>(obj,obj,obj)", CipherEncryptWithKeyAAD)
    RT_METHOD("DecryptWithKeyAad", "obj(obj,obj,obj)", CipherDecryptWithKeyAAD)
    RT_METHOD("DecryptWithKeyAadResult", "obj<Zanna.Result>(obj,obj,obj)", CipherDecryptWithKeyAADResult)
    RT_METHOD("TryDecryptWithKeyAad", "obj<Zanna.Option>(obj,obj,obj)", CipherTryDecryptWithKeyAAD)
    // Key utilities
    RT_METHOD("GenerateKey", "obj<Zanna.Collections.Bytes>()", CipherGenerateKey)
    RT_METHOD("DeriveKey", "obj(str,obj)", CipherDeriveKey)
RT_CLASS_END()

// Zanna.Crypto.Tls - TLS 1.3 secure connections
/// @summary Provides TLS 1.3 secure connections.
/// @details
/// `Zanna.Crypto.Tls` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes properties such as `Host`, `Port`,
/// `NegotiatedAlpn` and operations including `Connect`, `ConnectResult`, `ConnectFor`,
/// `ConnectForResult`.
RT_CLASS_BEGIN("Zanna.Crypto.Tls", Tls, "obj", none)
    // Static constructors
    RT_METHOD("Connect", "obj(str,i64)", TlsConnect)
    RT_METHOD("ConnectResult", "obj<Zanna.Result>(str,i64)", TlsConnectResult)
    RT_METHOD("ConnectFor", "obj(str,i64,i64)", TlsConnectFor)
    RT_METHOD("ConnectForResult", "obj<Zanna.Result>(str,i64,i64)", TlsConnectForResult)
    RT_METHOD("ConnectOptions", "obj(str,i64,str,str,i1,i64)", TlsConnectOptions)
    RT_METHOD("ConnectOptionsResult", "obj<Zanna.Result>(str,i64,str,str,i1,i64)", TlsConnectOptionsResult)
    // Properties
    RT_PROP("Host", "str", TlsHost, none)
    RT_PROP("Port", "i64", TlsPort, none)
    RT_PROP("NegotiatedAlpn", "str", TlsNegotiatedAlpn, none)
    RT_PROP("IsOpen", "i1", TlsIsOpen, none)
    // Send methods
    RT_METHOD("Send", "i64(obj)", TlsSend)
    RT_METHOD("SendStr", "i64(str)", TlsSendStr)
    // Receive methods
    RT_METHOD("Recv", "obj(i64)", TlsRecv)
    RT_METHOD("RecvStr", "str(i64)", TlsRecvStr)
    RT_METHOD("RecvLine", "str()", TlsRecvLine)
    // Error and close
    RT_METHOD("Close", "void()", TlsClose)
RT_CLASS_END()

// Zanna.Time.DateTime - static utility class
/// @summary Reads, converts, parses, and formats Unix timestamps.
/// @details Timestamps use signed Unix seconds except `NowMs`. Component access and `Create` use
/// the host local zone; `ToISO` uses UTC, and named-zone operations use Zanna's embedded subset.
/// Parsing uses legacy numeric sentinels plus `TryParseOption`; construction likewise offers the
/// sentinel `FromParts` and the unambiguous `TryFromParts` Option form. Checked arithmetic traps on
/// signed overflow.
RT_CLASS_BEGIN("Zanna.Time.DateTime", DateTime, "obj", none)
    RT_METHOD("AddDays", "i64(i64,i64)", DateTimeAddDays)
    RT_METHOD("AddSeconds", "i64(i64,i64)", DateTimeAddSeconds)
    RT_METHOD("FromParts", "i64(i64,i64,i64,i64,i64,i64)", DateTimeCreate)
    RT_METHOD("TryFromParts", "obj<Zanna.Option>(i64,i64,i64,i64,i64,i64)", DateTimeCreateOption)
    RT_METHOD("Day", "i64(i64)", DateTimeDay)
    RT_METHOD("DayOfWeek", "i64(i64)", DateTimeDayOfWeek)
    RT_METHOD("Diff", "i64(i64,i64)", DateTimeDiff)
    RT_METHOD("Format", "str(i64,str)", DateTimeFormat)
    RT_METHOD("FormatInZone", "str(i64,obj,str)", DateTimeFormatInZone)
    RT_METHOD("Hour", "i64(i64)", DateTimeHour)
    RT_METHOD("Minute", "i64(i64)", DateTimeMinute)
    RT_METHOD("Month", "i64(i64)", DateTimeMonth)
    RT_METHOD("Now", "i64()", DateTimeNow)
    RT_METHOD("NowMs", "i64()", DateTimeNowMs)
    RT_METHOD("Second", "i64(i64)", DateTimeSecond)
    RT_METHOD("ToIso8601", "str(i64)", DateTimeToISO)
    RT_METHOD("FormatLocal", "str(i64)", DateTimeToLocal)
    RT_METHOD("ToZone", "str(i64,obj)", DateTimeToZone)
    RT_METHOD("Year", "i64(i64)", DateTimeYear)
    RT_METHOD("ParseIso8601", "i64(str)", DateTimeParseISO)
    RT_METHOD("ParseDate", "i64(str)", DateTimeParseDate)
    RT_METHOD("ParseTime", "i64(str)", DateTimeParseTime)
    RT_METHOD("TryParse", "obj<Zanna.Option>(str)", DateTimeTryParseOption)
RT_CLASS_END()

// Zanna.Time.TimeZone - deterministic IANA named-zone lookup
/// @summary Resolves Zanna's deterministic embedded IANA-zone subset.
/// @details `Find` is exact and traps for an empty or unknown name. Returned handles point at
/// process-lifetime static data. Transition coverage is deliberately limited; `OffsetAt` and
/// `IsDstAt` keep the first/last configured rules outside each zone's embedded window.
RT_CLASS_BEGIN("Zanna.Time.TimeZone", TimeZone, "obj", none)
    RT_METHOD("Find", "obj<Zanna.Time.TimeZone>(str)", TimeZoneFind)
    RT_PROP("Name", "str", TimeZoneName, none)
    RT_METHOD("OffsetAt", "i64(i64)", TimeZoneOffsetAt)
    RT_METHOD("IsDstAt", "i1(i64)", TimeZoneIsDstAt)
RT_CLASS_END()

// Zanna.Time.Duration - time interval/duration type
/// @summary Manipulates signed 64-bit millisecond duration values.
/// @details Duration is a scalar rather than a heap object. Factories and arithmetic use checked
/// signed math; component accessors use the magnitude, while total accessors preserve the sign
/// and truncate whole-unit conversions toward zero. Formatting returns owned strings.
RT_CLASS_BEGIN("Zanna.Time.Duration", Duration, "obj", none)
    // Creation
    RT_METHOD("FromMillis", "i64(i64)", DurationFromMillis)
    RT_METHOD("FromSeconds", "i64(i64)", DurationFromSeconds)
    RT_METHOD("FromMinutes", "i64(i64)", DurationFromMinutes)
    RT_METHOD("FromHours", "i64(i64)", DurationFromHours)
    RT_METHOD("FromDays", "i64(i64)", DurationFromDays)
    RT_METHOD("FromParts", "i64(i64,i64,i64,i64,i64)", DurationCreate)
    RT_METHOD("Zero", "i64()", DurationZero)
    // Total conversions
    RT_METHOD("TotalMillis", "i64(i64)", DurationTotalMillis)
    RT_METHOD("TotalSeconds", "i64(i64)", DurationTotalSeconds)
    RT_METHOD("TotalMinutes", "i64(i64)", DurationTotalMinutes)
    RT_METHOD("TotalHours", "i64(i64)", DurationTotalHours)
    RT_METHOD("TotalDays", "i64(i64)", DurationTotalDays)
    RT_METHOD("TotalSecondsF", "f64(i64)", DurationTotalSecondsF)
    // Components (properties)
    RT_PROP("Days", "i64", DurationGetDays, none)
    RT_PROP("Hours", "i64", DurationGetHours, none)
    RT_PROP("Minutes", "i64", DurationGetMinutes, none)
    RT_PROP("Seconds", "i64", DurationGetSeconds, none)
    RT_PROP("Millis", "i64", DurationGetMillis, none)
    // Operations
    RT_METHOD("Add", "i64(i64,i64)", DurationAdd)
    RT_METHOD("Sub", "i64(i64,i64)", DurationSub)
    RT_METHOD("Mul", "i64(i64,i64)", DurationMul)
    RT_METHOD("Div", "i64(i64,i64)", DurationDiv)
    RT_METHOD("Abs", "i64(i64)", DurationAbs)
    RT_METHOD("Negate", "i64(i64)", DurationNeg)
    RT_METHOD("Compare", "i64(i64,i64)", DurationCmp)
    // Formatting
    RT_METHOD("ToString", "str(i64)", DurationToString)
    RT_METHOD("ToIso8601", "str(i64)", DurationToISO)
RT_CLASS_END()

// Zanna.Time.RelativeTime - human-readable relative time formatting
/// @summary Formats timestamps and millisecond durations as compact English relative text.
/// @details Timestamp forms use fixed second/minute/hour/day/30-day-month/365-day-year buckets.
/// `FormatDuration` emits whole-second multi-unit text and discards sub-second precision. These
/// helpers are hard-coded English and are separate from the localization formatters.
RT_CLASS_BEGIN("Zanna.Time.RelativeTime", RelativeTime, "obj", none)
    RT_METHOD("Format", "str(i64)", RelTimeFormat)
    RT_METHOD("FormatFrom", "str(i64,i64)", RelTimeFormatFrom)
    RT_METHOD("FormatDuration", "str(i64)", RelTimeFormatDuration)
    RT_METHOD("FormatShort", "str(i64)", RelTimeFormatShort)
RT_CLASS_END()

// Zanna.Time.DateRange - date interval type
/// @summary Represents a normalized closed range of integer Unix seconds.
/// @details `New` swaps reversed endpoints. Containment includes both endpoints; duration queries
/// use `End - Start`. `Intersection` returns null for disjoint ranges, while `Union` returns null
/// unless the ranges overlap or are adjacent by one second.
RT_CLASS_BEGIN("Zanna.Time.DateRange", DateRange, "obj", DateRangeNew)
    RT_PROP("Start", "i64", DateRangeStart, none)
    RT_PROP("End", "i64", DateRangeEnd, none)
    RT_METHOD("Contains", "i1(i64)", DateRangeContains)
    RT_METHOD("Days", "i64()", DateRangeDays)
    RT_METHOD("Duration", "i64()", DateRangeDuration)
    RT_METHOD("Hours", "i64()", DateRangeHours)
    RT_METHOD("Intersection", "obj(obj)", DateRangeIntersection)
    RT_METHOD("Overlaps", "i1(obj)", DateRangeOverlaps)
    RT_METHOD("ToString", "str()", DateRangeToString)
    RT_METHOD("Union", "obj(obj)", DateRangeUnion)
RT_CLASS_END()

// Zanna.Text.InvariantNumberFormat - number formatting utilities
/// @summary Provides number formatting utilities.
/// @details
/// `Zanna.Text.InvariantNumberFormat` exposes a registry-backed runtime surface without requiring
/// callers to construct the class directly. Its public surface exposes operations including
/// `Bytes`, `Currency`, `Decimals`, `Ordinal`.
RT_CLASS_BEGIN("Zanna.Text.InvariantNumberFormat", InvariantNumberFormat, "obj", none)
    RT_METHOD("Bytes", "str(i64)", NumFmtBytes)
    RT_METHOD("Currency", "str(f64,str)", NumFmtCurrency)
    RT_METHOD("Decimals", "str(f64,i64)", NumFmtDecimals)
    RT_METHOD("Ordinal", "str(i64)", NumFmtOrdinal)
    RT_METHOD("Pad", "str(i64,i64)", NumFmtPad)
    RT_METHOD("Percent", "str(f64)", NumFmtPercent)
    RT_METHOD("Thousands", "str(i64,str)", NumFmtThousands)
    RT_METHOD("ToWords", "str(i64)", NumFmtToWords)
RT_CLASS_END()

/// @summary Provides Char constants and static operations for text processing workflows.
/// @details
/// `Zanna.Text.Char` is a static runtime surface and does not require an instance. Its public
/// Its public surface exposes operations including `IsIdentifierStart`, `IsIdentifierPart`,
/// `IsAlphanumeric`.
RT_CLASS_BEGIN("Zanna.Text.Char", TextChar, "none", none)
    RT_METHOD("IsIdentifierStart", "i1(str)", TextCharIsIdentStart)
    RT_METHOD("IsIdentifierPart",  "i1(str)", TextCharIsIdentPart)
    RT_METHOD("IsAlphanumeric",           "i1(str)", TextCharIsAlnum)
RT_CLASS_END()

