// File: src/il/runtime/defs/classes/foundation.def
// Purpose: Foundational runtime class declarations.
// Key invariants:
//   - Included in declaration order by src/il/runtime/runtime.def.
//   - Class blocks remain balanced within this fragment.
// Ownership/Lifetime:
//   - Declarative registry data is consumed by rtgen and X-macro tests.
//   - Generated string storage has process lifetime.
// Links: src/il/runtime/runtime.def, src/tools/rtgen/rtgen.cpp
//
//===----------------------------------------------------------------------===//

// RUNTIME CLASSES
//
// Classes define the OOP interface exposed to Zanna languages.
// Ordered alphabetically by fully-qualified class name.
//
//=============================================================================
//=============================================================================

// Zanna.Math.Bits - bit manipulation utilities
/// @summary Provides bit manipulation utilities.
/// @details
/// `Zanna.Math.Bits` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `And`, `Clear`,
/// `CountOnes`, `CountLeadingZeros`.
RT_CLASS_BEGIN("Zanna.Math.Bits", Bits, "obj", none)
    RT_METHOD("And", "i64(i64,i64)", BitsAnd)
    RT_METHOD("Clear", "i64(i64,i64)", BitsClear)
    RT_METHOD("CountOnes", "i64(i64)", BitsCount)
    RT_METHOD("CountLeadingZeros", "i64(i64)", BitsCountLeadingZeros)
    RT_METHOD("CountTrailingZeros", "i64(i64)", BitsCountTrailingZeros)
    RT_METHOD("Flip", "i64(i64)", BitsFlip)
    RT_METHOD("Get", "i1(i64,i64)", BitsGet)
    RT_METHOD("Not", "i64(i64)", BitsNot)
    RT_METHOD("Or", "i64(i64,i64)", BitsOr)
    RT_METHOD("RotateLeft", "i64(i64,i64)", BitsRotateLeft)
    RT_METHOD("RotateRight", "i64(i64,i64)", BitsRotateRight)
    RT_METHOD("Set", "i64(i64,i64)", BitsSet)
    RT_METHOD("ShiftRightLogical", "i64(i64,i64)", BitsShiftRightLogical)
    RT_METHOD("Shl", "i64(i64,i64)", BitsShl)
    RT_METHOD("Shr", "i64(i64,i64)", BitsShr)
    RT_METHOD("Swap", "i64(i64)", BitsSwap)
    RT_METHOD("Toggle", "i64(i64,i64)", BitsToggle)
    RT_METHOD("Xor", "i64(i64,i64)", BitsXor)
RT_CLASS_END()

