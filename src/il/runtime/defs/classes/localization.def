// Viper.Localization.Locale - immutable BCP-47 language tag handle
/// @summary Provides immutable BCP-47 language tag handle.
/// @details
/// Create `Viper.Localization.Locale` values through its registered constructor and use the
/// returned object with the instance members below. Its public surface exposes properties such as
/// `Language`, `Script`, `Region` and operations including `Parse`, `TryParse`, `TryParseOption`,
/// `FromParts`.
RT_CLASS_BEGIN("Viper.Localization.Locale", Locale, "obj", LocaleNew)
    RT_METHOD("Parse",     "obj(str)",         LocaleParse)
    RT_METHOD("TryParse",  "obj(str)",         LocaleTryParse)
    RT_METHOD("TryParseOption", "obj<Viper.Option>(str)", LocaleTryParseOption)
    RT_METHOD("FromParts", "obj(str,str,str)", LocaleFromParts)
    RT_METHOD("Invariant", "obj()",            LocaleInvariant)
    RT_METHOD("Equals",    "i1(obj)",          LocaleEquals)
    RT_METHOD("Fallbacks", "obj()",            LocaleFallbacks)
    RT_METHOD("ToString",  "str()",            LocaleToString)
    RT_PROP("Language", "str", LocaleLanguage, none)
    RT_PROP("Script",   "str", LocaleScript,   none)
    RT_PROP("Region",   "str", LocaleRegion,   none)
    RT_PROP("Tag",      "str", LocaleTag,      none)
RT_CLASS_END()

// Viper.Localization.LocaleInfo - static queries about a Locale
/// @summary Provides static queries about a Locale.
/// @details
/// `Viper.Localization.LocaleInfo` is a static runtime surface and does not require an instance.
/// Its public surface exposes operations including `DisplayName`, `LanguageName`, `RegionName`,
/// `TextDirection`.
RT_CLASS_BEGIN("Viper.Localization.LocaleInfo", LocaleInfo, "none", none)
    RT_METHOD("DisplayName",       "str(obj,obj)", LocInfoDisplayName)
    RT_METHOD("LanguageName",      "str(obj,obj)", LocInfoLanguageName)
    RT_METHOD("RegionName",        "str(obj,obj)", LocInfoRegionName)
    RT_METHOD("TextDirection",     "str(obj)",     LocInfoTextDirection)
    RT_METHOD("FirstDayOfWeek",    "i64(obj)",     LocInfoFirstDayOfWeek)
    RT_METHOD("IsRightToLeft",     "i1(obj)",      LocInfoIsRTL)
    RT_METHOD("MeasurementSystem", "str(obj)",     LocInfoMeasurement)
    RT_METHOD("Currency",          "str(obj)",     LocInfoCurrency)
RT_CLASS_END()

