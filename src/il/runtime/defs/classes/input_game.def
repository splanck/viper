    RT_PROP("Unknown", "i64", InputKeyUnknown, none)
    RT_PROP("A", "i64", InputKeyA, none)
    RT_PROP("B", "i64", InputKeyB, none)
    RT_PROP("C", "i64", InputKeyC, none)
    RT_PROP("D", "i64", InputKeyD, none)
