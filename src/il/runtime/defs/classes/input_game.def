// Viper.Input.Mouse - mouse input handling (static class)
/// @summary Provides mouse input handling.
/// @details
/// `Viper.Input.Mouse` is a static runtime surface and does not require an instance. Its public
/// surface exposes properties such as `RelativeMode`, `RelativeModeNative`, `ButtonLeft` and
/// operations including `X`, `Y`, `DeltaX`, `DeltaY`.
RT_CLASS_BEGIN("Viper.Input.Mouse", Mouse, "none", none)
    // Position (relative to canvas)
    RT_METHOD("X", "i64()", MouseX)
    RT_METHOD("Y", "i64()", MouseY)
    RT_METHOD("DeltaX", "i64()", MouseDeltaX)
    RT_METHOD("DeltaY", "i64()", MouseDeltaY)

    // Button state (polling)
    RT_METHOD("IsDown", "i1(i64)", MouseIsDown)
    RT_METHOD("IsUp", "i1(i64)", MouseIsUp)
    RT_METHOD("Left", "i1()", MouseLeft)
    RT_METHOD("Right", "i1()", MouseRight)
    RT_METHOD("Middle", "i1()", MouseMiddle)

    // Button events (since last poll)
    RT_METHOD("WasPressed", "i1(i64)", MouseWasPressed)
    RT_METHOD("WasReleased", "i1(i64)", MouseWasReleased)
    RT_METHOD("WasClicked", "i1(i64)", MouseWasClicked)
    RT_METHOD("WasDoubleClicked", "i1(i64)", MouseWasDoubleClicked)

    // Scroll wheel
    RT_METHOD("WheelX", "i64()", MouseWheelX)
    RT_METHOD("WheelY", "i64()", MouseWheelY)
    RT_METHOD("WheelXF", "f64()", MouseWheelXF)
    RT_METHOD("WheelYF", "f64()", MouseWheelYF)

    // Cursor control
    RT_METHOD("Show", "void()", MouseShow)
    RT_METHOD("Hide", "void()", MouseHide)
    RT_METHOD("IsHidden", "i1()", MouseIsHidden)
    RT_METHOD("Capture", "void()", MouseCapture)
    RT_METHOD("Release", "void()", MouseRelease)
    RT_METHOD("IsCaptured", "i1()", MouseIsCaptured)
    RT_METHOD("SetPos", "void(i64,i64)", MouseSetPos)

    // Relative (raw) mouse mode — FPS mouse-look. Enabling implies Capture;
    // deltas become unbounded and sub-pixel (DeltaXF/DeltaYF). RelativeModeNative
    // reports whether the platform delivers raw motion (else warp-to-center
    // fallback serves the same deltas).
    RT_METHOD("SetRelativeMode", "void(i1)", MouseSetRelativeMode)
    RT_PROP("RelativeMode", "i1", MouseGetRelativeMode, none)
    RT_PROP("RelativeModeNative", "i1", MouseGetRelativeNative, none)
    RT_METHOD("DeltaXF", "f64()", MouseDeltaXF)
    RT_METHOD("DeltaYF", "f64()", MouseDeltaYF)

    // Button constants
    RT_PROP("ButtonLeft", "i64", MouseButtonLeft, none)
    RT_PROP("ButtonRight", "i64", MouseButtonRight, none)
    RT_PROP("ButtonMiddle", "i64", MouseButtonMiddle, none)
    RT_PROP("ButtonX1", "i64", MouseButtonX1, none)
    RT_PROP("ButtonX2", "i64", MouseButtonX2, none)
RT_CLASS_END()

// Viper.Input.Pad - gamepad/controller input handling (static class)
/// @summary Provides gamepad/controller input handling.
/// @details
/// `Viper.Input.Pad` is a static runtime surface and does not require an instance. Its public
/// surface exposes properties such as `ButtonA`, `ButtonB`, `ButtonX` and operations including
/// `Count`, `IsConnected`, `Name`, `IsDown`.
RT_CLASS_BEGIN("Viper.Input.Pad", Pad, "none", none)
    // Controller enumeration
    RT_METHOD("Count", "i64()", PadCount)
    RT_METHOD("IsConnected", "i1(i64)", PadIsConnected)
    RT_METHOD("Name", "str(i64)", PadName)

    // Button state (polling)
    RT_METHOD("IsDown", "i1(i64,i64)", PadIsDown)
    RT_METHOD("IsUp", "i1(i64,i64)", PadIsUp)

    // Button events (since last poll)
    RT_METHOD("WasPressed", "i1(i64,i64)", PadWasPressed)
    RT_METHOD("WasReleased", "i1(i64,i64)", PadWasReleased)

    // Analog inputs (-1.0 to 1.0 for sticks, 0.0 to 1.0 for triggers)
    RT_METHOD("LeftX", "f64(i64)", PadLeftX)
    RT_METHOD("LeftY", "f64(i64)", PadLeftY)
    RT_METHOD("RightX", "f64(i64)", PadRightX)
    RT_METHOD("RightY", "f64(i64)", PadRightY)
    RT_METHOD("LeftTrigger", "f64(i64)", PadLeftTrigger)
    RT_METHOD("RightTrigger", "f64(i64)", PadRightTrigger)

    // Deadzone handling
    RT_METHOD("SetDeadzone", "void(f64)", PadSetDeadzone)
    RT_METHOD("GetDeadzone", "f64()", PadGetDeadzone)

    // Vibration/rumble
    RT_METHOD("Vibrate", "void(i64,f64,f64)", PadVibrate)
    RT_METHOD("StopVibration", "void(i64)", PadStopVibration)

    // Button constants (standard gamepad layout)
    RT_PROP("ButtonA", "i64", PadButtonA, none)
    RT_PROP("ButtonB", "i64", PadButtonB, none)
    RT_PROP("ButtonX", "i64", PadButtonX, none)
    RT_PROP("ButtonY", "i64", PadButtonY, none)
    RT_PROP("ButtonLeftBumper", "i64", PadButtonLB, none)
    RT_PROP("ButtonRightBumper", "i64", PadButtonRB, none)
    RT_PROP("ButtonBack", "i64", PadButtonBack, none)
    RT_PROP("ButtonStart", "i64", PadButtonStart, none)
    RT_PROP("ButtonLeftStick", "i64", PadButtonLStick, none)
    RT_PROP("ButtonRightStick", "i64", PadButtonRStick, none)
    RT_PROP("ButtonUp", "i64", PadButtonUp, none)
    RT_PROP("ButtonDown", "i64", PadButtonDown, none)
    RT_PROP("ButtonLeft", "i64", PadButtonLeft, none)
    RT_PROP("ButtonRight", "i64", PadButtonRight, none)
    RT_PROP("ButtonGuide", "i64", PadButtonGuide, none)
RT_CLASS_END()

// Viper.Input.Action - action mapping system (static class)
/// @summary Provides action mapping system.
/// @details
/// `Viper.Input.Action` is a static runtime surface and does not require an instance. Its public
/// surface exposes properties such as `AxisLeftX`, `AxisLeftY`, `AxisRightX` and operations
/// including `Clear`, `Define`, `DefineAxis`, `Exists`.
RT_CLASS_BEGIN("Viper.Input.Action", Action, "none", none)
    // Action definition
    RT_METHOD("Clear", "void()", ActionClear)
    RT_METHOD("Define", "i1(str)", ActionDefine)
    RT_METHOD("DefineAxis", "i1(str)", ActionDefineAxis)
    RT_METHOD("Exists", "i1(str)", ActionExists)
    RT_METHOD("IsAxis", "i1(str)", ActionIsAxis)
    RT_METHOD("Remove", "i1(str)", ActionRemove)

    // Keyboard bindings
    RT_METHOD("BindKey", "i1(str,i64)", ActionBindKey)
    RT_METHOD("BindKeyAxis", "i1(str,i64,f64)", ActionBindKeyAxis)
    RT_METHOD("UnbindKey", "i1(str,i64)", ActionUnbindKey)

    // Key chord/combo bindings
    RT_METHOD("BindChord", "i1(str,obj)", ActionBindChord)
    RT_METHOD("UnbindChord", "i1(str,obj)", ActionUnbindChord)
    RT_METHOD("ChordCount", "i64(str)", ActionChordCount)

    // Mouse bindings
    RT_METHOD("BindMouse", "i1(str,i64)", ActionBindMouse)
    RT_METHOD("UnbindMouse", "i1(str,i64)", ActionUnbindMouse)
    RT_METHOD("BindMouseX", "i1(str,f64)", ActionBindMouseX)
    RT_METHOD("BindMouseY", "i1(str,f64)", ActionBindMouseY)
    RT_METHOD("BindScrollX", "i1(str,f64)", ActionBindScrollX)
    RT_METHOD("BindScrollY", "i1(str,f64)", ActionBindScrollY)

    // Gamepad bindings
    RT_METHOD("BindPadButton", "i1(str,i64,i64)", ActionBindPadButton)
    RT_METHOD("UnbindPadButton", "i1(str,i64,i64)", ActionUnbindPadButton)
    RT_METHOD("BindPadAxis", "i1(str,i64,i64,f64)", ActionBindPadAxis)
    RT_METHOD("UnbindPadAxis", "i1(str,i64,i64)", ActionUnbindPadAxis)
    RT_METHOD("BindPadButtonAxis", "i1(str,i64,i64,f64)", ActionBindPadButtonAxis)

    // State queries
    RT_METHOD("Pressed", "i1(str)", ActionPressed)
    RT_METHOD("Released", "i1(str)", ActionReleased)
    RT_METHOD("Held", "i1(str)", ActionHeld)
    RT_METHOD("Strength", "f64(str)", ActionStrength)
    RT_METHOD("Axis", "f64(str)", ActionAxis)
    RT_METHOD("AxisRaw", "f64(str)", ActionAxisRaw)

    // Introspection
    RT_METHOD("List", "obj()", ActionList)
    RT_METHOD("BindingsStr", "str(str)", ActionBindingsStr)
    RT_METHOD("BindingCount", "i64(str)", ActionBindingCount)
    RT_METHOD("KeyBoundTo", "str(i64)", ActionKeyBoundTo)
    RT_METHOD("MouseBoundTo", "str(i64)", ActionMouseBoundTo)
    RT_METHOD("PadButtonBoundTo", "str(i64,i64)", ActionPadButtonBoundTo)

    // Persistence
    RT_METHOD("Save", "str()", ActionSave)
    RT_METHOD("Load", "i1(str)", ActionLoad)

    // Presets
    RT_METHOD("LoadPreset", "i1(str)", ActionLoadPreset)

    // Gamepad axis constants
    RT_PROP("AxisLeftX", "i64", ActionAxisLeftX, none)
    RT_PROP("AxisLeftY", "i64", ActionAxisLeftY, none)
    RT_PROP("AxisRightX", "i64", ActionAxisRightX, none)
    RT_PROP("AxisRightY", "i64", ActionAxisRightY, none)
    RT_PROP("AxisLeftTrigger", "i64", ActionAxisLeftTrigger, none)
    RT_PROP("AxisRightTrigger", "i64", ActionAxisRightTrigger, none)
RT_CLASS_END()

// Viper.Grid2D - 2D array container
