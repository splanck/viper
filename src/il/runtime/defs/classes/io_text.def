    RT_METHOD("Directory", "str(str)", PathDir)
    RT_METHOD("Extension", "str(str)", PathExt)
    RT_METHOD("ExeDir", "str()", PathExeDir)
    // Per-user writable data directory (created on demand):
    // %APPDATA%\<app> | ~/Library/Application Support/<app> | $XDG_DATA_HOME/<app>.
    RT_METHOD("DataDir", "str(str)", PathDataDir)
    RT_METHOD("IsAbsolute", "i1(str)", PathIsAbs)
    RT_METHOD("Join", "str(str,str)", PathJoin)
    RT_METHOD("Name", "str(str)", PathName)
    RT_METHOD("Normalize", "str(str)", PathNorm)
    RT_METHOD("Separator", "str()", PathSep)
    RT_METHOD("Stem", "str(str)", PathStem)
    RT_METHOD("WithExtension", "str(str,str)", PathWithExt)
RT_CLASS_END()

