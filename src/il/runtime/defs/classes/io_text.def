// Zanna.IO.Dir - directory operations
/// @summary Provides directory enumeration, creation, movement, and removal operations.
/// @details
/// `Zanna.IO.Dir` exposes a registry-backed runtime surface without requiring callers to construct
/// the class directly. Its public surface exposes operations including `Current`, `Dirs`,
/// `Exists`, `Entries`.
RT_CLASS_BEGIN("Zanna.IO.Dir", Dir, "obj", none)
    RT_METHOD("Current", "str()", DirCurrent)
    RT_METHOD("Dirs", "seq<str>(str)", DirDirs)
    RT_METHOD("Exists", "i1(str)", DirExists)
    RT_METHOD("Entries", "seq<str>(str)", DirEntries)
    RT_METHOD("Files", "seq<str>(str)", DirFiles)
    RT_METHOD("List", "seq<str>(str)", DirList)
    RT_METHOD("Make", "void(str)", DirMake)
    RT_METHOD("MakeAll", "void(str)", DirMakeAll)
    RT_METHOD("Move", "void(str,str)", DirMove)
    RT_METHOD("Remove", "void(str)", DirRemove)
    RT_METHOD("RemoveAll", "void(str)", DirRemoveAll)
    RT_METHOD("SetCurrent", "void(str)", DirSetCurrent)
RT_CLASS_END()

