// Zanna.IO.Stream - unified stream interface
/// @summary Provides unified stream interface.
/// @details
/// `Zanna.IO.Stream` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes properties such as `Type`,
/// `Position`, `Length` and operations including `OpenFile`, `OpenMemory`, `OpenBytes`,
/// `FromBinFile`.
RT_CLASS_BEGIN("Zanna.IO.Stream", Stream, "obj", none)
    // Static constructors
    RT_METHOD("OpenFile", "obj(str,str)", StreamOpenFile)
    RT_METHOD("OpenMemory", "obj()", StreamOpenMemory)
    RT_METHOD("OpenBytes", "obj(obj)", StreamOpenBytes)
    RT_METHOD("FromBinFile", "obj(obj)", StreamFromBinFile)
    RT_METHOD("FromMemStream", "obj(obj)", StreamFromMemStream)
    // Properties
    RT_PROP("Type", "i64", StreamGetType, none)
    RT_PROP("Position", "i64", StreamGetPos, StreamSetPos)
    RT_PROP("Length", "i64", StreamGetLen, none)
    RT_PROP("Eof", "i1", StreamIsEof, none)
    // Operations
    RT_METHOD("Read", "obj(i64)", StreamRead)
    RT_METHOD("ReadAll", "obj()", StreamReadAll)
    RT_METHOD("Write", "void(obj)", StreamWrite)
    RT_METHOD("ReadByte", "i64()", StreamReadByte)
    RT_METHOD("WriteByte", "void(i64)", StreamWriteByte)
    RT_METHOD("Flush", "void()", StreamFlush)
    RT_METHOD("Close", "void()", StreamClose)
    // Conversion
    RT_METHOD("AsBinFile", "obj<Zanna.IO.BinFile>()", StreamAsBinFile)
    RT_METHOD("AsMemStream", "obj<Zanna.IO.MemStream>()", StreamAsMemStream)
    RT_METHOD("ToBytes", "obj()", StreamToBytes)
RT_CLASS_END()

