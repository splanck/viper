//=============================================================================
// IO - ASSETS
//=============================================================================

/// @summary Provides Assets constants and static operations for filesystem and stream workflows.
/// @details
/// `Viper.IO.Assets` is a static runtime surface and does not require an instance. Its public
/// Its public surface exposes operations including `Load`, `LoadBytes`, `Exists`, `SizeBytes`.
RT_CLASS_BEGIN("Viper.IO.Assets", Assets, "none", none)
    RT_METHOD("Load",      "obj(str)",     AssetLoad)
    RT_METHOD("LoadBytes", "obj(str)",     AssetLoadBytes)
    RT_METHOD("Exists",    "i1(str)",      AssetExists)
    RT_METHOD("SizeBytes",      "i64(str)",     AssetSize)
    RT_METHOD("List",      "obj()",        AssetList)
    RT_METHOD("Mount",     "i64(str)",     AssetMount)
    RT_METHOD("Unmount",   "i64(str)",     AssetUnmount)
RT_CLASS_END()

/// @summary Provides Resolver constants and static operations for asset loading workflows.
/// @details
/// `Viper.Assets.Resolver` is a static runtime surface and does not require an instance. Its public
/// Its public surface exposes operations including `Resolve`.
RT_CLASS_BEGIN("Viper.Assets.Resolver", AssetResolver, "none", none)
    RT_METHOD("Resolve", "obj<Viper.Collections.Map>(str,str,str,str)", AssetResolverResolve)
RT_CLASS_END()

/// @summary Provides File Index constants and static operations for workspace tooling.
/// @details
/// `Viper.Workspace.FileIndex` is a static runtime surface and does not require an instance.
/// Its public surface exposes operations including `Enumerate`, `Page`, `Status`, `ShouldIgnore`.
RT_CLASS_BEGIN("Viper.Workspace.FileIndex", WorkspaceFileIndex, "none", none)
    RT_METHOD("Enumerate",    "obj<Viper.Collections.Seq>(str,str,str,i1)", WorkspaceFileIndexEnumerate)
    RT_METHOD("Page",         "obj<Viper.Collections.Map>(str,str,str,i1,i64,i64)", WorkspaceFileIndexPage)
    RT_METHOD("Status",       "obj<Viper.Collections.Map>(str,str,str,i1)", WorkspaceFileIndexStatus)
    RT_METHOD("ShouldIgnore", "i1(str,str,str)",                            WorkspaceFileIndexShouldIgnore)
RT_CLASS_END()

/// @summary Provides Workspace Watcher constants and static operations for workspace tooling.
/// @details
/// `Viper.Workspace.WorkspaceWatcher` is a static runtime surface and does not require an instance.
/// Its public surface exposes operations including `PollBatch`.
RT_CLASS_BEGIN("Viper.Workspace.WorkspaceWatcher", WorkspaceWatcher, "none", none)
    RT_METHOD("PollBatch", "obj<Viper.Collections.Seq>(obj,i64)", WorkspaceWatcherPollBatch)
RT_CLASS_END()

/// @summary Provides Manifest constants and static operations for project tooling.
/// @details
/// `Viper.Project.Manifest` is a static runtime surface and does not require an instance.
/// Its public surface exposes operations including `ParseText`, `ParseFile`.
RT_CLASS_BEGIN("Viper.Project.Manifest", ProjectManifest, "none", none)
    RT_METHOD("ParseText", "obj<Viper.Collections.Map>(str)", ProjectManifestParseText)
    RT_METHOD("ParseFile", "obj<Viper.Collections.Map>(str)", ProjectManifestParseFile)
RT_CLASS_END()

/// @summary Provides Edit constants and static operations for workspace tooling.
/// @details
/// `Viper.Workspace.Edit` is a static runtime surface and does not require an instance. Its public
/// Its public surface exposes operations including `Validate`, `Apply`, `ValidateInRoot`,
/// `ApplyInRoot`.
RT_CLASS_BEGIN("Viper.Workspace.Edit", WorkspaceEdit, "none", none)
    RT_METHOD("Validate",       "obj<Viper.Collections.Map>(obj)",     WorkspaceEditValidate)
    RT_METHOD("Apply",          "obj<Viper.Collections.Map>(obj)",     WorkspaceEditApply)
    RT_METHOD("ValidateInRoot", "obj<Viper.Collections.Map>(obj,str)", WorkspaceEditValidateInRoot)
    RT_METHOD("ApplyInRoot",    "obj<Viper.Collections.Map>(obj,str)", WorkspaceEditApplyInRoot)
RT_CLASS_END()

