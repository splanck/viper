//=============================================================================
// DIAGNOSTICS - TRAP
//=============================================================================

RT_FUNC(Trap, rt_trap_string, "Zanna.Core.Diagnostics.Trap", "void(str)")

/// @summary Provides Diagnostics functionality for core runtime services.
/// @details
/// `Zanna.Core.Diagnostics` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Assert`,
/// `AssertEq`, `AssertNeq`, `AssertEqNum`.
RT_CLASS_BEGIN("Zanna.Core.Diagnostics", CoreDiag, "obj", none)
    RT_METHOD("Assert",        "void(i1,str)",      DiagAssert)
    RT_METHOD("AssertEq",      "void(i64,i64,str)", DiagAssertEq)
    RT_METHOD("AssertNeq",     "void(i64,i64,str)", DiagAssertNeq)
    RT_METHOD("AssertEqNum",   "void(f64,f64,str)", DiagAssertEqNum)
    RT_METHOD("AssertEqStr",   "void(str,str,str)", DiagAssertEqStr)
    RT_METHOD("AssertNull",    "void(obj,str)",     DiagAssertNull)
    RT_METHOD("AssertNotNull", "void(obj,str)",     DiagAssertNotNull)
    RT_METHOD("AssertFail",    "void(str)",         DiagAssertFail)
    RT_METHOD("AssertGt",      "void(i64,i64,str)", DiagAssertGt)
    RT_METHOD("AssertLt",      "void(i64,i64,str)", DiagAssertLt)
    RT_METHOD("AssertGte",     "void(i64,i64,str)", DiagAssertGte)
    RT_METHOD("AssertLte",     "void(i64,i64,str)", DiagAssertLte)
    RT_METHOD("Trap",          "void(str)",         Trap)
RT_CLASS_END()

/// @summary Provides Diagnostics functionality for diagnostics and observability.
/// @details
/// `Zanna.Diagnostics` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `CurrentTrap`.
RT_CLASS_BEGIN("Zanna.Diagnostics", Diagnostics, "obj", none)
    RT_METHOD("CurrentTrap", "obj<Zanna.Option>()", DiagnosticsCurrentTrap)
RT_CLASS_END()

/// @summary Provides Trap Info functionality for diagnostics and observability.
/// @details
/// `Zanna.Diagnostics.TrapInfo` exposes a registry-backed runtime surface without requiring callers
/// to construct the class directly. Its public surface exposes properties such as `Kind`, `Code`,
/// `Ip`.
RT_CLASS_BEGIN("Zanna.Diagnostics.TrapInfo", TrapInfo, "obj", none)
    RT_PROP("Kind", "i64", TrapInfoKind, none)
    RT_PROP("Code", "i64", TrapInfoCode, none)
    RT_PROP("Ip", "i64", TrapInfoIp, none)
    RT_PROP("Line", "i64", TrapInfoLine, none)
    RT_PROP("KindName", "str", TrapInfoKindName, none)
    RT_PROP("Message", "str", TrapInfoMessage, none)
    RT_PROP("Location", "str", TrapInfoLocation, none)
RT_CLASS_END()

