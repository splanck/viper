/// @summary Provides Aes constants and static operations for cryptographic workflows.
/// @details
/// `Zanna.Crypto.Aes` is a static runtime surface and does not require an instance. Its public
/// Its public surface exposes operations including `EncryptAuth`, `DecryptAuth`,
/// `DecryptAuthResult`, `TryDecryptAuth`.
RT_CLASS_BEGIN("Zanna.Crypto.Aes", CryptoAes, "none", none)
    RT_METHOD("EncryptAuth", "obj<Zanna.Collections.Bytes>(obj,obj,obj)", AesEncryptAuth)
    RT_METHOD("DecryptAuth", "obj(obj,obj,obj)", AesDecryptAuth)
    RT_METHOD("DecryptAuthResult", "obj<Zanna.Result>(obj,obj,obj)", AesDecryptAuthResult)
    RT_METHOD("TryDecryptAuth", "obj<Zanna.Option>(obj,obj,obj)", AesTryDecryptAuth)
    RT_METHOD("EncryptStr", "obj<Zanna.Collections.Bytes>(str,str)",     AesEncryptStr)
    RT_METHOD("DecryptStr", "str(obj,str)",     AesDecryptStr)
    RT_METHOD("DecryptStrResult", "obj<Zanna.Result>(obj,str)", AesDecryptStrResult)
    RT_METHOD("TryDecryptStr", "obj<Zanna.Option>(obj,str)", AesTryDecryptStr)
RT_CLASS_END()

/// @summary Provides Aes constants and static operations for cryptographic workflows.
/// @details
/// `Zanna.Crypto.Legacy.Aes` is a static runtime surface and does not require an instance.
/// Its public surface exposes operations including `EncryptCbc`, `DecryptCbc`,
/// `DecryptCbcResult`, `TryDecryptCbc`.
RT_CLASS_BEGIN("Zanna.Crypto.Legacy.Aes", LegacyCryptoAes, "none", none)
    RT_METHOD("EncryptCbc", "obj(obj,obj,obj)", LegacyAesEncryptCBC)
    RT_METHOD("DecryptCbc", "obj(obj,obj,obj)", LegacyAesDecryptCBC)
    RT_METHOD("DecryptCbcResult", "obj<Zanna.Result>(obj,obj,obj)", LegacyAesDecryptCBCResult)
    RT_METHOD("TryDecryptCbc", "obj<Zanna.Option>(obj,obj,obj)", LegacyAesTryDecryptCBC)
RT_CLASS_END()

