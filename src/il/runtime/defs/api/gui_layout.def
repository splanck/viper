    RT_METHOD("SelectFolder",  "str(str,str)",         FileDialogSelectFolder)
    RT_METHOD("SelectFolderOption", "obj<Zanna.Option>(str,str)", FileDialogSelectFolderOption)
    RT_METHOD("New", "obj(i64)", FileDialogNew)
