// File: src/il/runtime/defs/api/gui_layout.def
// Purpose: GUI layout, tooling, and advanced widget runtime functions.
// Key invariants:
//   - Included in declaration order by src/il/runtime/runtime.def.
//   - Class blocks remain balanced within this fragment.
// Ownership/Lifetime:
//   - Declarative registry data is consumed by rtgen and X-macro tests.
//   - Generated string storage has process lifetime.
// Links: src/il/runtime/runtime.def, src/tools/rtgen/rtgen.cpp
//
//===----------------------------------------------------------------------===//

// GUI - LAYOUT
//=============================================================================

RT_FUNC(GuiVBoxNew,           rt_vbox_new,             "Viper.GUI.VBox.New",           "obj()")
RT_FUNC(GuiHBoxNew,           rt_hbox_new,             "Viper.GUI.HBox.New",           "obj()")
RT_FUNC(GuiContainerSetSpacing, rt_container_set_spacing, "Viper.GUI.Container.SetSpacing", "void(obj,f64)")
RT_FUNC(GuiContainerSetPadding, rt_container_set_padding, "Viper.GUI.Container.SetPadding", "void(obj,f64)")

/// @summary Provides Container functionality for graphical user interfaces.
/// @details
/// `Viper.GUI.Container` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `SetSpacing`,
/// `SetPadding`.
RT_CLASS_BEGIN("Viper.GUI.Container", GuiContainer, "obj", none)
    RT_METHOD("SetSpacing", "void(f64)", GuiContainerSetSpacing)
    RT_METHOD("SetPadding", "void(f64)", GuiContainerSetPadding)
RT_CLASS_END()

//=============================================================================
// GUI - CLIPBOARD (Phase 1)
//=============================================================================

RT_FUNC(ClipboardSetText,  rt_clipboard_set_text,  "Viper.GUI.ClipboardText.SetText",  "void(str)")
RT_FUNC(ClipboardGetText,  rt_clipboard_get_text,  "Viper.GUI.ClipboardText.GetText",  "str()")
RT_FUNC(ClipboardHasText,  rt_clipboard_has_text,  "Viper.GUI.ClipboardText.HasText",  "i1()")
RT_FUNC(ClipboardClear,    rt_clipboard_clear,     "Viper.GUI.ClipboardText.Clear",    "void()")

/// @summary Provides Clipboard Text constants and static operations for graphical user interfaces.
/// @details
/// `Viper.GUI.ClipboardText` is a static runtime surface and does not require an instance. Its
/// public surface exposes operations including `SetText`, `GetText`, `HasText`, `Clear`.
RT_CLASS_BEGIN("Viper.GUI.ClipboardText", GuiClipboardText, "none", none)
    RT_METHOD("SetText", "void(str)", ClipboardSetText)
    RT_METHOD("GetText", "str()",     ClipboardGetText)
    RT_METHOD("HasText", "i1()",     ClipboardHasText)
    RT_METHOD("Clear",   "void()",    ClipboardClear)
RT_CLASS_END()

