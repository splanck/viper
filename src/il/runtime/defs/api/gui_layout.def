RT_FUNC(ShortcutsSetEnabled,       rt_shortcuts_set_enabled,       "Viper.GUI.Shortcuts.SetEnabled",       "void(str,i1)")
RT_FUNC(ShortcutsGetGlobalEnabled, rt_shortcuts_get_global_enabled,"Viper.GUI.Shortcuts.GetGlobalEnabled", "i1()")
