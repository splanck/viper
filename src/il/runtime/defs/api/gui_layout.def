/// @summary Defines cross-axis alignment constants for GUI layout containers.
/// @details
/// `Zanna.GUI.Align` is a static typed-constant surface. Its stable values are accepted by VBox,
/// HBox, and Flex alignment methods while legacy integer values remain source-compatible.
RT_CLASS_BEGIN("Zanna.GUI.Align", GuiAlign, "none", none)
    RT_PROP("Start", "i64", GuiAlignStart, none)
    RT_PROP("Center", "i64", GuiAlignCenter, none)
    RT_PROP("End", "i64", GuiAlignEnd, none)
    RT_PROP("Stretch", "i64", GuiAlignStretch, none)
RT_CLASS_END()

/// @summary Defines main-axis distribution constants for GUI layout containers.
/// @details
/// `Zanna.GUI.Justify` names the six stable packing and free-space distribution policies accepted
/// by VBox, HBox, and Flex instead of requiring application code to embed magic integers.
RT_CLASS_BEGIN("Zanna.GUI.Justify", GuiJustify, "none", none)
    RT_PROP("Start", "i64", GuiJustifyStart, none)
    RT_PROP("Center", "i64", GuiJustifyCenter, none)
    RT_PROP("End", "i64", GuiJustifyEnd, none)
    RT_PROP("SpaceBetween", "i64", GuiJustifySpaceBetween, none)
    RT_PROP("SpaceAround", "i64", GuiJustifySpaceAround, none)
    RT_PROP("SpaceEvenly", "i64", GuiJustifySpaceEvenly, none)
RT_CLASS_END()

/// @summary Defines stable main-axis directions for Flex layout.
/// @details
/// `Zanna.GUI.FlexDirection` uses a public row/column-first ordinal order and the runtime converts
/// it explicitly to lower toolkit enums, insulating applications from internal enum layout.
RT_CLASS_BEGIN("Zanna.GUI.FlexDirection", GuiFlexDirection, "none", none)
    RT_PROP("Row", "i64", GuiFlexDirectionRow, none)
    RT_PROP("Column", "i64", GuiFlexDirectionColumn, none)
    RT_PROP("RowReverse", "i64", GuiFlexDirectionRowReverse, none)
    RT_PROP("ColumnReverse", "i64", GuiFlexDirectionColumnReverse, none)
RT_CLASS_END()

/// @summary Defines line-wrapping policies for Flex layout.
/// @details
/// `Zanna.GUI.FlexWrap` distinguishes one-line layout, forward wrapping, and reverse cross-axis
/// wrapping through stable read-only integer properties.
RT_CLASS_BEGIN("Zanna.GUI.FlexWrap", GuiFlexWrap, "none", none)
    RT_PROP("NoWrap", "i64", GuiFlexWrapNoWrap, none)
    RT_PROP("Wrap", "i64", GuiFlexWrapWrap, none)
    RT_PROP("WrapReverse", "i64", GuiFlexWrapWrapReverse, none)
RT_CLASS_END()

/// @summary Defines edge and fill placement constants for DockPanel children.
/// @details
/// `Zanna.GUI.Dock` names each public DockPanel placement. The runtime translates these zero-based
/// values to the toolkit's internal enum, whose zero value is reserved for undocked widgets.
RT_CLASS_BEGIN("Zanna.GUI.Dock", GuiDock, "none", none)
    RT_PROP("Left", "i64", GuiDockLeft, none)
    RT_PROP("Top", "i64", GuiDockTop, none)
    RT_PROP("Right", "i64", GuiDockRight, none)
    RT_PROP("Bottom", "i64", GuiDockBottom, none)
    RT_PROP("Fill", "i64", GuiDockFill, none)
RT_CLASS_END()

/// @summary Defines built-in, system-following, and custom GUI theme modes.
/// @details
/// `Zanna.GUI.ThemeMode` values are accepted by Theme.SetMode and returned by Theme.GetMode. Custom
/// identifies an installed application palette, while System follows platform appearance changes.
RT_CLASS_BEGIN("Zanna.GUI.ThemeMode", GuiThemeMode, "none", none)
    RT_PROP("Dark", "i64", GuiThemeModeDark, none)
    RT_PROP("Light", "i64", GuiThemeModeLight, none)
    RT_PROP("System", "i64", GuiThemeModeSystem, none)
    RT_PROP("Custom", "i64", GuiThemeModeCustom, none)
RT_CLASS_END()

/// @summary Defines semantic accessibility roles for GUI widgets.
/// @details
/// `Zanna.GUI.AccessibleRole` publishes the complete stable role vocabulary consumed by
/// Widget.SetAccessibleRole and emitted by accessibility snapshots and native platform adapters.
RT_CLASS_BEGIN("Zanna.GUI.AccessibleRole", GuiAccessibleRole, "none", none)
    RT_PROP("None", "i64", GuiAccessibleRoleNone, none)
    RT_PROP("Application", "i64", GuiAccessibleRoleApplication, none)
    RT_PROP("Window", "i64", GuiAccessibleRoleWindow, none)
    RT_PROP("Group", "i64", GuiAccessibleRoleGroup, none)
    RT_PROP("Label", "i64", GuiAccessibleRoleLabel, none)
    RT_PROP("Button", "i64", GuiAccessibleRoleButton, none)
    RT_PROP("CheckBox", "i64", GuiAccessibleRoleCheckBox, none)
    RT_PROP("RadioButton", "i64", GuiAccessibleRoleRadioButton, none)
    RT_PROP("TextBox", "i64", GuiAccessibleRoleTextBox, none)
    RT_PROP("SearchBox", "i64", GuiAccessibleRoleSearchBox, none)
    RT_PROP("ComboBox", "i64", GuiAccessibleRoleComboBox, none)
    RT_PROP("List", "i64", GuiAccessibleRoleList, none)
    RT_PROP("ListItem", "i64", GuiAccessibleRoleListItem, none)
    RT_PROP("Tree", "i64", GuiAccessibleRoleTree, none)
    RT_PROP("TreeItem", "i64", GuiAccessibleRoleTreeItem, none)
    RT_PROP("TabList", "i64", GuiAccessibleRoleTabList, none)
    RT_PROP("Tab", "i64", GuiAccessibleRoleTab, none)
    RT_PROP("Table", "i64", GuiAccessibleRoleTable, none)
    RT_PROP("Row", "i64", GuiAccessibleRoleRow, none)
    RT_PROP("Cell", "i64", GuiAccessibleRoleCell, none)
    RT_PROP("Slider", "i64", GuiAccessibleRoleSlider, none)
    RT_PROP("ProgressBar", "i64", GuiAccessibleRoleProgressBar, none)
    RT_PROP("Dialog", "i64", GuiAccessibleRoleDialog, none)
    RT_PROP("Alert", "i64", GuiAccessibleRoleAlert, none)
    RT_PROP("Menu", "i64", GuiAccessibleRoleMenu, none)
    RT_PROP("MenuItem", "i64", GuiAccessibleRoleMenuItem, none)
    RT_PROP("ToolBar", "i64", GuiAccessibleRoleToolBar, none)
    RT_PROP("StatusBar", "i64", GuiAccessibleRoleStatusBar, none)
    RT_PROP("Image", "i64", GuiAccessibleRoleImage, none)
    RT_PROP("Video", "i64", GuiAccessibleRoleVideo, none)
    RT_PROP("Link", "i64", GuiAccessibleRoleLink, none)
RT_CLASS_END()

/// @summary Defines accessibility live-region announcement urgency.
/// @details
/// `Zanna.GUI.LiveRegionMode` values configure automatic widget announcements and explicit
/// Accessibility.Announce calls as off, queued/polite, or interrupting/assertive.
RT_CLASS_BEGIN("Zanna.GUI.LiveRegionMode", GuiLiveRegionMode, "none", none)
    RT_PROP("Off", "i64", GuiLiveRegionModeOff, none)
    RT_PROP("Polite", "i64", GuiLiveRegionModePolite, none)
    RT_PROP("Assertive", "i64", GuiLiveRegionModeAssertive, none)
RT_CLASS_END()

/// @summary Defines semantic roles for custom message-box buttons.
/// @details
/// `Zanna.GUI.DialogButtonRole` drives localized styling, Enter/Escape behavior, and terminal
/// outcome classification without inspecting translated button labels.
RT_CLASS_BEGIN("Zanna.GUI.DialogButtonRole", GuiDialogButtonRole, "none", none)
    RT_PROP("Normal", "i64", GuiDialogButtonRoleNormal, none)
    RT_PROP("Default", "i64", GuiDialogButtonRoleDefault, none)
    RT_PROP("Cancel", "i64", GuiDialogButtonRoleCancel, none)
    RT_PROP("Destructive", "i64", GuiDialogButtonRoleDestructive, none)
    RT_PROP("Accept", "i64", GuiDialogButtonRoleAccept, none)
    RT_PROP("Reject", "i64", GuiDialogButtonRoleReject, none)
    RT_PROP("Help", "i64", GuiDialogButtonRoleHelp, none)
RT_CLASS_END()

/// @summary Defines the shared asynchronous dialog lifecycle states.
/// @details
/// `Zanna.GUI.DialogStatus` is returned by FileDialog and MessageBox status APIs. Terminal states
/// distinguish acceptance, cancellation, and operational failure while Idle permits reuse.
RT_CLASS_BEGIN("Zanna.GUI.DialogStatus", GuiDialogStatus, "none", none)
    RT_PROP("Idle", "i64", GuiDialogStatusIdle, none)
    RT_PROP("Open", "i64", GuiDialogStatusOpen, none)
    RT_PROP("Accepted", "i64", GuiDialogStatusAccepted, none)
    RT_PROP("Cancelled", "i64", GuiDialogStatusCancelled, none)
    RT_PROP("Failed", "i64", GuiDialogStatusFailed, none)
RT_CLASS_END()

/// @summary Defines deterministic and interpolated GUI image sampling modes.
/// @details
/// `Zanna.GUI.ImageFilter` values configure Image scaling as nearest-neighbour or bilinear while
/// leaving source Pixels ownership and decoded image storage unchanged.
RT_CLASS_BEGIN("Zanna.GUI.ImageFilter", GuiImageFilter, "none", none)
    RT_PROP("Nearest", "i64", GuiImageFilterNearest, none)
    RT_PROP("Bilinear", "i64", GuiImageFilterBilinear, none)
RT_CLASS_END()

/// @summary Defines normalized tabular sort directions.
/// @details
/// `Zanna.GUI.SortDirection` is returned by Grid.GetSortDirection and can represent no active sort,
/// increasing order, or decreasing order without application-owned magic integers.
RT_CLASS_BEGIN("Zanna.GUI.SortDirection", GuiSortDirection, "none", none)
    RT_PROP("None", "i64", GuiSortDirectionNone, none)
    RT_PROP("Ascending", "i64", GuiSortDirectionAscending, none)
    RT_PROP("Descending", "i64", GuiSortDirectionDescending, none)
RT_CLASS_END()

/// @summary Provides Container functionality for graphical user interfaces.
/// @details
/// `Zanna.GUI.Container` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `SetSpacing`,
/// `SetPadding`.
RT_CLASS_BEGIN("Zanna.GUI.Container", GuiContainer, "obj", none)
    RT_METHOD("SetSpacing", "void(f64)", GuiContainerSetSpacing)
    RT_METHOD("SetPadding", "void(f64)", GuiContainerSetPadding)
RT_CLASS_END()

/// @summary Provides a wrapping Flexbox-style layout container.
/// @details
/// Create `Zanna.GUI.Flex` through its registered constructor. Direction, wrap, alignment,
/// justification, gap, and padding values are validated at the runtime boundary; all distances
/// use logical units.
RT_CLASS_BEGIN("Zanna.GUI.Flex", GuiFlex, "obj", GuiFlexNew)
    RT_METHOD("SetDirection", "void(i64)", GuiFlexSetDirection)
    RT_METHOD("SetWrap", "void(i64)", GuiFlexSetWrap)
    RT_METHOD("SetAlign", "void(i64)", GuiFlexSetAlign)
    RT_METHOD("SetJustify", "void(i64)", GuiFlexSetJustify)
    RT_METHOD("SetGap", "void(f64)", GuiFlexSetGap)
    RT_METHOD("SetPadding", "void(f64)", GuiFlexSetPadding)
RT_CLASS_END()

/// @summary Provides fixed, auto/content, and fractional two-dimensional layout tracks.
/// @details
/// `Zanna.GUI.LayoutGrid` is distinct from the tabular data `Zanna.GUI.Grid`. Children must be
/// attached through `Widget.AddChild` before `Place`; invalid placement is atomic and returns
/// false. Positive track sizes are logical fixed units, zero is auto, and negative is fractional.
RT_CLASS_BEGIN("Zanna.GUI.LayoutGrid", GuiLayoutGrid, "obj", GuiLayoutGridNew)
    RT_METHOD("SetRows", "void(i64)", GuiLayoutGridSetRows)
    RT_METHOD("SetColumns", "void(i64)", GuiLayoutGridSetColumns)
    RT_METHOD("SetRowSize", "void(i64,f64)", GuiLayoutGridSetRowSize)
    RT_METHOD("SetColumnSize", "void(i64,f64)", GuiLayoutGridSetColumnSize)
    RT_METHOD("SetGap", "void(f64,f64)", GuiLayoutGridSetGap)
    RT_METHOD("SetPadding", "void(f64)", GuiLayoutGridSetPadding)
    RT_METHOD("Place", "i1(obj,i64,i64,i64,i64)", GuiLayoutGridPlace)
RT_CLASS_END()

/// @summary Provides edge-claiming DockPanel layout.
/// @details
/// `DockChild` attaches a detached widget or updates an existing direct child. Cross-parent moves,
/// invalid dock constants, and allocation failure return false without changing either tree.
RT_CLASS_BEGIN("Zanna.GUI.DockPanel", GuiDockPanel, "obj", GuiDockPanelNew)
    RT_METHOD("SetPadding", "void(f64)", GuiDockPanelSetPadding)
    RT_METHOD("SetGap", "void(f64)", GuiDockPanelSetGap)
    RT_METHOD("DockChild", "i1(obj,i64)", GuiDockPanelDockChild)
RT_CLASS_END()

