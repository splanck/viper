/// @summary Provides Message Box functionality for graphical user interfaces.
/// @details
/// Create `Zanna.GUI.MessageBox` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes operations including
/// `Info`, `Warning`, `Error`, `Question`.
RT_CLASS_BEGIN("Zanna.GUI.MessageBox", GuiMessageBox, "obj", MessageBoxNew)
    RT_METHOD("Info",     "i64(str,str)",  MessageBoxInfo)
    RT_METHOD("Warning",  "i64(str,str)",  MessageBoxWarning)
    RT_METHOD("Error",    "i64(str,str)",  MessageBoxError)
    RT_METHOD("Question", "i64(str,str)",  MessageBoxQuestion)
    RT_METHOD("Confirm",  "i64(str,str)",  MessageBoxConfirm)
    RT_METHOD("Prompt",   "str(str,str)",  MessageBoxPrompt)
    RT_METHOD("PromptOption", "obj<Zanna.Option>(str,str)", MessageBoxPromptOption)
    RT_METHOD("New", "obj(str,str,i64)", MessageBoxNew)
    RT_METHOD("NewInfo", "obj(str,str)", MessageBoxNewInfo)
    RT_METHOD("NewWarning", "obj(str,str)", MessageBoxNewWarning)
    RT_METHOD("NewError", "obj(str,str)", MessageBoxNewError)
    RT_METHOD("NewQuestion", "obj(str,str)", MessageBoxNewQuestion)
    RT_METHOD("AddButton", "void(str,i64)", MessageBoxAddButton)
    RT_METHOD("AddButtonWithRole", "void(str,i64,i64)", MessageBoxAddButtonWithRole)
    RT_METHOD("SetButtonRole", "i1(i64,i64)", MessageBoxSetButtonRole)
    RT_METHOD("SetCancelButton", "i1(i64)", MessageBoxSetCancelButton)
