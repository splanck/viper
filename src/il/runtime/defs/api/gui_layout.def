RT_FUNC(ShortcutsGetTriggered,     rt_shortcuts_get_triggered,     "Viper.GUI.Shortcuts.GetTriggered",     "str()")

/// @summary Provides Shortcuts constants and static operations for graphical user interfaces.
/// @details
/// `Viper.GUI.Shortcuts` is a static runtime surface and does not require an instance. Its public
/// surface exposes operations including `Register`, `Unregister`, `Clear`, `IsEnabled`.
RT_CLASS_BEGIN("Viper.GUI.Shortcuts", GuiShortcuts, "none", none)
    RT_METHOD("Register",          "void(str,str,str)", ShortcutsRegister)
    RT_METHOD("Unregister",        "void(str)",         ShortcutsUnregister)
    RT_METHOD("Clear",             "void()",            ShortcutsClear)
    RT_METHOD("IsEnabled",         "i1(str)",          ShortcutsIsEnabled)
    RT_METHOD("SetEnabled",        "void(str,i1)",     ShortcutsSetEnabled)
    RT_METHOD("GetGlobalEnabled",  "i1()",             ShortcutsGetGlobalEnabled)
    RT_METHOD("SetGlobalEnabled",  "void(i1)",         ShortcutsSetGlobalEnabled)
    RT_METHOD("WasTriggered",      "i1(str)",          ShortcutsWasTriggered)
    RT_METHOD("GetTriggered",      "str()",             ShortcutsGetTriggered)
RT_CLASS_END()

