//=============================================================================
// Zanna.Zia.Document — incremental document mirror sync (plan 08). The IDE
// pushes edit deltas so semantic requests avoid re-materializing the full
// buffer on every keystroke; the service keeps a per-path text mirror keyed by
// revision. SyncDelta returns i1 (0 = no baseline / malformed → caller must
// full-sync). CheckForFile runs diagnostics straight off the mirror (no text
// argument). Text is a testability accessor.
//=============================================================================

RT_FUNC(ZiaDocSyncFull,     rt_zia_doc_sync_full,          "Zanna.Zia.Document.SyncFull",     "void(str,str,i64)")
RT_FUNC(ZiaDocSyncDelta,    rt_zia_doc_sync_delta,         "Zanna.Zia.Document.SyncDelta",    "i1(str,str,i64)")
RT_FUNC(ZiaDocClose,        rt_zia_doc_close,              "Zanna.Zia.Document.Close",        "void(str)")
RT_FUNC(ZiaDocText,         rt_zia_doc_text,               "Zanna.Zia.Document.Text",         "str(str)")
RT_FUNC(ZiaDocHas,          rt_zia_doc_has,                "Zanna.Zia.Document.Has",          "i1(str)")
RT_FUNC(ZiaServiceAvailable, rt_zia_service_available,     "Zanna.Zia.Completion.IsAvailable", "i1()")
RT_FUNC(ZiaDocCheckForFile, rt_zia_check_for_file_mirror,  "Zanna.Zia.Document.CheckForFile", "str(str)")
RT_FUNC(ZiaDocBeginCheckForFile, rt_zia_doc_begin_check_for_file, "Zanna.Zia.Document.BeginCheckForFile", "obj<Zanna.Zia.SemanticJob.SemanticJobHandle>(str)")

//=============================================================================
// Zanna BASIC Language Services (Phase 4 IDE) — sync, in-process bridge over the
// BASIC frontend engines (parseAndAnalyzeBasic / BasicCompletionEngine). Result
// shapes mirror Zanna.Zia.* so the IDE controllers consume both. Exposed as one
// Zanna.Basic.LanguageService class: Zanna.* class leaf names must be unique
// (test_runtime_class_qualified_surface) and BASIC's completion + toolchain
// share a single sync engine. See ADR 0014.
//=============================================================================

