/// @summary Provides Mat 3 functionality for numeric and geometric calculations.
/// @details
/// Create `Zanna.Math.Mat3` values through its registered constructor and use the returned object
/// with the instance members below. Its public surface exposes operations including `New`,
/// `Identity`, `Zero`, `Translate`.
RT_CLASS_BEGIN("Zanna.Math.Mat3", MathMat3, "obj", Mat3New)
    RT_METHOD("New",            "obj(f64,f64,f64,f64,f64,f64,f64,f64,f64)", Mat3New)
    RT_METHOD("Identity",       "obj()",           Mat3Identity)
    RT_METHOD("Zero",           "obj()",           Mat3Zero)
    RT_METHOD("Translate",      "obj(f64,f64)",    Mat3Translate)
    RT_METHOD("Scale",          "obj(f64,f64)",    Mat3Scale)
    RT_METHOD("ScaleUniform",   "obj(f64)",        Mat3ScaleUniform)
    RT_METHOD("Rotate",         "obj(f64)",        Mat3Rotate)
    RT_METHOD("Shear",          "obj(f64,f64)",    Mat3Shear)
    RT_METHOD("Get",            "f64(obj,i64,i64)",Mat3Get)
    RT_METHOD("Row",            "obj(obj,i64)",    Mat3Row)
    RT_METHOD("Col",            "obj(obj,i64)",    Mat3Col)
    RT_METHOD("Add",            "obj(obj,obj)",    Mat3Add)
    RT_METHOD("Sub",            "obj(obj,obj)",    Mat3Sub)
    RT_METHOD("Mul",            "obj(obj,obj)",    Mat3Mul)
    RT_METHOD("MulScalar",      "obj(obj,f64)",    Mat3MulScalar)
    RT_METHOD("TransformPoint", "obj(obj,obj)",    Mat3TransformPoint)
    RT_METHOD("TransformVector",   "obj(obj,obj)",    Mat3TransformVec)
    RT_METHOD("Transpose",      "obj(obj)",        Mat3Transpose)
    RT_METHOD("Determinant",            "f64(obj)",        Mat3Det)
    RT_METHOD("Inverse",        "obj(obj)",        Mat3Inverse)
    RT_METHOD("Negate",            "obj(obj)",        Mat3Neg)
    RT_METHOD("ApproxEquals",             "i1(obj,obj,f64)", Mat3Eq)
RT_CLASS_END()

