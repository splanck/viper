RT_FUNC(RuntimeUnsafeSetTrapFields, rt_trap_fields_set, "Viper.Runtime.Unsafe.SetTrapFields", "void(i32,i32,i32)")
RT_FUNC(RuntimeUnsafeRaiseKind, rt_trap_raise_kind_nomsg, "Viper.Runtime.Unsafe.RaiseKind", "void(i32,i32,i32)")
// NOTE: rt_str_release_maybe is already registered in RuntimeSignatures.cpp
// under its C name. Use "rt_str_release_maybe" directly as the callee.


/// @summary Provides Unsafe functionality for low-level runtime services.
/// @details
/// `Viper.Runtime.Unsafe` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Retain`,
/// `Release`, `RetainStr`, `ReleaseStr`.
RT_CLASS_BEGIN("Viper.Runtime.Unsafe", RuntimeUnsafe, "obj", none)
    RT_METHOD("Retain",     "void(obj)", RuntimeUnsafeRetain)
    RT_METHOD("Release",    "i64(obj)",  RuntimeUnsafeRelease)
    RT_METHOD("RetainStr",  "void(str)", RuntimeUnsafeRetainStr)
    RT_METHOD("ReleaseStr", "i64(str)",  RuntimeUnsafeReleaseStr)
    RT_METHOD("ValueType", "obj(i64)", RuntimeUnsafeValueType)
    RT_METHOD("ValueTypeAddField", "void(obj,i64,i64,i1)", RuntimeUnsafeValueTypeAddField)
    RT_METHOD("SetThrowMsg", "void(str)", RuntimeUnsafeSetThrowMsg)
    RT_METHOD("ClearThrowMsg", "void()", RuntimeUnsafeClearThrowMsg)
    RT_METHOD("SetTrapFields", "void(i32,i32,i32)", RuntimeUnsafeSetTrapFields)
    RT_METHOD("RaiseKind", "void(i32,i32,i32)", RuntimeUnsafeRaiseKind)
RT_CLASS_END()

