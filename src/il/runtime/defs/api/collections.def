RT_FUNC(BoxI64,     rt_box_i64,     "Viper.Core.Box.I64",     "obj(i64)")
RT_FUNC(BoxF64,     rt_box_f64,     "Viper.Core.Box.F64",     "obj(f64)")
RT_FUNC(BoxI1,      rt_box_i1_bool, "Viper.Core.Box.I1",      "obj(i1)")
RT_FUNC(BoxStr,     rt_box_str,     "Viper.Core.Box.Str",     "obj(str)")
RT_FUNC(UnboxI64,   rt_unbox_i64,   "Viper.Core.Box.ToI64",   "i64(obj)")
RT_FUNC(UnboxF64,   rt_unbox_f64,   "Viper.Core.Box.ToF64",   "f64(obj)")
RT_FUNC(UnboxI1,    rt_unbox_i1,    "Viper.Core.Box.ToI1",    "i1(obj)")
RT_FUNC(UnboxStr,   rt_unbox_str,   "Viper.Core.Box.ToStr",   "str(obj)")
RT_FUNC(BoxToI64Option, rt_box_to_i64_option, "Viper.Core.Box.ToI64Option", "obj<Viper.Option>(obj)")
RT_FUNC(BoxToF64Option, rt_box_to_f64_option, "Viper.Core.Box.ToF64Option", "obj<Viper.Option>(obj)")
RT_FUNC(BoxToI1Option,  rt_box_to_i1_option,  "Viper.Core.Box.ToI1Option",  "obj<Viper.Option>(obj)")
RT_FUNC(BoxToStrOption, rt_box_to_str_option, "Viper.Core.Box.ToStrOption", "obj<Viper.Option>(obj)")
RT_FUNC(BoxType,    rt_box_type,    "Viper.Core.Box.Type",    "i64(obj)")
RT_FUNC(BoxEqI64,   rt_box_eq_i64,  "Viper.Core.Box.EqI64",   "i1(obj,i64)")
RT_FUNC(BoxEqF64,   rt_box_eq_f64,  "Viper.Core.Box.EqF64",   "i1(obj,f64)")
RT_FUNC(BoxEqStr,   rt_box_eq_str,  "Viper.Core.Box.EqStr",   "i1(obj,str)")

/// @summary Provides Box functionality for core runtime services.
/// @details
/// `Viper.Core.Box` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `I64`, `F64`,
/// `I1`, `Str`.
RT_CLASS_BEGIN("Viper.Core.Box", CoreBox, "obj", none)
    RT_METHOD("I64",       "obj(i64)",     BoxI64)
    RT_METHOD("F64",       "obj(f64)",     BoxF64)
    RT_METHOD("I1",        "obj(i1)",      BoxI1)
    RT_METHOD("Str",       "obj(str)",     BoxStr)
    RT_METHOD("ToI64",     "i64(obj)",     UnboxI64)
    RT_METHOD("ToF64",     "f64(obj)",     UnboxF64)
    RT_METHOD("ToI1",      "i1(obj)",      UnboxI1)
    RT_METHOD("ToStr",     "str(obj)",     UnboxStr)
    RT_METHOD("ToI64Option", "obj<Viper.Option>(obj)", BoxToI64Option)
    RT_METHOD("ToF64Option", "obj<Viper.Option>(obj)", BoxToF64Option)
    RT_METHOD("ToI1Option",  "obj<Viper.Option>(obj)", BoxToI1Option)
    RT_METHOD("ToStrOption", "obj<Viper.Option>(obj)", BoxToStrOption)
    RT_METHOD("Type",      "i64(obj)",     BoxType)
    RT_METHOD("EqI64",     "i1(obj,i64)",  BoxEqI64)
    RT_METHOD("EqF64",     "i1(obj,f64)",  BoxEqF64)
    RT_METHOD("EqStr",     "i1(obj,str)",  BoxEqStr)
RT_CLASS_END()


