RT_FUNC(RuntimeGcTrackedCount,   rt_gc_tracked_count,   "Viper.Runtime.GC.TrackedCount",   "i64()")
RT_FUNC(RuntimeGcTotalCollected, rt_gc_total_collected, "Viper.Runtime.GC.TotalCollected", "i64()")
RT_FUNC(RuntimeGcPassCount,      rt_gc_pass_count,      "Viper.Runtime.GC.PassCount",      "i64()")
RT_FUNC(RuntimeGcSetThreshold,   rt_gc_set_threshold,   "Viper.Runtime.GC.SetThreshold",   "void(i64)")
RT_FUNC(RuntimeGcGetThreshold,   rt_gc_get_threshold,   "Viper.Runtime.GC.GetThreshold",   "i64()")


/// @summary Provides GC functionality for low-level runtime services.
/// @details
/// `Viper.Runtime.GC` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Collect`,
/// `TrackedCount`, `TotalCollected`, `PassCount`.
RT_CLASS_BEGIN("Viper.Runtime.GC", RuntimeGC, "obj", none)
    RT_METHOD("Collect",        "i64()", RuntimeGcCollect)
    RT_METHOD("TrackedCount",   "i64()", RuntimeGcTrackedCount)
    RT_METHOD("TotalCollected", "i64()", RuntimeGcTotalCollected)
    RT_METHOD("PassCount",      "i64()", RuntimeGcPassCount)
    RT_METHOD("SetThreshold",   "void(i64)", RuntimeGcSetThreshold)
    RT_METHOD("GetThreshold",   "i64()", RuntimeGcGetThreshold)
RT_CLASS_END()

