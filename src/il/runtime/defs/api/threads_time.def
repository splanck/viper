RT_FUNC(ChannelGetIsFull,    rt_channel_get_is_full,    "Zanna.Threads.Channel.get_IsFull",    "i1(obj)")

/// @summary Provides Channel functionality for concurrent and asynchronous programs.
/// @details
/// Create `Zanna.Threads.Channel` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as `Count`,
/// `Capacity`, `IsClosed` and operations including `Send`, `TrySend`, `SendFor`, `Recv`.
RT_CLASS_BEGIN("Zanna.Threads.Channel", ThreadsChannel, "obj", ChannelNew)
    RT_METHOD("Send",    "void(obj)",    ChannelSend)
    RT_METHOD("TrySend", "i1(obj)",     ChannelTrySend)
    RT_METHOD("SendFor", "i1(obj,i64)", ChannelSendFor)
    RT_METHOD("Recv",    "obj()",        ChannelRecv)
    RT_METHOD("TryRecv", "obj<Zanna.Option>()", ChannelTryRecvOption)
    RT_METHOD("RecvFor", "obj(i64)",    ChannelRecvFor)
    RT_METHOD("Close",   "void()",       ChannelClose)
    RT_PROP("Count",      "i64", ChannelGetLen,      none)
    RT_PROP("Capacity",  "i64", ChannelGetCapacity, none)
    RT_PROP("IsClosed", "i1",  ChannelGetIsClosed, none)
    RT_PROP("IsEmpty",  "i1",  ChannelGetIsEmpty,  none)
    RT_PROP("IsFull",   "i1",  ChannelGetIsFull,   none)
RT_CLASS_END()

