RT_FUNC(ParseIsNum,    rt_parse_is_num,    "Zanna.Core.Parse.IsNum",    "i1(str)")
RT_FUNC(ParseIntRadix, rt_parse_int_radix, "Zanna.Core.Parse.IntRadix", "i64(str,i64,i64)")

/// @summary Provides Parse functionality for core runtime services.
/// @details
/// `Zanna.Core.Parse` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `TryInt`,
/// `TryDouble`, `TryBool`, `IntOr`.
RT_CLASS_BEGIN("Zanna.Core.Parse", CoreParse, "obj", none)
    RT_METHOD("TryInt",    "obj<Zanna.Option>(str)", ParseTryInt)
    RT_METHOD("TryDouble", "obj<Zanna.Option>(str)", ParseTryDouble)
    RT_METHOD("TryBool",   "obj<Zanna.Option>(str)", ParseTryBool)
    RT_METHOD("IntOr",     "i64(str,i64)",     ParseIntOr)
    RT_METHOD("DoubleOr",  "f64(str,f64)",     ParseDoubleOr)
    RT_METHOD("BoolOr",    "i1(str,i1)",       ParseBoolOr)
    RT_METHOD("IsInt",     "i1(str)",          ParseIsInt)
    RT_METHOD("IsNum",     "i1(str)",          ParseIsNum)
    RT_METHOD("IntRadix",  "i64(str,i64,i64)", ParseIntRadix)
RT_CLASS_END()

