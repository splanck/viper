RT_FUNC(PoolGetIsShutdown, rt_threadpool_get_is_shutdown,"Zanna.Threads.Pool.get_IsShutdown", "i1(obj)")

/// @summary Provides Pool functionality for concurrent and asynchronous programs.
/// @details
/// Create `Zanna.Threads.Pool` values through its registered constructor and use the returned
/// object with the instance members below. Its public surface exposes properties such as `Size`,
/// `Pending`, `Active` and operations including `Submit`, `Wait`, `WaitFor`, `Shutdown`.
RT_CLASS_BEGIN("Zanna.Threads.Pool", ThreadsPool, "obj", PoolNew)
    RT_METHOD("Submit",      "i1(obj,obj)", PoolSubmit)
    RT_METHOD("SubmitOwned", "i1(obj,obj)", PoolSubmitOwned)
    RT_METHOD("Wait",        "void()",      PoolWait)
    RT_METHOD("WaitFor",     "i1(i64)",     PoolWaitFor)
    RT_METHOD("Shutdown",    "void()",      PoolShutdown)
    RT_METHOD("ShutdownNow", "void()",      PoolShutdownNow)
    RT_PROP("Size",       "i64", PoolGetSize,       none)
    RT_PROP("Pending",    "i64", PoolGetPending,    none)
    RT_PROP("Active",     "i64", PoolGetActive,     none)
    RT_PROP("IsShutdown", "i1",  PoolGetIsShutdown, none)
RT_CLASS_END()

