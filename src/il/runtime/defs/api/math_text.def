/// @summary Provides Xml functionality for structured data processing.
/// @details
/// `Zanna.Data.Xml` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Parse`,
/// `ParseResult`, `IsValid`, `Element`.
RT_CLASS_BEGIN("Zanna.Data.Xml", DataXml, "obj", none)
    RT_METHOD("Parse",          "obj(str)",         XmlParse)
    RT_METHOD("ParseResult",    "obj<Zanna.Result>(str)", XmlParseResult)
    RT_METHOD("IsValid",        "i1(str)",          XmlIsValid)
    RT_METHOD("Element",        "obj(str)",         XmlElement)
    RT_METHOD("Text",           "obj(str)",         XmlText)
    RT_METHOD("Comment",        "obj(str)",         XmlComment)
    RT_METHOD("Cdata",          "obj(str)",         XmlCdata)
    RT_METHOD("NodeType",       "i64(obj)",         XmlNodeType)
    RT_METHOD("Tag",            "str(obj)",         XmlTag)
    RT_METHOD("Content",        "str(obj)",         XmlContent)
    RT_METHOD("TextContent",    "str(obj)",         XmlTextContent)
    RT_METHOD("Attr",           "str(obj,str)",     XmlAttr)
    RT_METHOD("HasAttr",        "i1(obj,str)",      XmlHasAttr)
    RT_METHOD("SetAttr",        "void(obj,str,str)",XmlSetAttr)
    RT_METHOD("RemoveAttr",     "i1(obj,str)",      XmlRemoveAttr)
    RT_METHOD("AttrNames",      "seq<str>(obj)",         XmlAttrNames)
    RT_METHOD("Children",       "seq<obj>(obj)",         XmlChildren)
    RT_METHOD("ChildCount",     "i64(obj)",         XmlChildCount)
    RT_METHOD("ChildAt",        "obj(obj,i64)",     XmlChildAt)
    RT_METHOD("Child",          "obj(obj,str)",     XmlChild)
    RT_METHOD("ChildrenByTag",  "seq<obj>(obj,str)",     XmlChildrenByTag)
    RT_METHOD("Append",         "void(obj,obj)",    XmlAppend)
    RT_METHOD("Insert",         "void(obj,i64,obj)",XmlInsert)
    RT_METHOD("Remove",         "i1(obj,obj)",      XmlRemove)
    RT_METHOD("RemoveAt",       "void(obj,i64)",    XmlRemoveAt)
    RT_METHOD("SetText",        "void(obj,str)",    XmlSetText)
    RT_METHOD("Parent",         "obj(obj)",         XmlParent)
    RT_METHOD("Root",           "obj(obj)",         XmlRoot)
    RT_METHOD("FindAll",        "seq<obj>(obj,str)",     XmlFindAll)
    RT_METHOD("Find",     "obj<Zanna.Option>(obj,str)", XmlFindOption)
    RT_METHOD("Format",         "str(obj)",         XmlFormat)
    RT_METHOD("FormatPretty",   "str(obj,i64)",     XmlFormatPretty)
    RT_METHOD("Escape",         "str(str)",         XmlEscape)
    RT_METHOD("Unescape",       "str(str)",         XmlUnescape)
RT_CLASS_END()

