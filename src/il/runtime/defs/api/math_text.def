RT_FUNC(WeakRefAlive,          rt_weakref_alive,   "Zanna.Memory.WeakRef.IsAlive",    "i1(obj)")
RT_FUNC(WeakRefFree,           rt_weakref_free,    "Zanna.Memory.WeakRef.Free",     "void(obj)")
RT_FUNC(WeakRefReset,          rt_weakref_reset,   "Zanna.Memory.WeakRef.Reset",    "void(obj,obj)")

/// @summary Holds a zeroing reference without keeping its managed target alive.
/// @details `New` and `Clear` accept a live managed object, array, string, or null and do not
/// retain it. `Get` atomically promotes a live target to a retained strong reference and returns
/// null after the target is freed or cleared. `Free` detaches the target and releases one owned
/// weak-reference handle; using a handle after its last reference was freed traps.
RT_CLASS_BEGIN("Zanna.Memory.WeakRef", MemoryWeakRef, "obj", WeakRefNew)
    RT_METHOD("New",   "obj<Zanna.Memory.WeakRef>(obj)", WeakRefNew)
    RT_METHOD("Get",   "obj()",       WeakRefGet)
    RT_METHOD("IsAlive", "i1()",        WeakRefAlive)
    RT_METHOD("Free",  "void()",      WeakRefFree)
    RT_METHOD("Reset", "void(obj)",   WeakRefReset)
    RT_METHOD("Get",   "obj(obj)",      WeakRefGet)
    RT_METHOD("IsAlive", "i1(obj)",       WeakRefAlive)
    RT_METHOD("Free",  "void(obj)",     WeakRefFree)
    RT_METHOD("Reset", "void(obj,obj)", WeakRefReset)
RT_CLASS_END()

