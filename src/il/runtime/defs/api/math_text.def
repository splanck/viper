RT_FUNC(SerializeParseResult,  rt_serialize_parse_result,    "Zanna.Data.Serialize.ParseResult",  "obj<Zanna.Result>(str,i64)")
RT_FUNC(SerializeFormat,       rt_serialize_format,          "Zanna.Data.Serialize.Format",       "str(obj,i64)")
RT_FUNC(SerializeFormatPretty, rt_serialize_format_pretty,   "Zanna.Data.Serialize.FormatPretty", "str(obj,i64,i64)")
RT_FUNC(SerializeIsValid,      rt_serialize_is_valid,        "Zanna.Data.Serialize.IsValid",      "i1(str,i64)")
RT_FUNC(SerializeDetect,       rt_serialize_detect,          "Zanna.Data.Serialize.Detect",       "i64(str)")
RT_FUNC(SerializeAutoParse,    rt_serialize_auto_parse,      "Zanna.Data.Serialize.AutoParse",    "obj(str)")
RT_FUNC(SerializeAutoParseResult, rt_serialize_auto_parse_result, "Zanna.Data.Serialize.AutoParseResult", "obj<Zanna.Result>(str)")
RT_FUNC(SerializeConvert,      rt_serialize_convert,         "Zanna.Data.Serialize.Convert",      "str(str,i64,i64)")
RT_FUNC(SerializeFormatName,   rt_serialize_format_name,     "Zanna.Data.Serialize.FormatName",   "str(i64)")
RT_FUNC(SerializeMimeType,     rt_serialize_mime_type,       "Zanna.Data.Serialize.MimeType",     "str(i64)")
RT_FUNC(SerializeFormatFromName, rt_serialize_format_from_name, "Zanna.Data.Serialize.FormatFromName", "i64(str)")

/// @summary Provides Serialize functionality for structured data processing.
/// @details
/// `Zanna.Data.Serialize` exposes a registry-backed runtime surface without requiring callers to
/// construct the class directly. Its public surface exposes operations including `Parse`,
/// `ParseResult`, `Format`, `FormatPretty`.
RT_CLASS_BEGIN("Zanna.Data.Serialize", DataSerialize, "obj", none)
    RT_METHOD("Parse",           "obj(str,i64)",     SerializeParse)
    RT_METHOD("ParseResult",     "obj<Zanna.Result>(str,i64)", SerializeParseResult)
    RT_METHOD("Format",          "str(obj,i64)",     SerializeFormat)
    RT_METHOD("FormatPretty",    "str(obj,i64,i64)", SerializeFormatPretty)
    RT_METHOD("IsValid",         "i1(str,i64)",      SerializeIsValid)
    RT_METHOD("Detect",          "i64(str)",         SerializeDetect)
    RT_METHOD("AutoParse",       "obj(str)",         SerializeAutoParse)
    RT_METHOD("AutoParseResult", "obj<Zanna.Result>(str)", SerializeAutoParseResult)
    RT_METHOD("Convert",         "str(str,i64,i64)", SerializeConvert)
    RT_METHOD("FormatName",      "str(i64)",         SerializeFormatName)
    RT_METHOD("MimeType",        "str(i64)",         SerializeMimeType)
    RT_METHOD("FormatFromName",  "i64(str)",         SerializeFormatFromName)
RT_CLASS_END()

