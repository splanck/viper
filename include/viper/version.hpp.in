//===----------------------------------------------------------------------===//
//
// File: include/viper/version.hpp.in
// Purpose: Define configured toolchain, source, and IL build identity.
//
// Key invariants:
//   - Release provenance is immutable and comes from configure-time metadata.
//   - Source state is exactly clean, dirty, or unknown.
//
// Ownership/Lifetime: CMake configures this template into generated/viper.
//
// Links: CMakeLists.txt, ToolchainInstallManifest.cpp
//
//===----------------------------------------------------------------------===//

#pragma once

// Toolchain (Viper) version as provided by CMake/configure_file.
#define VIPER_VERSION_STR    "@VIPER_VERSION_STR@"

// Numeric parts (derived from VIPER_VERSION_STR before any pre-release suffix)
#define VIPER_VERSION_MAJOR  @VIPER_VERSION_MAJOR@
#define VIPER_VERSION_MINOR  @VIPER_VERSION_MINOR@
#define VIPER_VERSION_PATCH  @VIPER_VERSION_PATCH@

// Optional snapshot/build metadata derived from `git describe`.
// Empty if not in a git checkout or no matching tags.
#define VIPER_SNAPSHOT_STR   "@VIPER_SNAPSHOT_STR@"

// Immutable source provenance used by release package gates and diagnostics.
#define VIPER_SOURCE_COMMIT_STR "@VIPER_SOURCE_COMMIT@"
#define VIPER_SOURCE_STATE_STR  "@VIPER_SOURCE_STATE@"

// IL/spec version (single source of truth from IL_VERSION file)
#define VIPER_IL_VERSION_STR "@VIPER_IL_VERSION_STR@"

// Runtime namespace transition flag (1 = dual-publish legacy rt_* aliases)
#define VIPER_RUNTIME_NS_DUAL @VIPER_RUNTIME_NS_DUAL_DEFINE@
