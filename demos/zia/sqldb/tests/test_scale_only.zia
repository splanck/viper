// Minimal scale test — just create 50 tables and count them
module test_scale_only;

bind Terminal = Viper.Terminal;
bind Fmt = Viper.Fmt;

bind "../executor";
bind "../types";

func main() -> Integer {
    var exec = new Executor();
    exec.init();

    var ti = 0;
    while ti < 50 {
        var r = exec.executeSql("CREATE TABLE scale_t" + Fmt.Int(ti) + " (id INTEGER, data TEXT)");
        if r.success == false {
            Terminal.Say("FAIL at table " + Fmt.Int(ti) + ": " + r.message);
            return 1;
        }
        ti = ti + 1;
    }

    var r = exec.executeSql("SHOW TABLES");
    if r.success {
        Terminal.Say("PASS: Created 50 tables, SHOW TABLES succeeded");
    } else {
        Terminal.Say("FAIL: SHOW TABLES failed: " + r.message);
        return 1;
    }

    return 0;
}
