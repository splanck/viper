// Debug scale test — track progress
module test_scale_debug;

bind Terminal = Viper.Terminal;
bind Fmt = Viper.Fmt;

bind "../executor";
bind "../types";

func main() -> Integer {
    var exec = new Executor();
    exec.init();

    // Phase 1: Create 50 tables
    var ti = 0;
    while ti < 50 {
        exec.executeSql("CREATE TABLE scale_t" + Fmt.Int(ti) + " (id INTEGER, data TEXT)");
        ti = ti + 1;
    }
    Terminal.Say("Phase 1: 50 tables created");

    // Phase 2: SHOW TABLES
    var r = exec.executeSql("SHOW TABLES");
    if r.success {
        Terminal.Say("Phase 2: SHOW TABLES succeeded, rows=" + Fmt.Int(r.rowCount()));
    } else {
        Terminal.Say("Phase 2: SHOW TABLES failed");
    }

    // Phase 3: Create big_table + bulk inserts
    exec.executeSql("CREATE TABLE big_table (id INTEGER, val INTEGER, name TEXT)");
    Terminal.Say("Phase 3a: big_table created");

    var bi = 0;
    while bi < 100 {
        var batch = "INSERT INTO big_table VALUES ";
        var bj = 0;
        while bj < 100 {
            var rowId = bi * 100 + bj;
            if bj > 0 {
                batch = batch + ", ";
            }
            batch = batch + "(" + Fmt.Int(rowId) + ", " + Fmt.Int(rowId * 7) + ", 'row" + Fmt.Int(rowId) + "')";
            bj = bj + 1;
        }
        exec.executeSql(batch);
        if bi % 10 == 0 {
            Terminal.Say("Phase 3b: batch " + Fmt.Int(bi) + "/100");
        }
        bi = bi + 1;
    }
    Terminal.Say("Phase 3c: 10000 rows inserted");

    // Phase 4: COUNT
    r = exec.executeSql("SELECT COUNT(*) FROM big_table");
    if r.success {
        Terminal.Say("Phase 4: COUNT succeeded");
    } else {
        Terminal.Say("Phase 4: COUNT failed");
    }

    Terminal.Say("ALL DONE");
    return 0;
}
